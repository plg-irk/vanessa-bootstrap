#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)  
	
	СписокНастроек = СтатистикаПоПоказателям.СписокНастроек();
	НаборКонстант = Константы.СоздатьНабор(СписокНастроек);		
	НаборКонстант.Прочитать();
	ЗаполнитьЗначенияСвойств(Объект, НаборКонстант, СписокНастроек);
	Элементы.ПозицияИдентификатораВСтатистике.Доступность = НЕ Объект.НеДобавлятьИдентификаторВСтатистику; 
	
КонецПроцедуры 

#КонецОбласти

#Область ОбработчикиСобытийКомандФормы

&НаКлиенте
Процедура Сохранить(Команда) 
	СохранитьНаСервере();    
	Закрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции     

&НаСервере
Процедура СохранитьНаСервере()  
	
	СписокНастроек = СтатистикаПоПоказателям.СписокНастроек();
	НаборКонстант = Константы.СоздатьНабор(СписокНастроек);		
	ЗаполнитьЗначенияСвойств(НаборКонстант, Объект, СписокНастроек);
	НаборКонстант.Записать();
	
КонецПроцедуры 

&НаКлиенте
Процедура ДобавлятьНомерОбластиВСтатистикуПриИзменении(Элемент)
	Элементы.ПозицияИдентификатораВСтатистике.Доступность = НЕ Объект.НеДобавлятьИдентификаторВСтатистику; 
КонецПроцедуры

#КонецОбласти

