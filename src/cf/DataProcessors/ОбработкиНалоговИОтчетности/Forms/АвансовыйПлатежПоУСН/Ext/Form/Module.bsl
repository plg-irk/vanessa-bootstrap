Процедура Пересчитать(Команда)

    КлючФоновогоЗадания = "ОбновлениеЗадачОтчетности";
    Если Объект.Организация <> Неопределено Тогда
        КлючФоновогоЗадания = КлючФоновогоЗадания + Объект.Организация.УникальныйИдентификатор();
    КонецЕсли;

    ОчиститьСообщения();
    ЕстьАктивныеФоновыеЗаданияОбновлениеЗадачОтчетности = КалендарьОтчетности.ЕстьАктивныеФоновыеЗаданияОбновлениеЗадачОтчетности(
        КлючФоновогоЗадания);
    Если ЕстьАктивныеФоновыеЗаданияОбновлениеЗадачОтчетности Тогда
        Сообщение = Новый СообщениеПользователю;
        Сообщение.Текст = "В данный момент выполняется обновление и расчет задач календаря отчетности. Повторите позже.";
        Сообщение.Сообщить();
        Возврат;
    КонецЕсли;

    ОбновитьРасчет();

