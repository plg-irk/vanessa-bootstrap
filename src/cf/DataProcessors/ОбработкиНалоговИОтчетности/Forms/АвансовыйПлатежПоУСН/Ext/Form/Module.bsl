#Область ОписаниеПеременных

&НаКлиенте
Перем СтруктураЗаписейПараметровУчета;

&НаКлиенте
Перем ВыводилисьДанныеДляБанка;

#КонецОбласти

#Область ОбработчикиСобытийФормы
///////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

    Если Не ЗначениеЗаполнено(Объект.Организация) Тогда

        Если ЗначениеЗаполнено(Параметры.Организация) Тогда
            Объект.Организация = Параметры.Организация;
        Иначе
            Организация = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнаяОрганизация");
            Если Не ЗначениеЗаполнено(Организация) Тогда
                Организация = Справочники.Организации.ПредопределеннаяОрганизация();
            КонецЕсли;
            Объект.Организация = Организация;
        КонецЕсли;

    КонецЕсли;

    Если Не ЗначениеЗаполнено(Объект.СобытиеКалендаря) Тогда
        Объект.СобытиеКалендаря = Параметры.СобытиеКалендаря;
    КонецЕсли;

    Если Не ЗначениеЗаполнено(Объект.СостояниеСобытия) Тогда

        Если ЗначениеЗаполнено(Параметры.СостояниеСобытия) Тогда

            Объект.СостояниеСобытия = Параметры.СостояниеСобытия;

        Иначе

            Объект.СостояниеСобытия = КалендарьОтчетности.ПолучитьСостояниеСобытияКалендаря(
                Объект.Организация, Объект.СобытиеКалендаря);

        КонецЕсли;

    КонецЕсли;

    ОбъектНалогообложения = РегламентированнаяОтчетностьУСН.ОбъектНалогообложенияНаДату(Объект.Организация,
        Объект.СобытиеКалендаря);
    ОбъектНалогообложенияДоходы = ОбъектНалогообложения = Перечисления.ВидыОбъектовНалогообложения.Доходы;

    ДатыСобытия = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.СобытиеКалендаря,
        "ДатаДокументаОбработкиСобытия,ДатаОкончанияСобытия,ДатаНачалаДокументов,ДатаОкончанияДокументов");

    УпрощенныйЗачетФиксированныхВзносов = РегламентированнаяОтчетностьУСН.УпрощенныйЗачетФиксированныхВзносов(
    Объект.Организация, ДатыСобытия.ДатаОкончанияСобытия);

    Если ОбъектНалогообложенияДоходы Тогда
        ВидВзаиморасчетов = Справочники.ВидыНалогов.АвансовыйПлатежПриУСН;
    Иначе
        ВидВзаиморасчетов = Справочники.ВидыНалогов.АвансовыйПлатежПриУСНРасходы;
    КонецЕсли;

    Если УпрощенныйЗачетФиксированныхВзносов И Не ОбъектНалогообложенияДоходы Тогда
        ДокументЗаписиУСНРасходыНаВзносыПодлежащиеУплатеИП
        = РегламентированнаяОтчетностьУСН.ПолучитьДокументЗаписейУСНВПериодеПоВиду(
        Объект.Организация, ДатыСобытия.ДатаДокументаОбработкиСобытия,
            Перечисления.ВидыЗаписейФормированийКУДиР.РасходыНаВзносыПодлежащиеУплатеИП);

        Если Тип("ДокументОбъект.ЗаписиУСН") = ТипЗнч(ДокументЗаписиУСНРасходыНаВзносыПодлежащиеУплатеИП) Тогда
            РасходыНаВзносыПодлежащиеУплатеИП = РегламентированнаяОтчетностьУСН.ПолучитьДокументЗаписейУСНВПериодеПоВиду(
            Объект.Организация, ДатыСобытия.ДатаДокументаОбработкиСобытия,
                Перечисления.ВидыЗаписейФормированийКУДиР.РасходыНаВзносыПодлежащиеУплатеИП).Ссылка;
            ПредставлениеРасходыНаВзносыПодлежащиеУплатеИП = Документы.ЗаписиУСН.ОписаниеДокумента(
            РасходыНаВзносыПодлежащиеУплатеИП);
            Элементы.РасходыНаВзносыПодлежащиеУплатеИП.Заголовок = ПредставлениеРасходыНаВзносыПодлежащиеУплатеИП.Наименование;
            Элементы.ГруппаРасходыНаВзносыПодлежащиеУплатеИП.Видимость = Истина;
        Иначе
            Элементы.ГруппаРасходыНаВзносыПодлежащиеУплатеИП.Видимость = Ложь;
        КонецЕсли;
    Иначе
        Элементы.ГруппаРасходыНаВзносыПодлежащиеУплатеИП.Видимость = Ложь;
    КонецЕсли;

    ДокументВзаиморасчетовСБюджетом = РегламентированнаяОтчетностьУСН.ПолучитьДокументВзаиморасчетовСБюджетом(
        Объект.Организация, ВидВзаиморасчетов, ДатыСобытия.ДатаДокументаОбработкиСобытия,
        ДатыСобытия.ДатаОкончанияСобытия, Истина);

    Элементы.ГруппаСтрокаРасчетУведомление.Видимость = Ложь;
    Элементы.ГруппаСтрокаРасчетУведомлениеПоказатели.Видимость = Ложь;

    ПолучитьДанныеОтчетности();

    Элементы.ГруппаУплатыЧерезБанкОписание.Видимость = Ложь;
    Элементы.ГруппаУплатыЧерезКассуОписание.Видимость = Ложь;
    Если ДатыСобытия.ДатаДокументаОбработкиСобытия > Дата('20200401') И ДатыСобытия.ДатаДокументаОбработкиСобытия
        < Дата('20210101') И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Организация, "ПоддержкаИП") Тогда
        Элементы.ДекорацияНалоговыйВычет.Видимость = Истина;
        Элементы.ДекорацияМинус4.Видимость = Истина;
        Элементы.СуммаНалоговыхВычетов.Видимость = Истина;
        Элементы.ДекорацияТекстОписаниеНалоговыйВычет.Видимость = Истина;
    ИначеЕсли ВзносСДоходовАП + ВзносПоЕдиномуТарифуАП > 0 Тогда
        Элементы.ДекорацияНалоговыйВычет.Видимость = Истина;
        Элементы.ДекорацияМинус4.Видимость = Истина;
        Элементы.СуммаНалоговыхВычетов.Видимость = Истина;
        Элементы.ДекорацияТекстОписаниеНалоговыйВычет2023.Видимость = ОбъектНалогообложенияДоходы;

        СобытиеВзносСДоходов = Обработки.ОбработкиНалоговИОтчетности.ПолучитьСобытиеКалендаряПоВносамИПДоходы(
        ДатыСобытия.ДатаОкончанияДокументов, Истина);

        СобытиеВзносПоЕдиномуТарифу = Обработки.ОбработкиНалоговИОтчетности.ПолучитьСобытиеКалендаряПоВносамИПДоходы(
        ДатыСобытия.ДатаОкончанияДокументов);
        Элементы.ГруппаВзносыУплаченные.Видимость = СуммаСтраховыхВзносовАП <> 0; 
        
        //сумма уплаченных взносов в шапке
        Элементы.ДекорацияМинус3.Видимость = Ложь;
        Элементы.ДекорацияСуммаСтраховыхВзносовЕН.Видимость = Ложь;
        Элементы.ДекорацияОтступ9.Видимость = Ложь;
        Элементы.СуммаСтраховыхВзносовЕН.Видимость = Ложь;
    Иначе
        Элементы.ДекорацияНалоговыйВычет.Видимость = Ложь;
        Элементы.ДекорацияМинус4.Видимость = Ложь;
        Элементы.СуммаНалоговыхВычетов.Видимость = Ложь;
        Элементы.ДекорацияТекстОписаниеНалоговыйВычет.Видимость = Ложь;
        Элементы.ГруппаВзносыУплаченные.Видимость = Ложь;
    КонецЕсли;

    ПериодЗадачиПредставление = ПредставлениеПериода(
    ДатыСобытия.ДатаНачалаДокументов, КонецДня(ДатыСобытия.ДатаОкончанияДокументов), "ФП=Истина");

    ПериодСобытия = ДатыСобытия.ДатаОкончанияСобытия;

    ПлательщикЕНП = РегламентированнаяОтчетностьУСН.ПлательщикЕНП(
    Объект.Организация, ПериодСобытия);

    ЗаписьКалендаря = Справочники.ЗаписиКалендаряПодготовкиОтчетности.ПолучитьЗаписьКалендаря(Объект.Организация,
        Объект.СобытиеКалендаря);

    ПодаетсяУведомлениеПоНалогуЗаПериод = ?(ПериодСобытия >= '20220701', Истина, Ложь);

    ЗаполнитьУведомления();
    УправлениеФормойБлокУведомление();

    ДатаДокументаОбработкиСобытия = КонецДня(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.СобытиеКалендаря,
        "ДатаДокументаОбработкиСобытия"));
    ПрименяетсяВычетЗаОнлайнКассу = ВычетыНаОнлайнКассыКлиентСервер.ВычетыПрименяются(Объект.Организация,
        ДатаДокументаОбработкиСобытия, Перечисления.ВидыНалоговУменьшаемыхНаРасходыККТ.УСН) И ОбъектНалогообложения
        = Перечисления.ВидыОбъектовНалогообложения.Доходы;
    УстановитьВидимостьБлокаВычетЗаОнлайнКассу(ПрименяетсяВычетЗаОнлайнКассу);

    Если ПрименяетсяВычетЗаОнлайнКассу Тогда
        РасходыУменьшающиеНалогККТ = СуммаРасходовККТ(ЗаписьКалендаря, ДатаДокументаОбработкиСобытия,
            Справочники.Патенты.ПустаяСсылка());
        РасходыУчтенныхВычетовНаПриобретениеККТЗаПериод = РегистрыНакопления.РасходыНаОнлайнКассыУменьшающиеНалоги.ИнформацияПоСуммамРасходовЗаПериод(
            Объект.Организация, НачалоГода(
            ДатаДокументаОбработкиСобытия),
            ДатаДокументаОбработкиСобытия, Перечисления.ВидыНалоговУменьшаемыхНаРасходыККТ.УСН);

        ИспользованныйВычет = РасходыУчтенныхВычетовНаПриобретениеККТЗаПериод.ИспользованныйВычет;
        СуммаВычетПокупкаККТ = Формат(ИспользованныйВычет, "ЧДЦ=2; ЧРГ=; ЧН=") + " р.";

    КонецЕсли;

    УправлениеФормойВычетЗаПриобретениеККТ();

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

    Если Объект.СостояниеСобытия = ПредопределенноеЗначение("Перечисление.СостоянияСобытийКалендаря.Ознакомиться") Тогда

        Элементы.СтраницаАвансовогоПлатежа.ТекущаяСтраница = Элементы.РезультатРасчета;

    ИначеЕсли Объект.СостояниеСобытия = ПредопределенноеЗначение("Перечисление.СостоянияСобытийКалендаря.Уплатить") Тогда

        Элементы.СтраницаАвансовогоПлатежа.ТекущаяСтраница = Элементы.УплатаАвансовогоПлатежа;

    Иначе

        Элементы.СтраницаАвансовогоПлатежа.ТекущаяСтраница = Элементы.ЗадачаВыполнена;

    КонецЕсли;

    НазначитьКнопкуПоУмолчаниюИУстановитьЗаголовок();

    ВыводилисьДанныеДляБанка = Ложь;

    УстановитьВидимостьИДоступностьЭлементов();  
    
    //провека начисление за 1 квартал 
    Если ПериодСобытия = '20240725' Тогда
        НачисленияКРегистрации = ПроверитьОбновитьНачислениеНалогаПоДоходамУСНПСН();

        Если НачисленияКРегистрации.Количество() > 0 Тогда

            Для Каждого Начисления Из НачисленияКРегистрации Цикл
                Если Начисления.СуммаНачисления = "нет" Тогда
                    ТекстИнформации = " отсутствует документ ""Начисление налогов""";
                Иначе
                    ТекстИнформации = " есть документ ""Начисление налогов"" на сумму - " + Начисления.СуммаНачисления;
                КонецЕсли;

                ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
                НСтр("ru='По уведомлению за 1 квартал на сумму - %1 %2  
                     |Создать/обновить его автоматически?'"), Начисления.СуммаВзаиморасчетовСБюджетом, ТекстИнформации);
                ОписаниеОповещения = Новый ОписаниеОповещения("ПриОтветеНаВопросОСозданииНачислениеНалогов",
                    ЭтотОбъект, НачисленияКРегистрации);
                Кнопки = Новый СписокЗначений;
                Кнопки.Добавить(КодВозвратаДиалога.Да, НСтр("ru='Создать автоматически'"));
                Кнопки.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru='Отмена'"));
            КонецЦикла;

            ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, Кнопки, , КодВозвратаДиалога.Да, НСтр(
                "ru='Сумма уведомления не совпадает с начислением налога'"));

        КонецЕсли;
    КонецЕсли;
    //провека начисление за 1 квартал
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

    Если ИмяСобытия = "ИзменениеСостоянияСобытияКалендаря" Тогда
        //Если использован вычет в данном налоговом периоде уменьшаем сумму использованного вычета на приобретение ККТ
        Если Объект.СостояниеСобытия = ПредопределенноеЗначение("Перечисление.СостоянияСобытийКалендаря.Заполнить")
            И ОбъектНалогообложения = ПредопределенноеЗначение("Перечисление.ВидыОбъектовНалогообложения.Доходы") Тогда
            Отказ = Ложь;
            ВернутьУменьшенныйВычетНаПриобретениеККТ(Объект.Организация, Объект.СобытиеКалендаря, Отказ);
        КонецЕсли;

        Если Параметр = Объект.СобытиеКалендаря И Источник <> ЭтотОбъект И Окно <> Неопределено И Не Окно.Основное Тогда
            Закрыть();
        КонецЕсли;
    ИначеЕсли ИмяСобытия = "Запись_УменьшениеУСННаФиксированныеВзносы" Тогда
        ОбновитьРасчет(Истина);
    ИначеЕсли ИмяСобытия = "Запись_РасходыНаКассовуюТехнику" Тогда

        РасходыУменьшающиеНалогККТ = СуммаРасходовККТ(ЗаписьКалендаря, Объект.ДатаДокументаОбработкиСобытия,
            ПредопределенноеЗначение("Справочник.Патенты.ПустаяСсылка"));

        Пересчитать(Неопределено);
        УправлениеФормойВычетЗаПриобретениеККТ();
    КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ФиксированныеСтраховыеВзносыНажатие(Элемент, СтандартнаяОбработка)

    СтандартнаяОбработка = Ложь;

    ПараметрыФормы = Новый Структура;
    ПараметрыФормы.Вставить("Организация", Объект.Организация);
    ПараметрыФормы.Вставить("ОтчетныйПериод", ДатаДокументаОбработкиСобытия);

    МинимальныйВзнос = СуммаВзносаЗаПрошлыйПериод;

    ПараметрыФормы.Вставить("МаксимальнаяСуммаВзноса", МаксимальнаяСуммаВзноса);
    ПараметрыФормы.Вставить("МинимальнаяСуммаВзноса", МинимальныйВзнос);
    ПараметрыФормы.Вставить("ВыбраннаяСуммаВзноса", СуммаВзносаДляУменьшения);
    ПараметрыФормы.Вставить("ВзносПоЕдиномуТарифу", ВзносПоЕдиномуТарифуАП);
    ПараметрыФормы.Вставить("ВзносСдоходов", ВзносСДоходовАП);
    ПараметрыФормы.Вставить("ВзносСДоходовПредыдущийГод", ВзносСДоходовПредыдущийГод);
    ПараметрыФормы.Вставить("ВзносСДоходовТекущийГод", ВзносСДоходовТекущийГод);
    ПараметрыФормы.Вставить("ПодсказкаВзносСДоходов", ПодсказкаВзносСДоходов);
    ПараметрыФормы.Вставить("ДоляДоходовПоУСН", ДоляДоходовПоУСН);
    ПараметрыФормы.Вставить("СуммаВзносаСкорректирована", СуммаВзносаСкорректирована);
    ПараметрыФормы.Вставить("ВзносыИспользованныеДляПатента", ВзносыИспользованныеДляПатента);
    ПараметрыФормы.Вставить("СобытиеВзносПоЕдиномуТарифу", СобытиеВзносПоЕдиномуТарифу);
    ПараметрыФормы.Вставить("СобытиеВзносСДоходов", СобытиеВзносСДоходов);
    ПараметрыФормы.Вставить("ОбъектНалогообложенияДоходы", ОбъектНалогообложенияДоходы);

    ОткрытьФорму("Обработка.ОбработкиНалоговИОтчетности.Форма.РасшифровкаФиксированныхВзносовУСН", ПараметрыФормы,
        ЭтотОбъект, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура СтраницыРезультатаРасчетаПриСменеСтраницы(Элемент, ТекущаяСтраница)

    Если ТекущаяСтраница.Имя = "РезультатРасчетаПредставляение" Тогда
        // Возможно необходимо перерасчет
        // пересчитаем
        ОбновитьРасчет();
    КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура СуммаДоходовЗаГодЕННажатие(Элемент, СтандартнаяОбработка)

    СтандартнаяОбработка = Ложь;

    ПериодПараметр = КалендарьОтчетностиПовтИсп.ПолучитьСтандартныйПериодДокументовДляСобытия(Объект.СобытиеКалендаря);

    ПараметрыФормы = Новый Структура;
    ПараметрыФормы.Вставить("Организация", Объект.Организация);
    ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
    ПараметрыФормы.Вставить("Период", ПериодПараметр);
