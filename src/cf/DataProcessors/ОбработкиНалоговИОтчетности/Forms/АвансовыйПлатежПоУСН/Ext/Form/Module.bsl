&НаСервере
Функция ОписаниеТаблицыНалоги()

    ТаблицаНалоги = ТаблицаНалогиДляУведомления();

    ТаблицыНалогов = Документы.УведомлениеОбИсчисленныхСуммахНалогов.ОписаниеТаблицНалогов();
    ТаблицыНалогов.ТаблицаНалоги = ТаблицаНалоги;

    АдресХранилищаТаблицыНалоги = ПоместитьВоВременноеХранилище(ТаблицыНалогов, УникальныйИдентификатор);

    Возврат АдресХранилищаТаблицыНалоги;

КонецФункции

&НаСервере
Функция ТаблицаНалогиДляУведомления() 

    ТаблицаНалоги = Документы.УведомлениеОбИсчисленныхСуммахНалогов.ОписаниеТаблицыНалогов();

    Если ОбъектНалогообложенияДоходы Тогда
        ВидВзаиморасчетов = Справочники.ВидыНалогов.АвансовыйПлатежПриУСН;
    Иначе
        ВидВзаиморасчетов = Справочники.ВидыНалогов.АвансовыйПлатежПриУСНРасходы;
    КонецЕсли;

    Если НалогДляУведомленияЧисло <> 0 Тогда
        ДатаОкончанияСобытия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.СобытиеКалендаря,
            "ДатаОкончанияСобытия");

        НоваяСтрока = ТаблицаНалоги.Добавить();
        НоваяСтрока.РегистрацияВНалоговомОргане = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Организация,
            "РегистрацияВНалоговомОргане");
        НоваяСтрока.КодПоОКТМО                  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
            НоваяСтрока.РегистрацияВНалоговомОргане, "КодПоОКТМО");
        НоваяСтрока.Налог                       = ВидВзаиморасчетов;
        НоваяСтрока.КодБК                       = Справочники.ВидыНалогов.КБК(НоваяСтрока.Налог, , );
        НоваяСтрока.СчетУчета                   = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НоваяСтрока.Налог,
            "СчетУчета");
        НоваяСтрока.Сумма = НалогДляУведомленияЧисло;
        НоваяСтрока.СрокУплаты                  = РегламентированнаяОтчетностьУСН.ОпределитьСрокПлатежаПоЕНП(
            ДатаОкончанияСобытия);
        НоваяСтрока.НачалоПериода = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.СобытиеКалендаря, "ДатаНачалаДокументов");
        НоваяСтрока.КонецПериода = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.СобытиеКалендаря, "ДатаОкончанияДокументов");

    КонецЕсли;

    Возврат ТаблицаНалоги;

КонецФункции

