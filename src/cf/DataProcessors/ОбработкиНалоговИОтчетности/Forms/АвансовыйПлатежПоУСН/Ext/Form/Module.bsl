&НаКлиенте
Процедура ФайлВыгрузкиДляКлиентБанка(Команда)

    ВыводилисьДанныеДляБанка = Истина;

    Если ВсегоКУплатеАП = "0,00 р." Тогда
        ПоказатьПредупреждение( , НСтр("ru='Сумма нулевая. Уплата не требуется.'"));
        Возврат;
    КонецЕсли;

    Если ПлатежноеПоручение.Пустая() Тогда
        ОписаниеОповещения = Новый ОписаниеОповещения("ОповещениеВыбораСчета", ЭтотОбъект, Новый Структура("Файл",
            Истина));
        РегламентированнаяОтчетностьУСНКлиент.ПолучитьБанковскийСчетДляУплатыНалога(ОписаниеОповещения,
            Объект.Организация);
        Возврат;
    КонецЕсли;
    СписокПлатежек = Новый СписокЗначений;
    СписокПлатежек.Добавить(ПлатежноеПоручение);

    ПараметрыОткрытия = Новый Структура("СписокПлатежек, БанковскийСчет", СписокПлатежек, БанковскийСчетПоУмолчанию);
   ОткрытьФорму("Обработка.КлиентБанк.Форма.Форма", ПараметрыОткрытия);

КонецПроцедуры

&НаКлиенте
Процедура РаспечататьКвитанциюДляСбербанка(Команда)

    Если ПроверитьНаличиеГосОргана("РаспечататьКвитанциюЗавершение") Тогда
        РаспечататьКвитанциюЗавершение();
    КонецЕсли;

КонецПроцедуры

