&НаСервереБезКонтекста
Функция СуммаРасходовККТ(ЗаписьКалендаря, ДатаДокументаОбработкиСобытия, Патент)
    
    РасходыУменьшающиеНалог = 0;
    
    ОрганизацияЗаписиКалендаря = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗаписьКалендаря,
                                                                           "Организация");
    
    ВидНалогов = Перечисления.ВидыНалоговУменьшаемыхНаРасходыККТ.УСН;
    РасходыУменьшающиеНалог = РегистрыНакопления.РасходыНаОнлайнКассыУменьшающиеНалоги.ЗарегистрированоВсего(ОрганизацияЗаписиКалендаря, 
                                                                                                             ДатаДокументаОбработкиСобытия, 
                                                                                                             ВидНалогов, 
                                                                                                             Неопределено);
    
    Возврат РасходыУменьшающиеНалог;
КонецФункции

&НаСервереБезКонтекста
Процедура ВернутьУменьшенныйВычетНаПриобретениеККТ(Организация, СобытиеКалендаря, Отказ)
    
    ДатаДокументаОбработкиСобытия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СобытиеКалендаря,
        "ДатаДокументаОбработкиСобытия");   
    
    ПрименяетсяВычетЗаОнлайнКассу = ВычетыНаОнлайнКассыКлиентСервер.ВычетыПрименяются(Организация, 
                                                                                      ДатаДокументаОбработкиСобытия, 
                                                                                      Перечисления.ВидыНалоговУменьшаемыхНаРасходыККТ.УСН); 
    
    Если ПрименяетсяВычетЗаОнлайнКассу Тогда
        //Определим документ расхода в движениях которого за данный налоговый период сделаем сумму проводки, которая ранее уменьшала налог равной нулю
        ОстаткиСуммВычетовНаПриобретениеККТ = РегистрыНакопления.РасходыНаОнлайнКассыУменьшающиеНалоги.ИнформацияПоСуммамРасходовЗаПериод(Организация, 
                                                                                                                                          Неопределено, 
                                                                                                                                          ДатаДокументаОбработкиСобытия, 
                                                                                                                                          Перечисления.ВидыНалоговУменьшаемыхНаРасходыККТ.УСН);

        //Обнуляем в движениях документа расхода сумму вычета за данный налоговый период                                                                                                                                
        Если ЗначениеЗаполнено(ОстаткиСуммВычетовНаПриобретениеККТ.ДокументРасхода) Тогда 
            ОбъектДокументРасхода = ОстаткиСуммВычетовНаПриобретениеККТ.ДокументРасхода.ПолучитьОбъект();
            РегистрыНакопления.РасходыНаОнлайнКассыУменьшающиеНалоги.ОтражениеПогашенияСуммыВычетаЗаПриобретениеККТ(ОбъектДокументРасхода, 
                                                                                                                    0, 
                                                                                                                    ДатаДокументаОбработкиСобытия, 
                                                                                                                    РежимЗаписиДокумента.Проведение, 
                                                                                                                    Отказ);
        КонецЕсли; 
    КонецЕсли;

КонецПроцедуры

