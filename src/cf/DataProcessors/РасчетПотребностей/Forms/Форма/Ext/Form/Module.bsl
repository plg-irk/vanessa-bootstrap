&НаКлиенте
Процедура ЗапасыСписокПриАктивизацииСтроки(Элемент)
	
	Если Элементы.ГруппаЗапасыРасшифровка.Видимость Тогда
		ПодключитьОбработчикОжидания("ВывестиРасшифровкуПотребности", 0.5, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапасыСписокИсточникПриИзменении(Элемент)
	
	Если Элементы.ЗапасыСписок.ТекущиеДанные <> Неопределено Тогда

		ОбработатьТаблицуНаСервере(
			ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьПоставщика"),
			Элементы.ЗапасыСписок.ТекущиеДанные.Источник,
			Элементы.ЗапасыСписок.ТекущаяСтрока);
			
		РассчитатьКоличествоЗаказов();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапасыСписокЗаказатьПриИзменении(Элемент)
	
	ТекСтр = Элементы.ЗапасыСписок.ТекущиеДанные;
	Если ТекСтр <> Неопределено 
		И ТекСтр.Заказать > 0  Тогда
		ТекСтр.Выбран = Истина;
	КонецЕсли;
	
	РассчитатьКоличествоЗаказов();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапасыСписокВыбранПриИзменении(Элемент)
	
	ТекСтр = Элементы.ЗапасыСписок.ТекущиеДанные;
	Если ТекСтр = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ТекСтр.Выбран Тогда
		
		Разница 		= ТекСтр.Дефицит - ТекСтр.Заказать;
		ТекСтр.Заказать = ТекСтр.Дефицит;
		ЦелоеЧисло		= НЕ ТекСтр.Весовой 
			И ТекСтр.Заказать <> Цел(ТекСтр.Заказать) 
			И СтрНачинаетсяС(Рассчитывать, РассчитыватьПоПродажам());
		
		Если ЦелоеЧисло Тогда
			
			Разница 		= Разница + (ОкруглитьПотребность(ТекСтр.Заказать) - ТекСтр.Заказать);
			ТекСтр.Заказать = ОкруглитьПотребность(ТекСтр.Заказать);
			
		КонецЕсли;
		
	Иначе
		
		ЦелоеЧисло		= Ложь;
		Разница 		= - ТекСтр.Заказать;
		ТекСтр.Заказать = 0;
		
	КонецЕсли;          
	
	Если ЗначениеЗаполнено(ТекСтр.Цена) Тогда
		ТекСтр.Сумма = ТекСтр.Заказать * ТекСтр.Цена;
		СтараяСуммаУчета = ТекСтр.СуммаУчета;
		ПересчитатьСуммуРегл(ТекСтр, ПараметрыФормы, ИтогоСумма);
	КонецЕсли;

	РассчитатьКоличествоЗаказов();
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыЗапасыРасшифровка

&НаКлиенте
Процедура ЗапасыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущаяСтрока = Элемент.ТекущиеДанные;
	Если Поле = Элементы.ЗапасыИконкаПредупреждение Тогда
		Если ТипЗнч(ТекущаяСтрока.Сообщения) <> Тип("ФиксированныйМассив") ИЛИ ТекущаяСтрока.Сообщения.Количество() = 0 Тогда
			Возврат;
		КонецЕсли; 
		Для каждого Сообщение Из ТекущаяСтрока.Сообщения Цикл
			ОбщегоНазначенияКлиент.СообщитьПользователю(Сообщение);
		КонецЦикла; 
	КонецЕсли; 	
	
КонецПроцедуры

#КонецОбласти

