
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбновитьПараметрыФормы();
	
	ДоступныЗакупки = УправлениеДоступомУНФ.ДоступноСозданиеДокументовРазделаЗакупки();
	ДоступнаПереработка = ПолучитьФункциональнуюОпцию("ПередачаСырьяВПереработку") 
		И ПравоДоступа("ИнтерактивноеПроведение", Метаданные.Документы.ОтчетПереработчика);
	ДоступноПроизводство = ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуПроизводство") 
		И УправлениеДоступомУНФ.ДоступноСозданиеДокументовРазделаПроизводство();
	ДоступноПеремещение = ПолучитьФункциональнуюОпцию("УчетПотребностиПоСкладам") 
		И УправлениеДоступомУНФ.ДоступноСозданиеДокументовРазделаСклад();

	// Способ пополнения по умолчанию
	Если Параметры.Свойство("СпособПополнения") Тогда
		
		ОтборСпособПополнения = Параметры.СпособПополнения;
		
		Если Параметры.СпособПополнения = "Закупки" Тогда
			Если ДоступнаПереработка Тогда
				ОтборСпособПополнения = СпособПополненияЗакупкаПереработка();
			Иначе
				ОтборСпособПополнения = СпособПополненияЗакупка();
			КонецЕсли;
		ИначеЕсли Параметры.СпособПополнения = "Производство" Тогда
			ОтборСпособПополнения = СпособПополненияПроизводство();
		ИначеЕсли Параметры.СпособПополнения = "Перемещение" Тогда
			Если ПолучитьФункциональнуюОпцию("УчетПотребностиПоСкладам") Тогда
				ОтборСпособПополнения = СпособПополненияПеремещение();
			Иначе
				ОтборСпособПополнения = СпособПополненияВсе();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Обработка = РеквизитФормыВЗначение("Объект");
	СхемаКомпоновкиДанных = Обработка.ПолучитьМакет("СхемаКомпоновкиДанных");
	
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, УникальныйИдентификатор);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
	КомпоновщикНастроек.Инициализировать(ИсточникНастроек);
	КомпоновщикНастроек.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
	
	МетодОбеспечения				= "MinMax";
	МетодРасчетаСтраховогоЗапаса	= "ПоПоставке";

	ЗаполнитьЗначенияСвойств(
		ДополнительныеПоляМетодаПрогноза.Добавить(),                 
		Новый Структура("Имя, ИдентификаторМетодаПрогноза", "МетодОбеспечения", РассчитыватьПоПродажам()));
	
	ЗаполнитьЗначенияСвойств(
		ДополнительныеПоляМетодаПрогноза.Добавить(),
		Новый Структура("Имя, ИдентификаторМетодаПрогноза", "СтраховойЗапас", РассчитыватьПоПродажам()));

	ЗаполнитьЗначенияСвойств(
		ДополнительныеПоляМетодаПрогноза.Добавить(),
		Новый Структура("Имя, ИдентификаторМетодаПрогноза", "МетодРасчетаСтраховогоЗапаса", РассчитыватьПоПродажам()));

	Если ЗначениеЗаполнено(Параметры.ВариантРасчетаПотребностей) Тогда
		ВосстановитьНастройкиОтборов(Параметры.ВариантРасчетаПотребностей);
	ИначеЕсли Параметры.Свойство("ЗаказНаПроизводство") Тогда
		ВосстановитьНастройкиОтборов(Параметры.ЗаказНаПроизводство, ПараметрыФормы.ЗаказПокупателя);
	ИначеЕсли Параметры.Свойство("ЗаказНаПеремещение") Тогда
		ВосстановитьНастройкиОтборов(Параметры.ЗаказНаПеремещение, ПараметрыФормы.ЗаказПокупателя);
	ИначеЕсли Параметры.Свойство("ЗаказПокупателя") Тогда
		ВосстановитьНастройкиОтборов(Параметры.ЗаказПокупателя);
	Иначе
		
		Если ЗначениеЗаполнено(ОтборСпособПополнения) Тогда
	
			СохраненныйВариантРасчетаПотребностей = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
				СтрЗаменить(ЭтаФорма.ИмяФормы, ".", ""), 
				ОтборСпособПополнения + "_ВариантРасчетаПотребностей");
			
		КонецЕсли;			

		ВосстановитьНастройкиОтборов(СохраненныйВариантРасчетаПотребностей);
		
	КонецЕсли;
	
	ПоляМетодаПрогноза = ДополнительныеПоляМетодаПрогноза.Выгрузить();
	РасчетПотребностейПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, ПоляМетодаПрогноза, Отказ, СтандартнаяОбработка);

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ПоляМетодаПрогноза, ДополнительныеПоляМетодаПрогноза);

	Элементы.ПериодичностьПланирования.СписокВыбора.Очистить();
	
	Для Каждого ИмяПеречисления Из Перечисления.Периодичность.ПустаяСсылка().Метаданные().ЗначенияПеречисления Цикл
		Элементы.ПериодичностьПланирования.СписокВыбора.Добавить(Перечисления.Периодичность[ИмяПеречисления.Имя]);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ПериодичностьПланирования)
		И Элементы.ПериодичностьПланирования.СписокВыбора.НайтиПоЗначению(ПериодичностьПланирования) = Неопределено Тогда
		Элементы.ПериодичностьПланирования.СписокВыбора.Добавить(ПериодичностьПланирования);
	КонецЕсли;
	
	Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаНадписьНетДанных;

	Элементы.ГруппаПроверкаПраваСохранениеНастроек.Видимость = ПараметрыФормы.ЕстьПравоСохраненияВариантаРасчетаПотребности;
	
	Если Параметры.СформироватьПриОткрытии Тогда
		ПараметрыФормы.РезультатФоновогоЗадания = ЗапуститьФоновоеЗаданиеНаСервере();
	КонецЕсли;
	
	// ГрупповоеИзменениеСтрок
	ЗаполнитьСписокДействий();

	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.Поставщик", Истина));
		
	Элементы.ЗапасыИзменениеСтрокЗначение.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
	
	ГрупповоеИзменениеСтрокСервер.ПриСозданииНаСервере(
		НаборЭлементовГрупповогоИзмененияСтрокСервер(), 
		ЭтотОбъект.ЗапасыИзменениеСтрокДействие);
		
	ЗапасыИзменениеСтрокДействиеПриОткрытии = ЗапасыИзменениеСтрокДействие;
	// Конец ГрупповоеИзменениеСтрок

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	НастроитьДополнительныеПоля();
	
	// ГрупповоеИзменениеСтрок
	ОпределитьОбъектИзменений();
	// Конец ГрупповоеИзменениеСтрок

	РассчитатьФоновымЗаданием(Истина);
	РассчитатьКоличествоЗаказов();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.ВариантыРасчетаПотребностей") Тогда
		
		ВариантРасчетаПотребностей = ВыбранноеЗначение;
		
		ОбновитьКомандыСпособаОбеспечения(ВыбранноеЗначение);
		УправлениеФормой();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)

	Если НавигационнаяСсылкаФорматированнойСтроки = "ОткрытьУправлениеЗапасами" Тогда
		
		СтандартнаяОбработка = Ложь;
		ОткрытьФорму("РегистрСведений.УправлениеЗапасами.ФормаСписка", , ЭтотОбъект, УникальныйИдентификатор);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если НЕ ЗавершениеРаботы Тогда
		СохранитьНастройкиОтборов();
		// ГрупповоеИзменениеСтрок
		СохранитьТекущееДействиеИзмененияСтрок();
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ЗапасыИзменениеСтрокДействиеПриИзменении(Элемент)
	
	ОпределитьОбъектИзменений();
	НастроитьОформлениеПанелиРедактирования(2);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапасыИзменениеСтрокЗначениеПриИзменении(Элемент)
	
	НастроитьОформлениеПанелиРедактирования(3);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияИнформацияПоРасчетуПотребностейОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "ЗапуститьРасчетПотребностейПоНоменклатуре" Тогда
		
		СтандартнаяОбработка 					= Ложь;
		
		ШаблонЗаголовка							= НСтр("ru='Рекомендации (%1)'");
		Номенклатура							= Элементы.ЗапасыСписок.ТекущиеДанные.Номенклатура;
		ЗаголовокПодборкиСпискаНоменклатуры     = СтрШаблон(ШаблонЗаголовка, Номенклатура);
		
		СтруктураПараметрыФормы 				= Новый Структура;
		СтруктураПараметрыФормы.Вставить("СпособПополнения", 					"Закупки");
		СтруктураПараметрыФормы.Вставить("Склад", 								Склад);
		СтруктураПараметрыФормы.Вставить("Номенклатура", 						Номенклатура);
		СтруктураПараметрыФормы.Вставить("ЗаголовокПодборкиСпискаНоменклатуры", ЗаголовокПодборкиСпискаНоменклатуры);
		
		ОткрытьФорму("Обработка.РасчетПотребностей.Форма.Форма", СтруктураПараметрыФормы, , УникальныйИдентификатор);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияИнформацияПоРасчетуПотребностейЗакрытьНажатие(Элемент)
	
	Элементы.ГруппаИнформацияПоРасчетуПотребности.Видимость = Ложь;
	СохранитьНастройкуПоказыватьИнформациюПоРасчетуПотребностей();
	
КонецПроцедуры

&НаКлиенте
Процедура РежимПриИзменении(Элемент)
	
	Если Режим = 2 И Заказы.Количество() = 0 Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Нет заказов для отображения'"), , 
			НСтр("ru = 'Сначала следует сформировать заказы на этапе планирование'"), 
			БиблиотекаКартинок.Предупреждение32, СтатусОповещенияПользователя.Информация);
		Режим = 1;
	КонецЕсли;
	
	Если Режим = 1 Тогда
		ДатаПоставки = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
		ОтметитьЗаказываемыеРекурсивно(Запасы.ПолучитьЭлементы());
		ТекущаяСтрока = Элементы.Запасы.ТекущиеДанные;
		Если ТекущаяСтрока = Неопределено ИЛИ НЕ ТекущаяСтрока.Показывать Тогда
			ТекущаяСтрока = НайтиСтрокуДереваРекурсивно(Запасы.ПолучитьЭлементы(), "Показывать", Истина);
			Если ТекущаяСтрока <> Неопределено Тогда
				Элементы.Запасы.ТекущаяСтрока = ТекущаяСтрока.ПолучитьИдентификатор();
			КонецЕсли; 
		КонецЕсли; 
	КонецЕсли; 
	
	Если НЕ Режим = 1 И ВидимостьПанелиИзменениеСтрок Тогда
		ПоказатьСкрытьПанельРедактирования(Истина);
	КонецЕсли;
	
	УправлениеФормой(Элемент.Имя);
	НастроитьДополнительныеПоля();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодичностьПланированияПриИзменении(Элемент)
	
	ПериодПоВсемПериодам	= ПериодПоДатеНачалаИДлительности(
		ДатаНачалаПланирования, 
		КоличествоДнейПланирования, 
		ПоВсемПериодам);
	
	Если ПериодичностьПланирования = ПоВсемПериодам 
		ИЛИ ПериодПланирования.ДатаОкончания = ПериодПоВсемПериодам.ДатаОкончания Тогда

		КоличествоДнейПланирования  = 1;
		ПериодПланирования 			= ПериодПоДатеНачалаИДлительности(
			ДатаНачалаПланирования, 
			КоличествоДнейПланирования, 
			ПериодичностьПланирования);
		
	Иначе
		
		ДатаОкончанияПериода		= ПериодПланирования.ДатаОкончания;
		КоличествоДнейПланирования  = 1;
	
		// +1, чтобы отловить в какой момент период выходит за пределы предыдущего, и не делать его еще больше
		ПериодПроверки				= ПериодПоДатеНачалаИДлительности(
			ДатаНачалаПланирования, 
			КоличествоДнейПланирования + 1, 
			ПериодичностьПланирования); 

		Пока ПериодПроверки.ДатаОкончания <= ДатаОкончанияПериода Цикл

			КоличествоДнейПланирования  = КоличествоДнейПланирования + 1;
			ПериодПроверки				= ПериодПоДатеНачалаИДлительности(
				ДатаНачалаПланирования, 
				КоличествоДнейПланирования + 1, 
				ПериодичностьПланирования);
		
		КонецЦикла;
	
		ПериодПланирования 			= ПериодПоДатеНачалаИДлительности(
			ДатаНачалаПланирования, 
			КоличествоДнейПланирования, 
			ПериодичностьПланирования);

	КонецЕсли;
	
	Если Не ПроизвольныйПериод Тогда
		НастроитьДополнительныеПоля(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаПланированияПриИзменении(Элемент)
	
	Если ДатаНачалаПланирования < НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса()) Тогда
		ДатаНачалаПланирования = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
	КонецЕсли;

	ПериодПланирования = ПериодПоДатеНачалаИДлительности(ДатаНачалаПланирования, КоличествоДнейПланирования, ПериодичностьПланирования);	
	
КонецПроцедуры

&НаКлиенте
Процедура КоличествоДнейПланированияПриИзменении(Элемент)
	
	ПериодПланирования = ПериодПоДатеНачалаИДлительности(ДатаНачалаПланирования, КоличествоДнейПланирования, ПериодичностьПланирования);
	
	Если Не ПроизвольныйПериод Тогда
		НастроитьДополнительныеПоля(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеПериодаПродажНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода;
	Диалог.Период = ПериодПродаж;
	
	Диалог.Показать(Новый ОписаниеОповещения("ПредставлениеПериодаПродажНажатиеЗавершение", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура ПроизвольныйПериодПриИзменении(Элемент)
	
	НастроитьДополнительныеПоля(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура КоличествоПериодовПрогнозаПриИзменении(Элемент)
	
	НастроитьДополнительныеПоля();
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитыватьПриИзменении(Элемент)

	УправлениеФормой(Элемент.Имя);
	НастроитьДополнительныеПоля();
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппировкаПриИзменении(Элемент)
	
	ГруппировкаПриИзмененииСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоЗаказамПриИзменении(Элемент)
	
	УправлениеФормой(Элемент.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборСпособПополненияПриИзменении(Элемент)
	
	ОбновитьКомандыСпособаОбеспечения();
	УправлениеФормой(Элемент.Имя);
	
	// ГрупповоеИзменениеСтрок
	ЗаполнитьСписокДействий();
	// Конец ГрупповоеИзменениеСтрок
	
КонецПроцедуры

&НаКлиенте
Процедура ПоставкаОднойДатойПриИзменении(Элемент)
	
 	ЗаказыПоставщикуРазнымиДатами = Ложь;
	УправлениеФормой(Элемент.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаПоставкиПриИзменении(Элемент)
	
	Если ДатаПоставки < НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса()) Тогда
		ДатаПоставки = НачалоДня(ОбщегоНазначенияКлиент.ДатаСеанса());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МетодОбеспеченияПриИзменении(Элемент)
	
	НастроитьДополнительныеПоля();
	
КонецПроцедуры

&НаКлиенте
