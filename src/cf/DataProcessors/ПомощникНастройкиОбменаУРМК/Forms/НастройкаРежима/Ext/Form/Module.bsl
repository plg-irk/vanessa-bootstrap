#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИнициализироватьСвойстваФормы();
	
	РазрешенРасширенныйРежимНастройки =
		ИнтеграцияУРМКПереопределяемый.РазрешенРасширенныйРежимНастройкиОбменаУРМК();
		
	Если Не РазрешенРасширенныйРежимНастройки Тогда
		ИспользоватьРасширенныйРежимНастройкиУРМК = Ложь;
		УпрощенныйРежимНастройкиУРМКПриИзмененииНаСервере();
		
	КонецЕсли;
	
	ИспользоватьРасширенныйРежимНастройкиУРМК =
		ИнтеграцияУРМКСлужебный.ИспользоватьРасширенныйРежимНастройкиУРМК();
		
	БлокировкаСнятияРасширенногоРежима = БлокировкаСнятияРасширенногоРежимаНаСервере();
		
КонецПроцедуры


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	НастроитьФорму();
		
КонецПроцедуры      

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбновлениеОтборовНаУзле" Тогда
		БлокировкаСнятияРасширенногоРежима = БлокировкаСнятияРасширенногоРежимаНаСервере();
		НастроитьФорму();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура УпрощенныйРежимНастройкиУРМКПриИзменении(Элемент)
	
	УпрощенныйРежимНастройкиУРМКПриИзмененииНаСервере();
	
	НастроитьФорму();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиНажатие(Элемент)
	
	Если Элемент.Имя = "НастройкиУРМК" Тогда
		
		ОткрытьФорму("Обработка.ПомощникНастройкиОбменаУРМК.Форма.ПомощникНастройкиОбменаДанными");
		
	ИначеЕсли Элемент.Имя = "СпособыОплаты" Тогда

		УстановитьОпцииДляРаботыПодсистемы();
		
		ТипыПлатежныхСистем = Новый Массив;
		ТипыПлатежныхСистем.Добавить(ПредопределенноеЗначение("Перечисление.ТипыСпособовОплат.СБП"));
		ТипыПлатежныхСистем.Добавить(ПредопределенноеЗначение("Перечисление.ТипыСпособовОплат.ЮKassa"));

		ТипыПлатежныхСистем = Новый ФиксированныйМассив(ТипыПлатежныхСистем);
		Отбор 				= Новый Структура("Тип", ТипыПлатежныхСистем);
		
		ОткрытьФорму("Справочник.СпособыОплаты.Форма.ФормаСписка", Новый Структура("РежимПлатежнойСистемы, Отбор", Истина, Отбор));
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УРМКНажатие(Элемент)
	ОткрытьФорму("Справочник.УниверсальныеРабочиеМестаКассиров.ФормаСписка");
КонецПроцедуры

#КонецОбласти

#Область ИнициализацияФормыПриСоздании

&НаСервере
Процедура ИнициализироватьСвойстваФормы()
	
	Заголовок = НСтр("ru = 'Режим настройки обмена с 1С:РМК, 1С:Касса, 1С:Мобильная касса'");
	ОпределенитьНомерОбласти();
	ЭтоБизнесПриложение = ВозможностиПриложения.ЭтоБизнесПриложение(НомерТекущейОбласти);
	Если ЭтоБизнесПриложение Тогда
		ИмяСлужебногоПользователя = ИмяСлужебногоПользователяОбмена(НомерТекущейОбласти);
		СлужебныйПользовательОбмена(ИмяСлужебногоПользователя);
		АдресПрограммы = АдресПубликацииПриложения(НомерТекущейОбласти);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УпрощенныйРежимНастройкиУРМКПриИзмененииНаСервере()
	
	Константы.ИспользоватьРасширенныйРежимНастройкиУРМК.Установить(ИспользоватьРасширенныйРежимНастройкиУРМК);
	
КонецПроцедуры

&НаСервере
Функция БлокировкаСнятияРасширенногоРежимаНаСервере()
	Возврат ИнтеграцияУРМКСлужебный.БлокировкаСнятияРасширенногоРежима();
КонецФункции
	
&НаСервере
Процедура УстановитьОпцииДляРаботыПодсистемы()
	ИнтеграцияСПлатежнымиСистемамиУНФ.УстановитьОпцииДляРаботыПодсистемы();
КонецПроцедуры

#Область НастройкиСинхронизацииБизнесПриложение
&НаКлиенте
Процедура НастроитьЭлементыБизнесПриложения()
	Элементы.ГруппаДанныеСлужебногоПользователя.Видимость = ЭтоБизнесПриложение; 
	УстановитьДоступностьНастроек(НЕ ЭтоБизнесПриложение);
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьНастроек(ЗначениеДоступности)
	Элементы.ГруппаНастроекРежима.Доступность = ЗначениеДоступности;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИмяСлужебногоПользователяОбмена(НомерТекущейОбласти)
			
	Возврат "Exchange_" + Формат(НомерТекущейОбласти,"ЧГ=");
	
КонецФункции

&НаСервере
Процедура ОпределенитьНомерОбласти()
	
	НомерТекущейОбласти = 0;
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		МодульРаботаВМоделиСервиса = ОбщегоНазначения.ОбщийМодуль("РаботаВМоделиСервиса");
		СеансЗапущенБезРазделителей = МодульРаботаВМоделиСервиса.СеансЗапущенБезРазделителей();
		Если НЕ СеансЗапущенБезРазделителей Тогда
			НомерТекущейОбласти = МодульРаботаВМоделиСервиса.ЗначениеРазделителяСеанса();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция АдресПубликацииПриложения(НомерТекущейОбласти)
	
	АдресПубликации = Константы.АдресПубликацииИнформационнойБазыВИнтернете.Получить();
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		МодульРаботаВМоделиСервиса = ОбщегоНазначения.ОбщийМодуль("РаботаВМоделиСервиса");
		СеансЗапущенБезРазделителей = МодульРаботаВМоделиСервиса.СеансЗапущенБезРазделителей();
		Если НЕ СеансЗапущенБезРазделителей Тогда
			Попытка
				МодульПрограммныйИнтерфейсСервиса = ОбщегоНазначения.ОбщийМодуль("ПрограммныйИнтерфейсСервиса");
				СвойстваПриложения = МодульПрограммныйИнтерфейсСервиса.СвойстваПриложения(НомерТекущейОбласти);
				АдресПубликации = СвойстваПриложения.АдресПриложения;
			Исключение
				АдресПубликации = "";
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	Возврат АдресПубликации;
	
КонецФункции

&НаСервере
Процедура СлужебныйПользовательОбмена(ИмяПользователя)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПользовательСсылка = Справочники.Пользователи.НайтиПоНаименованию(ИмяПользователя, Истина);
	
	Если НЕ ПользовательСсылка.Пустая() Тогда
		
		ИдентификаторПользователяИБ = ПользовательСсылка.ИдентификаторПользователяИБ;

		УстановитьПривилегированныйРежим(Истина);
		ПользовательОбменаИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ИдентификаторПользователяИБ);
		УстановитьПривилегированныйРежим(Ложь);
		
		Если ПользовательОбменаИБ <> Неопределено Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Пароль = НовыйПароль();
	ОписаниеПользователяИБ = Пользователи.НовоеОписаниеПользователяИБ();
	ОписаниеПользователяИБ.Имя = ИмяПользователя;
	ОписаниеПользователяИБ.ПолноеИмя = ИмяПользователя;
	ОписаниеПользователяИБ.АутентификацияСтандартная = Истина;
	ОписаниеПользователяИБ.ПоказыватьВСпискеВыбора = Ложь;
	ОписаниеПользователяИБ.Пароль = Пароль;
	ОписаниеПользователяИБ.Вставить("Действие", "Записать");
	ОписаниеПользователяИБ.Роли = Новый Массив;
	ОписаниеПользователяИБ.Роли.Добавить(Метаданные.Роли.ВыполнениеСинхронизацииДанных.Имя);
	ОписаниеПользователяИБ.Роли.Добавить(Метаданные.Роли.УдаленныйДоступБазоваяФункциональность.Имя);
	
	ИспользоватьСерверЛояльности = Константы.ИспользоватьСерверЛояльностиПоставщикДанных.Получить();
	Если ИспользоватьСерверЛояльности Тогда
		ОписатьПрофиль_СерверЛояльности(ОписаниеПользователяИБ);
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.Пользователи");
		БлокировкаДанных.Заблокировать();
		
		Если НЕ ПользовательСсылка.Пустая() Тогда
			ПользовательОбъект = ПользовательСсылка.ПолучитьОбъект();
		Иначе
			ПользовательОбъект = Справочники.Пользователи.СоздатьЭлемент();
			ПользовательОбъект.Наименование = ИмяПользователя;
			ПользовательОбъект.Недействителен = Ложь;
			ПользовательОбъект.Служебный = Истина;
		КонецЕсли;
		ПользовательОбъект.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", ОписаниеПользователяИБ);
		ПользовательОбъект.Записать();
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Ошибка создания пользователя.'", КодОсновногоЯзыка),
			УровеньЖурналаРегистрации.Ошибка,,,
			ОписаниеОшибки);
		ТекстСообщенияПользователю = ОбработкаОшибок.СообщениеОбОшибкеДляПользователя(ИнформацияОбОшибке());
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияПользователю);
		
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ОписатьПрофиль_СерверЛояльности(ОписаниеПрофиля)
	
	ОписаниеПрофиля.Роли.Добавить(Метаданные.Роли.БазовыеПраваСерверЛояльности.Имя);
	ОписаниеПрофиля.Роли.Добавить(Метаданные.Роли.БазовыеПраваПриложения.Имя);
	ОписаниеПрофиля.Роли.Добавить(Метаданные.Роли.БазовыеПраваБСП.Имя);
	ОписаниеПрофиля.Роли.Добавить(Метаданные.Роли.ЧтениеСерверЛояльности.Имя);
	ОписаниеПрофиля.Роли.Добавить(Метаданные.Роли.ДобавлениеИзменениеСерверЛояльности.Имя);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НовыйПароль()
	
	МинимальнаяДлинаПароля = ПолучитьМинимальнуюДлинуПаролейПользователей();
	Если МинимальнаяДлинаПароля <= 8 Тогда
		МинимальнаяДлинаПароля = 8;
	КонецЕсли;
	ПараметрыПароля = Пользователи.СвойстваПароля();
	Возврат Пользователи.СоздатьПароль(ПараметрыПароля);
	
КонецФункции

&НаКлиенте
Процедура СгенерироватьНовыйПароль(Команда)
	УстановитьНовыйПарольНаСервере();
КонецПроцедуры

&НаСервере
Процедура УстановитьНовыйПарольНаСервере()
	
	ПользовательСсылка = Справочники.Пользователи.НайтиПоНаименованию(ИмяСлужебногоПользователя, Истина);
	Если НЕ ПользовательСсылка.Пустая() Тогда
		НачатьТранзакцию();
		Попытка
			
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.Пользователи");
			БлокировкаДанных.Заблокировать();
			ПользовательКУдалению = ПользовательСсылка.ПолучитьОбъект();
			
			ОписаниеПользователяИБ = Пользователи.НовоеОписаниеПользователяИБ();
			ОписаниеПользователяИБ.Вставить("Действие", "Удалить");
			
			ПользовательКУдалению.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", ОписаниеПользователяИБ);
			ПользовательКУдалению.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			
			ОтменитьТранзакцию();
			ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Ошибка генерации пользователя.'", КодОсновногоЯзыка),
				УровеньЖурналаРегистрации.Ошибка,,,
				ОписаниеОшибки);
			ТекстСообщенияПользователю = ОбработкаОшибок.СообщениеОбОшибкеДляПользователя(ИнформацияОбОшибке());
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияПользователю);
			
		КонецПопытки;
	КонецЕсли;
	
	СлужебныйПользовательОбмена(ИмяСлужебногоПользователя);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанныеПользователя(Команда)
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("СохранитьФайлСДаннымиАвторизации", ЭтотОбъект);
	ПоказатьВопрос(ОповещениеОЗакрытии, НСтр("ru = 'Сохранить настройки в файл?'"),РежимДиалогаВопрос.ДаНет);
	УстановитьДоступностьНастроек(Истина);
КонецПроцедуры

&НаКлиенте
Процедура СохранитьФайлСДаннымиАвторизации(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	АдресФайла = СкачатьФайлСДаннымиАвторизацииНаСервере();
	
	Оповещение = Новый ОписаниеОповещения("СкачатьДанныеАвторизацииЗавершение", ЭтотОбъект, Новый Структура);
	Оповещение.ДополнительныеПараметры.Вставить("АдресФайла", АдресФайла);
	
	ПараметрыСохранения = ФайловаяСистемаКлиент.ПараметрыСохраненияФайла();
	ПараметрыСохранения.Диалог.Заголовок = НСтр("ru = 'Сохранить данные авторизации для 1С:РМК'");
	ПараметрыСохранения.Диалог.Фильтр = "Документ txt (*.txt)|*.txt";
	
	ФайловаяСистемаКлиент.СохранитьФайл(
		Оповещение,
		АдресФайла,
		НСтр("ru = 'Данные авторизации для РМК.txt'"),
		ПараметрыСохранения);
КонецПроцедуры
	
&НаСервере
Функция СкачатьФайлСДаннымиАвторизацииНаСервере()
	
	ИмяФайла = ПолучитьИмяВременногоФайла("txt");
	
	ДанныеАвторизацииТекст = СформироватьДокументДанныеАвторизации();
	ДанныеАвторизацииТекст.Записать(ИмяФайла);
	
	АдресФайла = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяФайла), УникальныйИдентификатор);
	
	Попытка
		УдалитьФайлы(ИмяФайла);
	Исключение
		
		ТекстОшибки = НСтр("ru = 'Ошибка удаления временного файла по причине:'") + Символы.ПС 
			+ ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
	Возврат АдресФайла;
	
КонецФункции

&НаСервере
Функция СформироватьДокументДанныеАвторизации()
	
	ТекстЗаголовка = НСтр("ru = 'Данные для авторизации при подключении программы 1С:РМК к приложению.'");
	
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(ТекстЗаголовка);
	ТекстовыйДокумент.ДобавитьСтроку("Адрес программы: " + АдресПрограммы);
	ТекстовыйДокумент.ДобавитьСтроку("Пользователь: " + ИмяСлужебногоПользователя);
	
	Если ЗначениеЗаполнено(Пароль) Тогда
		ТекстовыйДокумент.ДобавитьСтроку("Пароль: " + Пароль);
	Иначе
		ТекстовыйДокумент.ДобавитьСтроку("Пароль: <пароль установлен ранее> - если не помните, то установите новый пароль.");
	КонецЕсли;
	
	Возврат ТекстовыйДокумент;
	
КонецФункции

&НаКлиенте
Процедура СкачатьДанныеАвторизацииЗавершение(ПолученныеФайлы, ДополнительныеПараметры) Экспорт
	
	УдалитьИзВременногоХранилища(ДополнительныеПараметры.АдресФайла);
	
	Если ПолученныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОповещениеОткрытияФайла = Новый ОписаниеОповещения(
		"ФайлДанныеАвторизацииСохраненЗавершение",
		ЭтотОбъект,
		Новый Структура("ПутьКФайлу",  ПолученныеФайлы[0].ПолноеИмя));
	
	ПоказатьОповещениеПользователя(
		НСтр("ru = 'Файл успешно сохранен'"),
		ОповещениеОткрытияФайла,
		ПолученныеФайлы[0].ПолноеИмя,
		БиблиотекаКартинок["Информация32"]);
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлДанныеАвторизацииСохраненЗавершение(ДополнительныеПараметры) Экспорт
	
	ФайловаяСистемаКлиент.ОткрытьФайл(ДополнительныеПараметры.ПутьКФайлу);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область ОбщиеПроцедурыИФункции

&НаКлиенте
Процедура НастроитьФорму()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПолеФлажкаРасширенныйРежим",
		"Доступность",
		 Не БлокировкаСнятияРасширенногоРежима);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Прочее",
		"Видимость",
		ИспользоватьРасширенныйРежимНастройкиУРМК);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ГруппаДекорацияКомментарийДоступности",
		"Видимость",
		БлокировкаСнятияРасширенногоРежима);

	КомментарийДоступности =
		НСтр("ru = 'Отключение расширенного режима настройки недоступно, потому что:
		|- существуют Универсальные рабочие места с двумя подключенными кассами ККМ.'");

	Если БлокировкаСнятияРасширенногоРежима Тогда
		Элементы.ДекорацияКомментарийДоступности.Подсказка = КомментарийДоступности;
	КонецЕсли;
	
	НастроитьЭлементыБизнесПриложения();

КонецПроцедуры

&НаКлиенте
Процедура ДекорацияКомментарийДоступностиНажатие(Элемент)
	
	ТекстСообщения = Элемент.Подсказка;
	ПоказатьПредупреждение(, ТекстСообщения);

КонецПроцедуры

#КонецОбласти
