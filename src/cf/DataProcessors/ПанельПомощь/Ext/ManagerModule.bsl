#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// Возвращает результаты поиска на ИТС
//	Параметры:
//		ТекстВопроса - Строка
//	Возвращаемое значение:
//		Структура
//
Функция ВыполнитьПоиск(ТекстВопроса) Экспорт
	
	АдресAPI = ОбщегоНазначенияКлиентСервер.СтруктураURI("https://its.1c.ru/db/search/api");
	
	Если ОбщегоНазначенияУНФ.ЭтоУНФ() Тогда		
		КлючAPI = "{A2E0AD4A-3B79-4AE9-B0F1-277D3A7FD5C6}";
	Иначе
		КлючAPI = "{12DCD9FF-A49A-4946-9697-059F71D0AE30}";
	КонецЕсли;
	
	НомерЗапроса = Строка(Новый УникальныйИдентификатор());
		
	СтруктураЗапроса = Новый Структура();
	СтруктураЗапроса.Вставить("query", ТекстВопроса);
	
	ПараметрыЗапроса = Новый Структура();
	ПараметрыЗапроса.Вставить("id", НомерЗапроса);
	ПараметрыЗапроса.Вставить("apiKey", КлючAPI);
	ПараметрыЗапроса.Вставить("method", "search");
	ПараметрыЗапроса.Вставить("params", СтруктураЗапроса);
	
	ТипКонтента = "application/json";
	
	ЗапросHTTP = Новый HTTPЗапрос(АдресAPI.ПутьНаСервере);
	ЗапросHTTP.Заголовки["Content-type"] = ТипКонтента;
	ЗапросВJSON = ОбщегоНазначения.ЗначениеВJSON(ПараметрыЗапроса);
	ЗапросHTTP.УстановитьТелоИзСтроки(ЗапросВJSON);
	
	РезультатЗапроса = ВыполнитьЗапрос(ЗапросHTTP, АдресAPI);
	
	НомерЗапросаСовпадает = РезультатЗапроса.Свойство("ОтветСервера")
		И РезультатЗапроса.ОтветСервера.Получить("id") = НомерЗапроса;
	 
	Если Не РезультатЗапроса.ЗапросВыполнен ИЛИ Не НомерЗапросаСовпадает Тогда
		ТекстОшибки = НСтр("ru = 'Сайт its.1c.ru недоступен. Проверьте настройки подключения к сети интернет.'");
		ВызватьИсключение (ТекстОшибки);
	КонецЕсли;
	
	Ответ = РезультатЗапроса.ОтветСервера.Получить("result");
	
	Возврат Ответ;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ВыполнитьЗапрос(ЗапросHTTP, АдресAPI)

	Прокси = ПолучениеФайловИзИнтернета.ПолучитьПрокси(АдресAPI.Схема);
	HTTPСоединение = Новый HTTPСоединение(
		АдресAPI.Хост,
		АдресAPI.Порт, , ,
		Прокси,
		60,
		ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение());
	
	Результат = Новый Структура;
	
	Попытка
		//@skip-check bsl-legacy-check-dynamic-feature-access
		ОтветHTTP = HTTPСоединение.ОтправитьДляОбработки(ЗапросHTTP);
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(НСтр("ru='Поиск на ИТС'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка, , , ПодробноеПредставлениеОшибки);
		Результат.Вставить("ЗапросВыполнен", Ложь);
		Возврат Результат;
	КонецПопытки;
	
	ТекстОшибки = "";
	
	Если ОтветHTTP.КодСостояния <> 200 Тогда
		ТекстОшибки = НСтр("ru = 'Ошибка обращения к сервису its.1c.ru. Попробуйте повторить поиск позже.'");
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
		ВызватьИсключение(ТекстОшибки);
	КонецЕсли;
	
	ОтветСервера = ОбщегоНазначения.JSONВЗначение(ОтветHTTP.ПолучитьТелоКакСтроку());
	Результат.Вставить("ЗапросВыполнен", ОтветHTTP.КодСостояния = 200);
	Результат.Вставить("ОтветСервера", ОтветСервера);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецЕсли
