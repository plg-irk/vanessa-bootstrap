&НаКлиенте
Процедура ПредыдущийБаннерНажатие(Элемент)
	
	Если НомерТекущегоБаннера = 0 Тогда
		НомерТекущегоБаннера = СписокБаннеров.Количество() - 1;
	Иначе
		НомерТекущегоБаннера = НомерТекущегоБаннера - 1;
	КонецЕсли;
	
	ВывестиБаннер(НомерТекущегоБаннера);
	
КонецПроцедуры

&НаКлиенте
Процедура СледующийБаннерНажатие(Элемент)
	
	Если НомерТекущегоБаннера = СписокБаннеров.Количество() - 1 Тогда
		НомерТекущегоБаннера = 0;
	Иначе
		НомерТекущегоБаннера = НомерТекущегоБаннера + 1;
	КонецЕсли;
	ВывестиБаннер(НомерТекущегоБаннера);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьВозможностьОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, 
	СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	Тег = НСтр("ru = 'Подсистема Помощь'");
	УправлениеНебольшойФирмойКлиент.ПредложитьВозможностьНажатие(Тег);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьОбращениеВТехподдержкуОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки,
		СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	РазделениеВключено = ОбщегоНазначенияКлиент.РазделениеВключено();
	
	ШаблонСообщения = ШаблонСообщенияВПоддержку();
	
	Если Не РазделениеВключено
		И ОбщегоНазначенияКлиент.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.СообщенияВСлужбуТехническойПоддержки") Тогда
		
		МодульСообщенияВСлужбуТехническойПоддержкиКлиентСервер =
			ОбщегоНазначенияКлиент.ОбщийМодуль("СообщенияВСлужбуТехническойПоддержкиКлиентСервер");
		ДанныеСообщения = МодульСообщенияВСлужбуТехническойПоддержкиКлиентСервер.ДанныеСообщения();
		ДанныеСообщения.Получатель = "webIts";
		ДанныеСообщения.Тема       = НСтр("ru = 'Сообщение из раздела Помощь:'");
		ДанныеСообщения.Сообщение  = ШаблонСообщения;
		ДанныеСообщения.ИспользоватьСтандартныйШаблон = Ложь;
		
		МодульСообщенияВСлужбуТехническойПоддержкиКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль(
			"СообщенияВСлужбуТехническойПоддержкиКлиент");
		МодульСообщенияВСлужбуТехническойПоддержкиКлиент.ОтправитьСообщение(
			ДанныеСообщения);
		
	ИначеЕсли РазделениеВключено Тогда
		
		ПараметрыОбращения = ИнформационныйЦентрКлиент.НовыеПараметрыОбращенияВСлужбуПоддержки();
		ПараметрыОбращения.ИспользоватьСтандартныйШаблон = Ложь;
		ПараметрыОбращения.Тема = НСтр("ru = 'Сообщение из раздела Помощь:'");
		ПараметрыОбращения.Текст = ШаблонСообщения;
		ИнформационныйЦентрКлиент.ОткрытьФормуОтправкиСообщенияВСлужбуПоддержки(Истина, , , ПараметрыОбращения);
		
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

