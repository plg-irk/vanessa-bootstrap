&НаКлиенте
Процедура ПоказатьГлавнуюСтраницу()
	
	СтрокаПоиска = "";
	Элементы.СтрокаПоиска.КнопкаОчистки = Ложь;
	Элементы.Назад.Видимость = Ложь;
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаПанельРазделов;
	ОчиститьПодчиненныеЭлементы("ГруппаРезультатыПоиска");
	
КонецПроцедуры

&НаСервере
Процедура СохранитьИсториюПоиска()
	
	КлючаОбъекта = "ФормаПомощь";
	КлючНастроек = "ИсторияПоиска";
	Настройки = ИсторияПоиска.ВыгрузитьЗначения();
	ХранилищеСистемныхНастроек.Сохранить(КлючаОбъекта, КлючНастроек, Настройки);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьИсториюПоиска()
	
	КлючаОбъекта = "ФормаПомощь";
	КлючНастроек = "ИсторияПоиска";
	
	Настройки = ХранилищеСистемныхНастроек.Загрузить(КлючаОбъекта, КлючНастроек);
	Если Настройки <> Неопределено Тогда
		ИсторияПоиска.ЗагрузитьЗначения(Настройки);
	КонецЕсли;
	Элементы.СтрокаПоиска.СписокВыбора.ЗагрузитьЗначения(ИсторияПоиска.ВыгрузитьЗначения());
	Элементы.СтрокаПоиска.КнопкаВыпадающегоСписка = ИсторияПоиска.Количество() > 0;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВИсториюПоиска(СтрокаПоиска)
	
	Если ИсторияПоиска.НайтиПоЗначению(СокрЛП(СтрокаПоиска)) = Неопределено Тогда
		Если ИсторияПоиска.Количество() = 10 Тогда
			ИсторияПоиска.Удалить(9);
		КонецЕсли;
		ИсторияПоиска.Вставить(0, СтрокаПоиска);
	КонецЕсли;
	
	Элементы.СтрокаПоиска.СписокВыбора.ЗагрузитьЗначения(ИсторияПоиска.ВыгрузитьЗначения());
	Элементы.СтрокаПоиска.КнопкаВыпадающегоСписка = ИсторияПоиска.Количество() > 0;
	
КонецПроцедуры

&НаСервере
Функция ОперацияВыполнитьПоискНаСервере()
	
	ОчиститьПодчиненныеЭлементы("ГруппаРезультатыПоиска");
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаФоновоеЗадание;
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "Обработки.ПанельПомощь.ВыполнитьПоиск",
		СтрокаПоиска);
	
КонецФункции

&НаКлиенте
Процедура ПриЗавершенииПоиска(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаПанельРазделов;
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	Элементы.Назад.Видимость = Истина;
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаРезультатыПоиска;
	
	ВывестиРезультатыПоиска(Результат.АдресРезультата);

КонецПроцедуры

