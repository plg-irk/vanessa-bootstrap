	ЗаполнитьРазделы();
	ЗаполнитьБаннеры();
	ВывестиБаннер(0);
	ПрочитатьИсториюПоиска();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	СохранитьИсториюПоиска();
	
КонецПроцедуры

