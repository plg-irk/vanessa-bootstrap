&НаСервере
Процедура ЗаполнитьБаннеры()

	Если ЭтоУНФ Тогда
		АдресРуководства = "https://its.1c.ru/db/unfdoc#bookmark:unf:UNF000018";
	Иначе
		АдресРуководства = "https://its.1c.ru/db/retail30doc#bookmark:ur:UR000018";
	КонецЕсли;

	НоваяНовость = СписокБаннеров.Добавить();
	НоваяНовость.Заголовок = НСтр("ru = 'Мини-уроки «Старт в 1С:Розница и 1С:УНФ»'");
	НоваяНовость.АдресСтраницы = "https://rutube.ru/plst/536586/";
	НоваяНовость.ЗаголовокСсылки = НСтр("ru = 'Смотрите на rutube.ru'");
	БаннерПереключатель_0 = 1;

	НоваяНовость = СписокБаннеров.Добавить();
	НоваяНовость.Заголовок = НСтр("ru = 'Руководство пользователя'");
	НоваяНовость.АдресСтраницы = АдресРуководства;
	НоваяНовость.ЗаголовокСсылки = НСтр("ru = 'Читайте на its.1c.ru'");
	БаннерПереключатель_1 = 1;
	
	ДанныеБаннер = Обработки.ПанельПомощь.ПолучитьМакет("Баннер");
	АдресКартинкиБаннера = ПоместитьВоВременноеХранилище(ДанныеБаннер);
	
КонецПроцедуры

&НаСервере
Процедура ВывестиБаннер(Знач НомерБаннера)
	
	ТекстБаннера = СписокБаннеров[НомерБаннера].Заголовок;
	АдресБаннера = СписокБаннеров[НомерБаннера].АдресСтраницы;
	ЗаголовокСсылки = СписокБаннеров[НомерБаннера].ЗаголовокСсылки;
	
	ТекстБаннера = СтроковыеФункции.ФорматированнаяСтрока(
		"<span style = ""font: ШрифтЗаголовкаБаннераКрупный"">%1</span>", ТекстБаннера);
	СсылкаБаннера = СтроковыеФункции.ФорматированнаяСтрока(
		"<span style = ""font: ШрифтТекстаБаннера""><a href = ""%1"">%2</a></span>", АдресБаннера, ЗаголовокСсылки);
	
	Элементы.ТекстБаннера.Заголовок = ТекстБаннера;
	Элементы.АдресБаннера.Заголовок = СсылкаБаннера;
	
	ВключитьПереключательБаннера(НомерБаннера);
	
КонецПроцедуры

&НаСервере
Процедура ВключитьПереключательБаннера(НомерБаннера)
	
	ПрефиксИмени = "БаннерПереключатель_";
	Для Индекс = 0 По СписокБаннеров.Количество() - 1 Цикл
		Если Индекс = НомерБаннера Тогда
			ЭтотОбъект[ПрефиксИмени + Строка(Индекс)] = 2;
		Иначе
			ЭтотОбъект[ПрефиксИмени + Строка(Индекс)] = 1;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиРезультатыПоиска(Знач АдресРезультата)
	
	РезультатПоиска = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Если РезультатПоиска = Неопределено Тогда
		Возврат;
	КонецЕсли;
		
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаРезультатыПоиска;
	Элементы.СтрокаПоиска.КнопкаОчистки = Истина;
	
	РезультатыПоискаЗаписи = РезультатПоиска.Получить("items");
	
	КоличествоДокументов = РезультатПоиска.Получить("count");
	ТекстНайденоСтрокШаблон = НСтр("ru = 'Найдено: %1'");
	ТекстНайденоСтрок = СтрШаблон(ТекстНайденоСтрокШаблон, КоличествоДокументов);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьКоличествоСтрок", 
		"Заголовок", ТекстНайденоСтрок);
	
	РезультатыПоиска.Очистить();
	 
	СчетчикРезультатов = 0;
	СтруктураРезультата = Новый Структура;
	
	Для каждого Элемент Из РезультатыПоискаЗаписи Цикл
		
		СчетчикРезультатов = СчетчикРезультатов + 1;
		
		Если ТипЗнч(Элемент["snippet_text"]) = Тип("Массив") И Элемент["snippet_text"].Количество() > 0 Тогда
			СтруктураРезультата.Очистить();
			СтруктураРезультата.Вставить("ДатаПубликации", Элемент["datetime"]);
			СтруктураРезультата.Вставить("Название", Элемент["title"]);
			СтруктураРезультата.Вставить("Адрес", Элемент["url"]);
			СтруктураРезультата.Вставить("Фрагмент", Элемент["snippet_text"][0]);
			Если СтрДлина(СтруктураРезультата.Фрагмент) > 3 И Лев(СтруктураРезультата.Фрагмент, 3) = "..." Тогда
				СтруктураРезультата.Фрагмент = Прав(СтруктураРезультата.Фрагмент, 
					СтрДлина(СтруктураРезультата.Фрагмент) - 3);
			КонецЕсли;
			ДобавитьЭлементРезультатПоиска(СтруктураРезультата, Строка(СчетчикРезультатов));
		КонецЕсли;
		
		Если СчетчикРезультатов = МаксимальноеКоличествоРезультатовПоиска Тогда
			Прервать;
		КонецЕсли;
				
	КонецЦикла;
	
	Если СчетчикРезультатов = 0 Тогда
		
		ТекстНайденоСтрок = НСтр("ru = 'По вашему запросу ничего не найдено. Попробуйте изменить поисковый запрос.'");
		ТекстЗаголовкаИТС = "";
		
	ИначеЕсли СчетчикРезультатов < МаксимальноеКоличествоРезультатовПоиска  Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьСсылкаНаИТС", 
			"Видимость", Ложь);
		Возврат;
		
	Иначе
		
		ШаблонКоличествоРезультатов = НСтр("ru = 'Показано %1 результатов.'");
		СтрокаКоличествоРезультатов = СтрШаблон(ШаблонКоличествоРезультатов, СчетчикРезультатов);
		СтрокаИТС = НСтр("ru = 'Полный список результатов поиска на'");
		СоставСсылки = "http://its.1c.ru/db/alldb#search:its:" 
			+ СтрокаПоиска 
			+ "?attributes[dbnick]=&attributes[conf][]=УНФ&attribute=conf";
		СсылкаИТС = Новый ФорматированнаяСтрока("its.1c.ru", , , , СоставСсылки);
		ТекстЗаголовкаИТС = Новый ФорматированнаяСтрока(СтрокаКоличествоРезультатов, " ", СтрокаИТС, " ", СсылкаИТС);
		
	КонецЕсли;

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьКоличествоСтрок", 
		"Заголовок", ТекстНайденоСтрок);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьСсылкаНаИТС", 
		"Заголовок", ТекстЗаголовкаИТС);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьСсылкаНаИТС", 
		"Видимость", Истина);
		
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементРезультатПоиска(ЭлементОтвета, Идентификатор)
	
	СтрокаРезультатПоиска = РезультатыПоиска.Добавить();
	СтрокаРезультатПоиска.ИмяКоманды = "КомандаРезультатПоиска" + Идентификатор;
	СтрокаРезультатПоиска.АдресСтраницы = ЭлементОтвета.Адрес;
	
	РодительскаяГруппа = Элементы.Добавить("ГруппаРезультатыПоиска" + Идентификатор, 
		Тип("ГруппаФормы"), Элементы.ГруппаРезультатыПоиска);
	РодительскаяГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	РодительскаяГруппа.ОтображатьЗаголовок = Ложь;
	РодительскаяГруппа.Отображение = ОтображениеОбычнойГруппы.Нет;
	РодительскаяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	РодительскаяГруппа.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
	РодительскаяГруппа.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	
	НоваяКоманда = Команды.Добавить("КомандаРезультатПоиска" + Идентификатор);
	НоваяКоманда.Действие = "Подключаемый_ОткрытьСтатьюПоАдресу";

	НовоеПоле = Элементы.Добавить("НазваниеРезультатПоиска" + Идентификатор,
		Тип("КнопкаФормы"), РодительскаяГруппа);
	НовоеПоле.ИмяКоманды = НоваяКоманда.Имя;
	НовоеПоле.Заголовок = ЭлементОтвета.Название;
	НовоеПоле.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
	ЦветЗаголовка = ЦветаСтиля.ГиперссылкаЦвет;	
	ШрифтЗаголовка = ШрифтыСтиля.ВариантОтчетаОбычныйШрифт;
	НовоеПоле.Шрифт = ШрифтЗаголовка;
	НовоеПоле.ЦветТекста = ЦветЗаголовка;
	
	НовоеПоле = Элементы.Добавить("ФрагментРезультатПоиска" + Идентификатор,
		Тип("ДекорацияФормы"), РодительскаяГруппа);
	НовоеПоле.Вид = ВидДекорацииФормы.Надпись;
	НовоеПоле.АвтоМаксимальнаяШирина = Ложь;
	НовоеПоле.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
	НовоеПоле.Заголовок = ЭлементОтвета.Фрагмент;
	
	НовоеПоле = Элементы.Добавить("ДатаПубликацииРезультатПоиска" + Идентификатор,
		Тип("ДекорацияФормы"), РодительскаяГруппа);
	НовоеПоле.Вид = ВидДекорацииФормы.Надпись;
	НовоеПоле.АвтоМаксимальнаяШирина = Ложь;
	НовоеПоле.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
	НовоеПоле.Заголовок = ЭлементОтвета.ДатаПубликации;
	ШрифтЗаголовка = ШрифтыСтиля.МелкийШрифтТекста;
	ЦветЗаголовка = ЦветаСтиля.ЦветТекстаКнопки;
	НовоеПоле.Шрифт = ШрифтЗаголовка;
	НовоеПоле.ЦветТекста = ЦветЗаголовка;		
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьПодчиненныеЭлементы(Знач ИмяГруппы)
	
	МассивКУдалению = Новый Массив;
	Для каждого Элемент Из Элементы[ИмяГруппы].ПодчиненныеЭлементы Цикл
		МассивКУдалению.Добавить(Элемент);
	КонецЦикла;
	
	Для каждого Элемент Из МассивКУдалению Цикл
		Элементы.Удалить(Элемент);
	КонецЦикла;

	Для ИД = 1 По МаксимальноеКоличествоРезультатовПоиска Цикл
		Команда = Команды.Найти("КомандаРезультатПоиска" + Строка(ИД));
		Если Команда <> Неопределено Тогда
			Команды.Удалить(Команда);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОткрытьСтатьюПоАдресу(Команда)

	НайтиОткрытьСсылку("РезультатыПоиска", "ИмяКоманды", Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСсылкуРаздела(ИмяРаздела)
	
	НайтиОткрытьСсылку("СсылкиПоРазделам", "ИмяРаздела", ИмяРаздела);
	
КонецПроцедуры

&НаКлиенте
Процедура НайтиОткрытьСсылку(ИмяТаблицы, ИмяКолонки, Значение)
	
	Отбор = Новый Структура(ИмяКолонки, Значение);
	АдресСтраницы = ЭтотОбъект[ИмяТаблицы].НайтиСтроки(Отбор);
	Если АдресСтраницы = Неопределено Тогда
		Адрес = "";
	Иначе
		Адрес = АдресСтраницы[0].АдресСтраницы;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Адрес) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(Адрес);
	КонецЕсли;
	
КонецПроцедуры

