	НаследоватьСвойстваГруппыФормы(ГруппаФИО, Элементы.ГруппаФИО1, ЗначенияСвойствЭлементов);
	
	ГруппаПодсказкиФИО = Элементы.Добавить("ГруппаПодсказкиФИО" + ПостФикс, Тип("ГруппаФормы"), ГруппаФИО);
