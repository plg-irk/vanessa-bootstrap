		НаследоватьСвойстваПоляВвода(СистемаНалогообложения, Элементы.СистемаНалогообложения1, ЗначенияСвойствЭлементов);
		
		// Вид объекта налогообложения
		ГруппаОблагаетсяНалогом = Элементы.Добавить("ГруппаОблагаетсяНалогом" + ПостФикс, Тип("ГруппаФормы"), ДанныеОрганизацииЛево);
		ГруппаОблагаетсяНалогом.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НаследоватьСвойстваГруппыФормы(ГруппаОблагаетсяНалогом, Элементы.ГруппаОблагаетсяНалогом1, ЗначенияСвойствЭлементов);
		
		ГруппаОблагаетсяНалогомМК = Элементы.Добавить("ГруппаОблагаетсяНалогомМК" + ПостФикс, Тип("ГруппаФормы"), ГруппаОблагаетсяНалогом);
		ГруппаОблагаетсяНалогомМК.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НаследоватьСвойстваГруппыФормы(ГруппаОблагаетсяНалогомМК, Элементы.ГруппаОблагаетсяНалогомМК1, ЗначенияСвойствЭлементов);
		
		ОблагаетсяНалогомЗаголовок = Элементы.Добавить("ОблагаетсяНалогомЗаголовок" + ПостФикс, Тип("ДекорацияФормы"), ГруппаОблагаетсяНалогомМК);
		ОблагаетсяНалогомЗаголовок.Вид = ВидДекорацииФормы.Надпись;
		НаследоватьСвойстваДекорацииФормы(ОблагаетсяНалогомЗаголовок, Элементы.ОблагаетсяНалогомЗаголовок1, ЗначенияСвойствЭлементов);
		
		ВидыОбъектовНалогообложения = Элементы.Добавить("ВидыОбъектовНалогообложения" + ПостФикс, Тип("ПолеФормы"), ГруппаОблагаетсяНалогом);
		ВидыОбъектовНалогообложения.Вид = ВидПоляФормы.ПолеПереключателя;
		ВидыОбъектовНалогообложения.ПутьКДанным = "ВидыОбъектовНалогообложения" + ПостФикс;
		ВидыОбъектовНалогообложения.УстановитьДействие("ПриИзменении", "НалогообложениеПриИзменении");
		НаследоватьСвойстваПоляПереключателя(ВидыОбъектовНалогообложения, Элементы.ВидыОбъектовНалогообложения1, ЗначенияСвойствЭлементов);
		
		// Налоговая ставка
		ГруппаНалоговаяСтавка = Элементы.Добавить("ГруппаНалоговаяСтавка" + ПостФикс, Тип("ГруппаФормы"), ДанныеОрганизацииЛево);
		ГруппаНалоговаяСтавка.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НаследоватьСвойстваГруппыФормы(ГруппаНалоговаяСтавка, Элементы.ГруппаНалоговаяСтавка1, ЗначенияСвойствЭлементов);
		
		ГруппаНалоговаяСтавкаМК = Элементы.Добавить("ГруппаНалоговаяСтавкаМК" + ПостФикс, Тип("ГруппаФормы"), ГруппаНалоговаяСтавка);
		ГруппаНалоговаяСтавкаМК.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НаследоватьСвойстваГруппыФормы(ГруппаНалоговаяСтавкаМК, Элементы.ГруппаНалоговаяСтавкаМК1, ЗначенияСвойствЭлементов);
		
		НалоговаяСтавкаЗаголовок = Элементы.Добавить("НалоговаяСтавкаЗаголовок" + ПостФикс, Тип("ДекорацияФормы"), ГруппаНалоговаяСтавкаМК);
		НалоговаяСтавкаЗаголовок.Вид = ВидДекорацииФормы.Надпись;
		НаследоватьСвойстваДекорацииФормы(НалоговаяСтавкаЗаголовок, Элементы.НалоговаяСтавкаЗаголовок1, ЗначенияСвойствЭлементов);
		
		СтавкаНалога = Элементы.Добавить("СтавкаНалога" + ПостФикс, Тип("ПолеФормы"), ГруппаНалоговаяСтавка);
		СтавкаНалога.Вид = ВидПоляФормы.ПолеВвода;
		СтавкаНалога.ПутьКДанным = "СтавкаНалога" + ПостФикс;
		СтавкаНалога.УстановитьДействие("ПриИзменении", "СтавкаНалогаПриИзменении");
		НаследоватьСвойстваПоляВвода(СтавкаНалога, Элементы.СтавкаНалога1, ЗначенияСвойствЭлементов);
		
		// Ставка НДС
		ГруппаСтавкаНДС = Элементы.Добавить("ГруппаСтавкаНДС" + ПостФикс, Тип("ГруппаФормы"), ДанныеОрганизацииЛево);
		ГруппаСтавкаНДС.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НаследоватьСвойстваГруппыФормы(ГруппаСтавкаНДС, Элементы.ГруппаСтавкаНДС1, ЗначенияСвойствЭлементов);
		
		ГруппаСтавкаНДСМК = Элементы.Добавить("ГруппаСтавкаНДСМК" + ПостФикс, Тип("ГруппаФормы"), ГруппаСтавкаНДС);
		ГруппаСтавкаНДСМК.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НаследоватьСвойстваГруппыФормы(ГруппаСтавкаНДСМК, Элементы.ГруппаСтавкаНДСМК1, ЗначенияСвойствЭлементов);
		
		СтавкаНДСЗаголовок = Элементы.Добавить("СтавкаНДСЗаголовок" + ПостФикс, Тип("ДекорацияФормы"), ГруппаСтавкаНДСМК);
		СтавкаНДСЗаголовок.Вид = ВидДекорацииФормы.Надпись;
		НаследоватьСвойстваДекорацииФормы(СтавкаНДСЗаголовок, Элементы.СтавкаНДСЗаголовок1, ЗначенияСвойствЭлементов);
		
		СтавкаНДС = Элементы.Добавить("СтавкаНДС" + ПостФикс, Тип("ПолеФормы"), ГруппаСтавкаНДС);
		СтавкаНДС.Вид = ВидПоляФормы.ПолеВвода;
		СтавкаНДС.ПутьКДанным = "СтавкаНДС" + ПостФикс;
		СтавкаНДС.УстановитьДействие("ПриИзменении", "СтавкаНДСПриИзменении");
		НаследоватьСвойстваПоляВвода(СтавкаНДС, Элементы.СтавкаНДС1, ЗначенияСвойствЭлементов);
		
		ИПИспользуетТрудНаемныхРаботников = Элементы.Добавить(
		"ИПИспользуетТрудНаемныхРаботников" + ПостФикс, Тип("ПолеФормы"), ДанныеОрганизацииЛево);
		ИПИспользуетТрудНаемныхРаботников.ПутьКДанным = "ИПИспользуетТрудНаемныхРаботников" + ПостФикс;
		ИПИспользуетТрудНаемныхРаботников.Вид = ВидПоляФормы.ПолеФлажка;
		ИПИспользуетТрудНаемныхРаботников.УстановитьДействие("ПриИзменении", "ЕстьСотрудникиПриИзменении");
		НаследоватьСвойстваПоляФлажка(
		ИПИспользуетТрудНаемныхРаботников, Элементы.ИПИспользуетТрудНаемныхРаботников1, ЗначенияСвойствЭлементов);
		
	КонецЕсли;
	
	// Правая колонка
	ДанныеОрганизацииПраво = Элементы.Добавить("ДанныеОрганизацииПраво" + ПостФикс, Тип("ГруппаФормы"), ДанныеОрганизации);
	ДанныеОрганизацииПраво.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НаследоватьСвойстваГруппыФормы(ДанныеОрганизацииПраво, Элементы.ДанныеОрганизацииПраво1, ЗначенияСвойствЭлементов);
	
	// Логотип
	АдресЛоготипа = Элементы.Добавить("АдресЛоготипа" + ПостФикс, Тип("ПолеФормы"), ДанныеОрганизацииПраво);
	АдресЛоготипа.ПутьКДанным = "АдресЛоготипа" + ПостФикс;
	АдресЛоготипа.Вид = ВидПоляФормы.ПолеКартинки;
	АдресЛоготипа.УстановитьДействие("Нажатие", "АдресЛоготипаНажатие");
	НаследоватьСвойстваПоляКартинки(АдресЛоготипа, Элементы.АдресЛоготипа1, ЗначенияСвойствЭлементов);
	
	// Удаление организации
	УдалитьОрганизацию = Элементы.Добавить("УдалитьОрганизацию" + ПостФикс, Тип("КнопкаФормы"), ДанныеОрганизации);
	УдалитьОрганизацию.Вид = ВидКнопкиФормы.Гиперссылка;
	УдалитьОрганизацию.ИмяКоманды = "УдалитьОрганизацию";
	
КонецПроцедуры

&НаСервере
Процедура УдалитьОрганизациюНаСервере()
	
	Если ТекущийЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоМобильныйКлиент Тогда
		ИндексОрганизации = ИндексТекущейОрганизацииМК();
	Иначе
		ИндексОрганизации = ИндексПоИмениЭлемента(ТекущийЭлемент.Имя, "УдалитьОрганизацию");
	КонецЕсли;
	
	Если ИндексОрганизации = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаОрганизации = СтрокаОрганизацииПоИндексуНаСервере(ИндексОрганизации);
	Объект.Организации.Удалить(СтрокаОрганизации);
	
	УдаляемыеРеквизиты = Новый Массив;
	УдаляемыеРеквизиты.Добавить("ИНН" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("ЮридическоеФизическоеЛицо" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("Наименование" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("ФИО" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("Сайт" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("СистемаНалогообложения" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("ВидыОбъектовНалогообложения" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("СтавкаНалога" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("СтавкаНДС" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("ИПИспользуетТрудНаемныхРаботников" + ИндексОрганизации);
	УдаляемыеРеквизиты.Добавить("АдресЛоготипа" + ИндексОрганизации);
	
	ИзменитьРеквизиты(, УдаляемыеРеквизиты);
	
	Элементы.Удалить(Элементы["ДанныеОрганизации" + ИндексОрганизации]);
	Элементы.Удалить(Элементы["ОтступОрганизации" + ИндексОрганизации]);
	
КонецПроцедуры

#КонецОбласти

#Область Логотип

&НаСервере
Процедура ОбновитьИзображениеЛоготипа(Источник)
	
	Индекс = КэшЗначений.ТекущийИндексОрганизации;
	Если Индекс = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаОрганизации = СтрокаОрганизацииПоИндексуНаСервере(Индекс);
	СтрокаОрганизации.ФайлЛоготип = ?(ТипЗнч(Источник) = Тип("Массив"), Источник[0], Источник);
	
	Если ЗначениеЗаполнено(СтрокаОрганизации.ФайлЛоготип) Тогда
		
		ДанныеФайла = ДанныеФайла(СтрокаОрганизации.ФайлЛоготип, УникальныйИдентификатор);
		АдресЛоготипа = ДанныеФайла.СсылкаНаДвоичныеДанныеФайла;
		ИмяФайла = ДанныеФайла.ИмяФайла;
		
	Иначе
		
		АдресЛоготипа = "";
		ИмяФайла = "";
		
	КонецЕсли;
	
	ЭтотОбъект["АдресЛоготипа" + СтрокаОрганизации.ИндексОрганизации] = АдресЛоготипа;
	ОпределитьИнтерфейсЛоготипаМК(Индекс, ИмяФайла);
	КэшЗначений.ТекущийИндексОрганизации = Неопределено;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеФайла(ФайлКартинки, ИдентификаторФормы)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДополнительныеПараметры = РаботаСФайламиКлиентСервер.ПараметрыДанныхФайла();
	ДополнительныеПараметры.ИдентификаторФормы = ИдентификаторФормы;
	
	Возврат РаботаСФайлами.ДанныеФайла(ФайлКартинки, ДополнительныеПараметры);
	
КонецФункции

&НаКлиенте
Процедура ПросмотретьПрисоединенныйФайл(ФайлЛоготип)
	
	ДанныеФайла = ДанныеФайла(ФайлЛоготип, УникальныйИдентификатор);
	РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзображениеНаКлиенте(ИндексОрганизации)
	Перем ИдентификаторФайла, Фильтр;
	
	КэшЗначений.ТекущийИндексОрганизации = ИндексОрганизации;
	
	СтрокаОрганизации = СтрокаОрганизацииПоИндексуНаКлиенте(ИндексОрганизации);
	
	ЭтотОбъект["АдресЛоготипа" + СтрокаОрганизации.ИндексОрганизации] = "";
	
	ИдентификаторФайла = Новый УникальныйИдентификатор;
	Фильтр = РаботаСФайламиУНФКлиентСервер.ФильтрФайловИзображений();
	
	РаботаСФайламиКлиент.ДобавитьФайлы(СтрокаОрганизации.Ссылка, ИдентификаторФайла, Фильтр);
	
КонецПроцедуры

#КонецОбласти

#Область СНО

&НаКлиентеНаСервереБезКонтекста
Функция СписокЗначенийСНО(ЭтоЮрЛицо)
	
	Результат = Новый СписокЗначений;
	
	Результат.Добавить("ОСНО", НСтр("ru = 'ОСНО (общая)'"));
	
	Если Не ЭтоЮрЛицо Тогда
		Результат.Добавить("ОСНО_ПСН", НСтр("ru = 'ОСНО + ПСН (общая + патент)'"));
	КонецЕсли;
	
	Результат.Добавить("УСН", НСтр("ru = 'УСН (упрощенная)'"));
	
	Если Не ЭтоЮрЛицо Тогда
		Результат.Добавить("УСН_ПСН", НСтр("ru = 'УСН + ПСН (упрощенная + патент)'"));
	КонецЕсли;
	
	Результат.Добавить("УСН_НДС", НСтр("ru = 'УСН + НДС (упрощенная + НДС)'"));
	Результат.Добавить("АУСН", НСтр("ru = 'АУСН (автоматизированная упрощенная)'"));
	
	Если Не ЭтоЮрЛицо Тогда
		Результат.Добавить("ПСН", НСтр("ru = 'ПСН (патент)'"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ФормаСобственностиПоддерживаетСНО(ФормаСобственности, СНО)
	
	Если ФормаСобственности = ПредопределенноеЗначение("Перечисление.ЮридическоеФизическоеЛицо.ФизическоеЛицо") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат СНО = "ОСНО" Или СНО = "УСН" Или СНО = "УСН_НДС" Или СНО = "АУСН";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НоваяСНОПоСтаройСНОИФормеСобственности(СтараяСНО, ФормаСобственности)
	
	Если ФормаСобственностиПоддерживаетСНО(ФормаСобственности, СтараяСНО) Тогда
		Возврат СтараяСНО;
	КонецЕсли;
	
	Если СтараяСНО = "УСН_ПСН" Тогда
		Возврат "УСН";
	КонецЕсли;
	
	Возврат "ОСНО";
	
КонецФункции

&НаКлиенте
Процедура УстановитьДанныеПоСНО(СНО, Индекс)
	
	ЭтотОбъект["СистемаНалогообложения" + Индекс] = СНО;
	ЗаписатьЗначениеОрганизации("СистемаНалогообложения", СНО, Индекс);
	
	Если ЭтоУСН(СНО) Тогда
		
		ЗначениеСтавкаНалога = 6;
		ЗначениеНалогообложение = КэшЗначений.Доходы;
		
		ЭтотОбъект["СтавкаНалога" + Индекс] = ЗначениеСтавкаНалога;
		ЭтотОбъект["ВидыОбъектовНалогообложения" + Индекс] = ЗначениеНалогообложение;
		
		ЗаписатьЗначениеОрганизации("СтавкаНалога", ЗначениеСтавкаНалога, Индекс);
		ЗаписатьЗначениеОрганизации("ВидыОбъектовНалогообложения", ЗначениеНалогообложение, Индекс);
		
	ИначеЕсли ЭтоАУСН(СНО) Тогда
		
		ЗначениеСтавкаНалога = 8;
		ЗначениеНалогообложение = КэшЗначений.Доходы;
		
		ЭтотОбъект["СтавкаНалога" + Индекс] = ЗначениеСтавкаНалога;
		ЭтотОбъект["ВидыОбъектовНалогообложения" + Индекс] = ЗначениеНалогообложение;
		
		ЗаписатьЗначениеОрганизации("СтавкаНалога", ЗначениеСтавкаНалога, Индекс);
		ЗаписатьЗначениеОрганизации("ВидыОбъектовНалогообложения", ЗначениеНалогообложение, Индекс);
		
	КонецЕсли;
	
	Если ВключаетНДС(СНО) Тогда
		
		ЗначениеСтавкаНДС = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.ПониженнаяУСН");
		
		ЭтотОбъект["СтавкаНДС" + Индекс] = ЗначениеСтавкаНДС;
		ЗаписатьЗначениеОрганизации("СтавкаНДС", ЗначениеСтавкаНДС, Индекс);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоУСН(СНО)
	
	Возврат СНО = "УСН" Или СНО = "УСН_ПСН" Или СНО = "УСН_НДС";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоАУСН(СНО)
	
	Возврат СНО = "АУСН";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВключаетНДС(СНО)
	
	Возврат СтрНайти(СНО, "НДС");
	
КонецФункции

#КонецОбласти

#Область ЮрФизЛицо

&НаКлиенте
Процедура ЗаписатьЗначениеОрганизацииЮрФизЛицо(ЗначениеЮрФизЛицо, ПредыдущееЗначение, Индекс)
	
	ЗаписатьЗначениеОрганизации("ЮридическоеФизическоеЛицо", ЗначениеЮрФизЛицо, Индекс);
	ПослеЗаписиЗначенияЮрФизЛицо(ЗначениеЮрФизЛицо, ПредыдущееЗначение, Индекс);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписиЗначенияЮрФизЛицо(ЗначениеЮрФизЛицо, ПредыдущееЗначение, Индекс)
	
	ТекущаяСНО = ЭтотОбъект["СистемаНалогообложения" + Индекс];
	
	Если ЗначениеЮрФизЛицо = КэшЗначений.ЮрЛицо Тогда
		
		ЭтотОбъект["ИПИспользуетТрудНаемныхРаботников" + Индекс] = Ложь;
		ЗаписатьЗначениеОрганизации("ИПИспользуетТрудНаемныхРаботников", Ложь, Индекс);
		
		ЭтотОбъект["ФИО" + Индекс] = "";
		ЗаписатьЗначениеОрганизации("ФИО", "", Индекс);
		
		Если ПредыдущееЗначение <> КэшЗначений.ЮрЛицо Тогда
			НоваяСНО = НоваяСНОПоСтаройСНОИФормеСобственности(ТекущаяСНО, ЗначениеЮрФизЛицо);
			УстановитьДанныеПоСНО(НоваяСНО, Индекс);
		КонецЕсли;
		
	Иначе
		
		Если ПредыдущееЗначение = КэшЗначений.ЮрЛицо Тогда
			Если ТекущаяСНО = "УСН" Или ТекущаяСНО = "УСН_НДС" Тогда
				УстановитьДанныеПоСНО(ТекущаяСНО, Индекс);
			Иначе
				УстановитьДанныеПоСНО("УСН", Индекс);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьЗначениеОрганизацииЮрФизЛицоНаСервере(ЗначениеЮрФизЛицо, Индекс)
	
	ЗаписатьЗначениеОрганизацииНаСервере("ЮридическоеФизическоеЛицо", ЗначениеЮрФизЛицо, Индекс);
	ПослеЗаписиЗначенияЮрФизЛицоНаСервере(ЗначениеЮрФизЛицо, Индекс);
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиЗначенияЮрФизЛицоНаСервере(ЗначениеЮрФизЛицо, Индекс)
	
	Если ЗначениеЮрФизЛицо = КэшЗначений.ЮрЛицо Тогда
		
		ЭтотОбъект["ИПИспользуетТрудНаемныхРаботников" + Индекс] = Ложь;
		ЗаписатьЗначениеОрганизацииНаСервере("ИПИспользуетТрудНаемныхРаботников", Ложь, Индекс);
		
		ЭтотОбъект["ФИО" + Индекс] = "";
		ЗаписатьЗначениеОрганизацииНаСервере("ФИО", "", Индекс);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область НаименованиеДляБюджета

&НаКлиенте
Функция ПолучитьНаименованиеДляБюджета(Индекс)
	
	ДанныеСтрокиОрганизации = СтрокаОрганизацииПоИндексуНаКлиенте(Индекс);
	
	// Для организации заполняем из полного наименования
	Если ДанныеСтрокиОрганизации.ЮридическоеФизическоеЛицо = КэшЗначений.ЮрЛицо Тогда
		
		Возврат ДанныеСтрокиОрганизации.НаименованиеПолное;
		
	КонецЕсли;
	
	// Для ИП:
	// п.4 Приложения 1 к Приказу Минфина 107н:
	// Фамилия имя отчество "(ИП)" "//"Адрес регистрации"//"
	Шаблон = "%1 (ИП) //%2//";
	
	Отбор = Новый Структура;
	Отбор.Вставить("ИндексОрганизации", Индекс);
	Отбор.Вставить("Вид", ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации"));
	Строки = КонтактнаяИнформацияОрганизаций.НайтиСтроки(Отбор);
	
	Если Строки.Количество() Тогда
		АдресРегистрации = Строки[0].Представление;
	Иначе
		АдресРегистрации = "";
	КонецЕсли;
	
	Возврат СтрШаблон(Шаблон, ДанныеСтрокиОрганизации.ФИО, АдресРегистрации);
	
КонецФункции

&НаСервере
Функция ПолучитьНаименованиеДляБюджетаНаСервере(Индекс)
	
	ДанныеСтрокиОрганизации = СтрокаОрганизацииПоИндексуНаСервере(Индекс);
	
	// Для организации заполняем из полного наименования
	Если ДанныеСтрокиОрганизации.ЮридическоеФизическоеЛицо = КэшЗначений.ЮрЛицо Тогда
		
		Возврат ДанныеСтрокиОрганизации.НаименованиеПолное;
		
	КонецЕсли;
	
	// Для ИП:
	// п.4 Приложения 1 к Приказу Минфина 107н:
	// Фамилия имя отчество "(ИП)" "//"Адрес регистрации"//"
	Шаблон = "%1 (ИП) //%2//";
	
	Отбор = Новый Структура;
	Отбор.Вставить("ИндексОрганизации", Индекс);
	Отбор.Вставить("Вид", ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации"));
	Строки = КонтактнаяИнформацияОрганизаций.НайтиСтроки(Отбор);
	
	Если Строки.Количество() Тогда
		АдресРегистрации = Строки[0].Представление;
	Иначе
		АдресРегистрации = "";
	КонецЕсли;
	
	Возврат СтрШаблон(Шаблон, ДанныеСтрокиОрганизации.ФИО, АдресРегистрации);
	
КонецФункции

&НаКлиенте
Процедура ЗаписатьНаименованиеПлательщикаПриПеречисленииНалогов(Индекс)
	
	НаименованиеПлательщика = ПолучитьНаименованиеДляБюджета(Индекс);
	ЗаписатьЗначениеОрганизации("НаименованиеПлательщикаПриПеречисленииНалогов", НаименованиеПлательщика, Индекс);
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНаименованиеПлательщикаПриПеречисленииНалоговНаСервере(Индекс)
	
	НаименованиеПлательщика = ПолучитьНаименованиеДляБюджетаНаСервере(Индекс);
	ЗаписатьЗначениеОрганизацииНаСервере(
	"НаименованиеПлательщикаПриПеречисленииНалогов", НаименованиеПлательщика, Индекс);
	
КонецПроцедуры

#КонецОбласти

#Область КонтактнаяИнформация

&НаСервере
Процедура ДобавитьКИОрганизации(Индекс, ВидКИ, ПредставлениеКИ, ЗначениеКИ = Неопределено)
	
	КИОрганизации = СохраненнаяКИОрганизации(КонтактнаяИнформацияОрганизаций, Индекс);
	
	Строка = КИОрганизации[ВидКИ];
	Если Строка = Неопределено Тогда
		Строка = КонтактнаяИнформацияОрганизаций.Добавить();
		Строка.Вид = ВидКИ;
		Строка.ИндексОрганизации = Индекс;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЗначениеКИ) Тогда
		
		ЗначениеКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(
		ПредставлениеКИ, Справочники.ВидыКонтактнойИнформации.СайтОрганизации);
		
	КонецЕсли;
	
	Строка.Значение = ЗначениеКИ;
	Строка.Представление = ПредставлениеКИ;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СохраненнаяКИОрганизации(КонтактнаяИнформацияОрганизаций, ИндексОрганизации)
	
	Строки = КонтактнаяИнформацияОрганизаций.НайтиСтроки(Новый Структура("ИндексОрганизации", ИндексОрганизации));
	
	Результат = Новый Соответствие;
	Для Каждого Строка Из Строки Цикл
		Результат[Строка.Вид] = Строка;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

&НаКлиенте
Функция СтрокаОрганизацииПоИндексуНаКлиенте(ИндексОрганизации)
	
	НайденныеСтроки = Объект.Организации.НайтиСтроки(Новый Структура("ИндексОрганизации", ИндексОрганизации));
	Возврат НайденныеСтроки[0];
	
КонецФункции

&НаСервере
Функция СтрокаОрганизацииПоИндексуНаСервере(ИндексОрганизации)
	
	НайденныеСтроки = Объект.Организации.НайтиСтроки(Новый Структура("ИндексОрганизации", ИндексОрганизации));
	Возврат НайденныеСтроки[0];
	
КонецФункции

&НаСервере
Функция СформироватьУникальныйИндексОрганизации(СтрокаОрганизации)
	
	ИндексОрганизации = Объект.Организации.Количество();
	
	Пока Истина Цикл
		
		НайденныеСтроки = Объект.Организации.НайтиСтроки(Новый Структура("ИндексОрганизации", ИндексОрганизации));
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			Прервать;
			
		Иначе
			
			ИндексОрганизации = ИндексОрганизации + 1;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ИндексОрганизации;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ИндексПоИмениЭлемента(ИмяЭлемента, ОбщаяЧастьИмени)
	
	ИндексЭлемента = СтрЗаменить(ИмяЭлемента, ОбщаяЧастьИмени, "");
	
	Если ПустаяСтрока(ИндексЭлемента) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат Число(ИндексЭлемента);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ИндексТекущейОрганизацииМК()
	
	ПредпоследнийСимвол = Лев(Прав(ТекущийЭлемент.Имя, 2), 1);
	ПоследнийСимвол = Прав(ТекущийЭлемент.Имя, 1);
	
	ОписаниеТипа = Новый ОписаниеТипов("Число");
	ПредпоследниеЧисло = ОписаниеТипа.ПривестиЗначение(ПредпоследнийСимвол);
	ПоследнееЧисло = ОписаниеТипа.ПривестиЗначение(ПоследнийСимвол);
	
	Если ПоследнееЧисло = 0 И ПредпоследниеЧисло = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ПредпоследниеЧисло * 10 + ПоследнееЧисло;
	
КонецФункции

&НаКлиенте
Процедура ЗаписатьЗначениеОрганизации(ИмяРеквизита, ЗначениеРеквизита, Индекс)
	
	ДанныеСтрокиОрганизации = СтрокаОрганизацииПоИндексуНаКлиенте(Индекс);
	ДанныеСтрокиОрганизации[ИмяРеквизита] = ЗначениеРеквизита;
	
КонецПроцедуры

&НаСервере
Функция ИндексыОрганизаций()
	
	Результат = Новый Массив;
	
	Для Каждого Элемент Из Объект.Организации Цикл
		Результат.Добавить(Элемент.ИндексОрганизации);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаписатьЗначениеОрганизацииНаСервере(ИмяРеквизита, ЗначениеРеквизита, Индекс, НеЗатиратьТекущее = Ложь)
	
	ДанныеСтрокиОрганизации = СтрокаОрганизацииПоИндексуНаСервере(Индекс);
	
	Если НеЗатиратьТекущее Тогда
		
		Если НЕ ЗначениеЗаполнено(ДанныеСтрокиОрганизации[ИмяРеквизита]) Тогда
			
			ДанныеСтрокиОрганизации[ИмяРеквизита] = ЗначениеРеквизита;
			
		КонецЕсли;
		
	Иначе
		
		ДанныеСтрокиОрганизации[ИмяРеквизита] = ЗначениеРеквизита;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеФИОИП(Индекс)
	
	ФИО = СокрЛП(ЭтотОбъект["ФИО" + Индекс]);
	ФамилияИнициалы = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ФИО);
	
	Наименование = СтрШаблон(НСтр("ru = '%1 ИП'"), ФамилияИнициалы);
	НаименованиеПолное = СтрШаблон(НСтр("ru='Индивидуальный предприниматель %1'"), ФамилияИнициалы);
	НаименованиеСокращенное = СтрШаблон(НСтр("ru='ИП %1'"), ФамилияИнициалы);
	
	ЗаписатьЗначениеОрганизации("Наименование", Наименование, Индекс);
	ЗаписатьЗначениеОрганизации("НаименованиеПолное", НаименованиеПолное, Индекс);
	ЗаписатьЗначениеОрганизации("НаименованиеСокращенное", НаименованиеСокращенное, Индекс);
	
	ЭтотОбъект["Наименование" + Индекс] = Наименование;
	
КонецПроцедуры

#КонецОбласти

#Область ВидыБизнеса

&НаКлиенте
Процедура ПриВыбореВидаБизнеса(ВыбранныйВидБизнеса)
	
	НайденныйЭлемент = ВидыБизнеса.НайтиПоЗначению(ВыбранныйВидБизнеса);
	Если НайденныйЭлемент = Неопределено Тогда
		ВидыБизнеса.Добавить(ВыбранныйВидБизнеса);
	Иначе
		ВидыБизнеса.Удалить(НайденныйЭлемент);
	КонецЕсли;
	
	ОпределитьИнтерфейсВидовБизнеса();
	
КонецПроцедуры

#КонецОбласти

#Область НачалоРаботы

&НаКлиенте
Процедура ОжидатьНачалаРаботыСПрограммой()
	
	Элементы.ГруппаИнформацияОжиданияНачалаРаботы.Видимость = Истина;
	
	Если КоличествоОжиданий > 0 Тогда
		Элементы.ПодсказкаОжиданиеНачалаРаботы.Заголовок = СтрШаблон(НСтр("ru='Чтобы применить введенные данные,
		|программа будет перезапущена через: %1...'"), КоличествоОжиданий);
		КоличествоОжиданий = КоличествоОжиданий - 1;
		ПодключитьОбработчикОжидания("ОжидатьНачалаРаботыСПрограммой", 1, Истина);
		Возврат;
	КонецЕсли;
	
	ПродолжитьНачалоРаботы();
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ПродолжитьНачалоРаботы()
	
	Если КэшЗначений.Свойство("ИмяПользователяВСервисе") Тогда
		ИмяПользователя = КэшЗначений.ИмяПользователяВСервисе;
	Иначе
		ИмяПользователя = ПользовательИмя;
	КонецЕсли;
	
	ДополнительныйПараметр = "";
	Если ВРЕГ(ПользовательИмя) = КэшЗначений.ДополнительныйПараметр Тогда
		ДополнительныйПараметр = КэшЗначений.ДополнительныйПараметр;
	КонецЕсли;
	
	ДругойВидБизнеса = ВидыБизнеса.НайтиПоЗначению("Другое");
	Если ДругойВидБизнеса <> Неопределено Тогда
		ВидыБизнеса.Удалить(ДругойВидБизнеса);
	КонецЕсли;
	
	РезультатФормыНачалаРаботы = НачалоРаботыСПрограммойКлиентСервер.НовыйРезультатФормыНачалаРаботы();
	РезультатФормыНачалаРаботы.НачатьРаботу = Истина;
	РезультатФормыНачалаРаботы.Пользователь= КэшЗначений.Пользователь;
	РезультатФормыНачалаРаботы.РазрешитьИнтерактивноеОткрытие = РазрешитьИнтерактивноеОткрытие;
	РезультатФормыНачалаРаботы.ПользовательИмя = ИмяПользователя;
	РезультатФормыНачалаРаботы.ПользовательПароль = ПользовательПароль;
	РезультатФормыНачалаРаботы.ПользовательEmail = СокрЛП(ПользовательEmail);
	РезультатФормыНачалаРаботы.ПользовательТелефон = СокрЛП(ПользовательТелефон);
	РезультатФормыНачалаРаботы.ВидБизнесаОрганизации = ВидыБизнеса;
	РезультатФормыНачалаРаботы.Организации = Объект.Организации;
	РезультатФормыНачалаРаботы.КонтактнаяИнформацияОрганизаций = КонтактнаяИнформацияОрганизаций;
	РезультатФормыНачалаРаботы.ДополнительныйПараметр = ДополнительныйПараметр;
	
	Попытка
		
		Ответ = НачалоРаботыСПрограммойКлиент.ОбработкаЗакрытияФормыНачалаРаботы(
		РезультатФормыНачалаРаботы, КэшЗначений.ПараметрыНачалаРаботы);
		
		Если Ответ.РаботуСистемыНужноЗавершить Тогда
			ПерезапуститьПриЗавершенииПриНеудачномЗавершении = Ответ.ПерезапуститьПриЗавершении;
			ДополнительныеПараметрыПриНеудачномЗавершении = Ответ.ДополнительныеПараметрыКоманднойСтроки;
			ПодключитьОбработчикОжидания("ЗавершитьРаботуОбработчик", 1, Ложь);
		КонецЕсли;
		
	Исключение
		
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЖурналРегистрацииКлиент.ДобавитьСообщениеДляЖурналаРегистрации(
		НачалоРаботыСПрограммойКлиентСервер.ИмяСобытияЖР(),
		"Ошибка",
		ТекстОшибки);
		
		МаксимальнаяДлинаОшибки = 512;
		Если СтрДлина(ТекстОшибки) > МаксимальнаяДлинаОшибки Тогда
			ТекстОшибки = СтрШаблон("%1...", Лев(ТекстОшибки, МаксимальнаяДлинаОшибки));
		КонецЕсли;
		
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		ТекстВопроса = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		НСтр("ru = '%1.
		|
		|<b>Изменить данные или продолжить работу без начальной настройки?</b>'"), ТекстОшибки);
		
		КнопкиВопроса = Новый СписокЗначений;
		КнопкиВопроса.Добавить("ИзменитьДанные", НСтр("ru = 'Изменить данные'"));
		КнопкиВопроса.Добавить("ПродолжитьРаботу", НСтр("ru = 'Продолжить работу'"));
		
		ОтветОтПользователя = Ждать ВопросАсинх(ТекстВопроса,
		КнопкиВопроса, , "ИзменитьДанные", НСтр("ru = 'Не удалось выполнить начальную настройку по причине:'"),);
		
		Если ОтветОтПользователя = "ПродолжитьРаботу" Тогда
			НачалоРаботыСПрограммойКлиент.ОбработкаЗакрытияФормыНачалаРаботыПриОшибке(
			РезультатФормыНачалаРаботы, КэшЗначений.ПараметрыНачалаРаботы);
			Возврат;
		КонецЕсли;
		
		УстановитьШагПриСоздании();
		
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьРаботуОбработчик()
	
	ЗавершитьРаботуСистемы(Ложь, ПерезапуститьПриЗавершенииПриНеудачномЗавершении, ДополнительныеПараметрыПриНеудачномЗавершении);
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура СайтПриИзмененииНаСервере(ИмяЭлемента)
	
	Индекс = ИндексПоИмениЭлемента(ИмяЭлемента, "Сайт");
	Если Индекс = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеСайта = ЭтотОбъект["Сайт" + Индекс];
	
	ДобавитьКИОрганизации(Индекс, Справочники.ВидыКонтактнойИнформации.СайтОрганизации, ЗначениеСайта);
	
КонецПроцедуры

#КонецОбласти