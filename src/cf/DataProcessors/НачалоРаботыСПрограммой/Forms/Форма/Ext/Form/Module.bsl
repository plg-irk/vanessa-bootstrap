	ФИО.ПутьКДанным = "ФИО" + ПостФикс;
	ФИО.УстановитьДействие("ПриИзменении", "ФИОПриИзменении");
	ФИО.УстановитьДействие("АвтоПодбор", "ФИОАвтоПодбор");
	НаследоватьСвойстваПоляВвода(ФИО, Элементы.ФИО1, ЗначенияСвойствЭлементов);
	
	// Сайт
	ГруппаСайт = Элементы.Добавить("ГруппаСайт" + ПостФикс, Тип("ГруппаФормы"), ДанныеОрганизацииЛево);
