&НаСервере
Процедура КэшироватьСвойстваЭлементовФормы()
	
	ЗначенияСвойствЭлементов = Новый Соответствие;
	
	НаследуемыеПоляВвода = Новый Массив;
	НаследуемыеПоляВвода.Добавить(Элементы.ИНН1);
	НаследуемыеПоляВвода.Добавить(Элементы.Наименование1);
	НаследуемыеПоляВвода.Добавить(Элементы.ФИО1);
	НаследуемыеПоляВвода.Добавить(Элементы.Сайт1);
	НаследуемыеПоляВвода.Добавить(Элементы.СистемаНалогообложения1);
	НаследуемыеПоляВвода.Добавить(Элементы.СтавкаНалога1);
	НаследуемыеПоляВвода.Добавить(Элементы.СтавкаНДС1);
	НаследуемыеСвойстваПоляВвода = НаследуемыеСвойстваПоляВвода();
	Для каждого Элемент Из НаследуемыеПоляВвода Цикл
		СвойстваЭлемента = СтруктураСвойствЭлементаФормы(Элемент, НаследуемыеСвойстваПоляВвода);
		ЗначенияСвойствЭлементов.Вставить(Элемент.Имя, СвойстваЭлемента);
	КонецЦикла;
	
	НаследуемыеПоляПереключателя = Новый Массив;
	НаследуемыеПоляПереключателя.Добавить(Элементы.ЮридическоеФизическоеЛицо1);
	НаследуемыеПоляПереключателя.Добавить(Элементы.ВидыОбъектовНалогообложения1);
	НаследуемыеСвойстваПоляПереключателя = НаследуемыеСвойстваПоляПереключателя();
	Для каждого Элемент Из НаследуемыеПоляПереключателя Цикл
		СвойстваЭлемента = СтруктураСвойствЭлементаФормы(Элемент, НаследуемыеСвойстваПоляПереключателя);
		ЗначенияСвойствЭлементов.Вставить(Элемент.Имя, СвойстваЭлемента);
	КонецЦикла;
	
	НаследуемыеПоляФлажка = Новый Массив;
	НаследуемыеПоляФлажка.Добавить(Элементы.ИПИспользуетТрудНаемныхРаботников1);
	НаследуемыеСвойстваПоляФлажка = НаследуемыеСвойстваПоляФлажка();
	Для каждого Элемент Из НаследуемыеПоляФлажка Цикл
		СвойстваЭлемента = СтруктураСвойствЭлементаФормы(Элемент, НаследуемыеСвойстваПоляФлажка);
		ЗначенияСвойствЭлементов.Вставить(Элемент.Имя, СвойстваЭлемента);
	КонецЦикла;
	
	НаследуемыеПоляКартинки = Новый Массив;
	НаследуемыеПоляКартинки.Добавить(Элементы.АдресЛоготипа1);
	НаследуемыеСвойстваПоляКартинки = НаследуемыеСвойстваПоляКартинки();
	Для каждого Элемент Из НаследуемыеПоляКартинки Цикл
		СвойстваЭлемента = СтруктураСвойствЭлементаФормы(Элемент, НаследуемыеСвойстваПоляКартинки);
		ЗначенияСвойствЭлементов.Вставить(Элемент.Имя, СвойстваЭлемента);
	КонецЦикла;
	
	НаследуемыеГруппыФормы = Новый Массив;
	НаследуемыеГруппыФормы.Добавить(Элементы.ДанныеОрганизации1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ДанныеОрганизацииЛево1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаИНН1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаФормаСобственности1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаНаименование1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаПодсказкиНаименования1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаФИО1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаПодсказкиФИО1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаСайт1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаСН1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаОблагаетсяНалогом1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаНалоговаяСтавка1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаСтавкаНДС1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ДанныеОрганизацииПраво1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаФормаСобственностиМК1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаСНМК1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаОблагаетсяНалогомМК1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаНалоговаяСтавкаМК1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаСтавкаНДСМК1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаЛоготипМК1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаПодсказкаИПолеИНН1);
	НаследуемыеГруппыФормы.Добавить(Элементы.ГруппаОшибокИНН1);
	НаследуемыеСвойстваГруппыФормы = НаследуемыеСвойстваГруппыФормы();
	Для каждого Элемент Из НаследуемыеГруппыФормы Цикл
		СвойстваЭлемента = СтруктураСвойствЭлементаФормы(Элемент, НаследуемыеСвойстваГруппыФормы);
		ЗначенияСвойствЭлементов.Вставить(Элемент.Имя, СвойстваЭлемента);
	КонецЦикла;
	
	НаследуемыеДекорацииФормы = Новый Массив;
	НаследуемыеДекорацииФормы.Добавить(Элементы.ИННЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ИННОшибкаВвода1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ФормаСобственностиЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.НаименованиеЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ДекорацияОбязательногоПоляНаименование1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ФИОЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ДекорацияОбязательногоПоляФИО1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.СайтЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.СНЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ОблагаетсяНалогомЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.НалоговаяСтавкаЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.СтавкаНДСЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ЛоготипЗаголовок1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ЛоготипСсылка1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ОтступОшибокИНН1);
	НаследуемыеДекорацииФормы.Добавить(Элементы.ИННОшибкаВвода1);
	НаследуемыеСвойстваДекорацииФормы = НаследуемыеСвойстваДекорацииФормы();
	Для каждого Элемент Из НаследуемыеДекорацииФормы Цикл
		СвойстваЭлемента = СтруктураСвойствЭлементаФормы(Элемент, НаследуемыеСвойстваДекорацииФормы);
		ЗначенияСвойствЭлементов.Вставить(Элемент.Имя, СвойстваЭлемента);
	КонецЦикла;
	
	КэшЗначенийСвойствЭлементовАдрес = ПоместитьВоВременноеХранилище(ЗначенияСвойствЭлементов, УникальныйИдентификатор);
	
