#Область Интерфейс

&НаСервере
Процедура ОпределитьИнтерфейсПоШагу()
	
	ВидимостьШапки = Ложь;
	ВидимостьНомераШага = Ложь;
	ВидимостьПодсказкиШага = Ложь;
	ЗаголовокНомераШага = "";
	ЗаголовокЗаголовкаШага = "";
	ЗаголовокПодсказкиШага = "";
	ВидимостьОтступаШапки = Ложь;
	
	ВидимостьШага1 = Ложь;
	ВидимостьШага2 = Ложь;
	ВидимостьШага3 = Ложь;
	ВидимостьШага4 = Ложь;
	
	ВидимостьДанныхОрганизации = Ложь;
	
	ВидимостьПодвала = Ложь;
	ВидимостьКнопкиНазад = Ложь;
	ВидимостьКнопкиПродолжить = Ложь;
	ВидимостьКнопкиНачатьРаботу = Ложь;
	
	ТекущийШаг = Элементы.СтраницыКонтента.ТекущаяСтраница;
	Если ТекущийШаг = Элементы.СтраницаШаг1 Тогда
		
		ВидимостьШапки = Истина;
		ВидимостьНомераШага = Истина;
		ВидимостьПодсказкиШага = Истина;
		Если Не ОтображатьВыборВидаБизнеса Тогда
			ЗаголовокНомераШага = НСтр("ru = 'Шаг 1 из 2'");
		Иначе
			ЗаголовокНомераШага = НСтр("ru = 'Шаг 1 из 3'");
		КонецЕсли;
		ЗаголовокЗаголовкаШага = НСтр("ru = 'Заполните информацию о себе'");
		ЗаголовокПодсказкиШага = НСтр("ru = 'Перед началом работы, пожалуйста, расскажите немного о вас и вашей организации. 
		|Это поможет настроить приложение максимально эффективно для вас.'");
		ВидимостьОтступаШапки = Истина;
		
		ВидимостьШага1 = Истина;
		
		ВидимостьПодвала = Истина;
		ВидимостьКнопкиПродолжить = Истина;
		
	ИначеЕсли ТекущийШаг = Элементы.СтраницаШаг2 Тогда
		
		ВидимостьШапки = Истина;
		ВидимостьНомераШага = Истина;
		ВидимостьПодсказкиШага = Истина;
		Если РазделениеВключено Тогда
			ЗаголовокНомераШага = НСтр("ru = 'Шаг 1 из 2'");
		Иначе
			ЗаголовокНомераШага = НСтр("ru = 'Шаг 2 из 3'");
		КонецЕсли;
		ЗаголовокЗаголовкаШага = НСтр("ru = 'Вид вашего бизнеса'");
		ЗаголовокПодсказкиШага = НСтр("ru = 'Выберите пункты, наиболее точно описывающие ваш бизнес, это поможет настроить
		|приложение именно для ваших задач.'");
		ВидимостьОтступаШапки = Истина;
		
		ВидимостьШага2 = Истина;
		
		ВидимостьПодвала = Истина;
		ВидимостьКнопкиНазад = Не РазделениеВключено;
		ВидимостьКнопкиПродолжить = Истина;
		
	ИначеЕсли ТекущийШаг = Элементы.СтраницаШаг3 Тогда
		
		ПоказатьДанныеОрганизации = Не РазделениеВключено Или Не ПодключенаИПП Или ЗавершеноЗаданиеПолученияДанныхОрганизацииСервиса;
		
		ВидимостьШапки = Истина;
		ВидимостьНомераШага = Не РазделениеВключено Или ОтображатьВыборВидаБизнеса;
		ВидимостьПодсказкиШага = ПоказатьДанныеОрганизации;
		Если РазделениеВключено Или Не ОтображатьВыборВидаБизнеса Тогда
			ЗаголовокНомераШага = НСтр("ru = 'Шаг 2 из 2'");
		Иначе
			ЗаголовокНомераШага = НСтр("ru = 'Шаг 3 из 3'");
		КонецЕсли;
		ЗаголовокЗаголовкаШага = НСтр("ru = 'Ваша организация'");
		ЗаголовокПодсказкиШага = НСтр("ru = 'Укажите информацию о своей организации, чтобы автоматически использовать ее
		|при оформлении документов.'");
		ВидимостьОтступаШапки = ПоказатьДанныеОрганизации;
		
		ВидимостьШага3 = Истина;
		
		ВидимостьДанныхОрганизации = ПоказатьДанныеОрганизации;
		
		ВидимостьПодвала = Истина;
		ВидимостьКнопкиНазад = Не РазделениеВключено Или ОтображатьВыборВидаБизнеса;
		ВидимостьКнопкиНачатьРаботу = Истина;
		
	ИначеЕсли ТекущийШаг = Элементы.СтраницаШаг4 Тогда
		
		ВидимостьШага4 = Истина;
		
	Иначе
		Возврат;
	КонецЕсли;
	
	Элементы.Шапка.Видимость = ВидимостьШапки;
	Элементы.НомерШага.Видимость = ВидимостьНомераШага;
	Элементы.НомерШага.Заголовок = ЗаголовокНомераШага;
	Элементы.ЗаголовокШага.Заголовок = ЗаголовокЗаголовкаШага;
	Элементы.ПодсказкаШага.Видимость = ВидимостьПодсказкиШага;
	Элементы.ПодсказкаШага.Заголовок = ЗаголовокПодсказкиШага;
	Элементы.ОтступОтШапки.Видимость = ВидимостьОтступаШапки;
	
	Элементы.СтраницаШаг1.Видимость = ВидимостьШага1;
	Элементы.СтраницаШаг2.Видимость = ВидимостьШага2;
	Элементы.СтраницаШаг3.Видимость = ВидимостьШага3;
	Элементы.СтраницаШаг4.Видимость = ВидимостьШага4;
	
	Элементы.ДанныеОрганизаций.Видимость = ВидимостьДанныхОрганизации;
	Элементы.ЗагрузкаДанныхОрганизации.Видимость = Не ВидимостьДанныхОрганизации;
	
	Элементы.Подвал.Видимость = ВидимостьПодвала;
	Элементы.Назад.Видимость = ВидимостьКнопкиНазад;
	Элементы.Продолжить.Видимость = ВидимостьКнопкиПродолжить;
	Элементы.НачатьРаботуСПрограммой.Видимость = ВидимостьКнопкиНачатьРаботу;
	Элементы.НачатьРаботуСПрограммой.Доступность = ВидимостьДанныхОрганизации;
	
	Если ВидимостьКнопкиПродолжить Тогда
		Элементы.Продолжить.КнопкаПоУмолчанию = Истина;
	Иначе
		Элементы.НачатьРаботуСПрограммой.КнопкаПоУмолчанию = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсПодключенияИТС()
	
	Если Не ДоступноПодключениеИнтернетПоддержки Тогда
		Возврат;
	КонецЕсли;
	
	ВидимостьПодключения = Ложь;
	ВидимостьОтключения = Ложь;
	ЗаголовокПрофиля = "";
	
	Если Не ПодключенаИПП Тогда
		
		ВидимостьПодключения = Истина;
		
	Иначе
		
		ВидимостьОтключения = Истина;
		ЗаголовокПрофиля = ЛогинИнтернетПоддержки;
		
	КонецЕсли;
	
	Элементы.ПодключитьПрофильИТС.Видимость = ВидимостьПодключения;
	Элементы.ОтключениеПрофиляИТС.Видимость = ВидимостьОтключения;
	Элементы.ПрофильИТС.Заголовок = ЗаголовокПрофиля;
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсВидовБизнеса()
	
	Элементы.ВидБизнесаОптоваяТорговля.ЦветФона = ЦветФонаКнопки;
	Элементы.ВидБизнесаРозничнаяТорговля.ЦветФона = ЦветФонаКнопки;
	Элементы.ВидБизнесаИнтернетМагазин.ЦветФона = ЦветФонаКнопки;
	Элементы.ВидБизнесаРаботыУслуги.ЦветФона = ЦветФонаКнопки;
	Элементы.ВидБизнесаПроизводство.ЦветФона = ЦветФонаКнопки;
	Элементы.ВидБизнесаДругое.ЦветФона = ЦветФонаКнопки;
	
	Элементы.ВидБизнесаОптоваяТорговля.Картинка = БиблиотекаКартинок.ВидБизнесаОптоваяТорговляОключен;
	Элементы.ВидБизнесаРозничнаяТорговля.Картинка = БиблиотекаКартинок.ВидБизнесаРозничнаяТорговляОтключен;
	Элементы.ВидБизнесаИнтернетМагазин.Картинка = БиблиотекаКартинок.ВидБизнесаИнтернетМагазинОтключен;
	Элементы.ВидБизнесаРаботыУслуги.Картинка = БиблиотекаКартинок.ВидБизнесаРаботыУслугиОтключен;
	Элементы.ВидБизнесаПроизводство.Картинка = БиблиотекаКартинок.ВидБизнесаПроизводствоОтключен;
	Элементы.ВидБизнесаДругое.Картинка = БиблиотекаКартинок.ВидБизнесаДругоеОтключен;
	
	Для Каждого ВидБизнеса Из ВидыБизнеса Цикл
		
		НазваниеКнопки = СтрШаблон("ВидБизнеса%1", ВидБизнеса.Значение);
		НазваниеКартинки = СтрШаблон("ВидБизнеса%1", ВидБизнеса.Значение);
		
		Если НазваниеКартинки = "ВидБизнесаРозничнаяТорговля" Тогда
			НазваниеКартинки = "ВидБизнесаРозничнаяТорговляВключен";
		ИначеЕсли НазваниеКартинки = "ВидБизнесаРаботыУслуги" Тогда
			НазваниеКартинки = "ВидБизнесаРаботыУслугиВключен";
		КонецЕсли;
		
		Элементы[НазваниеКнопки].ЦветФона = ЦветФонУправляющегоПоля;
		Элементы[НазваниеКнопки].Картинка = БиблиотекаКартинок[НазваниеКартинки];
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеФормой(ИндексОрганизации)
	
	ЭтоЮрЛицо = (ЭтотОбъект["ЮридическоеФизическоеЛицо" + ИндексОрганизации] = КэшЗначений.ЮрЛицо);
	
	Элементы["ГруппаОшибокИНН" + ИндексОрганизации].Видимость =
	ЗначениеЗаполнено(ЭтотОбъект["ИНН" + ИндексОрганизации])
	И ЗначениеЗаполнено(Элементы["ИННОшибкаВвода" + ИндексОрганизации].Заголовок);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
	Элементы, "ГруппаНаименование" + ИндексОрганизации, "Видимость", ЭтоЮрЛицо);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
	Элементы, "ГруппаФИО" + ИндексОрганизации, "Видимость", Не ЭтоЮрЛицо);
	
	Если Не ОтображатьРеквизитыНалогообложения Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеСистемаНалогообложения = ЭтотОбъект["СистемаНалогообложения" + ИндексОрганизации];
	ЭтоУСН = ЭтоУСН(ЗначениеСистемаНалогообложения);
	ЭтоАУСН = ЭтоАУСН(ЗначениеСистемаНалогообложения);
	ВключаетНДС = ВключаетНДС(ЗначениеСистемаНалогообложения);
	
	СписокВыбораСНО = Элементы["СистемаНалогообложения" + ИндексОрганизации].СписокВыбора;
	СписокЗначенийСНО = СписокЗначенийСНО(ЭтоЮрЛицо);
	
	СписокВыбораСНО.Очистить();
	Для Каждого ДанныеВыбора Из СписокЗначенийСНО Цикл
		Элемент = СписокВыбораСНО.Добавить();
		ЗаполнитьЗначенияСвойств(Элемент, ДанныеВыбора);
	КонецЦикла;
	
	НужноУказыватьПараметрыНО = Не ЭтоЮрЛицо И (ЭтоУСН ИЛИ ЭтоАУСН);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
	Элементы, "ГруппаОблагаетсяНалогом" + ИндексОрганизации, "Видимость", НужноУказыватьПараметрыНО);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
	Элементы, "ГруппаНалоговаяСтавка" + ИндексОрганизации, "Видимость", НужноУказыватьПараметрыНО);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
	Элементы, "ИПИспользуетТрудНаемныхРаботников" + ИндексОрганизации, "Видимость", НужноУказыватьПараметрыНО);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
	Элементы, "ГруппаСтавкаНДС" + ИндексОрганизации, "Видимость", ВключаетНДС);
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсМобильногоКлиентаПриСоздании()
	
	Если Не ЭтоМобильныйКлиент Тогда
		Возврат;
	КонецЕсли;
	
	ШиринаПоляШага1 = 25;
	ШиринаПодсказкиШага1 = 14;
	
	Элементы.Экраны.Видимость = Ложь;
	
	Элементы.ИмяПользователя.МаксимальнаяШирина = ШиринаПоляШага1;
	Элементы.Телефон.МаксимальнаяШирина = ШиринаПоляШага1;
	Элементы.Телефон.Ширина = 0;
	Элементы.Email.МаксимальнаяШирина = ШиринаПоляШага1;
	Элементы.Пароль.МаксимальнаяШирина = ШиринаПоляШага1;
	Элементы.ПарольПодтверждение.МаксимальнаяШирина = ШиринаПоляШага1;
	
	Элементы.ГруппаПодсказкиИмяПользователя.Ширина = ШиринаПодсказкиШага1;
	Элементы.ТелефонЗаголовок.Ширина = ШиринаПодсказкиШага1;
	Элементы.EmailЗаголовок.Ширина = ШиринаПодсказкиШага1;
	Элементы.ПарольЗаголовок.Ширина = ШиринаПодсказкиШага1;
	Элементы.ГруппаПовтораПароляМК.Ширина = ШиринаПодсказкиШага1;
	
	Элементы.Подвал.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Элементы.Подвал.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Центр;
	Элементы.ПодвалОтступСправа.Видимость = Ложь;
	
	ОпределитьИнтерфейсОрганизацийПоМК();
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсОрганизацийПоМК()
	
	Если Не ЭтоМобильныйКлиент Тогда
		Возврат;
	КонецЕсли;
	
	ИндексыОрганизаций = ИндексыОрганизаций();
	КоличествоОрганизаций = ИндексыОрганизаций.Количество();
	
	Если КоличествоОрганизаций = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ШиринаПодсказки = 14;
	ШиринаПодсказкиСПереключателем = 17;
	ШиринаПодсказкиСПереключателемУПоследнейОрганизации = 20;
	
	Для Каждого Индекс Из ИндексыОрганизаций Цикл
		
		Элементы["ИННЗаголовок" + Индекс].Ширина = ШиринаПодсказки;
		Элементы["ГруппаПодсказкиНаименования" + Индекс].Ширина = ШиринаПодсказки;
		Элементы["ГруппаПодсказкиФИО" + Индекс].Ширина = ШиринаПодсказки;
		Элементы["СайтЗаголовок" + Индекс].Ширина = ШиринаПодсказки;
		
		Если Индекс > 1 И Индекс = КоличествоОрганизаций Тогда
			Элементы["ГруппаФормаСобственностиМК" + Индекс].Ширина = ШиринаПодсказкиСПереключателемУПоследнейОрганизации;
		Иначе
			Элементы["ГруппаФормаСобственностиМК" + Индекс].Ширина = ШиринаПодсказкиСПереключателем;
		КонецЕсли;
		
		Если ОтображатьРеквизитыНалогообложения Тогда
			
			Элементы["ГруппаСНМК" + Индекс].Ширина = ШиринаПодсказки;
			Элементы["СНЗаголовок" + Индекс].Ширина = ШиринаПодсказки;
			Элементы["ГруппаНалоговаяСтавкаМК" + Индекс].Ширина = ШиринаПодсказки;
			Элементы["ГруппаСтавкаНДСМК" + Индекс].Ширина = ШиринаПодсказки;
			
			Если Индекс > 1 И Индекс = КоличествоОрганизаций Тогда
				Элементы["ГруппаОблагаетсяНалогомМК" + Индекс].Ширина = ШиринаПодсказкиСПереключателемУПоследнейОрганизации;
			Иначе
				Элементы["ГруппаОблагаетсяНалогомМК" + Индекс].Ширина = ШиринаПодсказкиСПереключателем;
			КонецЕсли;
			
		КонецЕсли;
		
		Элементы["ДанныеОрганизацииПраво" + Индекс].Видимость = Ложь;
		Элементы["ГруппаЛоготипМК" + Индекс].Видимость = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуМобильноеПриложение()
	
	Если МобильноеПриложениеВызовСервера.ЕстьОграничениеМобильногоУНФ()
		ИЛИ МобильноеПриложениеВызовСервера.ЕстьОграничениеМобильногоУНФ20() Тогда
		
		УстановитьШаг(1);
		
		Элементы.НомерШага.Видимость = Ложь;
		Элементы.Назад.Видимость = Ложь;
		Элементы.Продолжить.Видимость = Ложь;
		Элементы.НачатьРаботуСПрограммой.Видимость = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуОграниченияКонфигурации()
	
	Элементы.ГруппаПрофильИТС.Видимость = ДоступноПодключениеИнтернетПоддержки;
	Элементы.ДобавитьОрганизацию.Видимость = Не ЭтоБазоваяВерсияКонфигурации;
	
	Элементы.ГруппаСН1.Видимость = ОтображатьРеквизитыНалогообложения;
	Элементы.ГруппаОблагаетсяНалогом1.Видимость = ОтображатьРеквизитыНалогообложения;
	Элементы.ГруппаНалоговаяСтавка1.Видимость = ОтображатьРеквизитыНалогообложения;
	Элементы.ГруппаСтавкаНДС1.Видимость = ОтображатьРеквизитыНалогообложения;
	Элементы.ИПИспользуетТрудНаемныхРаботников1.Видимость = ОтображатьРеквизитыНалогообложения;
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсЛоготипаМК(Индекс, ИмяФайла)
	
	Если ПустаяСтрока(ИмяФайла) Тогда
		ЗаголовокЭлемента = НСтр("ru = 'Выбрать...'");
	Иначе
		ЗаголовокЭлемента = ИмяФайла;
	КонецЕсли;
	
	Элементы["ЛоготипСсылка" + Индекс].Заголовок = ЗаголовокЭлемента;
	
КонецПроцедуры

#КонецОбласти

