
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДобавитьОрганизацию(Ложь, Справочники.Организации.ОсновнаяОрганизация);
	
	ЗаполнитьКэшЗначений();
	ПолучитьГлобальныеНастройки();
	ЗаполнитьПостоянныеРеквизиты();
	ЗаполнитьДанныеПользователяБазы();
	
	НастроитьФормуОграниченияКонфигурации();
	
	УстановитьШагПриСоздании();
	ОпределитьИнтерфейсПодключенияИТС();
	ОпределитьИнтерфейсВидовБизнеса();
	
	УправлениеФормой(1);
	НастроитьФормуМобильноеПриложение();
	ОпределитьИнтерфейсМобильногоКлиентаПриСоздании();
	
	Если РазделениеВключено И ПодключенаИПП Тогда
		НачатьПолучениеДанныхОрганизацииВФоне();
	КонецЕсли;     
	
	СтатистикаПоПоказателямКлиентСервер.ДобавитьСобытие("НачалоРаботыСПрограммой.ОткрытиеФормы");
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если РазделениеВключено И ПодключенаИПП Тогда
		ЗаполнитьДанныеОрганизацииВФоне();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_Файл" Тогда
		ОбновитьИзображениеЛоготипа(Источник);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы <> Истина Тогда
		
		Если НЕ КэшЗначений.РазрешитьЗакрытие Тогда
			
			ТекстПредупреждения = НСтр("ru ='Заполните, пожалуйста, обязательные поля.
				|Работа программы без указанных сведений затруднительна.'");
				
			ПоказатьПредупреждение(, ТекстПредупреждения);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ЮрФизЛицоПриИзменении(Элемент)
	
	Индекс = ИндексПоИмениЭлемента(Элемент.Имя, "ЮридическоеФизическоеЛицо");
	Если Индекс = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеЮридическоеФизическоеЛицо = ЭтотОбъект["ЮридическоеФизическоеЛицо" + Индекс];
	
	Если ЗначениеЮридическоеФизическоеЛицо = КэшЗначений.ЮрЛицо Тогда
		ПредыдущееЗначение = КэшЗначений.ФизЛицо;
	Иначе
		ПредыдущееЗначение = КэшЗначений.ЮрЛицо;
	КонецЕсли;
	
	ЗаписатьЗначениеОрганизацииЮрФизЛицо(ЗначениеЮридическоеФизическоеЛицо, ПредыдущееЗначение, Индекс);
	
	ЭтотОбъект["ИНН" + Индекс] = "";
	ЗаписатьЗначениеОрганизации("ИНН", "", Индекс);
	
	ЗаписатьНаименованиеПлательщикаПриПеречисленииНалогов(Индекс);
	
	УправлениеФормой(Индекс);
	
КонецПроцедуры

&НаКлиенте
Процедура НаименованиеПриИзменении(Элемент)
	
	Индекс = ИндексПоИмениЭлемента(Элемент.Имя, "Наименование");
	Если Индекс = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеНаименование = ЭтотОбъект["Наименование" + Индекс];
	
	ЗаписатьЗначениеОрганизации("Наименование", ЗначениеНаименование, Индекс);
	ЗаписатьЗначениеОрганизации("НаименованиеПолное", ЗначениеНаименование, Индекс);
	ЗаписатьЗначениеОрганизации("НаименованиеСокращенное", ЗначениеНаименование, Индекс);
	
	ЗаписатьНаименованиеПлательщикаПриПеречисленииНалогов(Индекс);    
	
	Если ЗначениеЗаполнено(Наименование1) Тогда
		СтатистикаПоПоказателямКлиентСервер.ДобавитьСобытие("НачалоРаботыСПрограммой.ВводНазвания");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФИОПриИзменении(Элемент)
	
	Индекс = ИндексПоИмениЭлемента(Элемент.Имя, "ФИО");
	Если Индекс = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьЗначениеОрганизации("ФИО", ЭтотОбъект["ФИО" + Индекс], Индекс);
	
	ОбработатьИзменениеФИОИП(Индекс);
	
	ЗаписатьНаименованиеПлательщикаПриПеречисленииНалогов(Индекс);
	
КонецПроцедуры

&НаКлиенте
Процедура ФИОАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	Если Не РазделениеВключено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстДляАвтоПодбора = СокрЛП(Текст);
	Если СтрДлина(ТекстДляАвтоПодбора) < 1 Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФИО = Новый Структура("Представление", ТекстДляАвтоПодбора);
	
	Попытка
		ДанныеКлассификатора = ПодборФИОКлиент.Подобрать("ФИО", ДанныеФИО, 0);
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЖурналРегистрацииКлиент.ДобавитьСообщениеДляЖурналаРегистрации(
		НачалоРаботыСПрограммойКлиентСервер.ИмяСобытияЖР(),
		"Ошибка",
		ТекстОшибки);
		Возврат;
		
	КонецПопытки;
	
	ДанныеВыбора = Новый СписокЗначений;
	Для Каждого ЗначениеКлассификатора Из ДанныеКлассификатора Цикл
		ДанныеВыбора.Добавить(ЗначениеКлассификатора, ЗначениеКлассификатора);
	КонецЦикла;
	
	Если ДанныеВыбора.Количество() > 0 Тогда
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СайтПриИзменении(Элемент)
	
	СайтПриИзмененииНаСервере(Элемент.Имя);
	Если ЗначениеЗаполнено(Сайт1) Тогда
		СтатистикаПоПоказателямКлиентСервер.ДобавитьСобытие("НачалоРаботыСПрограммой.ВводСайта");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НалогообложениеПриИзменении(Элемент)
	
	Индекс = ИндексПоИмениЭлемента(Элемент.Имя, "ВидыОбъектовНалогообложения");
	Если Индекс = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеНалогообложение = ЭтотОбъект["ВидыОбъектовНалогообложения" + Индекс];
	ЗаписатьЗначениеОрганизации("ВидыОбъектовНалогообложения", ЗначениеНалогообложение, Индекс);
	
	ЗначениеСНО = ЭтотОбъект["СистемаНалогообложения" + Индекс];
	ЭтоАУСН = ЭтоАУСН(ЗначениеСНО);
	ЭтоУСН = ЭтоУСН(ЗначениеСНО);
	
	Если ЭтоАУСН Тогда
		ЗначениеСтавкаНалога = ?(ЗначениеНалогообложение = КэшЗначений.Доходы, 8, 20);
	ИначеЕсли ЭтоУСН Тогда
		ЗначениеСтавкаНалога = ?(ЗначениеНалогообложение = КэшЗначений.Доходы, 6, 15);
	Иначе
		ЗначениеСтавкаНалога = 0;
	КонецЕсли;
	
	ЭтотОбъект["СтавкаНалога" + Индекс] = ЗначениеСтавкаНалога;
	ЗаписатьЗначениеОрганизации("СтавкаНалога", ЗначениеСтавкаНалога, Индекс);
	
КонецПроцедуры

