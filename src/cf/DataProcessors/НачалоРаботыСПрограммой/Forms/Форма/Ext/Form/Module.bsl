		НаследоватьСвойстваДекорацииФормы(СНЗаголовок, Элементы.СНЗаголовок1, ЗначенияСвойствЭлементов);
		
		СистемаНалогообложения = Элементы.Добавить("СистемаНалогообложения" + ПостФикс, Тип("ПолеФормы"), ГруппаСН);
