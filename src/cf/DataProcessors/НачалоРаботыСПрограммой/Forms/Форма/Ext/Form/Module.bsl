	ГруппаПодсказкаИПолеИНН = Элементы.Добавить("ГруппаПодсказкаИПолеИНН" + ПостФикс, Тип("ГруппаФормы"), ГруппаИНН);
	ГруппаПодсказкаИПолеИНН.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НаследоватьСвойстваГруппыФормы(ГруппаПодсказкаИПолеИНН, Элементы.ГруппаПодсказкаИПолеИНН1, ЗначенияСвойствЭлементов);
	
	ИННЗаголовок = Элементы.Добавить("ИННЗаголовок" + ПостФикс, Тип("ДекорацияФормы"), ГруппаПодсказкаИПолеИНН);
	ИННЗаголовок.Вид = ВидДекорацииФормы.Надпись;
	НаследоватьСвойстваДекорацииФормы(ИННЗаголовок, Элементы.ИННЗаголовок1, ЗначенияСвойствЭлементов);
	
	ИНН = Элементы.Добавить("ИНН" + ПостФикс, Тип("ПолеФормы"), ГруппаПодсказкаИПолеИНН);
