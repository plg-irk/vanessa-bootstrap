КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НачатьРаботуСПрограммой(Команда)
	
	ОчиститьСообщения();
	ПроверитьЗаполнениеФормы(3);
	Если Не КэшЗначений.РазрешитьЗакрытие Тогда
		Возврат;
	КонецЕсли;
	
	СтатистикаПоПоказателямКлиентСервер.ДобавитьСобытие("НачалоРаботыСПрограммой.КнопкаНачатьРаботу");
	Если РазделениеВключено Тогда
		ПродолжитьНачалоРаботы();
	Иначе
		УстановитьШаг(4);
		КоличествоОжиданий = 3;
		ОжидатьНачалаРаботыСПрограммой();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикКомандыДобавитьОрганизацию(Команда)
	
	ОбработчикКомандыДобавитьОрганизациюНаСервере();
	СтатистикаПоПоказателямКлиентСервер.ДобавитьСобытие("НачалоРаботыСПрограммой.КнопкаДобавитьОрганизацию");
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзображениеЛоготипа(Команда)
	
	Если ТекущийЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли; 

	ИндексОрганизации = ИндексПоИмениЭлемента(ТекущийЭлемент.Имя, "АдресЛоготипа");
	Если ИндексОрганизации = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьИзображениеНаКлиенте(ИндексОрганизации);
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьИзображениеЛоготипа(Команда)

	Если ТекущийЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	ИндексОрганизации = ИндексПоИмениЭлемента(ТекущийЭлемент.Имя, "АдресЛоготипа");
	Если ИндексОрганизации = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьЗначениеОрганизации("ФайлЛоготип", Неопределено, ИндексОрганизации);
	ЭтотОбъект["АдресЛоготипа" + ИндексОрганизации] = "";
	
КонецПроцедуры

