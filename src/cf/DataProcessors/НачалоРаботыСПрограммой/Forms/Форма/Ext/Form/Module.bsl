#Область АвтоматическоеЗаполнениеДанныхОрганизации

&НаСервере
Процедура НачатьПолучениеДанныхОрганизацииВФоне()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	ДлительнаяОперацияПолученияДанныхОрганизации = ДлительныеОперации.ВыполнитьФункцию(
	ПараметрыВыполнения, "НачалоРаботыСПрограммойСервер.ПолучитьДанныеОрганизацииССервиса");
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеОрганизацииВФоне()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗаполнитьДанныеОрганизацииВФонеЗавершение", ЭтотОбъект);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Ложь;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперацияПолученияДанныхОрганизации, ОписаниеОповещения, ПараметрыОжидания);
	
	ПодключитьОбработчикОжидания("ЗаполнитьДанныеОрганизацииВФонеОжидание", 15, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеОрганизацииВФонеОжидание()
	
	ЗаполнитьДанныеОрганизацииВФонеОжиданиеНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеОрганизацииВФонеОжиданиеНаСервере()
	
	Если ТипЗнч(ДлительнаяОперацияПолученияДанныхОрганизации) = Тип("Структура")
		И ДлительнаяОперацияПолученияДанныхОрганизации.Свойство("ИдентификаторЗадания") Тогда
		ДлительныеОперации.ОтменитьВыполнениеЗадания(ДлительнаяОперацияПолученияДанныхОрганизации.ИдентификаторЗадания);
	КонецЕсли;
	
	ЗавершеноЗаданиеПолученияДанныхОрганизацииСервиса = Истина;
	ОпределитьИнтерфейсПоШагу();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеОрганизацииВФонеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ОтключитьОбработчикОжидания("ЗаполнитьДанныеОрганизацииВФонеОжидание");
	ЗаполнитьДанныеОрганизацииВФонеЗавершениеНаСервере(Результат);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеОрганизацииВФонеЗавершениеНаСервере(Результат)
	
	Попытка
		
		ЗавершеноЗаданиеПолученияДанныхОрганизацииСервиса = Истина;
		ОпределитьИнтерфейсПоШагу();
		
		Если Результат = Неопределено Или Результат.Статус <> "Выполнено" Тогда
			Возврат;
		КонецЕсли;
		
		ДанныеОрганизации = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если ДанныеОрганизации = Неопределено Или ДанныеОрганизации.ИНН = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ИНН = ДанныеОрганизации.ИНН;
		
		ИндексОрганизации = 1;
		ЭтотОбъект["ИНН" + ИндексОрганизации] = ИНН;
		ЗаписатьЗначениеОрганизацииНаСервере("ИНН", ИНН, ИндексОрганизации);
		
		ЗначениеЮрФизЛицо = ?(СтрДлина(ИНН) = 12, КэшЗначений.ФизЛицо, КэшЗначений.ЮрЛицо);
		ЭтотОбъект["ЮридическоеФизическоеЛицо" + ИндексОрганизации] = ЗначениеЮрФизЛицо;
		ЗаписатьЗначениеОрганизацииЮрФизЛицоНаСервере(ЗначениеЮрФизЛицо, ИндексОрганизации);
		
		Если ПодключенаИПП И ДанныеОрганизации.ДанныеГосРеестра <> Неопределено Тогда
			ОбработкаПриИзмененииИНН(ИндексОрганизации, ИНН, ДанныеОрганизации.ДанныеГосРеестра);
		КонецЕсли;
		
		ЗаписатьНаименованиеПлательщикаПриПеречисленииНалоговНаСервере(ИндексОрганизации);
		
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(
		НачалоРаботыСПрограммойКлиентСервер.ИмяСобытияЖР(),
		УровеньЖурналаРегистрации.Ошибка,
		Метаданные.Обработки.НачалоРаботыСПрограммой, ,
		ТекстОшибки);
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ЗаполнитьДанныеПользователяБазы()
	
	ПользовательСсылка = КэшЗначений.Пользователь;
	
	Если РазделениеВключено Тогда
		
		ПользовательИмя = ПользовательСсылка.Наименование;
		
		УстановитьПривилегированныйРежим(Истина);
		ПрочитанныеСвойства = Пользователи.СвойстваПользователяИБ(ПользовательСсылка.ИдентификаторПользователяИБ);
		УстановитьПривилегированныйРежим(Ложь);
		
		КэшЗначений.Вставить("ИмяПользователяВСервисе", ПрочитанныеСвойства.Имя);
		
	КонецЕсли;
	
	ПользовательEmail = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
	ПользовательСсылка, Справочники.ВидыКонтактнойИнформации.EmailПользователя);
	ПользовательТелефон = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
	ПользовательСсылка, Справочники.ВидыКонтактнойИнформации.ТелефонПользователя);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКэшЗначений()
	
	ДополнительныйПараметр = НачалоРаботыСПрограммойКлиентСервер.ЗначениеДополнительногоПараметра();
	
	КэшЗначений = Новый Структура;
	КэшЗначений.Вставить("Пользователь", Пользователи.АвторизованныйПользователь());
	КэшЗначений.Вставить("РазрешитьЗакрытие", Ложь);
	КэшЗначений.Вставить("ДополнительныйПараметр",ДополнительныйПараметр);
	КэшЗначений.Вставить("Доходы", Перечисления.ВидыОбъектовНалогообложения.Доходы);
	КэшЗначений.Вставить("ДоходыМинусРасходы", Перечисления.ВидыОбъектовНалогообложения.ДоходыМинусРасходы);
	КэшЗначений.Вставить("ЮрЛицо", Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо);
	КэшЗначений.Вставить("ФизЛицо", Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо);
	КэшЗначений.Вставить("ТекущийИндексОрганизации", Неопределено);
	КэшЗначений.Вставить("ПараметрыНачалаРаботы", Новый Структура);
	КэшЗначений.ПараметрыНачалаРаботы.Вставить("РазделениеВключено", ОбщегоНазначения.РазделениеВключено());
	КэшЗначений.ПараметрыНачалаРаботы.Вставить("ВерсияДанныхОсновнойКонфигурации", Метаданные.Версия);
	
	КэшироватьСвойстваЭлементовФормы();
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьГлобальныеНастройки()
	
	ОтображатьВыборВидаБизнеса = ПолучитьФункциональнуюОпцию("ОтображатьВыборВидаБизнеса");
	ОтображатьРеквизитыНалогообложения = ПолучитьФункциональнуюОпцию("ОтображатьРеквизитыНалогообложения");
	
	ДоступноПодключениеИнтернетПоддержки = ИнтернетПоддержкаПользователей.ДоступноПодключениеИнтернетПоддержки();
	РазделениеВключено = ОбщегоНазначения.РазделениеВключено();
	ЭтоБазоваяВерсияКонфигурации = СтандартныеПодсистемыСервер.ЭтоБазоваяВерсияКонфигурации();
	ЭтоМобильныйКлиент = ОбщегоНазначения.ЭтоМобильныйКлиент();
	
	Если РазделениеВключено Тогда
		ПодключенаИПП = ИнтернетПоддержкаПользователей.ЗаполненыДанныеАутентификацииПользователяИнтернетПоддержки();
	Иначе
		
		УстановитьПривилегированныйРежим(Истина);
		ДанныеИПП = ИнтернетПоддержкаПользователей.ДанныеАутентификацииПользователяИнтернетПоддержки();
		УстановитьПривилегированныйРежим(Ложь);
		Если ДанныеИПП <> Неопределено Тогда
			ЛогинИнтернетПоддержки = ДанныеИПП.Логин;
			ПодключенаИПП = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПостоянныеРеквизиты()
	
	ЦветФонУправляющегоПоля = Метаданные.ЭлементыСтиля.ФонУправляющегоПоля.Значение;
	ЦветФонаКнопки = Элементы.ВидБизнесаОптоваяТорговля.ЦветФона;
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСШагами

&НаСервере
Процедура УстановитьШагПриСоздании()
	
	Если РазделениеВключено Тогда
		
		Если ОтображатьВыборВидаБизнеса Тогда
			УстановитьШаг(2);
		Иначе
			УстановитьШаг(3);
		КонецЕсли;
		
	Иначе
		
		УстановитьШаг(1);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьШаг(НомерШага)
	
	Если НомерШага = 1 Тогда
		Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг1;
	ИначеЕсли НомерШага = 2 Тогда
		Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг2;
	ИначеЕсли НомерШага = 3 Тогда
		Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг3;
	Иначе
		Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг4;
	КонецЕсли;
	
	ОпределитьИнтерфейсПоШагу();
	
КонецПроцедуры

&НаСервере
Процедура НазадНаСервере()
	
	Если Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг2 Тогда
		НомерНовогоШага = 1;
	ИначеЕсли Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг3 Тогда
		
		Если ОтображатьВыборВидаБизнеса Тогда
			НомерНовогоШага = 2;
		Иначе
			НомерНовогоШага = 1;
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьШаг(НомерНовогоШага);
	
КонецПроцедуры

&НаСервере
Процедура ПродолжитьКомандаНаСервере()
	
	Если Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг1 Тогда
		НомерШага = 1;
	ИначеЕсли Элементы.СтраницыКонтента.ТекущаяСтраница = Элементы.СтраницаШаг2 Тогда
		НомерШага = 2;
	Иначе
		Возврат;
	КонецЕсли;
	
	ПроверитьЗаполнениеФормы(НомерШага);
	Если Не КэшЗначений.РазрешитьЗакрытие Тогда
		Возврат;
	КонецЕсли;
	
	Если РазделениеВключено Или Не ОтображатьВыборВидаБизнеса Тогда
		НомерНовогоШага = 3;
	Иначе
		НомерНовогоШага = НомерШага + 1;
	КонецЕсли;
	
	УстановитьШаг(НомерНовогоШага);
	
КонецПроцедуры

#КонецОбласти

#Область ПроверкаЗаполнения

&НаСервере
Процедура ПроверитьЗаполнениеФормы(НомерШага)
	
	Если ВРЕГ(ПользовательИмя) = КэшЗначений.ДополнительныйПараметр Тогда
		Возврат;
	КонецЕсли;
	
	Ошибки = Неопределено;
	
	Если НомерШага = 1 Тогда
		
		Если ПустаяСтрока(ПользовательИмя) Тогда
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
			Ошибки, "ПользовательИмя", НСтр("ru ='Заполните имя пользователя'"), "");
		КонецЕсли;
		
		Если СтрНайти(ПользовательИмя, ":") Тогда
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
			Ошибки, "ПользовательИмя", НСтр("ru ='Имя пользователя не должно содержать двоеточие "":""'"), "");
		КонецЕсли;
		
		Если ПользовательПароль <> ПользовательПарольПодтверждение Тогда
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
			Ошибки, "ПользовательПарольПодтверждение", НСтр("ru ='Не совпадают пароли'"), "");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ПользовательEmail)
			И Не ОбщегоНазначенияКлиентСервер.АдресЭлектроннойПочтыСоответствуетТребованиям(ПользовательEmail) Тогда
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
			Ошибки, "ПользовательEmail", НСтр("ru ='Введите корректный E-mail'"), "")
		КонецЕсли;
		
	ИначеЕсли НомерШага = 3 Тогда
		
		Для каждого СтрокаОрганизации Из Объект.Организации Цикл
			
			Если ПустаяСтрока(СтрокаОрганизации.Наименование) Тогда
				ТекстОшибки = НСтр("ru ='Заполните название (организация %1)'");
				ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстОшибки, СтрокаОрганизации.НомерСтроки);
				ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
				Ошибки, "Наименование" + СтрокаОрганизации.НомерСтроки, ТекстОшибки, "");
			КонецЕсли;
			
			Если СтрокаОрганизации.ЮридическоеФизическоеЛицо = КэшЗначений.ФизЛицо Тогда
				
				Если ПустаяСтрока(СтрокаОрганизации.ФИО) Тогда
					ТекстОшибки = НСтр("ru ='Заполните ФИО (организация %1)'");
					ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстОшибки, СтрокаОрганизации.НомерСтроки);
					ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
					Ошибки, "ФИО" + СтрокаОрганизации.НомерСтроки, ТекстОшибки, "");
				КонецЕсли;
				
			КонецЕсли;
			
			Если ПустаяСтрока(СтрокаОрганизации.СистемаНалогообложения) Тогда
				ТекстОшибки = НСтр("ru ='Заполните систему налогообложения (организация %1)'");
				ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстОшибки, СтрокаОрганизации.НомерСтроки);
				ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
				Ошибки, "СистемаНалогообложения" + СтрокаОрганизации.НомерСтроки, ТекстОшибки, "");
			КонецЕсли;
			
			Если СтрокаОрганизации.СистемаНалогообложения = "УСН_НДС" И ПустаяСтрока(СтрокаОрганизации.СтавкаНДС) Тогда
				ТекстОшибки = НСтр("ru ='Заполните ставку НДС (организация %1)'");
				ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстОшибки, СтрокаОрганизации.НомерСтроки);
				ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(
				Ошибки, "СтавкаНДС" + СтрокаОрганизации.НомерСтроки, ТекстОшибки, "");
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	КэшЗначений.РазрешитьЗакрытие = (Ошибки = Неопределено);
	Если Не КэшЗначений.РазрешитьЗакрытие Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗаполнениеИмениПользователя()
	
	Если СтрНайти(ПользовательИмя, ":") Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
		НСтр("ru ='Имя пользователя не должно содержать двоеточие "":""'"), , "ПользовательИмя");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ПрофильИТС

&НаКлиенте
Процедура ПодключитьПрофильИТСНажатиеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПодключенаИПП = Истина;
	ЛогинИнтернетПоддержки = Результат.Логин;
	ОпределитьИнтерфейсПодключенияИТС();
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСИНН

&НаКлиенте
Процедура ПроверитьИНН(ИндексОрганизации)
	
	Элементы["ИННОшибкаВвода" + ИндексОрганизации].Заголовок = "";
	ЗначениеИНН = ЭтотОбъект["ИНН" + ИндексОрганизации];
	Если Не ЗначениеЗаполнено(ЗначениеИНН) Тогда
		Возврат;
	КонецЕсли;
	
	ДлинаИНН = СтрДлина(СокрЛП(ЗначениеИНН));
	Если ДлинаИНН = 12 Тогда
		ЭтоЮрЛицо = Ложь;
	ИначеЕсли ДлинаИНН = 10 Тогда
		ЭтоЮрЛицо = Истина;
	Иначе
		ЭтоЮрЛицо = ЭтотОбъект["ЮридическоеФизическоеЛицо" + ИндексОрганизации] = КэшЗначений.ЮрЛицо;
	КонецЕсли;
	
	ОписаниеОшибки = "";
	ИННВведенКорректно = 
	РегламентированныеДанныеКлиентСервер.ИННСоответствуетТребованиям(ЗначениеИНН, ЭтоЮрЛицо, ОписаниеОшибки);
	
	Элементы["ГруппаОшибокИНН" + ИндексОрганизации].Видимость = Не ИННВведенКорректно;
	Если Не ИННВведенКорректно Тогда
		Элементы["ИННОшибкаВвода" + ИндексОрганизации].Заголовок = ОписаниеОшибки;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРеквизитыПоИНН(ИндексОрганизации)
	
	ЗначениеИНН = ЭтотОбъект["ИНН" + ИндексОрганизации];
	ЗаписатьЗначениеОрганизации("ИНН", ЗначениеИНН, ИндексОрганизации);
	
	ИННВведенКорректно = ПустаяСтрока(Элементы["ИННОшибкаВвода" + ИндексОрганизации].Заголовок);
	Если Не ИННВведенКорректно Тогда
		УправлениеФормой(ИндексОрганизации);
		Возврат;
	КонецЕсли;
	
	ПредыдущееЗначение = ЭтотОбъект["ЮридическоеФизическоеЛицо" + ИндексОрганизации];
	ЗначениеЮрФизЛицо = ?(СтрДлина(ЗначениеИНН) = 12, КэшЗначений.ФизЛицо, КэшЗначений.ЮрЛицо);
	ЭтотОбъект["ЮридическоеФизическоеЛицо" + ИндексОрганизации] = ЗначениеЮрФизЛицо;
	
	ЗаписатьЗначениеОрганизацииЮрФизЛицо(ЗначениеЮрФизЛицо, ПредыдущееЗначение, ИндексОрганизации);
	
	Если Не ПодключенаИПП Тогда
		УправлениеФормой(ИндексОрганизации);
		Возврат;
	КонецЕсли;
	
	ОбработкаПриИзмененииИНН(ИндексОрганизации, ЗначениеИНН);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПриИзмененииИНН(Знач ИндексОрганизации, Знач ЗначениеИНН, Знач ДанныеГосРеестра = Неопределено)
	
	Если ДанныеГосРеестра = Неопределено Тогда
		ДанныеГосРеестра = НачалоРаботыСПрограммойСервер.ДанныеГосРеестра(ЗначениеИНН);
	КонецЕсли;
	
	// Стартовое окно не должно сообщать о существующих ошибках в учетных данных. Цель быстро собрать сведения, 
	// если они ошибочные - продолжить работу.
	
	СведенияПолучены = Ложь;
	Если ДанныеГосРеестра.Свойство("СведенияПолучены") Тогда
		СведенияПолучены = ДанныеГосРеестра.СведенияПолучены;
	КонецЕсли;
	
	Если Не СведенияПолучены Тогда
		УправлениеФормой(ИндексОрганизации);
		Возврат;
	КонецЕсли;
	
	ЗаполнитьСписокВыбораНаименования(ДанныеГосРеестра, ИндексОрганизации);
	
	ДанныеСтрокиОрганизации = СтрокаОрганизацииПоИндексуНаСервере(ИндексОрганизации);
	
	Если ДанныеГосРеестра.Свойство("Наименование") 
		И НЕ ПустаяСтрока(ДанныеГосРеестра.Наименование) Тогда
		
		ЭтотОбъект["Наименование" + ИндексОрганизации] = ДанныеГосРеестра.Наименование;
		ДанныеСтрокиОрганизации.Наименование = ДанныеГосРеестра.Наименование;
		
	КонецЕсли;
	
	Если ДанныеГосРеестра.Свойство("КПП") Тогда
		
		ДанныеСтрокиОрганизации.КПП = ДанныеГосРеестра.КПП;
		
	КонецЕсли;
	
	ДанныеСтрокиОрганизации.НаименованиеСокращенное = ДанныеГосРеестра.НаименованиеСокращенное;
	ДанныеСтрокиОрганизации.НаименованиеПолное = ДанныеГосРеестра.НаименованиеПолное;
	ДанныеСтрокиОрганизации.ОГРН = ДанныеГосРеестра.ОГРН;
	ДанныеСтрокиОрганизации.КодОКВЭД = ДанныеГосРеестра.КодОКВЭД;
	
	Если НЕ ДанныеГосРеестра.ЭтоЮрЛицо Тогда
		
		ДанныеСтрокиОрганизации.СвидетельствоСерияНомер = ДанныеГосРеестра.СвидетельствоСерияНомер;
		ДанныеСтрокиОрганизации.СвидетельствоДатаВыдачи = ДанныеГосРеестра.СвидетельствоДатаВыдачи;
		ДанныеСтрокиОрганизации.Пол = ДанныеГосРеестра.Пол;
		
		ПолноеФИО = "";
		Если ЗначениеЗаполнено(ДанныеГосРеестра.Фамилия) Тогда
			ПолноеФИО = ДанныеГосРеестра.Фамилия;
		КонецЕсли;
		Если ЗначениеЗаполнено(ДанныеГосРеестра.Имя) Тогда
			Если ЗначениеЗаполнено(ПолноеФИО) Тогда
				ПолноеФИО = СтрШаблон("%1 %2", ПолноеФИО, ДанныеГосРеестра.Имя);
			Иначе
				ПолноеФИО = ДанныеГосРеестра.Имя;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ДанныеГосРеестра.Отчество) Тогда
			Если ЗначениеЗаполнено(ПолноеФИО) Тогда
				ПолноеФИО = СтрШаблон("%1 %2", ПолноеФИО, ДанныеГосРеестра.Отчество);
			Иначе
				ПолноеФИО = ДанныеГосРеестра.Отчество;
			КонецЕсли;
		КонецЕсли;
		
		ДанныеСтрокиОрганизации.ФИО = ПолноеФИО;
		ЭтотОбъект["ФИО" + ИндексОрганизации] = ПолноеФИО;
		
	КонецЕсли;
	
	ДанныеСтрокиОрганизации.КодНалоговогоОргана = ДанныеГосРеестра.КодНалоговогоОрганаПолучателя;
	ДанныеСтрокиОрганизации.КодНалоговогоОрганаПолучателя = ДанныеГосРеестра.КодНалоговогоОрганаПолучателя;
	
	Если ДанныеГосРеестра.Свойство("РегистрацияВПенсионномФонде")
		И ЗначениеЗаполнено(ДанныеГосРеестра.РегистрацияВПенсионномФонде) Тогда
		
		ДанныеСтрокиОрганизации.КодОрганаПФР = ДанныеГосРеестра.РегистрацияВПенсионномФонде.КодОрганаПФР;
		
		Если ДанныеГосРеестра.ЭтоЮрЛицо Тогда
			
			ДанныеСтрокиОрганизации.РегистрационныйНомерПФР = ДанныеГосРеестра.РегистрационныйНомерПФР;
			
		Иначе
			
			ДанныеСтрокиОрганизации.РегистрационныйНомерПФР_ИП = ДанныеГосРеестра.РегистрационныйНомерПФР_ИП;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ДанныеСтрокиОрганизации.КодОрганаФСС = ДанныеГосРеестра.КодОрганаФСС;
	ДанныеСтрокиОрганизации.НаименованиеТерриториальногоОрганаФСС = ДанныеГосРеестра.НаименованиеТерриториальногоОрганаФСС;
	ДанныеСтрокиОрганизации.РегистрационныйНомерФСС = ДанныеГосРеестра.РегистрационныйНомерФСС;
	ДанныеСтрокиОрганизации.НаименованиеПлательщикаПриПеречисленииНалогов = 
	ДанныеГосРеестра.НаименованиеПлательщикаПриПеречисленииНалогов;
	
	Если ЗначениеЗаполнено(ДанныеГосРеестра.Телефон) Тогда
		
		ДобавитьКИОрганизации(
		ИндексОрганизации,
		Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации,
		ДанныеГосРеестра.Телефон.Представление,
		ДанныеГосРеестра.Телефон.КонтактнаяИнформация);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеГосРеестра.ЮридическийАдрес) Тогда
		
		ДобавитьКИОрганизации(
		ИндексОрганизации,
		Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации,
		ДанныеГосРеестра.ЮридическийАдрес.Представление,
		ДанныеГосРеестра.ЮридическийАдрес.КонтактнаяИнформация);
		
		ДобавитьКИОрганизации(
		ИндексОрганизации,
		Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации,
		ДанныеГосРеестра.ЮридическийАдрес.Представление,
		ДанныеГосРеестра.ЮридическийАдрес.КонтактнаяИнформация);
		
	КонецЕсли;
	
	УправлениеФормой(ИндексОрганизации);
	
КонецПроцедуры

&НаСервере
Функция ВыделитьИзНаименованияОПФ(КлассификаторОПФ, знач НаименованиеОрганизации)
	
	Результат = Новый Структура("НаименованиеБезОПФ, КраткаяФорма, ПолнаяФорма", НаименованиеОрганизации, "", "");
	МассивСлов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(НаименованиеОрганизации);
	
	Для Каждого Слово Из МассивСлов Цикл
		Для Каждого ДанныеОПФ Из КлассификаторОПФ Цикл
			Если ВРег(СокрЛП(Слово)) = ВРег(ДанныеОПФ.ПолнаяФорма) Тогда
				Результат.КраткаяФорма = ДанныеОПФ.КраткаяФорма;
				Результат.ПолнаяФорма = ДанныеОПФ.ПолнаяФорма;
				Результат.НаименованиеБезОПФ = 
				СтроковыеФункцииКлиентСервер.СократитьДвойныеКавычки(СокрЛП(СтрЗаменить(НаименованиеОрганизации, Слово, "")));
				Возврат Результат;
			ИначеЕсли Не ПустаяСтрока(ДанныеОПФ.КраткаяФорма) И ВРег(СокрЛП(Слово)) = ВРег(ДанныеОПФ.КраткаяФорма) Тогда
				Результат.КраткаяФорма = ДанныеОПФ.КраткаяФорма;
				Результат.ПолнаяФорма = ДанныеОПФ.ПолнаяФорма;
				Результат.НаименованиеБезОПФ = 
				СтроковыеФункцииКлиентСервер.СократитьДвойныеКавычки(СокрЛП(СтрЗаменить(НаименованиеОрганизации, Слово, "")));
				Возврат Результат;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьСписокВыбораНаименования(ДанныеГосРеестра, ИндексОрганизации)
	
	СписокВыбора = Элементы["Наименование" + ИндексОрганизации].СписокВыбора;
	СписокВыбора.Очистить();
	
	Если ПустаяСтрока(ДанныеГосРеестра.Наименование) Тогда
		Элементы["Наименование" + ИндексОрганизации].КнопкаВыпадающегоСписка = Ложь;
		Возврат;
	КонецЕсли;
	
	СписокВыбора.Добавить(ДанныеГосРеестра.Наименование);
	
	Если Не ПустаяСтрока(ДанныеГосРеестра.НаименованиеСокращенное)
		И СписокВыбора.НайтиПоЗначению(ДанныеГосРеестра.НаименованиеСокращенное) = Неопределено Тогда
		
		СписокВыбора.Добавить(ДанныеГосРеестра.НаименованиеСокращенное);
		
	КонецЕсли;
	
	Если Не ПустаяСтрока(ДанныеГосРеестра.НаименованиеПолное) Тогда
		
		КлассификаторОПФ = РегламентированныеДанныеПовтИсп.КлассификаторОрганизационноПравовыхФорм();
		ОрганизационноПравоваяФорма = ВыделитьИзНаименованияОПФ(КлассификаторОПФ, ДанныеГосРеестра.НаименованиеПолное);
		
		Если СписокВыбора.НайтиПоЗначению(ОрганизационноПравоваяФорма.НаименованиеБезОПФ) = Неопределено Тогда
			СписокВыбора.Добавить(ОрганизационноПравоваяФорма.НаименованиеБезОПФ);
		КонецЕсли;
		
		Если НЕ ПустаяСтрока(ОрганизационноПравоваяФорма.КраткаяФорма) Тогда
			
			Значение = СтрШаблон(
			"%1 %2", ОрганизационноПравоваяФорма.КраткаяФорма, ОрганизационноПравоваяФорма.НаименованиеБезОПФ);
			Если СписокВыбора.НайтиПоЗначению(Значение) = Неопределено Тогда
				СписокВыбора.Добавить(Значение);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы["Наименование" + ИндексОрганизации].КнопкаВыпадающегоСписка = СписокВыбора.Количество();
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСОрганизациями

#Область ДобавлениеУдалениеОрганизаций

&НаСервере
Процедура ОбработчикКомандыДобавитьОрганизациюНаСервере()
	
	ИндексОрганизации = ДобавитьОрганизацию(Истина);
	УправлениеФормой(ИндексОрганизации);
	ОпределитьИнтерфейсОрганизацийПоМК();
	
КонецПроцедуры

&НаСервере
Функция ДобавитьОрганизацию(СоздатьРеквизитыЭлементы, ОрганизацияСсылка = Неопределено)
	
	ДобавленнаяСтрока = Объект.Организации.Добавить();
	
	ИндексОрганизации = СформироватьУникальныйИндексОрганизации(ДобавленнаяСтрока);
	
	Если СоздатьРеквизитыЭлементы Тогда
		
		ДобавитьРеквизитыИЭлементыФормы(ИндексОрганизации);
		ТекущийЭлемент = Элементы["Наименование" + ИндексОрганизации];
		
	КонецЕсли;
	
	Если ОрганизацияСсылка = Неопределено Тогда
		
		ОрганизацияСсылка = Справочники.Организации.ПолучитьСсылку();
		
	КонецЕсли;
	
	СтрокаТаблицы = Объект.Организации.НайтиПоИдентификатору(ДобавленнаяСтрока.ПолучитьИдентификатор());
	
	СтрокаТаблицы.Ссылка = ОрганизацияСсылка;
	СтрокаТаблицы.ИндексОрганизации = ИндексОрганизации;
	
	РеквизитыОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ОрганизацияСсылка,
		"Наименование, НаименованиеПолное, НаименованиеСокращенное, ЮридическоеФизическоеЛицо");
	СтрокаТаблицы.Наименование = РеквизитыОрганизации.Наименование;
	СтрокаТаблицы.НаименованиеПолное = РеквизитыОрганизации.НаименованиеПолное;
	СтрокаТаблицы.НаименованиеСокращенное = РеквизитыОрганизации.НаименованиеСокращенное;
	ЭтотОбъект["Наименование" + ИндексОрганизации] = СтрокаТаблицы.Наименование;
	
	СтрокаТаблицы.ЮридическоеФизическоеЛицо = РеквизитыОрганизации.ЮридическоеФизическоеЛицо;
	Если Не ЗначениеЗаполнено(СтрокаТаблицы.ЮридическоеФизическоеЛицо) Тогда
		СтрокаТаблицы.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
	КонецЕсли;
	ЭтотОбъект["ЮридическоеФизическоеЛицо" + ИндексОрганизации] = СтрокаТаблицы.ЮридическоеФизическоеЛицо;
	
	СтрокаТаблицы.ВидыОбъектовНалогообложения = Перечисления.ВидыОбъектовНалогообложения.Доходы;
	ЭтотОбъект["ВидыОбъектовНалогообложения" + ИндексОрганизации] = СтрокаТаблицы.ВидыОбъектовНалогообложения;
	
	СтрокаТаблицы.СистемаНалогообложения = "ОСНО";
	ЭтотОбъект["СистемаНалогообложения" + ИндексОрганизации] = СтрокаТаблицы.СистемаНалогообложения;
	
	Возврат ИндексОрганизации;
	
КонецФункции

&НаСервере
Процедура ДобавитьРеквизитыИЭлементыФормы(ИндексОрганизации)
	
	ПостФикс = ИндексОрганизации;
	
	ДобавитьРеквизитыДляНовойОрганизации(ПостФикс);
	ДобавитьЭлементыДляНовойОрганизации(ПостФикс);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитыДляНовойОрганизации(ПостФикс)
	
	МассивРеквизитов = Новый Массив;
	
	НовыйРеквизитИНН = Новый РеквизитФормы(
	"ИНН" + ПостФикс, Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(12)), , "");
	МассивРеквизитов.Добавить(НовыйРеквизитИНН);
	
	НовыйЮридическоеФизическоеЛицо = Новый РеквизитФормы(
	"ЮридическоеФизическоеЛицо" + ПостФикс, Новый ОписаниеТипов("ПеречислениеСсылка.ЮридическоеФизическоеЛицо"), , "");
	МассивРеквизитов.Добавить(НовыйЮридическоеФизическоеЛицо);
	
	НовыйНаименование = Новый РеквизитФормы(
	"Наименование" + ПостФикс, Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(50)), , "");
	МассивРеквизитов.Добавить(НовыйНаименование);
	
	НовыйНаименование = Новый РеквизитФормы(
	"ФИО" + ПостФикс, Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(150)), , "");
	МассивРеквизитов.Добавить(НовыйНаименование);
	
	НовыйНаименование = Новый РеквизитФормы(
