	НаследоватьСвойстваДекорацииФормы(ФормаСобственностиЗаголовок, Элементы.ФормаСобственностиЗаголовок1, ЗначенияСвойствЭлементов);
	
	ЮридическоеФизическоеЛицо = Элементы.Добавить("ЮридическоеФизическоеЛицо" + ПостФикс, Тип("ПолеФормы"), ГруппаФормаСобственности);
	ЮридическоеФизическоеЛицо.Вид = ВидПоляФормы.ПолеПереключателя;
	ЮридическоеФизическоеЛицо.ПутьКДанным = "ЮридическоеФизическоеЛицо" + ПостФикс;
	ЮридическоеФизическоеЛицо.УстановитьДействие("ПриИзменении", "ЮрФизЛицоПриИзменении");
	НаследоватьСвойстваПоляПереключателя(ЮридическоеФизическоеЛицо, Элементы.ЮридическоеФизическоеЛицо1, ЗначенияСвойствЭлементов);
	
	// Наименование
	ГруппаНаименование = Элементы.Добавить("ГруппаНаименование" + ПостФикс, Тип("ГруппаФормы"), ДанныеОрганизацииЛево);
	ГруппаНаименование.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НаследоватьСвойстваГруппыФормы(ГруппаНаименование, Элементы.ГруппаНаименование1, ЗначенияСвойствЭлементов);
	
	ГруппаПодсказкиНаименования = Элементы.Добавить("ГруппаПодсказкиНаименования" + ПостФикс, Тип("ГруппаФормы"), ГруппаНаименование);
	ГруппаПодсказкиНаименования.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НаследоватьСвойстваГруппыФормы(ГруппаПодсказкиНаименования, Элементы.ГруппаПодсказкиНаименования1, ЗначенияСвойствЭлементов);
	
	НаименованиеЗаголовок = Элементы.Добавить("НаименованиеЗаголовок" + ПостФикс, Тип("ДекорацияФормы"), ГруппаПодсказкиНаименования);
	НаименованиеЗаголовок.Вид = ВидДекорацииФормы.Надпись;
