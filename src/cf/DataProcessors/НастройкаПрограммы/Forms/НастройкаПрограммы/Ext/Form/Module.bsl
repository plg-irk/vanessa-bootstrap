#Область ОбработчикиСобытийЭлементовТаблицыФормыСписокРазделов

&НаКлиенте
Процедура СписокРазделовПриАктивизацииСтроки(Элемент)
	
	Если Не ОбрабатыватьАктивизациюСпискаРазделов Тогда
		ОбрабатыватьАктивизациюСпискаРазделов = Не ОбрабатыватьАктивизациюСпискаРазделов;
		Элементы.СписокРазделов.ВыделенныеСтроки.Очистить();
		ОтборСтрок = Новый Структура("Имя", Элементы.СтраницыНастроек.ТекущаяСтраница.Имя);
		СоответствующийСтраницеРаздел = СписокРазделов.НайтиСтроки(ОтборСтрок);
		Если СоответствующийСтраницеРаздел.Количество() <> 0 Тогда
			Элементы.СписокРазделов.ВыделенныеСтроки.Добавить(СоответствующийСтраницеРаздел[0].ПолучитьИдентификатор());
			Элементы.СписокРазделов.ТекущаяСтрока = СоответствующийСтраницеРаздел[0].ПолучитьИдентификатор();
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если Элементы.СписокРазделов.ТекущаяСтрока = Неопределено
		Или Элементы.СписокРазделов.ТекущиеДанные.Видимость = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	СоответствующаяРазделуСтраница = Элементы.Найти(Элементы.СписокРазделов.ТекущиеДанные.Имя);
	
	Если СоответствующаяРазделуСтраница = Неопределено Тогда
		Элементы.СтраницыНастроек.ТекущаяСтраница = Элементы.СтраницаНеНайдено;
	Иначе
		Элементы.СтраницыНастроек.ТекущаяСтраница = СоответствующаяРазделуСтраница;
	КонецЕсли;
	
#Если МобильныйКлиент Тогда
	НастроитьВидимостьДереваНастроекМобильныйКлиент(Элементы, Ложь);
#КонецЕсли
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СнятьОтбор(Команда)
	
	НастроитьВидимостьДереваНастроекМобильныйКлиент(Элементы, Истина);
	
КонецПроцедуры

