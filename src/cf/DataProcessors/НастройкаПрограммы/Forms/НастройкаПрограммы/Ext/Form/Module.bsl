// Сервер

&НаСервере
Функция ПриИзмененииНастройкиСервер(ИмяЭлемента)
	
	РеквизитПутьКДанным = Элементы[ИмяЭлемента].ПутьКДанным;
	ИмяКонстанты = СохранитьЗначениеНастройки(РеквизитПутьКДанным);
	ПрочитатьЗначенияВсехНастроек();
	ПриУстановкеДоступностиНастроек(РеквизитПутьКДанным);
	ОбновитьПовторноИспользуемыеЗначения();
	Возврат ИмяКонстанты;
	
КонецФункции

&НаСервере
Процедура ПрочитатьЗначенияВсехНастроек()
	УстановитьПривилегированныйРежим(Истина);
	ПрочитатьЗначенияКонстант();
	ПриПолученииЗначенийНастроек();
КонецПроцедуры

&НаСервере
Процедура ПрочитатьЗначенияКонстант()
	
	КонстантыНаФорме = Новый Соответствие;
	ПриОпределенииКонстантНаФорме(КонстантыНаФорме);
	
	ВыбираемыеКонстантыЧастьЗапроса = Новый Массив;
	Для каждого ИспользуемаяКонстанта Из КонстантыНаФорме Цикл
		ТекстВыбираемойКонстанты = СтрШаблон("Константы.%1", ИспользуемаяКонстанта.Значение);
		ВыбираемыеКонстантыЧастьЗапроса.Добавить(ТекстВыбираемойКонстанты);
	КонецЦикла;
	
	ТекстЗапросаЧтоВыбрать = СтрСоединить(ВыбираемыеКонстантыЧастьЗапроса, "," + Символы.ПС);
	ШаблонЗапроса = 
	"ВЫБРАТЬ
	|	%1
	|ИЗ
	|	Константы КАК Константы";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон(ШаблонЗапроса, ТекстЗапросаЧтоВыбрать);;
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Для каждого ИспользуемаяКонстанта Из КонстантыНаФорме Цикл
			ЭтотОбъект[ИспользуемаяКонстанта.Ключ] = Результат[ИспользуемаяКонстанта.Значение];
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СохранитьЗначениеНастройки(РеквизитПутьКДанным)
	
	НовоеЗначение = ЭтотОбъект[РеквизитПутьКДанным];
	
	Отказ = Ложь;
	ПроверитьКорректностьНастройкиПередИзменением(РеквизитПутьКДанным, НовоеЗначение, Отказ);
	Если Отказ Тогда
		Возврат "";
	КонецЕсли;
	
	СтандартнаяОбработка = Истина;
	ВызыватьОповещение = Ложь;
	ПриСохраненииЗначенияНастройки(РеквизитПутьКДанным, НовоеЗначение, СтандартнаяОбработка, ВызыватьОповещение);
	КонстантыНаФорме = Новый Соответствие;
	ПриОпределенииКонстантНаФорме(КонстантыНаФорме);
	ИмяКонстанты = КонстантыНаФорме.Получить(РеквизитПутьКДанным);
	
	Если НЕ СтандартнаяОбработка Тогда
		Если ВызыватьОповещение Тогда
			Возврат ИмяКонстанты;
		Иначе		
			Возврат "";
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ИмяКонстанты) Тогда
		Возврат "";
	КонецЕсли;
	
	КонстантаМенеджер = Константы[ИмяКонстанты];
	КонстантаМенеджер.Установить(НовоеЗначение);
	
	Возврат ИмяКонстанты;
	
КонецФункции

&НаСервере
Процедура ПроверитьКорректностьНастройкиПередИзменением(РеквизитПутьКДанным, НовоеЗначение, Отказ)
	
	ТекстОшибки = "";
	ПриПроверкеКорректностиНастройкиПередИзменением(РеквизитПутьКДанным, НовоеЗначение, ТекстОшибки);
	
	Если НЕ ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначения.СообщитьПользователю(ТекстОшибки,,, РеквизитПутьКДанным, Отказ);
	
КонецПроцедуры

#КонецОбласти

#Область НедоступнаяФункциональность

&НаСервере
Процедура ОформитьНедоступныеНастройкиКонфигурации()
	
	КонстантыНаФорме = Новый Соответствие;
	ПриОпределенииКонстантНаФорме(КонстантыНаФорме);
	
	НедоступныеКонстанты = Новый Массив;
	СписокДоступныхКонстант = ВозможностиПриложения.СписокДоступныхКонстант(КонстантыНаФорме);
	
	Для Каждого ИспользуемаяКонстанта Из КонстантыНаФорме Цикл
		
		Если СписокДоступныхКонстант.Найти(ИспользуемаяКонстанта.Значение) = Неопределено Тогда
			
			НедоступныеКонстанты.Добавить(ИспользуемаяКонстанта.Значение);
			
			Если Не Элементы.Найти(ИспользуемаяКонстанта.Значение)= Неопределено Тогда
				Элементы[ИспользуемаяКонстанта.Значение].Видимость = Ложь;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если Не НедоступныеКонстанты.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	ГруппыНедоступности = Новый Соответствие;
	ОформляемыеГруппыНедоступности = Новый Массив;
	ПриОпределенииГруппНедоступнойФункциональностиКонфигурации(ГруппыНедоступности);
	
	Для каждого ГруппаНедоступности Из ГруппыНедоступности Цикл
		Если ТипЗнч(ГруппаНедоступности.Значение) = Тип("Массив") Тогда
			ЭлементыФормыГруппыНедоступности = ГруппаНедоступности.Значение;
		Иначе
			ЭлементыФормыГруппыНедоступности = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ГруппаНедоступности.Значение);
		КонецЕсли;
		Для каждого ЭлементФормы Из ЭлементыФормыГруппыНедоступности Цикл
			Если НедоступныеКонстанты.Найти(ГруппаНедоступности.Ключ) <> Неопределено
				И ОформляемыеГруппыНедоступности.Найти(ЭлементФормы) = Неопределено Тогда
				ОформляемыеГруппыНедоступности.Добавить(ЭлементФормы);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Для каждого ИмяГруппы Из ОформляемыеГруппыНедоступности Цикл
		ОформляемаяГруппа = Элементы[ИмяГруппы];
		Если ПоказатьНовыеВозможности Тогда
			ОформитьНедоступнойНастройкуКонфигурации(ОформляемаяГруппа);
		Иначе
			ОформляемаяГруппа.Видимость = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	НедоступныеТумблеры = Новый Соответствие;
	ОформляемыеНедоступныеТумблеры = Новый Массив;
	ПриОпределенииТумблеровНедоступнойФункциональностиКонфигурации(НедоступныеТумблеры);
	
	Для каждого НедоступныйТумблер Из НедоступныеТумблеры Цикл
		Если НедоступныеКонстанты.Найти(НедоступныйТумблер.Ключ) <> Неопределено
			И ОформляемыеНедоступныеТумблеры.Найти(НедоступныйТумблер.Значение) = Неопределено Тогда
			ОформляемыеНедоступныеТумблеры.Добавить(НедоступныйТумблер.Значение);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ИмяЭлемента Из ОформляемыеНедоступныеТумблеры Цикл
		ОформляемыйЭлементФормы = Элементы[ИмяЭлемента];
		ОформляемыйЭлементФормы.ТолькоПросмотр = Истина;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОформитьНедоступнойНастройкуКонфигурации(ОформляемаяГруппа)
	
	МассивСимволов = Новый Массив;
	МассивСимволов.Добавить(Символы.ПС);
	МассивСимволов.Добавить(БиблиотекаКартинок.НовинкаСтикер);
	ОформляемаяГруппа.РасширеннаяПодсказка.Заголовок = Новый ФорматированнаяСтрока(МассивСимволов);
	ОформляемаяГруппа.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСверху;
	ОформляемаяГруппа.ТолькоПросмотр = Истина;
	ОформляемаяГруппа.Видимость = Истина;
	
	Для каждого ЭлементФормыНедоступнойГруппы Из ОформляемаяГруппа.ПодчиненныеЭлементы Цикл
		Если ТипЗнч(ЭлементФормыНедоступнойГруппы) = Тип("ГруппаФормы")
			И ЭлементФормыНедоступнойГруппы.Поведение = ПоведениеОбычнойГруппы.Свертываемая Тогда
			Для каждого ЭлементФормыСвертываемойГруппы Из ЭлементФормыНедоступнойГруппы.ПодчиненныеЭлементы Цикл
				ЭлементФормыСвертываемойГруппы.Доступность = Ложь;
			КонецЦикла;
		Иначе
			ЭлементФормыНедоступнойГруппы.Доступность = Ложь;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

