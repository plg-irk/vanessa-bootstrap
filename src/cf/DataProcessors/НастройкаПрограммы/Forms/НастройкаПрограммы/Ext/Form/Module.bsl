Процедура НастройкаЗаполненияДатыОтгрузкиЗавершение(РезультатЗначение, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(РезультатЗначение) = Тип("Структура") Тогда
		ЗаписатьНастройкиСрокаОтгрузки(РезультатЗначение);
	КонецЕсли;
	
	УстановитьЗаголовокНастроекОтгрузки();
	
