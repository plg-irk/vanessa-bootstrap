&НаСервере
Процедура ПриЗаполненииСпискаРазделов()
	
	КонстантыДляПроверки = ПроверяемыеКонстантыРазделов();
	ДоступныеКонстанты = ВозможностиПриложения.СписокДоступныхКонстант(КонстантыДляПроверки);

	Раздел = СписокРазделов.Добавить();
	Раздел.Имя = "СтраницаГлавное";
	Раздел.Представление = НСтр("ru='Общее'");
	Раздел.Подсказка = НСтр("ru='Товары • Единицы измерения • Штрихкоды • Печать'");
	Раздел.НомерРаздела = 1;
	
	РазделДоступен = ДоступныеКонстанты.Найти("ИспользоватьПодсистемуCRM") <> Неопределено;
	Если РазделДоступен Или (Не РазделДоступен И ЭтоКонфигурацияРозница) Тогда
		
		Раздел = СписокРазделов.Добавить();
		Раздел.Имя = "СтраницаCRM";
		Раздел.Представление = НСтр("ru='CRM'");
		Раздел.Подсказка = НСтр("ru='Чаты • Звонки • Почта • Варианты КП'");
		Раздел.НомерРаздела = 2;
		Если ЭтоКонфигурацияРозница Тогда
			Раздел.Недоступный = Истина;
			Раздел.ЕстьНовшества = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ДоступныеКонстанты.Найти("ИспользоватьПодсистемуПродажи") <> Неопределено Тогда
		
