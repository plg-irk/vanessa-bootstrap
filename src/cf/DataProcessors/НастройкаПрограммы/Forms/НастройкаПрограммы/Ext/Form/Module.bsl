	КонецЕсли;
	
	Если ДоступныеКонстанты.Найти("ИспользоватьПодсистемуКомпания") <> Неопределено Тогда
		
		Раздел = СписокРазделов.Добавить();
		Раздел.Имя = "СтраницаКомпания";
		Раздел.Представление = НСтр("ru='Компания'");
		Если ПоказатьНовыеВозможности Тогда
			Раздел.Подсказка = НСтр("ru='Интеркампани • Магазины • Проекты • Имущество'");
		Иначе
			ДополнениеПодсказки1 = ?(ДоступныеКонстанты.Найти("ПередачаТоваровМеждуОрганизациями") <> Неопределено, НСтр("ru='Интеркампани •'"), "");
			ДополнениеПодсказки2 = ?(ДоступныеКонстанты.Найти("ФункциональнаяОпцияУчетПоПроектам") <> Неопределено, НСтр("ru=' • Проекты'"), "");
			ДополнениеПодсказки3 = ?(ДоступныеКонстанты.Найти("ФункциональнаяОпцияУчетВнеоборотныхАктивов") <> Неопределено, НСтр("ru='• Имущество'"), "");
			Раздел.Подсказка = СокрЛП(СтрШаблон(НСтр("ru='%1 Магазины%2 %3'"), ДополнениеПодсказки1, ДополнениеПодсказки2, ДополнениеПодсказки3 )) ;
		КонецЕсли;
		Раздел.НомерРаздела = 11;
		Если ЭтоКонфигурацияРозница Тогда
			Раздел.ЕстьНовшества = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоКонфигурацияРозница Тогда
		Раздел = СписокРазделов.Добавить();
		Раздел.Имя = "СтраницаБольшеВозможностей";
		Раздел.Представление = НСтр("ru='Еще больше возможностей'");
		Раздел.Подсказка = НСтр("ru='Обновление • 1С:УНФ'");
		Раздел.НомерРаздела = 12;
	КонецЕсли;
	
КонецПроцедуры

