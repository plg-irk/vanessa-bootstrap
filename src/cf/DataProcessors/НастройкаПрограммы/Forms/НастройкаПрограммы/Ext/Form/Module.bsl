				ИзмененныеКонстантыУНФ.Добавить("ФункциональнаяОпцияВестиУчетНалогаНаДоходыИВзносов");
				ИзмененныеКонстантыУНФ.Добавить("ФункциональнаяОпцияВыполнятьРасчетНДФЛПоПрогрессивнойШкале");
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПромокоды" Тогда
		
		СтандартнаяОбработка = Ложь;
		Константы.ФункциональнаяОпцияИспользоватьПромокоды.Установить(НовоеЗначение);
		ИзмененныеКонстантыУНФ.Добавить("ФункциональнаяОпцияИспользоватьПромокоды");
		Если НовоеЗначение И Не Константы.ФункциональнаяОпцияИспользоватьАвтоматическиеСкидкиНаценки.Получить() Тогда
			Константы.ФункциональнаяОпцияИспользоватьАвтоматическиеСкидкиНаценки.Установить(Истина);
			ИзмененныеКонстантыУНФ.Добавить("ФункциональнаяОпцияИспользоватьАвтоматическиеСкидкиНаценки");
		КонецЕсли;
		
	ИначеЕсли РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсчетПосетителей" Тогда
		
		СтандартнаяОбработка = Ложь;
		Константы.ФункциональнаяОпцияИспользоватьПодсчетПосетителей.Установить(НовоеЗначение);
		ИзмененныеКонстантыУНФ.Добавить("ФункциональнаяОпцияИспользоватьПодсчетПосетителей");
		
	ИначеЕсли РеквизитПутьКДанным = "ОтслеживатьСтатусыОтчетовОРозничныхПродажах" Тогда
		
		Если НЕ ОтслеживатьСтатусыОтчетовОРозничныхПродажах Тогда
			// Очистим служебный реквизит Статусы отчетов о розничных продажах
			НаборЗаписей = РегистрыСведений.СтатусыОтчетовОРозничныхПродажах.СоздатьНаборЗаписей();
			НаборЗаписей.Записать();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Подходит для установи доступности взаимосвязанных настроек.
//
// Параметры:
//  РеквизитПутьКДанным - Строка - Пустая при первом открытии формы.
//                                 Заполнена при изменении одной из настроек формы.
//
&НаСервере
Процедура ПриУстановкеДоступностиНастроек(РеквизитПутьКДанным = "")
	
	Если РеквизитПутьКДанным = "ИспользоватьНесколькоОрганизаций"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.УчетПоКомпании.Доступность = ИспользоватьНесколькоОрганизаций;
		Элементы.ГруппаПередачаТоваров.Доступность = ИспользоватьНесколькоОрганизаций;
		Элементы.ГруппаНастройкаПередачиТоваров.Доступность = ИспользоватьНесколькоОрганизаций;
		
		
		Если Не ИспользоватьНесколькоОрганизаций Тогда
			Элементы.ОткрытьСписокОрганизацийИмпорт.Заголовок = НСтр("ru = 'Настроить учет подакцизных товаров'");
			Элементы.ДекорацияИмпортАкцизов.Видимость = Ложь;
		Иначе
			Элементы.ДекорацияИмпортАкцизов.Видимость = Истина;
			Элементы.ОткрытьСписокОрганизацийИмпорт.Заголовок = НСтр("ru = 'Открыть список организаций'");
		КонецЕсли;
		
		Если Не ИспользоватьНесколькоОрганизаций Тогда
			Элементы.ОткрытьСписокОрганизацийПроизводство.Заголовок = НСтр("ru = 'Настроить учет подакцизных товаров'");
			Элементы.ДекорацияПроизводствоАкцизов.Видимость = Ложь;
		Иначе
			Элементы.ОткрытьСписокОрганизацийПроизводство.Заголовок = НСтр("ru = 'Открыть список организаций'");
			Элементы.ДекорацияПроизводствоАкцизов.Видимость = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ИспользоватьНесколькоОрганизаций"
		Или РеквизитПутьКДанным = "УчетПоКомпании"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.Компания.Доступность = ИспользоватьНесколькоОрганизаций И УчетПоКомпании;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьАвтоматическиеСкидкиНаценки" Или РеквизитПутьКДанным = "" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
			"ОбработкаВидыСкидокНаценокРучныеИАвтоматическиеОткрытьОкругления", "Доступность",
			ФункциональнаяОпцияИспользоватьАвтоматическиеСкидкиНаценки);
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодарочныеСертификаты" Или РеквизитПутьКДанным = "" Тогда
		Элементы.КонтрагентДляПредоплаты.Доступность = ФункциональнаяОпцияИспользоватьПодарочныеСертификаты;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодарочныеСертификаты" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьЧастичноеПогашениеСертификатов.Доступность = ФункциональнаяОпцияИспользоватьПодарочныеСертификаты;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПартии" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияПриемТоваровНаКомиссию.Доступность = ФункциональнаяОпцияИспользоватьПартии;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж"
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПредоплатуВЧекахККМ"
		Или РеквизитПутьКДанным = "ИспользоватьРассрочкуПлатежаВЧекахККМ"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.АрхивироватьЧекиККМПриЗакрытииКассовойСмены.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж 
		И НЕ ФункциональнаяОпцияИспользоватьПредоплатуВЧекахККМ И НЕ ИспользоватьРассрочкуПлатежаВЧекахККМ;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.УдалятьНепробитыеЧекиПриЗакрытииКассовойСмены.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ГруппаОстаткиВРознице.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ОтслеживатьСтатусыОтчетовОРозничныхПродажах.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.УказыватьПричинуВозвратов.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьЗаказыВРозничнойТорговлеДляНастроек.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж"
		Или РеквизитПутьКДанным = "АрхивироватьЧекиККМПриЗакрытииКассовойСмены"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьПредоплатуВЧекахККМ.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж И Не АрхивироватьЧекиККМПриЗакрытииКассовойСмены;
		Элементы.ИспользоватьРассрочкуПлатежаВЧекахККМ.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж И Не АрхивироватьЧекиККМПриЗакрытииКассовойСмены;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ОтправкаЭлектронныхЧековПослеПробитияЧека.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж"
		Или РеквизитПутьКДанным = "ОтправкаЭлектронныхЧековПослеПробитияЧека"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.АвтоматическаяОтправкаЭлектронныхЧековПоРасписанию.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж И ОтправкаЭлектронныхЧековПослеПробитияЧека = 1;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж"
		Или РеквизитПутьКДанным = "ОтправкаЭлектронныхЧековПослеПробитияЧека"
		Или РеквизитПутьКДанным = "АвтоматическаяОтправкаЭлектронныхЧековПоРасписанию"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.РассылкаЭлектронныхЧековРасписание.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж
			И ОтправкаЭлектронныхЧековПослеПробитияЧека = 1
			И АвтоматическаяОтправкаЭлектронныхЧековПоРасписанию;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ОткрытьОчередьЭлектронныхЧеков.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		НастроитьГруппуНовоеРМК();
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьНовоеРМК" Или РеквизитПутьКДанным = "" Тогда
		НастроитьГруппуНовоеРМК();
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияСуммовойУчетВРознице.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьПодсчетПосетителей.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ГруппаНовоеРМК.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетРозничныхПродаж" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьОплатуКредитом.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж;
	КонецЕсли;
	Если РеквизитПутьКДанным = "КонтролироватьОстаткиПриПробитииЧековККМ"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ДекорацияНастроитьИсключения.Доступность = КонтролироватьОстаткиПриПробитииЧековККМ;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ИспользоватьБиллинг" Или РеквизитПутьКДанным = "" Тогда
		Элементы.БиллингВестиУчетРасходовПоДоговорамОбслуживания.Доступность = ИспользоватьБиллинг;
	КонецЕсли;
	Если РеквизитПутьКДанным = "БиллингВестиУчетРасходовПоДоговорамОбслуживания" Или РеквизитПутьКДанным = "" Тогда
		Элементы.БиллингГоловноеНаправлениеДеятельности.Доступность = БиллингВестиУчетРасходовПоДоговорамОбслуживания;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетПоНесколькимСкладам" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияРазрешитьСкладыВТабличныхЧастях.Доступность = ФункциональнаяОпцияУчетПоНесколькимСкладам;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ИспользоватьСерииНоменклатуры" Или РеквизитПутьКДанным = "" Тогда
		Элементы.КонтрольОстатковСерийНоменклатуры.Доступность = ИспользоватьСерииНоменклатуры;
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьСервисРасчетПотребностей" Или РеквизитПутьКДанным = "" Тогда
		Элементы.УчетПотребностиПоСкладам.Доступность = ФункциональнаяОпцияИспользоватьСервисРасчетПотребностей;
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетГТД" Или РеквизитПутьКДанным = "" Тогда
		
		Элементы.КонтролироватьОстаткиПоНомерамГТД.Доступность = ФункциональнаяОпцияУчетГТД;
		Элементы.ТребоватьЗаполнениеГТДИмпортногоТовара.Доступность = ФункциональнаяОпцияУчетГТД;
		Элементы.АвтоПодборНомеровГТД.Доступность = ФункциональнаяОпцияУчетГТД;
		Элементы.ВестиУчетПрослеживаемыхТоваров.Доступность = ФункциональнаяОпцияУчетГТД;
		
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПартии" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияПриемЗапасовНаОтветХранение.Доступность = ФункциональнаяОпцияИспользоватьПартии;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуРаботы" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ИспользоватьВидыЗаказНарядов.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуРаботы;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуРаботы" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ИспользоватьРемонты.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуРаботы;
		Элементы.ИспользоватьРемонты2.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуРаботы;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуРаботы" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияПланироватьЗагрузкуРесурсовПредприятияРаботы.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуРаботы;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуПроизводство"
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияРезервированиеЗапасов"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьЭтапыПроизводства.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуПроизводство
			И ФункциональнаяОпцияРезервированиеЗапасов;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьЭтапыПроизводства"
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияУчетПоНесколькимПодразделениям"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияВыполнениеЭтаповРазнымиПодразделениями.Доступность = ФункциональнаяОпцияИспользоватьЭтапыПроизводства
			И ФункциональнаяОпцияУчетПоНесколькимПодразделениям;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуПроизводство" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьТехоперации.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуПроизводство;
		Элементы.ИспользоватьРучноеРаспределениеМатериаловПоУмолчанию.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуПроизводство;
		Элементы.ФункциональнаяОпцияИспользоватьПараметрическиеСпецификации.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуПроизводство;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьТехоперации" Или РеквизитПутьКДанным = "" Тогда
		Элементы.АвтоматическиПланироватьОперацийЗаказомНаПроизводство.Доступность = ФункциональнаяОпцияИспользоватьТехоперации;
		Элементы.РасчетСтоимостиОперацийПоНормеВремени.Доступность = ФункциональнаяОпцияИспользоватьТехоперации;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуПроизводство"
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПартии"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияПереработкаДавальческогоСырья.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуПроизводство
			И ФункциональнаяОпцияИспользоватьПартии;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуПроизводство" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияПланироватьЗагрузкуРесурсовПредприятия.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуПроизводство;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяУчетВалютныхОпераций" Или РеквизитПутьКДанным = "" Тогда
		Элементы.НациональнаяВалюта.Доступность = ФункциональнаяУчетВалютныхОпераций;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяУчетВалютныхОпераций" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ВалютаУчета.Доступность = ФункциональнаяУчетВалютныхОпераций;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияПлатежныйКалендарь" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьРезервированиеДенежныхСредств.Доступность = ФункциональнаяОпцияПлатежныйКалендарь;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяУчетВалютныхОпераций" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ЧастотаРасчетаКурсовыхРазниц.Видимость = ФункциональнаяУчетВалютныхОпераций;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяУчетВалютныхОпераций" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ДекорацияСписокВалют.Видимость = ФункциональнаяУчетВалютныхОпераций;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуЗарплата" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияВестиШтатноеРасписание.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуЗарплата;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуЗарплата" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьСовместительство.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуЗарплата;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуЗарплата" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияВестиУчетНалогаНаДоходыИВзносов.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуЗарплата;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодсистемуЗарплата" Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияВыполнятьРасчетНДФЛПоПрогрессивнойШкале.Доступность = ФункциональнаяОпцияИспользоватьПодсистемуЗарплата;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ПередачаТоваровМеждуОрганизациями" 
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.НастройкаПередачиТоваровМеждуОрганизациями.Доступность = ПередачаТоваровМеждуОрганизациями;
	КонецЕсли;
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьАгентскиеУслуги"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьАгентскиеПлатежиИРазделениеВыручки.Доступность = ФункциональнаяОпцияИспользоватьАгентскиеУслуги;
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияПриемТоваровНаКомиссию"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ЗапретКомиссионныхПартийБезВладельца.Доступность = ФункциональнаяОпцияПриемТоваровНаКомиссию;
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьМинимальныеЦены" 
		ИЛИ РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияМинимальныеЦеныОтступ.Видимость = ФункциональнаяОпцияИспользоватьМинимальныеЦены;
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ИспользоватьСерверЛояльностиПоставщикДанных"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ВидКартыСерверЛояльности.Доступность = ИспользоватьСерверЛояльностиПоставщикДанных;
	КонецЕсли; 
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьАвтоматическиеСкидкиНаценки" 
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьДисконтныеКарты" 
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьБонусныеПрограммы"
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПромокоды"
		Или РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПодарочныеСертификаты"
		Или РеквизитПутьКДанным = "" Тогда
		
		Элементы.ГруппаИспользоватьСерверЛояльностиПоставщикДанных.Доступность = 
					(ФункциональнаяОпцияИспользоватьАвтоматическиеСкидкиНаценки 
					ИЛИ ФункциональнаяОпцияИспользоватьДисконтныеКарты
					ИЛИ ФункциональнаяОпцияИспользоватьБонусныеПрограммы
					ИЛИ ФункциональнаяОпцияИспользоватьПромокоды
					ИЛИ ФункциональнаяОпцияИспользоватьПодарочныеСертификаты);
					
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьПечатьЭтикетокИЦенников"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ИспользоватьСтаруюОбработкуПечатиЦенниковСклад.Видимость = ФункциональнаяОпцияИспользоватьПечатьЭтикетокИЦенников
			И Не ПолучитьФункциональнуюОпцию("ИспользоватьТолькоНовуюОбработкуПечатиЦенников");
		Элементы.ИспользоватьСтаруюОбработкуПечатиЦенников.Видимость      = ФункциональнаяОпцияИспользоватьПечатьЭтикетокИЦенников
			И Не ПолучитьФункциональнуюОпцию("ИспользоватьТолькоНовуюОбработкуПечатиЦенников");
	КонецЕсли;
	
	// БЗКБ
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьОтчетность"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьРегламентированныйУчетЗарплатыИКадров.Доступность = ФункциональнаяОпцияИспользоватьОтчетность;
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияИспользоватьРегулярныеПлатежи"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ФункциональнаяОпцияИспользоватьРегулярныеПлатежи.Доступность = РегистрацияВзаимодействия;
	КонецЕсли;
	
	// Акцизы
	Если РеквизитПутьКДанным = "ИмпортПодакцизныхТоваров"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ГруппаИмпортАкцизовПодсказка.Видимость = ИмпортПодакцизныхТоваров;
		Если Не ИспользоватьНесколькоОрганизаций Тогда
			Элементы.ОткрытьСписокОрганизацийИмпорт.Заголовок = НСтр("ru = 'Настроить учет подакцизных товаров'");
			Элементы.ДекорацияИмпортАкцизов.Видимость = Ложь;
		Иначе
			Элементы.ДекорацияИмпортАкцизов.Видимость = Истина;
			Элементы.ОткрытьСписокОрганизацийИмпорт.Заголовок = НСтр("ru = 'Открыть список организаций'");
		КонецЕсли;
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ПроизводствоПодакцизныхТоваров"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ГруппаПроизводствоАкцизовПодсказка.Видимость = ПроизводствоПодакцизныхТоваров;
		Если Не ИспользоватьНесколькоОрганизаций Тогда
			Элементы.ОткрытьСписокОрганизацийПроизводство.Заголовок = НСтр("ru = 'Настроить учет подакцизных товаров'");
			Элементы.ДекорацияПроизводствоАкцизов.Видимость = Ложь;
		Иначе
			Элементы.ОткрытьСписокОрганизацийПроизводство.Заголовок = НСтр("ru = 'Открыть список организаций'");
			Элементы.ДекорацияПроизводствоАкцизов.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;  
	
	Если РеквизитПутьКДанным = "ФункциональнаяОпцияУчетЦенКонтрагентов"
		Или РеквизитПутьКДанным = "" Тогда  
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФункциональнаяОпцияРегистрироватьЦеныКонтрагентов", 
			"Видимость", ФункциональнаяОпцияУчетЦенКонтрагентов); 
	КонецЕсли;
	
	Если РеквизитПутьКДанным = "ИспользоватьДокументРасходыПредпринимателя"
		Или РеквизитПутьКДанным = "" Тогда
		Элементы.ИспользоватьДокументРасходыПредпринимателя.Доступность = НастройкиУНФ.ЕстьХотяБыОднаОрганизацияИП();
	КонецЕсли;
	
КонецПроцедуры

// Подходит для установки видимости настроек в зависимости от режима работы приложения.
//
&НаСервере
Процедура ПриУстановкеВидимостиНастроекПриСозданииНаСервере()
	
	Элементы.ОтправкаЭлектронныхЧековПослеПробитияЧека.Видимость = Не РежимРаботы.МодельСервиса;
	Элементы.АвтоматическаяОтправкаЭлектронныхЧековПоРасписанию.Видимость = Не РежимРаботы.МодельСервиса;
	Элементы.РассылкаЭлектронныхЧековРасписание.Видимость = Не РежимРаботы.МодельСервиса;
	
	ДоступностьНовогоРМК = Не ПолучитьФункциональнуюОпцию("ИспользоватьТолькоНовыйРМК");
	Элементы.ФункциональнаяОпцияИспользоватьНовоеРМК.Доступность = ДоступностьНовогоРМК;
	
	ПродажиЗакупкиВключены = ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуПродажи") И ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуЗакупки");
	Элементы.ЗаполнениеРеквизитовВзаиморасчетовКонтрагентовПоУмолчанию.Видимость = ПродажиЗакупкиВключены;
	
КонецПроцедуры

// Процедура - При определении тумблеров недоступной функциональности конфигурации
//
// Параметры:
//  ПоляНедоступности - Соответствие	 - Поля недоступности
//
//@skip-check doc-comment-collection-item-type
&НаСервере
Процедура ПриОпределенииТумблеровНедоступнойФункциональностиКонфигурации(ПоляНедоступности)
	
	ПоляНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьПодсистемуРаботы.Имя,
		Элементы.ФункциональнаяОпцияИспользоватьПодсистемуРаботы.Имя);
	ПоляНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьПодсистемуПроизводство.Имя,
		Элементы.ФункциональнаяОпцияИспользоватьПодсистемуПроизводство.Имя);
	ПоляНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьОтчетность.Имя,
		Элементы.ФункциональнаяОпцияИспользоватьОтчетность.Имя);
	
КонецПроцедуры

&НаСервере
Процедура ПриОпределенииГруппНедоступнойФункциональностиКонфигурации(ГруппыНедоступности)
	
	// Раздел Главное
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияКонтрольДоговоров.Имя,
		Элементы.СтраницаГлавноеГруппаКонтрагенты.Имя);
	
	// Раздел CRM
	ЭлементыНедоступности = Новый Массив;
	ЭлементыНедоступности.Добавить(Элементы.СтраницаCRMГруппаCRM.Имя);
	ЭлементыНедоступности.Добавить(Элементы.СтраницаCRMГруппаПланирование.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ИспользоватьПодсистемуCRM.Имя, ЭлементыНедоступности);
	
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияПланироватьЗагрузкуРесурсовПредприятияЖурналЗаписи.Имя,
		Элементы.СтраницаCRMГруппаПланирование.Имя);
	
	// Раздел Продажи
	ГруппыНедоступности.Вставить(Метаданные.Константы.ИспользоватьБиллинг.Имя,
		Элементы.СтраницаПродажиГруппаБиллингНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьРучныеСкидкиНаценкиПродажи.Имя,
		Элементы.СтраницаПродажиГруппаЦеныИСкидки.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияПриемТоваровНаКомиссию.Имя,
		Элементы.ГруппаЗапретКомиссионныхПартийБезВладельца.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьАгентскиеУслуги.Имя,
		Элементы.ГруппаФункциональнаяОпцияИспользоватьАгентскиеУслугиОтступ.Имя);
		
	ЭлементыНедоступности = Новый Массив;
	ЭлементыНедоступности.Добавить(Элементы.СтраницаПродажиГруппаРозничныеПродажи.Имя);
	ЭлементыНедоступности.Добавить(Элементы.СтраницаПродажиГруппаСмТакжеАдминистрирование.Имя);
	ЭлементыНедоступности.Добавить(Элементы.ГруппаФункциональнаяОпцияИспользоватьОплатуКредитомНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияУчетРозничныхПродаж.Имя, ЭлементыНедоступности);
	
	ЭлементыНедоступности = Новый Массив;
	ЭлементыНедоступности.Добавить(Элементы.ГруппаИспользоватьРемонтыНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ИспользоватьРемонты.Имя, ЭлементыНедоступности);
	
	// Раздел Закупки
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияПередачаЗапасовНаОтветХранение.Имя,
		Элементы.СтраницаЗакупкиГруппаПереработкаНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияПриемЗапасовНаОтветХранение.Имя,
		Элементы.СтраницаЗакупкиГруппаПереработкаНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияПередачаСырьяВПереработку.Имя,
		Элементы.СтраницаЗакупкиГруппаПереработкаНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьРучныеСкидкиНаценкиЗакупки.Имя,
		Элементы.СтраницаЗакупкиГруппаЦеныСкидки.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьСервисРасчетПотребностей.Имя,
		Элементы.СтраницаЗакупкиГруппаПланирование.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияУчетГТД.Имя,
		Элементы.СтраницаЗакупкиГруппаИмпорт.Имя);
		
	// Раздел Склад
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияУчетПоЯчейкам.Имя,
		Элементы.ГруппаФункциональнаяОпцияУчетПоЯчейкамНедоступность.Имя);
	
	// Раздел Работы
	ЭлементыНедоступности = Новый Массив;
	ЭлементыНедоступности.Добавить(Элементы.СтраницаРаботыГруппаРаботы.Имя);
	ЭлементыНедоступности.Добавить(Элементы.СтраницаРаботыГруппаПланирование.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьПодсистемуРаботы.Имя, ЭлементыНедоступности);
	
	// Раздел Производство
	ЭлементыНедоступности = Новый Массив;
	ЭлементыНедоступности.Добавить(Элементы.СтраницаПроизводствоГруппаПроизводство.Имя);
	ЭлементыНедоступности.Добавить(Элементы.СтраницаПроизводствоГруппаПереработка.Имя);
	ЭлементыНедоступности.Добавить(Элементы.СтраницаПроизводствоГруппаПланирование.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьПодсистемуПроизводство.Имя, ЭлементыНедоступности);
	
	// Раздел Деньги
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяУчетВалютныхОпераций.Имя,
		Элементы.ГруппаФункциональнаяУчетВалютныхОперацийНедоступность.Имя);
		
	ГруппыНедоступности.Вставить(Метаданные.Константы.ЗачитыватьАвансыДолгиАвтоматически.Имя,
		Элементы.ГруппаЗачитыватьАвансыДолгиАвтоматическиНедоступность.Имя);
		
	ЭлементыНедоступности = Новый Массив;
	ЭлементыНедоступности.Добавить(Элементы.ГруппаФункциональнаяОпцияКредитыИЗаймыНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияКредитыИЗаймы.Имя, ЭлементыНедоступности);
	
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьРезервированиеДенежныхСредств.Имя,
		Элементы.ГруппаФункциональнаяОпцияИспользоватьРезервированиеДенежныхСредствНедоступность.Имя);
		
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияПлатежныйКалендарь.Имя,
		Элементы.СтраницаДеньгиГруппаПланирование.Имя);
	
	// Раздел Персонал
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияВестиУчетНалогаНаДоходыИВзносов.Имя,
		Элементы.СтраницаЗарплатаГруппаНалогиНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияВыполнятьРасчетНДФЛПоПрогрессивнойШкале.Имя,
		Элементы.СтраницаЗарплатаГруппаНалогиНедоступность.Имя);
	
	// Раздел Компания
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияКассовыйМетодУчетаДоходовИРасходов.Имя,
		Элементы.ГруппаФункциональнаяОпцияКассовыйМетодУчетаДоходовИРасходовНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияУчетПоПроектам.Имя,
		Элементы.СтраницаКомпанияГруппаПроектыНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияИспользоватьБюджетирование.Имя,
		Элементы.СтраницаКомпанияГруппаПланированиеНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияУчетВнеоборотныхАктивов.Имя,
		Элементы.ГруппаФункциональнаяОпцияУчетВнеоборотныхАктивовНедоступность.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ФункциональнаяОпцияУчетПоНесколькимПодразделениям.Имя,
		Элементы.СтраницаКомпанияГруппаПодразделения.Имя);
	ГруппыНедоступности.Вставить(Метаданные.Константы.ПередачаТоваровМеждуОрганизациями.Имя,
		Элементы.ГруппаПередачаТоваров.Имя);

КонецПроцедуры

#КонецОбласти


&НаСервере
Функция ДанныеОрганизацииПоУмолчанию()
	
	ОрганизацияПоУмолчанию = Справочники.Организации.ОрганизацияПоУмолчанию();
	НалогообложениеОрганизации = Справочники.Организации.ПолучитьСистемуНалогообложения(ТекущаяДатаСеанса(), ОрганизацияПоУмолчанию);
	ДанныеПоОрганизации = Новый Структура("Организация, УСН", ОрганизацияПоУмолчанию, НалогообложениеОрганизации.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная); 
	
	Возврат ДанныеПоОрганизации;
	
КонецФункции

&НаСервере
Процедура ОбработатьОповещениеОбсужденияПодключены(ИмяСобытия)
	
	Если ИмяСобытия <> "ОбсужденияПодключены" Тогда
		Возврат;
	КонецЕсли;
	
	ПрочитатьЗначенияВсехНастроек();
	ПриУстановкеДоступностиНастроек();
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьОповещениеЗаписьНаборКонстант(ИмяСобытия)
	
	Если ИмяСобытия <> "Запись_НаборКонстант" Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ОбрабатыватьОповещениеЗаписьНаборКонстант Тогда
		ОбрабатыватьОповещениеЗаписьНаборКонстант = Истина;
		Возврат;
	КонецЕсли;
	
	ПрочитатьЗначенияВсехНастроек();
	ПриУстановкеДоступностиНастроек();
	
КонецПроцедуры

&НаСервере
Процедура АвтоПодборНомеровГТДПриИзмененииНаСервере()
	
	НовоеЗначение = ?(АвтоПодборНомеровГТД = Истина, Перечисления.ДаНет.Да, Перечисления.ДаНет.Нет);
	
	Константы.АвтоПодборНомеровГТД.Установить(НовоеЗначение);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокНастроекОтгрузки()
	
    Элементы.ДекорацияНастройкиСрокаОтгрузки.Заголовок = Обработки.НастройкаЗаполненияДатыОтгрузки.ПолучитьЗаголовок();

КонецПроцедуры

&НаСервере
Процедура ЗаписатьНастройкиСрокаОтгрузки(РезультатЗначение)
 
		НаборКонстант = Константы.СоздатьНабор("ВариантЗаполненияДатыОтгрузки,
		|ВидДнейРасчетаДатыОтгрузки, ПроизводственныйКалендарьРасчетаДатыОтгрузки, КоличествоДнейРасчетаДатыОтгрузки");
        ЗаполнитьЗначенияСвойств(НаборКонстант, РезультатЗначение);
		НаборКонстант.Записать();
		
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокНастроекОплаты()
	
    Элементы.ДекорацияНастройкиСрокаОплаты.Заголовок = Обработки.НастройкаЗаполненияДатыОплаты.ПолучитьЗаголовок();

КонецПроцедуры

&НаСервере
Процедура ЗаписатьНастройкиСрокаОплаты(РезультатЗначение)
 
		НаборКонстант = Константы.СоздатьНабор("ВариантЗаполненияДатыОплаты,
		|ВидДнейРасчетаДатыОплаты, ПроизводственныйКалендарьРасчетаДатыОплаты, КоличествоДнейРасчетаДатыОплаты");
        ЗаполнитьЗначенияСвойств(НаборКонстант, РезультатЗначение);
		НаборКонстант.Записать();
		
КонецПроцедуры

&НаСервере
Процедура НастроитьГруппуНовоеРМК()
	
	Элементы.ФункциональнаяОпцияИспользоватьНовоеРМК.Доступность = ФункциональнаяОпцияУчетРозничныхПродаж
		И Не ПолучитьФункциональнуюОпцию("ИспользоватьТолькоНовыйРМК");
	Элементы.ОткрытьПомощникНастройкиРМК.Видимость = ФункциональнаяОпцияИспользоватьНовоеРМК;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьПараметрыНаСервере()

	Если Не ПустаяСтрока(ВведеннаяСтрокаПоиска) Тогда
		ВосстановитьИсходнуюВидимостьНастроек();
		ВыполнитьПоискСервер();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
