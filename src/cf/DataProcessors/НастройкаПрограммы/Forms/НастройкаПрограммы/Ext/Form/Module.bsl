// Варианты создания настройки.
// См. методы в области "СлужебныеПроцедурыИФункции.ПереопределяемаяЧасть".
//
// Вариант 1. Универсальный. Для размещения настройки с простой логикой, когда настройка хранится в константе.
//   1. Создать реквизит на форме с именем константы.
//   2. Создать соответствующий элемент формы и вызвать обработчик изменения ПриИзмененииЭлементаУНФ().
//   2. Заполнить соответствие реквизита с константой в ПриОпределенииКонстантНаФорме().
//
// Вариант 2. Альтернативный. Для более сложных сценариев, когда значение настройки определяется алгоритмом.
//   1. Разместить реквизит на форме.
//   2. Создать соответствующий элемент формы и вызвать обработчик изменения ПриИзмененииЭлементаУНФ().
//   3. Прописать получение значения настройки в ПриПолученииЗначенийНастроек().
//   4. Прописать установку значения настройки в ПриСохраненииЗначенияНастройки().
//
// Универсальные процедуры выполняют общую для разных настроек логику:
//   - очищаются сообщения на клиенте,
//   - показываются сообщения об ошибке,
//   - отправляются глобальные оповещения,
//   - запускается перечитывание значений и установка доступности.
//
// Вариант 3. Сложный.
//   Без использования ПриИзмененииЭлементаУНФ().
//   Если предыдущие варианты не подходят, можно сделать отдельную реализацию, как серверную, так и клиентскую.

#Область ОписаниеПеременных

&НаКлиенте
Перем ОбновитьИнтерфейс;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РежимРаботы = Новый ФиксированнаяСтруктура(УправлениеНебольшойФирмойПовтИсп.РежимРаботыПрограммы());
	РазделениеВключено = ОбщегоНазначения.РазделениеВключено();
	ЭтоКонфигурацияРозница = ОбщегоНазначенияУНФ.ЭтоРозница();
	ЭтоКонфигурацияУНФ = ОбщегоНазначенияУНФ.ЭтоУНФ();
	
	Если ЗначениеЗаполнено(Параметры.СтрокаПоиска) Тогда
		ВведеннаяСтрокаПоиска = Параметры.СтрокаПоиска;
	КонецЕсли;
	
	ОформитьСтраницуБольшеВозможностей();
	УстановитьУсловноеОформление();
	ЗаполнитьСписокРазделов();
	
	ПрочитатьЗначенияВсехНастроек();
	ПриУстановкеДоступностиНастроек();
	ПриУстановкеВидимостиНастроекПриСозданииНаСервере();
	УстановитьЗаголовокНастроекОтгрузки();
	УстановитьЗаголовокНастроекОплаты();
	НастроитьДоступностьНастроекДляОграниченныхПрав();
	ОформитьНедоступныеНастройкиКонфигурации();
	УстановитьВидимостьПодсказокРазделов();
	
	ЭтоВнешнийПоиск = Параметры.ЭтоВнешнийПоиск;
	
	Если Параметры.Свойство("АвтоТест") Тогда
		ЗаполнитьТаблицуПоиска();
	КонецЕсли;
	
	Если Не ПустаяСтрока(ВведеннаяСтрокаПоиска) Тогда
		ЗаполнитьТаблицуПоиска();
		ВыполнитьПоискСервер();
	Иначе
		УстановитьВидимостьРазделовРекурсивно();
	КонецЕсли;
	
	НастроитьВидимостьФормыМобильныйКлиент();  
	
	Если Параметры.Свойство("ТекущаяСтраница") Тогда
		//@skip-check unknown-form-parameter-access
		СоответствующаяРазделуСтраница = Элементы.Найти(Параметры.ТекущаяСтраница);
		Если СоответствующаяРазделуСтраница <> Неопределено Тогда
			Элементы.СтраницыНастроек.ТекущаяСтраница = СоответствующаяРазделуСтраница;
		КонецЕсли;
		//@skip-check unknown-form-parameter-access
		СтрокиСпискаРазделов = СписокРазделов.НайтиСтроки(Новый Структура("Имя", Параметры.ТекущаяСтраница));
		Если СтрокиСпискаРазделов.Количество() > 0 Тогда   
			СтрокаСпискаРазделов = СтрокиСпискаРазделов[0];
			Элементы.СписокРазделов.ТекущаяСтрока = СтрокаСпискаРазделов.ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриПовторномОткрытии()
	
	ОбработатьПараметрыНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбсужденияПодключены" Тогда
		РегистрацияВзаимодействия = Параметр;
		ОбработатьОповещениеОбсужденияПодключены(ИмяСобытия);
		Если Параметр = Ложь Тогда
			ФункциональнаяОпцияИспользоватьРегулярныеПлатежи = Ложь;
			ПриИзмененииЭлементаУНФ(Элементы.ФункциональнаяОпцияИспользоватьРегулярныеПлатежи);
		КонецЕсли;
		Элементы.ФункциональнаяОпцияИспользоватьРегулярныеПлатежи.Доступность = Параметр;
	КонецЕсли;
	
	Если ИмяСобытия = "Запись_НаборКонстант" Тогда
		ОбработатьОповещениеЗаписьНаборКонстант(ИмяСобытия);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ФункциональнаяОпцияИспользоватьНовоеРМКПриИзменении(Элемент)
	
	ПриИзмененииЭлементаУНФ(Элементы.ФункциональнаяОпцияИспользоватьНовоеРМК);
	
	Если ФункциональнаяОпцияИспользоватьНовоеРМК Тогда
		
		ОповещениеОЗакрытииИнтерфейсаПомощникаНастройкиРМК =
			Новый ОписаниеОповещения("ЗакрытиеФормыПомощникаНастройкиРМК", ЭтотОбъект);
		
			ОткрытьФорму("Обработка.ПомощникНастройкиКассовогоМестаРМК.Форма.Форма",,
				ЭтотОбъект,
				УникальныйИдентификатор,,, ОповещениеОЗакрытииИнтерфейсаПомощникаНастройкиРМК,
				РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

#Область БольшеВозможностей

&НаКлиенте
Процедура ПредложитьВозможностьНажатие(Элемент)
	
	Тег = НСтр("ru = 'Еще больше возможностей'");
	УправлениеНебольшойФирмойКлиент.ПредложитьВозможностьНажатие(Тег);
	
КонецПроцедуры

#КонецОбласти


&НаКлиенте
Процедура ВведеннаяСтрокаПоискаПриИзменении(Элемент)
	
	ВосстановитьИсходнуюВидимостьНастроек();
	ВыполнитьПоискСервер();
	ВыбратьПервыйОтображаемыйРазделЕслиНеобходимо();
	
КонецПроцедуры

&НаКлиенте
Процедура ВведеннаяСтрокаПоискаОчистка(Элемент, СтандартнаяОбработка)
	
	ВосстановитьИсходнуюВидимостьНастроек();
	УстановитьВариантУправленияВысотойДляСпискаРазделов();
	
КонецПроцедуры

&НаКлиенте
Процедура АвтоПодборНомеровГТДПриИзменении(Элемент)
	
	АвтоПодборНомеровГТДПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиНумерацииДоговоровОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Если НавигационнаяСсылкаФорматированнойСтроки = "Нумерация" Тогда
		ОткрытьФорму("Справочник.НастройкиНумерацииДоговоровКонтрагентов.ФормаСписка");
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ШаблоныНаименований" Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Отбор", Новый Структура("ВидНаименования", ПредопределенноеЗначение("Перечисление.ВидыНаименованийОбъектов.ДоговорКонтрагента")));
		ОткрытьФорму("Справочник.ШаблоныНаименований.ФормаСписка", ПараметрыФормы, Элемент);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РассылкаЭлектронныхЧековРасписаниеНажатие(Элемент)
	НачатьИзменениеРасписанияРегламентногоЗадания("РассылкаЭлектронныхЧеков", Элемент.Имя);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОчередьЭлектронныхЧековНажатие(Элемент)
	ОткрытьФорму("Справочник.ОчередьЭлектронныхЧековКОтправке.ФормаСписка");
КонецПроцедуры

&НаКлиенте
Процедура ПереводыВПутиНажатие(Элемент)
	ОткрытьФорму("РегистрСведений.ПрименениеПереводовВПути.ФормаСписка");
КонецПроцедуры

&НаКлиенте
Процедура НастройкаОбязательностиЗаполненияИсточникПривлеченияНажатие(Элемент)
	ОткрытьФорму("Справочник.ИсточникиПривлеченияПокупателей.Форма.ФормаВыбораОбязательногоЗаполнения");
КонецПроцедуры

&НаКлиенте
Процедура АнализШтрихкодовНажатие(Элемент)
	ОткрытьФорму("ОбщаяФорма.АнализШтрихкодов");
КонецПроцедуры

&НаКлиенте
Процедура НастройкаСквознойКонтрольДублейНоменклатурыНажатие(Элемент)
	ОткрытьФорму("Обработка.НастройкаПрограммы.Форма.НастройкаКонтроляДублейНоменклатуры");
КонецПроцедуры

&НаКлиенте
Процедура НастройкаСквознойКонтрольДублейНажатие(Элемент)
	ОткрытьФорму("Обработка.НастройкаПрограммы.Форма.НастройкаСквозногоКонтроляДублей");
КонецПроцедуры

&НаКлиенте
Процедура ФункциональнаяОпцияПлатежныйКалендарьПриИзменении(Элемент)
	
	ПриИзмененииЭлементаУНФ(Элемент);
	
	Если НЕ ФункциональнаяОпцияПлатежныйКалендарь И ФункциональнаяОпцияИспользоватьРезервированиеДенежныхСредств Тогда
		ФункциональнаяОпцияИспользоватьРезервированиеДенежныхСредств = Ложь;
		ПриИзмененииЭлементаУНФ(Элементы.ФункциональнаяОпцияИспользоватьРезервированиеДенежныхСредств);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнениеРеквизитовВзаиморасчетовКонтрагентовПоУмолчаниюНажатие(Элемент)
	
	ОткрытьФорму("Обработка.НастройкаПрограммы.Форма.ЗаполнениеРеквизитовВзаиморасчетовКонтрагентов");
	
КонецПроцедуры

&НаКлиенте
Процедура СтатьяПроОтчетностьНажатие(Элемент)
	
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку("https://v8.1c.ru/small.biz/otchetnost-i-nalogi/");
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаПередачиТоваровМеждуОрганизациямиНажатие(Элемент)
	ОткрытьФорму("РегистрСведений.НастройкаПередачиТоваровМеждуОрганизациями.Форма.ФормаСписка");
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияНастройкиСрокаОтгрузкиНажатие(Элемент)
	
	Оповещение = Новый ОписаниеОповещения("НастройкаЗаполненияДатыОтгрузкиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.НастройкаЗаполненияДатыОтгрузки.Форма.ФормаНастроек",,,,,,Оповещение);

КонецПроцедуры

&НаКлиенте
Процедура ДекорацияНастройкиСрокаОплатыНажатие(Элемент)
	
	Оповещение = Новый ОписаниеОповещения("НастройкаЗаполненияДатыОплатыЗавершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.НастройкаЗаполненияДатыОплаты.Форма.ФормаНастроек",,,,,,Оповещение);

КонецПроцедуры

&НаКлиенте
Процедура ДекорацияПодключитьКассыК_ОФДНажатие(Элемент)
	
	Если Не ФункциональнаяОпцияУчетРозничныхПродаж Тогда
		Оповещение = Новый ОписаниеОповещения("ДекорацияПодключитьКассыК_ОФДНажатиеЗавершение", ЭтотОбъект);
		ПоказатьВопрос(
			Оповещение,
			НСтр("ru = 'Включить учет розничных продаж?'"),
			РежимДиалогаВопрос.ДаНет,,
			КодВозвратаДиалога.Да,
			НСтр("ru = 'Учет розничных продаж'"));
	Иначе
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку("http://v8.1c.ru/cnt.jsp/:kd_unf:/https://portal.1c.ru/applications/56");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияВсеО54ФЗНажатие(Элемент)
	
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку("http://v8.1c.ru/cnt.jsp/:kd_unf:/http://v8.1c.ru/kkt");
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияНастроитьИсключенияНажатие(Элемент)
	
	ОткрытьФорму("РегистрСведений.ИсключенияКонтроляОстатковВРознице.ФормаСписка",,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

 &НаКлиенте
Процедура ОткрытьСписокОрганизацийПроизводствоНажатие(Элемент)
	
	Если ИспользоватьНесколькоОрганизаций Тогда
		ОткрытьФорму("Справочник.Организации.ФормаСписка");
	Иначе
		ДанныеПоОрганизации = ДанныеОрганизацииПоУмолчанию();
		ПараметрыОткрытия = Новый Структура("Организация, ПрименяетсяУСН",  ДанныеПоОрганизации.Организация, ДанныеПоОрганизации.УСН);
		ОткрытьФорму("Справочник.Организации.Форма.ФормаНастройкиАкцизов", ПараметрыОткрытия);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСписокОрганизацийИмпортНажатие(Элемент)
	
	Если ИспользоватьНесколькоОрганизаций Тогда
		ОткрытьФорму("Справочник.Организации.ФормаСписка");
	Иначе
		ДанныеПоОрганизации = ДанныеОрганизацииПоУмолчанию();
		ПараметрыОткрытия = Новый Структура("Организация, ПрименяетсяУСН",  ДанныеПоОрганизации.Организация, ДанныеПоОрганизации.УСН);
		ОткрытьФорму("Справочник.Организации.Форма.ФормаНастройкиАкцизов", ПараметрыОткрытия);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФункциональнаяОпцияПриемЗапасовНаОтветХранениеРасширеннаяПодсказкаОбработкаНавигационнойСсылки(Элемент,
		НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПерейтиНаНастройку(НСтр("ru = 'партии номенк'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ФункциональнаяОпцияПриемТоваровНаКомиссиюРасширеннаяПодсказкаОбработкаНавигационнойСсылки(Элемент,
		НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПерейтиНаНастройку(НСтр("ru = 'партии номенк'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ФункциональнаяОпцияПереработкаДавальческогоСырьяРасширеннаяПодсказкаОбработкаНавигационнойСсылки(Элемент,
		НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПерейтиНаНастройку(НСтр("ru = 'партии номенк'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ОтслеживатьСтатусыОтчетовОРозничныхПродажахПриИзменении(Элемент)
	
	Если ОтслеживатьСтатусыОтчетовОРозничныхПродажах Тогда
		ПриИзмененииЭлементаУНФ(Элемент);
		Возврат;
	КонецЕсли;
	
	ТекстЗаголовка = НСтр("ru = 'Статусы отчетов о розничных продажах'");
	ТекстВопроса = НСтр("ru = 'При выключении опции статусы отслеживаемых документов будут очищены.'");

	КнопкиОтвета = Новый СписокЗначений;
	КнопкиОтвета.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Продолжить'"));
	КнопкиОтвета.Добавить(КодВозвратаДиалога.Нет, НСтр("ru = 'Отмена'"));

	ОповещениеЗавершения = Новый ОписаниеОповещения("ОтслеживатьСтатусыОтчетовОРозничныхПродажахПриИзмененииЗавершение",
		ЭтотОбъект);
	ПоказатьВопрос(ОповещениеЗавершения, ТекстВопроса, КнопкиОтвета, , , ТекстЗаголовка);
	
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьНесколькоВариантовКППриИзменении(Элемент)
	ПриИзмененииЭлементаУНФ(Элемент);
