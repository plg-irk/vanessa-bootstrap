	ФормаПараметрыИмпортаДанныхОписаниеОбновить();
	
	
	ИмпортируемыеТовары.ПолучитьЭлементы().Очистить();    
	
	ФормаРежимОтображенияЭлементыОбновить( ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияЗагрузитьСДетальнымиНастройками() );

