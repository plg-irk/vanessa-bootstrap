&НаКлиенте
Процедура ФормаПараметрыИмпортаДанныхОписаниеОбновить()

	Если ВариантЗагрузкиДанных = 0 Тогда
		ПараметрыИмпортаДанныхЗаголовок = НСтр("ru = ' • Обновлять сопоставленные карточки товаров'");
	Иначе
		ПараметрыИмпортаДанныхЗаголовок = НСтр("ru = ' • Загружать несопоставленные карточки товаров'");
	КонецЕсли;

	Если ЗначениеЗаполнено( РазмерПорцииЗагрузкиДанных ) Тогда
		ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
		+ СтрШаблон( " " + НСтр( "ru = '(%1 позиций за один запрос)'" ),
		РазмерПорцииЗагрузкиДанных );
	КонецЕсли;
	
	Если ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда
		Если ЗагрузитьОписанияАрхивныхПозиций Тогда
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
			+ НСтр("ru = ' • Загружать архивные позиции'");
		Иначе
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
			+ НСтр("ru = ' • Не загружать архивные позиции'");
		КонецЕсли;

		Если СоздатьЭлементыНоменклатуры Тогда
			ДополнениеЗаголовкаШаблон = НСтр("ru = ' • Создавать «Номенклатуру» в группе ""%1""'");
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
			+ СтрШаблон( ДополнениеЗаголовкаШаблон, ГруппаДляСозданияНовыхТоваров );
		Иначе
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
			+ НСтр("ru = ' • Не создавать «Номенклатуру»'");
		КонецЕсли;

	КонецЕсли;
    
	ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок + Символы.ПС;

	Если ПерезаполнитьЗначенияРеквизитовНоменклатуры Тогда
		ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
		+ НСтр("ru = ' • Перезаполнять значения реквизитов «Номенклатуры»'")
	КонецЕсли;

	Если ЗагрузитьИзображения Тогда
		ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
		+ НСтр("ru = ' • Загружать изображения'");
	Иначе
		ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
		+ НСтр("ru = ' • Не загружать изображения'");
	КонецЕсли;

	Если ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда

		Если СоздатьХарактеристикиНоменклатуры Тогда
			ДополнениеЗаголовкаТекст = НСтр("ru = ' • Создавать «Характеристики номенклатуры»'");
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
			+ ДополнениеЗаголовкаТекст;
		Иначе
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
				+ НСтр("ru = ' • Не создавать «Характеристики номенклатуры»'");
		КонецЕсли;

		Если СоздатьКатегорииНоменклатуры Тогда
			ДополнениеЗаголовкаТекст = НСтр("ru = ' • Создавать «Категории номенклатуры»'");
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
			+ ДополнениеЗаголовкаТекст;
		Иначе
			ПараметрыИмпортаДанныхЗаголовок = ПараметрыИмпортаДанныхЗаголовок
			+ НСтр("ru = ' • Не создавать «Категории номенклатуры»'");
		КонецЕсли;
	КонецЕсли;
	
	Элементы.ПараметрыИмпортаДанныхОписание.Заголовок = ПараметрыИмпортаДанныхЗаголовок;

КонецПроцедуры

