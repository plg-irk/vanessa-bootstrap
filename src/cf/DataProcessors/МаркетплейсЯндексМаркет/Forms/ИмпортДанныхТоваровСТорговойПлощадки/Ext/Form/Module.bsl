
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Параметры.Свойство( "УчетнаяЗаписьМаркетплейса", УчетнаяЗаписьМаркетплейса );
	Параметры.Свойство( "ВариантЗагрузкиДанных", ВариантЗагрузкиДанных );

	Параметры.Свойство( "ИмяИдентификатора", ИмяИдентификатора );
	Если Не ЗначениеЗаполнено( ИмяИдентификатора ) Тогда
		ИмяИдентификатора = "ИдентификаторПубликации";
	КонецЕсли;

	Параметры.Свойство( "РазмерПорцииЗагрузкиДанных", РазмерПорцииЗагрузкиДанных );
	
	Если ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда 
		Если Не ЗначениеЗаполнено( РазмерПорцииЗагрузкиДанных ) Тогда
			РазмерПорцииЗагрузкиДанных = 100;
		КонецЕсли;
	КонецЕсли;
	
	Параметры.Свойство( "СоздатьЭлементыНоменклатуры", СоздатьЭлементыНоменклатуры );
	Параметры.Свойство( "ПерезаполнитьЗначенияРеквизитовНоменклатуры", ПерезаполнитьЗначенияРеквизитовНоменклатуры );
	Параметры.Свойство( "СоздатьИерархиюНоменклатуры", СоздатьИерархиюНоменклатуры );
	Параметры.Свойство( "СоздатьХарактеристикиНоменклатуры", СоздатьХарактеристикиНоменклатуры );
	
	Параметры.Свойство( "СоздатьКатегорииНоменклатуры", СоздатьКатегорииНоменклатуры);
	Параметры.Свойство( "СоздатьИерархиюКатегорийНоменклатуры", СоздатьИерархиюКатегорийНоменклатуры );
	
	Параметры.Свойство( "ЗагрузитьИзображения", ЗагрузитьИзображения );	
	Параметры.Свойство( "ЗагрузитьЦеныПродажи", ЗагрузитьЦеныПродажи );
	
	Параметры.Свойство( "ЗагрузитьОписанияАрхивныхПозиций", ЗагрузитьОписанияАрхивныхПозиций );
	Параметры.Свойство( "СортироватьСтрокиДереваТоваров", СортироватьСтрокиДереваТоваров );
	Параметры.Свойство( "ИдентификаторКампанииЯндексМаркет", ИдентификаторКампанииЯндексМаркет );
	
	
	ДанныеВыделенныхСтрок = ОбменСВнешнимиСистемамиЛогирование.ПолучитьЗначениеПоля( Параметры, "ДанныеВыделенныхСтрок", Новый Массив );
	Если ТипЗнч( ДанныеВыделенныхСтрок ) <> Тип( "Массив" ) Тогда
		ДанныеВыделенныхСтрок = Новый Массив;
	КонецЕсли;
	
	ЗаписатьЦеныОтдельнойКомандой = Ложь;
	
	ИзменитьРеквизитыФормы();
    
	Если ДанныеВыделенныхСтрок.Количество() > 0 Тогда 
		СтрокаДереваГруппаОбновить = ИмпортируемыеТовары.ПолучитьЭлементы().Добавить();
		СтрокаДереваГруппаОбновить.ВариантЗагрузки = 0;
		СтрокаДереваГруппаОбновить.ИндексСтатуса = -2;

		Для каждого КлючЗаписи Из ДанныеВыделенныхСтрок Цикл
			Запись = РегистрыСведений.СтатусыПубликацииТоваровЯндексМаркет.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(Запись, КлючЗаписи);
			Запись.Прочитать();
			
			Если Запись.Выбран() Тогда
				СтрокаДереваВторогоУровня = СтрокаДереваГруппаОбновить.ПолучитьЭлементы().Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаДереваВторогоУровня, Запись,, "ДанныеОбъекта, ИсточникиСхожихПредложений");
				
				СтрокаДереваВторогоУровня.Пометка = Истина;
				СтрокаДереваВторогоУровня.ВариантЗагрузки = 0;
				СтрокаДереваВторогоУровня.ИндексСтатуса = 5;
				СтрокаДереваВторогоУровня.ПродаетсяПоСхемеРаботыFBO = Истина;

				ДанныеОбъекта = Запись.ДанныеОбъекта.Получить();
				Если ДанныеОбъекта <> Неопределено Тогда
					СтрокаДереваВторогоУровня.ДанныеОбъекта.Загрузить(ДанныеОбъекта);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	ИсточникКатегории = ОбщегоНазначения.ЗначениеРеквизитаОбъекта( УчетнаяЗаписьМаркетплейса, "ИсточникКатегории" );
	
	Если ИсточникКатегории = ПредопределенноеЗначение("Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры") Тогда
		Элементы.ИмпортируемыеТоварыКатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет.Заголовок = "Категория для сопоставления с категорией Яндекс Маркет";
		Элементы.ИмпортируемыеТоварыКатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.КатегорииНоменклатуры");
	ИначеЕсли ИсточникКатегории = ПредопределенноеЗначение("Перечисление.ИсточникиКатегорийДляМаркетплейса.ИерархияНоменклатуры") Тогда
		Элементы.ИмпортируемыеТоварыКатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет.Заголовок = "Номенклатура или группа для сопоставления с категорией Яндекс Маркет";
		Элементы.ИмпортируемыеТоварыКатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	КонецЕсли;
	
	ОтображатьСопоставленные = 0;
	ОтображатьПоСтатусу = -1;
	ОбновитьКнопкуОтбораПоСтатусу("ОтобратьПоСтатусуВсе");
	
	Заголовок = НСтр("ru = 'Импорт описаний товаров с торговой площадки Яндекс Маркет'") + ", " + СокрЛП( УчетнаяЗаписьМаркетплейса );
	УстановитьУсловноеОформление();

	Если ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда 
		Элементы.ГруппаИмпортДанных.Видимость = Ложь;
	КонецЕсли;
	
	Если СоздатьЭлементыНоменклатуры = Ложь Тогда
		ПерезаполнитьЗначенияРеквизитовНоменклатуры = Ложь;
		СоздатьИерархиюНоменклатуры = Ложь;
		СоздатьХарактеристикиНоменклатуры = Ложь;
		СоздатьКатегорииНоменклатуры = Ложь;
		СоздатьИерархиюКатегорийНоменклатуры = Ложь;
		ЗагрузитьИзображения = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	//@skip-check invocation-form-event-handler
	ВариантЗагрузкиДанныхПриИзменении(Неопределено);
	
	Если ИмпортируемыеТовары.ПолучитьЭлементы().Количество() > 0 Тогда
		ПодключитьОбработчикОжидания( "ОбновитьСлужебныеДанные", 0.1, Истина);
	КонецЕсли;
	
	ФормаРежимОтображенияЭлементыОбновить( ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияОткрытие() );
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗакрытьФормуОбработки Тогда
		Отказ = Истина;

		ОповещениеОЗавершении = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект,);
		ПоказатьВопрос(ОповещениеОЗавершении, 
			НСтр("ru = 'Закрыть форму?'"), 
			РежимДиалогаВопрос.ДаНет, 
			, 
			КодВозвратаДиалога.Нет, 
			НСтр("ru = 'Импорт данных'"), 
			КодВозвратаДиалога.Нет);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоАдресВременногоХранилища(АдресИзображения) Тогда
		УдалитьИзВременногоХранилища(АдресИзображения);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ИмяСобытия = "УчетнаяЗаписьДеактивирована" Тогда
		Если Параметр = УчетнаяЗаписьМаркетплейса Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Учетная запись маркетплейса удалена. Дальнейшее использование обработки недоступно.'"));
            ТолькоПросмотр = Истина;
			УстановитьВидимостьДоступность();
			ФормаПараметрыИмпортаДанныхОписаниеОбновить();
		КонецЕсли;

	ИначеЕсли ИмяСобытия = "Запись_УчетныеЗаписиМаркетплейсов" Тогда
		Если Параметр = УчетнаяЗаписьМаркетплейса Тогда
			УстановитьВидимостьДоступность();
			ФормаПараметрыИмпортаДанныхОписаниеОбновить();
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ИсточникКатегорииИзменен" Тогда
		Если УчетнаяЗаписьМаркетплейса = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметр, "УчетнаяЗаписьМаркетплейса", ПредопределенноеЗначение("Справочник.УчетныеЗаписиМаркетплейсов.ПустаяСсылка")) Тогда
			ОбновитьКатегорииТоваров(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметр, "ИсточникКатегории", ПредопределенноеЗначение("Перечисление.ИсточникиКатегорийДляМаркетплейса.ПустаяСсылка")));
		КонецЕсли; 
		
	ИначеЕсли ИмяСобытия = "Запись_Номенклатура" Тогда
		Для каждого СтрокаДереваПервогоУровня Из ИмпортируемыеТовары.ПолучитьЭлементы() Цикл
			Для каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.ПолучитьЭлементы() Цикл
				Если СтрокаДереваВторогоУровня.Номенклатура = Источник Тогда
					//@skip-check invocation-form-event-handler
					ИмпортируемыеТоварыНоменклатураПриИзменении(СтрокаДереваВторогоУровня);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
	ИначеЕсли ИмяСобытия = "Запись_СтатусыПубликацииТоваровЯндексМаркет" Тогда
		Если Параметр.Свойство("ИсходныйКлючЗаписи")
			 И Источник.УчетнаяЗаписьМаркетплейса = УчетнаяЗаписьМаркетплейса Тогда
			ОбновитьСтрокуДереваТоваров(Параметр.ИсходныйКлючЗаписи, Источник);
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ЯндексМаркетЗаписаныСопоставленияКатегорий" Тогда
		Если ТипЗнч( Параметр ) = Тип( "ДанныеФормыКоллекция" ) Тогда
			
			СопоставлениеКатегорий = Параметр;
			ИмпортируемыеТоварыКатегорииПоСопоставлениюЗаполнить( СопоставлениеКатегорий );

		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РежимПоискаИСозданияТоваровПриИзменении(Элемент)
	Если РежимПоискаИСозданияТоваров = Истина Тогда
		ОтображатьДанныеТовара = Ложь;
	КонецЕсли;
	УстановитьВидимостьДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ВариантЗагрузкиДанныхПриИзменении(Элемент)

	Для каждого СтрокаДереваПервогоУровня Из ИмпортируемыеТовары.ПолучитьЭлементы() Цикл
		Если СтрокаДереваПервогоУровня.ВариантЗагрузки = 0 И ВариантЗагрузкиДанных = 2
			 ИЛИ СтрокаДереваПервогоУровня.ВариантЗагрузки = 2 И ВариантЗагрузкиДанных = 0 
			 ИЛИ СтрокаДереваПервогоУровня.ВариантЗагрузки = 3 Тогда
			 
			СтрокаДереваПервогоУровня.Пометка = Ложь;
			УстановитьСнятьПометки(СтрокаДереваПервогоУровня, СтрокаДереваПервогоУровня.Пометка);
			Элементы.ИмпортируемыеТовары.Свернуть(СтрокаДереваПервогоУровня.ПолучитьИдентификатор());
			
		ИначеЕсли СтрокаДереваПервогоУровня.ВариантЗагрузки = 0 И ВариантЗагрузкиДанных < 2
			 	  ИЛИ СтрокаДереваПервогоУровня.ВариантЗагрузки = 2 И ВариантЗагрузкиДанных > 0 Тогда
			 	  
			Элементы.ИмпортируемыеТовары.Развернуть(СтрокаДереваПервогоУровня.ПолучитьИдентификатор());
			
		КонецЕсли;
	КонецЦикла;
	
	ОпределитьНаименованияГруппДереваТоваров();
	УстановитьВидимостьДоступность();
	ФормаПараметрыИмпортаДанныхОписаниеОбновить();

КонецПроцедуры

&НаКлиенте
Процедура ОтображатьСопоставленныеПриИзменении(Элемент)
	
	ОпределитьНаименованияГруппДереваТоваров();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтображатьДанныеТовараПриИзменении(Элемент)

	УстановитьВидимостьДоступность();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыИмпортируемыеТовары

&НаКлиенте
Процедура ИмпортируемыеТоварыСоздатьХарактеристикуПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ИмпортируемыеТовары.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

    Если ТекущиеДанные.СоздатьХарактеристику = Ложь Тогда
    	Возврат;
    КонецЕсли;
	
	ИмпортируемыеТоварыПоОбъединениюФлагСоздатьХарактеристикуЗаполнить();
	
КонецПроцедуры

&НаКлиенте
Процедура ИмпортируемыеТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ИмпортируемыеТоварыНаименованиеКатегорииМаркетплейса" Тогда
		
		СтандартнаяОбработка = Ложь;
	
	ИначеЕсли Поле.Имя = "ИмпортируемыеТоварыИдентификаторОбъектаМаркетплейса" 
	И ЗначениеЗаполнено( ТекущиеДанные.ИдентификаторОбъектаМаркетплейса )  Тогда

	    СтандартнаяОбработка = Ложь;

	    ШаблонURL = "https://partner.market.yandex.ru/supplier/%1/assortment/offer-card?article=%2";
	    URL = СтрШаблон( ШаблонURL, ИдентификаторКампанииЯндексМаркет, ТекущиеДанные.ИдентификаторОбъектаМаркетплейса );
	    ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку( URL );

	ИначеЕсли Поле.Имя = "ИмпортируемыеТоварыИдентификаторПубликации" 
	И ЗначениеЗаполнено( ТекущиеДанные.ИдентификаторПубликации )  Тогда

	    СтандартнаяОбработка = Ложь;

	    ШаблонURL = "https://partner.market.yandex.ru/supplier/%1/assortment/offer-card?article=%2";
	    URL = СтрШаблон( ШаблонURL, ИдентификаторКампанииЯндексМаркет, ТекущиеДанные.ИдентификаторПубликации );
	    ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку( URL );
	
	ИначеЕсли Поле.Имя = "ИмпортируемыеТоварыРезультатПоискаКнопкаВыбрать" Тогда
		
		Если ЗначениеЗаполнено( ТекущиеДанные.РезультатПоискаНоменклатура )
		Или ЗначениеЗаполнено( ТекущиеДанные.РезультатПоискаХарактеристика ) Тогда
			ТекущиеДанные.Номенклатура = ТекущиеДанные.РезультатПоискаНоменклатура;
			ТекущиеДанные.Характеристика = ТекущиеДанные.РезультатПоискаХарактеристика;
			
			НоменклатураЗначенияРеквизитов = ЗначенияРеквизитовОбъекта( ТекущиеДанные.Номенклатура, "ИспользоватьХарактеристики, КатегорияНоменклатуры" );
			ТекущиеДанные.ХарактеристикиИспользуются = НоменклатураЗначенияРеквизитов.ИспользоватьХарактеристики;
			ТекущиеДанные.Категория = НоменклатураЗначенияРеквизитов.КатегорияНоменклатуры;
			
			ТекущиеДанные.Пометка = Истина;
		КонецЕсли;
		
	ИначеЕсли Поле.Имя = "ИмпортируемыеТоварыРезультатПоискаНоменклатура"
	 ИЛИ Поле.Имя = "ИмпортируемыеТоварыРезультатПоискаХарактеристика"
	 ИЛИ Поле.Имя = "ИмпортируемыеТоварыРезультатПоискаКоличество"
	 ИЛИ Поле.Имя = "ИмпортируемыеТоварыРезультатПоискаВероятностьСовпадения"
	Тогда
		
		Если ТекущиеДанные.РезультатыПоиска.Количество() > 0 Тогда
			РезультатПоискаВыбратьЭлемент( ТекущиеДанные );
		КонецЕсли;
		
	ИначеЕсли Поле.Имя = "ИмпортируемыеТоварыНоменклатура" Тогда
		Если ЗначениеЗаполнено( ТекущиеДанные.Номенклатура ) Тогда
			
		КонецЕсли;
	ИначеЕсли ТекущиеДанные.ВариантЗагрузки <> 2 
			  И ТекущиеДанные.ИндексСтатуса >= 0 
			  И Поле.Имя <> "ИмпортируемыеТоварыСтавкаНДС" Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Если Поле.Имя <> "ИмпортируемыеТоварыНоменклатура" 
			 И Поле.Имя <> "ИмпортируемыеТоварыХарактеристика" 
			 И Поле.Имя <> "ИмпортируемыеТоварыУпаковка" 
			 И Поле.Имя <> "ИмпортируемыеТоварыКатегория" 
			 И Поле.Имя <> "ИмпортируемыеТоварыКатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет" 
			 И Поле.Имя <> "ИмпортируемыеТоварыИсточникКатегорииМаркетплейса" Тогда
			 
			Измерения = Новый Структура;
			Измерения.Вставить("УчетнаяЗаписьМаркетплейса", УчетнаяЗаписьМаркетплейса);
			Измерения.Вставить("Номенклатура",              ТекущиеДанные.Номенклатура);
			Измерения.Вставить("Характеристика",            ТекущиеДанные.Характеристика);

			ПараметрыЗаписи = Новый Массив;
			ПараметрыЗаписи.Добавить(Измерения);

			КлючЗаписи = Новый(Тип("РегистрСведенийКлючЗаписи.СтатусыПубликацииТоваровЯндексМаркет"), ПараметрыЗаписи);

			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("Ключ", КлючЗаписи);

			ОткрытьФорму("РегистрСведений.СтатусыПубликацииТоваровЯндексМаркет.ФормаЗаписи", ПараметрыОткрытия);
			
		Иначе
			ПоказатьЗначение(, ТекущиеДанные[СтрЗаменить(Поле.Имя, "ИмпортируемыеТовары", "")]);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИмпортируемыеТоварыПриАктивизацииСтроки(Элемент)

	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементФормыДеревоРеквизитовРазвернуть();
	
	ФормаОбновитьСтатусЗагрузкиТовара( ТекущиеДанные );
	
	//@skip-check invocation-form-event-handler
	ТаблицаИмпортированныхТоваровИзображенияПриАктивизацииСтроки(Элементы.ТаблицаИмпортированныхТоваровИзображения);

КонецПроцедуры

