	КонецЕсли;
	
	Элементы.ИмпортируемыеТоварыРезультатыПоискаГруппа.Видимость = РежимПоискаИСозданияТоваров;
	Элементы.КнопкаНайтиТовары.Видимость = РежимПоискаИСозданияТоваров;
	
КонецПроцедуры

&НаКлиенте
Процедура ФормаРежимОтображенияЭлементыОбновить( ПараметрФормаРежимОтображения )
	
	ФормаРежимОтображенияТекущий = ПараметрФормаРежимОтображения;
	
	Если ФормаРежимОтображенияТекущий = ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияОткрытие() Тогда

		Элементы.ГруппаНазадВперед.Видимость = Ложь;

		Если ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиОбновитьСопоставленныеКарточкиТоваров() Тогда 
		
    		Элементы.ГруппаДополнительныеДействия.Видимость = Ложь;
			Элементы.ГруппаИмпортДанных.Видимость = Истина;
			Элементы.ГруппаДетальныеНастройкиИмпорта.Видимость = Истина;
			
		ИначеЕсли ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда 
		
			Элементы.ГруппаДополнительныеДействия.Видимость = Истина;
			Элементы.ГруппаИмпортДанных.Видимость = Ложь;
			Элементы.ГруппаДетальныеНастройкиИмпорта.Видимость = Истина;
			
		КонецЕсли;
	    
	    Элементы.ПолучитьДанныеСТорговойПлощадки.Видимость = Истина;
	    
	ИначеЕсли ФормаРежимОтображенияТекущий = ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияЗагрузитьВсеОписания() Тогда

		Элементы.ГруппаНазадВперед.Видимость = Истина;

   		Элементы.ГруппаДополнительныеДействия.Видимость = Ложь;
		Элементы.ГруппаИмпортДанных.Видимость = Истина;
		Элементы.ГруппаДетальныеНастройкиИмпорта.Видимость = Ложь;
		
		Элементы.ПолучитьДанныеСТорговойПлощадки.Видимость = Ложь;
		Элементы.ОтображатьСопоставленные.Видимость = Ложь;
		
		РежимПоискаИСозданияТоваров = Ложь;
		Элементы.РежимПоискаИСозданияТоваров.Видимость = Ложь;
		
	
	ИначеЕсли ФормаРежимОтображенияТекущий = ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияЗагрузитьСДетальнымиНастройками() Тогда

		Элементы.ГруппаНазадВперед.Видимость = Истина;

   		Элементы.ГруппаДополнительныеДействия.Видимость = Ложь;
		Элементы.ГруппаИмпортДанных.Видимость = Истина;
		Элементы.ГруппаДетальныеНастройкиИмпорта.Видимость = Истина;
		
		Элементы.ПолучитьДанныеСТорговойПлощадки.Видимость = Истина;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбновитьКнопкуОтбораПоСтатусу(ИмяКоманды)

	Команда = Команды.Найти(ИмяКоманды);
	Если Команда = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Элементы.ОтборПоСтатусам.Заголовок = Команда.Заголовок;
	Элементы.ОтборПоСтатусам.Картинка  = Команда.Картинка;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьСнятьПометки(Знач ЭлементДерева, Знач Пометка, Знач ИмяКоманды = "")
	
	Если ЭлементДерева.ИндексСтатуса = -2 Тогда
		Если Пометка 
			 И (ЭлементДерева.ВариантЗагрузки = 0 И ВариантЗагрузкиДанных = 2
				ИЛИ ЭлементДерева.ВариантЗагрузки = 2 И ВариантЗагрузкиДанных = 0
				ИЛИ ЭлементДерева.ВариантЗагрузки = 3) Тогда
			Пометка = Ложь;
		КонецЕсли;
		
		Для каждого СтрокаДереваВторогоУровня Из ЭлементДерева.ПолучитьЭлементы() Цикл
			УстановитьСнятьПометки(СтрокаДереваВторогоУровня, Пометка, ИмяКоманды);
		КонецЦикла;
		
	Иначе
		Если Пометка 
			 И ЭлементДерева.ИндексСтатуса = 4 Тогда
			Пометка = Ложь;
		КонецЕсли;
		
		Если Пометка
			 И ЗначениеЗаполнено(ИмяКоманды) Тогда
			Если ИмяКоманды = "ТребующиеПолученияДанных" 
				 И ЭлементДерева.ИндексСтатуса <> 5 Тогда
				Пометка = Ложь;
			ИначеЕсли ИмяКоманды = "ТребующиеЗаписиТоваровИЦен" 
					  И ЭлементДерева.ИндексСтатуса <> 6 
					  И НЕ ЭлементДерева.ЕстьРазличияЦеновыеПоказатели Тогда
				Пометка = Ложь;
			ИначеЕсли ИмяКоманды = "ТребующиеЗаписиТоваров" 
					  И ЭлементДерева.ИндексСтатуса <> 6 Тогда
				Пометка = Ложь;
			ИначеЕсли ИмяКоманды = "ТребующиеЗаписиЦен" 
				 	  И НЕ ЭлементДерева.ЕстьРазличияЦеновыеПоказатели Тогда
				Пометка = Ложь;
			ИначеЕсли ИмяКоманды = "НеСопоставленнаяНоменклатура" 
				 	  И ЗначениеЗаполнено(ЭлементДерева.Номенклатура) Тогда
				Пометка = Ложь;
			КонецЕсли;
		КонецЕсли;

		Если Пометка И ЭлементДерева.ВариантЗагрузки = 0 И ВариантЗагрузкиДанных = 2 Тогда
			// Позиция уже записана
			Пометка = Ложь;
		КонецЕсли;
		
		ЭлементДерева.Пометка = Пометка;
		ЭлементДереваРодитель = ЭлементДерева.ПолучитьРодителя();
		ЭлементДереваРодитель.КоличествоОтмеченныхСтрок = ЭлементДереваРодитель.КоличествоОтмеченныхСтрок + ?(ЭлементДерева.Пометка, 1, -1);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОпределитьНаименованияГруппДереваТоваров(Знач СтрокаДереваПервогоУровня = Неопределено)
	
	Если СтрокаДереваПервогоУровня = Неопределено Тогда
		Для каждого СтрокаДереваПервогоУровня Из ИмпортируемыеТовары.ПолучитьЭлементы() Цикл
			ОпределитьНаименованияГруппДереваТоваров(СтрокаДереваПервогоУровня);
		КонецЦикла;
		
	Иначе
		Если СтрокаДереваПервогоУровня.ВариантЗагрузки = 0 Тогда
			ШаблонПредставления = НСтр("ru = 'Обновить (%1 из %2)'");
		ИначеЕсли СтрокаДереваПервогоУровня.ВариантЗагрузки = 2 Тогда
			ШаблонПредставления = НСтр("ru = 'Загрузить (%1 из %2)'");
		ИначеЕсли СтрокаДереваПервогоУровня.ВариантЗагрузки = 3 Тогда
			ШаблонПредставления = НСтр("ru = 'Не найдены (%2)'");
		КонецЕсли;
		
		КоличествоСтрок           = СтрокаДереваПервогоУровня.ПолучитьЭлементы().Количество();
		КоличествоОтмеченныхСтрок = 0;
		
		Для каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.ПолучитьЭлементы() Цикл
			Если ОтображатьСопоставленные = 1
				 И (НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Номенклатура) 
				 	ИЛИ СтрокаДереваВторогоУровня.ХарактеристикиИспользуются
				        И НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Характеристика)
				 	ИЛИ НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Категория)) Тогда
				КоличествоСтрок = КоличествоСтрок - 1;
				Продолжить;
				
			ИначеЕсли ОтображатьСопоставленные = 2
				 	  И ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Номенклатура) 
				 	  И (НЕ СтрокаДереваВторогоУровня.ХарактеристикиИспользуются
				         ИЛИ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Характеристика))
				 	  И ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Категория) Тогда
				КоличествоСтрок = КоличествоСтрок - 1;
				Продолжить;
			КонецЕсли;
			
			Если ОтображатьПоСтатусу <> -1
				 И СтрокаДереваВторогоУровня.ИндексСтатуса <> ОтображатьПоСтатусу Тогда
				КоличествоСтрок = КоличествоСтрок - 1;
				Продолжить;
			КонецЕсли;
			
			КоличествоОтмеченныхСтрок = КоличествоОтмеченныхСтрок + ?(СтрокаДереваВторогоУровня.Пометка, 1, 0);
		КонецЦикла;
		
		Если КоличествоСтрок = 0 Тогда
			ШаблонПредставления = СтрЗаменить(ШаблонПредставления, " (%1 из %2)", "");
			ШаблонПредставления = СтрЗаменить(ШаблонПредставления, " (%2)", "");
		КонецЕсли;
		
		СтрокаДереваПервогоУровня.Пометка = (КоличествоОтмеченныхСтрок > 0);
		СтрокаДереваПервогоУровня.КоличествоОтмеченныхСтрок = КоличествоОтмеченныхСтрок;
		СтрокаДереваПервогоУровня.ПредставлениеОбъектаМаркетплейса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			ШаблонПредставления,
			КоличествоОтмеченныхСтрок,
			КоличествоСтрок);

		ТекущиеДанные = Элементы.ИмпортируемыеТовары.ТекущиеДанные;
		
		Если ТекущиеДанные <> Неопределено Тогда
			Если ОтображатьСопоставленные = 1
				 И (НЕ ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) 
				 	ИЛИ ТекущиеДанные.ХарактеристикиИспользуются
				        И НЕ ЗначениеЗаполнено(ТекущиеДанные.Характеристика)
				 	ИЛИ НЕ ЗначениеЗаполнено(ТекущиеДанные.Категория)) Тогда
				Элементы.ИмпортируемыеТовары.ТекущаяСтрока = СтрокаДереваПервогоУровня.ПолучитьИдентификатор();
				
			ИначеЕсли ОтображатьСопоставленные = 2
				 	  И ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) 
				 	  И (НЕ ТекущиеДанные.ХарактеристикиИспользуются
				         ИЛИ ЗначениеЗаполнено(ТекущиеДанные.Характеристика))
				 	  И ЗначениеЗаполнено(ТекущиеДанные.Категория) Тогда
				Элементы.ИмпортируемыеТовары.ТекущаяСтрока = СтрокаДереваПервогоУровня.ПолучитьИдентификатор();
			КонецЕсли;
			
			Если ОтображатьПоСтатусу <> -1
				 И ТекущиеДанные.ИндексСтатуса <> ОтображатьПоСтатусу Тогда
				Элементы.ИмпортируемыеТовары.ТекущаяСтрока = СтрокаДереваПервогоУровня.ПолучитьИдентификатор();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеЛегенды(Знач ДеревоТоваров = Неопределено)
	
	Если ДеревоТоваров = Неопределено Тогда
		ДеревоТоваров = РеквизитФормыВЗначение("ИмпортируемыеТовары");
	КонецЕсли;
	
	ОжидаютИсправленияОшибок = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ВариантЗагрузки, ИндексСтатуса", 0, 0), Истина).Количество();
	ПодготовленыКПубликации  = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ВариантЗагрузки, ИндексСтатуса", 0, 1), Истина).Количество();
	ПеремещеныВАрхив         = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ВариантЗагрузки, ИндексСтатуса", 0, 2), Истина).Количество();
	ГотовыКПродаже           = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ВариантЗагрузки, ИндексСтатуса", 0, 3), Истина).Количество();
	
	ОжидаютПолученияДанных   = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ВариантЗагрузки, ИндексСтатуса", 0, 5), Истина).Количество();
	НеНайденыНаПлощадке      = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ИндексСтатуса", 4), Истина).Количество();
	ОбнаруженыРасхождения    = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ИндексСтатуса", 6), Истина).Количество();
	ОбновлениеНеТребуется    = ДеревоТоваров.Строки.НайтиСтроки(Новый Структура("ИндексСтатуса", 7), Истина).Количество();
	
	ЛегендаОжидаютИсправленияОшибок = ?(ОжидаютИсправленияОшибок = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Ожидают исправления ошибок: %1'"),
											ОжидаютИсправленияОшибок));
	ЛегендаПодготовленыКПубликации  = ?(ПодготовленыКПубликации = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Подготовлены к публикации: %1'"),
											ПодготовленыКПубликации));
	ЛегендаПеремещеныВАрхив         = ?(ПеремещеныВАрхив = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Перемещены в архив: %1'"),
											ПеремещеныВАрхив));
	ЛегендаГотовыКПродаже           = ?(ГотовыКПродаже = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Готовы к продаже: %1'"),
											ГотовыКПродаже));

	ЛегендаОжидаютПолученияДанных   = ?(ОжидаютПолученияДанных = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Ожидают получения данных: %1'"),
											ОжидаютПолученияДанных));
	ЛегендаНеНайденыНаПлощадке      = ?(НеНайденыНаПлощадке = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Не найдены на площадке: %1'"),
											НеНайденыНаПлощадке));
	ЛегендаОбнаруженыРасхождения    = ?(ОбнаруженыРасхождения = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Обнаружены расхождения: %1'"),
											ОбнаруженыРасхождения));
	ЛегендаОбновлениеНеТребуется    = ?(ОбновлениеНеТребуется = 0,
										"",
										СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
											НСтр("ru = 'Обновление не требуется: %1'"),
											ОбновлениеНеТребуется));
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСлужебныеДанные()

	Модифицированность = Ложь;
	ОчиститьСообщения();
	ПоказатьОповещениеПользователя(
		НСтр("ru = 'Импорт данных'"),
		, 
		НСтр("ru = 'Обновление служебных данных по выбранным товарным позициям.'"),
		БиблиотекаКартинок.ЯндексМаркетЛоготип);
		
	ДлительнаяОперация    = ОбновитьСлужебныеДанныеНаСервере();
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОбновитьСлужебныеДанныеЗавершениеФоновогоЗадания", ЭтотОбъект,);
	
	ПараметрыОжидания 								   = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания 			   = Истина;
	ПараметрыОжидания.ТекстСообщения                   = НСтр("ru = 'Обновление служебных данных по товарным позициям.'");
	ПараметрыОжидания.ОповещениеПользователя.Показать  = Истина;
	ПараметрыОжидания.ОповещениеПользователя.Текст 	   = НСтр("ru = 'Импорт данных'");
	ПараметрыОжидания.ОповещениеПользователя.Пояснение = НСтр("ru = 'Завершено обновление служебных данных по товарным позициям.'");
	ПараметрыОжидания.ОповещениеПользователя.Картинка  = БиблиотекаКартинок.ЯндексМаркетЛоготип;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);

КонецПроцедуры

&НаСервере
Функция ОбновитьСлужебныеДанныеНаСервере()
	
	ПараметрыВыполнения 							 = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение            = 0;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания  = НСтр("ru = 'Яндекс Маркет. Обновление служебных данных по товарным позициям.'");
	ПараметрыВыполнения.ЗапуститьВФоне               = Истина;
	ПараметрыВыполнения.ПрерватьВыполнениеЕслиОшибка = Истина;
	
	ИмяМетода = "ИнтеграцияСЯндексМаркетСервер.ИмпортИзЯндексМаркетОбновитьСлужебныеДанные";
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
		ИмяМетода, 
		УчетнаяЗаписьМаркетплейса, 
		РеквизитФормыВЗначение("ИмпортируемыеТовары"),
		СортироватьСтрокиДереваТоваров);
	
КонецФункции

&НаКлиенте
Процедура ОбновитьСлужебныеДанныеЗавершениеФоновогоЗадания(Результат, ДополнительныеПараметры) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Статус = "Ошибка" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ПодробноеПредставлениеОшибки);
		
		ИначеЕсли Результат.Статус = "Выполнено" И Результат.Свойство("АдресРезультата") Тогда
		
			Ошибка = РезультатОбновленияСлужебныхДанныхНаСервере(Результат.АдресРезультата);
			ИнтеграцияСЯндексМаркетКлиент.ВывестиСостояние(Ошибка, ДополнительныеПараметры, Истина);
			
			РазвернутьУзлыДерева(Истина);
			
			ПараметрыКоманда = Новый Структура( "Имя", "ПолучитьДанныеСТорговойПлощадки" );
			//@skip-check invocation-form-event-handler
			ПолучитьДанныеСТорговойПлощадки( ПараметрыКоманда );
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция РезультатОбновленияСлужебныхДанныхНаСервере(Знач АдресРезультата)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	Если ПустаяСтрока(Результат.Ошибка.КодОшибки) Тогда
		Если Результат.Свойство("ДеревоТоваров") Тогда
			ЗначениеВРеквизитФормы(Результат.ДеревоТоваров, "ИмпортируемыеТовары");
			ПолучитьДанныеЛегенды(Результат.ДеревоТоваров);
			УстановитьВидимостьДоступность();
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат.Ошибка;
	
КонецФункции

&НаСервере
Функция ПолучитьДанныеСТорговойПлощадкиНаСервере( КэшКатегорий, Знач СледующаяПорцияДанных = Ложь)
	
	ПараметрыВыполнения 							 = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение            = 0;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания  = НСтр("ru = 'Яндекс Маркет. Получение данных по товарным позициям с торговой площадки.'");
	ПараметрыВыполнения.ЗапуститьВФоне               = Истина;
	ПараметрыВыполнения.ПрерватьВыполнениеЕслиОшибка = Истина;
	
	ПараметрыФункции = ИнтеграцияСЯндексМаркетСервер.ИмпортИзЯндексМаркетПараметрыНовый();
	
	ПараметрыФункции.ВариантЗагрузкиДанных = ВариантЗагрузкиДанных;
	ПараметрыФункции.КэшКатегорий = КэшКатегорий;
	ПараметрыФункции.ЗагрузитьЦеныПродажи = ЗагрузитьЦеныПродажи;
	ПараметрыФункции.ИмяИдентификатора = ИмяИдентификатора;
	ПараметрыФункции.РазмерПорцииЗагрузкиДанных = РазмерПорцииЗагрузкиДанных;
	
	ПараметрыФункции.ЗагрузитьОписанияАрхивныхПозиций = ЗагрузитьОписанияАрхивныхПозиций;
	
	ПараметрыФункции.СоздатьЭлементыНоменклатуры = СоздатьЭлементыНоменклатуры;
	ПараметрыФункции.ПерезаполнитьЗначенияРеквизитовНоменклатуры = ПерезаполнитьЗначенияРеквизитовНоменклатуры;
	ПараметрыФункции.СоздатьХарактеристикиНоменклатуры = СоздатьХарактеристикиНоменклатуры;
	
	ПараметрыФункции.СоздатьКатегорииНоменклатуры = СоздатьКатегорииНоменклатуры;
	ПараметрыФункции.СоздатьИерархиюКатегорийНоменклатуры = СоздатьИерархиюКатегорийНоменклатуры;
	
	ПараметрыФункции.СортироватьСтрокиДереваТоваров = СортироватьСтрокиДереваТоваров;
	ПараметрыФункции.ОтображатьСопоставленные = ОтображатьСопоставленные;
	ПараметрыФункции.ОтображатьПоСтатусу = ОтображатьПоСтатусу;
	ПараметрыФункции.СледующаяПорцияДанных = СледующаяПорцияДанных;
	ПараметрыФункции.ИдентификаторыТоваров = РеквизитФормыВЗначение( "ИдентификаторыТоваров" );
	
	Если ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиОбновитьСопоставленныеКарточкиТоваров() Тогда
		ПараметрыФункции.ТоварыНайти = Ложь;
	Иначе
		ПараметрыФункции.ТоварыНайти = Истина;
	КонецЕсли;

	ПараметрИмпортируемыеТовары = РеквизитФормыВЗначение( "ИмпортируемыеТовары" );
	
	Если ВариантЗагрузкиДанных = ИнтеграцияСЯндексМаркетКлиентСервер.ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда
		// удаление всех пометок для получения новой порции
		ПараметрИмпортируемыеТоварыСтроки = ПараметрИмпортируемыеТовары.Строки.НайтиСтроки( Новый Структура( "Пометка", Истина ), Истина );
		Для Каждого ПараметрИмпортируемыеТоварыСтрока Из ПараметрИмпортируемыеТоварыСтроки Цикл
			ПараметрИмпортируемыеТоварыСтрока.Пометка = Ложь;
		КонецЦикла;
	КонецЕсли;

	ИмяМетода = "ИнтеграцияСЯндексМаркетСервер.ИмпортИзЯндексМаркетПолучитьИмпортируемыеДанныеСТорговойПлощадки";
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения, 
		ИмяМетода, 
		УчетнаяЗаписьМаркетплейса, 
		ПараметрыФункции, 
		ПараметрИмпортируемыеТовары );
	
КонецФункции

&НаКлиенте
Процедура ПолучитьДанныеСТорговойПлощадкиЗавершениеФоновогоЗадания( Результат, ДополнительныеПараметры ) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") Тогда
	
		Если Результат.Свойство( "Сообщения" ) Тогда
			Для Каждого СообщениеЭлемент Из Результат.Сообщения Цикл
				ОбщегоНазначенияКлиент.СообщитьПользователю( СообщениеЭлемент.Текст );
			КонецЦикла;
		КонецЕсли;
	
		Если Результат.Статус = "Ошибка" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ПодробноеПредставлениеОшибки);
		
		ИначеЕсли Результат.Статус = "Выполнено" 
		 		  И Результат.Свойство("АдресРезультата") Тогда
		 		  
			КэшКатегорий = Неопределено;
			
			Ошибка = РезультатПолученияДанныхСТорговойПлощадкиНаСервере(Результат.АдресРезультата, КэшКатегорий);
			
			ИнтеграцияСЯндексМаркетКлиент.ВывестиСостояние(Ошибка, ДополнительныеПараметры, Истина);
			
			//@skip-check invocation-form-event-handler
			УстановитьФлажкиДляТребующихЗаписиТоваров( Неопределено );
			
			РазвернутьУзлыДерева(Истина);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция РезультатПолученияДанныхСТорговойПлощадкиНаСервере(Знач АдресРезультата, КэшКатегорий = Неопределено)
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	
	Если ПустаяСтрока(Результат.Ошибка.КодОшибки) Тогда
		Если Результат.Свойство("ДеревоТоваров") Тогда
		    
			ЗначениеВРеквизитФормы( Результат.ДеревоТоваров, "ИмпортируемыеТовары" );
			
			ПолучитьДанныеЛегенды(Результат.ДеревоТоваров);
			УстановитьВидимостьДоступность();
		КонецЕсли;
		
		Если Результат.Свойство("ИдентификаторыТоваров") Тогда
			ЗначениеВРеквизитФормы( Результат.ИдентификаторыТоваров, "ИдентификаторыТоваров" );
		КонецЕсли;
		
		Если Результат.Свойство("КэшКатегорий") Тогда
			КэшКатегорий = Результат.КэшКатегорий;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат.Ошибка;
	
КонецФункции

&НаСервере
Функция ЗаписатьЗагруженныеДанныеНаСервере( Знач ЗаписатьТолькоЦены = Ложь, Знач ТолькоСоздатьНоменклатуру = Ложь, КэшКатегорийДерево = Неопределено )

	ПараметрыВыполнения 							 = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение            = 0;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания  = НСтр("ru = 'Яндекс Маркет. Запись загруженных данных по товарным позициям с торговой площадки.'");
	ПараметрыВыполнения.ЗапуститьВФоне               = Истина;
	ПараметрыВыполнения.ПрерватьВыполнениеЕслиОшибка = Истина;
	
	ДоступнаУстановкаЦен = ПравоДоступа("Проведение", Метаданные.Документы.УстановкаЦенНоменклатуры);
	
	ПараметрыФункции = ИнтеграцияСЯндексМаркетСервер.ИмпортИзЯндексМаркетПараметрыНовый();
	
	ПараметрыФункции.УчетнаяЗаписьМаркетплейса = УчетнаяЗаписьМаркетплейса;
	
	ПараметрыФункции.ВариантЗагрузкиДанных = ВариантЗагрузкиДанных;
	ПараметрыФункции.ЗагрузитьЦеныПродажи = ЗагрузитьЦеныПродажи И ДоступнаУстановкаЦен И НЕ ЗаписатьЦеныОтдельнойКомандой;
	ПараметрыФункции.ЗаписатьТолькоЦены = ЗагрузитьЦеныПродажи И ДоступнаУстановкаЦен И ЗаписатьТолькоЦены;
	ПараметрыФункции.ТолькоСоздатьНоменклатуру = ТолькоСоздатьНоменклатуру;
	
	ПараметрыФункции.ЗагрузитьОписанияАрхивныхПозиций = ЗагрузитьОписанияАрхивныхПозиций;
	
	ПараметрыФункции.ИмяИдентификатора = ИмяИдентификатора;
	ПараметрыФункции.РазмерПорцииЗагрузкиДанных = РазмерПорцииЗагрузкиДанных;
	
	ПараметрыФункции.СоздатьЭлементыНоменклатуры = СоздатьЭлементыНоменклатуры;
	ПараметрыФункции.ПерезаполнитьЗначенияРеквизитовНоменклатуры = ПерезаполнитьЗначенияРеквизитовНоменклатуры;
	ПараметрыФункции.ГруппаДляСозданияНовыхТоваров = ГруппаДляСозданияНовыхТоваров;
	ПараметрыФункции.СоздатьИерархиюНоменклатуры = СоздатьИерархиюНоменклатуры;
	ПараметрыФункции.СоздатьХарактеристикиНоменклатуры = СоздатьХарактеристикиНоменклатуры;
	ПараметрыФункции.ЗагрузитьИзображения = ЗагрузитьИзображения;
	
	ПараметрыФункции.СоздатьКатегорииНоменклатуры = СоздатьКатегорииНоменклатуры;
	ПараметрыФункции.СоздатьИерархиюКатегорийНоменклатуры = СоздатьИерархиюКатегорийНоменклатуры;
	
	ПараметрыФункции.ИсточникКатегории = ИсточникКатегории;
	ПараметрыФункции.КэшКатегорийДерево = КэшКатегорийДерево;
	
	ПараметрыФункции.СортироватьСтрокиДереваТоваров = СортироватьСтрокиДереваТоваров;
	ПараметрыФункции.ОтображатьСопоставленные = ОтображатьСопоставленные;
	ПараметрыФункции.ОтображатьПоСтатусу = ОтображатьПоСтатусу;
	ПараметрыФункции.ДокументУстановкаЦенНоменклатуры = ДокументУстановкаЦенНоменклатуры;
	
	ИмяМетода = "ИнтеграцияСЯндексМаркетСервер.ИмпортИзЯндексМаркетЗаписатьЗагруженныеДанныеСТорговойПлощадки";
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, 
		ИмяМетода, 
		УчетнаяЗаписьМаркетплейса, 
		РеквизитФормыВЗначение( "ИмпортируемыеТовары" ), 
		ПараметрыФункции);
	
КонецФункции

&НаКлиенте
Процедура ЗаписатьЗагруженныеДанныеЗавершениеФоновогоЗадания(Результат, ДополнительныеПараметры) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		Если Результат.Свойство( "Сообщения" ) Тогда
			Для Каждого СообщениеЭлемент Из Результат.Сообщения Цикл
				ОбщегоНазначенияКлиент.СообщитьПользователю( СообщениеЭлемент.Текст );
			КонецЦикла;
		КонецЕсли;
		
		Если Результат.Статус = "Ошибка" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ПодробноеПредставлениеОшибки);
			
		ИначеЕсли Результат.Статус = "Выполнено" 
			И Результат.Свойство("АдресРезультата") Тогда
			
			// текущая позиция курсора
			Если Элементы.ИмпортируемыеТовары.ТекущиеДанные <> Неопределено Тогда
				ТекущаяПозицияИдентификаторОбъектаМаркетплейса = Элементы.ИмпортируемыеТовары.ТекущиеДанные.ИдентификаторОбъектаМаркетплейса;
			КонецЕсли;
			
			Ошибка = РезультатЗаписиЗагруженныхДанныхНаСервере(Результат.АдресРезультата);
			ИнтеграцияСЯндексМаркетКлиент.ВывестиСостояние(Ошибка, ДополнительныеПараметры, Истина);
			
			РазвернутьУзлыДерева(Истина);
			
			// текущая позиция курсора
			Если ЗначениеЗаполнено( ТекущаяПозицияИдентификаторОбъектаМаркетплейса ) Тогда
				ИмпортируемыеТоварыТекущаяСтрокаУстановить( ТекущаяПозицияИдентификаторОбъектаМаркетплейса );
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	Оповестить( "ЯндексМаркетТоварыСписокОбновить" );
	
КонецПроцедуры

&НаСервере
Функция РезультатЗаписиЗагруженныхДанныхНаСервере(Знач АдресРезультата)

	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
		
	Если ПустаяСтрока(Результат.Ошибка.КодОшибки) Тогда
	
		ЗначениеВРеквизитФормы( Результат.ДеревоТоваров, "ИмпортируемыеТовары" );
		
		ПолучитьДанныеЛегенды(Результат.ДеревоТоваров);
		УстановитьВидимостьДоступность();
		
		Если Результат.НеЗаписано > 0 Тогда
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не удалось записать товарных позиций: %1.'", 
					ОбщегоНазначения.КодОсновногоЯзыка()),
				Результат.НеЗаписано);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
			
			Для каждого ЭлементКоллекции Из Результат.Пропущено Цикл
				ОбщегоНазначения.СообщитьПользователю(
					Символы.Таб + "" + ЭлементКоллекции.Сообщение,,,
					ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("ИмпортируемыеТовары", ЭлементКоллекции.НомерСтроки, "Номенклатура"));
			КонецЦикла;
		КонецЕсли;
		
		Если Результат.Записано > 0 Тогда
			Если Результат.ВТомЧислеНовых > 0 Тогда
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Записано товарных позиций: %1, в том числе новых: %2.'", 
						ОбщегоНазначения.КодОсновногоЯзыка()),
					Результат.Записано,
					Результат.ВТомЧислеНовых);
			Иначе
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Записано товарных позиций: %1.'", 
						ОбщегоНазначения.КодОсновногоЯзыка()),
					Результат.Записано);
			КонецЕсли;
			ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );
		    
		    
			ТекстСообщения = СтрШаблон( НСтр("ru = 'Номенклатура: создано %1, обновлено %2.'" ),
		    Результат.НоменклатураКоличествоСоздано, Результат.НоменклатураКоличествоОбновлено );
		    ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );
			
		    ТекстСообщения = СтрШаблон( НСтр("ru = 'Характеристики номенклатуры: создано %1, обновлено %2.'" ),
		    Результат.ХарактеристикиКоличествоСоздано, Результат.ХарактеристикиКоличествоОбновлено );
		    ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );

			ТекстСообщения = СтрШаблон( НСтр("ru = 'Категории номенклатуры: создано %1.'" ),
		    Результат.КатегорииНоменклатурыСоздано );
		    ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );

			ТекстСообщения = СтрШаблон( НСтр("ru = 'Файлы: создано %1.'" ),
		    Результат.ФайлыКоличествоСоздано );
		    ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );
			
			ТекстСообщения = СтрШаблон( НСтр("ru = 'Штрихкоды: создано %1.'" ),
		    Результат.ШтрихкодыКоличествоСоздано );
		    ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );
		    
		    
			Если Результат.ЗагруженыЦены Тогда

				СозданныеДокументыУстановкаЦенНоменклатуры = ИнтеграцияСМаркетплейсамиСервер.СтруктураСвойствоЗначениеПолучить( Результат, 
				"СозданныеДокументыУстановкаЦенНоменклатуры" );

				Если ТипЗнч( СозданныеДокументыУстановкаЦенНоменклатуры ) = Тип( "Соответствие" ) Тогда
					ДокументыУстановкаЦенНоменклатуры = СозданныеДокументыУстановкаЦенНоменклатуры.Получить( УчетнаяЗаписьМаркетплейса );
					Если ТипЗнч( ДокументыУстановкаЦенНоменклатуры ) = Тип( "Массив" )
					И ДокументыУстановкаЦенНоменклатуры.Количество() > 0
					Тогда
						ДокументУстановкаЦенНоменклатуры = ДокументыУстановкаЦенНоменклатуры[ 0 ];
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		
	КонецЕсли;

	Возврат Результат.Ошибка;
	
КонецФункции

&НаСервере
Процедура ОбновитьКатегорииТоваров(Знач ИсточникКатегории)
	
	Если ИсточникКатегории = ПредопределенноеЗначение("Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры") Тогда
		Элементы.ИмпортируемыеТоварыКатегория.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.КатегорииНоменклатуры");
		ТипЗначения = ТипЗнч(Справочники.КатегорииНоменклатуры.ПустаяСсылка());
	ИначеЕсли ИсточникКатегории = ПредопределенноеЗначение("Перечисление.ИсточникиКатегорийДляМаркетплейса.ИерархияНоменклатуры") Тогда
		Элементы.ИмпортируемыеТоварыКатегория.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
		ТипЗначения = ТипЗнч(Справочники.Номенклатура.ПустаяСсылка());
	Иначе
		ТипЗначения = ТипЗнч(Неопределено);
	КонецЕсли;
	
	Для каждого СтрокаДереваПервогоУровня Из ИмпортируемыеТовары.ПолучитьЭлементы() Цикл
		Если СтрокаДереваПервогоУровня.ВариантЗагрузки <> 2 Тогда
			Продолжить;
		КонецЕсли;
		
		Для каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.ПолучитьЭлементы() Цикл
			Если ТипЗнч(СтрокаДереваВторогоУровня.Категория) <> ТипЗначения Тогда
				ТекущаяКатегория = ИнтеграцияСЯндексМаркетСервер.ОпределитьТекущуюСопоставленнуюКатегориюМаркетплейсаПоНоменклатуре(
					УчетнаяЗаписьМаркетплейса,
					СтрокаДереваВторогоУровня.Номенклатура,
					СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса,
					ИсточникКатегории);
						
				СтрокаДереваВторогоУровня.Категория                                 = ТекущаяКатегория.Категория;
				СтрокаДереваВторогоУровня.ИсточникКатегорииМаркетплейса             = ТекущаяКатегория.ИсточникКатегории;
				СтрокаДереваВторогоУровня.ТекущееИдентификаторКатегорииМаркетплейса = ТекущаяКатегория.ИдентификаторКатегории;
				СтрокаДереваВторогоУровня.ТекущееНаименованиеКатегорииМаркетплейса  = ТекущаяКатегория.НаименованиеКатегории;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ЗагрузитьИзображение()
    
    // замена на поле HTML
    ТекущиеДанные = Элементы.ТаблицаИмпортированныхТоваровИзображения.ТекущиеДанные;
    Если ТекущиеДанные = Неопределено Тогда
    	ИзображениеПолеHTML = "";
    Иначе
    
    ТекстHTML = 
	"<html style=""height: 100%;"">
	|<head>
	|<meta name=""viewport"" content=""width=device-width, minimum-scale=0.1"">
	|<title> </title>
	|</head>
	|<body style=""margin: 0px; height: 100%;"">
	|<img style=""display: block; height: 100%; margin: 0 auto;"" src=""#Адрес изображения#"">
	|</body>
	|</html>";
    
    	ТекстHTML = СтрЗаменить( ТекстHTML, "#Адрес изображения#", ТекущиеДанные.ПутьКФайлу );
		ИзображениеПолеHTML = ТекстHTML;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтрокуДереваТоваров(ИсходныйКлючЗаписи, КлючЗаписи)
	
	Запись = РегистрыСведений.СтатусыПубликацииТоваровЯндексМаркет.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(Запись, КлючЗаписи);
	Запись.Прочитать();
	
	Если НЕ Запись.Выбран() Тогда
		Возврат;
	КонецЕсли;
	
	ИсточникКатегории = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УчетнаяЗаписьМаркетплейса, "ИсточникКатегории");
	
	Для Каждого СтрокаДереваПервогоУровня Из ИмпортируемыеТовары.ПолучитьЭлементы() Цикл
		Для Каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.ПолучитьЭлементы() Цикл 
		
			Если СтрокаДереваВторогоУровня.Номенклатура = ИсходныйКлючЗаписи.Номенклатура 
				 И СтрокаДереваВторогоУровня.Характеристика = ИсходныйКлючЗаписи.Характеристика
				 И СтрокаДереваВторогоУровня.Упаковка = ИсходныйКлючЗаписи.Упаковка Тогда
				 
				ДанныеОбъекта = Запись.ДанныеОбъекта.Получить();
				ЗначенияРеквизитовИзСервиса = СтрокаДереваВторогоУровня.ЗначенияРеквизитовИзСервиса.Выгрузить();

				// Текущие сопоставления категории
				ТекущаяКатегория = ИнтеграцияСЯндексМаркетСервер.ОпределитьТекущуюСопоставленнуюКатегориюМаркетплейсаПоНоменклатуре(
					УчетнаяЗаписьМаркетплейса,
					СтрокаДереваВторогоУровня.Номенклатура,
					СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса,
					ИсточникКатегории);
					
				СтрокаДереваВторогоУровня.ТекущееИдентификаторКатегорииМаркетплейса = ТекущаяКатегория.ИдентификаторКатегории;
				СтрокаДереваВторогоУровня.ТекущееНаименованиеКатегорииМаркетплейса  = ТекущаяКатегория.НаименованиеКатегории;
				
				// Перезаполнить реквизиты
				ЗаполнитьЗначенияСвойств(СтрокаДереваВторогоУровня, Запись,, "ДанныеОбъекта, ИсточникиСхожихПредложений");
				
				Если ДанныеОбъекта <> Неопределено Тогда
					СтрокаДереваВторогоУровня.ДанныеОбъекта.Загрузить(ДанныеОбъекта.Скопировать());
				КонецЕсли;
				
				СтрокаДереваВторогоУровня.ЗначенияРеквизитовИзСервиса.Загрузить(ЗначенияРеквизитовИзСервиса);
				
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры	

&НаКлиенте
Процедура РазвернутьУзлыДерева(РазвернутьСПодчиненными = Ложь)
	
	Для каждого СтрокаДереваПервогоУровня Из ИмпортируемыеТовары.ПолучитьЭлементы() Цикл
		Элементы.ИмпортируемыеТовары.Развернуть(СтрокаДереваПервогоУровня.ПолучитьИдентификатор(), РазвернутьСПодчиненными);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ТоварыНайтиНаСервере()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции( УникальныйИдентификатор );
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Яндекс Маркет. Поиск данных по товарным позициям.'");
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ПрерватьВыполнениеЕслиОшибка = Истина;
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить( "ИмпортируемыеТовары", РеквизитФормыВЗначение( "ИмпортируемыеТовары" ) );
	ПараметрыФункции.Вставить( "УчетнаяЗаписьМаркетплейса", УчетнаяЗаписьМаркетплейса );
	ПараметрыФункции.Вставить( "ИсточникКатегории", ИсточникКатегории );
	
	ИмяМетода = "ИнтеграцияСЯндексМаркетСервер.ТоварыНайти";
	Возврат ДлительныеОперации.ВыполнитьФункцию( ПараметрыВыполнения, ИмяМетода, ПараметрыФункции );
		
КонецФункции

&НаСервере
Функция ТоварыНайтиНаСервереЗаполнитьРезультатНаФорме( АдресРезультата )
	
	Результат = ПолучитьИзВременногоХранилища( АдресРезультата );
	ЗначениеВРеквизитФормы( Результат.ИмпортируемыеТовары, "ИмпортируемыеТовары" );
	
	Возврат Истина;
КонецФункции

&НаКлиенте
Процедура ТоварыНайтиНаСервереЗавершениеФоновогоЗадания( Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		Если Результат.Свойство( "Сообщения" ) Тогда
			Для Каждого СообщениеЭлемент Из Результат.Сообщения Цикл
				ОбщегоНазначенияКлиент.СообщитьПользователю( СообщениеЭлемент.Текст );
			КонецЦикла;
		КонецЕсли;
		
		Если Результат.Статус = "Ошибка" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю( Результат.ПодробноеПредставлениеОшибки );
			
		ИначеЕсли Результат.Статус = "Выполнено" И Результат.Свойство( "АдресРезультата" ) Тогда
			
			// текущая позиция курсора
			Если Элементы.ИмпортируемыеТовары.ТекущиеДанные <> Неопределено Тогда
				ТекущаяПозицияИдентификаторОбъектаМаркетплейса = Элементы.ИмпортируемыеТовары.ТекущиеДанные.ИдентификаторОбъектаМаркетплейса;
			КонецЕсли;
			
			ТоварыНайтиНаСервереЗаполнитьРезультатНаФорме( Результат.АдресРезультата );
			
			РазвернутьУзлыДерева( Истина );
			
			// текущая позиция курсора
			Если ЗначениеЗаполнено( ТекущаяПозицияИдентификаторОбъектаМаркетплейса ) Тогда
				ИмпортируемыеТоварыТекущаяСтрокаУстановить( ТекущаяПозицияИдентификаторОбъектаМаркетплейса );
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИмпортируемыеТоварыТекущаяСтрокаУстановить( ИдентификаторОбъектаМаркетплейса )

		ИмпортируемыеТоварыТекущаяСтрока = Неопределено;
		
		СтрокиПервыйУровень = ИмпортируемыеТовары.ПолучитьЭлементы();
		Для Каждого СтрокаПервыйУровень Из СтрокиПервыйУровень Цикл

			СтрокиВторойУровень = СтрокаПервыйУровень.ПолучитьЭлементы();

			Для Каждого СтрокаВторойУровень Из СтрокиВторойУровень Цикл

				Если СтрокаВторойУровень.ИдентификаторОбъектаМаркетплейса = ИдентификаторОбъектаМаркетплейса Тогда
					ИмпортируемыеТоварыТекущаяСтрока = СтрокаВторойУровень.ПолучитьИдентификатор();
					Прервать;
				КонецЕсли;

			КонецЦикла;

			Если ЗначениеЗаполнено( ИмпортируемыеТоварыТекущаяСтрока ) Тогда
				Прервать;
			КонецЕсли;

		КонецЦикла;

		Если ЗначениеЗаполнено( ИмпортируемыеТоварыТекущаяСтрока ) Тогда
			Элементы.ИмпортируемыеТовары.ТекущаяСтрока = ИмпортируемыеТоварыТекущаяСтрока;
		КонецЕсли;

КонецПроцедуры

&НаКлиенте
Асинх Процедура ИмпортируемыеТоварыПоОбъединениюНоменклатураЗаполнить()
	
	ИмпортируемыеТоварыТекущиеДанные = Элементы.ИмпортируемыеТовары.ТекущиеДанные;
	Если ИмпортируемыеТоварыТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Номенклатура = ИмпортируемыеТоварыТекущиеДанные.Номенклатура;
	
	ЗначениеОбъединенияВОднуКарточку = ИмпортируемыеТоварыТекущиеДанные.ЗначениеОбъединенияВОднуКарточку;
	ИдентификаторКатегорииМаркетплейса = ИмпортируемыеТоварыТекущиеДанные.ИдентификаторКатегорииМаркетплейса;
	
	ИмпортируемыеТоварыСтроки = ИмпортируемыеТоварыТекущиеДанные.ПолучитьРодителя().ПолучитьЭлементы();
	СтрокиПоЗначениюОбъединения = Новый Соответствие;
	Для Каждого ИмпортируемыеТоварыСтрока Из ИмпортируемыеТоварыСтроки Цикл
	
	   	Если ПустаяСтрока( ИдентификаторКатегорииМаркетплейса ) 
	   	Или ПустаяСтрока( ЗначениеОбъединенияВОднуКарточку ) Тогда
	   		Продолжить;
	   	КонецЕсли;
	
		Если ИмпортируемыеТоварыСтрока.ИдентификаторКатегорииМаркетплейса = ИдентификаторКатегорииМаркетплейса
		И ИмпортируемыеТоварыСтрока.ЗначениеОбъединенияВОднуКарточку = ЗначениеОбъединенияВОднуКарточку Тогда
			СтрокиПоЗначениюОбъединения.Вставить( ИмпортируемыеТоварыСтрока.ИдентификаторОбъектаМаркетплейса, ИмпортируемыеТоварыСтрока );
		КонецЕсли;
	КонецЦикла;
	
	Если СтрокиПоЗначениюОбъединения.Количество() <= 1 Тогда
		Возврат;
	КонецЕсли;

	ВопросШаблон = 
	НСтр( "ru = 'Найдено строк по значению объединения: %1.
	|Заполнить выбранную номенклатуру для всех
	|строк с одинаковым значением объединения ?'" );
	ВопросТекст = СтрШаблон( ВопросШаблон, СтрокиПоЗначениюОбъединения.Количество() );
    ОтветОбещание = ВопросАсинх( ВопросТекст, РежимДиалогаВопрос.ДаНетОтмена, , , "Заполнение по значению объединения" );
    Ответ = Ждать ОтветОбещание;
    Если Ответ <> КодВозвратаДиалога.Да Тогда
    	Возврат;
    КонецЕсли;
	
	// одинаковые значения по объединению	
	Для Каждого СтрокаПоЗначениюОбъединения Из СтрокиПоЗначениюОбъединения Цикл
		
		ИмпортируемыеТоварыДанные = СтрокаПоЗначениюОбъединения.Значение;
		
		ИмпортируемыеТоварыДанные.Номенклатура = Номенклатура;
		ИмпортируемыеТоварыДанные.Характеристика = Неопределено;
		
		ИмпортируемыеТоварыДанные.Категория = ИмпортируемыеТоварыТекущиеДанные.Категория;
		ИмпортируемыеТоварыДанные.ИсточникКатегорииМаркетплейса = ИмпортируемыеТоварыТекущиеДанные.ИсточникКатегорииМаркетплейса;
		ИмпортируемыеТоварыДанные.ЕдиницаИзмерения = ИмпортируемыеТоварыТекущиеДанные.ЕдиницаИзмерения;
		ИмпортируемыеТоварыДанные.ХарактеристикиИспользуются = ИмпортируемыеТоварыТекущиеДанные.ХарактеристикиИспользуются;
		
		ИмпортируемыеТоварыДанные.Пометка = Истина;
		
	КонецЦикла;
	
	СообщениеШаблон = НСтр( "ru = 'Заполное строк по значению объединения: %1'" );
	СообщениеТекст = СтрШаблон( СообщениеШаблон, СтрокиПоЗначениюОбъединения.Количество()) ;
	ПоказатьОповещениеПользователя( СообщениеТекст, , , БиблиотекаКартинок.ЯндексМаркетЛоготип );

КонецПроцедуры

&НаКлиенте
Асинх Процедура ИмпортируемыеТоварыПоОбъединениюФлагСоздатьХарактеристикуЗаполнить()
	
	ИмпортируемыеТоварыТекущиеДанные = Элементы.ИмпортируемыеТовары.ТекущиеДанные;
	Если ИмпортируемыеТоварыТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СоздатьХарактеристику = ИмпортируемыеТоварыТекущиеДанные.СоздатьХарактеристику;
	
	ЗначениеОбъединенияВОднуКарточку = ИмпортируемыеТоварыТекущиеДанные.ЗначениеОбъединенияВОднуКарточку;
	НаименованиеКатегорииМаркетплейса = ИмпортируемыеТоварыТекущиеДанные.НаименованиеКатегорииМаркетплейса;
	
	ИмпортируемыеТоварыСтроки = ИмпортируемыеТоварыТекущиеДанные.ПолучитьРодителя().ПолучитьЭлементы();
	СтрокиПоЗначениюОбъединения = Новый Соответствие;
	Для Каждого ИмпортируемыеТоварыСтрока Из ИмпортируемыеТоварыСтроки Цикл
		Если ИмпортируемыеТоварыСтрока.НаименованиеКатегорииМаркетплейса = НаименованиеКатегорииМаркетплейса
		И ИмпортируемыеТоварыСтрока.ЗначениеОбъединенияВОднуКарточку = ЗначениеОбъединенияВОднуКарточку Тогда
			СтрокиПоЗначениюОбъединения.Вставить( ИмпортируемыеТоварыСтрока.ИдентификаторОбъектаМаркетплейса, ИмпортируемыеТоварыСтрока );
		КонецЕсли;
	КонецЦикла;
	
	Если СтрокиПоЗначениюОбъединения.Количество() <= 1 Тогда
		Возврат;
	КонецЕсли;

	ВопросШаблон = 
	НСтр( "ru = 'Найдено строк по значению объединения: %1.
	|Заполнить флаг ""Создать характеристику"" для всех
	|строк с одинаковым значением объединения ?'" );
	ВопросТекст = СтрШаблон( ВопросШаблон, СтрокиПоЗначениюОбъединения.Количество() );
    ОтветОбещание = ВопросАсинх( ВопросТекст, РежимДиалогаВопрос.ДаНетОтмена, , , "Заполнение по значению объединения" );
    Ответ = Ждать ОтветОбещание;
    Если Ответ <> КодВозвратаДиалога.Да Тогда
    	Возврат;
    КонецЕсли;
	
	// одинаковые значения по объединению	
	Для Каждого СтрокаПоЗначениюОбъединения Из СтрокиПоЗначениюОбъединения Цикл
		
		ИмпортируемыеТоварыДанные = СтрокаПоЗначениюОбъединения.Значение;
		
		ИмпортируемыеТоварыДанные.СоздатьХарактеристику = СоздатьХарактеристику;
		
		ИмпортируемыеТоварыДанные.Пометка = Истина;
		
	КонецЦикла;
	
	СообщениеШаблон = НСтр( "ru = 'Заполное строк по значению объединения: %1'" );
	СообщениеТекст = СтрШаблон( СообщениеШаблон, СтрокиПоЗначениюОбъединения.Количество()) ;
	ПоказатьОповещениеПользователя( СообщениеТекст, , , БиблиотекаКартинок.ЯндексМаркетЛоготип );

КонецПроцедуры

&НаСервере
Функция ЗагрузитьИСоздатьВсеТоварыИзЯндексМаркетНаСервере( КэшКатегорий )
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания  = НСтр("ru = 'Яндекс Маркет. Получение ВСЕХ описаний товаров с торговой площадки.'");
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.ПрерватьВыполнениеЕслиОшибка = Истина;
	
	ПараметрыФункции = ИнтеграцияСЯндексМаркетСервер.ИмпортИзЯндексМаркетПараметрыНовый();
	
	ПараметрыФункции.ВариантЗагрузкиДанных = ВариантЗагрузкиДанных;
	ПараметрыФункции.КэшКатегорий = КэшКатегорий;
	ПараметрыФункции.ЗагрузитьЦеныПродажи = Ложь;
	ПараметрыФункции.ИмяИдентификатора = ИмяИдентификатора;
	
	РазмерПорцииЗагрузкиДанных = 99999;
	ПараметрыФункции.РазмерПорцииЗагрузкиДанных = РазмерПорцииЗагрузкиДанных;
	
	ПараметрыФункции.СоздатьЭлементыНоменклатуры = Истина;
	ПараметрыФункции.ПерезаполнитьЗначенияРеквизитовНоменклатуры = Истина;
	ПараметрыФункции.ГруппаДляСозданияНовыхТоваров = ГруппаДляСозданияНовыхТоваров;
	ПараметрыФункции.СоздатьИерархиюНоменклатуры = Ложь;
	ПараметрыФункции.СоздатьХарактеристикиНоменклатуры = Ложь;
	
	ПараметрыФункции.СоздатьКатегорииНоменклатуры = Истина;
	ПараметрыФункции.СоздатьИерархиюКатегорийНоменклатуры = Ложь;
	
	ПараметрыФункции.СортироватьСтрокиДереваТоваров = Истина;
	ПараметрыФункции.ОтображатьСопоставленные = ОтображатьСопоставленные;
	ПараметрыФункции.ОтображатьПоСтатусу = ОтображатьПоСтатусу;
	ПараметрыФункции.СледующаяПорцияДанных = Ложь;
	ПараметрыФункции.ИдентификаторыТоваров = РеквизитФормыВЗначение( "ИдентификаторыТоваров" );
	
	ПараметрыФункции.ТоварыНайти = Истина;
	
	ПараметрыФункции.ИмпортируемыеТовары = РеквизитФормыВЗначение( "ИмпортируемыеТовары" );
	
	ПараметрыФункции.УчетнаяЗаписьМаркетплейса = УчетнаяЗаписьМаркетплейса;
	ПараметрыФункции.ИсточникКатегории = ИсточникКатегории;
	
	ПараметрыФункции.ЗагрузитьИзображения = Истина;
	
	ПараметрыФункции.ЗаписатьТолькоЦены = Ложь;
	ПараметрыФункции.ТолькоСоздатьНоменклатуру = Ложь;
	ПараметрыФункции.КэшКатегорийДерево = Неопределено;
	ПараметрыФункции.ДокументУстановкаЦенНоменклатуры = Неопределено;
	ПараметрыФункции.ЗагрузитьОписанияАрхивныхПозиций = Ложь;
	
	ЗагрузитьОписанияАрхивныхПозиций = Ложь;
	
	ИмяМетода = "ИнтеграцияСЯндексМаркетСервер.ЗагрузитьИСоздатьВсеТоварыИзЯндексМаркет";
	Возврат ДлительныеОперации.ВыполнитьФункцию( ПараметрыВыполнения, ИмяМетода, ПараметрыФункции );
	
КонецФункции

&НаКлиенте
Процедура ЗагрузитьИСоздатьВсеТоварыИзЯндексМаркетЗавершениеФоновогоЗадания( Результат, ДополнительныеПараметры ) Экспорт

	Если ТипЗнч( Результат ) = Тип( "Структура" ) Тогда

		Если Результат.Свойство( "Сообщения" ) Тогда
			Для Каждого СообщениеЭлемент Из Результат.Сообщения Цикл
				ОбщегоНазначенияКлиент.СообщитьПользователю( СообщениеЭлемент.Текст );
			КонецЦикла;
		КонецЕсли;

		Если Результат.Статус = "Ошибка" Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю( Результат.ПодробноеПредставлениеОшибки );
		КонецЕсли;
		
		Если Результат.Свойство( "АдресРезультата" ) Тогда
			ЗагрузитьИСоздатьВсеТоварыИзЯндексМаркетРезультатОбработатьНаСервере( Результат.АдресРезультата );
		КонецЕсли;
		
	КонецЕсли;
	
	РазвернутьУзлыДерева( Истина );
	
	Если ИмпортируемыеТовары.ПолучитьЭлементы().Количество() > 0 Тогда
		ФормаРежимОтображенияЭлементыОбновить( ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияЗагрузитьВсеОписания() ); 
	Иначе
		ПоказатьПредупреждение( Новый ОписаниеОповещения, "Не найдено новых описаний товаров для импорта на сайте Яндекс Маркет." );
		ФормаРежимОтображенияЭлементыОбновить( ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияОткрытие() ); 
	КонецЕсли;
	
	Оповестить( "КатегорииПослеЗаписиСоответствия" );
	Оповестить( "ЯндексМаркетТоварыСписокОбновить" );
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИСоздатьВсеТоварыИзЯндексМаркетРезультатОбработатьНаСервере( АдресРезультата )
	
	Результат = ПолучитьИзВременногоХранилища( АдресРезультата );
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Свойство( "Пропущено" ) И ТипЗнч( Результат.Пропущено ) = Тип( "Массив" ) Тогда
	
		Для Каждого ПропущеноЭлемент Из Результат.Пропущено Цикл
			ОбщегоНазначения.СообщитьПользователю( ПропущеноЭлемент.Сообщение );
		КонецЦикла;
		
	КонецЕсли;
	
	ЗначениеВРеквизитФормы( Результат.ДеревоТоваров, "ИмпортируемыеТовары" );
	
	ПолучитьДанныеЛегенды( Результат.ДеревоТоваров );
	УстановитьВидимостьДоступность();
	
КонецПроцедуры

&НаКлиенте
Функция СтатистикаПоСтатусамОчистить()
	
	ЛегендаГотовыКПродаже = "";
	ЛегендаНеНайденыНаПлощадке = "";
	ЛегендаОбнаруженыРасхождения = "";
	ЛегендаОбновлениеНеТребуется = "";
	ЛегендаОжидаютИсправленияОшибок = "";
	ЛегендаОжидаютПолученияДанных = "";
	ЛегендаПеремещеныВАрхив = "";
	ЛегендаПодготовленыКПубликации = "";
	
	Возврат Истина;
КонецФункции

&НаКлиенте
Процедура СоздатьНоменклатуруЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ОчиститьСообщения();
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Импорт данных'"),
			, 
			НСтр("ru = 'Создание номенклатуры для несопоставленных позиций.'"),
			БиблиотекаКартинок.ЯндексМаркетЛоготип);
			
		ДлительнаяОперация    = ЗаписатьЗагруженныеДанныеНаСервере( Ложь, Истина );
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗаписатьЗагруженныеДанныеЗавершениеФоновогоЗадания", ЭтотОбъект,);
		
		ПараметрыОжидания 								   = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания 			   = Истина;
		ПараметрыОжидания.ТекстСообщения                   = НСтр("ru = 'Создание номенклатуры для несопоставленных позиций.'");
		ПараметрыОжидания.ОповещениеПользователя.Показать  = Истина;
		ПараметрыОжидания.ОповещениеПользователя.Текст 	   = НСтр("ru = 'Импорт данных'");
		ПараметрыОжидания.ОповещениеПользователя.Пояснение = НСтр("ru = 'Завершено создание номенклатуры для несопоставленных позиций.'");
		ПараметрыОжидания.ОповещениеПользователя.Картинка  = БиблиотекаКартинок.ЯндексМаркетЛоготип;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьТекущийИсточникКатегорииМаркетплейса(УчетнаяЗаписьМаркетплейса, Категория1С, БлижайшийРодитель = Истина)

	ДанныеИсточникаКатегорииМаркетплейса = Новый Структура;
	ДанныеИсточникаКатегорииМаркетплейса.Вставить("ИсточникКатегорииМаркетплейса",               Неопределено);
	ДанныеИсточникаКатегорииМаркетплейса.Вставить("ИдентификаторИсточникаКатегорииМаркетплейса", "");
	ДанныеИсточникаКатегорииМаркетплейса.Вставить("НаименованиеИсточникаКатегорииМаркетплейса",  "");
	
	Возврат ДанныеИсточникаКатегорииМаркетплейса;
КонецФункции

&НаКлиенте
Процедура ПоКнопкеПараметрыИмпортаДанныхЗавершение( РезультатЗакрытия, ДополнительныеПараметры ) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяИдентификатора = РезультатЗакрытия.ИмяИдентификатора;
	РазмерПорцииЗагрузкиДанных = РезультатЗакрытия.РазмерПорцииЗагрузкиДанных;
	СортироватьСтрокиДереваТоваров = РезультатЗакрытия.СортироватьСтрокиДереваТоваров;
	
	СоздатьЭлементыНоменклатуры = РезультатЗакрытия.СоздатьЭлементыНоменклатуры;
	ПерезаполнитьЗначенияРеквизитовНоменклатуры = РезультатЗакрытия.ПерезаполнитьЗначенияРеквизитовНоменклатуры;
	ГруппаДляСозданияНовыхТоваров = РезультатЗакрытия.ГруппаДляСозданияНовыхТоваров;
	СоздатьИерархиюНоменклатуры = РезультатЗакрытия.СоздатьИерархиюНоменклатуры;
	СоздатьХарактеристикиНоменклатуры = РезультатЗакрытия.СоздатьХарактеристикиНоменклатуры;
	
	СоздатьКатегорииНоменклатуры = РезультатЗакрытия.СоздатьКатегорииНоменклатуры;
	СоздатьИерархиюКатегорийНоменклатуры = РезультатЗакрытия.СоздатьИерархиюКатегорийНоменклатуры;
	
	ЗагрузитьЦеныПродажи = РезультатЗакрытия.ЗагрузитьЦеныПродажи;
	ЗаписатьЦеныОтдельнойКомандой = РезультатЗакрытия.ЗаписатьЦеныОтдельнойКомандой;
	ДокументУстановкаЦенНоменклатуры = РезультатЗакрытия.ДокументУстановкаЦенНоменклатуры;
	
	ЗагрузитьИзображения = РезультатЗакрытия.ЗагрузитьИзображения;
	
	ЗагрузитьОписанияАрхивныхПозиций = РезультатЗакрытия.ЗагрузитьОписанияАрхивныхПозиций;
	
	Если ВариантЗагрузкиДанных <> РезультатЗакрытия.ВариантЗагрузкиДанных Тогда
		ВариантЗагрузкиДанных = РезультатЗакрытия.ВариантЗагрузкиДанных;
		//@skip-check invocation-form-event-handler
		ВариантЗагрузкиДанныхПриИзменении(Неопределено);
	Иначе
		УстановитьВидимостьДоступность();
		ФормаПараметрыИмпортаДанныхОписаниеОбновить();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ИмпортируемыеТоварыЕстьПометки()

	ИмпортируемыеТоварыЭлементы = ИмпортируемыеТовары.ПолучитьЭлементы();
	Для Каждого ИмпортируемыеТоварыЭлемент Из ИмпортируемыеТоварыЭлементы Цикл
		ИмпортируемыеТоварыЭлементыВторогоУровня = ИмпортируемыеТоварыЭлемент.ПолучитьЭлементы();
		Для Каждого ИмпортируемыеТоварыЭлементВторогоУровня Из ИмпортируемыеТоварыЭлементыВторогоУровня Цикл
			Если ИмпортируемыеТоварыЭлементВторогоУровня.Пометка = Истина Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Ложь;
КонецФункции

#КонецОбласти


