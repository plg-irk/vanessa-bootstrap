	Если ИмпортируемыеТовары.ПолучитьЭлементы().Количество() > 0 Тогда
	
		ВопросТекст = 
		НСтр( "ru = 'Таблица товаров на форме будет очищена.
		|Продолжить?'" );
		ОтветОбещание = ВопросАсинх( ВопросТекст, РежимДиалогаВопрос.ДаНетОтмена, , , "Импорт описаний товаров из Яндекс Маркет" );
		Ответ = Ждать ОтветОбещание;
		Если Ответ <> КодВозвратаДиалога.Да Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ИмпортируемыеТовары.ПолучитьЭлементы().Очистить();    
	СтатистикаПоСтатусамОчистить();
	
	ФормаРежимОтображенияЭлементыОбновить( ИнтеграцияСЯндексМаркетКлиентСервер.ФормаРежимОтображенияОткрытие() );
	
