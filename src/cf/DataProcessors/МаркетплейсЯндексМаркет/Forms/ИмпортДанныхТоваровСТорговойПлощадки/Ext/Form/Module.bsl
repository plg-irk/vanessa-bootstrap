	ПараметрыОткрытия.Вставить( "ДокументУстановкаЦенНоменклатуры", ДокументУстановкаЦенНоменклатуры );
	
	ПараметрыОткрытия.Вставить( "СоздатьЭлементыНоменклатуры", СоздатьЭлементыНоменклатуры );
	ПараметрыОткрытия.Вставить( "ПерезаполнитьЗначенияРеквизитовНоменклатуры", ПерезаполнитьЗначенияРеквизитовНоменклатуры );
	ПараметрыОткрытия.Вставить( "ГруппаДляСозданияНовыхТоваров", ГруппаДляСозданияНовыхТоваров );
	ПараметрыОткрытия.Вставить( "СоздатьИерархиюНоменклатуры", СоздатьИерархиюНоменклатуры );
	ПараметрыОткрытия.Вставить( "СоздатьХарактеристикиНоменклатуры", СоздатьХарактеристикиНоменклатуры );
	
	ПараметрыОткрытия.Вставить( "СоздатьКатегорииНоменклатуры", СоздатьКатегорииНоменклатуры );
	ПараметрыОткрытия.Вставить( "СоздатьИерархиюКатегорийНоменклатуры", СоздатьИерархиюКатегорийНоменклатуры );
	
