
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИмяОбластиСпискаТоваров = НСтр("ru = 'Список товаров'");
	ЭтоНастройкиКнопки = ЭтоРедактированиеКнопкиФормы();
	Если Параметры.Свойство("ЗаголовокОбъекта") Тогда
		ТипОбласти = ?(ЭтоНастройкиКнопки, НСтр("ru = 'Кнопка'"), НСтр("ru = 'Панель'"));
		ЗаголовокОбласти = Параметры.ЗаголовокОбъекта;
		ЭтотОбъект.Заголовок = СтрШаблон("%1 ""%2""", ТипОбласти, Параметры.ЗаголовокОбъекта);
		ЭтоОбластьСпискаТоваров = (ЗаголовокОбласти = ИмяОбластиСпискаТоваров);
	КонецЕсли;
	Если ЭтоНастройкиКнопки И Параметры.Свойство("ИмяЭлемента") Тогда
		ИмяЭлемента = Параметры.ИмяЭлемента;
	КонецЕсли;
	НастроитьВидимостьГруппДляОбласти();
	
КонецПроцедуры

