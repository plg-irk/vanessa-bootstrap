	ТаблицаЗарезервировано.Очистить();
	ТаблицаОперацииЕНП.Очистить();
	ТаблицаИсторияЕНС.Очистить();
	ТаблицаПроцедурыВзыскания.Очистить();
	ТаблицаПлатежи.Очистить();
	ТаблицаОтчеты.Очистить();
	ТаблицаНачисления.Очистить();
