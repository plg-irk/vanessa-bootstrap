	ДанныеОтсутствуют      = Истина;
	ЕстьПредстоящиеПлатежи = Ложь;
	ЕстьМерыВзыскания      = Ложь;
	ЕстьПениШтрафы         = Ложь;
	ЕстьЗадолженность      = Ложь;
	ЕстьРезервы            = Ложь;
	
	ОчиститьТаблицыДанных();
	
КонецПроцедуры

