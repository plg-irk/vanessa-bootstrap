&НаКлиенте
Функция ОтразитьВУчетеУплаты(ДанныеСтроки)
	
	Данные = НовыйДанныеОтразитьВУчетеУплаты();
	ДанныеСтрокиУплат = НовыйДанныеСтроки();
	ЗаполнитьЗначенияСвойств(ДанныеСтрокиУплат, ДанныеСтроки);
	ЗаполнитьДанныеОтразитьВУчетеУплаты(Данные, Объект.Организация, ДанныеСтрокиУплат);
	
	Результат = НовыйРезультатОтразитьВУчете();
	Результат.ИдентификаторСтроки = ДанныеСтроки.ИдентификаторСтроки;
	
	ЕдиныйНалоговыйСчетИнтеграцияФормыКлиентПереопределяемый.ОтразитьВУчетеУплаты(Данные, Результат);
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаполнитьДанныеОтразитьВУчетеУплаты(Данные, Организация, Знач ДанныеСтроки = Неопределено, Знач ТаблицаУплаты = Неопределено, ОтразитьВсеРасхождения = Ложь)
	
	Данные.Организация = Организация;
	ВременнаяТаблицаУплат = НовыйТаблицаУплат();
	Если ОтразитьВсеРасхождения Тогда
		Для Каждого СтрокаУплат Из ТаблицаУплаты Цикл
			Если СтрокаУплат.СуммаРасхождение > 0 Тогда
				НоваяСтрока = ВременнаяТаблицаУплат.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаУплат);
				НоваяСтрока.ВидНалога              = СтрокаУплат.ВидНалоговогоОбязательства;
				НоваяСтрока.КБК                    = СтрокаУплат.ПредставлениеКБК;
				НоваяСтрока.Сумма                  = СтрокаУплат.СуммаФНС;
				НоваяСтрока.ПредставлениеОснования = СтрокаУплат.ПредставлениеОснованияФНС;
			КонецЕсли;
		КонецЦикла;
	Иначе
		НоваяСтрока = ВременнаяТаблицаУплат.Добавить();
		НоваяСтрока.ДатаОперации           = ДанныеСтроки.ДатаОперации;
		НоваяСтрока.ВидНалога              = ДанныеСтроки.ВидНалоговогоОбязательства;
		НоваяСтрока.КБК                    = ДанныеСтроки.ПредставлениеКБК;
		НоваяСтрока.Сумма                  = ДанныеСтроки.СуммаФНС;
		НоваяСтрока.НалоговыйАгент         = ДанныеСтроки.НалоговыйАгент;
		НоваяСтрока.ИдентификаторОперации  = ДанныеСтроки.ИдентификаторОперации;
		НоваяСтрока.ПредставлениеОснования = ДанныеСтроки.ПредставлениеОснованияФНС;
	КонецЕсли;
	
	Данные.АдресТаблицыУплат = ПоместитьВоВременноеХранилище(ВременнаяТаблицаУплат, Новый УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Функция ОтразитьВУчетеПениШтрафы(ДанныеСтроки)
	
