	КонецЕсли;
	Если ЕстьТехническаяИнформация Тогда
		Сообщение.Добавить(Символы.ПС);
		Сообщение.Добавить(НСтр("ru = ' - техническая информация'"));
	КонецЕсли;
	
	Возврат СтрСоединить(Сообщение);
	
