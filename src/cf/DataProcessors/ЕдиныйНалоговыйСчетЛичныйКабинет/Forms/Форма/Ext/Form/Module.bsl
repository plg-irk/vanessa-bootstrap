	Результат = НовыйРезультатОтразитьВУчете();
	Результат.ИдентификаторСтроки = ДанныеСтроки.ИдентификаторСтроки;
	
	ЕдиныйНалоговыйСчетИнтеграцияФормыКлиентПереопределяемый.ОтразитьВУчетеПениШтрафы(Данные, Результат);
	
	Возврат Результат;
	
