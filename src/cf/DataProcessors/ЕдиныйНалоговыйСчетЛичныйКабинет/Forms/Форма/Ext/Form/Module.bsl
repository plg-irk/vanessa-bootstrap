&НаКлиенте
Процедура НачалоПериодаПриИзменении(Элемент)
	
	ОграничениеСнизу = ОграничениеСнизуНачалаРаботыРежимаСверки();
	
	Если ПериодГлавное.ДатаНачала < ОграничениеСнизу Тогда
		
		ПериодГлавное.ДатаНачала = ОграничениеСнизу;
		
		СообщениеОбОшибке = СтрШаблон(НСтр("ru = 'Сверка сальдо ЕНС возможна с %1'"), Формат(ОграничениеСнизу, "ДЛФ=DD"));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОбОшибке);
	КонецЕсли;
	
	Если ПериодГлавное.ДатаНачала > ПериодГлавное.ДатаОкончания Тогда
		ТекстСообщения = НСтр("ru = 'Дата начала периода не может быть больше даты конца периода'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "ПериодГлавное.ДатаНачала");
		Возврат;
	КонецЕсли;
	
	ИзменитьПериодыТаблицСверок();
	
	ИзмененПериодГлавное = Истина;
	
	СобратьДанныеЕдиногоНалоговогоСчета();
	
	ОтразитьВУчетеУплатыЗавершениеНаСервере();
	ОтразитьВУчетеПениЗавершениеНаСервере();
	
КонецПроцедуры

