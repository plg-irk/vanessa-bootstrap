&НаКлиенте
Процедура ОтразитьВУчетеЗавершение(Результат, ТекущиеДанные)
	
	Если Результат.Успешно Тогда
		
		НоваяСтрока = ТаблицаОснованияНачислений.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Результат);
		НоваяСтрока.Представление = СтрШаблон(НСтр("ru='%1 №%2 от %3'"),
			Строка(ТипЗнч(Результат.Ссылка)), Результат.Номер, Формат(Результат.Дата, "ДЛФ=D"));
		
		ТекущиеДанные.ПредставлениеОснованияУчет = НоваяСтрока.Представление;
		ТекущиеДанные.СуммаУчет = Результат.Сумма;
		ТекущиеДанные.СуммаРасхождение = ТекущиеДанные.СуммаФНС - ТекущиеДанные.СуммаУчет;
		ТекущиеДанные.ЕстьРасхождение = ТекущиеДанные.СуммаРасхождение <> 0;
		Если ЭтотОбъект.ТекущийЭлемент.Имя = "ТаблицаПениШтрафы" Тогда
			ОтразитьВУчетеПениЗавершениеНаСервере();
		КонецЕсли;
		
	ИначеЕсли Не ПустаяСтрока(Результат.СообщениеОбОшибке) Тогда
		
		ПоказатьПредупреждение(, Результат.СообщениеОбОшибке);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтразитьВУчетеУплатыЗавершение(Результат, ТекущиеДанные)
	
	Если Результат.Успешно Тогда
		
		Представление = СтрШаблон(НСтр("ru='%1 от %2'"),
			Строка(ТипЗнч(Результат.Ссылка)), Формат(Результат.Дата, "ДЛФ=D"));
		
		ТекущиеДанные.ПредставлениеОснованияУчет = Представление;
		ТекущиеДанные.ОснованиеУчета = Результат.Ссылка;
		ТекущиеДанные.СуммаУчет = Результат.Сумма;
		ТекущиеДанные.СуммаРасхождение = ТекущиеДанные.СуммаФНС - ТекущиеДанные.СуммаУчет;
		ТекущиеДанные.ЕстьРасхождение = ТекущиеДанные.СуммаРасхождение <> 0;
		
		ОтразитьВУчетеУплатыЗавершениеНаСервере();
		
	ИначеЕсли Не ПустаяСтрока(Результат.СообщениеОбОшибке) Тогда
		
		ПоказатьПредупреждение(, Результат.СообщениеОбОшибке);
		
	КонецЕсли;
	
КонецПроцедуры

