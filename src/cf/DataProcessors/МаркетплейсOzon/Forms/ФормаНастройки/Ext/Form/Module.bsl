&НаКлиенте
Процедура ОбновитьДанныеТоваровСТорговойПлощадки(Команда)
    
    // обновление
    
	УчетнаяЗаписьМаркетплейса = Объект.Ссылка;
	
	Если УчетнаяЗаписьМаркетплейса.Пустая() Тогда
		Возврат;
	КонецЕсли;

	ДанныеВыделенныхСтрок = Элементы.Товары.ВыделенныеСтроки;
	Если ДанныеВыделенныхСтрок.Количество() = 0 Тогда
		ПоказатьПредупреждение( Новый ОписаниеОповещения, НСтр( "ru = 'Для обновления необходимо выделить одну или несколько строк с товарами.'" ) );
		Возврат;
	КонецЕсли;

	ВариантЗагрузкиДанныхОбновитьВыбранныеКарточкиТоваров = 0;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить( "УчетнаяЗаписьМаркетплейса", УчетнаяЗаписьМаркетплейса );
	ПараметрыФормы.Вставить( "ВариантЗагрузкиДанных", ВариантЗагрузкиДанныхОбновитьВыбранныеКарточкиТоваров );

	ПараметрыФормы.Вставить( "СоздатьЭлементыНоменклатуры", Истина );// для обновления реквизитов номенклатуры и загрузки изображений
	ПараметрыФормы.Вставить( "ПерезаполнитьЗначенияРеквизитовНоменклатуры", Истина );
	ПараметрыФормы.Вставить( "СоздатьХарактеристикиНоменклатуры", Истина );
	
	ПараметрыФормы.Вставить( "СоздатьКатегорииНоменклатуры", Ложь );
	ПараметрыФормы.Вставить( "СоздатьИерархиюКатегорийНоменклатуры", Ложь );
	
	ПараметрыФормы.Вставить( "ЗагрузитьИзображения", Истина );
	ПараметрыФормы.Вставить( "ЗагрузитьЦеныПродажи", Истина );
	
	ПараметрыФормы.Вставить( "ДанныеВыделенныхСтрок", ДанныеВыделенныхСтрок );
	
	ПараметрыФормы.Вставить( "ЗагрузитьОписанияАрхивныхПозиций", Истина );
	ПараметрыФормы.Вставить( "РазмерПорцииЗагрузкиДанных", 0 );
	
	УникальностьФормы = "" + УчетнаяЗаписьМаркетплейса.УникальныйИдентификатор() + ВариантЗагрузкиДанныхОбновитьВыбранныеКарточкиТоваров;
	ОткрытьФорму("Обработка.МаркетплейсOzon.Форма.ИмпортДанныхТоваровСТорговойПлощадки", ПараметрыФормы, , УникальностьФормы );

КонецПроцедуры

