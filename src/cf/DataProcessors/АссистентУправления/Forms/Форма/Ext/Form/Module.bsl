
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если МобильныйКлиентУНФ.ФункциональностьВременноНедоступна(Отказ) Тогда
		Возврат;
	КонецЕсли;
	
	АссистентПодключен = АссистентУправления.Подключен();
	ИнформационнаяБазаПодключена = СистемаВзаимодействия.ИнформационнаяБазаЗарегистрирована();
	
	ТекущийЭлемент = Элементы.ИзмениСостояниеПриОплате;
	ТекущаяСтраница = "ИзмениСостояниеЗаказа";

	ИспользоватьПодсистемуПроизводство = ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуПроизводство");
	ИспользоватьБонусныеПрограммы = ПолучитьФункциональнуюОпцию("ИспользоватьБонусныеПрограммы");
	ИспользоватьОтчетность = ПолучитьФункциональнуюОпцию("ИспользоватьОтчетность");
	ПланироватьЗагрузкуРесурсовПредприятияЖурналЗаписи = ПолучитьФункциональнуюОпцию("ПланироватьЗагрузкуРесурсовПредприятияЖурналЗаписи");
	ПланироватьЗагрузкуРесурсовПредприятияРаботы  = ПолучитьФункциональнуюОпцию("ПланироватьЗагрузкуРесурсовПредприятияРаботы");
	УчетПотребностиПоСкладам = ПолучитьФункциональнуюОпцию("УчетПотребностиПоСкладам");
	ИспользоватьРегулярныеПлатежи = ПолучитьФункциональнуюОпцию("ИспользоватьРегулярныеПлатежи");
	ИспользоватьПодсистемуCRM = ПолучитьФункциональнуюОпцию( "ИспользоватьПодсистемуCRM" );
	ИспользоватьПодсистемуЗакупки = ПолучитьФункциональнуюОпцию( "ИспользоватьПодсистемуЗакупки" );
	ИспользоватьАнализБизнеса = ПолучитьФункциональнуюОпцию( "ИспользоватьАнализБизнеса" );
	ИспользоватьЗадачиСотрудников = ПолучитьФункциональнуюОпцию("ИспользоватьЗадачиСотрудников");
	
	УстановитьПризнакиВРаботе();
	
	УстановитьВидимостьЭлементов();
	
	УправлениеФормой();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПредложитьВозможностьНажатие(Элемент)
	
	ТекстПисьма = НСтр("ru = 'Опишите, каких навыков не хватает ассистенту управления:'");
	Тег = НСтр("ru = 'Ассистент управления'");
	
	УправлениеНебольшойФирмойКлиент.ПредложитьВозможностьНажатие(Тег, ТекстПисьма);
	
