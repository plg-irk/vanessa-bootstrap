
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекущийПользовательИБ = Пользователи.ТекущийПользователь();
	ИдентификаторПользователяИБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущийПользовательИБ, "ИдентификаторПользователяИБ");
	ИдентификаторПользователяСВ = СистемаВзаимодействия.ПолучитьИдентификаторПользователя(ИдентификаторПользователяИБ);
	
	ПользовательСВ = СистемаВзаимодействия.ПолучитьПользователя(ИдентификаторПользователяСВ);
	ТекущийПользователь = ПользовательСВ.ПолноеИмя;
	
	КартинкаПользователя = ПользовательСВ.Картинка;
	КартинкаТекущийПользователь = ПоместитьВоВременноеХранилище(КартинкаПользователя, Новый УникальныйИдентификатор);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	НовоеОбсуждение = СоздатьОбсуждениеСервер();
	Закрыть(НовоеОбсуждение);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция СоздатьОбсуждениеСервер()
	
	НовоеОбсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
	НовоеОбсуждение.Групповое = Истина;
	НовоеОбсуждение.Отображаемое = Истина;
	
	ТекущийПользовательИБ = Пользователи.ТекущийПользователь();
	ИдентификаторПользователяИБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущийПользовательИБ, "ИдентификаторПользователяИБ");
	ИдентификаторПользователяСВ = СистемаВзаимодействия.ПолучитьИдентификаторПользователя(ИдентификаторПользователяИБ);
	
	НовоеОбсуждение.Участники.Добавить(ИдентификаторПользователяСВ);
	НовоеОбсуждение.Заголовок = ТемаОбсуждения;
	НовоеОбсуждение.Записать();
	Возврат Строка(НовоеОбсуждение.Идентификатор);
	
КонецФункции

#КонецОбласти