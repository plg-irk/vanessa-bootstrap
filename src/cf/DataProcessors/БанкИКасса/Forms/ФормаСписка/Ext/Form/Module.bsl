	ИначеЕсли ИмяРеквизитаСписка = "СписокОперацииПоПлатежнымКартам" Тогда
		ИмяТЧДанныеМеток = "ДанныеМетокОперацииПоПлатежнымКартам";
		ИмяТЧДанныеОтборов = "ДанныеОтборовОперацииПоПлатежнымКартам";
