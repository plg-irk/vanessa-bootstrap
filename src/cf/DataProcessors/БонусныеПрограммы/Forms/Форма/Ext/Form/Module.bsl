#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВариантСовместногоПрименения = Константы.ВариантыСовместногоПримененияСкидокНаценок.Получить();
	Если ВариантСовместногоПрименения.Пустая() Тогда
		ВариантСовместногоПрименения = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Максимум;
		Константы.ВариантыСовместногоПримененияСкидокНаценок.Установить(ВариантСовместногоПрименения);
	КонецЕсли;
	
	// Открытие из вида дисконтных карт для настройки бонусов по ДК
	Если Параметры.Свойство("БонуснаяПрограмма") И ЗначениеЗаполнено(Параметры.БонуснаяПрограмма) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(БонусныеПрограммыИСкидки,
			"БонуснаяПрограмма", Параметры.БонуснаяПрограмма,,,,РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(АвтоматическиеОкругления,
			"БонуснаяПрограмма", Параметры.БонуснаяПрограмма,,,,РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный);
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаБонусныеПрограммы.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаНачисленияИСписания.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаРучныеСкидки.Видимость = Ложь;
		ВидимостьОкруглений = Ложь;
		Если Параметры.Свойство("ПоказыватьОкругления") И Параметры.ПоказыватьОкругления Тогда
			ВидимостьОкруглений = Истина;
		КонецЕсли;
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаАвтоматическоеОкругление.Видимость = ВидимостьОкруглений;		
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаПравилаНачисления.Видимость = НЕ ВидимостьОкруглений;		
	ИначеЕсли Параметры.Свойство("ОткрытиеБонусов") И Параметры.ОткрытиеБонусов Тогда
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаБонусныеПрограммы;
	ИначеЕсли Параметры.Свойство("ВидДК") И ЗначениеЗаполнено(Параметры.ВидДК) Тогда
		ВидыДКУсловия = Новый Массив();
		ВидыДКУсловия.Добавить(Параметры.ВидДК);
		ВидыДКУсловия.Добавить(Справочники.ВидыДисконтныхКарт.ПустаяСсылка());
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(БонусныеПрограммыИСкидки,
			"ВидДК", ВидыДКУсловия,ВидСравненияКомпоновкиДанных.ВСписке,,,РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный);
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаБонусныеПрограммы.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаНачисленияИСписания.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаАвтоматическоеОкругление.Видимость = Ложь;
		Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаРучныеСкидки.Видимость = Ложь;
	КонецЕсли;
	
	// Установка доступности цен для редактирования.
	РазрешеноРедактированиеЦенДокументов = УправлениеДоступомУНФ.РазрешеноРедактированиеЦенДокументов();
	Если Не РазрешеноРедактированиеЦенДокументов Тогда
		Элементы.ВариантСовместногоПрименения.Видимость = Ложь;
		
		Элементы.НадписьВариантСовместногоПрименения.Заголовок = СтрШаблон(НСтр("ru = 'Совместное применение: %1'"),
			ВариантСовместногоПрименения);
		Элементы.НадписьВариантСовместногоПрименения.Видимость = Истина;
	КонецЕсли;

	// АвтоматическиеСкидки
	ИспользоватьАвтоматическиеСкидкиНаценки = ПолучитьФункциональнуюОпцию("ИспользоватьАвтоматическиеСкидкиНаценки");
	ИспользоватьБонусы = ПолучитьФункциональнуюОпцию("ИспользоватьБонусныеПрограммы");
	ЗаголовокСкидкиИБонусы = "";
	Если ИспользоватьАвтоматическиеСкидкиНаценки И ИспользоватьБонусы Тогда
		ЗаголовокСкидкиИБонусы = НСтр("ru = 'Автоматические скидки и бонусы'");
	ИначеЕсли ИспользоватьАвтоматическиеСкидкиНаценки Тогда
		ЗаголовокСкидкиИБонусы = НСтр("ru = 'Автоматические скидки'");
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(БонусныеПрограммыИСкидки,
			"ЭтоПравилоНачисленияБонусов", Ложь, ВидСравненияКомпоновкиДанных.Равно);		
	ИначеЕсли ИспользоватьАвтоматическиеСкидкиНаценки Тогда
		ЗаголовокСкидкиИБонусы = НСтр("ru = 'Правила начисления бонусов'");
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(БонусныеПрограммыИСкидки,
			"ЭтоПравилоНачисленияБонусов", Истина, ВидСравненияКомпоновкиДанных.Равно);		
	Иначе
		Элементы.ГруппаПравилаНачисления.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ГруппаПравилаНачисления.Заголовок = ЗаголовокСкидкиИБонусы;
	Если ИспользоватьАвтоматическиеСкидкиНаценки ИЛИ ИспользоватьБонусы Тогда
		Вытеснение = ПредопределенноеЗначение("Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Вытеснение");
		Умножение = ПредопределенноеЗначение("Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Умножение");
		
		ВариантСовместногоПримененияСкидок = Константы.ВариантыСовместногоПримененияСкидокНаценок.Получить();
		Если ВариантСовместногоПримененияСкидок.Пустая() Тогда
			Если РазрешеноРедактированиеЦенДокументов Тогда
				ВариантСовместногоПримененияСкидок = Перечисления.ВариантыСовместногоПримененияСкидокНаценок.Сложение;
				УстановитьПривилегированныйРежим(Истина);
				Константы.ВариантыСовместногоПримененияСкидокНаценок.Установить(ВариантСовместногоПримененияСкидок);
				УстановитьПривилегированныйРежим(Ложь);
			Иначе
				Отказ = Истина;
				ОбщегоНазначения.СообщитьПользователю(НСтр(
					"ru = 'Автоматические скидки не настроены. Обратитесь к пользователю с правом редактирования цен в документах.'"));
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ВариантСовместногоПримененияСкидок = Вытеснение
		ИЛИ ВариантСовместногоПримененияСкидок = Умножение Тогда
		УстановитьСортировкуСпискаПоПолюПорядокНаСервере();
	КонецЕсли;
	СформироватьЗаголовокКоманды();
	УстановитьУсловноеОформление();
	// Конец АвтоматическиеСкидки

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Процедура - обработчик команды УстановитьФлагДействует формы.
//
&НаКлиенте
Процедура УстановитьФлагДействует(Команда)
	
	Если ЗначениеЗаполнено(Элементы.БонусныеПрограммыИСкидки.ВыделенныеСтроки) Тогда
		ИзменитьФлагДействуетСервер(Истина, Элементы.БонусныеПрограммыИСкидки.ВыделенныеСтроки);
	КонецЕсли;

КонецПроцедуры

// Процедура - обработчик команды СброситьФлагДействует формы.
//
&НаКлиенте
Процедура СброситьФлагДействует(Команда)
	
	Если ЗначениеЗаполнено(Элементы.БонусныеПрограммыИСкидки.ВыделенныеСтроки) Тогда
		ИзменитьФлагДействуетСервер(Ложь, Элементы.БонусныеПрограммыИСкидки.ВыделенныеСтроки);
	КонецЕсли;
	
КонецПроцедуры

#Область РучныеСкидки
&НаКлиенте
Процедура ВключитьРучныеСкидки(Команда)
	ВключитьРучныеСкидкиНаСервере();
	Элементы.БонусныеПрограммыИСкидки.Обновить();
КонецПроцедуры

&НаСервере
Процедура ВключитьРучныеСкидкиНаСервере()
	
	СтруктураНастройкиСкидки = Справочники.АвтоматическиеСкидки.ВернутьНастройкиРучнойСкидки();
	
	Если СтруктураНастройкиСкидки.СсылкаАвтоматическойСкидки.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Блокировка = Новый БлокировкаДанных();
	ЭлементБлокировки = Блокировка.Добавить("Справочник.АвтоматическиеСкидки");
	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		РучнаяСкидкаОбъект = СтруктураНастройкиСкидки.СсылкаАвтоматическойСкидки.ПолучитьОбъект();
		РучнаяСкидкаОбъект.Действует = НЕ РучнаяСкидкаОбъект.Действует;
		РучнаяСкидкаОбъект.Записать();
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Запись автоматических скидок'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.АвтоматическиеСкидки, , ТекстОшибки);
		СообщениеОшибки = ОбработкаОшибок.СообщениеОбОшибкеДляПользователя(ИнформацияОбОшибке());
		ОбщегоНазначения.СообщитьПользователю(СообщениеОшибки);
	КонецПопытки;
	СформироватьЗаголовокКоманды();
КонецПроцедуры

&НаСервере
Процедура СформироватьЗаголовокКоманды()
	ЗаголовокКомандыШаблон = НСтр("ru = '%1 ручные скидки'");
	НастройкиРучнойСкидки = Справочники.АвтоматическиеСкидки.ВернутьНастройкиРучнойСкидки();
	
	РучнаяСкидкаДействует = НастройкиРучнойСкидки.РучнаяСкидкаДействует;
	
	Если РучнаяСкидкаДействует Тогда
		Элементы.БонусныеПрограммыИСкидкиВключитьРучныеСкидки.Заголовок = СтрШаблон(ЗаголовокКомандыШаблон, НСтр("ru = 'Выключить'"));
		Элементы.БонусныеПрограммыИСкидкиВключитьРучныеСкидки.ЦветФона = ЦветаСтиля.ЦветАктивнойКнопкиРМК;
	Иначе
		Элементы.БонусныеПрограммыИСкидкиВключитьРучныеСкидки.Заголовок = СтрШаблон(ЗаголовокКомандыШаблон, НСтр("ru = 'Включить в расчет'"));
		Элементы.БонусныеПрограммыИСкидкиВключитьРучныеСкидки.ЦветФона = Новый Цвет;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#КонецОбласти

#Область ПроцедурыИФункцииОбщегоНазначения

// В процедуре можно установить или сбросить флаг "Действует".
//
// Параметры:
//  НовоеЗначение  - Булево - Новое значение флага "Действует".
//  МассивВыделенныхСтрок  - Массив - Массив строк, которые выделены в списке автоматических скидок.
//
&НаСервере
Процедура ИзменитьФлагДействуетСервер(НовоеЗначение, Знач МассивВыделенныхСтрок)

	НужноОбновлятьСписок = Ложь;
	Для Каждого СтрокаАвтоСкидок Из МассивВыделенныхСтрок Цикл
		Если СтрокаАвтоСкидок.Действует <> НовоеЗначение Тогда
			Если СтрокаАвтоСкидок.Ссылка.Пустая() Или СтрокаАвтоСкидок.ЭтоГруппа Тогда
				Продолжить;
			КонецЕсли;
			ОбъектАвтоСкидка = СтрокаАвтоСкидок.Ссылка.ПолучитьОбъект();
			ОбъектАвтоСкидка.Действует = НовоеЗначение;
			Попытка
				ОбъектАвтоСкидка.Записать();
				НужноОбновлятьСписок = Истина;
			Исключение
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = СтрШаблон(НСтр(
					"ru = 'Не удалось изменить флажок ""Действует"" для автоматической скидки, наценки ""%1"".'"),
					СтрокаАвтоСкидок.Ссылка);
				Сообщение.Поле = "Действует";
				Сообщение.УстановитьДанные(СтрокаАвтоСкидок.Ссылка);
				Сообщение.Сообщить();
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	Если НужноОбновлятьСписок Тогда
		Элементы.БонусныеПрограммыИСкидки.Обновить();
	КонецЕсли;

КонецПроцедуры // ИзменитьФлагДействуетСервер()
//
// Процедура устанавливает сортировку по полю РеквизитДопУпорядочивания.
//
&НаСервере
Процедура УстановитьСортировкуСпискаПоПолюПорядокНаСервере()
	
	СписокРеквизит = БонусныеПрограммыИСкидки;
	
	ПользовательскиеНастройкиПорядка = Неопределено;
	Для Каждого Элемент Из СписокРеквизит.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы Цикл
		Если ТипЗнч(Элемент) = Тип("ПорядокКомпоновкиДанных") Тогда
			ПользовательскиеНастройкиПорядка = Элемент;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.Проверить(ПользовательскиеНастройкиПорядка <> Неопределено, НСтр(
		"ru = 'Пользовательская настройка порядка не найдена.'"));
	
	ПользовательскиеНастройкиПорядка.Элементы.Очистить();
	Элемент = ПользовательскиеНастройкиПорядка.Элементы.Добавить(Тип("ЭлементПорядкаКомпоновкиДанных"));
	Элемент.Использование = Истина;
	Элемент.Поле = Новый ПолеКомпоновкиДанных("РеквизитДопУпорядочивания");
	Элемент.ТипУпорядочивания = НаправлениеСортировкиКомпоновкиДанных.Возр;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	// 1. Скидки при возврате (возврат с дисконтом) выделяются красным цветом
	НовоеУсловноеОформление = БонусныеПрограммыИСкидки.КомпоновщикНастроек.ФиксированныеНастройки.УсловноеОформление.Элементы.Добавить();
	
	Оформление = НовоеУсловноеОформление.Оформление.Элементы.Найти("ЦветТекста");
	Оформление.Значение 		= ЦветаСтиля.КрасныйТекстСтрок;
	Оформление.Использование 	= Истина;
	
	Отбор = НовоеУсловноеОформление.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ВидСравнения 		= ВидСравненияКомпоновкиДанных.Равно;
	Отбор.Использование 	= Истина;
	Отбор.ЛевоеЗначение 	= Новый ПолеКомпоновкиДанных("ИспользоватьПриВозврате");
	Отбор.ПравоеЗначение 	= Истина;
		
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицФормы

&НаКлиенте
Процедура ПравилаНачисленияБонусовПриИзменении(Элемент)
	
	Элемент.Обновить();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьГруппуПравилНачисления(Команда)
	
	ПараметрыДляФормыГруппы = Новый Структура("ЭтоГруппа, ЭтоПравилоНачисленияБонусов", Истина, Истина);
	ОткрытьФорму("Справочник.АвтоматическиеСкидки.ФормаГруппы", ПараметрыДляФормыГруппы,,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

// Процедура - обработчик события ПриИзменении элемента ВариантСовместногоПримененияСкидок.
//
&НаКлиенте
Процедура ВариантСовместногоПримененияБонусовПриИзменении(Элемент)
	
	ВариантСовместногоПримененияБонусовПриИзмененииНаСервере(ВариантСовместногоПрименения);
	Если ВариантСовместногоПрименения = ПредопределенноеЗначение("Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Вытеснение")
		ИЛИ ВариантСовместногоПрименения = ПредопределенноеЗначение("Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Умножение") Тогда
		ПроверитьСортировкуСписка();
	КонецЕсли;
	Элементы.БонусныеПрограммыИСкидки.Обновить();
	
КонецПроцедуры

