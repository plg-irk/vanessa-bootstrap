#Область ОписаниеПеременных

&НаКлиенте
Перем ЭлектронныеВесыЗаняты;

&НаКлиенте
Перем ПоступилоСобытиеВзвешивания;

&НаКлиенте
Перем ПоказанаОшибкаНулевогоВеса;

&НаКлиенте
Перем СчетчикВыводаОшибок;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	РежимыФормыПодтверждения = ИнтерфейсРМКСлужебныйКлиентСервер.РежимыФормыПодтвержденияДобавленияТоваров();
	ОбработатьВходныеПараметры();
	ЦветаФормы = ОбщегоНазначенияРМК.ЦветаФормыРМК();
	НастроитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.ДекорацияВертикальныйОтступ.Видимость = Истина;
	СчетчикВыводаОшибок = 0;
	ЭлектронныеВесыЗаняты = Ложь;
	ПоступилоСобытиеВзвешивания = Ложь;
	ПоказанаОшибкаНулевогоВеса = Ложь;
	Если Не ДляОбучения И РежимФормы = РежимыФормыПодтверждения.ПодтверждениеВеса Тогда
		ЗапуститьПериодическийОпросВеса();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ДляОбучения Тогда
		Возврат;
	КонецЕсли;
	
	Если Источник = "ПодключаемоеОборудование" И ЭтоПолучениеСтабильногоВеса(ИмяСобытия, Параметр) Тогда
		
		ПоступилоСобытиеВзвешивания = Истина;
		ОбработатьПолучениеВесаОтЭлектронныхВесов(Параметр.Вес);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТекущееКоличествоПриИзменении(Элемент)
	
	Если Не РежимФормы = РежимыФормыПодтверждения.ПодтверждениеВеса
			И ПоказанаОшибкаНулевогоВеса И Не ТекущееКоличество = 0 Тогда
		СкрытьОшибкуНулевогоВеса();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбновитьВес(Команда)
	
	ЗапроситьВесОднократно();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьТовар(Команда)
	
	ДобавлениеПодтверждено = Истина;
	Если ДляОбучения Тогда
		ОбработатьПодтверждениеДобавления();
	Иначе
		Если РежимФормы = РежимыФормыПодтверждения.ПодтверждениеВеса Тогда
			ЗапроситьВесОднократно();
		ИначеЕсли ТекущееКоличество = 0 Тогда
			ТекстОшибки = ?(РежимФормы = РежимыФормыПодтверждения.РучнойВводВеса,
				НСтр("ru='Укажите вес.'"),
				НСтр("ru='Укажите количество.'"));
			ПоказатьОшибкуНулевогоВеса(ТекстОшибки);
		Иначе
			ОбработатьПодтверждениеДобавления();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УвеличитьКоличество(Команда)
	УвеличитьКоличествоКлиент();
КонецПроцедуры

&НаКлиенте
Процедура УменьшитьКоличество(Команда)
	УменьшитьКоличествоКлиент();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДробноеКоличество(Команда)
	
	Если ЗначениеЗаполнено(ВеличинаДробногоКоличества) Тогда
		ТекущееКоличество = ВеличинаДробногоКоличества;
		СкрытьОшибкуНулевогоВеса();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ЗакрытьУниверсальнаяКлавиатура(Команда)
	
	ЗакрытьФормуЦифровойПанели();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ЦифраУниверсальнаяКлавиатура(Команда)
	ОбработатьЦифруЦифровойКлавиатуры(Команда.Имя);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ДваНуляУниверсальнаяКлавиатура(Команда)
	ОбработатьКомандуДваНуляЦифровойКлавиатуры();
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ЗапятаяУниверсальнаяКлавиатура(Команда)
	ОбработатьКомандуЦифровойКлавиатурыЗвездочкаЗапятая();
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОчиститьУниверсальнаяКлавиатура(Команда)
	ОбработатьКомандуЦифровойКлавиатурыОчистить();
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УдалитьПоследнееУниверсальнаяКлавиатура(Команда)
	ОбработатьКомандуЦифровойКлавиатурыУдалитьПоследнее();
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПоискУниверсальнаяКлавиатура(Команда)
	
	ТекущийЭлемент = Элементы.ТекущееКоличество;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьПодтверждениеДобавления()
	
	Ответ = Новый Структура("КоличествоТовара", ТекущееКоличество);
	Закрыть(Ответ);
	
КонецПроцедуры

&НаКлиенте
Функция ЭтоПолучениеСтабильногоВеса(ИмяСобытия, Параметр)
	Возврат (ИмяСобытия = "Weighting" И Параметр.Вес > 0 И Параметр.Стабилизация = Истина);
КонецФункции

&НаКлиенте
Процедура ОбработатьПолучениеВесаОтЭлектронныхВесов(ВесТовара)
	
	Если КоэффициентПереводаВКилограммы <> 0 Тогда
		ТекущееКоличество = ВесТовара * КоэффициентПереводаВКилограммы;
	Иначе
		ТекущееКоличество = ВесТовара;
	КонецЕсли;
	Если ТекущееКоличество > 0 И ПоказанаОшибкаНулевогоВеса Тогда
		СкрытьОшибкуНулевогоВеса();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьВходныеПараметры()
	
	Если Параметры.Свойство("ЭтоФормаобучения") Тогда
		ДляОбучения = Параметры.ЭтоФормаобучения;
	ИначеЕсли Параметры.Свойство("РежимФормы") Тогда
		РежимФормы = Параметры.РежимФормы;
	КонецЕсли;
	Если Параметры.Свойство("КоэффициентПереводаВКилограммы") Тогда
		КоэффициентПереводаВКилограммы = Параметры.КоэффициентПереводаВКилограммы;
	КонецЕсли;
	Если Параметры.Свойство("Масштаб") Тогда
		Масштаб = Параметры.Масштаб;
	КонецЕсли;
	Если Параметры.Свойство("СкрытьЦифровуюКлавиатуру") Тогда
		СкрытьЦифровуюКлавиатуру = Параметры.СкрытьЦифровуюКлавиатуру;
	КонецЕсли;
	НаименованиеПозиции = Параметры.НаименованиеПозиции;
	ИдентификаторФормыВладельца = Параметры.ИдентификаторФормыВладельца;
	Если (Не ДляОбучения) И (Не Параметры.ТекущиеЭлектронныеВесы = Неопределено) Тогда
		ЭлектронныеВесы = Параметры.ТекущиеЭлектронныеВесы;
	КонецЕсли;
	ИзображениеТовара = Параметры.АдресИзображения;
	Если РежимФормы = РежимыФормыПодтверждения.ВводДробногоКоличества Тогда
		Если Параметры.Свойство("ВеличинаДробногоКоличества") Тогда
			ВеличинаДробногоКоличества = Параметры.ВеличинаДробногоКоличества;
		КонецЕсли;
		Если Параметры.Свойство("ШагДробногоКоличества") Тогда
			ШагДробногоКоличества = Параметры.ШагДробногоКоличества;
		КонецЕсли;
		ТекущееКоличество = 1;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьВесОднократно()
	
	Если Не ЭлектронныеВесыЗаняты Тогда
		ПараметрыВзвешивания = Новый Структура();
		ПараметрыВзвешивания.Вставить("ВключитьОбработчикОжидания", ПоказанаОшибкаНулевогоВеса И Не ДобавлениеПодтверждено);
		ЗапроситьВес(ПараметрыВзвешивания);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьВес(ПараметрыВзвешивания)
	
	ЭлектронныеВесыЗаняты = Истина;
	ПараметрыОперации = Новый Структура();
	
	ИдентификаторВесов = Неопределено;
	Если ЗначениеЗаполнено(ЭлектронныеВесы) Тогда
		ИдентификаторВесов = ЭлектронныеВесы;
	КонецЕсли;
	
	ОповещениеЗавершенияВзвешивания = Новый ОписаниеОповещения("ПолучитьВесСЭлектронныхВесовЗавершение",
		ЭтотОбъект, ПараметрыВзвешивания);
		
	МенеджерОборудованияРМККлиент.НачатьПолученияВесаСЭлектронныхВесов(ОповещениеЗавершенияВзвешивания,
		ИдентификаторФормыВладельца, ИдентификаторВесов, ПараметрыОперации);
	
КонецПроцедуры
	
&НаКлиенте
Процедура ЗапуститьПериодическийОпросВеса()
	
	Если ЭлектронныеВесыЗаняты Тогда
		
		ЭтотОбъект.ПодключитьОбработчикОжидания("ЗапуститьПериодическийОпросВеса", 1, Истина);
		
	Иначе
		
		ПараметрыВзвешивания = Новый Структура();
		ПараметрыВзвешивания.Вставить("ВключитьОбработчикОжидания", Истина);
		ЗапроситьВес(ПараметрыВзвешивания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьВесСЭлектронныхВесовЗавершение(Результат, ПараметрыВзвешивания) Экспорт
	
	ЭлектронныеВесыЗаняты = Ложь;
	Если ОбщегоНазначенияРМККлиентСервер.ЕстьСвойство(Результат, "Результат") И Результат.Результат Тогда
		
		Если Не ЗначениеЗаполнено(ЭлектронныеВесы) Тогда
			ЭлектронныеВесы = Результат.ИдентификаторУстройства;
		КонецЕсли;
		ОбработатьПолучениеВесаОтЭлектронныхВесов(Результат.Вес);
		Если (Не ДобавлениеПодтверждено) И (Не ПоступилоСобытиеВзвешивания)
				И ПараметрыВзвешивания.ВключитьОбработчикОжидания Тогда
			ЭтотОбъект.ПодключитьОбработчикОжидания("ЗапуститьПериодическийОпросВеса", 1, Истина);
		КонецЕсли;
		
	Иначе
		
		ТекущееКоличество = 0;
		
	КонецЕсли;
	Если ДобавлениеПодтверждено Тогда
		Если ТекущееКоличество = 0 Тогда
			СчетчикВыводаОшибок = 0;
			ПодсветитьОшибкуНулевогоВеса();
			ДобавлениеПодтверждено = Ложь;
		Иначе
			ОбработатьПодтверждениеДобавления();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОшибкуНулевогоВеса(ТекстСообщения = "")
	
	Если ТекстСообщения = "" Тогда
		ТекстСообщения = НСтр("ru='Не указан вес. Положите товары на весы.'");
	КонецЕсли;
	Элементы.ДекорацияВертикальныйОтступ.Заголовок = ТекстСообщения;
	Элементы.ТекущееКоличество.ЦветРамки = ЦветаФормы.ОсобыйТекст;
	Элементы.ИзображениеТовара.ЦветРамки = WebЦвета.Красный;
	ПоказанаОшибкаНулевогоВеса = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьОшибкуНулевогоВеса()
	
	Элементы.ДекорацияВертикальныйОтступ.Заголовок = " ";
	Элементы.ТекущееКоличество.ЦветРамки = ЦветаФормы.Авто;
	Элементы.ИзображениеТовара.ЦветРамки = ЦветаФормы.Авто;
	ПоказанаОшибкаНулевогоВеса = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодсветитьОшибкуНулевогоВеса()
	
	КоличествоИтерацийПоказа = 7;
	СчетчикВыводаОшибок = СчетчикВыводаОшибок + 1;
	Если ПоказанаОшибкаНулевогоВеса Тогда
		СкрытьОшибкуНулевогоВеса();
	ИначеЕсли ТекущееКоличество = 0 Тогда
		ПоказатьОшибкуНулевогоВеса();
	КонецЕсли;
	
	Если ТекущееКоличество > 0 Или (ПоказанаОшибкаНулевогоВеса И СчетчикВыводаОшибок > КоличествоИтерацийПоказа) Тогда
		ЭтотОбъект.ПодключитьОбработчикОжидания("ЗапуститьПериодическийОпросВеса", 1, Истина);
	Иначе
		ЭтотОбъект.ПодключитьОбработчикОжидания("ПодсветитьОшибкуНулевогоВеса", 0.3, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьЭлементыФормы()
	
	ПоказатьЦиферблат = Ложь;
	Если ДляОбучения Тогда
		Элементы.ГруппаВес.Видимость = Ложь;
	Иначе
		Если РежимФормы = РежимыФормыПодтверждения.ВводДробногоКоличества Тогда
			Элементы.ДекорацияВес.Заголовок = НСтр("ru = 'Количество:'");
			Элементы.УменьшитьКоличество.Видимость = Истина;
			Элементы.ГруппаУвеличенияУстановкиДробногоКоличества.Видимость = Истина;
			Если ЗначениеЗаполнено(ВеличинаДробногоКоличества) Тогда
				Элементы.УстановитьДробноеКоличество.Заголовок = Параметры.ЗаголовокКнопки;
				Если Параметры.ШиринаКнопки > Элементы.УстановитьДробноеКоличество.Ширина Тогда
					Элементы.УстановитьДробноеКоличество.Ширина = Параметры.ШиринаКнопки;
				КонецЕсли;
				Элементы.УстановитьДробноеКоличество.Видимость = Истина;
			КонецЕсли;
			ПоказатьЦиферблат = Истина;
			Если СкрытьЦифровуюКлавиатуру Тогда
				Элементы.ГруппаДанныеИУправление.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
			КонецЕсли;
		ИначеЕсли РежимФормы = РежимыФормыПодтверждения.РучнойВводВеса Тогда
			ПоказатьЦиферблат = Истина;
		Иначе
			Элементы.ТекущееКоличество.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
			Элементы.ТекущееКоличество.ТолькоПросмотр = Истина;
			Элементы.ОбновитьВес.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;
	Если ПоказатьЦиферблат И Не СкрытьЦифровуюКлавиатуру Тогда
		ПостроитьЦифровуюКлавиатуру();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПостроитьЦифровуюКлавиатуру()
	
	ПараметрыПостроения = Новый Структура();
	ПараметрыПостроения.Вставить("ИнтервалМеждуКлавишамиВертикальный", ИнтервалМеждуЭлементамиФормы.Половинный);
	ТекстОшибки = ИнтерфейсРМКСлужебный.ПостроитьПанельЦифровойКлавиатуры(ЭтотОбъект,
		Элементы.ГруппаЦифроваяПанель, ПараметрыПостроения);
	Если ТекстОшибки = "" Тогда
		УниверсальнаяКлавиатураСоздана = Истина;
		Элементы.ПоискУниверсальнаяКлавиатура.Видимость = Ложь;
		Элементы.ЦифроваяПанельУниверсальнаяКлавиатура.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
		Элементы.ИзображениеТовара.РастягиватьПоВертикали = Истина;
		Элементы.ИзображениеТовара.Ширина = 40;
	Иначе
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УвеличитьКоличествоКлиент()
	
	Если ТекущееКоличество < 1 И ЗначениеЗаполнено(ШагДробногоКоличества) Тогда
		ТекущееКоличество = ТекущееКоличество + ШагДробногоКоличества;
	Иначе
		ТекущееКоличество = ТекущееКоличество + 1;
	КонецЕсли;
	Если ТекущееКоличество > 1 И ТекущееКоличество > Цел(ТекущееКоличество) Тогда
		ТекущееКоличество = Цел(ТекущееКоличество);
	КонецЕсли;
	СкрытьОшибкуНулевогоВеса();
	
КонецПроцедуры

&НаКлиенте
Процедура УменьшитьКоличествоКлиент()
	
	Дельта = 1;
	Если ЗначениеЗаполнено(ШагДробногоКоличества) И ТекущееКоличество <= 1 Тогда
		Дельта = ШагДробногоКоличества;
	КонецЕсли;
	Если ТекущееКоличество > Дельта Тогда
		Если Дельта  = 1 И ТекущееКоличество > Цел(ТекущееКоличество) Тогда
			ТекущееКоличество = Цел(ТекущееКоличество);
		Иначе
			ТекущееКоличество = ТекущееКоличество - Дельта;
		КонецЕсли;
		СкрытьОшибкуНулевогоВеса();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФормуЦифровойПанели()
	
	Элементы.ГруппаЦифроваяПанель.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеревестиКурсорНаВводДробнойЧасти()
	
	ЭлементВводаСуммы = Элементы.ТекущееКоличество;
	ИмяЭлемента = ЭлементВводаСуммы.Имя;
	НачалоВыделения = 0;
	НачалоСтроки = 0;
	КонецВыделения = 0;
	КонецСтроки = 0;
	ЭлементВВодаСуммы.ПолучитьГраницыВыделения(НачалоСтроки, НачалоВыделения, КонецСтроки, КонецВыделения);
	СимволРазделителя = ИнтерфейсРМКСлужебныйКлиентСервер.РазделительДробнойЧасти();
	ПозицияРазделителя = СтрНайти(ЭлементВВодаСуммы.ТекстРедактирования, СимволРазделителя);
	ТекущийЭлемент = ЭлементВводаСуммы;
	Если ПозицияРазделителя > 0 И ПозицияРазделителя >= НачалоВыделения Тогда
		НоваяПозицияКурсора = ПозицияРазделителя + 1;
		ЭлементВВодаСуммы.УстановитьГраницыВыделения(НоваяПозицияКурсора, НоваяПозицияКурсора);
	Иначе
		ЭлементВВодаСуммы.УстановитьГраницыВыделения(НачалоВыделения, КонецВыделения);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЦифруЦифровойКлавиатуры(ИмяКомандыКлавиатуры)

	СимволКлавиатуры = ИнтерфейсРМКСлужебныйКлиент.ПолучитьСимволКоманды(ИмяКомандыКлавиатуры);
	ИнтерфейсРМКСлужебныйКлиент.ВставитьСимволыВРедактируемоеПоле(ЭтотОбъект, Элементы.ТекущееКоличество,
		СимволКлавиатуры);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуДваНуляЦифровойКлавиатуры()
	
	Если ТекущееКоличество = 0 Тогда
		ТекущийЭлемент = Элементы.ТекущееКоличество;
	Иначе
		СимволыКлавиатуры = ИнтерфейсРМКСлужебныйКлиент.ПолучитьТекстКнопкиДваНуля();
		ИнтерфейсРМКСлужебныйКлиент.ВставитьСимволыВРедактируемоеПоле(ЭтотОбъект, Элементы.ТекущееКоличество,
			СимволыКлавиатуры);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуЦифровойКлавиатурыЗвездочкаЗапятая()
	
	ПеревестиКурсорНаВводДробнойЧасти();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуЦифровойКлавиатурыОчистить()
	ИнтерфейсРМКСлужебныйКлиент.ОчиститьТекстРедактированияВПолеФормы(ЭтотОбъект, Элементы.ТекущееКоличество);
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуЦифровойКлавиатурыУдалитьПоследнее()
	ИнтерфейсРМКСлужебныйКлиент.УдалитьСимволыВРедактируемомПоле(ЭтотОбъект, Элементы.ТекущееКоличество, Символы.НПП);
КонецПроцедуры

