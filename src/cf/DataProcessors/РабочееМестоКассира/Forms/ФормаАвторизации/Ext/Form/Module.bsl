
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЭтоПолноправныйПользователь = Пользователи.ЭтоПолноправныйПользователь();
	ПараметрыОткрытияФормы = Неопределено;
	ПользовательПоУмолчанию = Пользователи.ТекущийПользователь();
	НастроитьФормуПоВходнымПараметрам();
	Если РежимВхода Или РежимСмены Тогда
		НастроитьДоступностьСозданияКодаДоступа();
	КонецЕсли;
	НастроитьТиповыеГорячиеКлавиши();
	ОбщегоНазначенияРМК.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	НастроитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Не ПараметрыОткрытияФормы = Неопределено Тогда
		Оповещение = Новый ОписаниеОповещения("ЗакрытьПриложениеПриОшибке", ЭтотОбъект);
		ПоказатьПредупреждение(Оповещение,
			ПараметрыОткрытияФормы.ТекстСообщения, ,
			ПараметрыОткрытияФормы.ТекстЗаголовка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если Источник = "ПодключаемоеОборудование" Тогда
		Если ИмяСобытия = "ScanData" Тогда
			
			Штрихкод = ?(Параметр[1] = Неопределено, Параметр[0], Параметр[1][1]);
			ВыполнитьПоискПоШтрихкоду(Штрихкод);
			
		ИначеЕсли ИмяСобытия = "ScanDataBase64" Тогда
			
			Штрихкод = "";
			ШтрихкодBase64 = ?(Параметр[1] = Неопределено, Параметр[0], Параметр[1][1]);
			МенеджерОборудованияРМККлиентСервер.Base64ВШтрихкод(ШтрихкодBase64, Штрихкод);
			ВыполнитьПоискПоШтрихкоду(Штрихкод);
			
		ИначеЕсли ИмяСобытия = "TracksData" Тогда
			
			ВыполнитьПоискПоШтрихкоду(Параметр[0]);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)
	
	Если ОбщегоНазначенияРМККлиент.ИспользоватьВнешнееСобытие() И ВводДоступен() Тогда
		
		ОбрабатываемыеСобытия = Новый Массив;
		ОбрабатываемыеСобытия.Добавить("Штрихкод");
		ОбрабатываемыеСобытия.Добавить("ПолученШтрихкод");
		ОбрабатываемыеСобытия.Добавить("ScanData");
		ОбрабатываемыеСобытия.Добавить("TracksData");
		ОбрабатываемыеСобытия.Добавить("ДанныеКарты");
		
		Если Не ОбрабатываемыеСобытия.Найти(Событие) = Неопределено Тогда
			ВыполнитьПоискПоШтрихкоду(Данные);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТорговыйОбъектДляВходаПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(ТорговыйОбъектДляВхода) Тогда
		ТекущийЭлемент = Элементы.КассирДляВхода;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КассирДляВходаОткрытие(Элемент, СтандартнаяОбработка)
	
	ЕстьПравоПросмотра = Ложь;
	ПроверитьДоступностьПросмотраСотрудников(ЕстьПравоПросмотра);
	СтандартнаяОбработка = ЕстьПравоПросмотра;
	
КонецПроцедуры

&НаКлиенте
Процедура КассирДляВходаПриИзменении(Элемент)
	
	КассирПриИзмененииКлиент();
	
КонецПроцедуры

&НаКлиенте
Процедура КассирДляВходаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СобытиеПереопределено = Ложь;
	СтандартнаяОбработка = Ложь;
	ОбщегоНазначенияРМККлиентПереопределяемый.ОткрытьФормуВыбораКассира(ЭтотОбъект, СобытиеПереопределено);
	Если СобытиеПереопределено Тогда
		Возврат;
	КонецЕсли;
		
	ОбработкаОповещения = Новый ОписаниеОповещения("ВыборКассираЗавершение", ЭтотОбъект);
	ПараметрыОткрытияФормы = Новый Структура("НастроитьКассировДляВхода", НастроитьКассировДляВхода);
	ПараметрыОткрытияФормы.Вставить("РежимКассыСамообслуживания", РежимКассыСамообслуживания);
	ОткрытьФорму("Обработка.РабочееМестоКассира.Форма.ФормаВыбораПерсонала", ПараметрыОткрытияФормы, ЭтотОбъект,,,,
		ОбработкаОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ТорговыйОбъектДляВходаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	ОбщегоНазначенияРМККлиентПереопределяемый.ОткрытьФормуВыбораТорговогоОбъекта(ЭтотОбъект, СтандартнаяОбработка);
	Если Не СтандартнаяОбработка Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

