	ЭлементВыбор = Элементы.ИдентификаторКорзиныНСПК;
	ЭлементВыбор.СписокВыбора.Очистить(); 
	ЭлементВыбор.ПодсказкаВвода = Нстр("ru='Идентификатор корзины'");
	
