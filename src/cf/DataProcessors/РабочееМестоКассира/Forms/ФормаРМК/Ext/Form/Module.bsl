&НаКлиенте
Процедура ОбработатьРезультатПолученияСпискаСкидокПоВидуОплаты(РезультатВыполнения, ДополнительныеПараметры) Экспорт
	
	Если РезультатВыполнения.Свойство("ЕстьОшибки")
		И НЕ РезультатВыполнения.ЕстьОшибки Тогда
		СтрокаJSON = РезультатВыполнения.ДанныеОтвета;
		ДанныеОтвета = Неопределено;
		Если СтрокаJSON <> Неопределено Тогда
			СерверЛояльностиПолучательДанныхКлиентСервер.ОбработатьJSON(СтрокаJSON, ДанныеОтвета);
			Если ДанныеОтвета <> Неопределено И ТипЗнч(ДанныеОтвета) = Тип("Массив") Тогда
				Для Каждого СтрокаМассива Из ДанныеОтвета Цикл
					СтрокаСкидки = ТаблицаСкидокЗависяшихОтВидаОплаты.Добавить();
					СтрокаСкидки.СкидкаНаценка = СтрокаМассива.DiscountID;
					Если НЕ ЗначениеЗаполнено(СтрокаСкидки.СкидкаНаценка) Тогда
						ЗаполнитьЗначениеСкидкиНаценки(СтрокаСкидки.СкидкаНаценка, СтрокаМассива);
					КонецЕсли;
					ЗаполнитьВидОплаты(СтрокаСкидки.ВидОплаты, СтрокаМассива.PayType);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	ОбновитьДаннныеЗапретовПродажФоновое();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДаннныеЗапретовПродажФоновое()
	
	Если Не ИспользоватьКонтрольПродаж Тогда
		Возврат;
	КонецЕсли;
	
	ЗначенияПараметровМетода = СерверЛояльностиПолучательДанныхКлиентСервер.ПараметрыМетодовБонуснойПодсистемы();
	Если ЗначениеЗаполнено(Объект.ТорговыйОбъект) Тогда
		ЗначенияПараметровМетода.Вставить("Store", Строка(Объект.ТорговыйОбъект.УникальныйИдентификатор()));
	КонецЕсли;
	
	ПараметрыЗапуска = Новый Структура;
	ПараметрыЗапуска.Вставить("ПараметрыПодключенияКСерверуЛояльности", ПараметрыПодключенияКСерверуЛояльности);
	ПараметрыЗапуска.Вставить("ЗначенияПараметровМетода", ЗначенияПараметровМетода);
	
	ИмяСтраницыПередОжиданием = НСтр("ru = ''");
	УстановитьСтраницуОжидания(Элементы.Страницы.ТекущаяСтраница.Имя, ИмяСтраницыПередОжиданием);
	Элементы.ЗаголовокОжидания.Заголовок = НСтр("ru = 'Выполняется обновление данных контроля продаж'");
	НастроитьИнтерфейсУправленияЧеком(Элементы.СтраницаОжидание, Ложь);
		
	СтруктураПараметровВыполнения = Новый Структура;
	СтруктураПараметровВыполнения.Вставить("ВыполняемыйМетод", "ОбщегоНазначенияРМК.ПолучитьДанныеЗапретовРедактирования");
	СтруктураПараметровВыполнения.Вставить("НаименованиеФоновогоЗадания", НСтр("ru = 'Выполняется обновление данных контроля продаж.'"));
	СтруктураФоновогоЗадания				= ЗаполнитьСтруктуруФоновогоЗадания(ПараметрыЗапуска, СтруктураПараметровВыполнения);
	
	ДополнительныеПараметры = Новый Структура("ИмяОтложенногоМетода, ИмяСтраницыПередОжиданием", "ОбработатьРезультатПолученияКонтроляПродаж", ИмяСтраницыПередОжиданием);
	ПараметрыОжидания 	= ЗаполнитьПараметрыОжидания();
	ДлительныеОперацииКлиент.ОжидатьЗавершение(СтруктураФоновогоЗадания, Новый ОписаниеОповещения("ОбработатьДанныеССервераЛояльности", ЭтотОбъект, ДополнительныеПараметры), ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатПолученияКонтроляПродаж(РезультатВыполнения, ДополнительныеПараметры) Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("ПризнакУспешноОбновлен", Ложь);
	Результат.Вставить("КомментарийКОбновлениюПризнака", НСтр("ru = ''"));
	Результат.Вставить("ЗапретыПродажУспешноЗагружены", Ложь);
	Результат.Вставить("КомментарийОбновленияЗапретов", НСтр("ru = ''"));
	
	
	Если Не РезультатВыполнения.ЕстьОшибки Тогда
		
		ДанныеОтвета = Неопределено;
		СтрокаJSON = РезультатВыполнения.ДанныеОтвета;
		СерверЛояльностиПолучательДанныхКлиентСервер.ОбработатьJSON(СтрокаJSON, ДанныеОтвета);
		
		РезультатОбработки = ОбщегоНазначенияРМКВызовСервера.ОбработатьДанныеЗапретовИзОтвета(ДанныеОтвета, ТекущаяНастройкаРМК, Объект.ТорговыйОбъект);
		ЗаполнитьЗначенияСвойств(Результат, РезультатОбработки);
		
	КонецЕсли;
	
		
	Если НЕ Результат.ПризнакУспешноОбновлен Тогда
			
		ПричинаНевозможностиОбновленияПризнака = НСтр("ru = 'Признак разрешения редактирования не обновлен по причине:'");
		СостояниеОбновленияЗапретовПродаж = СтрШаблон("%1 %2%3",
			ПричинаНевозможностиОбновленияПризнака, Результат.КомментарийКОбновлениюПризнака, Символы.ПС);
			
	КонецЕсли;
		
	Если НЕ Результат.ЗапретыПродажУспешноЗагружены Тогда
			
		ПричинаНевозможностиОбновленияЗапретовПродаж = НСтр("ru = 'Не удалось обновить запреты продаж по причине:'");
		ПричинаНевозможностиОбновленияЗапретовПродажРасширенная = СтрШаблон("%1%2",
			ПричинаНевозможностиОбновленияЗапретовПродаж, Результат.КомментарийОбновленияЗапретов);
		СостояниеОбновленияЗапретовПродаж = СтрШаблон("%1%2%3",
			СостояниеОбновленияЗапретовПродаж, ПричинаНевозможностиОбновленияЗапретовПродажРасширенная, Символы.ПС);
			
	КонецЕсли;

	
	Если НЕ ПустаяСтрока(СостояниеОбновленияЗапретовПродаж) Тогда
		КомментарийКЗаписи = НСтр("ru = 'Данные о запретах продаж не были обновлены.'",
			ОбщегоНазначенияКлиент.КодОсновногоЯзыка());
		
		ИмяСобытия = НСтр("ru = 'Обновление данных запретов о продажах'",
			ОбщегоНазначенияКлиент.КодОсновногоЯзыка());
			
		ОбщегоНазначенияРМКВызовСервера.ЗафиксироватьОшибкуВЖурналеРегистрации(ИмяСобытия, КомментарийКЗаписи);
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтраницуПередОжиданием(ИмяСтраницыПередОжиданием)
	Элементы.ЗаголовокОжидания.Заголовок = НСтр("ru = ''");
	Если ПустаяСтрока(ИмяСтраницыПередОжиданием) Тогда
		Возврат;
	КонецЕсли;
	НастроитьИнтерфейсУправленияЧеком(Элементы[ИмяСтраницыПередОжиданием], Истина);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьГлобальныеНастройкиСервераЛояльности(ЗначениеНастройка)
	ИспользоватьНовыйАлгоритмЗапросаСЛ = ЗначениеНастройка;
	ИспользоватьЗапросПродажСЛ = ЗначениеНастройка;
	ИспользоватьВидКартыСЛ = ЗначениеНастройка;
	ИспользоватьАвтоматическиеСкидкиПриПродажеПоЗаказу = ЗначениеНастройка;
	ИспользоватьАлгоритмПоискаПоГУИД = ЗначениеНастройка;
	ИспользоватьАвтоматическиеСкидкиПриВозврате = ЗначениеНастройка;
	ДальнейшийРасчетДоступен = ЗначениеНастройка;
	ИспользоватьКоличествоУпаковок = ЗначениеНастройка;
	ТипЗапросаПодарочныеСертификаты = "POST";
	ИспользоватьНовыйМетодСЛ = ЗначениеНастройка;
	ЗаполнитьСписокНастроекСервераЛояльности(ЗначениеНастройка);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСписокНастроекСервераЛояльности(ЗначениеНастройка)
	СписокНастроекСервераЛояльности.Очистить();
	Если ЗначениеНастройка Тогда
		СписокНастроекСервераЛояльности.Добавить("РазрешитьЗаменуДисконтнойКарты");
		СписокНастроекСервераЛояльности.Добавить("ДоступноНачислениеБонусов");
		СписокНастроекСервераЛояльности.Добавить("ДоступноНачислениеСертификатов");
		СписокНастроекСервераЛояльности.Добавить("ИспользоватьНовыеМетоды_3_0_11");
		СписокНастроекСервераЛояльности.Добавить("ДоступенПоискПоФИО");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НачислитьБонусныеБаллыСерверЛояльности()
	
	Если ИспользоватьСерверЛояльностиПолучательДанных
		И СписокНастроекСервераЛояльности.НайтиПоЗначению("ДоступноНачислениеБонусов") <> Неопределено Тогда
		СуммаНачисления = ТаблицаБонусныеБаллы.Итог("КоличествоБонусныхБаллов");
		Если СуммаНачисления > 0 Тогда
			
			ЗначенияПараметровМетода = ПараметрыМетодовБонуснойПодсистемы();
			ЗначенияПараметровМетода.Вставить("BonusesCount", Строка(СуммаНачисления));
			
			ПараметрыВыполненияЗапроса = СерверЛояльностиПолучательДанныхКлиентСервер.ПараметрыЗапросаНачислитьБонусыКлиента(ПараметрыПодключенияКСерверуЛояльности,
					ЗначенияПараметровМетода);
			Результат = СерверЛояльностиПолучательДанныхКлиентСервер.ВыполнитьЗапросКСерверуЛояльности(ПараметрыВыполненияЗапроса);
			
			ОшибкаНачисления = Ложь;
			СтрокаОтвета = Результат.ДанныеОтвета;
			ДанныеОтвета = Неопределено;
			СерверЛояльностиПолучательДанныхКлиентСервер.ОбработатьJSON(СтрокаОтвета, ДанныеОтвета);
			Если НЕ ДанныеОтвета = Неопределено Тогда
				ОшибкаНачисления = ДанныеОтвета.Error;
				СообщениеОбОшибке = ДанныеОтвета.ErrorMessage;
			КонецЕсли;
			
			Если ОшибкаНачисления Тогда
				ТекстЗаголовка = НСтр("ru = 'Ошибка начисления бонусов.'");
				ОткрытьСтраницуИнфоОшибка(ТекстЗаголовка, СообщениеОбОшибке);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтраницуОжидания(ИмяСтраницы, ИмяСтраницыПередОжиданием)
	Если НЕ ИмяСтраницы = Элементы.СтраницаОжидание.Имя Тогда
		ИмяСтраницыПередОжиданием = ИмяСтраницы;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область ПервоначальныеДанныеЛокально
&НаСервере
Процедура ЗаполнитьПервоначальныеДанныеЛокально()
	Если ИспользоватьСерверЛояльностиПолучательДанных Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьТаблицуУправляемыхСкидок();
	ЗаполнитьТаблицуВидовКарт();
	ЗаполнитьТаблицуСкидокЗависящихОтВидаОплаты();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуУправляемыхСкидок()
	ТаблицаУправляемыхСкидок.Очистить();
	Если Не РежимКассыСамообслуживания Тогда
		ПараметрыУправляемыхСкидок = Новый Структура();
		ЗаполнитьПараметрыУправляемыхСкидокЛокально(ПараметрыУправляемыхСкидок);
		СерверЛояльностиПолучательДанныхКлиентСерверПереопределяемый.
			ЗаполнитьТаблицуУправляемыхСкидок(ТаблицаУправляемыхСкидок, ПараметрыУправляемыхСкидок);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПараметрыУправляемыхСкидокЛокально(ПараметрыУправляемыхСкидок)
	ПараметрыУправляемыхСкидок = Новый Структура();
	ПараметрыУправляемыхСкидок.Вставить("МаксимальныйПроцентСкидки", МаксимальныйПроцентРучнойСкидки);
	ПараметрыУправляемыхСкидок.Вставить("МаксимальныйПроцентНаценки", МаксимальныйПроцентРучнойНаценки);
	ПараметрыУправляемыхСкидок.Вставить("Магазин", Объект.ТорговыйОбъект.УникальныйИдентификатор());
	УИДКонтрагента = ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор();
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		УИДКонтрагента = Объект.Контрагент.УникальныйИдентификатор();
	КонецЕсли;
	ПараметрыУправляемыхСкидок.Вставить("Клиент", УИДКонтрагента);
	Если ЗначениеЗаполнено(Объект.ДисконтнаяКарта) Тогда
		ПараметрыУправляемыхСкидок.Вставить("УникальныйИдентификаторКарты", Объект.ДисконтнаяКарта.УникальныйИдентификатор());
	Иначе
		ПараметрыУправляемыхСкидок.Вставить("ИдентификаторКартыКлиента",НайденнаяКартаНомер);
	КонецЕсли;
	ПараметрыУправляемыхСкидок.Вставить("ИспользоватьОтборы",Истина);
	ПараметрыУправляемыхСкидок.Вставить("ДопускаетсяПрименениеСкидок", ДопускаетсяПрименениеСкидок);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуВидовКарт()
	
	ТаблицаВидыКарт.Очистить();
	Элементы.НоваяКартаВидКарты.СписокВыбора.Очистить();
	ПараметрыВидовКарт = Новый Структура();
	ЗаполнитьПараметрыВидовКартЛокально(ПараметрыВидовКарт);
	СерверЛояльностиПолучательДанныхКлиентСерверПереопределяемый.ЗаполнитьТаблицуВидовКарт(ТаблицаВидыКарт, ПараметрыВидовКарт);
	
	ОбработатьРезультатПолученияВидовКарт(ТаблицаВидыКарт);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуСкидокЗависящихОтВидаОплаты()
	
	ТаблицаСкидокЗависяшихОтВидаОплаты.Очистить();
	СерверЛояльностиПолучательДанныхКлиентСерверПереопределяемый.ЗаполнитьТаблицуСкидокЗависящихОтВидаОплаты(ТаблицаСкидокЗависяшихОтВидаОплаты);
	
КонецПроцедуры
#КонецОбласти

#Область НастройкиРМК
&НаКлиенте
Процедура ИзменитьНастройкиРабочегоМестаКассира(Команда)
	Если РежимНачальнойСтраницы = 1 Тогда
		ОсновнаяСтраница = Элементы.СтраницаОбщая;
	Иначе
		ОсновнаяСтраница = Элементы.СтраницаПустая;
	КонецЕсли;
	Если Объект.Товары.Количество() > 0 ИЛИ ФормаЗамороженаПослеПробитияЧека()
		Или НЕ Элементы.Страницы.ТекущаяСтраница = ОсновнаяСтраница Тогда
		ТекстСообщения = НСтр("ru = 'Таблица товаров не пуста. Команда недоступна.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("НастройкаРабочегоМеста", ТекущаяНастройкаРМК);
	ПараметрыОткрытия.Вставить("РабочееМестоКассира", Истина);
	ОписаниеОповещенияНастройкиРМК = Новый ОписаниеОповещения("ОбработатьИзменениеНастройкиРМК", ЭтаФорма);
	ОткрытьФорму("ОбщаяФорма.НастройкиРабочегоМестаКассира", ПараметрыОткрытия, ЭтаФорма,,,, ОписаниеОповещенияНастройкиРМК, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеНастройкиРМК(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьФормуПриСозданииНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ПодарочныеСертификаты
&НаКлиенте
Процедура ОплатаСертификатом(Команда) 
	
	ГруппаСлоевВспомогательнаяПанель = Элементы.ГруппаСлоевЛеваяВерхняяВспомогательнаяПанель;
	СкрытьЦифровуюПанельДляВводаСуммПриНеобходимости();
	Если РежимРаботыСЧеком = РежимыРаботыСЧеком.Оплата Или РежимРаботыСЧеком = РежимыРаботыСЧеком.ВозвратКоррекция
		Или ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьТекущийСлойГруппы(ГруппаСлоевВспомогательнаяПанель)
			= Элементы.ГруппаПоискСертификатов Тогда
		
		ПереключитьНаОплатуСертификатом();
		
	Иначе
		НеобходимПересчетАвтоматическихСкидок = ОпределитьНеобходимостьПересчетаАвтоматическихСкидок();
		Если НеобходимПересчетАвтоматическихСкидок И ВопросПоРасчетуСкидок Тогда
			ЗадатьВопросПоРасчетуСкидок("ПереключитьНаОплатуСертификатомЗавершение", , Истина);
		Иначе
			КодВозврата = ?(НеобходимПересчетАвтоматическихСкидок, КодВозвратаДиалога.Да, КодВозвратаДиалога.Нет);
			ПереключитьНаОплатуСертификатомЗавершение(КодВозврата);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НайтиСертификат(Команда)
	
	Если Не ЗначениеЗаполнено(НомерСертификата) Тогда 
		
		ТекстОшибки = НСтр("ru = 'Введите номер сертификата'");
		ПоказатьПредупреждение(, ТекстОшибки);
		Возврат;
		
	КонецЕсли;
	
	НайтиСертификатКлиент();
	
КонецПроцедуры

&НаКлиенте
Процедура НайтиСертификатКлиент()
	
	СкрытьЦифровуюПанельДляВводаСуммПриНеобходимости();
	Если ИспользоватьСерверЛояльностиПолучательДанных Тогда
		
		ЗначенияПараметровМетода = ЗначениеПараметровПодарочногоСертификата();
		ПараметрыВыполненияЗапроса = СерверЛояльностиПолучательДанныхКлиентСервер.ПараметрыЗапросаПолучитьДанныеПодарочногоСертификата(ПараметрыПодключенияКСерверуЛояльности,
										ЗначенияПараметровМетода, ТипЗапросаПодарочныеСертификаты);
		Результат = СерверЛояльностиПолучательДанныхКлиентСервер.ВыполнитьЗапросКСерверуЛояльности(ПараметрыВыполненияЗапроса);
		
		Если Результат.ЕстьОшибки Тогда
			ТекстЗаголовка = НСтр("ru = 'Ошибка поиска подарочного сертификата.'");
			ОткрытьСтраницуИнфоОшибка(ТекстЗаголовка, Результат.ТекстОшибки);
			Возврат;
		КонецЕсли;
		
		ДанныеОтвета = Неопределено;
		СтрокаJSON = Результат.ДанныеОтвета;
		СерверЛояльностиПолучательДанныхКлиентСервер.ОбработатьJSON(СтрокаJSON, ДанныеОтвета);
		
		Если НЕ ДанныеОтвета = Неопределено Тогда 
			
			Если ДанныеОтвета.Свойство("Error") И НЕ ДанныеОтвета.Error Тогда
				
				ОстатокСертификата = ДанныеОтвета.GiftCardBalance;
				
				ГУИД = ДанныеОтвета.GiftCard.GiftCardRef;
				ПодарочныйСертификат = ПодарочныйСертификатПоГУИД(ГУИД);
				
				УстановитьВидимостьЭлементаФормы(Элементы.ДекорацияСуммаСертификата, Истина);
				УстановитьВидимостьЭлементаФормы(Элементы.ОплатитьСертификатом, Истина);
				УстановитьВидимостьЭлементаФормы(Элементы.НайтиСертификат, Ложь);
				УстановитьВидимостьЭлементаФормы(Элементы.ДекорацияОплатаСертификатами, Ложь);
				УстановитьВидимостьЭлементаФормы(Элементы.НомерСертификата, Ложь);
				
				ТекстСообщения = СтрШаблон(НСтр("ru = 'У клиента %1 %2'"),
					Формат(ОстатокСертификата, "ЧЦ=15; ЧДЦ=2; ЧН=0,00"),
					ПредставлениеВалюты);
				Элементы.ДекорацияСуммаСертификата.Заголовок = ТекстСообщения;
				
				СуммаСертификата = ДанныеОтвета.GiftCardBalance;
				Если ЕстьСвойство(ДанныеОтвета, "GiftCardLimit")
					И ДанныеОтвета.GiftCardLimit Тогда
					ДоступноКОплате = ДанныеОтвета.GiftCardAvailable;
					ТекстДоступноКОплате = СтрШаблон(НСтр("ru = 'Доступно к оплате %1 %2'"),
						Формат(ДоступноКОплате, "ЧЦ=15; ЧДЦ=2; ЧН=0,00"),
						ПредставлениеВалюты);
					УстановитьВидимостьЭлементаФормы(Элементы.ДекорацияДоступноСертификата, Истина);
					Элементы.ДекорацияДоступноСертификата.Заголовок = ТекстДоступноКОплате;
					СуммаСертификата = ДоступноКОплате;
				КонецЕсли;
				
				УстановитьДоступностьЭлементаФормы(Элементы.ОплатитьСертификатом, СуммаСертификата > 0);
				ТекущийЭлемент = ?(СуммаСертификата > 0, Элементы.ОплатитьСертификатом, Элементы.ОтменаПоискаСертификата);
				
			ИначеЕсли ДанныеОтвета.Свойство("Error") И ДанныеОтвета.Error Тогда
				
				ТекстЗаголовка = НСтр("ru = 'Ошибка поиска подарочного сертификата.'");
				ТекстОшибки = СтрШаблон(НСтр("ru = '%1'"), ДанныеОтвета.ErrorMessage);
				ОткрытьСтраницуИнфоОшибка(ТекстЗаголовка, ТекстОшибки);
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ОбщегоНазначенияРМККлиент.ИспользоватьПоискСертификатаЛокально() Тогда
		
		НайтиСертификатЛокально();
		
		Если СуммаСертификата = 0 ИЛИ Не ЗначениеЗаполнено(ПодарочныйСертификат) Тогда
			ТекстЗаголовка = НСтр("ru = 'Ошибка поиска подарочного сертификата.'");
			Если СуммаСертификата = 0 Тогда
				ТекстОшибки = НСтр("ru = 'Сертификат не активирован или полностью погашен.'");
			Иначе
				ТекстОшибки = НСтр("ru = 'Сертификат не найден.'");
			КонецЕсли;
			ПараметрыОшибки = Новый Структура("ЭтоПредупреждение", Истина);
			
			ОткрытьСтраницуИнфоОшибка(ТекстЗаголовка, ТекстОшибки, ПараметрыОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НайтиСертификатЛокально()
	
	ОбщегоНазначенияРМКПереопределяемый.НайтиСертификатЛокально(ЭтотОбъект);
	
	УстановитьВидимостьЭлементаФормы(Элементы.ДекорацияСуммаСертификата, Истина);
	УстановитьВидимостьЭлементаФормы(Элементы.ОплатитьСертификатом, Истина);
	УстановитьВидимостьЭлементаФормы(Элементы.НайтиСертификат, Ложь);
	УстановитьВидимостьЭлементаФормы(Элементы.ДекорацияОплатаСертификатами, Ложь);
	УстановитьВидимостьЭлементаФормы(Элементы.НомерСертификата, Ложь);
	УстановитьДоступностьЭлементаФормы(Элементы.ОплатитьСертификатом, СуммаСертификата > 0);
		
КонецПроцедуры

&НаКлиенте
Процедура ОтменаПоискаСертификата(Команда)
	
	СкрытьЦифровуюПанельДляВводаСуммПриНеобходимости();
	НастроитьВидимостьОплатыПодарочнымиСертификатами();
	РазблокироватьПодарочныйСертификатПриОтмене();
	НомерСертификата = "";
	СуммаОстаткаСертификатов = 0;
	СуммаСертификата = 0;
	
	ТекущийЭлемент = Элементы.НомерСертификата;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСуммуОплатыСертификатамиДругихЧеков()
	
	РезультатФункции = 0;
	
	Если ЗначениеЗаполнено(ВыбраннаяОрганизация) Тогда
		Для Каждого СтрокаПодарочногоСертификата Из ТаблицаПодарочныхСертификатов Цикл
			Если Не (СтрокаПодарочногоСертификата.Организация = ВыбраннаяОрганизация
					И СтрокаПодарочногоСертификата.СистемаНалогообложения = ВыбраннаяСистемаНалогообложения) Тогда
				РезультатФункции = РезультатФункции + СтрокаПодарочногоСертификата.СуммаСертификата;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Процедура ОплатитьСертификатом(Команда)
	
	ИнтерфейсРМКСлужебныйКлиентСервер.УстановитьТекущийСлойГруппы(Элементы.ПанельУправленияЧеком);
	
	БалансСертификата = СуммаСертификата;
	ОсталосьДоступноДляОплаты = Объект.Товары.Итог("Сумма") - Объект.Оплата.Итог("Сумма")
		- ПолучитьСуммуОплатыСертификатамиДругихЧеков();
	СуммаСертификата = Мин(ОсталосьДоступноДляОплаты, СуммаСертификата);
	
	Если Не ЭтоСерийныйПодарочныйСертификат Тогда
		НомерСертификата = СтрЗаменить(Новый УникальныйИдентификатор(), "-", "_");
	КонецЕсли;
	Если НЕ Элементы.ГруппаСписокЧековПродажи.Видимость Тогда
		ПереключитьНаСледующийЧек("НаСледующий");
	КонецЕсли;
	
	ДобавитьСертификатВТаблицу(ЭтотОбъект, БалансСертификата);
	РаспределитьОплатуСертификатамиПоОрганизациям();
	ДобавитьРеквизиты(НомерСертификата);
	
	СуммаОстаткаСертификатов = ТаблицаПодарочныхСертификатов.Итог("СуммаСертификата");
	СуммаОплаченоСертификатами = СуммаОстаткаСертификатов;
	
	ПараметрыПересчета = СтруктураПараметровПересчетаСуммОплаты();
	ПараметрыПересчета.ПоКомандеОплатитьСертификатом = Истина;
	РассчитатьСуммыОплатыПриРедактировании(ПараметрыПересчета);
	
	НастроитьВидимостьОплатыПодарочнымиСертификатами(, Истина);
	
КонецПроцедуры

&НаКлиенте
Функция ЗначениеПараметровПодарочногоСертификата()
	
	СтатичныеПараметры	= СерверЛояльностиПолучательДанныхКлиентСервер.ПараметрыПодарочногоСертификата();
	СтатичныеПараметры.GiftCardNumber	= НомерСертификата;
	СтатичныеПараметры.GiftCardUID		= Строка(ПодарочныйСертификат.УникальныйИдентификатор());
	СтатичныеПараметры.Goods			= ПолучитьТоварыПоПодарочнымСертификатам();
	
	Возврат СтатичныеПараметры;
	
КонецФункции

&НаКлиенте
Функция ПолучитьТоварыПоПодарочнымСертификатам()
	МассивТоваров = Новый Массив;
	ТоварыДляЗапроса = Объект.Товары;
	Если НЕ ОплатаБезДеленияПоЧекам Тогда
		Отбор = Новый Структура("Организация", ВыбраннаяОрганизация);
		ТоварыДляЗапроса = Объект.Товары.НайтиСтроки(Отбор);
	КонецЕсли;
	Для Каждого СтрокаТовар Из ТоварыДляЗапроса Цикл
		
		СтруктураСтроки = СерверЛояльностиПолучательДанныхКлиентСервер.СтруктураТоваровДляРасчетаСкидок();
		
		СтруктураСтроки.Item = СерверЛояльностиПолучательДанныхКлиентСервер.ПолучитьПараметрыСсылки(СтрокаТовар.Номенклатура);
		СтруктураСтроки.Variant = СерверЛояльностиПолучательДанныхКлиентСервер.ПолучитьПараметрыСсылки(СтрокаТовар.Характеристика);
		СтруктураСтроки.Organization = СерверЛояльностиПолучательДанныхКлиентСервер.ПолучитьПараметрыСсылки(СтрокаТовар.Организация);
		СтруктураСтроки.Amount = СтрокаТовар.Сумма;
		
		МассивТоваров.Добавить(СтруктураСтроки);
		
	КонецЦикла;
	
	Возврат МассивТоваров;
КонецФункции

&НаСервере
Процедура ЗаполнитьБалансПодарочныхСертификатовПриВозврате()
	
	Для Каждого СтрокаТовара Из Объект.Товары Цикл
		ТипСертификат = ЭтоПодарочныйСертификат(СтрокаТовара.ТипНоменклатуры);
		Если НЕ ТипСертификат Тогда
			Продолжить;
		КонецЕсли;
		
		Если СерииНеВыгружаются Тогда
			Серия = СтрокаТовара.ИдентификаторСерий;
		Иначе
			Серия = СтрокаТовара.Серия;
		КонецЕсли;
		
		СерияЗаполнена = ЗначениеЗаполнено(Серия);
		
		Если НЕ СерияЗаполнена Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыСертификата = Новый Структура;
		ПараметрыСертификата.Вставить("БалансСертификата", 0);
		ПараметрыСертификата.Вставить("Сертификат", СтрокаТовара.Номенклатура);
		ПараметрыСертификата.Вставить("Серия", Серия);
		ПараметрыСертификата.Вставить("СерииНеВыгружаются", СерииНеВыгружаются);
		ПараметрыСертификата.Вставить("Организация", СтрокаТовара.Организация);
		
		ПолучитьБалансСертификата(ПараметрыСертификата, СтрокаТовара);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьВидимостьЗапросаБалансаСертификата()
	
	ЗапрашиватьБаланс = Ложь;
	ОбщегоНазначенияРМККлиентПереопределяемый.ОпределитьНеобходимостьЗапросаБалансаСертификата(ЗапрашиватьБаланс);
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(ТекущийТоварИдентификатор);
	
	Если ТекущаяСтрока = Неопределено
		Или НЕ ЗапрашиватьБаланс Тогда
		УстановитьВидимостьЭлементаФормы(Элементы.ЗапроситьБалансСертификата, Ложь);
		Возврат;
	КонецЕсли;
	
		
	ВидимостьЗапросаБаланса = Ложь;
	ЭтоПродажа = ОбщегоНазначенияРМККлиент.ЭтоВидОперацииПродажа(Объект.ВидОперации);
	ТипНоменклатурыСертификат = ОбщегоНазначенияРМККлиент.ТипНоменклатурыПодарочныйСертификат();
	
	ВидимостьЗапросаБаланса = НЕ ЭтоПродажа
		И ТекущаяСтрока.ТипНоменклатуры = ТипНоменклатурыСертификат
		И ТекущаяСтрока.НеобходимостьВводаСерии;
		
	УстановитьВидимостьЭлементаФормы(Элементы.ЗапроситьБалансСертификата, ВидимостьЗапросаБаланса);
	
КонецПроцедуры

&НаСервере
Процедура ЗапроситьБалансСертификатаСервер()
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(ТекущийТоварИдентификатор);
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СерииНеВыгружаются Тогда
		Серия = ТекущаяСтрока.ИдентификаторСерий;
	Иначе
		Серия = ТекущаяСтрока.Серия;
	КонецЕсли;
	СерияЗаполнена = ЗначениеЗаполнено(Серия);
	
	Если НЕ СерияЗаполнена Тогда
		ТекстСообщения = НСтр("ru = 'Серия не заполнена'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ПараметрыСертификата = Новый Структура;
	ПараметрыСертификата.Вставить("БалансСертификата", 0);
	ПараметрыСертификата.Вставить("Сертификат", ТекущаяСтрока.Номенклатура);
	ПараметрыСертификата.Вставить("Серия", Серия);
	ПараметрыСертификата.Вставить("СерииНеВыгружаются", СерииНеВыгружаются);
	ПараметрыСертификата.Вставить("Организация", ТекущаяСтрока.Организация);
	
	ПолучитьБалансСертификата(ПараметрыСертификата, ТекущаяСтрока);
КонецПроцедуры

&НаСервере
Процедура ПолучитьБалансСертификата(ПараметрыСертификата, СтрокаТовара)
	ОбщегоНазначенияРМКПереопределяемый.ЗапроситьБалансСертификата(ПараметрыСертификата);
	Если НЕ ПараметрыСертификата.БалансСертификата = 0 Тогда
		ТекущийТоварЦенаИзКарточки = ПараметрыСертификата.БалансСертификата;
		СтрокаТовара.Цена = ПараметрыСертификата.БалансСертификата;
		ДобавитьСертификатВТаблицу(ЭтотОбъект, ПараметрыСертификата.БалансСертификата, СтрокаТовара);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СписатьПодарочныйСертификат()
	
		ЭтоОперацияВозврат = ОбщегоНазначенияРМККлиент.ЭтоВидОперацииВозврат(Объект.ВидОперации);
		
		Если ЭтоОперацияВозврат
			И СписокНастроекСервераЛояльности.НайтиПоЗначению("ДоступноНачислениеСертификатов") <> Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Если ЭтоОперацияВозврат Тогда
			СуммаСписания = Строка(-СуммаСертификата);
		Иначе
			СуммаСписания = Строка(СуммаСертификата);
		КонецЕсли;
		
		ЗначенияПараметровМетода = ЗначениеПараметровПодарочногоСертификата();
		ЗначенияПараметровМетода.Вставить("GiftCardWriteOffAmount", СуммаСписания);
		
		Если СписокНастроекСервераЛояльности.НайтиПоЗначению("ИспользоватьНовыеМетоды_3_0_11") <> Неопределено Тогда
			ИмяРесурса = "writeoffgiftcard3_0";
		ИначеЕсли ИспользоватьНовыйМетодСЛ Тогда
			ИмяРесурса = "writeoffgiftcardnew";
		Иначе
			ИмяРесурса = "writeoffgiftcard";
		КонецЕсли;
		ПараметрыВыполненияЗапроса = СерверЛояльностиПолучательДанныхКлиентСервер.ПараметрыЗапросаСписатьПодарочныйСертификат(ПараметрыПодключенияКСерверуЛояльности,
				ЗначенияПараметровМетода, ИмяРесурса);
		Результат = СерверЛояльностиПолучательДанныхКлиентСервер.ВыполнитьЗапросКСерверуЛояльности(ПараметрыВыполненияЗапроса);
		
		СтрокаОтвета = Результат.ДанныеОтвета;
		
		Если СтрокаОтвета = "Подарочный сертификат успешно списан на указанную сумму" Тогда
			
			СуммаОстаткаСертификатов = СуммаОстаткаСертификатов - СуммаОплаченоСертификатами;
			Если ОжидаемоеКоличествоЧеков < 1 Тогда
				ОчиститьДанныеПодарочногоСертификата();
			КонецЕсли;
			
		Иначе
			ДанныеОтвета = Неопределено;
			СерверЛояльностиПолучательДанныхКлиентСервер.ОбработатьJSON(СтрокаОтвета, ДанныеОтвета);
			
			Если ДанныеОтвета <> Неопределено Тогда
				Если НЕ ДанныеОтвета.Error Тогда
					СуммаОстаткаСертификатов = СуммаОстаткаСертификатов - СуммаОплаченоСертификатами;
					Если ОжидаемоеКоличествоЧеков < 1 Тогда
						ОчиститьДанныеПодарочногоСертификата();
					КонецЕсли;
				Иначе
					РазблокироватьОбъектСервераЛояльности("giftcard");
				КонецЕсли;
			Иначе
				РазблокироватьОбъектСервераЛояльности("giftcard");
			КонецЕсли;
		КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура УдалитьПодарочныйСертификат(ИдентификаторСертификата, УдалитьСтрокуТаблицы = Ложь)
	
	Если УдалитьСтрокуТаблицы Тогда 
		
		Отбор = Новый Структура;
		Отбор.Вставить("УникальныйИдентификатор", ИдентификаторСертификата);
		МассивСтрокТаблицы = ТаблицаПодарочныхСертификатов.НайтиСтроки(Отбор);
		
		Для Каждого СтрокаТаблицы Из МассивСтрокТаблицы Цикл
			ЭтоСерийныйПодарочныйСертификат = СтрокаТаблицы.ЭтоСерийныйПодарочныйСертификат;
			ТаблицаПодарочныхСертификатов.Удалить(СтрокаТаблицы);
		КонецЦикла;
		УстановитьВидимостьКомандыУдаленияВсехСертификатов(Элементы.ГруппаУдалитьСертификаты, ТаблицаПодарочныхСертификатов);
		
	КонецЕсли;
	
	Если НЕ Элементы.Найти("СуммаСертификата_" + ИдентификаторСертификата) = Неопределено Тогда
		УдаляемыеРеквизиты = Новый Массив;
		УдаляемыеРеквизиты.Добавить("СуммаСертификата_" + ИдентификаторСертификата);
		ИзменитьРеквизиты(, УдаляемыеРеквизиты);
		
		УдалитьЭлементФормы("ГруппаСуммаОплатаСертификатом_" + ИдентификаторСертификата);
		УдалитьЭлементФормы("СуммаСертификата_" + ИдентификаторСертификата);
		УдалитьЭлементФормы("ДекорацияУдалитьСертификат_" + ИдентификаторСертификата);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СписатьРазблокироватьПодарочныеСертификаты(Списать = Ложь)
	
	Для Каждого СтрокаТаблицы Из ТаблицаПодарочныхСертификатов Цикл
		
		РазблокироватьСертификат = (СтрокаТаблицы.СуммаСертификата > 0) И СтрокаТаблицы.ЭтоСерийныйПодарочныйСертификат;
		СтруктураОтбора = Новый Структура("НомерСертификата, ПодарочныйСертификат",
			СтрокаТаблицы.НомерСертификата,
			СтрокаТаблицы.ПодарочныйСертификат);
		Если НЕ ТаблицаПодарочныхСертификатов.НайтиСтроки(СтруктураОтбора).Количество() 
			И РазблокироватьСертификат Тогда
			
			НомерСертификата = СтрокаТаблицы.НомерСертификата;
			ПодарочныйСертификат = СтрокаТаблицы.ПодарочныйСертификат;
			РазблокироватьОбъектСервераЛояльности("giftcard");
		КонецЕсли;
		
		Если СтрокаТаблицы.СуммаСертификата > 0 И СтрокаТаблицы.ЭтоСерийныйПодарочныйСертификат Тогда
			
			НомерСертификата = СтрокаТаблицы.НомерСертификата;
			ПодарочныйСертификат = СтрокаТаблицы.ПодарочныйСертификат;
			СуммаСертификата = СтрокаТаблицы.СуммаСертификата;
			
			Если Списать И ИспользоватьСерверЛояльностиПолучательДанных Тогда
				СписатьПодарочныйСертификат();
			Иначе
				РазблокироватьОбъектСервераЛояльности("giftcard");
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	РазблокироватьПодарочныйСертификатПриОтмене();
КонецПроцедуры

&НаКлиенте
Процедура НачислитьПодарочныеСертификаты()
	
	ЭтоОперацияВозврат = ОбщегоНазначенияРМККлиент.ЭтоВидОперацииВозврат(Объект.ВидОперации);
	ТипНоменклатурыПодарочныйСертификат = ОбщегоНазначенияРМККлиент.ТипНоменклатурыПодарочныйСертификат();
	Для Каждого СтрокаТовары Из Объект.Товары Цикл
		Если НЕ СтрокаТовары.ЭтоПодарочныйСертификат Тогда
			Продолжить;
		КонецЕсли;
		СуммаНачисления = СтрокаТовары.СуммаБезСкидки;
		Если ЭтоОперацияВозврат Тогда
			СуммаНачисления = -СуммаНачисления;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТовары.ИдентификаторСерий) Тогда
			Номер = СтрокаТовары.ИдентификаторСерий;
		Иначе
			Номер = Строка(СтрокаТовары.Серия.УникальныйИдентификатор());
		КонецЕсли;
		ЗначенияПараметровМетода	= СерверЛояльностиПолучательДанныхКлиентСервер.ПараметрыПодарочногоСертификата();
		ЗначенияПараметровМетода.GiftCardNumber = Номер;
		ЗначенияПараметровМетода.GiftCardUID = Строка(СтрокаТовары.Номенклатура.УникальныйИдентификатор());
		ЗначенияПараметровМетода.Вставить("GiftCardAccrueOffAmount", Строка(СуммаНачисления));
		НачислитьБалансСертификатаСерверЛояльности(ЗначенияПараметровМетода, СтрокаТовары.Серия, ЭтоОперацияВозврат);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура НачислитьБалансСертификатаСерверЛояльности(ЗначенияПараметровМетода, СерияПодарочногоСертификата, ЭтоОперацияВозврат)
	ПараметрыВыполненияЗапроса = СерверЛояльностиПолучательДанныхКлиентСервер.ПараметрыЗапросаНачислитьПодарочныйСертификат(ПараметрыПодключенияКСерверуЛояльности,
		ЗначенияПараметровМетода);
	Результат = СерверЛояльностиПолучательДанныхКлиентСервер.ВыполнитьЗапросКСерверуЛояльности(ПараметрыВыполненияЗапроса);
	
	ДанныеОтвета = Неопределено;
	СтрокаJSON = Результат.ДанныеОтвета;
	СерверЛояльностиПолучательДанныхКлиентСервер.ОбработатьJSON(СтрокаJSON, ДанныеОтвета);
	
	Если НЕ ДанныеОтвета = Неопределено Тогда
		Если ЕстьСвойство(ДанныеОтвета, "Error")
			И НЕ ДанныеОтвета.Error Тогда
			ОбщегоНазначенияРМКВызовСервера.УстановитьПризнакПроданПодарочныйСертификат(СерияПодарочногоСертификата, ЭтоОперацияВозврат);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура РазблокироватьПодарочныйСертификатПриОтмене()
	
	Если НЕ ЗначениеЗаполнено(ПодарочныйСертификат) Тогда
		Возврат;
	КонецЕсли;
	
	РазблокироватьСертификат = (СуммаСертификата > 0) И ЭтоСерийныйПодарочныйСертификат;
	Если РазблокироватьСертификат Тогда
		РазблокироватьОбъектСервераЛояльности("giftcard");
	КонецЕсли;
КонецПроцедуры


#КонецОбласти

#Область РаботаСЦифровойКлавиатурой

&НаКлиенте
Функция ВычислитьПозициюВыделенияПослеВставки(РедактируемыйЭлемент, ТекстДоРедактирования,
		НачалоВыделения, КонецВыделения, СимволыКлавиатуры)
	
	РезультатФункции = 0;
	
	ДлинаТекста = СтрДлина(РедактируемыйЭлемент.ТекстРедактирования);
	ДлинаВставки = СтрДлина(СимволыКлавиатуры);
	Если РежимЦифровойПанели = РежимыЦифровойПанели.ДанныеПокупателя И Не ЭтоЧисловоеПолеДанныхПокупателя() Тогда
		
		Если ИнтерфейсРМКСлужебныйКлиентСервер.ЭтоПолеТелефонаСМаской(РедактируемыйЭлемент) Тогда
			Если НачалоВыделения < 3 Тогда
				НачалоВыделения = 3;
			КонецЕсли;
			РезультатФункции = ИнтерфейсРМКСлужебныйКлиент.ПолучитьПозициюКурсораСУчетомФорматирования(ТекстДоРедактирования,
				РедактируемыйЭлемент.ТекстРедактирования, НачалоВыделения, ДлинаВставки, " ");
		ИначеЕсли ИнтерфейсРМКСлужебныйКлиентСервер.ЭтоПолеДатыСМаской(РедактируемыйЭлемент) Тогда
			РезультатФункции = ИнтерфейсРМКСлужебныйКлиент.ПолучитьПозициюКурсораСУчетомФорматирования(ТекстДоРедактирования,
				РедактируемыйЭлемент.ТекстРедактирования, НачалоВыделения, ДлинаВставки, ".");
		Иначе
			РезультатФункции = НачалоВыделения + ДлинаВставки;
		КонецЕсли;
		
	Иначе
		
		Если ЭтоПолеСтрокиЦифр(РедактируемыйЭлемент) Тогда
			РезультатФункции = НачалоВыделения + ДлинаВставки;
		Иначе
			
			СимволРазделителя = ИнтерфейсРМКСлужебныйКлиентСервер.РазделительДробнойЧасти();
			ВводДробнойЧасти = Ложь;
			ПозицияРазделителя = -1;
			Если РежимЦифровойПанели = РежимыЦифровойПанели.ВводСуммОплаты Тогда
				ПозицияРазделителя = СтрНайти(ТекстДоРедактирования, СимволРазделителя);
				ВводДробнойЧасти = (НачалоВыделения > ПозицияРазделителя);
			КонецЕсли;
			Если ВводДробнойЧасти Тогда
				
				РезультатФункции = Мин(ДлинаТекста + 1, НачалоВыделения + ДлинаВставки);
				
			ИначеЕсли ПозицияРазделителя > 0 И НачалоВыделения <= ПозицияРазделителя И КонецВыделения > ПозицияРазделителя Тогда
				// Точка внутри выделения
				РезультатФункции = СтрНайти(РедактируемыйЭлемент.ТекстРедактирования, СимволРазделителя);
			Иначе
				ТекстЦелоеДоЕдиницы = СтрШаблон("0%1", СимволРазделителя);
				Если Лев(ТекстДоРедактирования, 2) = ТекстЦелоеДоЕдиницы Тогда
					НачалоВыделения = 1;
				КонецЕсли;
				РезультатФункции = ИнтерфейсРМКСлужебныйКлиент.ПолучитьПозициюКурсораСУчетомФорматирования(ТекстДоРедактирования,
					РедактируемыйЭлемент.ТекстРедактирования, НачалоВыделения, ДлинаВставки, Символы.НПП);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Процедура УдалитьСимволыВРедактируемомПоле(Знач РедактируемыйЭлемент, СимволИсключения, ПараметрыФорматирования)
	
	Если (Не РедактируемыйЭлемент = Неопределено) И РедактируемыйЭлемент.Доступность Тогда
		
		НачалоВыделения = 0;
		НачалоСтроки = 0;
		КонецВыделения = 0;
		КонецСтроки = 0;
		
		РедактируемыйЭлемент.ПолучитьГраницыВыделения(НачалоСтроки, НачалоВыделения, КонецСтроки, КонецВыделения);
		РедактируемыйТекст = РедактируемыйЭлемент.ТекстРедактирования;
		ТекущийЭлемент = РедактируемыйЭлемент;
		
		НовыйКонецВыделения = 1;
		МинимальноеНачало = ?(ПараметрыФорматирования.ЭтоТелефон, 3, 1);
		СимволЗамены = ?(ПараметрыФорматирования.Форматированный, " ", "");
		Если НачалоВыделения = КонецВыделения Тогда
			Если НачалоВыделения > МинимальноеНачало Тогда
				СимволСлева = Сред(РедактируемыйТекст, НачалоВыделения - 1, 1);
				Если СимволСлева = СимволИсключения Тогда
					НовыйКонецВыделения = НачалоВыделения - 1;
				Иначе
					РедактируемыйЭлемент.УстановитьГраницыВыделения(НачалоВыделения - 1, НачалоВыделения);
					РедактируемыйЭлемент.ВыделенныйТекст = СимволЗамены;
					ОбновитьОтображениеДанных(РедактируемыйЭлемент);
					НовыйКонецВыделения = ВычислитьПозициюВыделенияПослеВставки(РедактируемыйЭлемент, РедактируемыйТекст,
						НачалоВыделения - 1, КонецВыделения, "");
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если ПараметрыФорматирования.ЭтоТелефон И КонецВыделения <= МинимальноеНачало Тогда
				НовыйКонецВыделения = НачалоВыделения;
			Иначе
				РедактируемыйЭлемент.ВыделенныйТекст = СимволЗамены;
				ОбновитьОтображениеДанных(РедактируемыйЭлемент);
				НовыйКонецВыделения = ВычислитьПозициюВыделенияПослеВставки(РедактируемыйЭлемент, РедактируемыйТекст,
					НачалоВыделения, КонецВыделения, "");
			КонецЕсли;
		КонецЕсли;
		РедактируемыйЭлемент.УстановитьГраницыВыделения(НовыйКонецВыделения, НовыйКонецВыделения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВставитьСимволыВРедактируемоеПоле(Знач РедактируемыйЭлемент, СимволыКлавиатуры)
	
	Если (Не РедактируемыйЭлемент = Неопределено) И РедактируемыйЭлемент.Доступность Тогда
	
		НачалоВыделения = 0;
		НачалоСтроки = 0;
		КонецВыделения = 0;
		КонецСтроки = 0;
		
		РедактируемыйЭлемент.ПолучитьГраницыВыделения(НачалоСтроки, НачалоВыделения, КонецСтроки, КонецВыделения);
		РедактируемыйТекст = РедактируемыйЭлемент.ТекстРедактирования;
		
		ТекущийЭлемент = РедактируемыйЭлемент;
		РедактируемыйЭлемент.ВыделенныйТекст = СимволыКлавиатуры;
		ОбновитьОтображениеДанных(РедактируемыйЭлемент);
		
		НовыйКонецВыделения = ВычислитьПозициюВыделенияПослеВставки(РедактируемыйЭлемент, РедактируемыйТекст,
			НачалоВыделения, КонецВыделения, СимволыКлавиатуры);
			
		ТекущийЭлемент = РедактируемыйЭлемент;
		РедактируемыйЭлемент.УстановитьГраницыВыделения(НовыйКонецВыделения, НовыйКонецВыделения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВставитьСимволВКодИзСМС(СимволВставки)

	РедактируемыйЭлемент = Элементы.КодПроверкиИзSMS;
	
	НачалоВыделения = 0;
	НачалоСтроки = 0;
	КонецВыделения = 0;
	КонецСтроки = 0;
	
	РедактируемыйЭлемент.ПолучитьГраницыВыделения(НачалоСтроки, НачалоВыделения, КонецСтроки, КонецВыделения);
	РедактируемыйТекст = РедактируемыйЭлемент.ТекстРедактирования;
	
	ЛеваяЧасть = "";
	ПраваяЧасть = "";
	ДлинаВставки = СтрДлина(СимволВставки);
	Если НачалоВыделения = КонецВыделения И ДлинаВставки = 0 И НачалоВыделения > 1 Тогда
		НачалоВыделения = НачалоВыделения - 1;
	КонецЕсли;
	Если НачалоВыделения > 1 Тогда
		ЛеваяЧасть = СокрЛП(Лев(РедактируемыйТекст, НачалоВыделения - 1));
	КонецЕсли;
	Если КонецВыделения < 5 Тогда
		ПраваяЧасть = СокрЛП(Сред(РедактируемыйТекст,КонецВыделения));
	КонецЕсли;
	КодПроверкиИзSMS = СтрШаблон("%1%2%3", ЛеваяЧасть, СимволВставки, ПраваяЧасть);
	ОбновитьОтображениеДанных(РедактируемыйЭлемент);
	НоваяПозиция = Мин(НачалоВыделения + ДлинаВставки, 5);
	РедактируемыйЭлемент.УстановитьГраницыВыделения(НоваяПозиция, НоваяПозиция);
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТекстРедактированияПоляФормы(Знач РедактируемыйЭлемент)
	
	Если (Не РедактируемыйЭлемент = Неопределено) И РедактируемыйЭлемент.Доступность Тогда
		ВводСЦифровойКлавиатуры = Истина;
		
		Если ИнтерфейсРМКСлужебныйКлиент.ОчиститьТекстРедактированияВПолеФормы(ЭтотОбъект, РедактируемыйЭлемент) Тогда
			Если РедактируемыйЭлемент = Элементы.ОтправкаЧекаТелефон Тогда
				НастроитьДоступностьОтправкиЧекаПриИзмененииТелефона(Ложь);
			КонецЕсли;
		Иначе
			СкрытьЦифровуюПанельДляВводаСумм();
		КонецЕсли;
		
		ВводСЦифровойКлавиатуры = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуЦифровойКлавиатурыУдалитьПоследнее()
	
	ПараметрыФорматирования = Новый Структура("Форматированный, ЭтоТелефон", Ложь, Ложь);
	СимволИсключения = "";
	Если РежимВводаСимволовИСумм(РежимЦифровойПанели, РежимыЦифровойПанели) Или ЭтоЧисловоеПолеДанныхПокупателя() Тогда
		Если Не ЭтоПолеСтрокиЦифр(ЭлементВводаСуммы) Тогда
			СимволИсключения = Символы.НПП;
		КонецЕсли;
		УдалитьСимволыВРедактируемомПоле(ЭлементВводаСуммы, СимволИсключения, ПараметрыФорматирования);
	Иначе
		ГруппаДополнительнаяОбласть = Элементы.ГруппаСлоевДанныеПокупателяДополнительнаяОбласть;
		ДополнительныйСлойДанныеПокупателя
			= ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьТекущийСлойГруппы(ГруппаДополнительнаяОбласть);
		Если ДополнительныйСлойДанныеПокупателя = Элементы.ГруппаПодтверждениеСМС Тогда
			
			ВставитьСимволВКодИзСМС("");
			
		ИначеЕсли Не ЭлементВводаДанныхПокупателя = Неопределено Тогда
			Если ИнтерфейсРМКСлужебныйКлиентСервер.ЭтоПолеТелефонаСМаской(ЭлементВводаДанныхПокупателя) Тогда
				ПараметрыФорматирования.Форматированный = Истина;
				ПараметрыФорматирования.ЭтоТелефон = Истина;
				СимволИсключения = " ";
			ИначеЕсли ИнтерфейсРМКСлужебныйКлиентСервер.ЭтоПолеДатыСМаской(ЭлементВводаДанныхПокупателя) Тогда
				ПараметрыФорматирования.Форматированный = Истина;
				СимволИсключения = ".";
			КонецЕсли;
			УдалитьСимволыВРедактируемомПоле(ЭлементВводаДанныхПокупателя, СимволИсключения, ПараметрыФорматирования);
			НастроитьКнопкиЦифровойПанели();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуЦифровойКлавиатурыОчистить()
	
	Если РежимВводаСимволовИСумм(РежимЦифровойПанели, РежимыЦифровойПанели) Или ЭтоЧисловоеПолеДанныхПокупателя() Тогда
		ОчиститьТекстРедактированияПоляФормы(ЭлементВводаСуммы);
	Иначе
		ГруппаДополнительнаяОбласть = Элементы.ГруппаСлоевДанныеПокупателяДополнительнаяОбласть;
		ДополнительныйСлойДанныеПокупателя
			= ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьТекущийСлойГруппы(ГруппаДополнительнаяОбласть);
		Если ДополнительныйСлойДанныеПокупателя = Элементы.ГруппаПодтверждениеСМС Тогда
			КодПроверкиИзSMS = "";
		Иначе
			ОчиститьТекстРедактированияПоляФормы(ЭлементВводаДанныхПокупателя);
			НастроитьКнопкиЦифровойПанели();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЦифруЦифровойКлавиатуры(ИмяКомандыКлавиатуры)
	
	СимволКлавиатуры = ИнтерфейсРМКСлужебныйКлиент.ПолучитьСимволКоманды(ИмяКомандыКлавиатуры);
	ПрименитьСимволыЦифровойКлавиатуры(СимволКлавиатуры);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуДваНуляЦифровойКлавиатуры()
	
	СимволыКлавиатуры = ИнтерфейсРМКСлужебныйКлиент.ПолучитьТекстКнопкиДваНуля();
	ПрименитьСимволыЦифровойКлавиатуры(СимволыКлавиатуры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьСимволыЦифровойКлавиатуры(СимволыКлавиатуры)
	
	Если РежимВводаСимволовИСумм(РежимЦифровойПанели, РежимыЦифровойПанели) Или ЭтоЧисловоеПолеДанныхПокупателя() Тогда
		ВставитьСимволыВРедактируемоеПоле(ЭлементВводаСуммы, СимволыКлавиатуры);
	Иначе
		
		ГруппаДополнительнаяОбласть = Элементы.ГруппаСлоевДанныеПокупателяДополнительнаяОбласть;
		ДополнительныйСлойДанныеПокупателя
			= ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьТекущийСлойГруппы(ГруппаДополнительнаяОбласть);
		Если ДополнительныйСлойДанныеПокупателя = Элементы.ГруппаПодтверждениеСМС Тогда
			ВставитьСимволВКодИзСМС(СимволыКлавиатуры);
			
			Введено4Цифры = СтрДлина(СокрЛП(КодПроверкиИзSMS)) = 4;
			Если Введено4Цифры Тогда
				ТекущийЭлемент = Элементы.ОтправитьSMSСКодомПроверки;
				ПроверитьВведенныйКодИзSMS();
			КонецЕсли;
			
		Иначе
			ВставитьСимволыВРедактируемоеПоле(ЭлементВводаДанныхПокупателя, СимволыКлавиатуры);
		КонецЕсли;
		НастроитьКнопкиЦифровойПанели();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуЦифровойКлавиатурыВводПоиск()
	
	Если РежимЦифровойПанели = РежимыЦифровойПанели.ДанныеПокупателя Тогда
		
		ОбработатьШтрихкодКлиент(СтрокаПоискаКарты);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьКомандуЦифровойКлавиатурыЗвездочкаЗапятая()
	
	Если РежимЦифровойПанели = РежимыЦифровойПанели.ДанныеПокупателя И Не ЭтоЧисловоеПолеДанныхПокупателя() Тогда
		РедактируемыйТекст = ЭлементВводаДанныхПокупателя.ТекстРедактирования;
		Если СокрЛП(РедактируемыйТекст) = "" Тогда
			ТекущийЭлемент = ЭлементВводаДанныхПокупателя;
			ЭлементВводаДанныхПокупателя.ВыделенныйТекст = ИнтерфейсРМКСлужебныйКлиент.ПолучитьСимволЗвездочка();
			ОбновитьОтображениеДанных(ЭлементВводаДанныхПокупателя);
			ЭлементВводаДанныхПокупателя.УстановитьГраницыВыделения(2, 2);
			НастроитьКнопкиЦифровойПанели();
		КонецЕсли;
	ИначеЕсли РежимЦифровойПанели = РежимыЦифровойПанели.ВводСуммОплаты Или ЭтоЧисловоеПолеДанныхПокупателя() Тогда
		ПеревестиКурсорНаВводДробнойЧасти();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВключитьЦифровуюПанельДляВводаСуммВнесенияВыемки(ЭтоВнесение = Истина)
	
	РежимЦифровойПанели = РежимыЦифровойПанели.ВводСуммОплаты;
	
	Если ЭтоВнесение Тогда
		ЭлементВводаСуммы = Элементы.СуммаВнесение;
		ИмяКонтейнераЦифровойПанели = "ГруппаВнесениеЦифроваяПанель";
	Иначе
		ЭлементВводаСуммы = Элементы.СуммаВыемка;
		ИмяКонтейнераЦифровойПанели = "ГруппаВыемкаЦифроваяПанель";
	КонецЕсли;
	ПоказатьЦифровуюКлавиатуру(ИмяКонтейнераЦифровойПанели);
	НастроитьКнопкиЦифровойПанелиДляВводаСумм(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьРежимЦифровойПанели()
	
	РежимЦифровойПанели = РежимыЦифровойПанели.Пустой;
	ЭлементВводаСуммы = Неопределено;
	
КонецПроцедуры

#КонецОбласти

#Область КомандыНастройкиВводаПоСтроке

&НаКлиенте
Процедура НастройкаВводаПоСтрокеОткрытьНастройки(Команда)
	Элементы.ГруппаНастройкаВводаПоСтрокеСвертываемая.Показать();
КонецПроцедуры

&НаКлиенте
Процедура НастройкаВводаПоСтрокеЗакрыть(Команда)
	Элементы.ГруппаНастройкаВводаПоСтрокеСвертываемая.Скрыть();
КонецПроцедуры

&НаКлиенте
Процедура НастройкаВводаПоСтрокеИспользоватьНастройки(Команда)
	
	НастройкаВводаПоСтрокеИспользовать = Не НастройкаВводаПоСтрокеИспользовать;
	ОбновитьЭлементыНастроекВводаПоСтроке();
	СформироватьСтрокуНастроекВводаПоСтроке();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаВводаПоСтрокеПереключитьНастройку(Команда)
	
	НастройкаВводаПоСтрокеТекущийРежим = НастройкаВводаПоСтрокеТекущийРежим + 1;
	Если НастройкаВводаПоСтрокеТекущийРежим = 4 Тогда
		НастройкаВводаПоСтрокеТекущийРежим = 0;
	КонецЕсли;
	НастроитьКартинкиКнопок();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаВводаПоСтрокеПоказатьНеактуальные(Команда)
	
	НастройкаВводаПоСтрокеПоказыватьНеактуальные = Не НастройкаВводаПоСтрокеПоказыватьНеактуальные;
	ОбновитьЭлементыНастроекВводаПоСтроке();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПолеПоискаВводаПоСтроке(Команда)
	
	НомерПоля = СтрЗаменить(Команда.Имя,"ПолеПоискаВводаПоСтроке_", "");
	
	СтруктураОтбора = Новый Структура("Порядок", Число(НомерПоля));
	СтрокиПолей = НастройкаВводаПоСтрокеНастройкиПолей.НайтиСтроки(СтруктураОтбора);
	Если СтрокиПолей.Количество() > 0 Тогда
		СтрокаПоля = СтрокиПолей[0];
		ИмяПоля = СтрокаПоля.ИмяПоля;
		
		ИмяНастройки = "";
		Если НастройкаВводаПоСтрокеТекущийРежим = 0 Тогда
			ИмяНастройки = "СпособПоиска";
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 1 Тогда
			ИмяНастройки = "СпособПоискаСПрефексом";
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 2 Тогда
			ИмяНастройки = "Порядок";
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 3 Тогда
			ИмяНастройки = "Отображать";
		КонецЕсли;
		
		ТекущееЗначение = СтрокаПоля[ИмяНастройки];
		
		Если НастройкаВводаПоСтрокеТекущийРежим = 0 Или НастройкаВводаПоСтрокеТекущийРежим = 1
			Или НастройкаВводаПоСтрокеТекущийРежим = 3 Тогда
			ТекущееЗначение = ТекущееЗначение + 1;
			Если ТекущееЗначение > 1 Тогда
				ТекущееЗначение = 0;
			КонецЕсли;
			СтрокаПоля[ИмяНастройки] = ТекущееЗначение;
			НастроитьКартинкиКнопок(ИмяПоля);
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 2 Тогда
			Если ТекущееЗначение > 0 Тогда
				НастройкаВводаПоСтрокеНастройкиПолей.Сдвинуть(ТекущееЗначение, -1);
				ОбновитьНаименованиеКнопокПолей();
			КонецЕсли;
			НастроитьКартинкиКнопок();
		КонецЕсли;
	КонецЕсли;
	
	СформироватьСтрокуНастроекВводаПоСтроке();
	
КонецПроцедуры

#КонецОбласти

#Область НастройкиВводаПоСтроке

&НаКлиенте
Процедура УстановитьОтборПоляВводаПоСтроке(Отбор)
	
	Отбор.Вставить("ЭтоВызовИзРМК", Истина);
	Если Не НастройкаВводаПоСтрокеПоказыватьНеактуальные Тогда
		Отбор.Вставить("ПометкаУдаления", Ложь);
	КонецЕсли;
	Если НастройкаВводаПоСтрокеИспользовать Тогда
		Отбор.Вставить("НастройкиПолейСтрокой", НастройкаВводаПоСтрокеНастройкиПолейСтрокой);
		Отбор.Вставить("ВидЦеныРМК", РозничныйВидЦены);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьСтрокуНастроекВводаПоСтроке()
	
	Если Не НастройкаВводаПоСтрокеИспользовать Тогда
		НастройкаВводаПоСтрокеНастройкиПолейСтрокой = "";
	КонецЕсли;
	
	ПоляПоискаСНастройками = Новый Массив;
	
	Для Каждого СтрокаПоля Из НастройкаВводаПоСтрокеНастройкиПолей Цикл
		
		ТекстПоляСНастройками = СтрокаПоля.ИмяПоля;
		
		ТекстПоляСНастройками = СтрШаблон("%1/%2", ТекстПоляСНастройками, СтрокаПоля.СпособПоиска);
		ТекстПоляСНастройками = СтрШаблон("%1/%2", ТекстПоляСНастройками, СтрокаПоля.СпособПоискаСПрефексом);
		ТекстПоляСНастройками = СтрШаблон("%1/%2", ТекстПоляСНастройками, СтрокаПоля.Порядок);
		ТекстПоляСНастройками = СтрШаблон("%1/%2", ТекстПоляСНастройками, СтрокаПоля.Отображать);
		
		ПоляПоискаСНастройками.Добавить(ТекстПоляСНастройками);
		
	КонецЦикла;
	
	ПоляПоискаСНастройками = СтрСоединить(ПоляПоискаСНастройками, ",");
	НастройкаВводаПоСтрокеНастройкиПолейСтрокой = ПоляПоискаСНастройками;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНаименованиеКнопокПолей()
	
	ИндексСтроки = 0;
	Для Каждого СтрокаПоля Из НастройкаВводаПоСтрокеНастройкиПолей Цикл
		СтрокаПоля.Порядок = ИндексСтроки;
		Элементы["ПолеПоискаВводаПоСтроке_" + ИндексСтроки].Заголовок = СтрокаПоля.ИмяПоля;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЭлементыНастроекВводаПоСтроке()
	
	Элементы.НастройкаВводаПоСтрокеПоказатьНеактуальные.Картинка =
		?(НастройкаВводаПоСтрокеПоказыватьНеактуальные,
		БиблиотекаКартинок.РМКАктивныйВыбор, БиблиотекаКартинок.РМКНеактивныйВыбор);
		
	Элементы.НастройкаВводаПоСтрокеИспользоватьНастройки.Картинка =
		?(НастройкаВводаПоСтрокеИспользовать,
		БиблиотекаКартинок.РМКАктивныйВыбор, БиблиотекаКартинок.РМКНеактивныйВыбор);
		
	ЦветАктивнойКнопки = ЦветаФормы.АктивнаяКнопка;
	ЦветНеАктивнойКнопки = ЦветаФормы.Авто;
	
	Элементы.НастройкаВводаПоСтрокеИспользоватьНастройки.ЦветФона =
		?(НастройкаВводаПоСтрокеИспользовать, ЦветАктивнойКнопки, ЦветНеАктивнойКнопки);
		
	Элементы.ГруппаНастройкаВводаПоСтрокеПоля.Доступность = НастройкаВводаПоСтрокеИспользовать;
	Элементы.НастройкаВводаПоСтрокеПереключитьНастройку.Доступность = НастройкаВводаПоСтрокеИспользовать;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьОтображениеНастроекПолейВводаПоСтроке()
	
	Если Не ИспользоватьБыстроеДобавлениеТовара Или РежимКассыСамообслуживания 
		Или Не НастройкаВводаПоСтрокеВозможноИспользовать Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ИмяПоляКаталога Из НастройкаВводаПоСтрокеИменаПолей Цикл
		
		ИмяКолонки = ИмяПоляКаталога.Значение;
		Отбор = Новый Структура("ИмяПоля", ИмяКолонки);
		СтрокиПолей = НастройкаВводаПоСтрокеНастройкиПолей.НайтиСтроки(Отбор);
		
		Если СтрокиПолей.Количество() = 0 Тогда
			СтрокаПоля = НастройкаВводаПоСтрокеНастройкиПолей.Добавить();
			СтрокаПоля.ИмяПоля = ИмяКолонки;
		КонецЕсли;
		
	КонецЦикла;
	
	ПорядковыйНомер = 0;
	Для Каждого СтрокаПоля Из НастройкаВводаПоСтрокеНастройкиПолей Цикл
		СтрокаПоля.Порядок = ПорядковыйНомер;
		ПорядковыйНомер = ПорядковыйНомер + 1;
	КонецЦикла;
	
	НастроитьКартинкиКнопок();
	ОбновитьНаименованиеКнопокПолей();
	ОбновитьЭлементыНастроекВводаПоСтроке();
	СформироватьСтрокуНастроекВводаПоСтроке();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьЭлементыНастроекВводаПоСтроке()
	
	Если Не ИспользоватьБыстроеДобавлениеТовара Или РежимКассыСамообслуживания 
		Или Не НастройкаВводаПоСтрокеВозможноИспользовать Тогда
		УстановитьВидимостьЭлементаФормы(Элементы.ГруппаНастройкаВводаПоСтроке, Ложь);
		Возврат;
	КонецЕсли;
	
	НастройкаВводаПоСтрокеИменаПолей.Очистить();
	НастройкаВводаПоСтрокеИменаПолей.Добавить("Наименование");
	НастройкаВводаПоСтрокеИменаПолей.Добавить("Код");
	НастройкаВводаПоСтрокеИменаПолей.Добавить("Артикул");
	НастройкаВводаПоСтрокеИменаПолей.Добавить("Штрихкод");
	НастройкаВводаПоСтрокеИменаПолей.Добавить("Цена");
	НастройкаВводаПоСтрокеИменаПолей.Добавить("SKU");
	
	ИмяРодительскойГруппы = "ГруппаНастройкаВводаПоСтрокеПоля";
	ЭлементГруппаПолей = Элементы[ИмяРодительскойГруппы];
	
	НомПП = 0;
	Для Каждого ИмяПоляКаталога Из НастройкаВводаПоСтрокеИменаПолей Цикл
		
		ИмяКолонки = НомПП;
		ИмяКоманды = "ПолеПоискаВводаПоСтроке_" + ИмяКолонки;
		НоваяКоманда = Команды.Добавить(ИмяКоманды);
		НоваяКоманда.Действие = "КомандаПолеПоискаВводаПоСтроке";
		НоваяКоманда.Заголовок = ИмяКолонки;
		
		КнопкаПолеПоискаКаталога = Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), ЭлементГруппаПолей);
		КнопкаПолеПоискаКаталога.ИмяКоманды = ИмяКоманды;
		КнопкаПолеПоискаКаталога.РастягиватьПоГоризонтали = Истина;
		КнопкаПолеПоискаКаталога.Высота = 2;
		КнопкаПолеПоискаКаталога.Картинка = БиблиотекаКартинок.ПоказатьПароль;
		КнопкаПолеПоискаКаталога.Отображение = ОтображениеКнопки.КартинкаИТекст;
		КнопкаПолеПоискаКаталога.ПоложениеКартинки = ПоложениеКартинкиКнопкиФормы.Лево;
		КнопкаПолеПоискаКаталога.Фигура = ФигураКнопки.Овал;
		
		НомПП = НомПП + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьКартинкиКнопок(ИмяПоля = "")
	
	Если ЗначениеЗаполнено(ИмяПоля) Тогда
		СтруктураОтбора = Новый Структура("ИмяПоля", ИмяПоля);
		СтрокиПолей = НастройкаВводаПоСтрокеНастройкиПолей.НайтиСтроки(СтруктураОтбора)
	Иначе
		
		НаименованиеНастройкиПолей = "";
		Если НастройкаВводаПоСтрокеТекущийРежим = 0 Тогда
			НаименованиеНастройкиПолей = НСтр("ru = 'Искать в:'");
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 1 Тогда
			НаименованиеНастройкиПолей = НСтр("ru = 'Искать с
			|префиксом ""*"" в:'");
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 2 Тогда
			НаименованиеНастройкиПолей = НСтр("ru = 'Приоритет:'");
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 3 Тогда
			НаименованиеНастройкиПолей = НСтр("ru = 'Отображать:'");
		КонецЕсли;
		Элементы.НастройкаВводаПоСтрокеПереключитьНастройку.Заголовок = НаименованиеНастройкиПолей;
		
		СтрокиПолей = НастройкаВводаПоСтрокеНастройкиПолей;
		
	КонецЕсли;
	
	Для Каждого СтрокаПоля Из СтрокиПолей Цикл
		Элемент = Элементы["ПолеПоискаВводаПоСтроке_" + СтрокаПоля.Порядок];
		
		КартинкаКнопки = Неопределено;
		ТекущееЗначение = Неопределено;
		Если НастройкаВводаПоСтрокеТекущийРежим = 0 Тогда
			ТекущееЗначение = СтрокаПоля.СпособПоиска;
			Если ТекущееЗначение = 1 Тогда
				КартинкаКнопки = БиблиотекаКартинок.Найти;
			ИначеЕсли ТекущееЗначение = 2 Тогда
				КартинкаКнопки = БиблиотекаКартинок.НайтиВСодержании;
			Иначе
				КартинкаКнопки = БиблиотекаКартинок.ОтменитьПоиск;
			КонецЕсли;
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 1 Тогда
			ТекущееЗначение = СтрокаПоля.СпособПоискаСПрефексом;
			Если ТекущееЗначение = 1 Тогда
				КартинкаКнопки = БиблиотекаКартинок.Найти;
			ИначеЕсли ТекущееЗначение = 2 Тогда
				КартинкаКнопки = БиблиотекаКартинок.НайтиВСодержании;
			Иначе
				КартинкаКнопки = БиблиотекаКартинок.ОтменитьПоиск;
			КонецЕсли;
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 2 Тогда
			ТекущееЗначение = СтрокаПоля.Порядок + 1;
			КартинкаКнопки = БиблиотекаКартинок["НомерИзбранногоТовара_" + ТекущееЗначение];
		ИначеЕсли НастройкаВводаПоСтрокеТекущийРежим = 3 Тогда
			ТекущееЗначение = СтрокаПоля.Отображать;
			КартинкаКнопки = ?(ТекущееЗначение, БиблиотекаКартинок.ПоказатьПароль, БиблиотекаКартинок.СкрытьПароль);
		КонецЕсли;
		
		Элемент.Картинка = КартинкаКнопки;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ЗаменаКарты
&НаКлиенте
Процедура ЗаменитьКарту(Команда)
	Элементы.ГруппаЗаменаКарты.Показать();
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьКартуВТаблицуЗамена(КартаНачисления = Ложь)
	ПолученаКарта = ЗначениеЗаполнено(Объект.ДисконтнаяКарта)
		Или ИнтерфейсРМКСлужебныйКлиентСервер.ПолученИдентификаторКартыЛояльности(ПараметрыКартыЛояльности);
	Если Не ПолученаКарта Тогда
		Возврат;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ДисконтнаяКарта) Тогда
		СтруктураОтбора = Новый Структура("ДисконтнаяКарта", Объект.ДисконтнаяКарта);
	Иначе
		СтруктураОтбора = Новый Структура("ИдентификаторКарты", ПараметрыКартыЛояльности.ИдентификаторКарты);
	КонецЕсли;
	СтрокиТаблицы = ТаблицаВыбранныхКарт.НайтиСтроки(СтруктураОтбора);
	
	Если СтрокиТаблицы.Количество() > 0 Тогда
		РежимЗаменыКарты = Ложь;
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = ТаблицаВыбранныхКарт.Добавить();
	Если ЗначениеЗаполнено(Объект.ДисконтнаяКарта) Тогда
		НоваяСтрока.ДисконтнаяКарта = Объект.ДисконтнаяКарта;
	Иначе
		НоваяСтрока.ИдентификаторКарты = ПараметрыКартыЛояльности.ИдентификаторКарты;
	КонецЕсли;
	НоваяСтрока.ОстатокБонусныхБаллов = КоличествоБонусов;
	НоваяСтрока.КодКарты = НайденнаяКартаНомер;
	НоваяСтрока.КурсБонусов = КурсБонусов;
	НоваяСтрока.КартаНачисления = КартаНачисления;
	Если НЕ КартаНачисления Тогда
		ШаблонКарты = НСтр("ru = '%1(%2)'");
		ПредставлениеКартыЗамена = СтрШаблон(ШаблонКарты, НайденнаяКартаФИО, НайденнаяКартаНомер);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НайтиИЗаменитьКарту(Команда)
	УстановитьЭлементыЗаменаКарты();
КонецПроцедуры

&НаКлиенте
Процедура СоздатьИЗаменитьКарту(Команда)
	УстановитьЭлементыЗаменаКарты(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьЗаменуКарты(Команда)
	ОтменитьЗаменуНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьЗаменуНаКлиенте()
	ОчиститьТаблицуКартЗамены();
	ПредставлениеКартыЗамена = НСтр("ru = ''");
	РежимЗаменыКарты = Ложь;
	УстановитьВидимостьЭлементаФормы(Элементы.ГруппаЗаменаКартыСоздание, РежимЗаменыКарты);
	УстановитьВидимостьЭлементаФормы(Элементы.ГруппаЗаменаКартыСоздание, РежимЗаменыКарты);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЭлементыЗаменаКарты(СоздатьНовую = Ложь)
	РежимЗаменыКарты = Истина;
	ДобавитьКартуВТаблицуЗамена();
	УстановитьВидимостьЭлементаФормы(Элементы.ГруппаЗаменаКартыСоздание, РежимЗаменыКарты);
	УстановитьВидимостьЭлементаФормы(Элементы.ГруппаЗаменаКартыСоздание, РежимЗаменыКарты);
	Если СоздатьНовую Тогда
		НомерТелефонаЗамена = НайденнаяКартаТелефон;
		ФИОЗамена = НайденнаяКартаФИО;
		ДатаРожденияЗамена = НайденнаяКартаДатаРождения;
		ПочтаЗамена = НайденнаяКартаПочта;
	КонецЕсли;
	ОтменитьВводКартыКлиент();
	Если СоздатьНовую Тогда
		РежимПанелиДанныеПокупателя = 1;
		СоздатьКартуЛояльности();
		Если ЗначениеЗаполнено(НомерТелефонаЗамена) Тогда
			НомерТелефонаЗамена = ИнтерфейсРМКСлужебныйКлиентСервер.ПривестиЗначениеКМаскеТелефона(НомерТелефонаЗамена,
				Элементы.НоваяКартаТелефон.Маска);
			НоваяКартаТелефон = НомерТелефонаЗамена;
		КонецЕсли;
		НоваяКартаФИО = ФИОЗамена;
		НоваяКартаДатаРождения = ДатаРожденияЗамена;
		НоваяКартаПочта = ПочтаЗамена;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьТаблицуКартЗамены()
	РазблокироватьБонусыТаблицыВыбранныхКарт();
	ТаблицаВыбранныхКарт.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьЗаменуКарты()
	Если НЕ РежимЗаменыКарты
		Или НЕ ВводДисконтныхКарт Тогда
		Возврат;
	КонецЕсли;
	
	Если ИспользоватьСерверЛояльностиПолучательДанных Тогда
		ОбъединитьДисконтныеКартыСерверЛояльности();
	Иначе
		СтруктураОтвета = Новый Структура("Error, ErrorMessage", Ложь, "");
		ОбъединитьДисконтныеКартыЛокально(СтруктураОтвета);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОграничениеОплаты
&НаКлиенте
Процедура УстановитьНастройкиОграниченияОплатыБаллами(УстановленоОграничение)
	
	УстановитьВидимостьЭлементаФормы(Элементы.ИнформацияОбОграничениях, УстановленоОграничение);
	Если УстановленоОграничение Тогда
		ШаблонДекорации = НСтр("ru = 'Оплата возможна, если остаток больше %1 баллов'");
		Элементы.ИнформацияОбОграничениях.Заголовок = СтрШаблон(ШаблонДекорации, КоличествоБонусовОграничение);
	Иначе
		КоличествоБонусовОграничение = 0;
		ШаблонДекорации = НСтр("ru = ''");
		Элементы.ИнформацияОбОграничениях.Заголовок = ШаблонДекорации;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область КомментарийПричинаВозврата

&НаКлиенте
Процедура ВвестиКомментарийПричинуВозвратаКлиент()
	
	ЭтоВозвратПродажи = ОбщегоНазначенияРМККлиент.ЭтоВидОперацииВозврат(Объект.ВидОперации);
	
	ПараметрыОткрытия = ПараметрыФормыВводаКомментарияПричиныВозврата();
	ПараметрыОткрытия.ВыводитьКомментарийКЧеку = ВыводитьКомментарийКЧеку;
	ПараметрыОткрытия.КомментарийКЧеку = КомментарийКЧеку;
	
	Если ЭтоВозвратПродажи И НЕ ЭтоЧекКоррекции Тогда
		ПараметрыОткрытия.УказыватьПричинуВозврата = УказыватьПричинуВозврата;
		ПараметрыОткрытия.ЗаголовокФормы = НСтр("ru = 'Причина возврата'");
		ПараметрыОткрытия.ПричинаВозврата = ПричинаВозврата;
	ИначеЕсли ЭтоЧекКоррекции Тогда
		ПараметрыОткрытия.ЗаголовокФормы = НСтр("ru = 'Комментарий к коррекции'");
	Иначе
		ПараметрыОткрытия.ЗаголовокФормы = НСтр("ru = 'Комментарий к продаже'");
	КонецЕсли;
	
	ОбработкаОповещения = Новый ОписаниеОповещения("ВвестиКомментарийПричинуВозвратаЗавершение",
		ЭтотОбъект);
	
	ОткрытьФорму("Обработка.РабочееМестоКассира.Форма.ФормаВводаКомментарияПричиныВозврата",
		ПараметрыОткрытия, ЭтотОбъект,,,, ОбработкаОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура УказатьПричинуВозврата(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		ВыборЧекаЗавершение(Результат, ДополнительныеПараметры);
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = ПараметрыФормыВводаКомментарияПричиныВозврата();
	ПараметрыОткрытия.ВыводитьКомментарийКЧеку = ВыводитьКомментарийКЧеку;
	ПараметрыОткрытия.УказыватьПричинуВозврата = Истина;
	ПараметрыОткрытия.ЗаголовокФормы = НСтр("ru = 'Причина возврата'");
	ПараметрыОткрытия.ВыборЧекаНаВозврат = Истина;
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("РезультатВыбораЧека", Результат);
	ПараметрыОповещения.Вставить("ДополнительныеПараметрыВыбораЧека", ДополнительныеПараметры);
	
	ОбработкаОповещения = Новый ОписаниеОповещения("ВвестиКомментарийПричинуВозвратаЗавершение",
		ЭтотОбъект, ПараметрыОповещения);
	
	ОткрытьФорму("Обработка.РабочееМестоКассира.Форма.ФормаВводаКомментарияПричиныВозврата",
		ПараметрыОткрытия, ЭтотОбъект,,,, ОбработкаОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиКомментарийПричинуВозвратаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеРезультата = ПараметрыФормыВводаКомментарияПричиныВозврата();
	ЗаполнитьЗначенияСвойств(ДанныеРезультата, Результат);
	
	Если ДанныеРезультата.ВыводитьКомментарийКЧеку Тогда
		КомментарийКЧеку = ДанныеРезультата.КомментарийКЧеку;
		УстановитьИконкуКомментарияКЧеку(Элементы.ВвестиКомментарийКЧеку, КомментарийКЧеку);
	КонецЕсли;
	Если ДанныеРезультата.УказыватьПричинуВозврата Тогда
		ПричинаВозврата = ДанныеРезультата.ПричинаВозврата;
		Элементы.ВвестиКомментарийКЧеку.Видимость = Не РежимПлитки;
	КонецЕсли;
	
	Если ДанныеРезультата.ВыборЧекаНаВозврат
		И ДополнительныеПараметры <> Неопределено
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДополнительныеПараметры,
			"РезультатВыбораЧека") Тогда
		
		РезультатВыбораЧека = Неопределено;
		ДополнительныеПараметрыВыбораЧека = Неопределено;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДополнительныеПараметры,
			"ДополнительныеПараметрыВыбораЧека") Тогда
			
			ДополнительныеПараметрыВыбораЧека = ДополнительныеПараметры.ДополнительныеПараметрыВыбораЧека;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ПричинаВозврата) Тогда
			РезультатВыбораЧека = ДополнительныеПараметры.РезультатВыбораЧека;
		КонецЕсли;
		ВыборЧекаЗавершение(РезультатВыбораЧека, ДополнительныеПараметрыВыбораЧека);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПараметрыФормыВводаКомментарияПричиныВозврата()
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВыборЧекаНаВозврат", Ложь);
	ПараметрыФормы.Вставить("ВыводитьКомментарийКЧеку", Ложь);
	ПараметрыФормы.Вставить("ЗаголовокФормы", "");
	ПараметрыФормы.Вставить("КомментарийКЧеку", "");
	ПараметрыФормы.Вставить("ПричинаВозврата", Неопределено);
	ПараметрыФормы.Вставить("УказыватьПричинуВозврата", Ложь);
	
	Возврат ПараметрыФормы;
	
КонецФункции

&НаКлиенте
Процедура НастроитьКнопкуВвестиКомментарийКЧеку()
	
	РежимПлиткиБезЗакрытияПриВыборе = РежимПлитки И НЕ ЗакрыватьПодборПриВыбореТовара;
	ЭтоВозвратПродажи = ОбщегоНазначенияРМККлиент.ЭтоВидОперацииВозврат(Объект.ВидОперации) И НЕ ЭтоЧекКоррекции;
	ВыводитьКомментарийПричинуВозвратов = ВыводитьКомментарийКЧеку ИЛИ (УказыватьПричинуВозврата И ЭтоВозвратПродажи);
	ПодходящийРежимИнтерфейса = (НЕ РежимКассыСамообслуживания) И (НЕ РежимПлитки ИЛИ РежимПлиткиБезЗакрытияПриВыборе);
	ВидимостьКнопкиВвестиКомментарийКЧеку = ВыводитьКомментарийПричинуВозвратов И ПодходящийРежимИнтерфейса;
	
	Элементы.ВвестиКомментарийКЧеку.Видимость = ВидимостьКнопкиВвестиКомментарийКЧеку;
	Если Элементы.ВвестиКомментарийКЧеку.Высота = 0 Тогда
		Элементы.ВвестиКомментарийКЧеку.Высота = 1;
	КонецЕсли;
	
	Если ВыводитьКомментарийКЧеку И УказыватьПричинуВозврата И ЭтоВозвратПродажи Тогда
		ЗаголовокПодсказки = НСтр("ru = 'Ввести комментарий и причину возврата'")
	ИначеЕсли НЕ ВыводитьКомментарийКЧеку И УказыватьПричинуВозврата И ЭтоВозвратПродажи Тогда
		ЗаголовокПодсказки = НСтр("ru = 'Ввести причину возврата'")
	Иначе
		ЗаголовокПодсказки = НСтр("ru = 'Ввести комментарий'")
	КонецЕсли;
	Элементы.ВвестиКомментарийКЧеку.РасширеннаяПодсказка.Заголовок = ЗаголовокПодсказки;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьИконкуКомментарияКЧеку(Элемент, КомментарийКЧеку)
	
	Если ЗначениеЗаполнено(КомментарийКЧеку) Тогда
		КартинкаКомментария = БиблиотекаКартинок.РМККомментарийЗаполнен;
	Иначе
		КартинкаКомментария = БиблиотекаКартинок.РМККомментарийПустой;
	КонецЕсли;
	
	Элемент.Картинка = КартинкаКомментария;
	
КонецПроцедуры

#КонецОбласти

#Область УточненияПринадлежностиЗапасов

&НаКлиенте
Процедура УстановитьПоставщикаТекущейСтроки(ТекущаяСтрока)
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Поставщик) Тогда
		Если ТекущаяСтрока.ЭтоАгентскаяУслуга Тогда
			ЗаголовокПоставщика = НСтр("ru = 'Агент:'");
		Иначе
			ЗаголовокПоставщика = НСтр("ru = 'Комитент:'");
		КонецЕсли;
		Элементы.ТекущийТоварПоставщик.Заголовок = СтрШаблон(" %1 %2", ЗаголовокПоставщика, ТекущаяСтрока.Поставщик);
		УстановитьВидимостьЭлементаФормы(Элементы.ТекущийТоварПоставщик, Истина);
	Иначе
		УстановитьВидимостьЭлементаФормы(Элементы.ТекущийТоварПоставщик, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьКэшУточненияПринадлежностиЗапасовКорзины()
	
	Если НЕ ИспользоватьУточненияПринадлежностиЗапасов Тогда
		Возврат;
	КонецЕсли;
	
	Если КэшиСтрокТоваров.Свойство("КэшПлитки") Тогда
		
		МассивНоменклатурыКСохранению = Новый Массив;
		
		Для Каждого СтрокаКэшаПлитки ИЗ КэшиСтрокТоваров.КэшПлитки Цикл
			
			ЭлементУточнения = КэшУточненияПринадлежностиЗапасов.Получить(СтрокаКэшаПлитки.Номенклатура);
			Если НЕ ЭлементУточнения = Неопределено Тогда
				Если МассивНоменклатурыКСохранению.Найти(СтрокаКэшаПлитки.Номенклатура) = Неопределено Тогда
					МассивНоменклатурыКСохранению.Добавить(СтрокаКэшаПлитки.Номенклатура);
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
		ОчищенныйКэшУточненияПринадлежностиЗапасов = Новый Соответствие;
		Для Каждого СоответствиеУточненияПринадлежности Из КэшУточненияПринадлежностиЗапасов Цикл
			Если НЕ МассивНоменклатурыКСохранению.Найти(СоответствиеУточненияПринадлежности.Ключ) = Неопределено Тогда
				ОчищенныйКэшУточненияПринадлежностиЗапасов.Вставить(СоответствиеУточненияПринадлежности.Ключ, СоответствиеУточненияПринадлежности.Значение);
			КонецЕсли;
		КонецЦикла;
		
		КэшУточненияПринадлежностиЗапасов = ОчищенныйКэшУточненияПринадлежностиЗапасов;
		
	Иначе
		
		КэшУточненияПринадлежностиЗапасов.Очистить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьИспользованиеУточненияПринадлежностиЗапасов()
	
	ОбщегоНазначенияРМК.УстановитьИспользованиеУточненияПринадлежностиЗапасов(ИспользоватьУточненияПринадлежностиЗапасов);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьОрганизаюКомитентаПоСпискуИдентификаторов()
	
	СписокИдентификаторов = СписокИдентификаторовСтрокДляУточнения.Скопировать();
	
	Для Каждого ИдентификаторСтроки ИЗ СписокИдентификаторов Цикл
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("ИдентификаторСтроки", ИдентификаторСтроки.Значение);
		
		СтрокиКорзины = Объект.Товары.НайтиСтроки(СтруктураОтбора);
		
		ОткрытаФормаУточнения = Ложь;
		Для Каждого СтрокаКорзины ИЗ СтрокиКорзины Цикл
			ЗаполнитьОрганизаюКомитентаПоУточнению(СтрокаКорзины, ОткрытаФормаУточнения);
		КонецЦикла;
		
		Если ОткрытаФормаУточнения Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьОрганизаюКомитентаПоУточнению(СтрокаТоваров, ОткрытаФормаУточнения = Ложь)
	
	Номенклатура = СтрокаТоваров.Номенклатура;
	
	МассивУточнений = КэшУточненияПринадлежностиЗапасов.Получить(Номенклатура);
	
	Если ЗначениеЗаполнено(МассивУточнений) Тогда
		ТорговыйОбъект = Объект.ТорговыйОбъект;
		Если ИспользоватьВыборСкладаПриПродаже Тогда
			ТорговыйОбъект = СтрокаТоваров.ТорговыйОбъект;
		КонецЕсли;
		Характеристика = СтрокаТоваров.Характеристика;
		Серия = СтрокаТоваров.Серия;
		
		ПодходящиеСтроки = Новый Массив;
		Для Каждого Уточнение Из МассивУточнений Цикл
			
			Если Уточнение.ТорговыйОбъект = ТорговыйОбъект И
				Уточнение.Характеристика = Характеристика И
				Уточнение.Серия = Серия Тогда
				
				ПодходящиеСтроки.Добавить(Уточнение);
				
			КонецЕсли;
			
		КонецЦикла;
		
		КоличествоПодходящихСтрок = ПодходящиеСтроки.Количество();
		
		Если КоличествоПодходящихСтрок = 1 Тогда
			
			Уточнение = ПодходящиеСтроки[0];
			ЗаполнитьУточненияПринадлежностиЗапасовВСтроке(СтрокаТоваров, Уточнение);
			
		ИначеЕсли КоличествоПодходящихСтрок > 1 Тогда
			
			СписокУточнений = Новый СписокЗначений;
			Для Каждого ПодходящаяСтрока ИЗ ПодходящиеСтроки Цикл
				СписокУточнений.Добавить(ПодходящаяСтрока);
				
				Если НЕ ЗначениеЗаполнено(ПодходящаяСтрока.ОрганизацияПродавец)
					И НЕ ЗначениеЗаполнено(ПодходящаяСтрока.Комитент) Тогда
					
					ВариантУточненияПринадлежностиСобственный = Новый Структура;
					ВариантУточненияПринадлежностиСобственный.Вставить("ИдентификаторСтроки", СтрокаТоваров.ИдентификаторСтроки);
					ВариантУточненияПринадлежностиСобственный.Вставить("Уточнение", ПодходящаяСтрока);
					
				КонецЕсли;
				
			КонецЦикла;
			
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("ИдентификаторСтроки", СтрокаТоваров.ИдентификаторСтроки);
			ПараметрыОткрытия.Вставить("СписокУточнений", СписокУточнений);
			
			ПредставлениеНоменклатуры =
				СтрШаблон(
					НСтр("ru = '%1%2%3'"),
					СтрокаТоваров.ПредставлениеНоменклатураХарактеристика,
					Символы.ПС,
					Серия);
			ПараметрыОткрытия.Вставить("Номенклатура", ПредставлениеНоменклатуры);
			
			ОповещениеУточнения = Новый ОписаниеОповещения("ОбработатьВыборУточненияПринадлежностиЗапасов", ЭтаФорма);
			
			Режим = РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс;
		
			ОткрытьФорму("Обработка.РабочееМестоКассира.Форма.ФормаУточненияПринадлежностиЗапасов",
						ПараметрыОткрытия, ЭтотОбъект, , , , 
						ОповещениеУточнения, Режим);
						
			ОткрытаФормаУточнения = Истина;
			
		КонецЕсли;
	КонецЕсли;
	
	НайденныйИдентификатор = СписокИдентификаторовСтрокДляУточнения.НайтиПоЗначению(СтрокаТоваров.ИдентификаторСтроки);
	Если НайденныйИдентификатор <> Неопределено Тогда
		СписокИдентификаторовСтрокДляУточнения.Удалить(НайденныйИдентификатор);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВыборУточненияПринадлежностиЗапасов(Результат, ДополнительныеПараметры) Экспорт
	
	УточнениеПринадлежности = ВариантУточненияПринадлежностиСобственный;
	Если ЗначениеЗаполнено(Результат) Тогда
		УточнениеПринадлежности = Результат;
	КонецЕсли;
	
	Если НЕ УточнениеПринадлежности = Неопределено Тогда
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("ИдентификаторСтроки", УточнениеПринадлежности.ИдентификаторСтроки);
		
		СтрокиКорзины = Объект.Товары.НайтиСтроки(СтруктураОтбора);
		
		Для Каждого СтрокаКорзины ИЗ СтрокиКорзины Цикл
			ЗаполнитьУточненияПринадлежностиЗапасовВСтроке(СтрокаКорзины, УточнениеПринадлежности.Уточнение);
		КонецЦикла;
		
	КонецЕсли;
	
	ВариантУточненияПринадлежностиСобственный = Неопределено;
	
	Если СписокИдентификаторовСтрокДляУточнения.Количество() > 0 Тогда
		ЗаполнитьОрганизаюКомитентаПоСпискуИдентификаторов();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьУточненияПринадлежностиЗапасовВСтроке(СтрокаТовара, Уточнение)
	
	Если ЗначениеЗаполнено(Уточнение.ОрганизацияПродавец)
		ИЛИ ЗначениеЗаполнено(Уточнение.Комитент)
		ИЛИ ЗначениеЗаполнено(Уточнение.СистемаНалогообложения) Тогда
		
		Если ЗначениеЗаполнено(Уточнение.ОрганизацияПродавец) Тогда
			СтрокаТовара.Организация = Уточнение.ОрганизацияПродавец;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Уточнение.СистемаНалогообложения) Тогда
			СтрокаТовара.СистемаНалогообложения = Уточнение.СистемаНалогообложения;
		КонецЕсли;
		
		СтрокаТовара.Поставщик = Уточнение.Комитент;
		СтрокаТовара.СтавкаНДС = Уточнение.СтавкаНДС;
		СтрокаТовара.СтавкаНДСУСН = Уточнение.СтавкаНДСУСН;
		
		ПересчитатьСуммы(СтрокаТовара, Истина);
		ОбщегоНазначенияРМККлиентСервер.УстановитьНомерКартинкиСтрокиТовара(СтрокаТовара);
		УстановитьПоставщикаТекущейСтроки(СтрокаТовара);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ВетРецепты

&НаКлиенте
Процедура НастроитьТекущийРецепт(ТекущаяСтрока)
	
	ЭтоВетТребование = ТекущаяСтрока.ЭтоВетТребование;
	ДатаВетРецепта = ТекущаяСтрока.ДатаВетРецепта;
	НомерВетРецепта = ТекущаяСтрока.НомерВетРецепта;
	
	Если ТекущаяСтрока.ПрепаратОтпускаетсяПоДокументу Тогда
		УстановитьВидимостьЭлементаФормы(Элементы.ГруппаВетРецептВертикальная, Истина);
	Иначе
		УстановитьВидимостьЭлементаФормы(Элементы.ГруппаВетРецептВертикальная, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтоВетТребованиеПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока.ЭтоВетТребование = ЭтоВетТребование;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаВетРецептаПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока.ДатаВетРецепта = ДатаВетРецепта;
	
КонецПроцедуры

&НаКлиенте
Процедура НомерВетРецептаПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока.НомерВетРецепта = НомерВетРецепта;
	
КонецПроцедуры

#КонецОбласти
