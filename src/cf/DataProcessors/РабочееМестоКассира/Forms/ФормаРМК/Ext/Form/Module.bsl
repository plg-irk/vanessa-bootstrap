&НаКлиенте
Процедура КомандаПолеКаталогаКнопка(Команда)
	
	НомерПоля = СтрЗаменить(Команда.Имя,"ПолеКаталогаКнопка_", "");
	СтруктураОтбора = Новый Структура("Порядок", Число(НомерПоля));
	СтрокиПолей = НастройкаКаталогаНастройкиПолей.НайтиСтроки(СтруктураОтбора);
	Если СтрокиПолей.Количество() > 0 Тогда
		СтрокаПоля = СтрокиПолей[0];
		ИмяПоля = СтрокаПоля.ИмяПоля;
		
		ИмяНастройки = "";
		Если НастройкаКаталогаТекущаяНастройкаПолей = 0 Тогда
			ИмяНастройки = "Видимость";
		ИначеЕсли НастройкаКаталогаТекущаяНастройкаПолей = 1 Тогда
			ИмяНастройки = "ИспользоватьПоискПоСтроке";
		ИначеЕсли НастройкаКаталогаТекущаяНастройкаПолей = 2 Тогда
			ИмяНастройки = "Порядок";
		ИначеЕсли НастройкаКаталогаТекущаяНастройкаПолей = 3 Тогда
			ИмяНастройки = "ИспользоватьПоискСПрефиксом";
		КонецЕсли;
		
		ТекущееЗначение = СтрокаПоля[ИмяНастройки];
		
		Если НастройкаКаталогаТекущаяНастройкаПолей = 0 Или НастройкаКаталогаТекущаяНастройкаПолей = 1
			Или НастройкаКаталогаТекущаяНастройкаПолей = 3 Тогда
			ТекущееЗначение = Не ТекущееЗначение;
			СтрокаПоля[ИмяНастройки] = ТекущееЗначение;
			НастроитьКнопкиПолейНастроекКаталога(ИмяПоля);
			ИменаПолей = Новый Массив;
			ИменаПолей.Добавить(ИмяПоля);
			Если НастройкаКаталогаТекущаяНастройкаПолей = 0 Тогда
				НастроитьВидимостьПолейКаталога(ИменаПолей, СтрокаПоля.Видимость);
				Если СтрокаПоля.ИспользоватьПоискПоСтроке Тогда
					НастроитьИспользованиеПоискаПолейКаталога(ИменаПолей, СтрокаПоля.Видимость);
				КонецЕсли;
			ИначеЕсли НастройкаКаталогаТекущаяНастройкаПолей = 1 Тогда
				НастроитьИспользованиеПоискаПолейКаталога(ИменаПолей, СтрокаПоля.ИспользоватьПоискПоСтроке);
			ИначеЕсли НастройкаКаталогаТекущаяНастройкаПолей = 3 Тогда
				НастроитьИспользованиеПоискаПолейКаталога(ИменаПолей, СтрокаПоля.ИспользоватьПоискПоСтроке);
			КонецЕсли;
		ИначеЕсли НастройкаКаталогаТекущаяНастройкаПолей = 2 Тогда
			Если ТекущееЗначение > 0 Тогда
				НастройкаКаталогаНастройкиПолей.Сдвинуть(ТекущееЗначение, -1);
				ОбновитьНаименованиеКнопокПолейНастроекКаталога();
				РасставитьКолонкиКаталога();
			КонецЕсли;
			НастроитьКнопкиПолейНастроекКаталога();
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
