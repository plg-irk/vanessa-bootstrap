КонецФункции

&НаСервере
Процедура ДополнитьСтрокуНаСервереПослеДобавленияНаКлиенте(ОбновитьДанныеРазливногоПива)
	
	СтрокаТовара = Объект.Товары.НайтиПоИдентификатору(ТекущийТоварИдентификатор);
	
	Если ОбновитьДанныеРазливногоПива Тогда
		ЗаполнитьДанныеКодовМаркировкиДляВыбора(СтрокаТовара);
		
		КодыМаркировкиДоступныеДляВыбора = КодыМаркировкиДоступныеДляВыбора(СтрокаТовара.КодыМаркировкиПоДаннымИБ, СтрокаТовара.ПредставлениеЕдиницыИзмерения);
		Если КодыМаркировкиДоступныеДляВыбора.Количество() = 1 Тогда
			СтрокаТовара.КодМаркировки = КодыМаркировкиДоступныеДляВыбора.Получить(0).Значение;
			СтрокаТовара.ТребуетсяПроверкаКодаМаркировки = Истина;
		Иначе
			Если ДанныеДобавляемогоТовара <> Неопределено И ДанныеДобавляемогоТовара.Свойство("КомментарийПодключенногоКега") Тогда
				Отбор = Новый Структура("КодМаркировкиПредставление", ДанныеДобавляемогоТовара.КомментарийПодключенногоКега);
				КодыМаркировкиПоКрану = СтрокаТовара.КодыМаркировкиПоДаннымИБ.НайтиСтроки(Отбор);
				Если КодыМаркировкиПоКрану.Количество() <> 0 Тогда
					СтрокаТовара.КодМаркировки = КодыМаркировкиПоКрану[КодыМаркировкиПоКрану.Количество() - 1].ПолныйКодМаркировки;
					СтрокаТовара.ТребуетсяПроверкаКодаМаркировки = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТовара.ТорговыйОбъект) Тогда
		ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьСНОСтрокиПоСкладу(СтрокаТовара, ЭтотОбъект);
	КонецЕсли;
	
	Если ОтображатьОстаток И Не ИспользуютсяСтатическиеОстаткиТоваров Тогда
		ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьКолонкуОстаток(СтрокаТовара, Объект.ТорговыйОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеСтрокиПоСкладу(СтрокаТаблицы)
	
	ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьСНОСтрокиПоСкладу(СтрокаТаблицы, ЭтотОбъект);
	
	Если ОтображатьОстаток Тогда
		ТорговыйОбъектОстатки = ?(НЕ ЗначениеЗаполнено(СтрокаТаблицы.ТорговыйОбъект), Объект.ТорговыйОбъект, СтрокаТаблицы.ТорговыйОбъект);
		ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьКолонкуОстаток(СтрокаТаблицы, ТорговыйОбъектОстатки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьСменуПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ТребуетсяВыемкаПриЗакрытииСмены = Ложь;
		ДенежныеСредстваВКассеККМ = 0;
		МинимальныйОстатокНаличныхВКассе = 0;
		СтруктураОтбора = Новый Структура("Организация, КассаККМ", Объект.Организация, Объект.КассаККМ);
		СтрокиКассККМ = ТаблицаКассККМОрганизаций.НайтиСтроки(СтруктураОтбора);
		Для Каждого СтрокаКассыККМ Из СтрокиКассККМ Цикл
			Если СтрокаКассыККМ.ТребуетсяВыемкаПриЗакрытииСмены Тогда
				ДенежныеСредстваВКассеККМ = СтрокаКассыККМ.ДенежныеСредстваВКассеККМ;
				МинимальныйОстатокНаличныхВКассе = СтрокаКассыККМ.МинимальныйОстатокНаличныхВКассе;
				
				ТребуетсяВыемкаПриЗакрытииСмены = СтрокаКассыККМ.ТребуетсяВыемкаПриЗакрытииСмены И (ДенежныеСредстваВКассеККМ - МинимальныйОстатокНаличныхВКассе > 0);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ТребуетсяВыемкаПриЗакрытииСмены Тогда
			ПараметрыЗакрытияСменыПриАвтоматическойВыемке.ВыемкаПриЗакрытииСмены = Истина;
			ПараметрыЗакрытияСменыПриАвтоматическойВыемке.ДополнительныеПараметры = ДополнительныеПараметры;
			СуммаВыемка = ДенежныеСредстваВКассеККМ - МинимальныйОстатокНаличныхВКассе;
			
			ОткрытьСтраницуВыемкиДенежныхСредств();
		Иначе
			ЗакрытьСменуЗавершение(Результат, ДополнительныеПараметры);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьСостояниеКассовойСменыВызовСервера(ПоказыватьСтатусСмен)
	
	ПроверитьВозможностьРаботы();
	
	Если ИспользоватьОплатуНаличными Тогда
		СписокСмен = ТаблицаКассККМОрганизаций;
		Если ЗначениеЗаполнено(КассаККМДляОперации) Тогда
			Отбор = Новый Структура("КассаККМ", КассаККМДляОперации);
			СтрокиКассы = ТаблицаКассККМОрганизаций.НайтиСтроки(Отбор);
			Если ЗначениеЗаполнено(СтрокиКассы) Тогда
				СписокСмен = СтрокиКассы;
			КонецЕсли;
		КонецЕсли;
		
		ЗафиксироватьНаличныеДенежныеСредстваСмены(СписокСмен);
	КонецЕсли;
	
	Если ПоказыватьСтатусСмен Тогда
		АктуализироватьСостояниеСтатусаКассовыхСменСервер();
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ВывестиРазделУчетаНаличных(Макет, ОтчетЗаСмену, КлиентскиеДанныеОтчетаЗаСмену, СерверныеДанныеОтчетаЗаСмену, ОтборКасса)
	
	НаличныеНаНачалоСмены = 0;
	СуммаВнесений = 0;
	СуммаВыемок = 0;
	ПриходНаличных = 0;
	РасходНаличных = 0;
	ТекущийОстатокНаличных = 0;
	ИтогоНаличных = 0;
	
	ОтборСтрокКассы = Новый Структура("Касса", ОтборКасса);
	
	Кассы = СерверныеДанныеОтчетаЗаСмену.ТаблицаКасс.НайтиСтроки(ОтборСтрокКассы);
	Если Кассы.Количество() > 0 Тогда
		СтрокаКассы = Кассы[0];
		НаличныеНаНачалоСмены = СтрокаКассы.НаличныеНаНачало;
		ТекущийОстатокНаличных = СтрокаКассы.НаличныеТекущийОстаток;
		СуммаВнесений = СтрокаКассы.СуммаВнесений;
		СуммаВыемок = СтрокаКассы.СуммаВыемок;
	КонецЕсли;
	Суммы = СерверныеДанныеОтчетаЗаСмену.ТаблицаСумм.НайтиСтроки(ОтборСтрокКассы);
	Для Каждого СтрокаСуммы Из Суммы Цикл
		
		Если СтрокаСуммы.ВидОплаты = "Наличные" Тогда
			ПриходНаличных = ПриходНаличных + СтрокаСуммы.СуммаПродаж;
			РасходНаличных = РасходНаличных + СтрокаСуммы.СуммаВозвратов;
		КонецЕсли;
		РасходНаличных = РасходНаличных + СтрокаСуммы.СуммаВыдачиНаличных;
		
	КонецЦикла;
	
	Если КлиентскиеДанныеОтчетаЗаСмену.ИспользоватьОплатуНаличными Тогда
	
		ОбластьУчетНаличных = Макет.ПолучитьОбласть("УчетНаличных");
		ОбластьУчетНаличных.Параметры.НаличныеНаНачалоСмены = НаличныеНаНачалоСмены;
		ОбластьУчетНаличных.Параметры.СуммаВнесений = СуммаВнесений;
		ОбластьУчетНаличных.Параметры.СуммаВыемок = -СуммаВыемок;
		ОбластьУчетНаличных.Параметры.ПриходНаличных = ПриходНаличных;
		ОбластьУчетНаличных.Параметры.РасходНаличных = -РасходНаличных;
		ОбластьУчетНаличных.Параметры.ИтогоНаличных = НаличныеНаНачалоСмены + СуммаВнесений - СуммаВыемок + ПриходНаличных - РасходНаличных;
		
		ОбластьУчетНаличных.Параметры.ТекущийОстатокНаличных = ТекущийОстатокНаличных;
		
		ОтчетЗаСмену.Вывести(ОбластьУчетНаличных);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВызватьПолныйАвтоматическийРасчетСкидок()
	
	Если (РежимРаботыСЧеком = РежимыРаботыСЧеком.ВводТоваров Или РежимРаботыСЧеком = РежимыРаботыСЧеком.ЧекПустой)
		И ПолныйРасчетСкидок
		И Не РаботаВРежимеМедленногоСоединения Тогда
		
		РассчитатьСкидкиКлиент();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеДляОтправкиЧека(ПочтаКонтрагента, ТелефонКонтрагента)
	
	ОтправкаЧекаПочта	= ПочтаКонтрагента;
	ОтправкаЧекаТелефон	= ТелефонКонтрагента;
		
КонецПроцедуры

&НаСервере
Процедура ОчиститьТаблицуПлатежныхКарт()
	
	Если КоличествоДополнительныхКарт = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ИндексСтроки = 0;
	Пока ИндексСтроки < КоличествоДополнительныхКарт Цикл
		Если ИспользоватьОплатуНесколькимиКартами И ИндексСтроки < 2 Тогда
			УдалитьРеквизитыОплатыКартой(Строка(ИндексСтроки));
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	ТаблицаОплатКартой.Очистить();
	КоличествоДополнительныхКарт = 0;
	УстановитьДоступностьЭлементаФормы(Элементы.ГруппаВидОплатыКартойГоризонтально, Истина);
	
КонецПроцедуры

&НаСервере
Процедура НастроитьПодсказкуПлатежнойСистемыВозврата()

	ДанныеВыбора	= Новый СписокЗначений;
	
	ИнтеграцияСПлатежнымиСистемамиРМКВызовСервера.ПодобратьПлатежнуюСистему(ДанныеВыбора, "#топ");
	
	Если ДанныеВыбора.Количество()
		И Не ЗначениеЗаполнено(Элементы.ПлатежнаяСистемаРасширеннаяПодсказка.Заголовок) Тогда
		
		МассивСтрок 	= Новый Массив;
		МассивСтрок.Добавить(НСтр("ru = 'Заполните банк карты покупателя. Например, '"));
		
		Для Каждого ЗначениеСписка Из ДанныеВыбора Цикл

			МассивСтрок.Добавить(Новый ФорматированнаяСтрока(ЗначениеСписка.Представление,,,, ЗначениеСписка.Значение));
			МассивСтрок.Добавить(НСтр("ru = ', '"));
			
		КонецЦикла;
		
		МассивСтрок.Удалить(МассивСтрок.ВГраница());
		МассивСтрок.Добавить(НСтр("ru = '.'"));
		
		Элементы.ПлатежнаяСистемаРасширеннаяПодсказка.Заголовок = Новый ФорматированнаяСтрока(МассивСтрок);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитыОплатыКартой(ИндексЭлемента)
	
	ПараметрыУвеличенногоИнтерфейса = ИнтерфейсРМКСлужебный.ПараметрыУвеличенногоИнтерфейса(ВидОтображения);
	ШрифтСуммы = ?(ВидОтображения = Перечисления.ВидыОтображения.Увеличенный, ПараметрыУвеличенногоИнтерфейса.ШрифтСуммОплат, ШрифтыСтиля.ШрифтОбычныйПолужирныйРМК);
	
	// Добавляем реквизиты на форму
	ДобавляемыеРеквизиты = Новый Массив;
	
	ТипРеквизита  = Новый ОписаниеТипов(Метаданные.ОпределяемыеТипы.НеотрицательноеЧисло15_2_РМК.Тип);
	ИмяРеквизита  = "СуммаОплаченоБН_" + ИндексЭлемента;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтотОбъект, ИмяРеквизита) Тогда
		Возврат;
	КонецЕсли;
	РеквизитФормы = Новый РеквизитФормы(ИмяРеквизита, ТипРеквизита);
	
	ДобавляемыеРеквизиты.Добавить(РеквизитФормы);
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	ЭтотОбъект[ИмяРеквизита] = 0;
	
	ИмяГруппы = "ГруппаВидОплатыКартойГоризонтально_" + ИндексЭлемента;
	ГруппаЭлементов = Элементы.Добавить(ИмяГруппы, Тип("ГруппаФормы"), Элементы.ГруппаВидОплатыКартой);
	ГруппаЭлементов.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаЭлементов.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаЭлементов.ОтображатьЗаголовок = Ложь;
	ГруппаЭлементов.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаЭлементов.РастягиватьПоГоризонтали = Истина;
	
	ИмяКнопки = "ОплатаКартой_" + ИндексЭлемента;
	НоваяКнопка = Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"), ГруппаЭлементов);
	НоваяКнопка.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	НоваяКнопка.ИмяКоманды = "ОплатаКартой";
	НоваяКнопка.Шрифт = ШрифтыСтиля.ШрифтОбычныйПолужирныйРМК;
	НоваяКнопка.Ширина = 12;
	НоваяКнопка.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	Если ВидОтображения = Перечисления.ВидыОтображения.Увеличенный Тогда
		НоваяКнопка.Высота = 2;
	КонецЕсли;
	
	ИмяГруппыСтраниц = "СтраницыОплатыКартой_" + ИндексЭлемента;
	ГруппаСтраниц = Элементы.Добавить(ИмяГруппыСтраниц, Тип("ГруппаФормы"), ГруппаЭлементов);
	ГруппаСтраниц.Вид = ВидГруппыФормы.Страницы;
	ГруппаСтраниц.ОтображениеСтраниц = ОтображениеСтраницФормы.Нет;
	ГруппаСтраниц.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
	
	ИмяГруппыОплаты = "ГруппаОплатаКартой_" + ИндексЭлемента;
	ГруппаЭлементовОплаты = Элементы.Добавить(ИмяГруппыОплаты, Тип("ГруппаФормы"), ГруппаСтраниц);
	ГруппаЭлементовОплаты.Вид = ВидГруппыФормы.Страница; 
	ГруппаЭлементовОплаты.Видимость = Ложь;
	ГруппаЭлементовОплаты.ОтображатьЗаголовок = Ложь;
	ГруппаЭлементовОплаты.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаЭлементовОплаты.РастягиватьПоГоризонтали = Истина;
	ГруппаЭлементовОплаты.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Право;
	
	ПоказатьКнопкуВыбора = (Не (СкрытьЦифровуюКлавиатуру Или РежимКассыСамообслуживания));
	ПолеЭталон = Элементы.СуммаОплаченоБН;
	ПолеСуммаОплатыБН = Элементы.Добавить(ИмяРеквизита, Тип("ПолеФормы"), ГруппаЭлементовОплаты);
	ПолеСуммаОплатыБН.ПутьКДанным = ИмяРеквизита;
	ПолеСуммаОплатыБН.Вид = ВидПоляФормы.ПолеВвода;
	ПолеСуммаОплатыБН.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ПолеСуммаОплатыБН.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	ПолеСуммаОплатыБН.КнопкаВыбора = ПоказатьКнопкуВыбора;
	ПолеСуммаОплатыБН.Ширина = ПолеЭталон.Ширина;
	ПолеСуммаОплатыБН.Шрифт = ШрифтСуммы;
	Если ПоказатьКнопкуВыбора Тогда
		ПолеСуммаОплатыБН.КартинкаКнопкиВыбора = БиблиотекаКартинок.РМКЦифроваяПанель;
	КонецЕсли;
	ПолеСуммаОплатыБН.УстановитьДействие("ПриИзменении", "СуммаОплаченоБНПриИзменении");
	ПолеСуммаОплатыБН.УстановитьДействие("НачалоВыбора", "СуммаОплаченоБННачалоВыбора");
	ПолеСуммаОплатыБН.УстановитьДействие("АвтоПодбор", "СуммаОплаченоБНАвтоПодбор");
	ПолеСуммаОплатыБН.УстановитьДействие("ОкончаниеВводаТекста", "СуммаОплаченоБНОкончаниеВводаТекста");
	
	ИмяГруппыПодсказки = "ГруппаПодсказкаОплатаКартой_" + ИндексЭлемента;
	ГруппаЭлементовПодсказки = Элементы.Добавить(ИмяГруппыПодсказки, Тип("ГруппаФормы"), ГруппаСтраниц);
	ГруппаЭлементовПодсказки.Вид = ВидГруппыФормы.Страница;
	ГруппаЭлементовПодсказки.ОтображатьЗаголовок = Ложь;
	ГруппаЭлементовПодсказки.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьРеквизитыОплатыКартой(ИндексОплатыКартой)
	
	ИндексЧислом = Число(ИндексОплатыКартой);
	ИндексУдаления = Строка(ИндексЧислом + 1);
	НаименованиеУдаляемогоРеквизита = "СуммаОплаченоБН_" + ИндексУдаления;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтотОбъект, НаименованиеУдаляемогоРеквизита) Тогда
		
		УдаляемыеРеквизиты = Новый Массив;
		УдаляемыеРеквизиты.Добавить("СуммаОплаченоБН_" + ИндексУдаления);
		ИзменитьРеквизиты(, УдаляемыеРеквизиты);
		
		УдалитьЭлементФормы("ГруппаВидОплатыКартойГоризонтально_" + ИндексУдаления);
		УдалитьЭлементФормы("ОплатаКартой_" + ИндексУдаления);
		УдалитьЭлементФормы("СтраницыОплатыКартой_" + ИндексУдаления);
		УдалитьЭлементФормы("ГруппаОплатаКартой_" + ИндексУдаления);
		УдалитьЭлементФормы("ГруппаПодсказкаОплатаКартой_" + ИндексУдаления); 
		УдалитьЭлементФормы("СуммаОплаченоБН_" + ИндексУдаления);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСуммуОплатыЧека(СуммаОперации, ЭтоПродажа = Истина)
	
	СтруктураОтбора = ВыбраннаяОрганизацияИСНО();
	СтруктураОтбора.Вставить("Сумма", СуммаОперации);
	СтруктураОтбора.Вставить("Оплачено", Не ЭтоПродажа);
	СтрокиОплаты = ТаблицаОплатКартой.НайтиСтроки(СтруктураОтбора);
	Если СтрокиОплаты.Количество() > 0 Тогда
		СтрокаОплатыКартой = СтрокиОплаты[0];
		СтрокаОплатыКартой.Оплачено = ЭтоПродажа;
	КонецЕсли;
	
	Отказ = Ложь;
	ТекстОшибки = "";
	
	ДополнительныеДанные = ДополнительныеДанныеДляФискализации();
	ОбщегоНазначенияРМККлиентПереопределяемый.ЗаполнитьДополнительныеДанныеДляПробитияЧека(ЭтотОбъект,
		ДополнительныеДанные);
	ЗаписатьЧекККМПередПробитием(ДополнительныеДанные, Отказ, ТекстОшибки);
	ОбновитьРеквизитыФормыПослеПодготовкиДанныхДляЧека(ДополнительныеДанные);
	
	СтруктураОтбора = ВыбраннаяОрганизацияИСНО();
	СтруктураОтбора.Вставить("Оплачено", ЭтоПродажа);
	
	СуммаОплаченоБНЧастично = 0;
	СтрокиОплаты = ТаблицаОплатКартой.НайтиСтроки(СтруктураОтбора);
	Для Каждого СтрокаОплаты Из СтрокиОплаты Цикл
		СуммаОплаченоБНЧастично = СуммаОплаченоБНЧастично + СтрокаОплаты.Сумма;
	КонецЦикла;
	Если СуммаОплаченоБН = СуммаОплаченоБНЧастично Тогда
		ТранзакцияПоКартеЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРеквизитыФормыПослеПодготовкиДанныхДляЧека(ДополнительныеДанные)
	
	ЧекККМВОбработке = ДополнительныеДанные.РеквизитыФормы.ЧекККМВОбработке;
	ОбщегоНазначенияРМККлиентПереопределяемый.ОбновитьРеквизитыФормыПослеПодготовкиДанныхДляЧека(ЭтотОбъект,
		ДополнительныеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТекстКороткогоСлипЧека(РезультатВыполнения)
	
	СтруктураОтбора = ВыбраннаяОрганизацияИСНО();
	СтрокиОплаты = ТаблицаОплатКартой.НайтиСтроки(СтруктураОтбора);
	
	Если СтрокиОплаты.Количество() > 1 ИЛИ НЕ ПечататьКороткийСлипЧек Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерОборудованияРМККлиент.ЗаполнитьТекстКороткогоСлипЧека(РезультатВыполнения);
	
КонецПроцедуры

&НаКлиенте
Процедура ИнициализироватьВводПредоплатыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не Результат = Неопределено Тогда
		БольшеНеПоказыватьСообщениеВыбораКонтрагента = Результат.БольшеНеПоказывать;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьДоступностьОтправкиЧекаПриИзмененииТелефона(ТекстТелефонаЗаполнен)

	УстановитьДоступностьЭлементаФормы(Элементы.ОтправкаЧекаПочта, НЕ ТекстТелефонаЗаполнен);
	ИнтерфейсРМКСлужебныйКлиент.НастроитьСвойстваКнопкиПробитьИОтправить(ЭтотОбъект, Ложь, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКВозвратуЧека(Знач ЧекНаВозврат)
	
	Результат = Новый Структура("ЧекККМ", ЧекНаВозврат);
	УстановитьДоступностьЭлементаФормы(Элементы.ГруппаВидовОплат, Истина);
	Объект.ВидОперации = ОбщегоНазначенияРМККлиент.ВидТекущейОперации(Истина);
	КассирДоЗаменыПрав = Объект.Кассир;
	ВыборЧекаЗавершение(Результат, Неопределено);
	
КонецПроцедуры

&НаСервере
Процедура АктуализироватьПервоначальноеСостояниеСтатусаКассовыхСмен(НастройкиЭлементов)
	
	Если ЗначениеЗаполнено(ТекущаяНастройкаРМК) И (Не РежимКассыСамообслуживания)
			И ИнтерфейсРМКСлужебныйКлиентСервер.ПоказыватьСтатусКассовыхСмен(НастройкиЭлементов) Тогда
		АктуализироватьСостояниеСтатусаКассовыхСменСервер();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура АктуализироватьСостояниеСтатусаКассовыхСменСервер()
	
	СтатусСменИзменился = Ложь;
	ДатаТекущая = ТекущаяДатаСеанса();
	ГрупповойСтатусСмен = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьГрупповойСтатусКассовыхСмен(ЭтотОбъект, ДатаТекущая,
		СтатусСменИзменился);
	Если СтатусСменИзменился Тогда
		ИнтерфейсРМКСлужебный.ОбновитьКнопкуСтатусаКассовыхСмен(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АктуализироватьСостояниеСтатусаКассовыхСменПриНеобходимостиКлиент()
	
	Если (Не РежимКассыСамообслуживания)
			И ИнтерфейсРМКСлужебныйКлиентСервер.ПоказыватьСтатусКассовыхСмен(СвойстваНастроекЭлементов) Тогда
		
		СтатусСменИзменился = Ложь;
		ДатаТекущая = ОбщегоНазначенияКлиент.ДатаСеанса();
		ГрупповойСтатусСмен = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьГрупповойСтатусКассовыхСмен(ЭтотОбъект, ДатаТекущая,
			СтатусСменИзменился);
		Если СтатусСменИзменился Тогда
			ОбновитьКнопкуСтатусаКассовыхСмен();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКнопкуСтатусаКассовыхСмен()
	ИнтерфейсРМКСлужебный.ОбновитьКнопкуСтатусаКассовыхСмен(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтатусыТСПИоТ()
	
	ТСПИоТГотов = ТСПИоТГотовКРаботе();
	
	Если ТСПИоТГотов Тогда
		
		ОтключитьОбработчикОжидания("ОбновитьСтатусыТСПИоТ");
		Возврат;
		
	КонецЕсли;
	
	Для каждого СтрокаКассы Из ТаблицаКассККМОрганизаций Цикл
		
		СменаАктуальна = СтрокаКассы.Открыта И СтрокаКассы.ДатаИстеченияСрокаДействия > ОбщегоНазначенияКлиент.ДатаСеанса();
		
		Если СменаАктуальна И СтрокаКассы.НастроенТСПИоТ И СтрокаКассы.АвторизацияПройденаТСПИоТ Тогда
			
			ПолучитьСтатусТСПИоТ(СтрокаКассы);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьДанныеСтатусовТСПИоТ()
	
	Для каждого СтрокаКассы Из ТаблицаКассККМОрганизаций Цикл
		
		ОбработатьСтрокуККТТСПИоТ(СтрокаКассы);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуККТТСПИоТ(СтрокаКассы)
	
	СменаАктуальна = СтрокаКассы.Открыта И СтрокаКассы.ДатаИстеченияСрокаДействия > ОбщегоНазначенияКлиент.ДатаСеанса();
	
	Если СтрокаКассы.НастроенТСПИоТ Тогда
		
		Если СменаАктуальна Тогда
			
			Если СтрокаКассы.АвторизацияПройденаТСПИоТ Тогда
				
				ПолучитьСтатусТСПИоТ(СтрокаКассы);
				
			Иначе
				
				АвторизоватьТСПИоТ(СтрокаКассы);
				
			КонецЕсли;
			
		Иначе
			
			ОбновитьСтатусТСПИоТ(Неопределено, СтрокаКассы.ИдентификаторУстройства);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АвторизоватьТСПИоТ(СтрокаКассы)
	
	ПаратмерыАвторизации = Новый Структура;
	ПаратмерыАвторизации.Вставить("ККТ", СтрокаКассы.ИдентификаторУстройства);
	ПаратмерыАвторизации.Вставить("ВнешнийТСПИоТ", СтрокаКассы.ВнешнийТСПИоТ);
	
	ПослеАвторизацииТСПИоТ = Новый ОписаниеОповещения("ПослеАвторизацииТСПИоТ", ЭтотОбъект, ПаратмерыАвторизации);
	
	ОбщегоНазначенияРМККлиентПереопределяемый.АвторизоватьТСПИоТ(ПослеАвторизацииТСПИоТ, ПаратмерыАвторизации, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьСтатусТСПИоТ(СтрокаКассы)
	
	ПаратмерыАвторизации = Новый Структура;
	ПаратмерыАвторизации.Вставить("ККТ", СтрокаКассы.ИдентификаторУстройства);
	ПаратмерыАвторизации.Вставить("ВнешнийТСПИоТ", СтрокаКассы.ВнешнийТСПИоТ);
	
	ПослеПолученияСтатусовТСПИоТ = Новый ОписаниеОповещения("ПослеПолученияСтатусовТСПИоТ", ЭтотОбъект, ПаратмерыАвторизации);
	
	ОбщегоНазначенияРМККлиентПереопределяемый.ПолучитьСтатусТСПИоТ(ПослеПолученияСтатусовТСПИоТ, ПаратмерыАвторизации, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеАвторизацииТСПИоТ(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат.Свойство("Результат") И Результат.Результат Тогда
		
		Если Результат.Свойство("СтатусСостояния") И Результат.СтатусСостояния <> Неопределено Тогда
			
			ОбновитьСтатусТСПИоТ(Результат.СтатусСостояния, ДополнительныеПараметры.ККТ);
			
		КонецЕсли;
		
		Отбор = Новый Структура("ИдентификаторУстройства", ДополнительныеПараметры.ККТ);
		СтрокиКасс = ТаблицаКассККМОрганизаций.НайтиСтроки(Отбор);
		
		Для Каждого СтрокаКассы Из СтрокиКасс Цикл
			Если СтрокаКассы.АвторизацияПройденаТСПИоТ Тогда
				
				ПолучитьСтатусТСПИоТ(СтрокаКассы);
				
			КонецЕсли;
		КонецЦикла;		
		
	Иначе
		
		ОбновитьСтатусТСПИоТ(Неопределено, ДополнительныеПараметры.ККТ);
		
		Если Результат.Свойство("ОписаниеОшибки") И ЗначениеЗаполнено(Результат.ОписаниеОшибки) Тогда
			
			ТекстЗаголовка = НСтр("ru = 'Ошибка авторизации ТС ПиОТ.'");
			ТекстОшибки = Результат.ОписаниеОшибки;
			ПараметрыОшибки = Новый Структура("ЭтоПредупреждение", Истина);
			ОткрытьСтраницуИнфоОшибка(ТекстЗаголовка, ТекстОшибки, ПараметрыОшибки);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПолученияСтатусовТСПИоТ(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат.Свойство("Результат") И Результат.Результат Тогда
		
		Если Результат.Свойство("СтатусСостояния") И Результат.СтатусСостояния <> Неопределено Тогда
			
			ОбновитьСтатусТСПИоТ(Результат.СтатусСостояния, ДополнительныеПараметры.ККТ);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтатусТСПИоТ(Статус, ККТ)
	
	Отбор = Новый Структура("ИдентификаторУстройства", ККТ);
	СтрокиКасс = ТаблицаКассККМОрганизаций.НайтиСтроки(Отбор);
	
	Для Каждого СтрокаКассы Из СтрокиКасс Цикл
		Если Статус = Неопределено Тогда
			
			СтрокаКассы.ГотовКРаботеТСПИоТ = Ложь;
			СтрокаКассы.АвторизацияПройденаТСПИоТ = Ложь;
			
		Иначе
			
			СтрокаКассы.АвторизацияПройденаТСПИоТ = Статус.АвторизацияПройдена Или Статус.РегистрацияПройдена;
			СтрокаКассы.АварийныйРежимТСПИоТ = Статус.АварийныйРежим;
			СтрокаКассы.ГотовКРаботеТСПИоТ = Статус.ГотовКПроверкеКМ И (Статус.ГотовКПроверкеКМOnline
			Или Статус.ГотовКПроверкеКМOffline) И Не Статус.АварийныйРежим;
			
		КонецЕсли;
		
		ПоказыватьСтатусСмен = (Не РежимКассыСамообслуживания)
			И ИнтерфейсРМКСлужебныйКлиентСервер.ПоказыватьСтатусКассовыхСмен(СвойстваНастроекЭлементов);
		
		Если ПоказыватьСтатусСмен Тогда
			
			ОбновитьОтображениеСтатусаТСПИоТ();
			
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтображениеСтатусаТСПИоТ()
	
	ТСПИоТГотов = ТСПИоТГотовКРаботе();
	
	Если ТСПИоТГотов Тогда
		
		Иконка = БиблиотекаКартинок.РМКУспешноеСканирование;
		
	Иначе
		
		Иконка = БиблиотекаКартинок.РМКОшибкаСканирования;
		
	КонецЕсли;
	
	Элементы.ДекорацияСтатусТСПИоТ.Картинка = Иконка;
	
	НастроитьСтраницуВыбораКассККМ();
	
КонецПроцедуры

&НаКлиенте
Функция ТСПИоТГотовКРаботе()
	
	ТСПИоТГотов = Ложь;
	
	Для каждого ККТ Из ТаблицаКассККМОрганизаций Цикл
		
		Если ККТ.НастроенТСПИоТ Тогда
			
			ТСПИоТГотов = ККТ.ГотовКРаботеТСПИоТ;
			
		Иначе
			
			Продолжить;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТСПИоТГотов;
	
КонецФункции // ТСПИоТГотов()

&НаСервереБезКонтекста
Функция ПолучитьПараметрыАварийногоРежима()
	
	ПараметрыАварийногоРежима = ОбщегоНазначенияИСМППовтИсп.ДанныеНастройкиАварийногоРежима();
	
	Возврат ПараметрыАварийногоРежима;
	
КонецФункции

&НаКлиенте
Процедура ПослеОбработкиФормыУточненияАварийногоРежима(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Свойство("АктивностьРежима") Тогда
		
		Если Результат.АктивностьРежима Тогда
			// включение аварийного режима
			ОбщегоНазначенияИСМПВызовСервера.ВключитьАварийныйРежимРазрешительнойСистемы(Результат.СрокДействияВЧасах);
			
		Иначе
			// отключение аварийного режима
			ОбщегоНазначенияИСМПВызовСервера.ОтключитьАварийныйРежимРазрешительнойСистемы();
			
		КонецЕсли;
		
		ПараметрыАварийногоРежима = ПолучитьПараметрыАварийногоРежима();
		ОбновитьПредставлениеАварийногоРежима();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПредставлениеАварийногоРежима()
	
	Если Не ПараметрыАварийногоРежима.Включено Тогда
		
		ОбработатьДанныеСтатусовТСПИоТ();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокКнопкеЗакрытьОткрытьСмену(ЗаголовокКнопки)
	
	ИдентификаторКнопки = Элементы.ЗакрытьСмену.Имя;
	Элементы.ЗакрытьСмену.Заголовок = ЗаголовокКнопки;
	СтрокаКнопки = СписокКомандЕще.НайтиПоЗначению(ИдентификаторКнопки);
	Если Не СтрокаКнопки = Неопределено Тогда
		СтрокаКнопки.Представление = ЗаголовокКнопки;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция  СоздатьДокументКассоваяСменаБезТО(ПараметрыКассовойСмены, Отказ)
	
	Возврат ОбщегоНазначенияРМК.ОткрытьКассовуюСменуБезОборудования(Отказ, ПараметрыКассовойСмены);
	
КонецФункции

&НаКлиенте
Функция ПолучитьЭквайринговыеТерминалыКассы(СтрокаКассыККМ)
	
	Терминалы = Новый Массив;
	
	Для Каждого СтрокаТерминала Из ТаблицаТерминалы Цикл
		Если СтрокаТерминала.Организация = СтрокаКассыККМ.Организация
				И ЗначениеЗаполнено(СтрокаТерминала.ПодключаемоеОборудование)
				И Не СтрокаТерминала.ИспользоватьБезПодключенияОборудования Тогда
				
			Терминалы.Добавить(СтрокаТерминала.ПодключаемоеОборудование);
				
		КонецЕсли;
	КонецЦикла;
	
	Возврат Терминалы;
	
КонецФункции

&НаКлиенте
Функция ПодготовитьДанныеУправленияКассовойСменойВКСО()
	
	ПараметрыУправленияСменой = Новый Структура();
	СтрокаКассыККМ = ТаблицаКассККМОрганизаций[0];
	ПараметрыУправленияСменой.Вставить("КассаККМ", СтрокаКассыККМ.КассаККМ);
	ПараметрыУправленияСменой.Вставить("КассоваяСмена", СтрокаКассыККМ.КассоваяСмена);
	ПараметрыУправленияСменой.Вставить("ИдентификаторУстройства", ПодключаемоеОборудование);
	ПараметрыУправленияСменой.Вставить("Пользователь", Объект.ПользовательБД);
	ПараметрыУправленияСменой.Вставить("Кассир", Объект.Кассир);
	ПараметрыУправленияСменой.Вставить("ВариантЗаполненияМестаРасчетов", ВариантЗаполненияМестаРасчетов);
	ПараметрыУправленияСменой.Вставить("ВремяНачалаСмены", ВремяНачалаСмены);
	ПараметрыУправленияСменой.Вставить("ИдентификаторыТерминалов", ПолучитьЭквайринговыеТерминалыКассы(СтрокаКассыККМ));
	ПараметрыУправленияСменой.Вставить("УникальныйИдентификаторВладельца", УникальныйИдентификатор);
	ПараметрыУправленияСменой.Вставить("Организация", СтрокаКассыККМ.Организация);
	ПараметрыУправленияСменой.Вставить("ТорговыйОбъект", Объект.ТорговыйОбъект);
	ПараметрыУправленияСменой.Вставить("РабочееМесто", РабочееМесто);
	
	Возврат ПараметрыУправленияСменой;
	
КонецФункции

&НаКлиенте
Функция ПодготовитьДанныеКассовойСменыКСО()
	
	ПараметрыКассовойСмены = Новый Структура();
	Если ТаблицаКассККМОрганизаций.Количество() = 1 Тогда
		СтрокаКассыККМ = ТаблицаКассККМОрганизаций[0];
		ПараметрыКассовойСмены.Вставить("КассаККМ", СтрокаКассыККМ.КассаККМ);
		ПараметрыКассовойСмены.Вставить("СменаОткрыта", СтрокаКассыККМ.Открыта);
		ПараметрыКассовойСмены.Вставить("НачалоКассовойСмены", СтрокаКассыККМ.НачалоКассовойСмены);
		ПараметрыКассовойСмены.Вставить("ВремяНачалаСмены", ВремяНачалаСмены);
	Иначе
		ПараметрыКассовойСмены.Вставить("КассаККМ", Неопределено);
	КонецЕсли;
	
	Возврат ПараметрыКассовойСмены;
	
КонецФункции

&НаКлиенте
Функция ОбнаруженыАктивныеДействияПользователя()
	
	РезультатФункции = (ОткрытаСтраницаНайтиПоШтрихкоду() Или ОткрытаСтраницаВнесения() Или ОткрытаСтраницаВыемки()
		Или ОткрытаСтраницаПоискаТовара() Или РежимЦифровойПанели = РежимыЦифровойПанели.ДанныеПокупателя
		Или Не Сокрлп(Элементы.ВводТовараПоСтроке.ТекстРедактирования) = "");
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьДанныеРМКПриВозможности()
	
	Если РежимРаботыСЧеком = РежимыРаботыСЧеком.ЧекПустой
			Или РежимРаботыСЧеком = РежимыРаботыСЧеком.ПродолжениеПослеПробития Тогда
		
		Если Не (ТипПостроенияПлитки = ТипыПостроенияПлитки.РаспознанныйВесовойТовар
				Или ОбнаруженыАктивныеДействияПользователя()) Тогда
		
			ОбновитьДанныеРМК();
		
		КонецЕсли;
		
		ИнтервалОбновления = 30;
		ПодключитьОбработчикОжидания("ОбновитьДанныеРМКПриВозможности", ИнтервалОбновления, Истина);
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеРМК()
	
	СтатусСменИзменился = Ложь;
	Если (Не РежимКассыСамообслуживания)
			И ИнтерфейсРМКСлужебныйКлиентСервер.ПоказыватьСтатусКассовыхСмен(СвойстваНастроекЭлементов) Тогда
		ДатаТекущая = ОбщегоНазначенияКлиент.ДатаСеанса();
		ГрупповойСтатусСмен = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьГрупповойСтатусКассовыхСмен(ЭтотОбъект, ДатаТекущая,
			СтатусСменИзменился);
	КонецЕсли;
	ФормаПлиточногоИнтерфейсаДоступна
		= ЕстьВесовойТоварВПлитке Или ЗначениеЗаполнено(СтруктураПлиточногоИнтерфейсаПодбора);
	
	ОбновитьДанныеИзбранных = Ложь;
	ОбновитьДанныеПлиток = Ложь;
	ОбновитьНаличныеВКассеККМ = Ложь;
	
	СтруктураДействийНаКлиентеПриОбновлении = Новый Структура;
	СтруктураДействийНаКлиентеПриОбновлении.Вставить("ОбновитьДанныеИзбранных", Ложь);
	СтруктураДействийНаКлиентеПриОбновлении.Вставить("ОбновитьДанныеПлиток", Ложь);
	СтруктураДействийНаКлиентеПриОбновлении.Вставить("ОбновитьНаличныеВКассеККМ", Ложь);
	СтруктураДействийНаКлиентеПриОбновлении.Вставить("СтатусСменИзменился", СтатусСменИзменился);
	СтруктураДействийНаКлиентеПриОбновлении.Вставить("ФормаПлиточногоИнтерфейсаДоступна",
		ФормаПлиточногоИнтерфейсаДоступна);

	Если ТребуетсяОбновлениеДанныхРМКНаСервере(СтруктураДействийНаКлиентеПриОбновлении) Тогда
		ОбновлениеДанныхРМКНаСервере(СтруктураДействийНаКлиентеПриОбновлении);
	КонецЕсли;
	
	Если СтруктураДействийНаКлиентеПриОбновлении.ОбновитьДанныеИзбранных Тогда
		ЗаполнитьКнопкиИзбранныхПозиций();
	КонецЕсли;
	
	Если СтруктураДействийНаКлиентеПриОбновлении.ОбновитьДанныеПлиток Тогда
		ЗаполнитьКнопкиПлиток();
	КонецЕсли;
	
	Если СтруктураДействийНаКлиентеПриОбновлении.ОбновитьНаличныеВКассеККМ Тогда
		ОтразитьОстаткиНаличныхДенежныхСредствНаФорме(Объект.Организация, Объект.КассаККМ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ТребуетсяОбновлениеДанныхРМКНаСервере(СтруктураДействийНаКлиентеПриОбновлении)
	
	Возврат (ИспользоватьПанельИзбранныхТоваров Или ИспользоватьОплатуНаличными
		Или СтруктураДействийНаКлиентеПриОбновлении.ФормаПлиточногоИнтерфейсаДоступна
		Или СтруктураДействийНаКлиентеПриОбновлении.СтатусСменИзменился);
	
КонецФункции

&НаСервере
Процедура ОбновлениеДанныхРМКНаСервере(СтруктураДействийНаКлиентеПриОбновлении)
	
	Если ИспользоватьПанельИзбранныхТоваров Тогда
		СтруктураДействийНаКлиентеПриОбновлении.ОбновитьДанныеИзбранных = ПерезаполнитьИзбранное();
	КонецЕсли;
	
	Если СтруктураДействийНаКлиентеПриОбновлении.ФормаПлиточногоИнтерфейсаДоступна Тогда
		СтруктураДействийНаКлиентеПриОбновлении.ОбновитьДанныеПлиток = ПерезаполнитьПлиточныйИнтерфейс();
	КонецЕсли;
	
	Если СтруктураДействийНаКлиентеПриОбновлении.ОбновитьДанныеИзбранных
			Или СтруктураДействийНаКлиентеПриОбновлении.ОбновитьДанныеПлиток Тогда
		ОбновитьЦеныИзбранныхИПлиток();
	КонецЕсли;
	
	Если ИспользоватьОплатуНаличными Тогда
		Для Каждого СтрокаКассыККМ Из ТаблицаКассККМОрганизаций Цикл
			ЗаполнитьНаличныеВКассеККМ(СтрокаКассыККМ);
		КонецЦикла;
		СтруктураДействийНаКлиентеПриОбновлении.ОбновитьНаличныеВКассеККМ = Истина;
	КонецЕсли;
	
	Если СтруктураДействийНаКлиентеПриОбновлении.СтатусСменИзменился Тогда
		ИнтерфейсРМКСлужебный.ОбновитьКнопкуСтатусаКассовыхСмен(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуУправленияКассовойСменойВКСО()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УправлениеКассовойСменойВКСОЗавершение", ЭтотОбъект);
	
	ПараметрыОткрытия = Новый Структура("Масштаб", Масштаб);
	ПараметрыОткрытия.Вставить("ПараметрыКассы", ПодготовитьДанныеУправленияКассовойСменойВКСО());
	
	ОткрытьФорму("Обработка.РабочееМестоКассира.Форма.ФормаУправленияКассовойСменойКСО",
		ПараметрыОткрытия, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.Независимый);
	
КонецПроцедуры

&НаКлиенте
Процедура УправлениеКассовойСменойВКСОЗавершение(Результат, ДополнительныеПараметры) Экспорт

	ВыбратьПользователяДоЗаменыПрав();
	Если Результат = Истина Тогда
		ИзменитьСостояниеКассовойСменыВызовСервера(Ложь);
		ЗаполнитьКэшКонтроляПродажПоДаннымПлиткиКлиент();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытииПродолжение(ОтложеннаяПроверкаКассовойСмены)
	
	Если РежимКассыСамообслуживания Тогда
		ОформитьРежимНовогоЧека("Продажа");
	КонецЕсли;
	ИзменитьКартинкуВводПокупателя();
	УстановитьЗаголовокКассир();
	ПоискТоваровОткрытИзСтрокиВвода = Ложь;

	ДанныеДляПлитки = Новый Массив;
	ТипПостроенияПлитки = ТипыПостроенияПлитки.ПоПалитре;
	ИнтерфейсРМКСлужебныйКлиент.ПодготовитьДанныеДляПлитки(ЭтотОбъект);
	ЗаполнитьКнопкиИзбранныхПозиций();
	ЗаполнитьКнопкиПлиток();
	НастроитьКомандыОплаты();
	
	СкрытьКомандуЗавершенияРаботыПриНеобходимости();
	Если РежимНачальнойСтраницы = 1 Тогда
		ОбновитьСостояниеЭлементовПриИзмененииТаблицыТоваров();
	КонецЕсли;
	ПереключатьсяВРежимПлитки = ОсновнойПодборПлиточный;
	ПереключитьВРежимПлитки();
	ОбновлятьСуммуАванса = Ложь;
	ПереключениеЦифровойПанели = Ложь;
	ВводСЦифровойКлавиатуры = Ложь;
	ТекущаяСтрокаРедактированияКоличества = Неопределено;
	УстановитьПризнакХочуБумажныйЧек(ПечататьБумажныйЧек);
	ПробитиеСоСтраницыОтправкиЧека = Ложь;
	Если ОтложеннаяПроверкаКассовойСмены Тогда
		ПодключитьОбработчикОжидания("ПроверитьКассовуюСменуИНайтиКассираВФоне", 0.1, Истина);
	КонецЕсли;
	НастроитьДоступностьГорячейКлавишиEnter();
	ФильтрПоискаПоШтрихкоду = Новый Структура("Номенклатура");
	ПустаяСтрокаТаблицыТоваров = СтруктураПустойСтрокиТаблицыТоваров();
	КэшУточненияПринадлежностиЗапасов = Новый Соответствие;
	СписокИдентификаторовСтрокДляУточнения = Новый СписокЗначений;
	КэшиСтрокТоваров = ОбщегоНазначенияРМККлиент.СтруктураКэшовСтрокТоваров();
	ЗаполнитьКэшПлитки();
	ПараметрыЗакрытияСменыПриАвтоматическойВыемке = ОбщегоНазначенияРМККлиент.ПараметрыЗакрытияСменыПриАвтоматическойВыемке();
	ОтразитьОстаткиНаличныхДенежныхСредствНаФорме(Объект.Организация, Объект.КассаККМ);
	НастроитьОтображениеКаталогаПриОткрытии();
	НастроитьОтображениеНастроекПолейВводаПоСтроке();
	ИнтерфейсРМКСлужебныйКлиент.НастроитьПерсонализированнуюПанельОпераций(ЭтотОбъект);
	ЦветФонаОтборВеса = Элементы.ОтборВесовогоТовара.ЦветФона;
	ЦветТекстаОтборВеса = Элементы.ОтборВесовогоТовара.ЦветТекста;
	УстановитьВидимостьПромокодов(РежимКассыСамообслуживания);
	
	ПодключитьОбработчикОжидания("ОбновитьДанныеРМКПриВозможности", 60, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьДействияПослеОткрытияИАвторизации();
	
	Если Не ПараметрыОткрытияФормыГосИС = Неопределено Тогда
		ПодключитьОбработчикОжидания("ОбработатьПараметрыГосИС", 0.1, Истина);
		ПодключитьОбработчикОжидания("ОбновитьСтатусыТСПИоТ", 1);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуАвторизацииДляПовторногоВхода()
	
	Если ЗавершатьСессиюКассираПослеПродажи Тогда
		ОткрытьФормуАвторизацииПринудительнаяСмена();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуАвторизации(ПараметрыАвторизации, ПроверяемоеПраво = "")
	
	ВозможныеНазначенияАвторизации = ИнтерфейсРМКСлужебныйКлиентСервер.НазначенияАвторизации();
	ПередаваемыйКассир = Неопределено;
	Если ПараметрыАвторизации.НазначениеАвторизации = ВозможныеНазначенияАвторизации.ОткрытиеФормы Тогда
		ПередаваемыйКассир = Объект.Кассир;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура();
	ПараметрыОткрытия.Вставить("ТорговыйОбъект", Объект.ТорговыйОбъект);
	ПараметрыОткрытия.Вставить("Кассир", ПередаваемыйКассир);
	ПараметрыОткрытия.Вставить("ИспользоватьЦифровуюКлавиатуру", Не СкрытьЦифровуюКлавиатуру);
	ПараметрыОткрытия.Вставить("НастроитьКассировДляВхода", НастроитьКассировДляВхода);
	ПараметрыОткрытия.Вставить("РежимКассыСамообслуживания", РежимКассыСамообслуживания);
	ПараметрыОткрытия.Вставить("НазначениеАвторизации", ПараметрыАвторизации.НазначениеАвторизации);
	ПараметрыОткрытия.Вставить("НеобходимоеПраво", ПроверяемоеПраво);
	Если ПараметрыАвторизации.НазначениеАвторизации = ВозможныеНазначенияАвторизации.ПовышениеПрав Тогда
		ПараметрыОткрытия.Вставить("НаименованиеПользователяПриЗапросеПрав", НаименованиеПользователяПриЗапросеПрав);
	КонецЕсли;
	
	ПараметрыАвторизации.Вставить("НеобходимоеПраво", ПроверяемоеПраво);
	ОбработкаОповещения = Новый ОписаниеОповещения("АвторизацияЗавершение", ЭтотОбъект, ПараметрыАвторизации);
	
	Элементы.ГруппаКомандыГорячихКлавиш.Доступность = Ложь;
	УправлениеФормойПередано = Истина;
	ОткрытьФорму("Обработка.РабочееМестоКассира.Форма.ФормаАвторизации", ПараметрыОткрытия, ЭтотОбъект,,,,
		ОбработкаОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуАвторизацииПриЗапуске()
	
	ВозможныеНазначенияАвторизации = ИнтерфейсРМКСлужебныйКлиентСервер.НазначенияАвторизации();
	ПараметрыАвторизации = Новый Структура("НазначениеАвторизации", ВозможныеНазначенияАвторизации.ОткрытиеФормы);
	ОткрытьФормуАвторизации(ПараметрыАвторизации);
	
КонецПроцедуры

&НаКлиенте
Процедура АвторизацияЗавершение(Результат, ДополнительныеПараметры) Экспорт

	ВозможныеНазначенияАвторизации = ИнтерфейсРМКСлужебныйКлиентСервер.НазначенияАвторизации();
	НазначениеАвторизации = ДополнительныеПараметры.НазначениеАвторизации;
	Если Результат = Неопределено Тогда
		
		Если НазначениеАвторизации = ВозможныеНазначенияАвторизации.ОткрытиеФормы
				Или НазначениеАвторизации = ВозможныеНазначенияАвторизации.ПринудительнаяСменаКассира Тогда
			
			РежимОсновногоОкна = КлиентскоеПриложение.ПолучитьРежимОсновногоОкна();
			ЭтоФиксированноеОкно = (РежимОсновногоОкна = РежимОсновногоОкнаКлиентскогоПриложения.РабочееМесто
				Или РежимОсновногоОкна = РежимОсновногоОкнаКлиентскогоПриложения.Киоск
				Или ((Не ЭтотОбъект.Окно = Неопределено) И Окно.НачальнаяСтраница));
				
			Если Открыта() И Не ЭтоФиксированноеОкно Тогда
				
				Закрыть();
				
			ИначеЕсли Открыта() И (Не ЭтотОбъект.Окно = Неопределено) И Окно.НачальнаяСтраница Тогда
				
				ПоказатьРекомендациюУбратьИзНачальнойСтраницы(Истина);
				
			КонецЕсли;
			
		ИначеЕсли НазначениеАвторизации = ВозможныеНазначенияАвторизации.ПовышениеПрав Тогда
			
			ТекущаяОперация = "";
			
		ИначеЕсли НазначениеАвторизации = ВозможныеНазначенияАвторизации.СлужебныеДействияКСО Тогда
			
			ТекущаяОперация = "";
			ОткрытьОбщуюСтраницу();
			СкрытьКомандуВыходаПриНеобходимости();
			
		КонецЕсли;
	Иначе
		
		Если НазначениеАвторизации = ВозможныеНазначенияАвторизации.ОткрытиеФормы Тогда
			
			ОбновитьДанныеМагазинаКассираПриСмене(Результат);
			ВыполнитьНастройкиПослеОбновленияКассираМагазина(Истина);
			ВыполнитьДействияПослеОткрытияИАвторизации();
			
		ИначеЕсли НазначениеАвторизации = ВозможныеНазначенияАвторизации.ПринудительнаяСменаКассира Тогда
			
			ОбновитьДанныеМагазинаКассираПриСменеСводно(Результат, Истина);
			
		ИначеЕсли НазначениеАвторизации = ВозможныеНазначенияАвторизации.СменаКассира
				Или НазначениеАвторизации = ВозможныеНазначенияАвторизации.СменаМагазина Тогда
			
			НеобходимоПерезаполнитьТаблицуУправляемыхСкидок = Истина;
			ОбновитьДанныеМагазинаКассираПриСменеСводно(Результат);
			
		ИначеЕсли НазначениеАвторизации = ВозможныеНазначенияАвторизации.ПовышениеПрав Тогда
			
			ЗапомнитьПользователяДоЗаменыПравКлиент();
			
			Если ТекущаяОперация = "ЧекНаВозвратРМК" Тогда
				УстановитьДанныеВыбранногоКассира(Результат, Истина);
				ЗарегистрироватьПовышениеПравНаВозвратЧека();
				ВыбратьЧекНаВозврат();
			ИначеЕсли ТекущаяОперация = "ВозвратБезЧекаРМК" Тогда
				УстановитьДанныеВыбранногоКассира(Результат, Истина);
				ЗарегистрироватьПовышениеПравНаВозвратЧека();
				ПереключитьФормуВРежимВозвратБезЧека();
			Иначе
				УстановитьДанныеВыбранногоКассира(Результат);
				ИмяРегистрируемойОперации = "Перечисление.ОперацииРабочегоМестаКассира.ПовышениеПравНаКоррекциюЧека";
				ОперацияПовышения = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент(ИмяРегистрируемойОперации);
				ЗарегистрироватьПовышениеПрав(ЭтотОбъект, ОперацияПовышения);
				ВыбратьЧекКоррекции();
			КонецЕсли;
			ВыбратьПользователяДоЗаменыПравКлиент();
			СформироватьЗаголовок();
			ОтразитьОстаткиНаличныхДенежныхСредствНаФорме(Объект.Организация, Объект.КассаККМ);
			ТекущаяОперация = "";
			
		ИначеЕсли НазначениеАвторизации = ВозможныеНазначенияАвторизации.СлужебныеДействияКСО Тогда
			
			ЗапомнитьПользователяДоЗаменыПравКлиент();
			УстановитьДанныеВыбранногоКассира(Результат);
			ОткрытьФормуОперацийСотрудника();
			ТекущаяОперация = "";
			
		КонецЕсли;
		
	КонецЕсли;
	УправлениеФормойПередано = Ложь;
	Элементы.ГруппаКомандыГорячихКлавиш.Доступность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьПовышениеПравНаВозвратЧека()
	
	ИмяРегистрируемойОперации = "Перечисление.ОперацииРабочегоМестаКассира.ПовышениеПравНаВозвратЧека";
	ОперацияПовышения = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент(ИмяРегистрируемойОперации);
	ЗарегистрироватьПовышениеПрав(ЭтотОбъект, ОперацияПовышения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьРекомендациюУбратьИзНачальнойСтраницы(ОтказАвторизации = Ложь)
	
	ТекстРекомендации = "";
	Если ОтказАвторизации Тогда
		ТекстРекомендации = НСтр("ru = 'Рекомендуем убрать рабочее место кассира из начальной страницы
			|или настроить текущему пользователю вход по умолчанию.'");
	Иначе
		ТекстРекомендации = НСтр("ru = 'Рекомендуем убрать рабочее место кассира из начальной страницы
			|до корректной настройки рабочего места кассира.'");
	КонецЕсли;
	
	Элементы.ЗаголовокОшибкиВхода.Заголовок = НСтр("ru = 'Ошибка входа'");
	Элементы.ТекстОшибкиВхода.Заголовок = ТекстРекомендации;
	УстановитьВидимостьЭлементаФормы(Элементы.ВыполнитьВход, Истина);
	УстановитьДоступностьЭлементаФормы(Элементы.ГруппаОперации, Ложь);
	ОбщегоНазначенияРМККлиентСервер.УстановитьТекущуюСтраницу(Элементы.СтраницаЗавершение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапомнитьПользователяДоЗаменыПравКлиент()
	
	ПользовательДоЗаменыПрав = Объект.ПользовательБД;
	КассирДоЗаменыПрав = Объект.Кассир;
	СписокРолейПользователяДоЗамены = СписокРолейПользователя.Скопировать();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьПользователяДоЗаменыПравКлиент()
	
	Если ЗначениеЗаполнено(ПользовательДоЗаменыПрав) И ЗначениеЗаполнено(КассирДоЗаменыПрав)
			И СписокРолейПользователяДоЗамены.Количество() > 0 Тогда
			
		Объект.ПользовательБД = ПользовательДоЗаменыПрав;
		Объект.Кассир = КассирДоЗаменыПрав;
		СписокРолейПользователя.Очистить();
		Для Каждого РольДоЗамены Из СписокРолейПользователяДоЗамены Цикл
			СписокРолейПользователя.Добавить(РольДоЗамены.Значение);
		КонецЦикла;
		КодДляЗаменыПрав = "";
			
	Иначе
		ВыбратьПользователяДоЗаменыПрав();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДанныеВыбранногоКассира(Результат, ЭтоВозврат = Ложь)
	
	Объект.Кассир = Результат.Кассир;
	Объект.ПользовательБД = Результат.ПользовательБД;
	ОткрытьОбщуюСтраницу(ЭтоВозврат);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеМагазинаКассираПриСмене(Результат)
	
	Объект.Кассир = Результат.Кассир;
	Объект.ПользовательБД = Результат.ПользовательБД;
	Если (ЗначениеЗаполнено(Результат.ТорговыйОбъект) И Не Результат.ТорговыйОбъект = Объект.ТорговыйОбъект)
			Или Не ЗначениеЗаполнено(ТекущаяНастройкаРМК) Тогда
		СменитьТорговыйОбъект(Результат.ТорговыйОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапомнитьПодключенноеОборудование(ПодключаемыеТипыОборудования)
	
	Для Каждого СтрокаТипа Из ПодключаемыеТипыОборудования Цикл
		Если СтрокаТипа.Значение Тогда
			РанееПодключенныеТипыОборудования[СтрокаТипа.Ключ] = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьТипыОборудованияДляПодключения()
	
	ПодключаемыеТипыОборудования = МенеджерОборудованияРМККлиентСервер.ПараметрыТипыОборудования();
	Для Каждого СтрокаТипа Из ПоддерживаемыеТипыПодключаемогоОборудования Цикл
		Если СтрокаТипа.Значение И Не РанееПодключенныеТипыОборудования[СтрокаТипа.Ключ] Тогда
			ПодключаемыеТипыОборудования[СтрокаТипа.Ключ] = Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат ПодключаемыеТипыОборудования;
	
КонецФункции

&НаСервере
Функция ПроверкаСвязанныхКассировУспешна()
	
	РезультатФункции = ФизЛицоПользователяЗаполнено Или ЗначениеЗаполнено(Объект.Кассир);
	
	Если Не РезультатФункции И НастроитьКассировДляВхода Тогда
		КассирКСО = ОбщегоназначенияРМК.ПолучитьКассираИзПараметраЗапуска();
		Если ЗначениеЗаполнено(КассирКСО) Тогда
			Объект.Кассир = КассирКСО;
			РезультатФункции = Истина;
		Иначе
			ДоступныеКассиры = ОбщегоназначенияРМК.ПолучитьДоступныхКассировПользователя(Объект.ПользовательБД);
			Если ДоступныеКассиры.Количество() > 0 Тогда
				РезультатФункции = Истина;
				Если ДоступныеКассиры.Количество() = 1 Тогда
					Объект.Кассир = ДоступныеКассиры[0];
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Процедура ЗавершитьВыборПокупателя(Результат, ДополнительныеПараметры) Экспорт
	
	УстановитьВыбранногоКонтрагента(Результат, ДополнительныеПараметры);

КонецПроцедуры

&НаСервере
