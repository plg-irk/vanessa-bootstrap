#Область ОписаниеПеременных

// Структура с кодами возможных операций сотрудника на КСО.
&НаКлиенте
Перем ВозможныеОперации;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Масштаб = Параметры.Масштаб;
	ТекущаяНастройкаРМК = Параметры.ТекущаяНастройкаРМК;
	ПараметрыКассовойСмены = Параметры.ПараметрыКассовойСмены;
	Элементы.ОбучениеУстройствРаспознавания.Видимость = Параметры.ОбучениеУстройствРаспознавания;
	НастроитьКомандуУправленияКассовойСменой();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ВозможныеОперации = ИнтерфейсРМКСлужебныйКлиент.ВозможныеОперацииСотрудникаВКСО();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗавершитьРаботу(Команда)
	
	Закрыть(ВозможныеОперации.ЗавершитьРаботу);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЧек(Команда)
	
	Закрыть(ВозможныеОперации.ПроверитьЧек);
	
КонецПроцедуры

&НаКлиенте
Процедура ВернутьсяВРежимКассыСамообслуживания(Команда)
	
	Закрыть(ВозможныеОперации.ПродолжитьРаботу);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбучениеУстройствРаспознавания(Команда)
	
	Закрыть(ВозможныеОперации.ОбучитьУстройстваРаспознавания);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьОткрытьКассовуюСмену(Команда)

	Закрыть(ВозможныеОперации.ЗакрытьОткрытьКассовуюСмену);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура НастроитьКомандуУправленияКассовойСменой()
	
	Если ЗначениеЗаполнено(ПараметрыКассовойСмены.КассаККМ) Тогда
		Сутки = 86400;
		ДатаТекущая = ТекущаяДатаСеанса();
		СменаАктуальна = ПараметрыКассовойСмены.СменаОткрыта;
		ВремяНачалаСменыВСекундах = ПараметрыКассовойСмены.ВремяНачалаСмены - Дата(1, 1, 1);
		МинимальнаяДатаНачалаСмены = НачалоДня(ДатаТекущая) + ВремяНачалаСменыВСекундах;
		Если ДатаТекущая < МинимальнаяДатаНачалаСмены Тогда
			МинимальнаяДатаНачалаСмены = МинимальнаяДатаНачалаСмены - Сутки;
		КонецЕсли;
		
		Если СменаАктуальна И (ДатаТекущая - ПараметрыКассовойСмены.НачалоКассовойСмены >= Сутки
				Или ПараметрыКассовойСмены.НачалоКассовойСмены < МинимальнаяДатаНачалаСмены) Тогда
			СменаАктуальна = Ложь;
		КонецЕсли;
		НачалоЗаголовка = НСтр("ru = 'Кассовая смена'");
		ПродолжениеЗаголовка = ?(ПараметрыКассовойСмены.СменаОткрыта,
			Формат(ПараметрыКассовойСмены.НачалоКассовойСмены, ""),
			НСтр("ru = 'закрыта'"));
		ЗаголовокКнопки = СтрШаблон("%1 (%2)", НачалоЗаголовка, ПродолжениеЗаголовка);
		
		Если СменаАктуальна Тогда
			Элементы.ЗакрытьОткрытьКассовуюСмену.ЦветТекста = ЦветаСтиля.ЦветТекстаПоложительногоЗначения;
		Иначе
			Элементы.ЗакрытьОткрытьКассовуюСмену.ЦветТекста = ЦветаСтиля.ЦветОсобогоТекстаРМК;
		КонецЕсли;
		Элементы.ЗакрытьОткрытьКассовуюСмену.Заголовок = ЗаголовокКнопки;
		Элементы.ЗакрытьОткрытьКассовуюСмену.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

