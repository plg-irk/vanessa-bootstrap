#Область ОбработчикиСобытийФормы

&НаСервере

Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДоступенВыборОрганизации = Ложь;
	ДоступенВыборКомитента = Ложь;
	
	ДоступенСобственный = Ложь;
	УточнениеВыбрано = Ложь;
	
	Если Параметры.Свойство("Номенклатура") Тогда
		Номенклатура = Параметры.Номенклатура;
	КонецЕсли;
	
	Если Параметры.Свойство("СписокУточнений") И ТипЗнч(Параметры.СписокУточнений) = Тип("СписокЗначений") Тогда
		Для каждого СтрокаУточнения Из Параметры.СписокУточнений Цикл
			
			Уточнение = СтрокаУточнения.Значение;
			
			Если НЕ ЗначениеЗаполнено(Уточнение.ОрганизацияПродавец) И НЕ ЗначениеЗаполнено(Уточнение.Комитент) Тогда
				ДоступенСобственный = Истина;
			Иначе
				СтрокаТаблицы = ТаблицаУточненияПринадлежностиЗапасов.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Уточнение);
				
				Если ЗначениеЗаполнено(Уточнение.ОрганизацияПродавец) И ЗначениеЗаполнено(Уточнение.Комитент) Тогда
					ДоступенВыборОрганизации = Истина;
					ДоступенВыборКомитента = Истина;
				ИначеЕсли ЗначениеЗаполнено(Уточнение.ОрганизацияПродавец) Тогда
					ДоступенВыборОрганизации = Истина;
				ИначеЕсли ЗначениеЗаполнено(Уточнение.Комитент) Тогда
					ДоступенВыборКомитента = Истина;
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	Если Параметры.Свойство("ИдентификаторСтроки") И ТипЗнч(Параметры.ИдентификаторСтроки) = Тип("Строка") Тогда
		ИдентификаторСтроки = Параметры.ИдентификаторСтроки;
	КонецЕсли;
	
	Элементы.Отмена.Видимость = ДоступенСобственный;
	Если ДоступенВыборОрганизации И ДоступенВыборКомитента Тогда
	ИначеЕсли ДоступенВыборОрганизации Тогда
		Заголовок = НСтр("ru='Уточните организацию'");
		Элементы.ТаблицаУточненияПринадлежностиЗапасовКомитент.Видимость = Ложь;
	ИначеЕсли ДоступенВыборКомитента Тогда
		Заголовок = НСтр("ru='Уточните комитента'");
		Элементы.ТаблицаУточненияПринадлежностиЗапасовОрганизацияПродавец.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если НЕ УточнениеВыбрано И НЕ ДоступенСобственный Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементов

&НаКлиенте
Процедура ТаблицаУточненияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ЗафиксироватьВыбор();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выбрать(Команда)
	
	ЗафиксироватьВыбор();
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗафиксироватьВыбор()
	
	УточнениеВыбрано = Истина;
	
	Результат = Новый Структура;
	
	ИдентификаторыСтрок = Элементы.ТаблицаУточненияПринадлежностиЗапасов.ВыделенныеСтроки;
	
	Если ИдентификаторыСтрок.Количество() = 0 Тогда
		Закрыть();
	Иначе
		Для Каждого ИдентификаторВыбраннойСтроки Из ИдентификаторыСтрок Цикл
			СтрокаВыбранногоУточнения = ТаблицаУточненияПринадлежностиЗапасов.НайтиПоИдентификатору(ИдентификаторВыбраннойСтроки);
			Если СтрокаВыбранногоУточнения = Неопределено Тогда
				Продолжить;
			КонецЕсли;
		
			Уточнение = Новый Структура;
			Уточнение.Вставить("ОрганизацияПродавец", СтрокаВыбранногоУточнения.ОрганизацияПродавец);
			Уточнение.Вставить("Комитент", СтрокаВыбранногоУточнения.Комитент);
			Уточнение.Вставить("СистемаНалогообложения", СтрокаВыбранногоУточнения.СистемаНалогообложения);
			Уточнение.Вставить("СтавкаНДС", СтрокаВыбранногоУточнения.СтавкаНДС);
			Уточнение.Вставить("СтавкаНДСУСН", СтрокаВыбранногоУточнения.СтавкаНДСУСН);
		
		КонецЦикла;
		
		Результат.Вставить("Уточнение", Уточнение);
		Результат.Вставить("ИдентификаторСтроки", ИдентификаторСтроки);
		
		Закрыть(Результат);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти