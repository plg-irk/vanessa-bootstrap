
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВыводитьКомментарийКЧеку  = Параметры.ВыводитьКомментарийКЧеку;
	КомментарийКЧеку          = Параметры.КомментарийКЧеку;
	УказыватьПричинуВозврата  = Параметры.УказыватьПричинуВозврата;
	ПричинаВозврата           = Параметры.ПричинаВозврата;
	ВыборЧекаНаВозврат        = Параметры.ВыборЧекаНаВозврат;
	
	Заголовок                 = Параметры.ЗаголовокФормы;
	
	Элементы.КомментарийКЧеку.Видимость = ВыводитьКомментарийКЧеку;
	Элементы.ПричинаВозврата.Видимость = УказыватьПричинуВозврата;
	
	Если УказыватьПричинуВозврата Тогда
		Элементы.Сохранить.Доступность = ЗначениеЗаполнено(ПричинаВозврата);
	Иначе
		Элементы.КомментарийКЧеку.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КонецЕсли;
	
	Если ВыборЧекаНаВозврат Тогда
		Элементы.Сохранить.Заголовок = НСтр("ru = 'Продолжить'");
	КонецЕсли;
	
	ОбщегоНазначенияРМКПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ВыборЧекаНаВозврат И НЕ Закрытие Тогда
		СтандартнаяОбработка = Ложь;
		ОбработатьЗакрытиеФормы();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПричинаВозвратаПриИзменении(Элемент)
	
	Если НЕ ВыборЧекаНаВозврат Тогда
		Модифицированность = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(ПричинаВозврата) Тогда
		Элементы.Сохранить.Доступность = Истина;
	Иначе
		Элементы.Сохранить.Доступность = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомментарийКЧекуПриИзменении(Элемент)
	
	Если НЕ ВыборЧекаНаВозврат Тогда
		Модифицированность = Истина;
	КонецЕсли
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Сохранить(Команда)
	
	Если УказыватьПричинуВозврата
		И НЕ ЗначениеЗаполнено(ПричинаВозврата) Тогда
		
		Элементы.Сохранить.Доступность = Ложь;
	Иначе
		ОбработатьЗакрытиеФормы(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	ОбработатьЗакрытиеФормы();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработатьЗакрытиеФормы(Сохранение = Ложь)
	
	Закрытие = Истина;
	
	Если НЕ ВыборЧекаНаВозврат И НЕ Модифицированность Тогда
		Закрыть();
		Возврат;
	КонецЕсли;
	
	ПараметрЗакрытия = Новый Структура;
	ПараметрЗакрытия.Вставить("ВыборЧекаНаВозврат", ВыборЧекаНаВозврат);
	Если Сохранение Тогда
		ПараметрЗакрытия.Вставить("ВыводитьКомментарийКЧеку", ВыводитьКомментарийКЧеку);
		ПараметрЗакрытия.Вставить("УказыватьПричинуВозврата", УказыватьПричинуВозврата);
		Если ВыводитьКомментарийКЧеку Тогда
			ПараметрЗакрытия.Вставить("КомментарийКЧеку", КомментарийКЧеку);
		КонецЕсли;
		Если УказыватьПричинуВозврата Тогда
			ПараметрЗакрытия.Вставить("ПричинаВозврата", ПричинаВозврата);
		КонецЕсли;
	КонецЕсли;
	
	Закрыть(ПараметрЗакрытия);
	
КонецПроцедуры

#КонецОбласти