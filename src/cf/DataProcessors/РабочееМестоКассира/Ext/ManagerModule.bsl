
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	ВозможностьЗапускаРМК = ОпределитьВозможностьЗапускаРМК();
	
	Если ВозможностьЗапускаРМК.ЕстьОшибки Тогда
		
		ВыбраннаяФорма = Метаданные.Обработки.РабочееМестоКассира.Формы.ФормаОшибкиОткрытияРМК;
		Параметры.Вставить("ТекстОшибки", ВозможностьЗапускаРМК.ТекстОшибки);
		
		СтандартнаяОбработка = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ОпределитьВозможностьЗапускаРМК() Экспорт
	
	ЕстьОшибки = Ложь;
	
	Результат = Новый Структура;
	Результат.Вставить("ТекстОшибки", "");
	Результат.Вставить("ЕстьОшибки", ЕстьОшибки);

	Если НЕ ЕстьОшибки Тогда
		ЭтоМобильныйКлиент = ОбщегоНазначения.ЭтоМобильныйКлиент();
		Если ЭтоМобильныйКлиент Тогда
			ЕстьОшибки = Истина;
			ТекстОшибки = НСтр("ru = 'Мобильный клиент не поддерживается.'");
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЕстьОшибки Тогда
		МожноОткрыватьРМК = Истина;
		ОбщегоНазначенияРМКПереопределяемый.ОпределитьВозможностьЗапускаРМК(МожноОткрыватьРМК);
		Если Не МожноОткрыватьРМК Тогда
			ЕстьОшибки = Истина;
			ТекстОшибки = НСтр("ru = 'Использование РМК отключено.'");
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЕстьОшибки Тогда
		ЭтоПолноправныйПользователь = Пользователи.ЭтоПолноправныйПользователь();
		Если НЕ ЭтоПолноправныйПользователь Тогда
			
			НедостающиеРолиДляЗапускаРМК = Новый Массив;
			ОбщегоНазначенияРМК.ЗаполнитьНедостающиеРолиДляЗапускаРМК(НедостающиеРолиДляЗапускаРМК);
			
			Если ЗначениеЗаполнено(НедостающиеРолиДляЗапускаРМК) Тогда
				ЕстьОшибки = Истина;
				ТекстОшибки = НСтр("ru ='Для работы РМК недостаточно прав, обратитесь к администратору.
				|Пользователю необходимо добавить следующие роли:'") + Символы.ПС;
				Для Каждого Роль Из НедостающиеРолиДляЗапускаРМК Цикл
					ТекстОшибки = ТекстОшибки + Роль + Символы.ПС;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ЕстьОшибки Тогда
	
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Запуск рабочего места кассира'"),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Обработки.РабочееМестоКассира,
			,
			ТекстОшибки);
		
		Результат.ТекстОшибки = ТекстОшибки;
		Результат.ЕстьОшибки = ЕстьОшибки;
		
	КонецЕсли;
	
	ПараметрыСеанса.ВозможностьЗапускаРМК = Новый ФиксированнаяСтруктура(Результат);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецЕсли
