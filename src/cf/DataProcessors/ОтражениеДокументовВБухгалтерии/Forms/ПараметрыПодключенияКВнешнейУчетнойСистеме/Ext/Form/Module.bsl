#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если ЗначениеЗаполнено(АдресПриложения) Тогда
		СтруктураАдреса = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресПриложения);
		
		ЧастиХоста = СтрРазделить(СтруктураАдреса.Хост, ".", Ложь);
		Если ЧастиХоста.Количество() < 2 Тогда
			Отказ = Истина;
		Иначе
			ДоменХоста = ЧастиХоста[ЧастиХоста.ВГраница() - 1] + "." +  ЧастиХоста[ЧастиХоста.ВГраница()];
			Если ВРег(ДоменХоста) <> ВРег("1cbo.ru") Тогда
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если Отказ Тогда
			Сообщение = Новый СообщениеПользователю();
		    Сообщение.Текст = НСтр("ru = 'Проверьте правильность указанного адреса учетной системы.'");
		    Сообщение.Поле = "АдресПриложения";
		    Сообщение.Сообщить();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Готово(Команда)
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьПроверкуПодключения(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПодключение(Команда)
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	ВыполнитьПроверкуПодключения(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыДоступаВИнтернет(Команда)
	
	ТранспортСообщенийОбменаКлиент.ОткрытьФормуПараметровПроксиСервера();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ВыполнитьПроверкуПодключения(СохранитьИЗакрыть)
	
	ДополнительныеПараметры = Новый Структура("СохранитьИЗакрыть", СохранитьИЗакрыть);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ВыполнитьПроверкуПодключенияЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	Если ОбщегоНазначенияКлиент.ПодсистемаСуществует("СтандартныеПодсистемы.ПрофилиБезопасности") Тогда
		Запросы = СоздатьЗапросНаИспользованиеВнешнихРесурсов(АдресПриложения);
		МодульРаботаВБезопасномРежимеКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("РаботаВБезопасномРежимеКлиент");
		МодульРаботаВБезопасномРежимеКлиент.ПрименитьЗапросыНаИспользованиеВнешнихРесурсов(Запросы, ЭтотОбъект, ОповещениеОЗакрытии);
	Иначе
		ВыполнитьОбработкуОповещения(ОповещениеОЗакрытии, КодВозвратаДиалога.ОК);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция РезультатЗакрытияНаСервере()
	
	ИдентификаторПароля = Строка(Новый УникальныйИдентификатор);
	
	УстановитьПривилегированныйРежим(Истина);
	ОбщегоНазначения.ЗаписатьДанныеВБезопасноеХранилище(ИдентификаторПароля, Пароль);
	УстановитьПривилегированныйРежим(Ложь);
	
	Результат = Новый Структура;
	Результат.Вставить("АдресПриложения", АдресПриложения);
	Результат.Вставить("ИмяПользователя", ИмяПользователя);
	Результат.Вставить("Пароль", ИдентификаторПароля);
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция СоздатьЗапросНаИспользованиеВнешнихРесурсов(АдресПриложения)
	
	ЗапросыРазрешений = Новый Массив;
	Разрешения = Новый Массив;
	
	Если Не ПустаяСтрока(АдресПриложения) Тогда
		
		МодульРаботаВБезопасномРежиме = ОбщегоНазначения.ОбщийМодуль("РаботаВБезопасномРежиме");
		
		СтруктураАдреса = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресПриложения);
		Если ЗначениеЗаполнено(СтруктураАдреса.Схема) Тогда
			
			Разрешения.Добавить(МодульРаботаВБезопасномРежиме.РазрешениеНаИспользованиеИнтернетРесурса(
				СтруктураАдреса.Схема, СтруктураАдреса.Хост, СтруктураАдреса.Порт));
				
			ЗапросыРазрешений.Добавить(
				МодульРаботаВБезопасномРежиме.ЗапросНаИспользованиеВнешнихРесурсов(Разрешения));
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ЗапросыРазрешений;
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьПроверкуПодключенияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.ОК Тогда
		
		ПодключениеУстановлено = Ложь;
		ПроверитьПодключениеНаСервере(ПодключениеУстановлено);
		
		Если ПодключениеУстановлено Тогда
			Если ДополнительныеПараметры.СохранитьИЗакрыть Тогда
				РезультатЗакрытия = РезультатЗакрытияНаСервере();
				Закрыть(РезультатЗакрытия);
			Иначе
				ПоказатьПредупреждение(, НСтр("ru = 'Подключение успешно установлено.'"));
			КонецЕсли;
		Иначе
			ПоказатьПредупреждение(, НСтр("ru = 'Не удалось установить подключение.'"));
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьПодключениеНаСервере(ПодключениеУстановлено)
	
	ОбработкаОбъект = Обработки.ТранспортСообщенийОбменаWS.Создать();
	ОбработкаОбъект.АдресВебСервиса = АдресПриложения;
	ОбработкаОбъект.ИмяПользователя = ИмяПользователя;
	ОбработкаОбъект.Пароль = Пароль;
	
	// Выполняем проверку подключения.
	ПодключениеУстановлено = ОбработкаОбъект.ПодключениеУстановлено();
	Если Не ПодключениеУстановлено Тогда
		СообщениеОбОшибке = ОбработкаОбъект.СообщениеОбОшибке
			+ Символы.ПС + НСтр("ru = 'Техническую информацию об ошибке см. в журнале регистрации.'");			
		ОбщегоНазначения.СообщитьПользователю(СообщениеОбОшибке);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
