#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВосстановитьНастройкиМонитора();

	ПодготовитьМониторОтражения();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	НачатьОбновлениеСостоянияНастройкиОтражения();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОтражениеОтключено" Тогда
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаНастройкиМонитора(Команда)
	
	ОткрытьФорму(
		"Обработка.ОтражениеДокументовВБухгалтерии.Форма.НастройкиРаздела",
		,
		ЭтотОбъект,
		,
		,
		,
		Новый ОписаниеОповещения("НастройкиМонитораЗавершение", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОбновитьДанныеМонитора(Команда)
	
	Элементы.ПанельМонитор.ТекущаяСтраница = Элементы.СтраницаОжидание;
	
	ПодключитьОбработчикОжидания("ОбновитьДанныеМонитораБезЗапросаИзменений", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбщийОбработчикКомандыРазделаУчета(Команда)
	
	ЧастиИмени = СтрРазделить(Команда.Имя, "_");
	
	ИдентификаторРаздела = ЧастиИмени[1];
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отборы", Новый Структура);
	
	ПараметрыФормы.Отборы.Вставить("Период", ОтборПериод);
	Если ЗначениеЗаполнено(ОтборОрганизация) Тогда
		ПараметрыФормы.Отборы.Вставить("Организации", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ОтборОрганизация));
	Иначе
		ПараметрыФормы.Отборы.Вставить("Организации", Новый Массив);
	КонецЕсли;
	ПараметрыФормы.Отборы.Вставить("РазделыУчета", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИдентификаторРаздела));
	ПараметрыФормы.Отборы.Вставить("Статусы", Новый Массив);
	
	ОткрытьФорму("Обработка.ОтражениеДокументовВБухгалтерии.Форма.ЖурналОтраженияДокументов", ПараметрыФормы, ЭтотОбъект, Команда.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОтборМонитораОрганизации(Команда)
	
	СписокДействий = Новый СписокЗначений;
	
	Если ПодключенныеОрганизации.Количество() = 1 Тогда
		СписокДействий.Добавить(ПодключенныеОрганизации[0].Значение, , Истина); 
	Иначе
		СписокДействий.Добавить(
			Неопределено,
			НСтр("ru = 'Все организации'"),
			Не ЗначениеЗаполнено(ОтборОрганизация));
		Для Каждого ЭлементСписка Из ПодключенныеОрганизации Цикл
			СписокДействий.Добавить(ЭлементСписка.Значение, , ЭлементСписка.Значение = ОтборОрганизация);
		КонецЦикла;
	КонецЕсли;
	
	Если СписокДействий.Количество() > 0 Тогда
		ПоказатьВыборИзМеню(
			Новый ОписаниеОповещения("ОтборМонитораОрганизацииЗавершение", ЭтотОбъект),
			СписокДействий,
			Элементы.КомандаОтборМонитораОрганизации);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОтборМонитораПериод(Команда)
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода;
	Диалог.Период = ОтборПериод;
	Диалог.Показать(Новый ОписаниеОповещения("ОтборМонитораПериодЗавершение", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаЖурналОтраженияДокументов(Команда)
	
