#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ВыполнитьКомандуБухгалтерии(ИмяКоманды)
	
	СсылкаДляПерехода = "";
	
	// Отчеты
	Если ИмяКоманды = "КомандаБухгалтерия_ОборотноСальдоваяВедомость" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.ОборотноСальдоваяВедомость";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_ОборотноСальдоваяВедомостьПоСчету" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.ОборотноСальдоваяВедомостьПоСчету";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_СводныеПроводки" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.СводныеПроводки";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_ОтчетПоПроводкам" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.ОтчетПоПроводкам";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_ОстаткиДенежныхСредств" Тогда
		СсылкаДляПерехода = "e1cib/app/Отчет.ОстаткиДенежныхСредств";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_РасчетыСПокупателямиИПоставщиками" Тогда
		СсылкаДляПерехода = "e1cib/app/Отчет.РасчетыСПокупателямиИПоставщиками";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_ОстаткиТоваров" Тогда
		СсылкаДляПерехода = "e1cib/app/Отчет.ОстаткиТоваров";
	// Отчетность
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_КалендарьОтчетности" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.КалендарьОтчетности";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_РегламентированныеОтчеты" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.ОткрытьФорму1СОтчетностьНаОтчетах";
	// Журналы документов
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_ЖурналОпераций" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.ЖурналОпераций";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_ЖурналПроводок" Тогда
		СсылкаДляПерехода = "e1cib/list/РегистрБухгалтерии.Хозрасчетный";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_Реализация" Тогда
		СсылкаДляПерехода = "e1cib/list/Документ.РеализацияТоваровУслуг";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_СчетаФактурыВыданные" Тогда
		СсылкаДляПерехода = "e1cib/list/Документ.СчетФактураВыданный";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_Поступление" Тогда
		СсылкаДляПерехода = "e1cib/list/Документ.ПоступлениеТоваровУслуг";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_СчетаФактурыПолученные" Тогда
		СсылкаДляПерехода = "e1cib/list/Документ.СчетФактураПолученный";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_АктыСверкиРасчетов" Тогда
		СсылкаДляПерехода = "e1cib/list/Документ.АктСверкиВзаиморасчетов";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_БанковскиеВыписки" Тогда
		СсылкаДляПерехода = "e1cib/command/ЖурналДокументов.Деньги.Команда.БанковскиеВыписки";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_КассовыеДокументы" Тогда
		СсылкаДляПерехода = "e1cib/command/ЖурналДокументов.Деньги.Команда.КассовыеДокументы";
	// Настройки
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_Организации" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.Организации";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_УчетнаяПолитика" Тогда
		СсылкаДляПерехода = "e1cib/command/РегистрСведений.УчетнаяПолитика.Команда.УчетнаяПолитика";
	ИначеЕсли ИмяКоманды = "КомандаБухгалтерия_Функциональность" Тогда
		СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.Функциональность";
	КонецЕсли;
	
	Если Не ПустаяСтрока(СсылкаДляПерехода) Тогда
		СовместноеИспользованиеКлиент.ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(
			СсылкаДляПерехода,
			"БухгалтерияПредприятия",
			Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиМонитораЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	ПодготовитьМониторОтражения(Ложь);
	
	НачатьОбновлениеСостоянияНастройкиОтражения();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборМонитораОрганизацииЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОтборОрганизация = ВыбранныйЭлемент.Значение;
	
	СохранитьНастройкиМонитора();
	
	ОбновитьДанныеМонитора(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборМонитораПериодЗавершение(ВыбранныйПериод, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйПериод = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОтборПериод = ВыбранныйПериод;
	
	СохранитьНастройкиМонитора();
	
	ОбновитьДанныеМонитора(Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиОтражения()
	
	ТекущаяНастройка = Справочники.НастройкиОтраженияДокументовВБухгалтерии.ТекущаяНастройка();
	
	ОписаниеНастройки = Справочники.НастройкиОтраженияДокументовВБухгалтерии.ОписаниеНастройки(ТекущаяНастройка);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ОписаниеНастройки, "УзелОбмена,ДатаНачалаОтражения,ОтражениеВключено");
	
	ПодключенныеОрганизации.ЗагрузитьЗначения(ОписаниеНастройки.Организации);
	ПодключенныеРазделы.ЗагрузитьЗначения(ОписаниеНастройки.РазделыУчета);
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиМонитора()
	
	СохраненныеОтборы = ХранилищеОбщихНастроек.Загрузить(КлючОбъектаНастроекМонитора(), "Отборы");
	Если СохраненныеОтборы <> Неопределено Тогда
		СохраненныеОтборы.Свойство("Организация", ОтборОрганизация);
		СохраненныеОтборы.Свойство("Период", ОтборПериод);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНастройкиМонитора()
	
	ОтборыМонитора = Новый Структура;
	ОтборыМонитора.Вставить("Организация", ОтборОрганизация);
	ОтборыМонитора.Вставить("Период", ОтборПериод);
	
	ХранилищеОбщихНастроек.Сохранить(КлючОбъектаНастроекМонитора(), "Отборы", ОтборыМонитора);
	
	СформироватьИнтерфейсШапкиМонитораНаСервере();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КлючОбъектаНастроекМонитора()
	
	Возврат "СовместноеИспользование.МониторОтраженияДокументовВБухгалтерии";
	
КонецФункции

&НаСервере
Процедура ПодготовитьМониторОтражения(ОбновитьИнформационнуюПанель = Истина)
	
	ВосстановитьНастройкиОтражения();
	
	Если ОбновитьИнформационнуюПанель Тогда
		УстановитьОтображениеИнформационнойПанели();
	КонецЕсли;
	
	СформироватьИнтерфейсШапкиМонитораНаСервере();
	СформироватьИнтерфейсПоказателейМонитораНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтображениеИнформационнойПанели(ЕстьАктивноеСообщение = Неопределено)
	
	Если ЕстьАктивноеСообщение = Истина Тогда
		Элементы.ДекорацияОбщаяИнформация.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не закончено сопоставление данных в Бухгалтерии'"),
			Формат(ДатаНачалаОтражения, "ДЛФ=D"));
		Элементы.ДекорацияОбщаяИнформация.ЦветТекста = ЦветаСтиля.ЦветТекстаВнимание;
		Элементы.ГруппаОбщаяИнформация.ЦветФона = ЦветаСтиля.ЦветФонаПодсказки;
		Элементы.ДекорацияКартинкаВнимание.Видимость = Истина;
	Иначе
		Элементы.ДекорацияОбщаяИнформация.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Включено автоматическое отражение документов с %1'"),
			Формат(ДатаНачалаОтражения, "ДЛФ=D"));
		Элементы.ДекорацияОбщаяИнформация.ЦветТекста = ЦветаСтиля.ЦветТекстаКнопки;
		Элементы.ГруппаОбщаяИнформация.ЦветФона = ЦветаСтиля.АльтернативныйЦветФонаПоля;
		Элементы.ДекорацияКартинкаВнимание.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьИнтерфейсШапкиМонитораНаСервере()
	
	Если ЗначениеЗаполнено(ОтборОрганизация) Тогда
		Элементы.КомандаОтборМонитораОрганизации.Заголовок = Строка(ОтборОрганизация);
	Иначе
		Если ПодключенныеОрганизации.Количество() = 1 Тогда
			Элементы.КомандаОтборМонитораОрганизации.Заголовок = Строка(ПодключенныеОрганизации[0].Значение);
		Иначе
			Элементы.КомандаОтборМонитораОрганизации.Заголовок = НСтр("ru = 'Все организации'");
		КонецЕсли;
	КонецЕсли;
	
	Элементы.КомандаОтборМонитораПериод.Заголовок = РаботаСОтборамиКлиентСервер.ОбновитьПредставлениеПериода(ОтборПериод);
	
КонецПроцедуры

&НаСервере
Процедура СформироватьИнтерфейсПоказателейМонитораНаСервере()
	
	ВсеРазделы = СовместноеИспользование.ДоступныеРазделыУчета();
	Для Каждого ОписаниеРаздела Из ВсеРазделы Цикл
		ИдентификаторРаздела = ОписаниеРаздела.Идентификатор;
		
		ГруппаРаздела = Элементы.ГруппаМониторРазделыУчета.ПодчиненныеЭлементы.Найти(ПрефиксИмениГруппыРаздела() + ИдентификаторРаздела);
		Если ГруппаРаздела = Неопределено Тогда
			ГруппаРаздела = НоваяГруппаРаздела(ИдентификаторРаздела);
			
			ДобавитьГруппуСОсновнойКомандойРаздела(ГруппаРаздела, ИдентификаторРаздела, ОписаниеРаздела.Представление);
			ДобавитьДекорациюНадписьВыравниваниеРаздела(ГруппаРаздела, ИдентификаторРаздела);
			ДобавитьДекорациюКартинкаСтатусаРаздела(ГруппаРаздела, ИдентификаторРаздела);
		КонецЕсли;
		
		ГруппаРаздела.Видимость = (ПодключенныеРазделы.НайтиПоЗначению(ИдентификаторРаздела) <> Неопределено);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьОбновлениеСостоянияНастройкиОтражения()
	
	Элементы.ГруппаОбщаяИнформация.Доступность = Ложь;
	
	Элементы.ПанельМонитор.ТекущаяСтраница = Элементы.СтраницаОжидание;
	
	ПодключитьОбработчикОжидания("ОбновитьСостояниеНастройкиОтражения", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСостояниеНастройкиОтражения()
	
	ДлительнаяОперация = ДлительнаяОперацияПолучитьНастройкиСовместногоИспользования(УникальныйИдентификатор, ТекущаяНастройка);
		
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ОбновитьСостояниеНастройкиОтраженияЗавершение", ЭтотОбъект),
		ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСостояниеНастройкиОтраженияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	ЕстьАктивноеСообщение = Неопределено;
	
	Если Не Отказ Тогда
		Настройки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Если Настройки <> Неопределено Тогда
			ЕстьАктивноеСообщение = Настройки.Получить("УзелОбмена").Получить("ПолученоСообщениеДляСопоставления");
		КонецЕсли;
	КонецЕсли;
	
	УстановитьОтображениеИнформационнойПанели(ЕстьАктивноеСообщение);
	
	Элементы.ГруппаОбщаяИнформация.Доступность = Истина;
	
	ОбновитьДанныеМонитора();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПолучитьНастройкиСовместногоИспользования(ИдентификаторФормы, НастройкаСсылка)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ПолучитьНастройкиСовместногоИспользования",
		НастройкаСсылка);
	
КонецФункции

&НаКлиенте
Процедура ОбновитьДанныеМонитораБезЗапросаИзменений()
	
	ОбновитьДанныеМонитора(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеМонитора(ЗапроситьИзмененияДанных = Истина)
	
	ДлительнаяОперация = ДлительнаяОперацияПодготовитьДанныеМонитораНаСервере(ЗапроситьИзмененияДанных);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ОбновлениеДанныхМонитораЗавершение", ЭтотОбъект),
		ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияПодготовитьДанныеМонитораНаСервере(ЗапроситьИзмененияДанных)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Данные монитора отражения документов в учете'");
	Если ЗапроситьИзмененияДанных Тогда
		ПараметрыВыполнения.ОжидатьЗавершение = 0;
	КонецЕсли;
	
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить("ВыполнитьОбновлениеДанных", ЗапроситьИзмененияДанных);
	ПараметрыФункции.Вставить("Отборы", Новый Структура);
	
	ПараметрыФункции.Отборы.Вставить("Период", ОтборПериод);
	Если ЗначениеЗаполнено(ОтборОрганизация) Тогда
		ПараметрыФункции.Отборы.Вставить("Организации", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ОтборОрганизация));
	Иначе
		ПараметрыФункции.Отборы.Вставить("Организации", Новый Массив);
	КонецЕсли;
	ПараметрыФункции.Отборы.Вставить("РазделыУчета", ПодключенныеРазделы.ВыгрузитьЗначения());
	ПараметрыФункции.Отборы.Вставить("Статусы", Новый Массив);
	ПараметрыФункции.Отборы.Вставить("ТипыДокумента", Новый Массив);
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ПодготовитьДанныеМонитора",
		ПараметрыФункции);
	
КонецФункции

&НаКлиенте
Процедура ОбновлениеДанныхМонитораЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Если Не Отказ Тогда
	    ЗаполнитьДанныеМонитораНаСервере(Результат.АдресРезультата);
	КонецЕсли;
	
	Элементы.ПанельМонитор.ТекущаяСтраница = Элементы.СтраницаПоказатели;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗавершенииДлительнойОперации(Результат, Отказ)
	
	Если Результат = Неопределено Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Действие отменено. Повторите попытку позже.'"), , , , Отказ);
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(Результат.ИнформацияОбОшибке), , , , Отказ);
	КонецЕсли;
	
КонецПроцедуры

#Область МониторОтраженияДокументов

&НаСервере
Функция НоваяГруппаРаздела(ИдентификаторРаздела)
	
	ГруппаРаздела = Элементы.Добавить(
		ПрефиксИмениГруппыРаздела() + ИдентификаторРаздела,
		Тип("ГруппаФормы"),
		Элементы.ГруппаМониторРазделыУчета);
	ГруппаРаздела.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаРаздела.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	ГруппаРаздела.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
	ГруппаРаздела.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаРаздела.ОтображатьЗаголовок = Ложь;
	ГруппаРаздела.ЦветФона = ЦветаСтиля.ЦветФонаРазделаУчетаБезПредупреждений;
	ГруппаРаздела.Высота = 2;
	
	Возврат ГруппаРаздела;
	
КонецФункции

&НаСервере
Функция ПрефиксИмениГруппыРаздела()
	
	Возврат "ГруппаРазделУчета_";
	
КонецФункции

&НаСервере
Процедура ДобавитьГруппуСОсновнойКомандойРаздела(ГруппаРаздела, ИдентификаторРаздела, Представление)
	
	КомандаРаздела = Команды.Добавить("КомандаРазделаУчета_" + ИдентификаторРаздела);
	КомандаРаздела.Заголовок = Представление;
	КомандаРаздела.Действие = "ОбщийОбработчикКомандыРазделаУчета";
	
	КнопкаРаздела = Элементы.Добавить(
		КомандаРаздела.Имя,
		Тип("КнопкаФормы"),
		ГруппаРаздела);
	КнопкаРаздела.Заголовок = Представление;
	КнопкаРаздела.ОтображениеФигуры = ОтображениеФигурыКнопки.Нет;
	КнопкаРаздела.ИмяКоманды = КомандаРаздела.Имя;
	КнопкаРаздела.Шрифт = ШрифтыСтиля.ВажнаяНадписьШрифт;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьДекорациюКартинкаСтатусаРаздела(ГруппаРаздела, ИдентификаторРаздела)
	
	ДекорацияКартинкаСтатусРаздела = Элементы.Добавить(
		"ДекорацияСтатусРазделУчета_" + ИдентификаторРаздела,
		Тип("ДекорацияФормы"),
		ГруппаРаздела);
	ДекорацияКартинкаСтатусРаздела.Вид = ВидДекорацииФормы.Картинка;
	ДекорацияКартинкаСтатусРаздела.Картинка = БиблиотекаКартинок.РазделУчетаБезПредупреждений;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьДекорациюНадписьВыравниваниеРаздела(ГруппаРаздела, ИдентификаторРаздела)
	
	ДекорацияНадпись = Элементы.Добавить(
		"ДекорацияНадписьВыравнивание_" + ИдентификаторРаздела,
		Тип("ДекорацияФормы"),
		ГруппаРаздела);
	ДекорацияНадпись.Вид = ВидДекорацииФормы.Надпись;
	ДекорацияНадпись.АвтоМаксимальнаяШирина = Ложь;
	ДекорацияНадпись.РастягиватьПоГоризонтали = Истина;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтображениеСостоянияРаздела(ИдентификаторРаздела, ЕстьПредупрежения)
	
	Если ЕстьПредупрежения Тогда
		Элементы[ПрефиксИмениГруппыРаздела() + ИдентификаторРаздела].ЦветФона = ЦветаСтиля.ЦветФонаРазделаУчетаСПредупреждениями;
		Элементы["ДекорацияСтатусРазделУчета_" + ИдентификаторРаздела].Картинка = БиблиотекаКартинок.РазделУчетаСПредупреждениями;
	Иначе
		Элементы[ПрефиксИмениГруппыРаздела() + ИдентификаторРаздела].ЦветФона = ЦветаСтиля.ЦветФонаРазделаУчетаБезПредупреждений;
		Элементы["ДекорацияСтатусРазделУчета_" + ИдентификаторРаздела].Картинка = БиблиотекаКартинок.РазделУчетаБезПредупреждений;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеМонитораНаСервере(АдресРезультата)
	
	ДанныеОтражения = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	ТаблицаДанные = ДанныеОтражения.ТаблицаДокументов;
	
	Для Каждого ЭлементРаздел Из ПодключенныеРазделы Цикл
		ИдентификаторРаздела = ЭлементРаздел.Значение;
		
		ТаблицаДанныеПоРазделу = ТаблицаДанные.Скопировать(Новый Структура("РазделУчета", ИдентификаторРаздела));
		
		КоличествоВсего = ТаблицаДанныеПоРазделу.Количество();
		КоличествоОтражено = 0;
		КоличествоОшибок = 0;
		
		Для Каждого СтрокаДанныеПоРазделу Из ТаблицаДанныеПоРазделу Цикл
			Если СтрокаДанныеПоРазделу.ОтраженВБизнесе
				И СтрокаДанныеПоРазделу.ОтраженВБухгалтерии Тогда
				КоличествоОтражено = КоличествоОтражено + 1;
			КонецЕсли;
			Если СтрокаДанныеПоРазделу.ЕстьОшибкиОтражения Тогда
				КоличествоОшибок = КоличествоОшибок + 1;
			КонецЕсли;
		КонецЦикла;
		
		ЕстьПредупрежения = (КоличествоОтражено < КоличествоВсего) Или (КоличествоОшибок > 0);
		
		УстановитьОтображениеСостоянияРаздела(ИдентификаторРаздела, ЕстьПредупрежения);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти