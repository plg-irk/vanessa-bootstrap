#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МоментОткрытияФормы = ТекущаяДатаСеанса();
	
	Если Параметры.Свойство("ВнешняяУчетнаяСистема") Тогда
		ВнешняяУчетнаяСистема = Параметры.ВнешняяУчетнаяСистема;
	КонецЕсли;
	
	ТекущаяНастройка = Справочники.НастройкиОтраженияДокументовВБухгалтерии.ТекущаяНастройка();
	
	ЗагрузитьНастройкиИнтеграции();
	
	СформироватьСписокОрганизаций();
	СформироватьСписокРазделовУчета();
	
	Если Не ВосстановитьТекущиеНастройкиОтражения() Тогда
		Заголовок = НСтр("ru = 'Бухгалтерия: Начальная настройка'");
		
		Если Не ПолучитьФункциональнуюОпцию("ИспользоватьНесколькоОрганизаций") Тогда
			Если ДоступныеОрганизации.Количество() = 1 Тогда
				ДоступныеОрганизации[0].Пометка = Истина;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Заголовок = НСтр("ru = 'Бухгалтерия: Настройки'");
	КонецЕсли;
	
	СформироватьЭлементыУправленияОрганизаций();
	СформироватьЭлементыУправленияРазделовУчета();
	
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
		ПроверитьЗаполнениеОбязательныхРеквизитовОрганизации(СтрокаОрганизации.КлючСтроки);
		УстановитьОформлениеЭлементовОрганизации(СтрокаОрганизации.КлючСтроки);
	КонецЦикла;
	
	Если ОтражениеВключено Тогда
		КэшДатаНачалаОтражения = ДатаНачалаОтражения;
		КэшДоступныеОрганизации.Загрузить(ДоступныеОрганизации.Выгрузить());
		КэшРазделыУчета.Загрузить(РазделыУчета.Выгрузить());
	Иначе
		Если Не ЗначениеЗаполнено(ДатаНачалаОтражения) Тогда
			ДатаНачалаОтражения = ТекущаяДатаСеанса();
		КонецЕсли;
	КонецЕсли;
	
	ПриИзмененииДатыНачалаОтраженияНаСервере();
	
	Элементы.ДекорацияЗаголовокОрганизации.Заголовок = ?(
		ПолучитьФункциональнуюОпцию("ИспользоватьНесколькоОрганизаций"),
		НСтр("ru = 'Организации'"),
		НСтр("ru = 'Организация'"));
		
	НачальнаяНастройкаВыполнена = ОтражениеВключено;
		
	Элементы.ГруппаИнформация.Видимость = Не НачальнаяНастройкаВыполнена;	
	Элементы.ОтражениеВключено.Видимость = ОтражениеВключено;
	
	Элементы.ГруппаПоздравление.Видимость = Не НачальнаяНастройкаВыполнена;
	Элементы.ДекорацияНадписьОтступРазделыУчета.Видимость = НачальнаяНастройкаВыполнена;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.ГруппаНастройкиОтраженияПервыйЭтап.Доступность = Ложь;
	
	УстановитьДоступностьКомандНачалаРаботыИИзмененияОрганизаций();
	
	Если ОтражениеВключено
		И ПриложенияБухгалтерии.Количество() > 0 Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОжиданиеСостояниеНастройки");
		
		ПодключитьОбработчикОжидания("ПолучитьНастройкиСовместногоИспользования", 0.1, Истина);
		
	Иначе
		УстановитьРежимПомощника("НачалоРаботыОжиданиеБухгалтерии");
		
		ПодключитьОбработчикОжидания("ПолучитьНастройкиБухгалтерии", 0.1, Истина);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "СовместноеИспользование.ЗакрытаФормаНастройкиУчетнойПолитикиОрганизации" Тогда
		ИдентификаторОрганизации = Параметр.Получить("ИдентификаторОрганизации");
		КлючОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("ПубличныйИдентификатор", ИдентификаторОрганизации))[0].КлючСтроки;
		
		УстановитьОформлениеЭлементовОрганизации(КлючОрганизации, Истина);
		ПолучитьСостояниеУчетнойПолитикиОрганизаций(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(КлючОрганизации));
	ИначеЕсли ИмяСобытия = "СовместноеИспользование.ЗакрытаФормаНастройкиСистемыНалогобложенияОрганизации" Тогда
		ИдентификаторОрганизации = Параметр.Получить("ИдентификаторОрганизации");
		КлючОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("ПубличныйИдентификатор", ИдентификаторОрганизации))[0].КлючСтроки;
		
		УстановитьОформлениеЭлементовОрганизации(КлючОрганизации, Истина);
		ПолучитьСостояниеУчетнойПолитикиОрганизаций(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(КлючОрганизации));
	ИначеЕсли ИмяСобытия = "СовместноеИспользование.ЗакрытПомощникСопоставленияОбъектов" Тогда
		Если ОтражениеВключено Тогда
			УстановитьРежимПомощника("НастройкиОтраженияОжиданиеСостояниеНастройки");
		
			ПодключитьОбработчикОжидания("ПолучитьНастройкиСовместногоИспользования", 0.1, Истина);
		КонецЕсли;
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	Если СтрНачинаетсяС(НавигационнаяСсылкаФорматированнойСтроки, "НастройкаУчетнойПолитики_") Тогда
		СтандартнаяОбработка = Ложь;
		
		КлючОрганизации = СтрРазделить(НавигационнаяСсылкаФорматированнойСтроки, "_")[1];
		СтрокаОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", КлючОрганизации))[0];
		
		ШаблонСсылки = "СовместноеИспользование/НастройкиУчетнойПолитикиОрганизации?uuid=%1&period=%2";
		
		СовместноеИспользованиеКлиент.ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(
			СтрШаблон(ШаблонСсылки, СтрокаОрганизации.ПубличныйИдентификатор, Формат(ДатаНачалаОтражения, "ДФ=yyyy-MM-dd")),
			"БухгалтерияПредприятия");
		
	ИначеЕсли СтрНачинаетсяС(НавигационнаяСсылкаФорматированнойСтроки, "НастройкаСистемыНалогообложения_") Тогда
		СтандартнаяОбработка = Ложь;
		
		КлючОрганизации = СтрРазделить(НавигационнаяСсылкаФорматированнойСтроки, "_")[1];
		СтрокаОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", КлючОрганизации))[0];
		
		ШаблонСсылки = "СовместноеИспользование/НастройкиСистемыНалогобложенияОрганизации?uuid=%1";
		
		СовместноеИспользованиеКлиент.ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(
			СтрШаблон(ШаблонСсылки, СтрокаОрганизации.ПубличныйИдентификатор),
			"БухгалтерияПредприятия");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОтражениеВключеноПриИзменении(Элемент)
	
	Если Не ОтражениеВключено Тогда
		Элементы.ОтражениеВключено.Доступность = Ложь;
		ОтражениеВключено = Истина;
		
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ВопросОтражениеВключеноЗавершение", ЭтотОбъект),
			НСтр("ru = 'Это отключит процесс отражения и удалит сделанные настройки. Продолжить?'"),
			РежимДиалогаВопрос.ДаНет);  
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаОтраженияПриИзменении(Элемент)
	
	Элементы.ГруппаКалендарьДатаНачалаОтражения.Скрыть();

	ПриИзмененииДатыНачалаОтраженияНаСервере();
	
	Если ЗначениеЗаполнено(ДатаНачалаОтражения) И НачальнаяНастройкаВыполнена Тогда
		Для Каждого СтрокаОрганизации Из ДоступныеОрганизации.НайтиСтроки(Новый Структура("Пометка", Истина)) Цикл
			СтрокаОрганизации.БылЗапросПолитики = Ложь;
		КонецЦикла;
		ПодключитьОбработчикОжидания("ОбновитьСостояниеУчетнойПолитикиОрганизаций", 0.1, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФлажокРазделаУчетаПриИзменении(Элемент)
	
	Если Не СтрНачинаетсяС(Элемент.Имя, "Раздел_") Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторРаздела = СтрРазделить(Элемент.Имя, "_")[1];
	
	СтрокиРазделыУчета = РазделыУчета.НайтиСтроки(Новый Структура("Идентификатор", ИдентификаторРаздела));
	
	Элементы["КомандаВидыДокументов_" + ИдентификаторРаздела].Доступность = СтрокиРазделыУчета[0].Пометка;   

	ФлажокРазделаУчетаПриИзмененииНаСервере(СтрокиРазделыУчета[0].Идентификатор, СтрокиРазделыУчета[0].ПоВсемДокументам, СтрокиРазделыУчета[0].Пометка);
	
КонецПроцедуры

&НаКлиенте
Процедура ФлажокОрганизацииПриИзменении(Элемент)
	
	Если Не СтрНачинаетсяС(Элемент.Имя, "Организация_") Тогда
		Возврат;
	КонецЕсли;
	
	КлючОрганизации = СтрРазделить(Элемент.Имя, "_")[1];
	
	ФлажокОрганизацииПриИзмененииНаСервере(КлючОрганизации);
	
	УстановитьДоступностьКомандНачалаРаботыИИзмененияОрганизаций();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаНачатьРаботу(Команда)
	
	УстановитьРежимПомощника("НачалоРаботыФоновыйОбмен");
	УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Ложь);
	
	ПодключитьОбработчикОжидания("НачатьРаботу", 0.1, Истина);
	
КонецПроцедуры  

&НаКлиенте
Процедура КомандаОрганизацииИзменены(Команда)
	
	УстановитьРежимПомощника("НастройкиОтраженияОжиданиеОрганизаций");
	УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Ложь);
	
	Элементы.КомандаОрганизацииИзменены.Доступность = Ложь;

	ПодключитьОбработчикОжидания("ВыполнитьНастройкуОрганизаций", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОтразитьДокументы(Команда)
	
	Если ОтражениеВключено Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОбновлениеНастроек");
	Иначе
		УстановитьРежимПомощника("НастройкиОтраженияФоновыйОбмен");
	КонецЕсли;
	
	УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Ложь);
	
	ПодключитьОбработчикОжидания("СохранитьНастройкиИВыполнитьСинхронизацию", 0.1, Истина);

КонецПроцедуры

&НаКлиенте
Процедура КомандаСохранитьНастройки(Команда)
	
	Если ОтражениеВключено Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОбновлениеНастроек");
	Иначе
		УстановитьРежимПомощника("НастройкиОтраженияФоновыйОбмен");
	КонецЕсли;
	
	УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Ложь);
	
	ПодключитьОбработчикОжидания("СохранитьНастройкиИВыйти", 0.1, Истина);
	
КонецПроцедуры    

&НаКлиенте
Процедура КомандаТехническиеНастройки(Команда)     
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("Ключ", УзелОбмена);
	
	ОткрытьФорму("ПланОбмена.СинхронизацияДанныхЧерезУниверсальныйФормат.Форма.ФормаУзла",
		ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбщийОбработчикКомандыОрганизации(Команда)
	
	Если Не СтрНачинаетсяС(Команда.Имя, "КомандаОрганизации_") Тогда
		Возврат;
	КонецЕсли;
	
	КлючОрганизации = СтрРазделить(Команда.Имя, "_")[1];
	
	СтрокаОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", КлючОрганизации))[0];
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("КлючОрганизации", КлючОрганизации);
	
	ОткрытьФорму("Справочник.Организации.ФормаОбъекта",
		Новый Структура("Ключ", СтрокаОрганизации.Ссылка),
		ЭтотОбъект,
		,
		,
		,
		Новый ОписаниеОповещения("ОбщийОбработчикКомандыОрганизацииЗакрытие", ЭтотОбъект, ДополнительныеПараметры));
	
КонецПроцедуры

&НаКлиенте
Процедура ОбщийОбработчикКомандыВидыДокументов(Команда)
	
	Если Не СтрНачинаетсяС(Команда.Имя, "КомандаВидыДокументов_") Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторРаздела = СтрРазделить(Команда.Имя, "_")[1];
	
	СтрокиРазделы = РазделыУчета.НайтиСтроки(Новый Структура("Идентификатор", ИдентификаторРаздела));
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИдентификаторРаздела", ИдентификаторРаздела);
	ДополнительныеПараметры.Вставить("ИмяКоманды", Команда.Имя);
	
	СписокВыбора = Новый СписокЗначений;
	СписокВыбора.Добавить("ПоВсемДокументам", НСтр("ru = 'Все документы'"), СтрокиРазделы[0].ПоВсемДокументам);
	СписокВыбора.Добавить("ВыбратьИзСписка", НСтр("ru = 'Выбрать из списка'"), Не СтрокиРазделы[0].ПоВсемДокументам);
	
	ПоказатьВыборИзМеню(
		Новый ОписаниеОповещения("ВыборИзМенюОтборПоВидамДокументовЗавершение", ЭтотОбъект, ДополнительныеПараметры),
		СписокВыбора);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПерейтиВСопоставление(Команда)
	
	ПерейтиВПомощникСопоставленияОбъектовБухгалтерии();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПерейтиВЖурналОпераций(Команда)
	
	СсылкаДляПерехода = "e1cib/command/ОбщаяКоманда.ЖурналОпераций";   
	СовместноеИспользованиеКлиент.ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(
		СсылкаДляПерехода,
		"БухгалтерияПредприятия",
		Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПерейтиВЖурналРегистрации(Команда)   

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ДатаНачала", МоментОткрытияФормы);
	ПараметрыФормы.Вставить("ДатаОкончания", КонецДня(МоментОткрытияФормы));
	ПараметрыФормы.Вставить("Уровень", "Ошибка");
	ПараметрыФормы.Вставить("ЗапускатьНеВФоне", Истина);
	
	ЖурналРегистрацииКлиент.ОткрытьЖурналРегистрации(ПараметрыФормы);  
	
	Закрыть();

КонецПроцедуры

&НаКлиенте
Процедура КомандаПерейтиВПолныйИнтерфейс(Команда)
	
	СсылкаДляПерехода = "e1cib/command/Обработка.ПанельАдминистрированияБП.Команда.Интерфейс";   
	СовместноеИспользованиеКлиент.ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(
		СсылкаДляПерехода,
		"БухгалтерияПредприятия",
		Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ФлажокРазделаУчетаПриИзмененииНаСервере(ИдентификаторРаздела, ПоВсемДокументам, Пометка)
	
	ВыборВидовДокументов = ПодготовитьВыборВидовДокументовПоРазделу(ИдентификаторРаздела);
	СписокВыбора = ВыборВидовДокументов.СписокВыбора;
	Если ПоВсемДокументам Тогда
		Для Каждого Элемент Из СписокВыбора Цикл
			Элемент.Пометка = Пометка;
		КонецЦикла;
	КонецЕсли; 
	
	КоличествоКВыгрузке = ПодсчитатьКоличествоДокументовПоРазделу(СписокВыбора, ИдентификаторРаздела);     
	УстановитьСвойстваСтрокиРаздела(ИдентификаторРаздела, КоличествоКВыгрузке);    
	УстановитьСвойстваКомандыОтразитьДокументы();
	
КонецПроцедуры

&НаСервере
Процедура ФлажокОрганизацииПриИзмененииНаСервере(КлючОрганизации)
	
	Если НачальнаяНастройкаВыполнена Тогда
		БылиИзменения = СравнитьКэшОрганизацийИРеквизиты(Истина);
		
		Элементы.КомандаОрганизацииИзменены.Видимость = БылиИзменения;
		Элементы.ГруппаКомандыВторогоЭтапаНастройки.Доступность = Не БылиИзменения;
	КонецЕсли;
	
	ПроверитьЗаполнениеОбязательныхРеквизитовОрганизации(КлючОрганизации);
	
	УстановитьОформлениеЭлементовОрганизации(КлючОрганизации, Ложь);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СинхронизацияДанныхЗапланирована(НастройкаОтражения, ВнешняяУчетнаяСистема)
	
	Возврат Обработки.ОтражениеДокументовВБухгалтерии.СинхронизацияДанныхЗапланирована(НастройкаОтражения, ВнешняяУчетнаяСистема);
	
КонецФункции  

&НаКлиенте
Процедура ОбработкаОжиданияЗавершенияСценарияОбмена()

	ОбменЗапланирован = СинхронизацияДанныхЗапланирована(ТекущаяНастройка, ВнешняяУчетнаяСистема);
	Если ОбменЗапланирован Тогда   
		ПодключитьОбработчикОжидания("ОбработкаОжиданияЗавершенияСценарияОбмена", 20, Истина);       
	Иначе  
		УстановитьРежимПомощника("НастройкиОтраженияУспехБухгалтерияПуста");
		УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
		
		Элементы.ОтражениеВключено.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СравнитьКэшИРеквизиты()    
	
	БылиДополняющиеИзменения = СравнитьКэшОрганизацийИРеквизиты();
	
	Для Каждого СтрокаРаздела Из РазделыУчета Цикл     
		СтрокиКэша = КэшРазделыУчета.НайтиСтроки(Новый Структура("Идентификатор", СтрокаРаздела.Идентификатор)); 
		Если СтрокиКэша.Количество() = 1 Тогда  
			СтрокаКэша = СтрокиКэша[0];
			Если СтрокаРаздела.Пометка И Не СтрокаКэша.Пометка Тогда
				БылиИзменения = Истина;
				БылиДополняющиеИзменения = Истина;
			ИначеЕсли Не СтрокаРаздела.Пометка И СтрокаКэша.Пометка Тогда
				БылиИзменения = Истина; 
			КонецЕсли;
		ИначеЕсли СтрокиКэша.Количество() = 0 Тогда  
			БылиИзменения = Истина;
			БылиДополняющиеИзменения = Истина;
		КонецЕсли;
	КонецЦикла;   
	
	Если ДатаНачалаОтражения < КэшДатаНачалаОтражения Тогда
		БылиИзменения = Истина;
		БылиДополняющиеИзменения = Истина;
	ИначеЕсли ДатаНачалаОтражения > КэшДатаНачалаОтражения Тогда
		БылиИзменения = Истина; 
	КонецЕсли;   
	
	Возврат БылиДополняющиеИзменения;
	
КонецФункции

&НаСервере
Функция СравнитьКэшОрганизацийИРеквизиты(ВсеИзменения = Ложь)    
	
	БылиИзменения = Ложь;
	БылиДополняющиеИзменения = Ложь;
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл     
		СтрокиКэша = КэшДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", СтрокаОрганизации.КлючСтроки)); 
		Если СтрокиКэша.Количество() = 1 Тогда  
			СтрокаКэша = СтрокиКэша[0];
			Если СтрокаОрганизации.Пометка И Не СтрокаКэша.Пометка Тогда
				БылиИзменения = Истина;
				БылиДополняющиеИзменения = Истина;
			ИначеЕсли Не СтрокаОрганизации.Пометка И СтрокаКэша.Пометка Тогда
				БылиИзменения = Истина; 
			КонецЕсли;    
		ИначеЕсли СтрокиКэша.Количество() = 0 Тогда  
			БылиИзменения = Истина;
			БылиДополняющиеИзменения = Истина;
		КонецЕсли;
	КонецЦикла;   

	Если ВсеИзменения Тогда
		Возврат БылиИзменения;
	Иначе
		Возврат БылиДополняющиеИзменения;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ВыполнитьРегистрациюИзмененийДляНачальнойВыгрузки()       
	
	СоставПлана = Новый Массив;
	Для Каждого ЭлементСостава Из Метаданные.ПланыОбмена.СинхронизацияДанныхЧерезУниверсальныйФормат.Состав Цикл
		СоставПлана.Добавить(ЭлементСостава.Метаданные);
	КонецЦикла;

	МассивДокументов = Новый Массив;
	Для Каждого СтрокаДокумента Из ДокументыКВыгрузке Цикл   
		МетаданныеДокумента = СтрокаДокумента.Ссылка.Метаданные();   
		Если СоставПлана.Найти(МетаданныеДокумента) <> Неопределено Тогда
			МассивДокументов.Добавить(СтрокаДокумента.Ссылка);
		КонецЕсли;
	КонецЦикла;   
	Если МассивДокументов.Количество() > 0 Тогда
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, МассивДокументов);
		ДокументыКВыгрузке.Очистить();  
	КонецЕсли; 
	
КонецПроцедуры    

&НаСервере
Процедура АктуализироватьКэши()
	
	КэшДатаНачалаОтражения = ДатаНачалаОтражения;
	КэшДоступныеОрганизации.Загрузить(ДоступныеОрганизации.Выгрузить());
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОформлениеЭлементовОрганизации(КлючОрганизации, ДлительнаяОперация = Ложь)
	
	ДанныеПоОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", КлючОрганизации))[0];
	
	ЭлементГруппа = Элементы["ГруппаОрганизация_" + КлючОрганизации];
	ЭлементФлажок = Элементы["Организация_" + КлючОрганизации];
	ЭлементКнопка = Элементы["КомандаОрганизации_" + КлючОрганизации];
	ЭлементНадпись = Элементы["ДекорацияНадписьСтатусОрганизация_" + КлючОрганизации];
	ЭлементКартинка = Элементы["ДекорацияКартинкаСтатусОрганизация_" + КлючОрганизации];

	ЭлементКнопка.Шрифт = ?(ДанныеПоОрганизации.Пометка, ШрифтыСтиля.ВажнаяНадписьШрифт, ШрифтыСтиля.ОбычныйШрифтТекста);
	
	ЭлементФлажок.Доступность = Не ДлительнаяОперация;
	ЭлементКнопка.Доступность = Не ДлительнаяОперация;
	
	ЭлементНадпись.Заголовок = "";
	ЭлементНадпись.Видимость = Ложь;
	
	ЭлементГруппа.Подсказка = "";
	ЭлементГруппа.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	
	ЭлементКартинка.Картинка = БиблиотекаКартинок.РазделУчетаБезПредупреждений;
	
	Если ДлительнаяОперация Тогда
		ЭлементКартинка.Картинка = БиблиотекаКартинок.ДлительнаяОперация16;
	Иначе
		Если ДанныеПоОрганизации.Пометка И ДанныеПоОрганизации.ЕстьНезаполненныеРеквизиты Тогда
			ЭлементГруппа.Подсказка = ДанныеПоОрганизации.ОшибкиПроверкиЗаполнения;
			ЭлементГруппа.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
			
			ЭлементКартинка.Картинка = БиблиотекаКартинок.РазделУчетаСПредупреждениями;
		ИначеЕсли ДанныеПоОрганизации.ОшибкаВыгрузки Тогда
			ЭлементНадпись.Заголовок = НСтр("ru = 'Не удалось сравнить сведения'");
			ЭлементНадпись.Видимость = Истина;
			
			ЭлементКартинка.Картинка = БиблиотекаКартинок.РазделУчетаСПредупреждениями;
		ИначеЕсли ДанныеПоОрганизации.Пометка Тогда
			Если ДанныеПоОрганизации.БылЗапросПолитики
				И Не ДанныеПоОрганизации.УчетнаяПолитикаСуществует
				И Не ДанныеПоОрганизации.СистемаНалогообложенияСуществует Тогда
				ЭлементКартинка.Картинка = БиблиотекаКартинок.РазделУчетаСПредупреждениями;
				
				ЭлементНадпись.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(
					НСтр("ru = 'не настроены <a href=""НастройкаУчетнойПолитики_%1"
						">учетная политика</a> и <a href=""НастройкаСистемыНалогообложения_%1"
						">система налогобложения</a>'"),
					КлючОрганизации);
				ЭлементНадпись.Видимость = Истина;
			ИначеЕсли ДанныеПоОрганизации.БылЗапросПолитики
				И Не ДанныеПоОрганизации.УчетнаяПолитикаСуществует Тогда
				ЭлементКартинка.Картинка = БиблиотекаКартинок.РазделУчетаСПредупреждениями;
				
				ЭлементНадпись.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(
					НСтр("ru = 'не настроена <a href=""НастройкаУчетнойПолитики_%1>учетная политика</a>'"),
					КлючОрганизации);
				ЭлементНадпись.Видимость = Истина;
			ИначеЕсли ДанныеПоОрганизации.БылЗапросПолитики
				И Не ДанныеПоОрганизации.СистемаНалогообложенияСуществует Тогда
				ЭлементКартинка.Картинка = БиблиотекаКартинок.РазделУчетаСПредупреждениями;
				
				ЭлементНадпись.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(
					НСтр("ru = 'не настроена <a href=""НастройкаСистемыНалогообложения_%1>система налогобложения</a>'"),
					КлючОрганизации);
				ЭлементНадпись.Видимость = Истина;
			ИначеЕсли Не ДанныеПоОрганизации.БылЗапросПолитики Тогда
				ЭлементКартинка.Картинка = БиблиотекаКартинок.Пустая;
			КонецЕсли;
		Иначе
			ЭлементКартинка.Картинка = БиблиотекаКартинок.Пустая;
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборИзМенюОтборПоВидамДокументовЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиРазделы = РазделыУчета.НайтиСтроки(Новый Структура("Идентификатор", ДополнительныеПараметры.ИдентификаторРаздела));
	
	ОбработкаВыбора = Новый ОписаниеОповещения("ОтметкаВидовДокументовПоРазделуЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ВыборВидовДокументов = ПодготовитьВыборВидовДокументовПоРазделу(ДополнительныеПараметры.ИдентификаторРаздела);
	Если ВыбранныйЭлемент.Значение = "ПоВсемДокументам" Тогда
		СтрокиРазделы[0].ПоВсемДокументам = Истина;
		
		СписокВыбора = ВыборВидовДокументов.СписокВыбора;
		Для Каждого Элемент Из СписокВыбора Цикл
			Элемент.Пометка = Истина;
		КонецЦикла;
		ВыполнитьОбработкуОповещения(ОбработкаВыбора, ВыборВидовДокументов.СписокВыбора);
	ИначеЕсли ВыбранныйЭлемент.Значение = "ВыбратьИзСписка" Тогда
		СтрокиРазделы[0].ПоВсемДокументам = Ложь;
		
		ВыборВидовДокументов.СписокВыбора.ПоказатьОтметкуЭлементов(
			ОбработкаВыбора,
			ВыборВидовДокументов.Заголовок);
	КонецЕсли;  
		
КонецПроцедуры

&НаКлиенте
Процедура ОтметкаВидовДокументовПоРазделуЗавершение(СписокВыбора, ДополнительныеПараметры) Экспорт
	
	Если СписокВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура("РазделУчета", ДополнительныеПараметры.ИдентификаторРаздела);
	Для Каждого СтрокаВыбранные Из ВыбранныеВидыДокументов.НайтиСтроки(Отбор) Цикл
		ВыбранныеВидыДокументов.Удалить(СтрокаВыбранные);
	КонецЦикла;
	
	Для Каждого Элемент Из СписокВыбора Цикл
		Если Элемент.Пометка Тогда
			НоваяСтрока = ВыбранныеВидыДокументов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент.Значение);
		КонецЕсли;
	КонецЦикла;
	
	УстановитьСвойстваКомандыВидыДокументов(ДополнительныеПараметры.ИмяКоманды, ДополнительныеПараметры.ИдентификаторРаздела);

	КоличествоКВыгрузке = ПодсчитатьКоличествоДокументовПоРазделу(СписокВыбора, ДополнительныеПараметры.ИдентификаторРаздела);  
	УстановитьСвойстваСтрокиРаздела(ДополнительныеПараметры.ИдентификаторРаздела, КоличествоКВыгрузке);   
	УстановитьСвойстваКомандыОтразитьДокументы();
	
КонецПроцедуры

#Область ПолучениеНастроекБухгалтерии

&НаКлиенте
Процедура ПолучитьНастройкиБухгалтерии()
	
	Если ПриложенияБухгалтерии.Количество() = 0 Тогда
		Если ВнешняяУчетнаяСистема Тогда
			ПолучитьПараметрыПодключенияКВнешнейУчетнойСистеме();
		Иначе
			ПолучитьДоступныеПриложенияБухгалтерии();
		КонецЕсли;
	Иначе
		ПослеПолученияДоступныхПриложенийБухгалтерии();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьРаботу()
	
	ДлительнаяОперация = ДлительнаяОперацияПолучитьНастройкиБухгалтерии();
		
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ПолучитьНастройкиБухгалтерииЗавершение", ЭтотОбъект, Новый Структура("НачалоРаботы", Истина)),
		ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияПолучитьНастройкиБухгалтерии()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ПолучитьНастройкиПриложения",
		ТекущиеПараметрыПодключения());

КонецФункции

&НаКлиенте
Процедура ПолучитьНастройкиБухгалтерииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	НастройкиБухгалтерии = Неопределено;
	Если Не Отказ Тогда
		НастройкиБухгалтерии = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	КонецЕсли;
	
	Если НастройкиБухгалтерии = Неопределено Тогда
		Если ДополнительныеПараметры.НачалоРаботы Тогда
			УстановитьРежимПомощника("НачалоРаботыИнформацияОшибка");
			УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
		Иначе
			ПоказатьПредупреждение(
				Новый ОписаниеОповещения("ПредупреждениеНастройкаОтраженияНедоступнаЗавершение", ЭтотОбъект),
				НСтр("ru = 'Настройка отражения документов в бухгалтерии временно недоступна. Повторите попытку позже.'"));
		КонецЕсли;
		
		Возврат;
	КонецЕсли;
	
	Если Не ТекущаяНастройка.Пустая()
		И Не ДополнительныеПараметры.НачалоРаботы Тогда
		УстановитьПараметрыПодключенияКБухгалтерииНаСервере(ТекущаяНастройка);
	КонецЕсли;
	
	НачалоРаботы = НастройкиБухгалтерии.Получить("НачалоРаботы"); 
	КоличествоОрганизаций = НастройкиБухгалтерии.Получить("КоличествоОрганизаций"); 
	БухгалтерияПуста = НачалоРаботы Или КоличествоОрганизаций = 0;
	ВключенПолныйИнтерфейс = НастройкиБухгалтерии.Получить("ПолныйИнтерфейс");
	
	Если ДополнительныеПараметры.НачалоРаботы Тогда
		Если Не БухгалтерияПуста И ВключенПолныйИнтерфейс = Ложь Тогда
			УстановитьРежимПомощника("НачалоРаботыИнформацияТребуетсяПолныйИнтерфейс");
			УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
			Возврат;
		КонецЕсли;
		
		УстановитьРежимПомощника("НачалоРаботыОжиданиеОрганизации");
		
		ПодключитьОбработчикОжидания("ВыполнитьНастройкуОрганизаций", 0.1, Истина);
	Иначе
		Если БухгалтерияПуста Тогда
			УстановитьРежимПомощника("НачалоРаботыИнформацияПустая");
		Иначе
			Если ВключенПолныйИнтерфейс = Неопределено Тогда
				УстановитьРежимПомощника("НачалоРаботыИнформацияРекомендуетсяПолныйИнтерфейс");
			ИначеЕсли ВключенПолныйИнтерфейс = Истина Тогда
				УстановитьРежимПомощника("НачалоРаботыИнформацияПустая");
			Иначе
				УстановитьРежимПомощника("НачалоРаботыИнформацияТребуетсяПолныйИнтерфейс");
			КонецЕсли;
		КонецЕсли;
		
		Элементы.ГруппаНастройкиОтраженияПервыйЭтап.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ПолучениеДоступныхПриложенийБухгалтерии

&НаКлиенте
Процедура ПолучитьПараметрыПодключенияКВнешнейУчетнойСистеме()
	ОткрытьФорму(
		"Обработка.ОтражениеДокументовВБухгалтерии.Форма.ПараметрыПодключенияКВнешнейУчетнойСистеме",
		,
		ЭтотОбъект,
		,
		,
		,
		Новый ОписаниеОповещения("ПолучитьПараметрыПодключенияКВнешнейУчетнойСистемеЗавершение", ЭтотОбъект));
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьПараметрыПодключенияКВнешнейУчетнойСистемеЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Закрыть();
		Возврат;
	КонецЕсли;
	
	СтрокаПриложения = ПриложенияБухгалтерии.Добавить();
	СтрокаПриложения.ВнешняяУчетнаяСистема = ВнешняяУчетнаяСистема;
	ЗаполнитьЗначенияСвойств(СтрокаПриложения, РезультатЗакрытия);
	
	ПослеПолученияДоступныхПриложенийБухгалтерии();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьДоступныеПриложенияБухгалтерии()
	
	ДлительнаяОперация = ДлительнаяОперацияПолучитьДоступныеПриложенияБухгалтерии(УникальныйИдентификатор);
		
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ПолучитьДоступныеПриложенияБухгалтерииЗавершение", ЭтотОбъект),
		ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПолучитьДоступныеПриложенияБухгалтерии(ИдентификаторФормы)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"РегистрыСведений.НастройкиИнтеграцииСБухгалтерией.ДоступныеПриложенияБухгалтерии");

КонецФункции

&НаКлиенте
Процедура ПолучитьДоступныеПриложенияБухгалтерииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Если Не Отказ Тогда
		ПолучитьДоступныеПриложенияБухгалтерииЗавершениеНаСервере(Результат.АдресРезультата);
	КонецЕсли;
	
	Если ПриложенияБухгалтерии.Количество() = 0 Тогда
		ПоказатьПредупреждение(
			Новый ОписаниеОповещения("ПредупреждениеНастройкаОтраженияНедоступнаЗавершение", ЭтотОбъект),
			НСтр("ru = 'Настройка отражения документов в бухгалтерии временно недоступна. Повторите попытку позже.'"));
		Возврат;
	КонецЕсли;
	
	ПослеПолученияДоступныхПриложенийБухгалтерии();
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДоступныеПриложенияБухгалтерииЗавершениеНаСервере(АдресВХранилище)
	
	ПриложенияБухгалтерии.Очистить();
	
	ДоступныеПриложения = ПолучитьИзВременногоХранилища(АдресВХранилище);
	
	Если ДоступныеПриложения <> Неопределено Тогда
		Для Каждого СтрокаДоступные Из ДоступныеПриложения Цикл
			СтрокаПриложения = ПриложенияБухгалтерии.Добавить();
			СтрокаПриложения.НомерОбласти = СтрокаДоступные.Код;
			СтрокаПриложения.АдресПриложения = СтрокаДоступные.АдресПриложения;
			СтрокаПриложения.Наименование = СтрокаДоступные.Наименование;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПолученияДоступныхПриложенийБухгалтерии()
	
	ОбработчикВыбора = Новый ОписаниеОповещения("ВыборПриложенияБухгалтерииЗавершение", ЭтотОбъект);
		
	СписокВыбора = Новый СписокЗначений;
	Для Каждого ОписаниеПриложения Из ПриложенияБухгалтерии Цикл
		ПредставлениеПриложения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = '%1 (%2)'"),
			ОписаниеПриложения.Наименование,
			Формат(ОписаниеПриложения.НомерОбласти, "ЧГ=0"));
		СписокВыбора.Добавить(ОписаниеПриложения.НомерОбласти, ПредставлениеПриложения);
	КонецЦикла;
	
	Если СписокВыбора.Количество() = 1 Тогда
		ВыполнитьОбработкуОповещения(ОбработчикВыбора, СписокВыбора[0]);
	Иначе
		СписокВыбора.ПоказатьВыборЭлемента(ОбработчикВыбора, НСтр("ru = 'Приложение бухгалтерии'"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборПриложенияБухгалтерииЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Закрыть();
		Возврат;
	КонецЕсли;
	
	НомерОбласти = ВыбранныйЭлемент.Значение;
	
	ДлительнаяОперация = ДлительнаяОперацияПолучитьНастройкиБухгалтерии();
		
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ПолучитьНастройкиБухгалтерииЗавершение", ЭтотОбъект, Новый Структура("НачалоРаботы", Ложь)),
		ПараметрыОжидания);
	
КонецПроцедуры

#КонецОбласти

#Область НастройкаОрганизаций

&НаКлиенте
Процедура ВыполнитьНастройкуОрганизаций()
	
	ОрганизацииДляОтправки = Новый Массив;
	
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации.НайтиСтроки(Новый Структура("Пометка,ПубличныйИдентификатор", Истина, "")) Цикл
		ОрганизацииДляОтправки.Добавить(СтрокаОрганизации.Ссылка); 
	КонецЦикла;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ОрганизацииДляОтправки", ОрганизацииДляОтправки);
	
	Если ОрганизацииДляОтправки.Количество() > 0 Тогда
		ДлительнаяОперация = ДлительнаяОперацияВыполнитьНачальнуюНастройкуОрганизаций(ОрганизацииДляОтправки);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(
			ДлительнаяОперация,
			Новый ОписаниеОповещения("ВыполнитьНастройкуОрганизацийЗавершение", ЭтотОбъект, ДополнительныеПараметры),
			ПараметрыОжидания);
	Иначе
		ПослеНастройкиОрганизаций();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияВыполнитьНачальнуюНастройкуОрганизаций(ОрганизацииДляОтправки)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ВыполнитьНачальнуюНастройкуОрганизаций",
		ОрганизацииДляОтправки,
		ТекущиеПараметрыПодключения());
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьНастройкуОрганизацийЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Если Не Отказ Тогда
		РезультатВыгрузки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
		Для Каждого КлючЗначение Из РезультатВыгрузки Цикл
			ОрганизацияСсылка = КлючЗначение.Ключ;
			РезультатСозданияОрганизации = КлючЗначение.Значение;
			
			СтрокаОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("Ссылка", ОрганизацияСсылка))[0];
			СтрокаОрганизации.ОшибкаВыгрузки = РезультатСозданияОрганизации.Отказ;
			
			СтрокаОрганизации.ЕстьНезаполненныеРеквизиты = Ложь;
			СтрокаОрганизации.ОшибкиПроверкиЗаполнения = "";
			
			Если СтрокаОрганизации.ОшибкаВыгрузки Тогда
				Отказ = Истина;
				
				Если РезультатСозданияОрганизации.ОшибкиПроверкиЗаполнения <> Неопределено Тогда
					СтрокаОрганизации.ЕстьНезаполненныеРеквизиты = Истина;
					СтрокаОрганизации.ОшибкиПроверкиЗаполнения = СтрСоединить(РезультатСозданияОрганизации.ОшибкиПроверкиЗаполнения, ", ");
				КонецЕсли;
			Иначе
				СтрокаОрганизации.ПубличныйИдентификатор = РезультатСозданияОрганизации.Идентификатор;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для Каждого ОрганизацияСсылка Из ДополнительныеПараметры.ОрганизацииДляОтправки Цикл
			СтрокаОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("Ссылка", ОрганизацияСсылка))[0];
			СтрокаОрганизации.ОшибкаВыгрузки = Истина;
		КонецЦикла;
	КонецЕсли;
	
	ОбновитьОформлениеСпискаОрганизацийНаСервере();
	
	Если Отказ Тогда
		УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
		УстановитьДоступностьКомандНачалаРаботыИИзмененияОрганизаций();
		
		Если НачальнаяНастройкаВыполнена Тогда
			УстановитьРежимПомощника("НастройкиОтраженияОшибка");
		Иначе
			УстановитьРежимПомощника("НачалоРаботыИнформацияОшибка");
		КонецЕсли;
		
		Возврат;
	КонецЕсли;

	Если УзелОбмена.Пустая() Тогда
		УстановитьРежимПомощника("НачалоРаботыОжиданиеНастройки");
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		Если ВнешняяУчетнаяСистема Тогда
			ДлительнаяОперация = ДлительнаяОперацияПроверитьПодключениеККорреспонденту();
			
			ДлительныеОперацииКлиент.ОжидатьЗавершение(
				ДлительнаяОперация,
				Новый ОписаниеОповещения("ПроверитьПодключениеККорреспондентуЗавершение", ЭтотОбъект),
				ПараметрыОжидания);
		Иначе
			ДлительнаяОперация = ДлительнаяОперацияНастройкиПодключенияКПриложениюВСервисе(НомерОбласти, УникальныйИдентификатор);
			
			ДлительныеОперацииКлиент.ОжидатьЗавершение(
				ДлительнаяОперация,
				Новый ОписаниеОповещения("ПолучитьНастройкиПодключенияКПриложениюВСервисеЗавершение", ЭтотОбъект),
				ПараметрыОжидания);
		КонецЕсли;
	Иначе
		ПослеНастройкиОрганизаций();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеНастройкиОрганизаций()
	
	УстановитьРежимПомощника("НастройкиОтраженияПараметрыДокументов");
	УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
	
	Если Не НачальнаяНастройкаВыполнена Тогда
		НачальнаяНастройкаВыполнена = Истина;
	КонецЕсли;
	
	ПослеИзмененияНастроекОтраженияНаСервере();
	
	ОбновитьСостояниеУчетнойПолитикиОрганизаций();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьОформлениеСпискаОрганизацийНаСервере(Ключи = Неопределено, ДлительнаяОперация = Ложь)
	
	Если Ключи = Неопределено Тогда
	    Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
			УстановитьОформлениеЭлементовОрганизации(СтрокаОрганизации.КлючСтроки, ДлительнаяОперация);
		КонецЦикла;
	Иначе
		Для Каждого КлючСтроки Из Ключи Цикл
			УстановитьОформлениеЭлементовОрганизации(КлючСтроки, ДлительнаяОперация);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область НастройкиПодключенияКПриложениюВСервисе

&НаСервереБезКонтекста
Функция ДлительнаяОперацияНастройкиПодключенияКПриложениюВСервисе(НомерОбласти, ИдентификаторФормы)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.НастройкиПодключенияКПриложениюВСервисе",
		НомерОбласти);
	
КонецФункции

&НаКлиенте
Процедура ПолучитьНастройкиПодключенияКПриложениюВСервисеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Если Отказ Тогда
		УстановитьРежимПомощника("НачалоРаботыИнформацияОшибка");
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ДлительнаяОперацияПроверитьПодключениеККорреспондентуВСервисе(Результат.АдресРезультата, УникальныйИдентификатор);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ПроверитьПодключениеККорреспондентуЗавершение", ЭтотОбъект),
		ПараметрыОжидания);
	
КонецПроцедуры

#КонецОбласти

#Область ПроверкаПодключенияККорреспонденту

&НаСервере
Функция ДлительнаяОперацияПроверитьПодключениеККорреспонденту()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ПроверитьПодключениеККорреспонденту",
		ТекущиеПараметрыПодключения());
	
КонецФункции

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПроверитьПодключениеККорреспондентуВСервисе(АдресВХранилище, ИдентификаторФормы)
	
	НастройкиПодключенияВСервисе = ПолучитьИзВременногоХранилища(АдресВХранилище);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ПроверитьПодключениеККорреспондентуВСервисе",
		НастройкиПодключенияВСервисе);
	
КонецФункции

&НаКлиенте
Процедура ПроверитьПодключениеККорреспондентуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Если Отказ Тогда
		УстановитьРежимПомощника("НачалоРаботыИнформацияОшибка");
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ДлительнаяОперацияСохранитьНастройкиПодключения(Результат.АдресРезультата, УникальныйИдентификатор);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("СохранитьНастройкиПодключенияЗавершение", ЭтотОбъект),
		ПараметрыОжидания);
	
КонецПроцедуры

#КонецОбласти

#Область СохранениеНастроекПодключения

&НаСервереБезКонтекста
Функция ДлительнаяОперацияСохранитьНастройкиПодключения(АдресВХранилище, ИдентификаторФормы)
	
	СтруктураНастроек = ПолучитьИзВременногоХранилища(АдресВХранилище);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.СохранитьНастройкиПодключения",
		СтруктураНастроек);
	
КонецФункции

&НаКлиенте
Процедура СохранитьНастройкиПодключенияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	РезультатВыполнения = Неопределено;
	Если Не Отказ Тогда
		РезультатВыполнения = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РезультатВыполнения)
		Или Не РезультатВыполнения.НастройкиПодключенияСохранены Тогда
		УстановитьРежимПомощника("НачалоРаботыИнформацияОшибка");
		Возврат;
	КонецЕсли;
	
	УзелОбмена = РезультатВыполнения.УзелОбмена;
	
	УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
	
	СообщениеОбОшибке = "";
	Если Не ЗаписатьУзелОбменаВНастройкуОтраженияНаСервере(СообщениеОбОшибке) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибке);
		
		УстановитьРежимПомощника("НачалоРаботыИнформацияОшибка");
		Возврат;
	КонецЕсли;
	
	ПослеНастройкиОрганизаций();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция УстановитьИспользованиеРазделаБухгалтерии(Использование)
	УстановитьПривилегированныйРежим(Истина);
	Возврат РегистрыСведений.НастройкиИнтеграцииСБухгалтерией.УстановитьИспользование(Использование);
КонецФункции

&НаСервере
Функция ЗаписатьУзелОбменаВНастройкуОтраженияНаСервере(СообщениеОбОшибке = "")
	
	ЕстьОшибки = Ложь;
	НастройкаОбъект = Неопределено;
	
	НачатьТранзакцию();
	Попытка
		Если ТекущаяНастройка.Пустая() Тогда
			НастройкаОбъект = Справочники.НастройкиОтраженияДокументовВБухгалтерии.СоздатьЭлемент();
			НастройкаОбъект.Код = Строка(Новый УникальныйИдентификатор);
		Иначе
			НастройкаОбъект = ТекущаяНастройка.ПолучитьОбъект();
		КонецЕсли;
		
		НастройкаОбъект.УзелОбмена = УзелОбмена;
		НастройкаОбъект.Записать();
		
		УстановитьПараметрыПодключенияКБухгалтерииНаСервере(НастройкаОбъект.Ссылка);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		Информация = ИнформацияОбОшибке();
		
		ЗаписьЖурналаРегистрации(
			СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(Информация));
			
		ЕстьОшибки = Истина;
		СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(Информация);
	КонецПопытки;
	
	Если ТекущаяНастройка.Пустая()
		И Не ЕстьОшибки Тогда
		ТекущаяНастройка = НастройкаОбъект.Ссылка;
	КонецЕсли;
	
	Возврат Не ЕстьОшибки;
	
КонецФункции

&НаСервере
Процедура УстановитьПараметрыПодключенияКБухгалтерииНаСервере(НастройкаСсылка)
	
	УстановитьПривилегированныйРежим(Истина);
	РегистрыСведений.НастройкиИнтеграцииСБухгалтерией.УстановитьПараметрыПодключения(ТекущиеПараметрыПодключения(), НастройкаСсылка);
	
КонецПроцедуры

#КонецОбласти

#Область ПолучениеНастроекСовместногоИспользования

&НаКлиенте
Процедура ПолучитьНастройкиСовместногоИспользования()    
	
	ДлительнаяОперация = ДлительнаяОперацияПолучитьНастройкиСовместногоИспользования();
		
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ПолучитьНастройкиСовместногоИспользованияЗавершение", ЭтотОбъект),
		ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияПолучитьНастройкиСовместногоИспользования()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ПолучитьНастройкиСовместногоИспользования",
		ТекущаяНастройка,
		ТекущиеПараметрыПодключения());
	
КонецФункции

&НаКлиенте
Процедура ПолучитьНастройкиСовместногоИспользованияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Настройки = Неопределено;
	Если Не Отказ Тогда
		Настройки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	КонецЕсли;
	
	Если Настройки = Неопределено Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОшибка");
		Возврат;
	КонецЕсли;
	
	Элементы.ГруппаНастройкиОтраженияПервыйЭтап.Доступность = Истина;
	
	ЕстьАктивноеСообщение = Настройки.Получить("УзелОбмена").Получить("ПолученоСообщениеДляСопоставления");
	
	Если ЕстьАктивноеСообщение = Истина Тогда
		УстановитьРежимПомощника("НастройкиОтраженияТребуетсяСопоставление");
		УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Ложь);
		
		УстановитьИспользованиеСценарияСинхронизации(УзелОбмена, Ложь, ВнешняяУчетнаяСистема);
	Иначе
		Если ЗакрытьПомощникПослеЗавершенияСопоставления Тогда
			ЗакрытьФормуИПерейтиВРазделБухгалтерия();
		Иначе
			УстановитьРежимПомощника("НастройкиОтраженияПараметрыДокументов");
		
			УстановитьИспользованиеСценарияСинхронизации(УзелОбмена, ОтражениеВключено, ВнешняяУчетнаяСистема);
			
			ОбновитьСостояниеУчетнойПолитикиОрганизаций();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область УчетнаяПолитикаОрганизаций

&НаКлиенте
Процедура ОбновитьСостояниеУчетнойПолитикиОрганизаций()
	
	КлючиОрганизаций = Новый Массив;
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации.НайтиСтроки(Новый Структура("Пометка,БылЗапросПолитики", Истина, Ложь)) Цикл
		Если ЗначениеЗаполнено(СтрокаОрганизации.ПубличныйИдентификатор) Тогда
			КлючиОрганизаций.Добавить(СтрокаОрганизации.КлючСтроки);
		КонецЕсли;
	КонецЦикла;
	
	Если КлючиОрганизаций.Количество() > 0 Тогда
		ОбновитьОформлениеСпискаОрганизацийНаСервере(КлючиОрганизаций, Истина);
		
	    ПолучитьСостояниеУчетнойПолитикиОрганизаций(КлючиОрганизаций);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьСостояниеУчетнойПолитикиОрганизаций(КлючиОрганизаций)
	
	ДлительнаяОперация = ДлительнаяОперацияУчетнаяПолитикаОрганизации(КлючиОрганизаций);
		
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("КлючиОрганизаций", КлючиОрганизаций);
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("ПолучитьУчетнуюПолитикуОрганизацииЗавершение", ЭтотОбъект, ДополнительныеПараметры),
		ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьУчетнуюПолитикуОрганизацииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	КлючиОрганизаций = ДополнительныеПараметры.КлючиОрганизаций;
	
	Если Не Отказ Тогда
		СостояниеУчетнойПолитики = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Для Каждого КлючОрганизации Из КлючиОрганизаций Цикл
			СтрокаОрганизаци = ДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", КлючОрганизации))[0];
			СтрокаОрганизаци.БылЗапросПолитики = Истина;
			
			СостояниеНастройки = СостояниеУчетнойПолитики.Получить(СтрокаОрганизаци.ПубличныйИдентификатор);
			Если СостояниеНастройки <> Неопределено Тогда
				СтрокаОрганизаци.УчетнаяПолитикаСуществует = СостояниеНастройки.Получить("УчетнаяПолитика").Получить("Существует");
				СтрокаОрганизаци.СистемаНалогообложенияСуществует = СостояниеНастройки.Получить("СистемаНалогообложения").Получить("Существует");
			Иначе
				СтрокаОрганизаци.ОшибкаВыгрузки = Истина;
				СтрокаОрганизаци.УчетнаяПолитикаСуществует = Ложь;
				СтрокаОрганизаци.СистемаНалогообложенияСуществует = Ложь;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для Каждого КлючОрганизации Из КлючиОрганизаций Цикл
			СтрокаОрганизаци = ДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", КлючОрганизации))[0];   
			СтрокаОрганизаци.ОшибкаВыгрузки = Истина;
		КонецЦикла;
	КонецЕсли;
	
	ОбновитьОформлениеСпискаОрганизацийНаСервере(КлючиОрганизаций);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияУчетнаяПолитикаОрганизации(КлючиОрганизаций)
	
	ПубличныеИдентификаторы = Новый Массив;
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
		Если КлючиОрганизаций.Найти(СтрокаОрганизации.КлючСтроки) <> Неопределено Тогда
			ПубличныеИдентификаторы.Добавить(СтрокаОрганизации.ПубличныйИдентификатор);   
		КонецЕсли;
	КонецЦикла;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.СостояниеУчетнойПолитикиОрганизации",
		ПубличныеИдентификаторы,
		ДатаНачалаОтражения,
		ТекущиеПараметрыПодключения());
	
КонецФункции

#КонецОбласти

#Область СохранениеНастроекСовместногоИспользования

&НаКлиенте
Процедура СохранитьНастройкиИВыполнитьСинхронизацию()
	
	СообщениеОбОшибке = "";
	Если Не СохранитьНастройкиОрганизацийИРазделовНаСервере(СообщениеОбОшибке) Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОшибка");
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибке);
		Возврат;
	КонецЕсли;
	
	УстановитьНастройкиОтраженияВБухгалтерии(Истина, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройкиИВыйти()
	
	СообщениеОбОшибке = "";
	Если Не СохранитьНастройкиОрганизацийИРазделовНаСервере(СообщениеОбОшибке) Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОшибка");
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибке);
		Возврат;
	КонецЕсли;
	
	УстановитьНастройкиОтраженияВБухгалтерии(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОтражениеДокументов()
	
	УстановитьНастройкиОтраженияВБухгалтерии(Ложь);
	
КонецПроцедуры

&НаСервере
Функция СохранитьНастройкиОрганизацийИРазделовНаСервере(СообщениеОбОшибке = "")
	
	ЕстьОшибки = Ложь;
	
	НачатьТранзакцию();
	Попытка
		НастройкаОбъект = ТекущаяНастройка.ПолучитьОбъект();
		УзелОбъект = УзелОбмена.ПолучитьОбъект();
		
		НастройкаОбъект.ДатаНачалаОтражения = ДатаНачалаОтражения;
		УзелОбъект.ДатаНачалаВыгрузкиДокументов = ДатаНачалаОтражения;
		
		НастройкаОбъект.Организации.Очистить();
		УзелОбъект.Организации.Очистить();
		Для Каждого СтрокаОрганизация Из ДоступныеОрганизации Цикл
			Если Не СтрокаОрганизация.Пометка Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = НастройкаОбъект.Организации.Добавить();
			НоваяСтрока.Организация = СтрокаОрганизация.Ссылка;
			
			НоваяСтрока = УзелОбъект.Организации.Добавить();
			НоваяСтрока.Организация = СтрокаОрганизация.Ссылка;
		КонецЦикла;
		УзелОбъект.ИспользоватьОтборПоОрганизациям = УзелОбъект.Организации.Количество() > 0;
		
		НастройкаОбъект.РазделыУчета.Очистить();
		НастройкаОбъект.ВидыДокументов.Очистить();
		
		УзелОбъект.ВидыДокументов.Очистить();
		ДоступныеВидыДокументов = СовместноеИспользование.СоответствиеВидовДокументовИРазделовУчета();
		
		Для Каждого СтрокаРаздел Из РазделыУчета.НайтиСтроки(Новый Структура("Пометка", Истина)) Цикл
			НоваяСтрокаРаздел = НастройкаОбъект.РазделыУчета.Добавить();
			НоваяСтрокаРаздел.Идентификатор = СтрокаРаздел.Идентификатор;
			
			Если Не СтрокаРаздел.ПоВсемДокументам Тогда
				СтрокиВидыДокументов = ВыбранныеВидыДокументов.НайтиСтроки(Новый Структура("РазделУчета", СтрокаРаздел.Идентификатор));
				Для Каждого СтрокаВидыДокументов Из СтрокиВидыДокументов Цикл
					// Настройка отражения.
					НоваяСтрока = НастройкаОбъект.ВидыДокументов.Добавить();
					НоваяСтрока.РазделУчета = СтрокаРаздел.Идентификатор;
					НоваяСтрока.ИдентификаторМетаданных = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(СтрокаВидыДокументов.ПолноеИмяМетаданных);
					
					// Узел обмена.
					НоваяСтрока = УзелОбъект.ВидыДокументов.Добавить();
					НоваяСтрока.ИмяОбъектаМетаданных = СтрокаВидыДокументов.ИмяОбъекта;
					НоваяСтрока.Представление = СтрокаВидыДокументов.Представление;
				КонецЦикла;
			Иначе
				Для Каждого СтрокаВидыДокументов Из ДоступныеВидыДокументов.НайтиСтроки(Новый Структура("РазделУчета", СтрокаРаздел.Идентификатор)) Цикл
					// Узел обмена.
					НоваяСтрока = УзелОбъект.ВидыДокументов.Добавить();
					НоваяСтрока.ИмяОбъектаМетаданных = СтрокаВидыДокументов.ИмяОбъектаМетаданных;
					НоваяСтрока.Представление = СтрокаВидыДокументов.Представление;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		УзелОбъект.ИспользоватьОтборПоВидамДокументов = УзелОбъект.ВидыДокументов.Количество() > 0;
		
		Если Не ОбменДаннымиСервер.НастройкаСинхронизацииЗавершена(УзелОбмена) Тогда
			УзелОбъект.ОбменДанными.Загрузка = Истина;
		КонецЕсли;
		
		НастройкаОбъект.Записать();
		УзелОбъект.Записать();
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		Информация = ИнформацияОбОшибке();
		
		ЗаписьЖурналаРегистрации(
			СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(Информация));
			
		ЕстьОшибки = Истина;
		СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(Информация);
	КонецПопытки;
	
	Возврат Не ЕстьОшибки;
	
КонецФункции

&НаКлиенте
Процедура УстановитьНастройкиОтраженияВБухгалтерии(ЗначениеОтражениеВключено, ВыполнитьСинхронизацию = Ложь)
	
	ДлительнаяОперация = ДлительнаяОперацияУстановитьНастройкиОтраженияВБухгалтерии(ЗначениеОтражениеВключено);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ОтражениеВключено", ЗначениеОтражениеВключено);
	ДополнительныеПараметры.Вставить("ВыполнитьСинхронизацию", ВыполнитьСинхронизацию);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(
		ДлительнаяОперация,
		Новый ОписаниеОповещения("УстановитьНастройкиОтраженияВБухгалтерииЗавершение", ЭтотОбъект, ДополнительныеПараметры),
		ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияУстановитьНастройкиОтраженияВБухгалтерии(ЗначениеОтражениеВключено)
	
	СвойстваУзлаОбмена = Новый Структура;
	
	Если ЗначениеОтражениеВключено Тогда
		СвойстваУзлаОбмена.Вставить("НастройкаСинхронизацииЗавершена", Истина);
		СвойстваУзлаОбмена.Вставить("ПравилаОтправкиСправочников", "СинхронизироватьПоНеобходимости");
		СвойстваУзлаОбмена.Вставить("ПравилаОтправкиДокументов", "АвтоматическаяСинхронизация");
		СвойстваУзлаОбмена.Вставить("ПравилаОтправкиЦен", "НеСинхронизировать");
	Иначе
		СвойстваУзлаОбмена.Вставить("ПравилаОтправкиСправочников", "НеСинхронизировать");
		СвойстваУзлаОбмена.Вставить("ПравилаОтправкиДокументов", "НеСинхронизировать");
	КонецЕсли;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.УстановитьНастройкиОтраженияВБухгалтерии",
		ТекущаяНастройка,
		ЗначениеОтражениеВключено,
		СвойстваУзлаОбмена,
		ТекущиеПараметрыПодключения());
	
КонецФункции

&НаКлиенте
Процедура УстановитьНастройкиОтраженияВБухгалтерииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	НастройкиУстановлены = Неопределено;
	Если Не Отказ Тогда
		НастройкиУстановлены = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	КонецЕсли;
	
	Если НастройкиУстановлены = Истина Тогда
		СообщениеОбОшибке = "";
		Если Не ПослеСохраненияНастроекОтраженияВБухгалтерииНаСервере(ДополнительныеПараметры.ОтражениеВключено, СообщениеОбОшибке) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибке);
			УстановитьРежимПомощника("НастройкиОтраженияОшибка");
		Иначе
			ОтражениеВключено = ДополнительныеПараметры.ОтражениеВключено;
			
			Если ВнешняяУчетнаяСистема Тогда
				Если УстановитьИспользованиеРазделаБухгалтерии(ОтражениеВключено) Тогда
					ОбновитьИнтерфейс();
				КонецЕсли;
			КонецЕсли;
			
			Если ОтражениеВключено Тогда
				Если ДополнительныеПараметры.ВыполнитьСинхронизацию Тогда
					УстановитьРежимПомощника("НастройкиОтраженияОтправкаДокументов");
					
					ПодключитьОбработчикОжидания("НачатьСинхронизацию", 0.1, Истина);
				Иначе
					ЗакрытьФормуИПерейтиВРазделБухгалтерия();
				КонецЕсли;
			Иначе
				Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
					СтрокаОрганизации.Пометка = Ложь;
				КонецЦикла;
				
				ОбновитьОформлениеСпискаОрганизацийНаСервере();
				
				НачальнаяНастройкаВыполнена = Ложь;
				
				УстановитьРежимПомощника("НачалоРаботыИнформацияПустая");
				Элементы.ГруппаНастройкиОтраженияПервыйЭтап.Доступность = Истина;
				УстановитьДоступностьКомандНачалаРаботыИИзмененияОрганизаций();
				
				Элементы.ГруппаИнформация.Видимость = Истина;
				Элементы.ОтражениеВключено.Видимость = Ложь;
				
				Оповестить("ОтражениеОтключено");
			КонецЕсли;
		КонецЕсли;
	Иначе
		УстановитьРежимПомощника("НастройкиОтраженияОшибка");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПослеСохраненияНастроекОтраженияВБухгалтерииНаСервере(ЗначениеОтражениеВключено, СообщениеОбОшибке = "")
	
	ЕстьОшибки = Ложь;
	
	НачатьТранзакцию();
	Попытка
		Если ЗначениеОтражениеВключено Тогда
			Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
				Если Не ЗначениеЗаполнено(СтрокаОрганизации.ПубличныйИдентификатор) Тогда
					Продолжить;
				КонецЕсли;
				
				Обработки.ОтражениеДокументовВБухгалтерии.ЗафиксироватьВыгрузкуОрганизации(
					СтрокаОрганизации.Ссылка,
					СтрокаОрганизации.ПубличныйИдентификатор,
					УзелОбмена);
			КонецЦикла;
			
			УзелОбъект = УзелОбмена.ПолучитьОбъект();
			УзелОбъект.ПравилаОтправкиСправочников = "СинхронизироватьПоНеобходимости";
			УзелОбъект.ПравилаОтправкиДокументов = "АвтоматическаяСинхронизация";
			УзелОбъект.Записать();
			
			Если Не ОбменДаннымиСервер.НастройкаСинхронизацииЗавершена(УзелОбмена) Тогда
				ОбменДаннымиСервер.ЗавершитьНастройкуСинхронизацииДанных(УзелОбмена);
			КонецЕсли;
		
			ВыполнитьРегистрациюИзмененийДляНачальнойВыгрузки();
		Иначе
			УзелОбъект = УзелОбмена.ПолучитьОбъект();
			УзелОбъект.ПравилаОтправкиСправочников = "НеСинхронизировать";
			УзелОбъект.ПравилаОтправкиДокументов = "НеСинхронизировать";
			УзелОбъект.Записать();
		КонецЕсли;
		
		ИспользованиеСценария = ЗначениеОтражениеВключено;
		Если ИспользованиеСценария И Не БухгалтерияПуста И Не ОтражениеВключено Тогда
			// Сценарий не включается, если выполняется настройка с непустой бухгалтерией,
			// и это первичная настройка отражения (т.к. требуется выполнить сопоставление).
			ИспользованиеСценария = Ложь;
		КонецЕсли;
		
		Если Не УстановитьИспользованиеСценарияСинхронизации(УзелОбмена, ИспользованиеСценария, ВнешняяУчетнаяСистема) Тогда
			ВызватьИсключение НСтр("ru = 'Не удалось обновить сценарий.'");
		КонецЕсли;
		
		НастройкаОбъект = ТекущаяНастройка.ПолучитьОбъект();
		НастройкаОбъект.ОтражениеВключено = ЗначениеОтражениеВключено;
		Если ЗначениеОтражениеВключено
			И Не ВнешняяУчетнаяСистема Тогда
			НастройкаОбъект.ПользовательДляИнтеграции = Пользователи.ТекущийПользователь();
		КонецЕсли;
		НастройкаОбъект.Записать();
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		Информация = ИнформацияОбОшибке();
		
		ЗаписьЖурналаРегистрации(
			СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(Информация));
			
		ЕстьОшибки = Истина;
		СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(Информация);
	КонецПопытки;
	
	Возврат Не ЕстьОшибки;
	
КонецФункции

&НаСервереБезКонтекста
Функция УстановитьИспользованиеСценарияСинхронизации(УзелОбмена, ИспользованиеСценария, ВнешняяУчетнаяСистема)
	
	Если ВнешняяУчетнаяСистема Тогда
		Возврат Истина;
	КонецЕсли;
	
	Отказ = Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	СценарийОбменаДанными = Неопределено;
	Расписание = Неопределено;
	
	ИдентификаторТранспорта = "SM";
	
	ОписаниеСценария = Обработки.ОтражениеДокументовВБухгалтерии.ОсновнойСценарийСинхронизации(УзелОбмена);
	
	Если ОписаниеСценария = Неопределено Тогда
		СценарийОбменаДанными = Справочники.СценарииОбменовДанными.СоздатьЭлемент();
		СценарийОбменаДанными.УстановитьНовыйКод();
		СценарийОбменаДанными.Наименование = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Автоматическая синхронизация данных с %1 (совместное использование)'"), Строка(УзелОбмена));
			
		СтрокаНастройкиОбмена = СценарийОбменаДанными.НастройкиОбмена.Добавить();
		СтрокаНастройкиОбмена.УзелИнформационнойБазы = УзелОбмена;
		СтрокаНастройкиОбмена.ВыполняемоеДействие = Перечисления.ДействияПриОбмене.ВыгрузкаДанных;
		СтрокаНастройкиОбмена.ИдентификаторТранспорта = ИдентификаторТранспорта;
		
		СтрокаНастройкиОбмена = СценарийОбменаДанными.НастройкиОбмена.Добавить();
		СтрокаНастройкиОбмена.УзелИнформационнойБазы = УзелОбмена;
		СтрокаНастройкиОбмена.ВыполняемоеДействие = Перечисления.ДействияПриОбмене.ЗагрузкаДанных;
		СтрокаНастройкиОбмена.ИдентификаторТранспорта = ИдентификаторТранспорта;
		
		Расписание = Справочники.СценарииОбменовДанными.РасписаниеРегламентногоЗаданияПоУмолчанию();
	ИначеЕсли ОписаниеСценария.ИспользоватьРегламентноеЗадание <> ИспользованиеСценария Тогда
		Если Не ОписаниеСценария.ОтключенАвтоматически Или Не ИспользованиеСценария Тогда
			СценарийОбменаДанными = ОписаниеСценария.Ссылка.ПолучитьОбъект();
		КонецЕсли;
	КонецЕсли;
	
	Если СценарийОбменаДанными <> Неопределено Тогда
		СценарийОбменаДанными.ИспользоватьРегламентноеЗадание = ИспользованиеСценария;
		
		Справочники.СценарииОбменовДанными.ОбновитьДанныеРегламентногоЗадания(Отказ, Расписание, СценарийОбменаДанными);
		
		Если Не Отказ Тогда
			СценарийОбменаДанными.Записать();
		КонецЕсли;
	КонецЕсли;
	
	Возврат Не Отказ;
	
КонецФункции

#КонецОбласти

#Область ПользовательскийИнтерфейсПомощника

&НаКлиенте
Процедура УстановитьРежимПомощника(Режим)
	
	Если Режим = "НачалоРаботыОжиданиеНастройки" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаОжиданиеНастройки;
	ИначеЕсли Режим = "НачалоРаботыФоновыйОбмен" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаОжиданиеФоновогоОбмена;
	ИначеЕсли Режим = "НачалоРаботыОжиданиеБухгалтерии" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаСостояниеНастройки;
	ИначеЕсли Режим = "НачалоРаботыОжиданиеОрганизации" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаОтправкаОрганизаций;
	ИначеЕсли Режим = "НачалоРаботыИнформацияПустая" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаНачалоРаботы;
		Элементы.СтраницыНачалоРаботыИнформация.ТекущаяСтраница = Элементы.СтраницаНачалоРаботыИнформацияПустая;
	ИначеЕсли Режим = "НачалоРаботыИнформацияОшибка" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаНачалоРаботы;
		Элементы.СтраницыНачалоРаботыИнформация.ТекущаяСтраница = Элементы.СтраницаНачалоРаботыИнформацияОшибка;
	ИначеЕсли Режим = "НачалоРаботыИнформацияТребуетсяПолныйИнтерфейс" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаНачалоРаботы;
		Элементы.СтраницыНачалоРаботыИнформация.ТекущаяСтраница = Элементы.СтраницаНачалоРаботыИнформацияТребуетсяПолныйИнтерфейс;
	ИначеЕсли Режим = "НачалоРаботыИнформацияРекомендуетсяПолныйИнтерфейс" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаНачалоРаботы;
		Элементы.СтраницыНачалоРаботыИнформация.ТекущаяСтраница = Элементы.СтраницаНачалоРаботыИнформацияРекомендуетсяПолныйИнтерфейс;
	ИначеЕсли Режим = "НастройкиОтраженияПараметрыДокументов" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаПараметрыДокументов;
	ИначеЕсли Режим = "НастройкиОтраженияОжиданиеСостояниеНастройки" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаСостояниеНастройки;
	ИначеЕсли Режим = "НастройкиОтраженияОшибка" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаНеудача;
	ИначеЕсли Режим = "НастройкиОтраженияОжиданиеОрганизаций" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаОтправкаОрганизаций;
	ИначеЕсли Режим = "НастройкиОтраженияОтправкаДокументов" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаОтправкаДокументов;
	ИначеЕсли Режим = "НастройкиОтраженияФоновыйОбмен" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаОжиданиеФоновогоОбмена;
	ИначеЕсли Режим = "НастройкиОтраженияОбновлениеНастроек" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаОжидание;
		Элементы.ПодстраницыОжидания.ТекущаяСтраница = Элементы.СтраницаОбновлениеНастроек;
	ИначеЕсли Режим = "НастройкиОтраженияТребуетсяСопоставление" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаТребуетсяСопоставление;
	ИначеЕсли Режим = "НастройкиОтраженияУспехБухгалтерияПуста" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаУспехБухгалтерияПуста;
	ИначеЕсли Режим = "НастройкиОтраженияУспехБухгалтерияНеПуста" Тогда
		Элементы.ГруппаНастройкиОтраженияВторойЭтап.ТекущаяСтраница = Элементы.СтраницаУспехБухгалтерияНеПуста;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Доступность)
	
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
		КлючСтроки = СтрокаОрганизации.КлючСтроки;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Организация_" + КлючСтроки, "Доступность", Доступность);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КомандаОрганизации_" + КлючСтроки, "Доступность", Доступность);
	КонецЦикла;
	
	Элементы.ГруппаКалендарьДатаНачалаОтражения.Доступность = Доступность;
	
КонецПроцедуры

#КонецОбласти

#Область ВосстановлениеСохраненныхНастроек

&НаСервере
Функция ВосстановитьТекущиеНастройкиОтражения()
	
	Если Не ТекущаяНастройка.Пустая() Тогда
		ОписаниеНастройки = Справочники.НастройкиОтраженияДокументовВБухгалтерии.ОписаниеНастройки(ТекущаяНастройка);
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ОписаниеНастройки, "УзелОбмена,ОтражениеВключено");
		
		Если ОтражениеВключено Тогда
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, ОписаниеНастройки, "ДатаНачалаОтражения");
			
			ВосстановитьНастройкиОрганизаций(ОписаниеНастройки);
			ВосстановитьНастройкиРазделовУчета(ОписаниеНастройки);
			ВосстановитьНастройкиВидовДокументов(ОписаниеНастройки);
		КонецЕсли;
		
		ВосстановитьСохраненныеПубличныеИдентификаторы();
	КонецЕсли;
	
	Возврат Не ТекущаяНастройка.Пустая();
	
КонецФункции

&НаСервере
Процедура ВосстановитьНастройкиОрганизаций(ОписаниеНастройки)
	
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
		СтрокаОрганизации.Пометка = (ОписаниеНастройки.Организации.Найти(СтрокаОрганизации.Ссылка) <> Неопределено);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиРазделовУчета(ОписаниеНастройки)
	
	Для Каждого СтрокаРазделы Из РазделыУчета Цикл
		СтрокаРазделы.Пометка = (ОписаниеНастройки.РазделыУчета.Найти(СтрокаРазделы.Идентификатор) <> Неопределено);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиВидовДокументов(ОписаниеНастройки)
	
	ВыбранныеВидыДокументов.Очистить();
	
	ДоступныеВидыДокументов = СовместноеИспользование.СоответствиеВидовДокументовИРазделовУчета();
	
	Для Каждого СтрокаВидыДокументов Из ОписаниеНастройки.ВидыДокументов Цикл
		Отбор = Новый Структура;
		Отбор.Вставить("РазделУчета", СтрокаВидыДокументов.РазделУчета);
		Отбор.Вставить("ПолноеИмяМетаданных", ОбщегоНазначения.ОбъектМетаданныхПоИдентификатору(СтрокаВидыДокументов.ИдентификаторМетаданных).ПолноеИмя());
		
		СтрокиДоступныеВиды = ДоступныеВидыДокументов.НайтиСтроки(Отбор);
		Если СтрокиДоступныеВиды.Количество() > 0 Тогда
			НоваяСтрока = ВыбранныеВидыДокументов.Добавить();
			НоваяСтрока.РазделУчета = СтрокиДоступныеВиды[0].РазделУчета;
			НоваяСтрока.ИмяОбъекта = СтрокиДоступныеВиды[0].ИмяОбъектаМетаданных;
			НоваяСтрока.Представление = СтрокиДоступныеВиды[0].Представление;
			НоваяСтрока.ПолноеИмяМетаданных = СтрокиДоступныеВиды[0].ПолноеИмяМетаданных;
		КонецЕсли;
		
		СтрокиРазделы = РазделыУчета.НайтиСтроки(Новый Структура("Идентификатор", СтрокаВидыДокументов.РазделУчета));
		Если СтрокиРазделы.Количество() > 0 Тогда
			СтрокиРазделы[0].ПоВсемДокументам = Ложь;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьСохраненныеПубличныеИдентификаторы()
	
	СписокОрганизаций = ДоступныеОрганизации.Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	ИдентификаторыОрганизаций = ПубличныеИдентификаторыОрганизаций(УзелОбмена, СписокОрганизаций);
	
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
		СтрокаОрганизации.ПубличныйИдентификатор = ИдентификаторыОрганизаций.Получить(СтрокаОрганизации.Ссылка);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПубличныеИдентификаторыОрганизаций(УзелОбмена, СписокСсылок)
	
	Результат = Новый Соответствие;
	
	Если Не УзелОбмена.Пустая() Тогда
		ТаблицаИдентификаторы = СовместноеИспользование.ПубличныеИдентификаторыСинхронизируемыхОбъектов(УзелОбмена, СписокСсылок);
		
		Для Каждого СтрокаИдентификаторы Из ТаблицаИдентификаторы Цикл
			Результат.Вставить(СтрокаИдентификаторы.Ссылка, СтрокаИдентификаторы.Идентификатор);
		КонецЦикла;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

#КонецОбласти

&НаСервере
Функция ТекущиеПараметрыПодключения()
	
	СтрокаПриложение = Неопределено;
	Если ВнешняяУчетнаяСистема Тогда
		СтрокаПриложение = ПриложенияБухгалтерии.НайтиСтроки(Новый Структура("ВнешняяУчетнаяСистема", Истина))[0];
	Иначе
		СтрокаПриложение = ПриложенияБухгалтерии.НайтиСтроки(Новый Структура("НомерОбласти", НомерОбласти))[0];
	КонецЕсли;
	
	ПараметрыПодключения = РегистрыСведений.НастройкиИнтеграцииСБухгалтерией.НовыеПараметрыПодключения();
	ЗаполнитьЗначенияСвойств(ПараметрыПодключения, СтрокаПриложение);
	
	Возврат ПараметрыПодключения;
	
КонецФункции

&НаКлиенте
Процедура ЗакрытьФормуИПерейтиВРазделБухгалтерия()
	
	ОткрытьФорму("Обработка.ОтражениеДокументовВБухгалтерии.Форма.РазделБухгалтерия");	
	
	Закрыть();
	
КонецПроцедуры

&НаСервере
Процедура ПослеИзмененияНастроекОтраженияНаСервере()
	
	АктуализироватьКэши();
	ПроизвестиПолныйПересчетДокументовПоРазделам();
	УстановитьСвойстваКомандыОтразитьДокументы();
	
	Если НачальнаяНастройкаВыполнена Тогда
		БылиИзменения = СравнитьКэшОрганизацийИРеквизиты(Истина);
		
		Элементы.КомандаОрганизацииИзменены.Видимость = БылиИзменения;
		Элементы.ГруппаКомандыВторогоЭтапаНастройки.Доступность = Не БылиИзменения;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииДатыНачалаОтраженияНаСервере()
	
	Если ЗначениеЗаполнено(ДатаНачалаОтражения) Тогда
		Элементы.ГруппаКалендарьДатаНачалаОтражения.ЦветТекстаЗаголовка = ЦветаСтиля.ЦветГиперссылки;
		Элементы.ГруппаКалендарьДатаНачалаОтражения.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'С %1'"),
			Формат(ДатаНачалаОтражения, "ДЛФ=DD"));
		Элементы.ДекорацияКартинкаДатаНачалаОтражения.Картинка = БиблиотекаКартинок.РазделУчетаБезПредупреждений;
		
		Элементы.ГруппаРазделыУчета.Доступность = Истина;
		Элементы.ГруппаКомандыВторогоЭтапаНастройки.Доступность = Истина;    
		
		ПослеИзмененияНастроекОтраженияНаСервере();
	Иначе
		Элементы.ГруппаКалендарьДатаНачалаОтражения.ЦветТекстаЗаголовка = ЦветаСтиля.РезультатПредупреждениеЦвет;
		Элементы.ГруппаКалендарьДатаНачалаОтражения.Заголовок = НСтр("ru = 'Не указана'");
		
		Элементы.ДекорацияКартинкаДатаНачалаОтражения.Картинка = БиблиотекаКартинок.РазделУчетаСПредупреждениями;
		
		Элементы.ГруппаРазделыУчета.Доступность = Ложь;
		Элементы.ГруппаКомандыВторогоЭтапаНастройки.Доступность = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПроизвестиПолныйПересчетДокументовПоРазделам()

	Для Каждого СтрокаРазделы Из РазделыУчета Цикл
		Если Не СтрокаРазделы.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		ВыборВидовДокументов = ПодготовитьВыборВидовДокументовПоРазделу(СтрокаРазделы.Идентификатор);
		СписокВыбора = ВыборВидовДокументов.СписокВыбора;
		Если СтрокаРазделы.ПоВсемДокументам Тогда
			Для Каждого Элемент Из СписокВыбора Цикл
				Элемент.Пометка = Истина;
			КонецЦикла;
		КонецЕсли;
		
		КоличествоКВыгрузке = ПодсчитатьКоличествоДокументовПоРазделу(СписокВыбора, СтрокаРазделы.Идентификатор);     
		УстановитьСвойстваСтрокиРаздела(СтрокаРазделы.Идентификатор, КоличествоКВыгрузке);     
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьНастройкиИнтеграции()
	
	ПараметрыПодключения = РегистрыСведений.НастройкиИнтеграцииСБухгалтерией.ПолучитьПараметрыПодключения(ТекущаяНастройка);
	Если Не ПустаяСтрока(ПараметрыПодключения.АдресПриложения) Тогда
		СтрокаПриложения = ПриложенияБухгалтерии.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПриложения, ПараметрыПодключения);
		
		ПараметрыПодключения.Свойство("ВнешняяУчетнаяСистема", ВнешняяУчетнаяСистема);
		ПараметрыПодключения.Свойство("НомерОбласти", НомерОбласти);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСписокОрганизаций()
	
	ДоступныеОрганизации.Очистить();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Организации.Ссылка КАК Ссылка,
	|	Организации.Наименование КАК Наименование
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	НЕ Организации.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организации.Наименование");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ДоступныеОрганизации.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		
		НоваяСтрока.КлючСтроки = СтрЗаменить(XMLСтрока(Выборка.Ссылка), "-", "");
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьЭлементыУправленияОрганизаций()
	
	Для Инд = 0 По ДоступныеОрганизации.Количество() - 1 Цикл
		ДобавитьЭлементыУправленияОрганизации(Инд);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнениеОбязательныхРеквизитовОрганизации(КлючСтроки)
	
	СтрокаОрганизации = ДоступныеОрганизации.НайтиСтроки(Новый Структура("КлючСтроки", КлючСтроки))[0];
	
	ОшибкиПроверкиЗаполнения = Новый Массив;
	Обработки.ОтражениеДокументовВБухгалтерии.ПолучитьОписаниеОрганизации(СтрокаОрганизации.Ссылка, ОшибкиПроверкиЗаполнения);
	
	Если ОшибкиПроверкиЗаполнения.Количество() > 0 Тогда
		СтрокаОрганизации.ЕстьНезаполненныеРеквизиты = Истина;
		СтрокаОрганизации.ОшибкиПроверкиЗаполнения = СтрСоединить(ОшибкиПроверкиЗаполнения, ", ");
	Иначе
		СтрокаОрганизации.ЕстьНезаполненныеРеквизиты = Ложь;
		СтрокаОрганизации.ОшибкиПроверкиЗаполнения = "";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбщийОбработчикКомандыОрганизацииЗакрытие(Результат, ДополнительныеПараметры) Экспорт
	
	ПослеЗакрытияКарточкиОрганизацииНаСервере(ДополнительныеПараметры.КлючОрганизации);
	
	УстановитьДоступностьКомандНачалаРаботыИИзмененияОрганизаций();
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗакрытияКарточкиОрганизацииНаСервере(КлючОрганизации)
	
	ПроверитьЗаполнениеОбязательныхРеквизитовОрганизации(КлючОрганизации);
	УстановитьОформлениеЭлементовОрганизации(КлючОрганизации);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементыУправленияОрганизации(Индекс)
	
	СтрокаОрганизации = ДоступныеОрганизации[Индекс];
	
	КлючСтроки = СтрокаОрганизации.КлючСтроки;
	Представление = СтрокаОрганизации.Наименование;
	
	ГруппаРодитель = Элементы.Добавить(
		"ГруппаОрганизация_" + КлючСтроки,
		Тип("ГруппаФормы"),
		Элементы.ГруппаОрганизации);
	ГруппаРодитель.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаРодитель.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаРодитель.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаРодитель.ОтображатьЗаголовок = Ложь;
	ГруппаРодитель.ЦветФона = ЦветаСтиля.ЦветФонаШапкиТаблицы;
	ГруппаРодитель.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
	ГруппаРодитель.РастягиватьПоГоризонтали = Истина;
	
	ГруппаРодитель.РасширеннаяПодсказка.АвтоМаксимальнаяШирина = Ложь;
	ГруппаРодитель.РасширеннаяПодсказка.РастягиватьПоГоризонтали = Истина;
	ГруппаРодитель.РасширеннаяПодсказка.ЦветТекста = ЦветаСтиля.НезаполненныйРеквизит;
	ГруппаРодитель.РасширеннаяПодсказка.Шрифт = Новый Шрифт(ШрифтыСтиля.ОбычныйШрифтТекста, , 9);
	
	ЭлементФлажок = Элементы.Добавить(
		"Организация_" + КлючСтроки,
		Тип("ПолеФормы"),
		ГруппаРодитель);
	ЭлементФлажок.Вид = ВидПоляФормы.ПолеФлажка;
	ЭлементФлажок.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ЭлементФлажок.ПутьКДанным = СтрШаблон("ДоступныеОрганизации[%1].Пометка", Формат(Индекс, "ЧГ=0"));
	ЭлементФлажок.УстановитьДействие("ПриИзменении", "ФлажокОрганизацииПриИзменении");
	
	НоваяКоманда = Команды.Добавить("КомандаОрганизации_" + КлючСтроки);
	НоваяКоманда.Заголовок = Представление;
	НоваяКоманда.Действие = "ОбщийОбработчикКомандыОрганизации";
	
	ЭлементКнопка = Элементы.Добавить(
		НоваяКоманда.Имя,
		Тип("КнопкаФормы"),
		ГруппаРодитель);
	ЭлементКнопка.Вид = ВидКнопкиФормы.Гиперссылка;
	ЭлементКнопка.Заголовок = Представление;
	ЭлементКнопка.ИмяКоманды = НоваяКоманда.Имя;
	ЭлементКнопка.Шрифт = ШрифтыСтиля.ОбычныйШрифтТекста;
	ЭлементКнопка.АвтоМаксимальнаяШирина = Ложь;
	ЭлементКнопка.РастягиватьПоГоризонтали = Истина;
	
	ЭлементНадпись = Элементы.Добавить(
		"ДекорацияНадписьВыравниваниеОрганизация_" + КлючСтроки,
		Тип("ДекорацияФормы"),
		ГруппаРодитель);
	ЭлементНадпись.Вид = ВидДекорацииФормы.Надпись;
	ЭлементНадпись.АвтоМаксимальнаяШирина = Ложь;
	ЭлементНадпись.РастягиватьПоГоризонтали = Истина;
	
	ЭлементНадпись = Элементы.Добавить(
		"ДекорацияНадписьСтатусОрганизация_" + КлючСтроки,
		Тип("ДекорацияФормы"),
		ГруппаРодитель);
	ЭлементНадпись.Вид = ВидДекорацииФормы.Надпись;
	ЭлементНадпись.АвтоМаксимальнаяШирина = Ложь;
	ЭлементНадпись.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
	ЭлементНадпись.Заголовок = "";
	ЭлементНадпись.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
	
	ЭлементКартинка = Элементы.Добавить(
		"ДекорацияКартинкаСтатусОрганизация_" + КлючСтроки,
		Тип("ДекорацияФормы"),
		ГруппаРодитель);
	ЭлементКартинка.Вид = ВидДекорацииФормы.Картинка;
	ЭлементКартинка.Картинка = БиблиотекаКартинок.Пустая;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСписокРазделовУчета()
	
	ДоступныеРазделы = СовместноеИспользование.ДоступныеРазделыУчета();
	
	Для Каждого ОписаниеРаздела Из ДоступныеРазделы Цикл
		СтрокаРазделы = РазделыУчета.Добавить();
		СтрокаРазделы.Идентификатор = ОписаниеРаздела.Идентификатор;
		СтрокаРазделы.Пометка = Истина;
		СтрокаРазделы.ПоВсемДокументам = Истина;
		СтрокаРазделы.Представление = ОписаниеРаздела.Представление;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьЭлементыУправленияРазделовУчета()
	
	Для Инд = 0 По РазделыУчета.Количество() - 1 Цикл
		ДобавитьЭлементыУправленияРазделаУчета(Инд);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементыУправленияРазделаУчета(Индекс)
	
	СтрокаРазделы = РазделыУчета[Индекс];
	
	ИдентификаторРаздела = СтрокаРазделы.Идентификатор;
	Представление = СтрокаРазделы.Представление;
	Пометка = СтрокаРазделы.Пометка;
	Количество = СтрокаРазделы.Количество;
	
	ГруппаРодитель = Элементы.Добавить(
		"ГруппаРазделУчета_" + ИдентификаторРаздела,
		Тип("ГруппаФормы"),
		Элементы.ГруппаРазделыУчета);
	ГруппаРодитель.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаРодитель.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	ГруппаРодитель.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаРодитель.ОтображатьЗаголовок = Ложь;
	ГруппаРодитель.ЦветФона = ЦветаСтиля.ЦветФонаШапкиТаблицы;
	ГруппаРодитель.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлемента.Центр;
	ГруппаРодитель.РастягиватьПоГоризонтали = Истина;
	
	ЭлементФлажок = Элементы.Добавить(
		"Раздел_" + ИдентификаторРаздела,
		Тип("ПолеФормы"),
		ГруппаРодитель);
	ЭлементФлажок.Вид = ВидПоляФормы.ПолеФлажка;
	ЭлементФлажок.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ЭлементФлажок.ПутьКДанным = СтрШаблон("РазделыУчета[%1].Пометка", Формат(Индекс, "ЧГ=0"));
	ЭлементФлажок.УстановитьДействие("ПриИзменении", "ФлажокРазделаУчетаПриИзменении");
	
	ЭлементНадпись = Элементы.Добавить(
		"ДекорацияНадписьРазделУчета_" + ИдентификаторРаздела,
		Тип("ДекорацияФормы"),
		ГруппаРодитель);   
		
	Если ЗначениеЗаполнено(Количество) Тогда
		ЭлементНадпись.Заголовок = Представление + " (отразить: " + Количество + ")";
	Иначе
		ЭлементНадпись.Заголовок = Представление;
	КонецЕсли;
		
	ЭлементНадпись.Шрифт = ШрифтыСтиля.ОбычныйШрифтТекста;
	ЭлементНадпись.Вид = ВидДекорацииФормы.Надпись;
	ЭлементНадпись.АвтоМаксимальнаяШирина = Ложь;
	ЭлементНадпись.РастягиватьПоГоризонтали = Истина;
	
	НоваяКоманда = Команды.Добавить("КомандаВидыДокументов_" + ИдентификаторРаздела);
	НоваяКоманда.Действие = "ОбщийОбработчикКомандыВидыДокументов";
	
	УстановитьСвойстваКомандыВидыДокументов(НоваяКоманда.Имя, ИдентификаторРаздела);
	
	ЭлементКнопка = Элементы.Добавить(
		НоваяКоманда.Имя,
		Тип("КнопкаФормы"),
		ГруппаРодитель);
	ЭлементКнопка.Вид = ВидКнопкиФормы.Гиперссылка;
	ЭлементКнопка.ИмяКоманды = НоваяКоманда.Имя;
	
	ЭлементКнопка.Доступность = Пометка;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСвойстваКомандыВидыДокументов(ИмяКоманды, ИдентификаторРаздела)
	
	Команда = Команды.Найти(ИмяКоманды);
	
	Если Команда = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиРазделы = РазделыУчета.НайтиСтроки(Новый Структура("Идентификатор", ИдентификаторРаздела));
	
	Если СтрокиРазделы[0].ПоВсемДокументам Тогда
		Команда.Заголовок = НСтр("ru = 'Все документы'");
		Команда.Подсказка = "";
		Возврат;
	Иначе
		Команда.Заголовок = НСтр("ru = 'Документы не выбраны'");
		Команда.Подсказка = "";
	КонецЕсли;
	
	ДоступныеВидыДокументов = СовместноеИспользование.СоответствиеВидовДокументовИРазделовУчета();
	
	Отбор = Новый Структура("РазделУчета", ИдентификаторРаздела);
	
	КоличествоВсего = ДоступныеВидыДокументов.НайтиСтроки(Отбор).Количество();
	
	СтрокиВыбранные = ВыбранныеВидыДокументов.НайтиСтроки(Отбор);
	
	Если СтрокиВыбранные.Количество() > 0
		И СтрокиВыбранные.Количество() < КоличествоВсего Тогда
		СтрокиЗаголовок = Новый Массив;
		
		КоличествоДляОтображенияВЗаголовке = 2;
		
		Для Сч = 1 По Мин(КоличествоДляОтображенияВЗаголовке, СтрокиВыбранные.Количество()) Цикл
			СтрокиЗаголовок.Добавить(СтрокиВыбранные[Сч - 1].Представление);
		КонецЦикла;
		
		Команда.Заголовок = СтрСоединить(СтрокиЗаголовок, ", ");
		
		Если СтрокиВыбранные.Количество() > КоличествоДляОтображенияВЗаголовке Тогда
			Команда.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '%1 (и еще %2)'"),
				Команда.Заголовок,
				Формат(СтрокиВыбранные.Количество() - КоличествоДляОтображенияВЗаголовке, "ЧГ=0"));
		КонецЕсли;
		
		СтрокиПодсказка = Новый Массив;
		Для Каждого СтрокаВыбранные Из СтрокиВыбранные Цикл
			СтрокиПодсказка.Добавить(СтрокаВыбранные.Представление);
		КонецЦикла;
		
		Команда.Подсказка = СтрСоединить(СтрокиПодсказка, ", ");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСвойстваСтрокиРаздела(ИдентификаторРаздела, Количество)
	
	ИмяЭлемента = "ДекорацияНадписьРазделУчета_" + ИдентификаторРаздела;
	ЭлементНадпись = Элементы.Найти(ИмяЭлемента);
	Если ЭлементНадпись = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиРазделы = РазделыУчета.НайтиСтроки(Новый Структура("Идентификатор", ИдентификаторРаздела));
	Представление = СтрокиРазделы[0].Представление;                           
	СтрокиРазделы[0].Количество = Количество;     
	БылиИзмененияНастроек = СравнитьКэшИРеквизиты();	
	Если БылиИзмененияНастроек И ЗначениеЗаполнено(Количество) Тогда
		ЭлементНадпись.Заголовок = Представление + " (отразить: " + Количество + ")";   
	Иначе
		ЭлементНадпись.Заголовок = Представление;
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура УстановитьСвойстваКомандыОтразитьДокументы()
	
	ИмяКоманды = "КомандаОтразитьДокументы";
	КомандаОтразить = Команды.Найти(ИмяКоманды);
	
	Если КомандаОтразить = Неопределено Тогда
		Возврат;
	КонецЕсли;     

	ИмяКоманды = "КомандаСохранитьНастройки";
	КомандаСохранить = Команды.Найти(ИмяКоманды);
	
	ОбщееКоличество = РазделыУчета.Итог("Количество");
	БылиИзмененияНастроек = СравнитьКэшИРеквизиты();	
	
	Если БылиИзмененияНастроек И ОбщееКоличество > 0 Тогда
		ТекстЗаголовка = НСтр("ru = 'Отразить документы сейчас (#1)'");     
		КомандаОтразить.Заголовок = СтрЗаменить(ТекстЗаголовка, "#1", Формат(ОбщееКоличество, "ЧЦ=10"));
		КомандаОтразить.Подсказка = "";
		Элементы.КомандаОтразитьДокументы.Видимость = Истина;

		ТекстЗаголовка = НСтр("ru = 'Сохранить и запланировать отражение (#1)'");     
		КомандаСохранить.Заголовок = СтрЗаменить(ТекстЗаголовка, "#1", Формат(ОбщееКоличество, "ЧЦ=10"));
	Иначе
		КомандаОтразить.Заголовок = НСтр("ru = 'Отразить документы сейчас'");
		КомандаСохранить.Заголовок = НСтр("ru = 'Сохранить настройки и выйти'");
		КомандаОтразить.Подсказка = "";
		Элементы.КомандаОтразитьДокументы.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПодготовитьВыборВидовДокументовПоРазделу(ИдентификаторРаздела)
	
	ДоступныеРазделы = СовместноеИспользование.ДоступныеРазделыУчета();
	СтрокаРаздел = ДоступныеРазделы.Найти(ИдентификаторРаздела, "Идентификатор");
	
	Результат = Новый Структура;
	Результат.Вставить("СписокВыбора", Новый СписокЗначений);
	Результат.Вставить("Заголовок", СтрокаРаздел.Представление);
	
	ДоступныеВидыДокументов = СовместноеИспользование.СоответствиеВидовДокументовИРазделовУчета();
	
	Отбор = Новый Структура("РазделУчета", ИдентификаторРаздела);
	
	Для Каждого СтрокаВидыДокументов Из ДоступныеВидыДокументов.НайтиСтроки(Отбор) Цикл
		ОтборВыбранные = Новый Структура("РазделУчета,ИмяОбъекта");
		ОтборВыбранные.РазделУчета = СтрокаВидыДокументов.РазделУчета;
		ОтборВыбранные.ИмяОбъекта = СтрокаВидыДокументов.ИмяОбъектаМетаданных;
		
		СтрокиВыбранные = ВыбранныеВидыДокументов.НайтиСтроки(ОтборВыбранные);
		
		ЗначениеВыбора = Новый Структура("РазделУчета,ИмяОбъекта,ПолноеИмяМетаданных,Представление,ЕстьОрганизация,РазрешеноПроведение");
		ЗаполнитьЗначенияСвойств(ЗначениеВыбора, СтрокаВидыДокументов);
		ЗначениеВыбора.ИмяОбъекта = СтрокаВидыДокументов.ИмяОбъектаМетаданных;
		
		Результат.СписокВыбора.Добавить(
			ЗначениеВыбора,
			СтрокаВидыДокументов.Представление,
			СтрокиВыбранные.Количество() > 0);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПодсчитатьКоличествоДокументовПоРазделу(СписокВыбора, ИдентификаторРаздела)   

	СтрокиКэша = КэшРазделыУчета.НайтиСтроки(Новый Структура("Идентификатор",  ИдентификаторРаздела));
	Если СтрокиКэша.Количество() > 0 Тогда
		Если СтрокиКэша[0].Пометка Тогда    
			РазделБылВключен = Истина;
		Иначе
			РазделБылВключен = Ложь;
		КонецЕсли;
	Иначе
		РазделБылВключен = Ложь;
	КонецЕсли;

	БылиДополненияОрганизаций = СравнитьКэшОрганизацийИРеквизиты();

	СтрокиРаздела = ДокументыКВыгрузке.НайтиСтроки(Новый Структура("ИдентификаторРаздела", ИдентификаторРаздела));
	Для Каждого СтрокаРаздела Из СтрокиРаздела Цикл
		ДокументыКВыгрузке.Удалить(СтрокаРаздела);
	КонецЦикла;

	ТекстыЗапросов = Новый Массив;    
	
	Для Каждого ВидДокумента Из СписокВыбора Цикл   
		
		Если ВидДокумента.Пометка Тогда
			ТекстЗапроса =
			"ВЫБРАТЬ
			|	Т.Ссылка КАК Ссылка,
			|	&ИдентификаторРаздела КАК ИдентификаторРаздела
			|ИЗ
			|	Документ.ПоступлениеВКассу КАК Т
			|ГДЕ
			|	Т.Дата >= &ДатаНачалаОтражения";
			
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Документ.ПоступлениеВКассу", ВидДокумента.Значение.ПолноеИмяМетаданных);   
			
			Если ВидДокумента.Значение.ЕстьОрганизация Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И Т.Организация В(&МассивОрганизаций)"; 
			КонецЕсли;
	
			Если ЗначениеЗаполнено(КэшДатаНачалаОтражения) И РазделБылВключен И НЕ БылиДополненияОрганизаций Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И Т.Дата < &КэшДатаНачалаОтражения";
			КонецЕсли;       
			
			Если ВидДокумента.Значение.РазрешеноПроведение Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И Т.Проведен";
			КонецЕсли;
	
			ТекстыЗапросов.Добавить(ТекстЗапроса);
		КонецЕсли;
	
	КонецЦикла;
	
	Разделитель = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|";
	
	ТекстЗапросаОбщий = СтрСоединить(ТекстыЗапросов, Разделитель);      
	
	КоличествоДокументов = 0;
	Если ЗначениеЗаполнено(ТекстЗапросаОбщий) Тогда
		Запрос = Новый Запрос(ТекстЗапросаОбщий);
		Запрос.УстановитьПараметр("ДатаНачалаОтражения", ДатаНачалаОтражения);     
		Запрос.УстановитьПараметр("КэшДатаНачалаОтражения", КэшДатаНачалаОтражения);     
		Запрос.УстановитьПараметр("ИдентификаторРаздела", ИдентификаторРаздела);     

		МассивОрганизаций = Новый Массив;
		Для Каждого СтрокаОрганизация Из ДоступныеОрганизации Цикл
			Если СтрокаОрганизация.Пометка Тогда
				МассивОрганизаций.Добавить(СтрокаОрганизация.Ссылка);
			КонецЕсли;  
		КонецЦикла;
		Запрос.УстановитьПараметр("МассивОрганизаций", МассивОрганизаций);
		Выборка = Запрос.Выполнить().Выбрать();     
	
		Пока Выборка.Следующий() Цикл 
			НоваяСтрока = ДокументыКВыгрузке.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		КонецЦикла;
		КоличествоДокументов = Выборка.Количество();
	КонецЕсли;
	
	Возврат КоличествоДокументов;
	
КонецФункции

&НаКлиенте
Процедура ПерейтиВПомощникСопоставленияОбъектовБухгалтерии()
	
	ШаблонСсылки = "СовместноеИспользование/ОткрытьПомощникСопоставленияОбъектов?node-id=%1";
	
	СовместноеИспользованиеКлиент.ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(
		СтрШаблон(ШаблонСсылки, ИдентификаторЭтогоУзлаОбмена()),
		"БухгалтерияПредприятия");
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьСинхронизацию()
	
	Если БухгалтерияПуста Тогда
		ОбменЗапланирован = СинхронизацияДанныхЗапланирована(ТекущаяНастройка, ВнешняяУчетнаяСистема);
		
		Если ОбменЗапланирован Тогда
			ПодключитьОбработчикОжидания("ОбработкаОжиданияЗавершенияСценарияОбмена", 20, Истина);
		Иначе
			ДлительнаяОперация = ДлительнаяОперацияВыполнитьСценарийСинхронизацииДанных(УникальныйИдентификатор, ТекущаяНастройка, ВнешняяУчетнаяСистема);
			
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
			ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
			
			ДлительныеОперацииКлиент.ОжидатьЗавершение(
				ДлительнаяОперация,
				Новый ОписаниеОповещения("ВыполнитьСценарийСинхронизацииДанныхЗавершение", ЭтотОбъект),
				ПараметрыОжидания);
		КонецЕсли;
	Иначе
		ДлительнаяОперация = ДлительнаяОперацияВыполнитьВыгрузкуЗарегистрированныхДанныхДляСопоставления(УникальныйИдентификатор, ТекущаяНастройка, ВнешняяУчетнаяСистема);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(
			ДлительнаяОперация,
			Новый ОписаниеОповещения("ВыполнитьВыгрузкуЗарегистрированныхДанныхДляСопоставленияЗавершение", ЭтотОбъект),
			ПараметрыОжидания);
	КонецЕсли;
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияВыполнитьСценарийСинхронизацииДанных(ИдентификаторФормы, НастройкаОтражения, ВнешняяУчетнаяСистема)
    ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Выполнение сценария синхронизации данных'");
	ПараметрыВыполнения.ОжидатьЗавершение = 0;

	Возврат ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ВыполнитьСценарийСинхронизацииДанных",
		НастройкаОтражения,
		ВнешняяУчетнаяСистема);
	
КонецФункции

&НаСервереБезКонтекста
Функция ДлительнаяОперацияВыполнитьВыгрузкуЗарегистрированныхДанныхДляСопоставления(ИдентификаторФормы, НастройкаОтражения, ВнешняяУчетнаяСистема)

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Выгрузка зарегистрированных данных для сопоставления'");
	ПараметрыВыполнения.ОжидатьЗавершение = 0;

	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения,
		"Обработки.ОтражениеДокументовВБухгалтерии.ВыполнитьВыгрузкуЗарегистрированныхДанныхДляСопоставления",
		НастройкаОтражения,
		ВнешняяУчетнаяСистема);
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьСценарийСинхронизацииДанныхЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Если Отказ Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОшибка");
		УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
		Возврат;
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ОбработкаОжиданияЗавершенияСценарияОбмена", 20, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьВыгрузкуЗарегистрированныхДанныхДляСопоставленияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Отказ = Ложь;
	
	ПриЗавершенииДлительнойОперации(Результат, Отказ);
	
	Если Отказ Тогда
		УстановитьРежимПомощника("НастройкиОтраженияОшибка");
		Возврат;
	КонецЕсли;
	
	УстановитьРежимПомощника("НастройкиОтраженияУспехБухгалтерияНеПуста");
	УстановитьДоступностьОрганизацийИДатыНачалаОтражения(Истина);
	
	Элементы.ОтражениеВключено.Видимость = Истина;
	
	ЗакрытьПомощникПослеЗавершенияСопоставления = Истина;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИдентификаторЭтогоУзлаОбмена()
	
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПланыОбмена.СинхронизацияДанныхЧерезУниверсальныйФормат.ЭтотУзел(), "Код");
	
КонецФункции

&НаКлиенте
Процедура УстановитьДоступностьКомандНачалаРаботыИИзмененияОрганизаций()
	
	ЕстьВыбранныеОрганизации = Ложь;
	ЕстьНезаполненныеРеквизиты = Ложь;
	
	Для Каждого СтрокаОрганизации Из ДоступныеОрганизации Цикл
		Если СтрокаОрганизации.Пометка Тогда
			ЕстьВыбранныеОрганизации = Истина;
			ЕстьНезаполненныеРеквизиты = ЕстьНезаполненныеРеквизиты Или СтрокаОрганизации.ЕстьНезаполненныеРеквизиты;
		КонецЕсли;
	КонецЦикла;
	
	Элементы.КомандаОрганизацииИзменены.Доступность = ЕстьВыбранныеОрганизации И Не ЕстьНезаполненныеРеквизиты;
	Элементы.КомандаНачатьРаботу.Доступность = ЕстьВыбранныеОрганизации И Не ЕстьНезаполненныеРеквизиты И ЗначениеЗаполнено(ДатаНачалаОтражения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредупреждениеНастройкаОтраженияНедоступнаЗавершение(ДополнительныеПараметры) Экспорт
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросОтражениеВключеноЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Элементы.ОтражениеВключено.Доступность = Истина;
		ОтражениеВключено = Истина;
		Возврат;
	КонецЕсли; 
	
	Элементы.ГруппаНастройкиОтраженияПервыйЭтап.Доступность = Ложь;
	Элементы.ГруппаНастройкиОтраженияВторойЭтап.Доступность = Ложь;
	
	ПодключитьОбработчикОжидания("ОтключитьОтражениеДокументов", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗавершенииДлительнойОперации(Результат, Отказ)
	
	Если Результат = Неопределено Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Действие отменено. Повторите попытку позже.'"), , , , Отказ);
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(Результат.ИнформацияОбОшибке), , , , Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СобытиеЖурналаРегистрации()
	
	Возврат НСтр("ru = 'Совместное использование.Настройки раздела'", ОбщегоНазначения.КодОсновногоЯзыка());
	
КонецФункции

#КонецОбласти