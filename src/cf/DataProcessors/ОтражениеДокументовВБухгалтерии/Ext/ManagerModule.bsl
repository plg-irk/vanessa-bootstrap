#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// Для выполнения в Фоновом задании.
//
Функция ПодготовитьДанныеМонитора(Параметры) Экспорт
	
	Если Параметры.ВыполнитьОбновлениеДанных Тогда
		// 1. Запуск обмена данными.
		// Запускается по расписанию.
		
		// 2. Синхронизация результатов обмена и выполнение проверок.
		РегистрыСведений.ПубличныеИдентификаторыБухгалтерии.ВыполнитьОбновлениеДанных();
	КонецЕсли;
	
	// 3. Подготовка данных для монитора.
	ОписаниеЗапроса = ОписаниеЗапросаДетальныхЗаписейОтраженияДокументов(Параметры.Отборы);
	
	Запрос = Новый Запрос(ОписаниеЗапроса.Текст);
	
	Для Каждого ОписаниеПараметра Из ОписаниеЗапроса.Параметры Цикл
		Запрос.УстановитьПараметр(ОписаниеПараметра.Ключ, ОписаниеПараметра.Значение);
	КонецЦикла;
	
	ТаблицаДокументов = Запрос.Выполнить().Выгрузить();
	
	ДанныеОтражения = Новый Структура;
	ДанныеОтражения.Вставить("ТаблицаДокументов", ТаблицаДокументов);
	
	Возврат ДанныеОтражения;
	
КонецФункции

Функция ОписаниеЗапросаДетальныхЗаписейОтраженияДокументов(Отборы) Экспорт

	ОписаниеЗапроса = Новый Структура;
	ОписаниеЗапроса.Вставить("Текст", "");
	ОписаниеЗапроса.Вставить("Параметры", Новый Структура);
	
	НастройкиУзлаОбмена = Справочники.НастройкиОтраженияДокументовВБухгалтерии.НастройкиУзлаОбмена();  
	УзелОбмена = НастройкиУзлаОбмена.УзелОбмена;
	
	СоставПланаОбмена = УзелОбмена.Метаданные().Состав;
	
	ТекстыЗапросов = Новый Массив;

	// 1. Объекты есть в бухгалтерии и должны быть выгружены в УНФ, но не выгружены. 
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(ИдентификаторыБухгалтерии.Идентификатор) КАК Идентификатор,
	|	МАКСИМУМ(ИдентификаторыБухгалтерии.ИдентификаторМетаданных) КАК ИдентификаторМетаданных,
	|	МАКСИМУМ(ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения) КАК ЕстьОшибкиОтражения,
	|	МИНИМУМ(ИдентификаторыБухгалтерии.Проведен) КАК Проведен,
	|	МАКСИМУМ(ИдентификаторыБухгалтерии.Множественный) КАК Множественный,
	|	ИдентификаторыБухгалтерии.ПубличныйИдентификатор КАК ПубличныйИдентификатор,
	|	МАКСИМУМ(ИдентификаторыБухгалтерии.СвязанныеИдентификаторы) КАК СвязанныеИдентификаторы
	|ПОМЕСТИТЬ СгруппированныеИдентификаторыБухгалтерии
	|ИЗ
	|	РегистрСведений.ПубличныеИдентификаторыБухгалтерии КАК ИдентификаторыБухгалтерии
	|
	|СГРУППИРОВАТЬ ПО
	|	ИдентификаторыБухгалтерии.ПубличныйИдентификатор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	NULL КАК Ссылка,
	|	ИдентификаторыБухгалтерии.ПубличныйИдентификатор КАК ПубличныйИдентификатор,
	|	ИдентификаторыБухгалтерии.Идентификатор КАК Идентификатор_Бухгалтерия,
	|	ИдентификаторыБухгалтерии.ИдентификаторМетаданных КАК ИдентификаторМетаданных_Бухгалтерия,
	|	ИдентификаторыБухгалтерии.РазделУчета КАК РазделУчета,
	|	ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения КАК ЕстьОшибкиОтражения,
	|	ИдентификаторыБухгалтерии.Номер КАК Номер,
	|	ИдентификаторыБухгалтерии.Дата КАК Дата,
	|	ПубличныеИдентификаторыОрганизации.Ссылка КАК Организация,
	|	ИдентификаторыБухгалтерии.СуммаДокумента КАК СуммаДокумента,
	|	ЛОЖЬ КАК ОтраженВБизнесе,
	|	ИдентификаторыБухгалтерии.Проведен КАК ОтраженВБухгалтерии,
	|	"""" КАК ТипДокумента,
	|	ИдентификаторыБухгалтерии.ВидОперации КАК ВидОперации,
	|	""НеОтражен"" КАК Статус,
	|	ИдентификаторыБухгалтерии.Множественный КАК Множественный,
	|	ИдентификаторыБухгалтерии.СвязанныеИдентификаторы КАК СвязанныеИдентификаторы
	|ИЗ
	|	РегистрСведений.ПубличныеИдентификаторыБухгалтерии КАК ИдентификаторыБухгалтерии
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторы
	|		ПО (ПубличныеИдентификаторы.Идентификатор = ИдентификаторыБухгалтерии.ПубличныйИдентификатор)
	|			И (ПубличныеИдентификаторы.УзелИнформационнойБазы = &УзелОбмена)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторыОрганизации
	|		ПО (ПубличныеИдентификаторыОрганизации.Идентификатор = ИдентификаторыБухгалтерии.Организация)
	|			И (ПубличныеИдентификаторыОрганизации.УзелИнформационнойБазы = &УзелОбмена)
	|			И (ПубличныеИдентификаторыОрганизации.Ссылка ССЫЛКА Справочник.Организации)
	|ГДЕ
	|	ПубличныеИдентификаторы.Ссылка ЕСТЬ NULL";
	
	Если Отборы.Организации.Количество() > 0 Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И ПубличныеИдентификаторыОрганизации.Ссылка В (&ОтборОрганизации)";
	КонецЕсли;
	Если Отборы.ТипыДокумента.Количество() > 0 Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И """" В (&ОтборТипыДокумента)";
	КонецЕсли;
	Если ЗначениеЗаполнено(Отборы.Период.ДатаНачала) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И ИдентификаторыБухгалтерии.Дата >= &ОтборДатаНачала";
	КонецЕсли;
	Если ЗначениеЗаполнено(Отборы.Период.ДатаОкончания) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И ИдентификаторыБухгалтерии.Дата <= &ОтборДатаОкончания";
	КонецЕсли;
	Если Отборы.РазделыУчета.Количество() > 0 Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И ИдентификаторыБухгалтерии.РазделУчета В (&ОтборРазделыУчета)";
	КонецЕсли;
	Если Отборы.Статусы.Количество() > 0 Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И (""НеОтражен"" В (&ОтборСтатусы) ИЛИ ""НеОтраженВБизнесе"" В (&ОтборСтатусы))";
	КонецЕсли;
	Если Отборы.Свойство("СсылкаНаДокумент") И  ЗначениеЗаполнено(Отборы.СсылкаНаДокумент) Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И ЛОЖЬ";
	КонецЕсли;
	
	ТекстыЗапросов.Добавить(ТекстЗапроса);
	
	ИсточникиДанных = СовместноеИспользование.ИсточникиДанныхСинхронизируемыхОбъектов();
	
	Для Каждого ОписаниеИсточника Из ИсточникиДанных Цикл
		Если Отборы.РазделыУчета.Количество() > 0
			И Отборы.РазделыУчета.Найти(ОписаниеИсточника.ИдентификаторРаздела) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
 		Если НЕ НастройкиУзлаОбмена.ИспользоватьОтборПоВидамЦен 
			И ОписаниеИсточника.ИмяТаблицы = "Документ.УстановкаЦенНоменклатуры" Тогда
			Продолжить;
		КонецЕсли;    

		Если СоставПланаОбмена.Содержит(ОписаниеИсточника.МетаданныеОбъекта) Тогда
			// 2. Объекты есть в УНФ, были выгружены в бухгалтерию.
			// На стороне бухгалтерии могли быть загружены, моли быть не загружены.
			ТекстЗапроса =
			"ВЫБРАТЬ
			|	ТаблицаДокумента.Ссылка КАК Ссылка,
			|	ПубличныеИдентификаторы.Идентификатор КАК ПубличныйИдентификатор,
			|	ИдентификаторыБухгалтерии.Идентификатор КАК Идентификатор_Бухгалтерия,
			|	ИдентификаторыБухгалтерии.ИдентификаторМетаданных КАК ИдентификаторМетаданных_Бухгалтерия,
			|	""#ИдентификаторРаздела"" КАК РазделУчета,
			|	ЕСТЬNULL(ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения, ЛОЖЬ) КАК ЕстьОшибкиОтражения,
			|	ТаблицаДокумента.Номер КАК Номер,
			|	ТаблицаДокумента.Дата КАК Дата,
			|	ТаблицаДокумента.Организация КАК Организация,
			|	ТаблицаДокумента.СуммаДокумента КАК СуммаДокумента,
			|	ТаблицаДокумента.Проведен КАК ОтраженВБизнесе,
			|	ЕСТЬNULL(ИдентификаторыБухгалтерии.Проведен, ЛОЖЬ) КАК ОтраженВБухгалтерии,
			|	#СинонимМетаданных КАК ТипДокумента,
			|	ТаблицаДокумента.ВидОперации КАК ВидОперации,
			|	ВЫБОР
			|		КОГДА НЕ ТаблицаДокумента.Проведен
			|				ИЛИ НЕ ЕСТЬNULL(ИдентификаторыБухгалтерии.Проведен, ЛОЖЬ)
			|			ТОГДА ""НеОтражен""
			|		КОГДА ЕСТЬNULL(ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения, ЛОЖЬ)
			|			ТОГДА ""ЕстьРасхождения""
			|		ИНАЧЕ ""Отражен""
			|	КОНЕЦ КАК Статус,
			|	ИдентификаторыБухгалтерии.Множественный КАК Множественный,
			|	ИдентификаторыБухгалтерии.СвязанныеИдентификаторы КАК СвязанныеИдентификаторы
			|ИЗ
			|	РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторы
			|		ЛЕВОЕ СОЕДИНЕНИЕ СгруппированныеИдентификаторыБухгалтерии КАК ИдентификаторыБухгалтерии
			|		ПО (ИдентификаторыБухгалтерии.ПубличныйИдентификатор = ПубличныеИдентификаторы.Идентификатор)
			|		ЛЕВОЕ СОЕДИНЕНИЕ #ТекстПодзапроса КАК ТаблицаДокумента
			|		ПО (ТаблицаДокумента.Ссылка = ПубличныеИдентификаторы.Ссылка)
			|ГДЕ
			|	ПубличныеИдентификаторы.УзелИнформационнойБазы = &УзелОбмена
			|	И НЕ ТаблицаДокумента.Ссылка ЕСТЬ NULL";
			
			ТекстЗапроса = ТекстЗапроса + "
			|	И ПубличныеИдентификаторы.Ссылка ССЫЛКА " + ОписаниеИсточника.ИмяТаблицы;
			
			Если Отборы.Организации.Количество() > 0 Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ТаблицаДокумента.Организация В (&ОтборОрганизации)";
			КонецЕсли;
			Если Отборы.ТипыДокумента.Количество() > 0 Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И #СинонимМетаданных В (&ОтборТипыДокумента)";
			КонецЕсли;
			Если ЗначениеЗаполнено(Отборы.Период.ДатаНачала) Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ТаблицаДокумента.Дата >= &ОтборДатаНачала";
			КонецЕсли;
			Если ЗначениеЗаполнено(Отборы.Период.ДатаОкончания) Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ТаблицаДокумента.Дата <= &ОтборДатаОкончания";
			КонецЕсли;    
			
			Если НастройкиУзлаОбмена.ПереноситьЗаказыКакСчетаНаОплату 
				И ОписаниеИсточника.ИмяТаблицы = "Документ.СчетНаОплату" Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ЕСТЬNULL(ИдентификаторыБухгалтерии.Проведен, ЛОЖЬ) ";
			ИначеЕсли НЕ НастройкиУзлаОбмена.ПереноситьЗаказыКакСчетаНаОплату 
				И ОписаниеИсточника.ИмяТаблицы = "Документ.ЗаказПокупателя"
				И СтрНайти (ОписаниеИсточника.ТекстЗапроса, "ТЗаказНаряд") = 0 Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ЕСТЬNULL(ИдентификаторыБухгалтерии.Проведен, ЛОЖЬ) ";
			КонецЕсли;     
				
			Если ОписаниеИсточника.ИмяТаблицы = "Документ.ПлатежноеПоручение" Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И НЕ ТаблицаДокумента.ВидОперацииЗначение В(&ЗапрещенныеОперацииПоручения) ";
  			КонецЕсли;     

			Если Отборы.Статусы.Количество() > 0 Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ВЫБОР
				|	    КОГДА НЕ ТаблицаДокумента.Проведен ИЛИ НЕ ЕСТЬNULL(ИдентификаторыБухгалтерии.Проведен, ЛОЖЬ) ТОГДА ""НеОтражен""
				|	    КОГДА ЕСТЬNULL(ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения, ЛОЖЬ) ТОГДА ""ЕстьРасхождения""
				|	    ИНАЧЕ ""Отражен""
				|	КОНЕЦ В (&ОтборСтатусы)";
				ТекстЗапроса = ТекстЗапроса + "
				|	И ВЫБОР
				|	    КОГДА НЕ ТаблицаДокумента.Проведен ТОГДА ""НеОтраженВБизнесе""
				|	    КОГДА НЕ ЕСТЬNULL(ИдентификаторыБухгалтерии.Проведен, ЛОЖЬ) ТОГДА ""НеОтраженВБухгалтерии""
				|	КОНЕЦ В (&ОтборСтатусы)";
			КонецЕсли;
			Если Отборы.Свойство("СсылкаНаДокумент") И  ЗначениеЗаполнено(Отборы.СсылкаНаДокумент) Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ПубличныеИдентификаторы.Ссылка = &СсылкаНаДокумент";
			КонецЕсли;
				
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ИдентификаторРаздела", ОписаниеИсточника.ИдентификаторРаздела);
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ТекстПодзапроса", "(" + ОписаниеИсточника.ТекстЗапроса + ")");
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#СинонимМетаданных", """" + ОписаниеИсточника.МетаданныеОбъекта.Синоним + """");
			ТекстыЗапросов.Добавить(ТекстЗапроса);
		
			// 3. Объекты есть в УНФ, зарегистрированы к обмену, но еще не выгружались.
			Если НастройкиУзлаОбмена.ПереноситьЗаказыКакСчетаНаОплату 
				И ОписаниеИсточника.ИмяТаблицы = "Документ.СчетНаОплату" Тогда
				Продолжить;
			ИначеЕсли НЕ НастройкиУзлаОбмена.ПереноситьЗаказыКакСчетаНаОплату 
				И ОписаниеИсточника.ИмяТаблицы = "Документ.ЗаказПокупателя"
				И СтрНайти(ОписаниеИсточника.ТекстЗапроса, "ТЗаказНаряд") = 0 Тогда
				Продолжить;
			КонецЕсли;     

			ТекстЗапроса =
			"ВЫБРАТЬ
			|	ТаблицаДокумента.Ссылка КАК Ссылка,
			|	NULL КАК ПубличныйИдентификатор,
			|	NULL КАК Идентификатор_Бухгалтерия,
			|	NULL КАК ИдентификаторМетаданных_Бухгалтерия,
			|	""#ИдентификаторРаздела"" КАК РазделУчета,
			|	ЛОЖЬ КАК ЕстьОшибкиОтражения,
			|	ТаблицаДокумента.Номер КАК Номер,
			|	ТаблицаДокумента.Дата КАК Дата,
			|	ТаблицаДокумента.Организация КАК Организация,
			|	ТаблицаДокумента.СуммаДокумента КАК СуммаДокумента,
			|	ТаблицаДокумента.Проведен КАК ОтраженВБизнесе,
			|	ЛОЖЬ КАК ОтраженВБухгалтерии,
			|	#СинонимМетаданных КАК ТипДокумента,
			|	ТаблицаДокумента.ВидОперации КАК ВидОперации,
			|	""НеОтражен"" КАК Статус,
			|	ЛОЖЬ КАК Множественный,
			|	"""" КАК СвязанныеИдентификаторы
			|ИЗ
			|	#ТаблицаИзмененийОбъекта КАК ТаблицаИзменений
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторы
			|		ПО (ПубличныеИдентификаторы.Ссылка = ТаблицаИзменений.Ссылка)
			|			И (ПубличныеИдентификаторы.УзелИнформационнойБазы = ТаблицаИзменений.Узел)
			|		ЛЕВОЕ СОЕДИНЕНИЕ #ТекстПодзапроса КАК ТаблицаДокумента
			|		ПО (ТаблицаДокумента.Ссылка = ТаблицаИзменений.Ссылка)
			|ГДЕ
			|	ТаблицаИзменений.Узел = &УзелОбмена
			|	И НЕ ТаблицаДокумента.Ссылка ЕСТЬ NULL
			|	И ПубличныеИдентификаторы.Ссылка ЕСТЬ NULL";
			
			Если Отборы.Организации.Количество() > 0 Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ТаблицаДокумента.Организация В (&ОтборОрганизации)";
			КонецЕсли;
			Если Отборы.ТипыДокумента.Количество() > 0 Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И #СинонимМетаданных В (&ОтборТипыДокумента)";
			КонецЕсли;
			Если ЗначениеЗаполнено(Отборы.Период.ДатаНачала) Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ТаблицаДокумента.Дата >= &ОтборДатаНачала";
			КонецЕсли;
			Если ЗначениеЗаполнено(Отборы.Период.ДатаОкончания) Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ТаблицаДокумента.Дата <= &ОтборДатаОкончания";
			КонецЕсли;
			Если Отборы.Статусы.Количество() > 0 Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И (""НеОтражен"" В (&ОтборСтатусы) ИЛИ ""НеОтраженВБухгалтерии"" В (&ОтборСтатусы))";
			КонецЕсли;
			Если Отборы.Свойство("СсылкаНаДокумент") И  ЗначениеЗаполнено(Отборы.СсылкаНаДокумент) Тогда
				ТекстЗапроса = ТекстЗапроса + "
				|	И ПубличныеИдентификаторы.Ссылка = &СсылкаНаДокумент";
			КонецЕсли;
			
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ИдентификаторРаздела", ОписаниеИсточника.ИдентификаторРаздела);
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ТаблицаИзмененийОбъекта", ОписаниеИсточника.ИмяТаблицы + ".Изменения");
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ТекстПодзапроса", "(" + ОписаниеИсточника.ТекстЗапроса + ")");
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#СинонимМетаданных", """" + ОписаниеИсточника.МетаданныеОбъекта.Синоним + """");
			ТекстыЗапросов.Добавить(ТекстЗапроса);
		КонецЕсли;
	КонецЦикла;
	
	Разделитель = "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|";
	
	ОписаниеЗапроса.Текст = СтрСоединить(ТекстыЗапросов, Разделитель);
	
	ОписаниеЗапроса.Параметры.Вставить("УзелОбмена", УзелОбмена);
	
	Если Отборы.Организации.Количество() > 0 Тогда
		ОписаниеЗапроса.Параметры.Вставить("ОтборОрганизации", ОбщегоНазначения.СкопироватьРекурсивно(Отборы.Организации));
	КонецЕсли;
	Если Отборы.ТипыДокумента.Количество() > 0 Тогда
		ОписаниеЗапроса.Параметры.Вставить("ОтборТипыДокумента", ОбщегоНазначения.СкопироватьРекурсивно(Отборы.ТипыДокумента));
	КонецЕсли;
	Если ЗначениеЗаполнено(Отборы.Период.ДатаНачала) Тогда
		ОписаниеЗапроса.Параметры.Вставить("ОтборДатаНачала", Отборы.Период.ДатаНачала);
	КонецЕсли;
	Если ЗначениеЗаполнено(Отборы.Период.ДатаОкончания) Тогда
		ОписаниеЗапроса.Параметры.Вставить("ОтборДатаОкончания", Отборы.Период.ДатаОкончания);
	КонецЕсли;
	Если Отборы.РазделыУчета.Количество() > 0 Тогда
		ОписаниеЗапроса.Параметры.Вставить("ОтборРазделыУчета", ОбщегоНазначения.СкопироватьРекурсивно(Отборы.РазделыУчета));
	КонецЕсли;
	Если Отборы.Статусы.Количество() > 0 Тогда
		ОписаниеЗапроса.Параметры.Вставить("ОтборСтатусы", ОбщегоНазначения.СкопироватьРекурсивно(Отборы.Статусы));
	КонецЕсли;
	Если Отборы.Свойство("СсылкаНаДокумент") И  ЗначениеЗаполнено(Отборы.СсылкаНаДокумент) Тогда
		ОписаниеЗапроса.Параметры.Вставить("СсылкаНаДокумент", Отборы.СсылкаНаДокумент);
	КонецЕсли;      
	МассивВидовОпераций = Новый Массив;  
	МассивВидовОпераций.Добавить(Перечисления.ВидыОперацийПлатежноеПоручение.Зарплата);
	МассивВидовОпераций.Добавить(Перечисления.ВидыОперацийПлатежноеПоручение.ЗарплатаСотруднику);
	МассивВидовОпераций.Добавить(Перечисления.ВидыОперацийПлатежноеПоручение.ПереводНаДругойСчет);
	МассивВидовОпераций.Добавить(Перечисления.ВидыОперацийПлатежноеПоручение.Подотчетнику);
	МассивВидовОпераций.Добавить(Перечисления.ВидыОперацийПлатежноеПоручение.ЛичныеСредстваПредпринимателя);
	МассивВидовОпераций.Добавить(Перечисления.ВидыОперацийПлатежноеПоручение.ВыплатаСамозанятому);
	МассивВидовОпераций.Добавить(Перечисления.ВидыОперацийПлатежноеПоручение.ВыплатыСамозанятым);
	
	ОписаниеЗапроса.Параметры.Вставить("ЗапрещенныеОперацииПоручения", МассивВидовОпераций);
	
	Возврат ОписаниеЗапроса;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция СостояниеУчетнойПолитикиОрганизации(ПубличныеИдентификаторы, Период, ПараметрыПодключения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ОписаниеПодключения = СовместноеИспользованиеИнтеграция.НовоеПодключениеКСервису(ПараметрыПодключения);
	УстановитьПривилегированныйРежим(Ложь);
	
	СостояниеУчетнойПолитики = Новый Соответствие;
	
	Для Каждого Идентификатор Из ПубличныеИдентификаторы Цикл
		СостояниеУчетнойПолитики.Вставить(Идентификатор,
			СовместноеИспользованиеИнтеграция.УчетнаяПолитикаОрганизации(ОписаниеПодключения, Идентификатор, Период));
	КонецЦикла;
	
	СовместноеИспользованиеИнтеграция.ЗавершитьСеанс(ОписаниеПодключения);
	
	Возврат СостояниеУчетнойПолитики;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция ПолучитьНастройкиПриложения(ПараметрыПодключения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ОписаниеПодключения = СовместноеИспользованиеИнтеграция.НовоеПодключениеКСервису(ПараметрыПодключения);
	УстановитьПривилегированныйРежим(Ложь);

	Если ОписаниеПодключения = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НастройкиПриложения = СовместноеИспользованиеИнтеграция.ПолучитьНастройкиПриложения(ОписаниеПодключения);
	
	СовместноеИспользованиеИнтеграция.ЗавершитьСеанс(ОписаниеПодключения);
	
	Возврат НастройкиПриложения;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция ПолучитьНастройкиСовместногоИспользования(НастройкаСсылка, Знач ПараметрыПодключения = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ИдентификаторНастройки = Справочники.НастройкиОтраженияДокументовВБухгалтерии.ИдентификаторНастройки(НастройкаСсылка);
	Если ПараметрыПодключения = Неопределено Тогда
		ПараметрыПодключения = РегистрыСведений.НастройкиИнтеграцииСБухгалтерией.ПолучитьПараметрыПодключения(НастройкаСсылка);
	КонецЕсли;
	ОписаниеПодключения = СовместноеИспользованиеИнтеграция.НовоеПодключениеКСервису(ПараметрыПодключения);
	УстановитьПривилегированныйРежим(Ложь);
	
	Настройки = СовместноеИспользованиеИнтеграция.ПолучитьНастройкиСовместногоИспользования(ОписаниеПодключения, ИдентификаторНастройки);
	
	СовместноеИспользованиеИнтеграция.ЗавершитьСеанс(ОписаниеПодключения);
	
	Возврат Настройки;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция ВыполнитьНачальнуюНастройкуОрганизаций(МассивОрганизаций, ПараметрыПодключения) Экспорт
	
	Результат = Новый Соответствие;
	
	УстановитьПривилегированныйРежим(Истина);
	ОписаниеПодключения = СовместноеИспользованиеИнтеграция.НовоеПодключениеКСервису(ПараметрыПодключения, 300);
	УстановитьПривилегированныйРежим(Ложь);
	
	Для Каждого Организация Из МассивОрганизаций Цикл
		РезультатСозданияОрганизации = Новый Структура;
		РезультатСозданияОрганизации.Вставить("Отказ", Ложь);
		РезультатСозданияОрганизации.Вставить("Идентификатор", "");
		РезультатСозданияОрганизации.Вставить("ОшибкиПроверкиЗаполнения", Неопределено);
		
		ОшибкиПроверкиЗаполнения = Неопределено;
		
		ДанныеЗапроса = Новый Структура;
		ДанныеЗапроса.Вставить("entity", ПолучитьОписаниеОрганизации(Организация, ОшибкиПроверкиЗаполнения));
		
		Если ОшибкиПроверкиЗаполнения.Количество() > 0 Тогда
			РезультатСозданияОрганизации.Отказ = Истина;
			РезультатСозданияОрганизации.ОшибкиПроверкиЗаполнения = ОшибкиПроверкиЗаполнения;
		Иначе
			РезультатНастройки = СовместноеИспользованиеИнтеграция.НастроитьОрганизацию(ОписаниеПодключения, ДанныеЗапроса);
			Если РезультатНастройки = Неопределено Тогда
				РезультатСозданияОрганизации.Отказ = Истина;
			Иначе
				РезультатСозданияОрганизации.Идентификатор = РезультатНастройки.Получить("uuid");
			КонецЕсли;
		КонецЕсли;
		
		Результат.Вставить(Организация, РезультатСозданияОрганизации);
	КонецЦикла;
	
	СовместноеИспользованиеИнтеграция.ЗавершитьСеанс(ОписаниеПодключения);
	
	Возврат Результат;
	
КонецФункции

#Область ПодсистемаОбменДанными

// Для выполнения в Фоновом задании.
//
Функция НастройкиПодключенияКПриложениюВСервисе(НомерОбласти) Экспорт
	
	МодульПомощника = ОбменДаннымиСервер.МодульПомощникНастройкиСинхронизацииДанныхМеждуПриложениямиВИнтернете();
	
	Настройки = Новый Структура;
	Настройки.Вставить("Режим", "НеНастроенныеОбмены");
	Настройки.Вставить("ИмяПланаОбмена", ИмяПланаОбмена());
	Настройки.Вставить("ФорматОбмена", ФорматОбмена());
	Настройки.Вставить("ИдентификаторНастройки", ВариантНастройкиОбмена());
	
	СтатусЗавершения = Неопределено;
	
	ПараметрыОбработчика = Неопределено;
	ПродолжитьОжидание = Ложь;
	
	МодульПомощника.ПриНачалеПолученияСпискаПриложений(Настройки, ПараметрыОбработчика, ПродолжитьОжидание);
	
	Пока ПродолжитьОжидание Цикл
		ОбменДаннымиСервер.Пауза(1);
		МодульПомощника.ПриОжиданииПолученияСпискаПриложений(ПараметрыОбработчика, ПродолжитьОжидание);
	КонецЦикла;
	
	МодульПомощника.ПриЗавершенииПолученияСпискаПриложений(ПараметрыОбработчика, СтатусЗавершения);
	
	Если СтатусЗавершения.Отказ Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТаблицаПриложений = СтатусЗавершения.Результат;
	
	НайденныеСтроки = ТаблицаПриложений.НайтиСтроки(Новый Структура("ОбластьДанных", НомерОбласти));
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	
	Для Каждого Колонка Из ТаблицаПриложений.Колонки Цикл
		Результат.Вставить(Колонка.Имя, НайденныеСтроки[0][Колонка.Имя]);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция ПроверитьПодключениеККорреспонденту(ПараметрыПодключения) Экспорт
	
	НастройкиПодключения = ТранспортСообщенийОбменаКлиентСервер.СтруктураНастроекПодключения();
	
	НастройкиПодключения.ВариантРаботыМастера = "НоваяСинхронизация";
	НастройкиПодключения.ИдентификаторНастройки = ВариантНастройкиОбмена();
	НастройкиПодключения.ИмяПланаОбмена = ИмяПланаОбмена();
	НастройкиПодключения.ИмяПланаОбменаКорреспондента = ИмяПланаОбмена();
	НастройкиПодключения.ФорматОбмена = ФорматОбмена();
	
	НастройкиПодключения.ИдентификаторТранспорта = "WS";
	
	НастройкиПодключения.НастройкиТранспорта.Вставить("АдресВебСервиса", ПараметрыПодключения.АдресПриложения);
	НастройкиПодключения.НастройкиТранспорта.Вставить("ИмяПользователя", ПараметрыПодключения.ИмяПользователя);
	
	ПарольВХранилище = "";		
	Если Не ПустаяСтрока(ПараметрыПодключения.Пароль) Тогда
		УстановитьПривилегированныйРежим(Истина);
		ПарольВХранилище = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(ПараметрыПодключения.Пароль);
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	НастройкиПодключения.ДанныеАутентификации.Вставить("Пароль", ПарольВХранилище);
	
	Префикс = ПолучитьФункциональнуюОпцию("ПрефиксИнформационнойБазы");
	Если ПустаяСтрока(Префикс) Тогда
		ОбменДаннымиПереопределяемый.ПриОпределенииПрефиксаИнформационнойБазыПоУмолчанию(Префикс);
	КонецЕсли;
	
	НастройкиПодключения.ИдентификаторИнформационнойБазыИсточника = ОбменДаннымиСервер.КодПредопределенногоУзлаПланаОбмена(ИмяПланаОбмена());
	НастройкиПодключения.ПрефиксИнформационнойБазыИсточника = Префикс;
	НастройкиПодключения.НаименованиеЭтойБазы = РаботаВМоделиСервиса.ПолучитьИмяПриложения();
	
	МодульПомощника = ОбменДаннымиСервер.МодульПомощникСозданияОбменаДанными();
	
	НастройкиКорреспондента = МодульПомощника.ПолучениеПараметровКорреспондента(НастройкиПодключения);
	
	Возврат Новый Структура("ВнешняяУчетнаяСистема,НастройкиКорреспондента,ПараметрыПодключения", Истина, НастройкиКорреспондента, ПараметрыПодключения);
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция СохранитьНастройкиПодключения(СтруктураНастроек) Экспорт
	
	НастройкиКорреспондента = СтруктураНастроек.НастройкиКорреспондента;
	ПараметрыПодключения = СтруктураНастроек.ПараметрыПодключения;
	
	ПроверкаПодключенияВыполнена = НастройкиКорреспондента.ПодключениеУстановлено
		И НастройкиКорреспондента.ПодключениеРазрешено;
		
	Если Не ПроверкаПодключенияВыполнена Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МодульПомощника = ОбменДаннымиСервер.МодульПомощникСозданияОбменаДанными();
	
	НастройкиПодключения = Неопределено;
	Если СтруктураНастроек.ВнешняяУчетнаяСистема Тогда
		НастройкиПодключения = СтруктураПараметровСозданияПодключения(НастройкиКорреспондента.ПараметрыКорреспондента, ПараметрыПодключения);
	Иначе
		НастройкиПодключения = СтруктураПараметровСозданияПодключенияВСервисе(НастройкиКорреспондента.ПараметрыКорреспондента, ПараметрыПодключения);
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(НастройкиПодключения, НастройкиКорреспондента, "УзелКорреспондентаЕстьВЭтойБазе,ЭтотУзелЕстьВКорреспонденте");
	НастройкиПодключения.ИсправитьДублированиеНастроекСинхронизации = Ложь;
	
	Возврат МодульПомощника.СохранитьНастройкиПодключения(НастройкиПодключения);
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция УстановитьНастройкиОтраженияВБухгалтерии(НастройкаСсылка, ЗначениеОтражениеВключено, СвойстваУзлаОбмена, ПараметрыПодключения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ОписаниеНастройки = Справочники.НастройкиОтраженияДокументовВБухгалтерии.ОписаниеНастройки(НастройкаСсылка);
	ОписаниеНастройки.ОтражениеВключено = ЗначениеОтражениеВключено;
	
	ОписаниеПодключения = СовместноеИспользованиеИнтеграция.НовоеПодключениеКСервису(ПараметрыПодключения);
	УстановитьПривилегированныйРежим(Ложь);
	
	Результат = СовместноеИспользованиеИнтеграция.УстановитьНастройкиСовместногоИспользования(ОписаниеПодключения, ОписаниеНастройки, СвойстваУзлаОбмена);
	
	СовместноеИспользованиеИнтеграция.ЗавершитьСеанс(ОписаниеПодключения);
	
	Возврат Результат;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция ВыполнитьВыгрузкуЗарегистрированныхДанныхДляСопоставления(НастройкаОтражения, ВнешняяУчетнаяСистема) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ДанныеВыгружены",   Истина);
	Результат.Вставить("СообщениеОбОшибке", "");
	
	ПериодПроверки = 15; // в секундах
	ДлительностьОжидания = 60 * 60; // в секундах
	
	КоличествоПроверок = Цел(ДлительностьОжидания / ПериодПроверки) + 1;
	
	ОбменЗапланирован = Неопределено;
	Пока КоличествоПроверок > 0 Цикл
		ОбменЗапланирован = СинхронизацияДанныхЗапланирована(НастройкаОтражения, ВнешняяУчетнаяСистема);
		Если Не ОбменЗапланирован Тогда
			Прервать;
		КонецЕсли;
		КоличествоПроверок = КоличествоПроверок - 1;
		ОбменДаннымиСервер.Пауза(ПериодПроверки);
	КонецЦикла;
	
	Если ОбменЗапланирован = Истина Тогда
		Результат.ДанныеВыгружены = Ложь;
		Результат.СообщениеОбОшибке = НСтр("ru = 'Истекло время ожидания начала отправки данных для сопоставления.'");
		Возврат Результат;
	КонецЕсли;
	
	УзелОбмена = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаОтражения, "УзелОбмена");
	
	ПараметрыОбмена = ОбменДаннымиСервер.ПараметрыОбмена();
	ПараметрыОбмена.ИдентификаторТранспорта = ?(ВнешняяУчетнаяСистема, "WS", "SM");
	ПараметрыОбмена.ДлительнаяОперация = Истина;
	ПараметрыОбмена.ДлительнаяОперацияРазрешена = Истина;
	ПараметрыОбмена.ВыполнятьЗагрузку = Ложь;
	ПараметрыОбмена.ВыполнятьВыгрузку = Истина;
	ПараметрыОбмена.ИнтервалОжиданияНаСервере = 15;
	ПараметрыОбмена.СообщениеДляСопоставленияДанных = Истина;
	
	Отказ = Ложь;
	Попытка
		ОбменДаннымиСервер.ВыполнитьОбменДаннымиДляУзлаИнформационнойБазы(УзелОбмена, ПараметрыОбмена, Отказ);
	Исключение
		Результат.ДанныеВыгружены = Ложь;
		Результат.СообщениеОбОшибке = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
		ЗаписьЖурналаРегистрации(ОбменДаннымиСервер.СобытиеЖурналаРегистрацииВыгрузкаДанныхДляСопоставления(),
			УровеньЖурналаРегистрации.Ошибка, , , Результат.СообщениеОбОшибке);
	КонецПопытки;
		
	Результат.ДанныеВыгружены = Результат.ДанныеВыгружены И Не Отказ;
	
	Если Не Результат.ДанныеВыгружены
		И ПустаяСтрока(Результат.СообщениеОбОшибке) Тогда
		Результат.СообщениеОбОшибке = НСтр("ru = 'При выполнении выгрузки данных для сопоставления возникли ошибки (см. Журнал регистрации).'");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Процедура ВыполнитьСценарийСинхронизацииДанных(НастройкаОтражения, ВнешняяУчетнаяСистема) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Если ВнешняяУчетнаяСистема Тогда
		Отказ = Ложь;
		ВыполнитьСценарийСинхронизацииДанныхСВнешнейУчетнойСистемой(НастройкаОтражения, Отказ);
	Иначе
		УзелОбмена = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаОтражения, "УзелОбмена");
		ОписаниеСценария = ОсновнойСценарийСинхронизации(УзелОбмена);
		
		Если ОписаниеСценария <> Неопределено
			И Не ОписаниеСценария.ОтключенАвтоматически Тогда
			КодСценария = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОписаниеСценария.Ссылка, "Код");
			ОбменДаннымиВнутренняяПубликация.ВыполнитьОбменДаннымиПоСценарию(КодСценария);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция СинхронизацияДанныхЗапланирована(НастройкаОтражения, ВнешняяУчетнаяСистема) Экспорт
	
	Результат = Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ВнешняяУчетнаяСистема Тогда
		СвойстваНастройки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			НастройкаОтражения, "ДатаНачалаПоследнегоОбменаУниверсальная,ДатаЗавершенияПоследнегоОбменаУниверсальная,ОбменПриостановлен");
		Если Не СвойстваНастройки.ОбменПриостановлен Тогда
			Результат = (СвойстваНастройки.ДатаНачалаПоследнегоОбменаУниверсальная > СвойстваНастройки.ДатаЗавершенияПоследнегоОбменаУниверсальная);
		КонецЕсли;
	Иначе
		УзелОбмена = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаОтражения, "УзелОбмена");
	    Результат = ОбменДаннымиВнутренняяПубликация.ПоУзлуЗапланированОбмен(УзелОбмена);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ВыполнитьСценарийСинхронизацииДанныхСВнешнейУчетнойСистемой(НастройкаОтражения, Отказ) Экспорт
	
	ОбменПриостановлен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаОтражения, "ОбменПриостановлен");
	Если ОбменПриостановлен Тогда
		Возврат;
	КонецЕсли;
	
	НастройкаОбъект = НастройкаОтражения.ПолучитьОбъект();
	НастройкаОбъект.ДатаНачалаПоследнегоОбменаУниверсальная = ТекущаяУниверсальнаяДата();
	НастройкаОбъект.Записать();
	
	Попытка
		УзелОбмена = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаОтражения, "УзелОбмена");
		
		ПараметрыОбмена = ОбменДаннымиСервер.ПараметрыОбмена();
		ПараметрыОбмена.ИдентификаторТранспорта = "WS";
		ПараметрыОбмена.ДлительнаяОперация = Истина;
		ПараметрыОбмена.ДлительнаяОперацияРазрешена = Истина;
		ПараметрыОбмена.ВыполнятьЗагрузку = Истина;
		ПараметрыОбмена.ВыполнятьВыгрузку = Истина;
		ПараметрыОбмена.ИнтервалОжиданияНаСервере = 15;
		
		ОбменДаннымиСервер.ВыполнитьОбменДаннымиДляУзлаИнформационнойБазы(УзелОбмена, ПараметрыОбмена, Отказ);
		
		Если Не Отказ Тогда
			ПараметрыОбмена.ВыполнятьВыгрузку = Ложь;
			// Получение квитанции о получении данных.
			ОбменДаннымиСервер.ВыполнитьОбменДаннымиДляУзлаИнформационнойБазы(УзелОбмена, ПараметрыОбмена, Отказ);
		КонецЕсли;
	Исключение
		Отказ = Истина;
		Инфо = ИнформацияОбОшибке();
		
		ЗаписьЖурналаРегистрации(
			СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ПодробноеПредставлениеОшибки(Инфо));
	КонецПопытки;
	
	НастройкаОбъект = НастройкаОтражения.ПолучитьОбъект();
	НастройкаОбъект.ДатаЗавершенияПоследнегоОбменаУниверсальная = ТекущаяУниверсальнаяДата();
	Если Отказ Тогда
		НастройкаОбъект.КоличествоНеудачныхОбменов = НастройкаОбъект.КоличествоНеудачныхОбменов + 1;
		НастройкаОбъект.ОбменПриостановлен = (НастройкаОбъект.КоличествоНеудачныхОбменов >= 3);
	Иначе
		НастройкаОбъект.КоличествоНеудачныхОбменов = 0;
		НастройкаОбъект.ОбменПриостановлен = Ложь;
	КонецЕсли;
	НастройкаОбъект.Записать();
	
КонецПроцедуры

Функция ОсновнойСценарийСинхронизации(УзелОбмена) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СценарииОбменовДанными.Ссылка КАК Ссылка,
	|	СценарииОбменовДанными.ИспользоватьРегламентноеЗадание КАК ИспользоватьРегламентноеЗадание,
	|	СценарииОбменовДанными.ОтключенАвтоматически КАК ОтключенАвтоматически
	|ИЗ
	|	Справочник.СценарииОбменовДанными КАК СценарииОбменовДанными
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СценарииОбменовДанными.НастройкиОбмена КАК СценарииОбменовДаннымиНастройкиОбмена1
	|		ПО (СценарииОбменовДаннымиНастройкиОбмена1.Ссылка = СценарииОбменовДанными.Ссылка)
	|			И (СценарииОбменовДаннымиНастройкиОбмена1.УзелИнформационнойБазы = &УзелОбмена)
	|			И (СценарииОбменовДаннымиНастройкиОбмена1.НомерСтроки = 1)
	|			И (СценарииОбменовДаннымиНастройкиОбмена1.ВыполняемоеДействие = ЗНАЧЕНИЕ(Перечисление.ДействияПриОбмене.ВыгрузкаДанных))
	|			И ((ВЫРАЗИТЬ(СценарииОбменовДаннымиНастройкиОбмена1.ИдентификаторТранспорта КАК СТРОКА(100))) = &ИдентификаторТранспорта)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СценарииОбменовДанными.НастройкиОбмена КАК СценарииОбменовДаннымиНастройкиОбмена2
	|		ПО (СценарииОбменовДаннымиНастройкиОбмена2.Ссылка = СценарииОбменовДанными.Ссылка)
	|			И (СценарииОбменовДаннымиНастройкиОбмена2.УзелИнформационнойБазы = &УзелОбмена)
	|			И (СценарииОбменовДаннымиНастройкиОбмена2.НомерСтроки = 2)
	|			И (СценарииОбменовДаннымиНастройкиОбмена2.ВыполняемоеДействие = ЗНАЧЕНИЕ(Перечисление.ДействияПриОбмене.ЗагрузкаДанных))
	|			И ((ВЫРАЗИТЬ(СценарииОбменовДаннымиНастройкиОбмена2.ИдентификаторТранспорта КАК СТРОКА(100))) = &ИдентификаторТранспорта)
	|ГДЕ
	|	НЕ СценарииОбменовДанными.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка");
	
	Запрос.УстановитьПараметр("УзелОбмена", УзелОбмена);
	Запрос.УстановитьПараметр("ИдентификаторТранспорта", "SM");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Новый Структура("Ссылка,ИспользоватьРегламентноеЗадание,ОтключенАвтоматически");
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		
		Возврат Результат;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Для выполнения в Фоновом задании.
//
Функция ПроверитьПодключениеККорреспондентуВСервисе(НастройкиПодключенияВСервисе) Экспорт
	
	НастройкиПодключения = ТранспортСообщенийОбменаКлиентСервер.СтруктураНастроекПодключения();
	
	НастройкиПодключения.ВариантРаботыМастера = "НоваяСинхронизация";
	НастройкиПодключения.ИдентификаторНастройки = ВариантНастройкиОбмена();
	НастройкиПодключения.ИмяПланаОбмена = ИмяПланаОбмена();
	НастройкиПодключения.ИмяПланаОбменаКорреспондента = ИмяПланаОбмена();
	НастройкиПодключения.ФорматОбмена = ФорматОбмена();
	
	НастройкиПодключения.ИдентификаторТранспорта = "SM";
	
	НастройкиПодключения.НастройкиТранспорта.Вставить("ВнутренняяПубликация", (НастройкиПодключенияВСервисе.ДоступенExchangeAdministrationManage_3_0_1_1 = Истина));
	НастройкиПодключения.НастройкиТранспорта.Вставить("КонечнаяТочка", НастройкиПодключенияВСервисе.КонечнаяТочка);
	НастройкиПодключения.НастройкиТранспорта.Вставить("КонечнаяТочкаКорреспондента", НастройкиПодключенияВСервисе.КонечнаяТочкаКорреспондента);
	НастройкиПодключения.НастройкиТранспорта.Вставить("НаименованиеКорреспондента", НастройкиПодключенияВСервисе.НаименованиеПриложения);
	НастройкиПодключения.НастройкиТранспорта.Вставить("ОбластьДанныхКорреспондента", НастройкиПодключенияВСервисе.ОбластьДанных);
	
	Префикс = ПолучитьФункциональнуюОпцию("ПрефиксИнформационнойБазы");
	Если ПустаяСтрока(Префикс) Тогда
		ОбменДаннымиПереопределяемый.ПриОпределенииПрефиксаИнформационнойБазыПоУмолчанию(Префикс);
	КонецЕсли;
	
	НастройкиПодключения.ИдентификаторИнформационнойБазыИсточника = ОбменДаннымиСервер.КодПредопределенногоУзлаПланаОбмена(ИмяПланаОбмена());
	НастройкиПодключения.ПрефиксИнформационнойБазыИсточника = Префикс;
	НастройкиПодключения.НаименованиеЭтойБазы = РаботаВМоделиСервиса.ПолучитьИмяПриложения();
	
	МодульПомощника = ОбменДаннымиСервер.МодульПомощникСозданияОбменаДанными();
	
	НастройкиКорреспондента = МодульПомощника.ПолучениеПараметровКорреспондента(НастройкиПодключения);
	
	Возврат Новый Структура("ВнешняяУчетнаяСистема,НастройкиКорреспондента,ПараметрыПодключения", Ложь, НастройкиКорреспондента, НастройкиПодключенияВСервисе);
	
КонецФункции

