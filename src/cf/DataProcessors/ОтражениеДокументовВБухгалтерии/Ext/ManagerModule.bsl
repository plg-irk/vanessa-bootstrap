Функция ПолучитьОписаниеОрганизации(Организация, ОшибкиПроверкиЗаполнения = Неопределено) Экспорт
	
	ОшибкиПроверкиЗаполнения = Новый Массив;
	
	ОписаниеОрганизации = Новый Структура;
	ОписаниеОрганизации.Вставить("guid", XMLСтрока(Организация));
	
	РеквизитыОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		Организация,
		"ЮридическоеФизическоеЛицо,НаименованиеСокращенное,НаименованиеПолное,Наименование,Префикс,ИНН,КПП,ФизическоеЛицо,ИПИспользуетТрудНаемныхРаботников");
		
	Если РеквизитыОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда
		СвойстваЮрЛица = Новый Структура;
		СвойстваЮрЛица.Вставить("inn", РеквизитыОрганизации.ИНН);
		СвойстваЮрЛица.Вставить("kpp", РеквизитыОрганизации.КПП);
		
		ОписаниеОрганизации.Вставить("organization", СвойстваЮрЛица);
		
		Если ПустаяСтрока(РеквизитыОрганизации.ИНН) И ПустаяСтрока(РеквизитыОрганизации.КПП) Тогда
			ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'не заполнены ИНН и КПП'"));
		Иначе
			Если ПустаяСтрока(РеквизитыОрганизации.ИНН) Тогда
				ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'не заполнен ИНН'"));
			ИначеЕсли СтрДлина(РеквизитыОрганизации.ИНН) <> 10 Тогда
				ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'ИНН юридического лица должен состоять из 10 символов'"));
			КонецЕсли;
			Если ПустаяСтрока(РеквизитыОрганизации.КПП) Тогда
				ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'не заполнен КПП'"));
			ИначеЕсли СтрДлина(РеквизитыОрганизации.КПП) <> 9 Тогда
				ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'КПП должен состоять из 9 символов'"));
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли РеквизитыОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		Если ПустаяСтрока(РеквизитыОрганизации.ИНН) Тогда
			ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'не заполнен ИНН'"));
		ИначеЕсли СтрДлина(РеквизитыОрганизации.ИНН) <> 12 Тогда
			ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'ИНН физического лица должен состоять из 12 символов'"));
		КонецЕсли;
		
		СвойстваФизЛица = Новый Структура;
		СвойстваФизЛица.Вставить("inn", РеквизитыОрганизации.ИНН);
		
		ЗаписиФИО = РегистрыСведений.ФИОФизическихЛиц.СрезПоследних(, Новый Структура("ФизическоеЛицо", РеквизитыОрганизации.ФизическоеЛицо));
		Если ЗаписиФИО.Количество() > 0 Тогда
			ЗаписьФИО = ЗаписиФИО[0];
			
			ФИОФизЛица = Новый Структура;
			ФИОФизЛица.Вставить("second_name", ЗаписьФИО.Фамилия);
			ФИОФизЛица.Вставить("first_name", ЗаписьФИО.Имя);
			ФИОФизЛица.Вставить("patronymic", ЗаписьФИО.Отчество);
			
			СвойстваФизЛица.Вставить("name", ФИОФизЛица);
		Иначе
			ОшибкиПроверкиЗаполнения.Добавить(НСтр("ru = 'не заполнены ФИО физического лица'"));
		КонецЕсли;
		
		СвойстваФизЛица.Вставить("have_staff", РеквизитыОрганизации.ИПИспользуетТрудНаемныхРаботников);
		
		ОписаниеОрганизации.Вставить("entrepreneur", СвойстваФизЛица);
	Иначе
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Ошибка при получении ОПФ организации %1'"),
					Организация);
	КонецЕсли;
	
	ОписаниеОрганизации.Вставить("short_name", РеквизитыОрганизации.НаименованиеСокращенное);
	ОписаниеОрганизации.Вставить("full_name", РеквизитыОрганизации.НаименованиеПолное);
	ОписаниеОрганизации.Вставить("nickname", РеквизитыОрганизации.Наименование);
	
	Если ПустаяСтрока(ОписаниеОрганизации.full_name) Тогда
		Если ПустаяСтрока(ОписаниеОрганизации.short_name) Тогда
			ОписаниеОрганизации.full_name = ОписаниеОрганизации.nickname;
		Иначе
			ОписаниеОрганизации.full_name = ОписаниеОрганизации.short_name;
		КонецЕсли;
	КонецЕсли;
	Если ПустаяСтрока(ОписаниеОрганизации.short_name) Тогда
		ОписаниеОрганизации.short_name = ОписаниеОрганизации.full_name;
	КонецЕсли;
	
	ОписаниеОрганизации.Вставить("number_prefix", РеквизитыОрганизации.Префикс);
	ОписаниеОрганизации.Вставить("business_type", "wholesale");
	
	КонтактнаяИнформацияОрганизации = Новый Структура;
	
	ОтборКИ = УправлениеКонтактнойИнформацией.ОтборКонтактнойИнформации();
	ОтборКИ.Дата = ТекущаяДатаСеанса();
	ОтборКИ.ВидыКонтактнойИнформации.Добавить(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации);
	ОтборКИ.ВидыКонтактнойИнформации.Добавить(Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации);
	ОтборКИ.ВидыКонтактнойИнформации.Добавить(Справочники.ВидыКонтактнойИнформации.ПочтовыйАдресОрганизации);
	ОтборКИ.ВидыКонтактнойИнформации.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации);
	ОтборКИ.ВидыКонтактнойИнформации.Добавить(Справочники.ВидыКонтактнойИнформации.EmailОрганизации);
	
	ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформация(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Организация), ОтборКИ);
	Для Каждого СтрокаКИ Из ТаблицаКИ Цикл
		Если СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации Тогда
			КонтактнаяИнформацияОрганизации.Вставить("legal_address", СтрокаКИ.Значение);
		ИначеЕсли СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации Тогда
			КонтактнаяИнформацияОрганизации.Вставить("actual_address", СтрокаКИ.Значение);
		ИначеЕсли СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ПочтовыйАдресОрганизации Тогда
			КонтактнаяИнформацияОрганизации.Вставить("post_address", СтрокаКИ.Значение);
		ИначеЕсли СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации Тогда
			КонтактнаяИнформацияОрганизации.Вставить("phone", СтрокаКИ.Значение);
		ИначеЕсли СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.EmailОрганизации Тогда
			КонтактнаяИнформацияОрганизации.Вставить("email", СтрокаКИ.Значение);
		КонецЕсли;
	КонецЦикла;
	
	ОписаниеОрганизации.Вставить("contact_info", КонтактнаяИнформацияОрганизации);
	
	ТаблицаСНО = РегистрыСведений.СистемыНалогообложенияОрганизаций.СрезПоследних(ТекущаяДатаСеанса(), Новый Структура("Организация", Организация));
	
	Если ТаблицаСНО.Количество() > 0 Тогда
		УчетнаяПолитикаОрганизации = ТаблицаСНО[0];
		
		СистемаНалогообложенияСтрокой = "";
	
		Если УчетнаяПолитикаОрганизации.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
			Если УчетнаяПолитикаОрганизации.ОбъектНалогообложения = Перечисления.ВидыОбъектовНалогообложения.Доходы Тогда
				СистемаНалогообложенияСтрокой = "УпрощеннаяДоходы";
			Иначе
				СистемаНалогообложенияСтрокой = "УпрощеннаяДоходыМинусРасходы";
			КонецЕсли;
		ИначеЕсли УчетнаяПолитикаОрганизации.СистемаНалогообложения = Перечисления.СистемыНалогообложения.АУСН Тогда
			Если УчетнаяПолитикаОрганизации.ОбъектНалогообложения = Перечисления.ВидыОбъектовНалогообложения.Доходы Тогда
				СистемаНалогообложенияСтрокой = "АУСНДоходы";
			Иначе
				СистемаНалогообложенияСтрокой = "АУСНДоходыМинусРасходы";
			КонецЕсли;
		ИначеЕсли УчетнаяПолитикаОрганизации.СистемаНалогообложения = Перечисления.СистемыНалогообложения.ОсобыйПорядок Тогда
			СистемаНалогообложенияСтрокой = "Патентная";
		ИначеЕсли УчетнаяПолитикаОрганизации.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Общая Тогда
			СистемаНалогообложенияСтрокой = "Общая";
		КонецЕсли;
		
		СтруктураУчетнойПолитики = Новый Структура;
		Если УчетнаяПолитикаОрганизации.Период <> Неопределено Тогда
			СтруктураУчетнойПолитики.Вставить("period", УчетнаяПолитикаОрганизации.Период);
		КонецЕсли;
		Если Не ПустаяСтрока(СистемаНалогообложенияСтрокой) Тогда
			СтруктураУчетнойПолитики.Вставить("tax_system", СистемаНалогообложенияСтрокой);
		КонецЕсли;
		Если УчетнаяПолитикаОрганизации.ПрименяетсяПатент <> Неопределено Тогда
			СтруктураУчетнойПолитики.Вставить("patent", УчетнаяПолитикаОрганизации.ПрименяетсяПатент);
		КонецЕсли;
		Если УчетнаяПолитикаОрганизации.ПлательщикТорговыйСбор <> Неопределено Тогда
			СтруктураУчетнойПолитики.Вставить("sales_tax", УчетнаяПолитикаОрганизации.ПлательщикТорговыйСбор);
		КонецЕсли;
		
		ОписаниеОрганизации.Вставить("accounting_policy", СтруктураУчетнойПолитики);
	КонецЕсли;
	
	Возврат ОписаниеОрганизации;
	
КонецФункции

Процедура ЗафиксироватьВыгрузкуОрганизации(Организация, ИдентификаторОрганизации, УзелОбмена) Экспорт
	
	РегистрыСведений.ДанныеОбъектовДляРегистрацииВОбменах.ДобавитьОбъектВФильтрРазрешенныхОбъектов(Организация, УзелОбмена);
		
	СтруктураЗаписиРПИ = Новый Структура;
	СтруктураЗаписиРПИ.Вставить("Идентификатор", ИдентификаторОрганизации);
	СтруктураЗаписиРПИ.Вставить("Ссылка", Организация);
	СтруктураЗаписиРПИ.Вставить("УзелИнформационнойБазы", УзелОбмена);
	
	РегистрыСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов.ДобавитьЗапись(СтруктураЗаписиРПИ);
	
КонецПроцедуры

#Область ПодсистемаОбменДанными

Функция СтруктураПараметровСозданияПодключенияВСервисе(ПараметрыКорреспондента, НастройкиПодключенияВСервисе)
	
	ИдентификаторИнформационнойБазыИсточника = ОбменДаннымиСервер.КодПредопределенногоУзлаПланаОбмена(ИмяПланаОбмена());
	ИдентификаторИнформационнойБазыПриемника = ПараметрыКорреспондента.КодЭтогоУзла;
	
	Префикс = ПолучитьФункциональнуюОпцию("ПрефиксИнформационнойБазы");
	Если ПустаяСтрока(Префикс) Тогда
		ОбменДаннымиПереопределяемый.ПриОпределенииПрефиксаИнформационнойБазыПоУмолчанию(Префикс);
	КонецЕсли;
	
	ПрефиксКорреспондента = ПараметрыКорреспондента.ПрефиксИнформационнойБазы;
	Если ПустаяСтрока(ПрефиксКорреспондента) Тогда
		ПрефиксКорреспондента = ПараметрыКорреспондента.ПрефиксИнформационнойБазыПоУмолчанию;
	КонецЕсли;
	
	ВерсияФорматаОбмена = ОбменДаннымиXDTOСервер.МаксимальнаяОбщаяВерсияФормата(
		ИмяПланаОбмена(),
		ПараметрыКорреспондента.ВерсииФорматаОбмена);
	
	ПоддерживаемыеОбъектыФорматаКорреспондента = Новый ХранилищеЗначения(ПараметрыКорреспондента.ПоддерживаемыеОбъектыФормата, Новый СжатиеДанных(9));
	
	СтруктураНастроекПомощника = ТранспортСообщенийОбменаКлиентСервер.СтруктураНастроекПодключения();
	
	СтруктураНастроекПомощника.ВариантРаботыМастера = "НоваяСинхронизация";
	СтруктураНастроекПомощника.ИдентификаторНастройки = ВариантНастройкиОбмена();
	СтруктураНастроекПомощника.ВариантНастройкиОбмена = ВариантНастройкиОбмена();
	СтруктураНастроекПомощника.ИмяПланаОбмена = ИмяПланаОбмена();
	СтруктураНастроекПомощника.ИмяПланаОбменаКорреспондента = ИмяПланаОбмена();
	СтруктураНастроекПомощника.ФорматОбмена = ФорматОбмена();
	
	СтруктураНастроекПомощника.ИдентификаторТранспорта = "SM";
	
	СтруктураНастроекПомощника.НастройкиТранспорта.Вставить("ВнутренняяПубликация", (НастройкиПодключенияВСервисе.ДоступенExchangeAdministrationManage_3_0_1_1 = Истина));
	СтруктураНастроекПомощника.НастройкиТранспорта.Вставить("КонечнаяТочка", НастройкиПодключенияВСервисе.КонечнаяТочка);
	СтруктураНастроекПомощника.НастройкиТранспорта.Вставить("КонечнаяТочкаКорреспондента", НастройкиПодключенияВСервисе.КонечнаяТочкаКорреспондента);
	СтруктураНастроекПомощника.НастройкиТранспорта.Вставить("НаименованиеКорреспондента", НастройкиПодключенияВСервисе.НаименованиеПриложения);
	СтруктураНастроекПомощника.НастройкиТранспорта.Вставить("ОбластьДанныхКорреспондента", НастройкиПодключенияВСервисе.ОбластьДанных);
	
	СтруктураНастроекПомощника.ИдентификаторИнформационнойБазыИсточника = ИдентификаторИнформационнойБазыИсточника;
	СтруктураНастроекПомощника.ИдентификаторИнформационнойБазыПриемника = ИдентификаторИнформационнойБазыПриемника;
	
	СтруктураНастроекПомощника.ПрефиксИнформационнойБазыИсточника = Префикс;
	СтруктураНастроекПомощника.ПрефиксИнформационнойБазыПриемника = ПрефиксКорреспондента;
	
	СтруктураНастроекПомощника.НаименованиеЭтойБазы = РаботаВМоделиСервиса.ПолучитьИмяПриложения();
	СтруктураНастроекПомощника.НаименованиеВторойБазы = НастройкиПодключенияВСервисе.НаименованиеПриложения;
	
	СтруктураНастроекПомощника.КодУзла = ИдентификаторИнформационнойБазыИсточника;
	СтруктураНастроекПомощника.КодУзлаКорреспондента = ИдентификаторИнформационнойБазыПриемника;
	
	СтруктураНастроекПомощника.КодПредопределенногоУзла = ИдентификаторИнформационнойБазыИсточника;	
	СтруктураНастроекПомощника.КодНовогоУзлаВторойБазы = ИдентификаторИнформационнойБазыПриемника;
	
	СтруктураНастроекПомощника.ВерсияФорматаОбмена = ВерсияФорматаОбмена;
	СтруктураНастроекПомощника.ПоддерживаемыеОбъектыФормата = ПоддерживаемыеОбъектыФорматаКорреспондента;
	
	СтруктураНастроекПомощника.ВерсияФорматаФайлаНастроекОбменаДанными = ПараметрыКорреспондента.ВерсияФорматаНастроекОбменаДанными;
	
	Возврат СтруктураНастроекПомощника;
	
КонецФункции

Функция ИмяПланаОбмена()
	
	Возврат "СинхронизацияДанныхЧерезУниверсальныйФормат";
	
КонецФункции

Функция ВариантНастройкиОбмена()
	
	Возврат "ОбменУНФ_БП3";
	
КонецФункции

Функция ФорматОбмена()
	
	Возврат "http://v8.1c.ru/edi/edi_stnd/EnterpriseData";
	
КонецФункции

