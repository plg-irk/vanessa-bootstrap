Функция СтрокаОтправкиВМессенджер()

	ДобавлятьДату = УстановленРежимПланированияНаКлиенте();
	
	ШаблонСтроки = НСтр("ru='Добрый день. Вам отправлено приглашение на видеовстречу. Адрес подключения: %1'");
	ШаблонСтрокиДата = НСтр("ru='Добрый день. Вам отправлено приглашение на видеовстречу %1 в %2. Адрес подключения: %3'");

	Если ДобавлятьДату Тогда
		СтрокаОтправки = СтрШаблон(ШаблонСтрокиДата, Формат(Объект.ДатаНачала, "ДФ=dd.MM.yyyy"),
			Формат(Объект.ДатаНачала, "ДФ=HH:mm"), Объект.ВнешнийАдресОбсуждения);
	Иначе
		СтрокаОтправки = СтрШаблон(ШаблонСтроки,  Объект.ВнешнийАдресОбсуждения);
	КонецЕсли;

	Возврат СтрокаОтправки;
	
