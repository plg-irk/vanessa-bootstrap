&НаКлиенте
Функция ДатыЗаполненыКорректно()
	
	Результат = Истина;
	
	Если УстановленРежимСозданияНаКлиенте() Тогда
		Возврат Результат;
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru='Дата начала не заполнена.'"), , "ДатаНачалаДата", , Результат);
	ИначеЕсли Не ЗначениеЗаполнено(Объект.ДатаОкончания) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru='Дата окончание не заполнена.'"), , "ДатаОкончанияДата", , Результат);
	ИначеЕсли Объект.ДатаНачала > Объект.ДатаОкончания Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru='Дата начала не может быть больше даты окончания'"), , "ДатаНачалаДата", , Результат);
	Иначе
		Возврат Результат;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ОтправкаПриглашения

&НаКлиенте
Процедура ЗаполнитьУчастниковПоОснованиюЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Или Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Получатели = Результат.Получатели;
	
	ПараметрыОтправки = РаботаСПочтовымиСообщениямиКлиент.ПараметрыОтправкиПисьма();

	ПараметрыОтправки.Получатель 	= Получатели;
	ПараметрыОтправки.Тема			= Объект.Тема;
	ПараметрыОтправки.Текст 		= ТекстПисьмаHTML();
	
	Если УстановленРежимПланированияНаКлиенте() И Не Объект.Ссылка.Пустая() Тогда
		ПараметрыОтправки.Предмет = Объект.Ссылка;
	КонецЕсли;
	
	РаботаСПочтовымиСообщениямиКлиент.СоздатьНовоеПисьмо(ПараметрыОтправки)
	
КонецПроцедуры

&НаКлиенте
Функция ТекстПисьмаHTML()
	
	ДатаВстречи = Формат(Объект.ДатаНачала, "ДФ=dd.MM.yyyy");
	ВремяВстречи = Формат(Объект.ДатаНачала, "ДФ=HH:mm");
	
	ШаблонТекстаПисьмаБезДаты = НСтр("ru='<!DOCTYPE html>
	|<html>
	|<head>
	|<meta http-equiv=""Content-Type"" content=""text/html; charset=utf-8"" />
	|<meta http-equiv=""X-UA-Compatible"" content=""IE=Edge"" />
	|<meta name=""format-detection"" content=""telephone=no"" />
	|</head>
	|<body>
	|<p>Добрый день.</p>
	|<br>
	|<p>Вам отправлено приглашение на видеовстречу.</p>
	|<br>
	|<p>Адрес подключения:</p>
	|<a href=""%1"">%1</a>
	|
	|</body>
	|</html>'");
	
	ШаблонТекстаПисьмаСДатой = НСтр("ru='<!DOCTYPE html>
	|<html>
	|<head>
	|<meta http-equiv=""Content-Type"" content=""text/html; charset=utf-8"" />
	|<meta http-equiv=""X-UA-Compatible"" content=""IE=Edge"" />
	|<meta name=""format-detection"" content=""telephone=no"" />
	|</head>
	|<body>
	|<p>Добрый день.</p>
	|<br>
	|<p>Вам отправлено приглашение на видеовстречу %1 в %2.</p>
	|<br>
	|<p>Адрес подключения:</p>
	|<a href=""%3"">%3</a>
	|
	|</body>
	|</html>'");
	
	Если УстановленРежимПланированияНаКлиенте() Тогда
		ТекстПисьма = СтрШаблон(ШаблонТекстаПисьмаСДатой, ДатаВстречи, ВремяВстречи, Объект.АдресОбсуждения);
	Иначе
		ТекстПисьма = СтрШаблон(ШаблонТекстаПисьмаБезДаты, Объект.АдресОбсуждения);
	КонецЕсли;

	Возврат ТекстПисьма;

КонецФункции

