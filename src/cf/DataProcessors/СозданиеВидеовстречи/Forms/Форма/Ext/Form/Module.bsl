#Область Напоминание

&НаКлиенте
Процедура СобытиеНажатиеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ОбновитьДанныеНапоминанияНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеНапоминанияНаСервере()

	ИмяПоляНапоминатьОСобытии = НапоминанияПользователяКлиентСервер.ИмяПоляНапоминатьОСобытии();
	ИмяПоляИнтервалВремениНапоминания = НапоминанияПользователяКлиентСервер.ИмяПоляИнтервалВремениНапоминания();
	
	НастройкиНапоминания = НапоминанияПользователяКлиентСервер.НастройкиНапоминанияВФорме(ЭтотОбъект);
	Если НастройкиНапоминания = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НапоминанияПоПредмету = НапоминанияПользователя.НайтиНапоминания(Объект.Ссылка);
	Если Не НапоминанияПоПредмету.Количество() Тогда
		
		ЭтотОбъект[ИмяПоляНапоминатьОСобытии] = Ложь;
		
		Если Не НастройкиНапоминания.ДобавлятьФлажок Тогда
			ЭтотОбъект[ИмяПоляИнтервалВремениНапоминания] = НапоминанияПользователяКлиентСервер.ПредставлениеПеречисленияНеНапоминать();
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;

	ДанныеСобытия = Новый Структура("Ссылка", Объект.Ссылка);
	// СтандартныеПодсистемы.НапоминанияПользователя
	НапоминанияПользователя.ПриЧтенииНаСервере(ЭтотОбъект, ДанныеСобытия);
	// Конец СтандартныеПодсистемы.НапоминанияПользователя
	
КонецПроцедуры

&НаСервере
Процедура УстановитьНапоминаниеНаСервере()

	ДанныеСобытия = Новый Структура("Ссылка", Объект.Ссылка);
	
	// СтандартныеПодсистемы.НапоминанияПользователя
	НапоминанияПользователя.ПриЗаписиНаСервере(ЭтотОбъект, Ложь, ДанныеСобытия, Новый Структура);
	// Конец СтандартныеПодсистемы.НапоминанияПользователя
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ПереключитьНаСтраницу(Страница)
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Страница;
	
	Для Каждого СтраницаГруппы Из Элементы.ГруппаСтраницы.ПодчиненныеЭлементы Цикл
		СтраницаГруппы.Видимость = Ложь;
	КонецЦикла;

	Страница.Видимость = Истина;

	Если Страница = Элементы.СтраницаОсновная Тогда
		Элементы.ГруппаКоманды.Видимость = Ложь;
	ИначеЕсли Страница = Элементы.СтраницаПараметры Тогда
		Элементы.ГруппаКоманды.Видимость = Истина;
		Элементы.КоманднаяПанельОбсуждения.Видимость = Ложь;
	ИначеЕсли Страница = Элементы.СтраницаГотово Тогда
		Элементы.КоманднаяПанельОбсуждения.Видимость 				= Истина;
		Элементы.ГруппаИнформацияОКоличествеУчастников.Видимость 	= Ложь;
		Элементы.СкопироватьТекстПриглашенияВБуфер.Видимость 		= СредстваБуфераОбмена.ИспользованиеДоступно();
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ОписаниеВидеовстречи()
	
	ОписаниеВидеовстречи = ВидеовстречиКлиентСервер.ОписаниеВидеовстречи();
	
	Если УстановленРежимПланированияНаКлиенте() Тогда
		
		ОписаниеВидеовстречи.СоздатьСобытие = Истина;
		ОписаниеВидеовстречи.КалендарьСотрудника = КалендарьСотрудника;
		ЗаполнитьЗначенияСвойств(ОписаниеВидеовстречи, Объект, "ДатаНачала, ДатаОкончания");
		
	КонецЕсли;
	
	Если ПустаяСтрока(Объект.Тема) Тогда
		ШаблонТемы = НСтр("ru='Встреча от %1'");
		Объект.Тема = СтрШаблон(ШаблонТемы, Формат(Объект.ДатаНачала, "ДФ=dd.MM.yyyy"));
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ОписаниеВидеовстречи, Объект, "Основание, Содержание, Тема");
	
	Возврат ОписаниеВидеовстречи;
	
КонецФункции

&НаКлиенте
Процедура ОбработатьРезультатСоздания(Результат)
	
	ЗаполнитьЗначенияСвойств(Объект, Результат, "АдресОбсуждения, ВнешнийАдресОбсуждения, ИдентификаторОбсуждения");
	
	Если Результат.СобытиеСоздано Тогда
		Объект.Ссылка = Результат.ДокументСобытия;
	КонецЕсли;
	
	ВстречаСоздана = Результат.ОбсуждениеСоздано;
	
	Элементы.Отменить.Видимость = Ложь;
	Элементы.Подключиться.Видимость = Истина;
	Элементы.Создать.Заголовок = НСтр("ru='Закрыть'");

КонецПроцедуры

&НаКлиенте
Процедура СформироватьТекстПриглашения()
	
	Если УстановленРежимПланированияНаКлиенте() Тогда
		ШаблонПриглашения = НСтр("ru='Добрый день. Вам отправлено приглашение на видеовстречу %1 в %2.
			|
			|Адрес подключения: %3'");
		ТекстПриглашения = СтрШаблон(ШаблонПриглашения, Формат(Объект.ДатаНачала, "ДФ='dd.MM.yyyy'"), 
			Формат(Объект.ДатаНачала, "ДФ='HH:mm'"), Объект.АдресОбсуждения);
	Иначе
		ШаблонПриглашения = НСтр("ru='Добрый день. Вам отправлено приглашение на видеовстречу.
			|
			|Адрес подключения: %1'");
		ТекстПриглашения = СтрШаблон(ШаблонПриглашения, Объект.АдресОбсуждения);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Асинх Процедура ПоместитьВБуферОбмена(Текст)
	
	ПомещаемыеДанные = Новый ЭлементБуфераОбмена(СтандартныйФорматДанныхБуфераОбмена.Текст, Текст);
	Результат = Ждать СредстваБуфераОбмена.ПоместитьДанныеАсинх(ПомещаемыеДанные);

	Если Результат Тогда
		ПоказатьОповещениеПользователя(НСтр("ru='Приглашение'"), , НСтр("ru='Текст приглашения скопирован.'"), БиблиотекаКартинок.Информация32);
	Иначе
		ПоказатьОповещениеПользователя(НСтр("ru='Приглашение'"), , НСтр("ru='Не удалось скопировать текст приглашения.'"), БиблиотекаКартинок.Ошибка32);
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти