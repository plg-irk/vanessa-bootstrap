
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не Параметры.Свойство("Основание") Тогда
		ВызватьИсключение НСтр("ru='Недопустимый вызов формы.'");
	КонецЕсли;
	
	Объект.Основание = Параметры.Основание;
	
	ПроверитьДоступностьОбсужденийНаСервере();
	
	ИспользуетсяРаботаССобытиями = ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуCRM")
		И ЭлектроннаяПочтаУНФ.ИспользуетсяРаботаССобытиями() И ПравоДоступа("Добавление", Метаданные.Документы.Событие);
		
	Элементы.ГруппаЗапланировать.Видимость = ИспользуетсяРаботаССобытиями;
	
	Если ИспользуетсяРаботаССобытиями Тогда
		
		// СтандартныеПодсистемы.НапоминанияПользователя
		ПараметрыРазмещения = НапоминанияПользователя.ПараметрыРазмещения();
		ПараметрыРазмещения.Группа = Элементы.ГруппаПараметрыНапоминания;
		ПараметрыРазмещения.ИмяРеквизитаСДатойСобытия = "НачалоСобытия";
		НапоминанияПользователя.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
		// Конец СтандартныеПодсистемы.НапоминанияПользователя
		
		КалендарьСотрудника = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойКалендарь"); 

	КонецЕсли;
	
	ИспользованиеНапоминанийРазрешено = ПолучитьФункциональнуюОпцию("ИспользоватьНапоминанияПользователя") 
		И ПравоДоступа("Редактирование", Метаданные.РегистрыСведений.НапоминанияПользователя);
	
	ЭтоМобильныйКлиент = ОбщегоНазначения.ЭтоМобильныйКлиент();
	Элементы.ДатаНачалаВремя.КнопкаВыпадающегоСписка    = Не ЭтоМобильныйКлиент;
	Элементы.ДатаОкончанияВремя.КнопкаВыпадающегоСписка = Не ЭтоМобильныйКлиент;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПереключитьНаСтраницу(Элементы.СтраницаОсновная);
	
	ПроверитьДоступностьВидеоконференцийНаКлиенте();
	ЗаполнитьМаксимальноеКоличествоУчастников();
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если УстановленРежимСозданияНаСервере() Тогда
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ПроверяемыеРеквизиты, "КалендарьСотрудника");
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ПроверяемыеРеквизиты, "ДатаНачалаДата");
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ПроверяемыеРеквизиты, "ДатаОкончанияДата");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИспользуетсяРаботаССобытиями Тогда
		// СтандартныеПодсистемы.НапоминанияПользователя
		НапоминанияПользователяКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
		// Конец СтандартныеПодсистемы.НапоминанияПользователя
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// СтандартныеПодсистемы.НапоминанияПользователя
&НаКлиенте
Процедура Подключаемый_ПриИзмененииНастройкиНапоминания(Элемент)
	
	НапоминанияПользователяКлиент.ПриИзмененииНастройкиНапоминания(Элемент, ЭтотОбъект);
	
	УстановитьНапоминаниеНаСервере();
	
	Модифицированность = Ложь;
	
КонецПроцедуры
// Конец СтандартныеПодсистемы.НапоминанияПользователя

&НаКлиенте
Процедура ДекорацияНачатьНажатие(Элемент)
	
	УстановитьРежимНаКлиенте(РежимСоздания());
	ПереключитьНаСтраницу(Элементы.СтраницаПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияЗапланироватьНажатие(Элемент)

	Если Не ЗначениеЗаполнено(Объект.Основание) Тогда
		ПоказатьПредупреждение(, НСтр("ru='Не задано основание.'"));
		Возврат;
	КонецЕсли;
	
	УстановитьРежимНаКлиенте(РежимПланирования());
	ПереключитьНаСтраницу(Элементы.СтраницаПараметры);
	
	ТекущийЭлемент = Элементы.ДатаНачалаВремя;
	
КонецПроцедуры

&НаКлиенте
Процедура ТемаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	
	ОткрытьФорму("Справочник.ТемыСобытий.ФормаВыбора", ПараметрыФормы, Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ТемаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Объект.Тема = ВыбранноеЗначение;
		Если УстановленРежимПланированияНаКлиенте() Тогда
			ЗаполнитьСодержание(ВыбранноеЗначение);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаДатаПриИзменении(Элемент)
	
	УправлениеНебольшойФирмойКлиент.ПересчитатьДатуОкончания(ЭтотОбъект, "ДатаНачала", "ДатаОкончания");
	СформироватьПредставлениеПродолжительности(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияДатаПриИзменении(Элемент)
	
	СформироватьПредставлениеПродолжительности(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаВремяПриИзменении(Элемент)
	
	УправлениеНебольшойФирмойКлиент.ПересчитатьДатуОкончания(ЭтотОбъект, "ДатаНачала", "ДатаОкончания");
	СформироватьПредставлениеПродолжительности(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаВремяОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	ВыбранноеЗначение = НачалоДня(Объект.ДатаНачала) + (ВыбранноеЗначение - НачалоДня(ВыбранноеЗначение));
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияВремяПриИзменении(Элемент)

	СформироватьПредставлениеПродолжительности(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияВремяОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	ВыбранноеЗначение = НачалоДня(Объект.ДатаОкончания) + (ВыбранноеЗначение - НачалоДня(ВыбранноеЗначение));
	
КонецПроцедуры

&НаКлиенте
Процедура СобытиеНажатие(Элемент, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("Ключ", Объект.Ссылка);
	ОписаниеОповещения = Новый ОписаниеОповещения("СобытиеНажатиеЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Документ.Событие.ФормаОбъекта", ПараметрыОткрытия, , , , , ОписаниеОповещения);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПодключитьОбсуждения(Команда)

	ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьСостояниеОбсужденийНаКлиенте", ЭтотОбъект);
	ОткрытьФорму("Обработка.ПанельАдминистрированияИнтеграцийУНФ.Форма.ЧатИнтеграцияСМессенджерами", , , , , ,
		ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСостояниеОбсуждений(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьСостояниеОбсужденийНаКлиенте", ЭтотОбъект);
	ВыполнитьОбработкуОповещения(ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура Отменить(Команда)
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура Создать(Команда)

	Если ВстречаСоздана Тогда
		Закрыть();
		Возврат;
	КонецЕсли;
	
	Если Не ПроверитьЗаполнение() Или Не ДатыЗаполненыКорректно() Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеВидеовстречи = ОписаниеВидеовстречи();
	Результат = ВидеовстречиКлиент.СоздатьВидеовстречу(ОписаниеВидеовстречи);
	
	Если Результат.Отказ Тогда
		ПоказатьПредупреждение(, Результат.ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ОбработатьРезультатСоздания(Результат);
	СформироватьТекстПриглашения();

	Если УстановленРежимПланированияНаКлиенте() Тогда
		Оповестить("Запись_Событие");
		Оповестить("Запись_ИсточникЗаписейКалендаряСотрудника");
	КонецЕсли;
		
	ПереключитьНаСтраницу(Элементы.СтраницаГотово);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключиться(Команда)

	ИдентификаторОбсуждения = Новый ИдентификаторОбсужденияСистемыВзаимодействия(Объект.ИдентификаторОбсуждения);
	ИдентификаторыУчастников = ИдентификаторыУчастниковОбсуждения(ИдентификаторОбсуждения);
	
	Участники = Новый КоллекцияИдентификаторовПользователейСистемыВзаимодействия;
	Для Каждого ИдентификаторУчастника Из ИдентификаторыУчастников Цикл
		Участник = Новый ИдентификаторПользователяСистемыВзаимодействия(ИдентификаторУчастника);
		Участники.Добавить(Участник);
	КонецЦикла;
	
	СистемаВзаимодействия.НачатьВидеоконференцию(, Участники, ИдентификаторОбсуждения, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОбсуждение(Команда)
	
	Если Не ПустаяСтрока(Объект.АдресОбсуждения) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(Объект.АдресОбсуждения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоделитьсяTelegram(Команда)

	ПерейтиПоНавигационнойСсылке(СтрокаОтправитьTelegram());

КонецПроцедуры

&НаКлиенте
Процедура ПоделитьсяWhatsApp(Команда)

	ПерейтиПоНавигационнойСсылке(СтрокаОтправитьWhatsApp());
	
КонецПроцедуры

&НаКлиенте
Процедура ПоделитьсяВПисьме(Команда)

	ОписаниеОповещения = Новый ОписаниеОповещения("ЗаполнитьУчастниковПоОснованиюЗавершение", ЭтотОбъект);
	
	Если УстановленРежимПланированияНаКлиенте() И ТипЗнч(Объект.Основание) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		Получатели = ЭлектроннаяПочтаУНФВызовСервера.ПодготовленныеЭлектронныеАдресаПолучателей(
			ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Объект.Основание));
			
		ПараметрыПодбора = Новый Структура("Получатели, НеВыбиратьФорматВложений", Получатели, Истина);
		ОткрытьФорму("ОбщаяФорма.ПодготовкаНовогоПисьма", ПараметрыПодбора, ЭтотОбъект , , , , ОписаниеОповещения);
		
		Возврат;
		
	КонецЕсли;
	
	ДанныеОповещения = Новый Структура("Получатели", Неопределено);
	ВыполнитьОбработкуОповещения(ОписаниеОповещения, ДанныеОповещения);
		
КонецПроцедуры

&НаКлиенте
Процедура СкопироватьТекстПриглашенияВБуфер(Команда)
	
	ПоместитьВБуферОбмена(ТекстПриглашения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Обсуждения

&НаКлиенте
Процедура ОбновитьСостояниеОбсужденийНаКлиенте(Результат, ДополнительныеПараметры) Экспорт
	
	ПроверитьДоступностьОбсужденийНаСервере();
	ПроверитьДоступностьВидеоконференцийНаКлиенте();
		
КонецПроцедуры

&НаСервере
Процедура ПроверитьДоступностьОбсужденийНаСервере()
	
	Попытка
		ОбсужденияДоступны 			= Обсуждения.СистемаВзаимодействийПодключена();
		ПоддерживаетсяВнешнийДоступ = ОбсужденияДоступны И СистемаВзаимодействия.ПоддерживаетсяВнешнийДоступ();	
	Исключение
		ИмяСобытия = ВидеовстречиКлиентСервер.НаименованиеСобытияЖурналаРегистрации();
		ОписаниеОшибки = ОписаниеОшибки();
		ОбщегоНазначения.СообщитьПользователю(ОписаниеОшибки);
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , ,
			ОписаниеОшибки);
		Элементы.СтраницаОсновная.Доступность = Ложь;
		Возврат;
	КонецПопытки;

	Элементы.ПанельОшибки.Видимость = Не ОбсужденияДоступны Или Не ПоддерживаетсяВнешнийДоступ;
	Элементы.СтраницаОсновная.Доступность = Не Элементы.ПанельОшибки.Видимость;
	
	Если Не ОбсужденияДоступны Тогда
		Элементы.ТекстОшибки.Заголовок = НСтр("ru='Обсуждения не подключены.'");
		Элементы.Подключить.Видимость = Истина;
		Элементы.ОбновитьСтатусДоступностиОбсуждений.Видимость = Истина;
	ИначеЕсли Не ПоддерживаетсяВнешнийДоступ Тогда
		ТекстОшибки = НСтр("ru='Сервер системы взаимодействия не поддерживает внешний доступ.'")
			+ НСтр("ru=' Обратитесь к системному администратору.'");
		Элементы.ТекстОшибки.Заголовок = ТекстОшибки;	
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьДоступностьВидеоконференцийНаКлиенте()
	
	Если Не ОбсужденияДоступны Тогда
		Возврат;
	КонецЕсли;
	
	ВидеоконференцииДоступны = СистемаВзаимодействия.ПоддерживаютсяВидеоконференции();
	Если Не ВидеоконференцииДоступны Тогда
		Элементы.ПанельОшибки.Видимость = Истина;
		Элементы.СтраницаОсновная.Доступность = Ложь;
		ТекстОшибки =  НСтр("ru='Приложение на устройстве не поддерживает видеозвонки.'")
			+ НСтр("ru=' Обратитесь к системному администратору.'");
		Элементы.ТекстОшибки.Заголовок = 	ТекстОшибки;	
		Возврат;
	КонецЕсли;
	
	ЗаполнитьМаксимальноеКоличествоУчастников();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьМаксимальноеКоличествоУчастников()
	
	Если Не ОбсужденияДоступны Или Не ВидеоконференцииДоступны Тогда
		Возврат;
	КонецЕсли;
	
	МаксимальноеКоличествоУчастников = СистемаВзаимодействия.ПолучитьМаксимальноеКоличествоУчастниковВидеоконференции();
	Элементы.ДекорацияКоличествоУчастников.Заголовок = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		НСтр("ru='Максимальное количество участников: %1'"), МаксимальноеКоличествоУчастников);
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИдентификаторыУчастниковОбсуждения(ИдентификаторОбсуждения)
		
	Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
	
	Если Обсуждение = Неопределено Тогда
		ВызватьИсключение НСтр("ru='Обсуждение не найдено.'");
	КонецЕсли;
	
	ИдентификаторыУчастников = Новый Массив;
	Для Каждого Участник Из Обсуждение.Участники Цикл
		ИдентификаторыУчастников.Добавить(Участник);
	КонецЦикла;
	
	Возврат ИдентификаторыУчастников;
	
КонецФункции

#КонецОбласти

#Область Режимы

&НаКлиенте
Процедура УстановитьРеквизитыПоРежиму()
	
	Если УстановленРежимПланированияНаКлиенте() Тогда
		
		#Если НЕ МобильныйКлиент Тогда
			
		СобытияУНФКлиентСервер.ЗаполнитьСписокВыбораВремени(Элементы.ДатаНачалаВремя);
		СобытияУНФКлиентСервер.ЗаполнитьСписокВыбораВремени(Элементы.ДатаОкончанияВремя);
		
		#КонецЕсли

		СекундВ15Мин 		= 900;
		Продолжительность 	= 1800;
		
		ДатаНаМомент = ОбщегоНазначенияКлиент.ДатаСеанса();
		СекундСНачалаДня = ДатаНаМомент - НачалоДня(ДатаНаМомент);
		
		ДатаНачалаДата = НачалоДня(ДатаНаМомент);
		ДатаНачалаВремя = Дата(1, 1, 1) + Цел(СекундСНачалаДня / СекундВ15Мин) * СекундВ15Мин + СекундВ15Мин;
		
		Объект.ДатаНачала = ДатаНачалаДата + (ДатаНачалаВремя - Дата(1, 1, 1));
		
		НачалоСобытияПередИзменением = Объект.ДатаНачала;
		
		Объект.ДатаОкончания = Объект.ДатаНачала + Продолжительность;
		ДатаОкончанияДата = Объект.ДатаОкончания;
		ДатаОкончанияВремя = Объект.ДатаОкончания;
		
		СформироватьПредставлениеПродолжительности(ЭтотОбъект);
		
	ИначеЕсли УстановленРежимСозданияНаКлиенте() Тогда
		
		Объект.ДатаНачала = ОбщегоНазначенияКлиент.ДатаСеанса();
		
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьЭлементовПоРежиму()
	
	Элементы.КоманднаяПанельОбсуждения.Видимость = Ложь;
	Элементы.ГруппаИнформацияОКоличествеУчастников.Видимость = Истина;

	ИменаЭлементов = "Основание,ГруппаДата,ГруппаНапоминания,КалендарьСотрудника,Содержание,Событие";
	ИменаЭлементов = СтрРазделить(ИменаЭлементов, ",");
	
	ЗначениеВидимости = ?(УстановленРежимПланированияНаКлиенте(), Истина, Ложь);
	
	Если УстановленРежимПланированияНаКлиенте() Тогда
		ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(ИменаЭлементов, "ГруппаНапоминания");
		Элементы.ГруппаНапоминания.Видимость = ИспользованиеНапоминанийРазрешено;
	КонецЕсли;
	
	Для Каждого ИмяЭлемента Из ИменаЭлементов Цикл
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяЭлемента, 
			"Видимость", ЗначениеВидимости);
	КонецЦикла;

КонецПроцедуры

