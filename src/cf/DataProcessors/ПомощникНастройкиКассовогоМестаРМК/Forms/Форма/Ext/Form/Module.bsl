	Если Не ПустаяСтрока(СтруктураРезультата.СообщениеПользователю) Тогда
		ОбщегоНазначения.СообщитьПользователю(СтруктураРезультата.СообщениеПользователю);
	КонецЕсли;
	Результат = СтруктураРезультата.Результат;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоНастроекСотрудниковПриАктивизацииСтроки(Элемент)
	ТекущиеДанные = Элементы.ДеревоНастроекСотрудников.ТекущиеДанные;
	МассивСотрудников = Новый Массив;
	Если ТекущиеДанные.Уровень = 3 Тогда
		Элементы.ТаблицаСотрудников.ТекущаяСтрока = ТекущиеДанные.ЭлементДерева;
		МассивСотрудников.Добавить(ТекущиеДанные.ЭлементДерева);
	ИначеЕсли ТекущиеДанные.Уровень = 2 Тогда
		СотрудникиСписок = ТекущиеДанные.ПолучитьЭлементы();
		Для Каждого СтрокаДерева Из СотрудникиСписок Цикл
			МассивСотрудников.Добавить(СтрокаДерева.ЭлементДерева);
		КонецЦикла;
	КонецЕсли;
	УстановитьТекстЗапросаТаблицаСотрудников(МассивСотрудников);
КонецПроцедуры

&НаКлиенте
Процедура ЗапускатьРМКПриСтарте(Команда)
	ТекущаяСтрокаДерево = Элементы.ДеревоНастроекСотрудников.ТекущиеДанные;
	Если ТекущаяСтрокаДерево.Уровень <> 2 Тогда
		СообщениеПользователю = НСтр("ru = 'Настройка запуска не установлена не установлен. Активируйте строку с пользователем.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеПользователю);
		Возврат;
	КонецЕсли;
	ЗапускатьРМКПриСтартеНаСервере(ТекущаяСтрокаДерево.ЭлементДерева);
КонецПроцедуры

&НаСервере
Процедура ЗапускатьРМКПриСтартеНаСервере(Пользователь)
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("СообщениеПользователю", НСтр("ru = ''"));
	СтруктураРезультата.Вставить("Результат", Ложь);
	ОбщегоНазначенияРМКПереопределяемый.ЗапускатьРМКПриСтарте(Пользователь, СтруктураРезультата);
	Если Не ПустаяСтрока(СтруктураРезультата.СообщениеПользователю) Тогда
		ОбщегоНазначения.СообщитьПользователю(СтруктураРезультата.СообщениеПользователю);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоСотрудников()
	ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьДеревоСотрудников(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ДеревоНастроекСотрудниковПередРазворачиванием(Элемент, Строка, Отказ)
	ТекущаяСтрока = ДеревоНастроекСотрудников.НайтиПоИдентификатору(Строка);
	Если ТекущаяСтрока <> Неопределено Тогда
		НайденноеЗначение = СоответствиеСтрокРазвернутая.Получить(ТекущаяСтрока.ЭлементДерева);
		
		Если НайденноеЗначение = Неопределено Тогда
			СоответствиеСтрокРазвернутая.Вставить(ТекущаяСтрока.ЭлементДерева, Строка);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоНастроекСотрудниковПередСворачиванием(Элемент, Строка, Отказ)
	ТекущаяСтрока = ДеревоНастроекСотрудников.НайтиПоИдентификатору(Строка);
	Если ТекущаяСтрока <> Неопределено Тогда
		СоответствиеСтрокРазвернутая.Удалить(ТекущаяСтрока.ЭлементДерева);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДеревоСотрудниковНаКлиенте()
	ТекущиеДанные = Элементы.ДеревоНастроекСотрудников.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		ЭлементДерева = ТекущиеДанные.ЭлементДерева;
	Иначе
		ЭлементДерева = Неопределено;
	КонецЕсли;
	ИдентификаторТекущейСтроки = Элементы.ДеревоНастроекСотрудников.ТекущаяСтрока;
	ЗаполнитьДеревоСотрудников();
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЭлементДерева", ЭлементДерева);
	ДополнительныеПараметры.Вставить("ИдентификаторТекущейСтроки", ИдентификаторТекущейСтроки);
	
	ОбновитьИдентификаторыСтрок(СоответствиеСтрокРазвернутая, ДополнительныеПараметры);
	Для Каждого ЭлементСоответствия Из СоответствиеСтрокРазвернутая Цикл
		Элементы.ДеревоНастроекСотрудников.Развернуть(ЭлементСоответствия.Значение);
	КонецЦикла;
	
	Если ДополнительныеПараметры.ИдентификаторТекущейСтроки > -1 Тогда
		Элементы.ДеревоНастроекСотрудников.ТекущаяСтрока = ДополнительныеПараметры.ИдентификаторТекущейСтроки;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьИдентификаторыСтрок(СоответствиеСтрокРазвернутая, ДополнительныеПараметры)
	Если СоответствиеСтрокРазвернутая = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьИдентификаторыЭлементовДерева(ДеревоНастроекСотрудников, СоответствиеСтрокРазвернутая, ДополнительныеПараметры);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьИдентификаторыЭлементовДерева(ДеревоЗначений, СоответствиеСтрокРазвернутая, ДополнительныеПараметры)
	ЭлементыДерева = ДеревоЗначений.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из ЭлементыДерева Цикл
		НайденноеЗначение = СоответствиеСтрокРазвернутая.Получить(СтрокаДерева.ЭлементДерева);
		Если НЕ НайденноеЗначение = Неопределено Тогда
			СоответствиеСтрокРазвернутая.Удалить(СтрокаДерева.ЭлементДерева);
			СоответствиеСтрокРазвернутая.Вставить(СтрокаДерева.ЭлементДерева, СтрокаДерева.ПолучитьИдентификатор());
		КонецЕсли;
		Если СтрокаДерева.ЭлементДерева = ДополнительныеПараметры.ЭлементДерева Тогда
			ДополнительныеПараметры.ИдентификаторТекущейСтроки = СтрокаДерева.ПолучитьИдентификатор();
		КонецЕсли;
		
		ЗаполнитьИдентификаторыЭлементовДерева(СтрокаДерева, СоответствиеСтрокРазвернутая, ДополнительныеПараметры);
	КонецЦикла;
КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункцииОбменДанными

&НаКлиенте
Процедура ВыполнитьПервоначальныйОбмен()
	ТекстВопроса = НСтр("ru = 'Выполнить первоначальный обмен?'");
	СписокОтветов = Новый СписокЗначений;
	СписокОтветов.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Выполнить'"));
	СписокОтветов.Добавить(КодВозвратаДиалога.Нет, НСтр("ru = 'Отмена'"));
	ОповещениеПоРезультатуВопроса = Новый ОписаниеОповещения("ВыполнитьПервоначальныйОбменРезультат", ЭтаФорма);
	ПоказатьВопрос(ОповещениеПоРезультатуВопроса, ТекстВопроса, СписокОтветов, ,КодВозвратаДиалога.Да, НСтр("ru = 'Обмен данными'"));
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПервоначальныйОбменРезультат(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	ВыполнятьПервоначальныйОбмен = Ложь;
	ЕстьОшибки = Ложь;
	ОписаниеСтрокиПриложения = Новый Структура;
	ЗаполнитьНастройкиСинхронизации(ОписаниеСтрокиПриложения, ЕстьОшибки);
	Если Не ЕстьОшибки Тогда
		СинхронизацияДанных(ОписаниеСтрокиПриложения);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНастройкиСинхронизации(ОписаниеСтрокиПриложения, ЕстьОшибки)
	ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьНастройкиСинхронизации(ОписаниеСтрокиПриложения, ЕстьОшибки, УзелОбмена);
КонецПроцедуры

&НаКлиенте
Процедура СинхронизацияДанных(ОписаниеСтрокиПриложения)
	
	РезультатДополнительнойПроверки = (ОписаниеСтрокиПриложения.ВариантОбменаДанными <> "Синхронизация" ИЛИ ОписаниеСтрокиПриложения.ИспользоватьДопОтборы);
	
	Если ОписаниеСтрокиПриложения.ПолученоСообщениеДляСопоставления
		ИЛИ (ОписаниеСтрокиПриложения.ДоступнаИнтерактивнаяОтправка И РезультатДополнительнойПроверки)
		Тогда
		
		ОткрытьПомощникИнтерактивнойСинхронизации(ОписаниеСтрокиПриложения);
		
	Иначе
		
		ОткрытьПомощникАвтоматическойСинхронизации(ОписаниеСтрокиПриложения);
		
	КонецЕсли;
	
КонецПроцедуры

// Стартовая процедура интерактивной синхронизации 
//
&НаКлиенте
Процедура ОткрытьПомощникИнтерактивнойСинхронизации(ДополнительныеПараметры)
	
	РежимДополненияВыгрузки = ДополнительныеПараметры.ИспользоватьДопОтборы ИЛИ (ДополнительныеПараметры.ВариантОбменаДанными = "ПолучениеИОтправка");
	
	ПараметрыПомощника = Новый Структура;
	ПараметрыПомощника.Вставить("ЭтоОбменСПриложениемВСервисе", ДополнительныеПараметры.ЭтоОбменСПриложениемВСервисе);
	ПараметрыПомощника.Вставить("ОбластьДанныхКорреспондента",  ДополнительныеПараметры.ОбластьДанныхКорреспондента);
	ПараметрыПомощника.Вставить("ОтправитьДанные", Не ДополнительныеПараметры.ЗапускОбменаИзКорреспондента);
	ПараметрыПомощника.Вставить("РежимДополненияВыгрузки", РежимДополненияВыгрузки);
	ПараметрыПомощника.Вставить("НастройкаРасписания", Ложь);
	
	ВспомогательныеПараметры = Новый Структура;
	ВспомогательныеПараметры.Вставить("ПараметрыПомощника", ПараметрыПомощника);
	ВспомогательныеПараметры.Вставить("ОповещениеОЗакрытии", Новый ОписаниеОповещения("ПослеЗакрытияПомощникаОбменов", ЭтотОбъект, ДополнительныеПараметры));
	
	ОбменДаннымиКлиент.ОткрытьПомощникСопоставленияОбъектовОбработкаКоманды(ДополнительныеПараметры.УзелИнформационнойБазы, ЭтотОбъект, ВспомогательныеПараметры);
	
КонецПроцедуры

// Стартовая процедура автоматической синхронизации 
//
&НаКлиенте
Процедура ОткрытьПомощникАвтоматическойСинхронизации(ДополнительныеПараметры)
	
	ПараметрыПомощника = Новый Структура;	
	ПараметрыПомощника.Вставить("ЭтоОбменСПриложениемВСервисе", ДополнительныеПараметры.ЭтоОбменСПриложениемВСервисе);
	ПараметрыПомощника.Вставить("ОбластьДанныхКорреспондента",  ДополнительныеПараметры.ОбластьДанныхКорреспондента);
		
	ВспомогательныеПараметры = Новый Структура;
	ВспомогательныеПараметры.Вставить("ПараметрыПомощника", ПараметрыПомощника);
	ВспомогательныеПараметры.Вставить("ОповещениеОЗакрытии", Новый ОписаниеОповещения("ПослеЗакрытияПомощникаОбменов", ЭтотОбъект, ДополнительныеПараметры));
	
	ОбменДаннымиКлиент.ВыполнитьОбменДаннымиОбработкаКоманды(ДополнительныеПараметры.УзелИнформационнойБазы, ЭтотОбъект, , Истина, ВспомогательныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияПомощникаОбменов(Результат, ДополнительныеПараметры) Экспорт
	ЗаполнитьТекущуюНастройкуРМК();
	ВыполнитьДействияПереходаНаСтраницу(0);
	ЗаполнитьДеревоГруппыДоступа();
КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункцииРабочиеМеста

&НаСервере
Процедура ЗаполнитьДанныеПоРабочемуМесту()
	ИспользоватьОтбор = Истина;
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(НастройкиРМК,
		"ТекущееРабочееМесто",
		ТекущееРабочееМесто,
		ИспользоватьОтбор);
		
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(РабочиеМеста,
		"ТекущееРабочееМесто",
		ТекущееРабочееМесто,
		ИспользоватьОтбор);
		
КонецПроцедуры

&НаКлиенте
Процедура МасштабМелкий(Команда)
	Масштаб = 80;
	УстановитьАктивностьКнопкиМасштаб();
КонецПроцедуры

&НаКлиенте
Процедура МасштабСтандартный(Команда)
	Масштаб = 100;
	УстановитьАктивностьКнопкиМасштаб();
КонецПроцедуры

&НаКлиенте
Процедура МасштабКрупный(Команда)
	Масштаб = 150;
	УстановитьАктивностьКнопкиМасштаб();
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьМасштаб(Команда)
	Элементы.ГруппаКомандыМасштаб.Показать();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьАктивностьКнопкиМасштаб(УстановитьНастройки = Истина)
	Элементы.МасштабМелкий.ЦветФона = ЦветаФормы.Авто;
	Элементы.МасштабСтандартный.ЦветФона = ЦветаФормы.Авто;
	Элементы.МасштабКрупный.ЦветФона = ЦветаФормы.Авто;
	Если Масштаб <= 80 Тогда
		Элементы.МасштабМелкий.ЦветФона = ЦветаФормы.АктивнаяКнопка;
		ВидОтображения = ПредопределенноеЗначение("Перечисление.ВидыОтображения.Уменьшенный");
	ИначеЕсли Масштаб > 80 И Масштаб <= 100 Тогда
		Элементы.МасштабСтандартный.ЦветФона = ЦветаФормы.АктивнаяКнопка;
		ВидОтображения = ПредопределенноеЗначение("Перечисление.ВидыОтображения.Стандартный");
	Иначе
		Элементы.МасштабКрупный.ЦветФона = ЦветаФормы.АктивнаяКнопка;
		ВидОтображения = ПредопределенноеЗначение("Перечисление.ВидыОтображения.Увеличенный");
	КонецЕсли;
	Если УстановитьНастройки Тогда
		МодифицированностьРеквизитовРМК = Истина;
		НастройкаРМК.ВидОтображения = ВидОтображения;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#КонецОбласти
