КонецПроцедуры

&НаКлиенте
Процедура ПерезаполнитьСпискиГрупп(Результат, ДополнительныеПараметры) Экспорт
	Если ЗначениеЗаполнено(Результат) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(Результат);
	КонецЕсли;
	Элементы.ТаблицаПользователей.Обновить();
	ЗаполнитьДеревоГруппыДоступа();
	РазвернутьГруппуДерева();
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьГруппуДерева()
	Если НЕ ЗначениеЗаполнено(ВыбраннаяГруппаДоступа) Тогда
		Возврат;
	КонецЕсли;

	СтрокиДерева = ДеревоГруппДоступа.ПолучитьЭлементы();
	Для Каждого Строка Из СтрокиДерева Цикл
		Если ВыбраннаяГруппаДоступа = Строка.ЭлементДерева Тогда
			Элементы.ДеревоГруппДоступа.Развернуть(Строка.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЦикла;
	
	ИдентификаторСтроки = 0;
	ОбщегоНазначенияКлиентСервер.ПолучитьИдентификаторСтрокиДереваПоЗначениюПоля("ЭлементДерева", ИдентификаторСтроки, ДеревоГруппДоступа.ПолучитьЭлементы(), ВыбраннаяГруппаДоступа, Ложь);
	Элементы.ДеревоГруппДоступа.ТекущаяСтрока = ИдентификаторСтроки;
	
	ПривестиЗначениеВыбраннойГруппы();
	
КонецПроцедуры

&НаСервере
Процедура ПривестиЗначениеВыбраннойГруппы()
	ВыбраннаяГруппаДоступа = Метаданные.ОпределяемыеТипы.ГруппаДоступаРМК.Тип.ПривестиЗначение();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДеревоГрупп(Результат, ДополнительныеПараметры) Экспорт
	ЗаполнитьДеревоГруппыДоступа();
	РазвернутьГруппуДерева();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьТаблицуПользователей(Результат, ДополнительныеПараметры) Экспорт
	Элементы.ТаблицаПользователей.Обновить();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоГруппыДоступа()
	
	ЭлементыГруппыДоступа = ДеревоГруппДоступа.ПолучитьЭлементы();
	ЭлементыГруппыДоступа.Очистить();
	
	ТекстЗапроса = "";
	
	ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьТекстЗапросаДеревоГруппыДоступа(ТекстЗапроса);
	Если ПустаяСтрока(ТекстЗапроса) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ДеревоОбъект = РеквизитФормыВЗначение("ДеревоГруппДоступа");
		ВыборкаГруппаДоступа = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппаДоступа.Следующий() Цикл
			СтрокиГруппыДоступа = ДеревоОбъект.Строки.Добавить();
			СтрокиГруппыДоступа.ЭлементДерева = ВыборкаГруппаДоступа.ГруппаДоступа;
			СтрокиГруппыДоступа.ГруппаДоступа = ВыборкаГруппаДоступа.ГруппаДоступа;
			СтрокиГруппыДоступа.Уровень = 1;
			ВыборкаПользователи = ВыборкаГруппаДоступа.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПользователи.Следующий() Цикл
				Если Не ЗначениеЗаполнено(ВыборкаПользователи.Пользователь) Тогда
					Продолжить;
				КонецЕсли;
				СтрокиПользователи = СтрокиГруппыДоступа.Строки.Добавить();
				СтрокиПользователи.ЭлементДерева = ВыборкаПользователи.Пользователь;
				СтрокиПользователи.ГруппаДоступа = ВыборкаПользователи.ГруппаДоступа;
				СтрокиПользователи.Уровень = 2;
				Выборка = ВыборкаПользователи.Выбрать();
				Пока Выборка.Следующий() Цикл
					Если Не ЗначениеЗаполнено(Выборка.ФизическоеЛицо) Тогда
						Продолжить;
					КонецЕсли;
					Строки = СтрокиПользователи.Строки.Добавить();
					Строки.ЭлементДерева = Выборка.ФизическоеЛицо;
					Строки.ГруппаДоступа = Выборка.ГруппаДоступа;
					Строки.Уровень = 3;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(ДеревоОбъект, "ДеревоГруппДоступа");
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоГруппДоступаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	ПараметрыОткрытия = Новый Структура("Ключ", ТекущиеДанные.ГруппаДоступа);
	
	ОткрытьФорму("Справочник.ГруппыДоступа.ФормаОбъекта", ПараметрыОткрытия, ЭтаФорма, ЭтаФорма.УникальныйИдентификатор,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаписьНаНаличие(ВыбраннаяСтрока, НетЗаписи, ДанныеЗаписи)
	ОбщегоНазначенияРМКПереопределяемый.ПроверитьИНайтиЗаписьПерсональныйКод(ВыбраннаяСтрока, НетЗаписи, ДанныеЗаписи);
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПользователейВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ПроверкаИСозданиеПерсональногоКода();
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаИСозданиеПерсональногоКода()
	НетЗаписи = Ложь;
	ТекущаяСтрока = Элементы.ТаблицаПользователей.ТекущиеДанные;
	ДанныеЗаписи = Новый Структура("Пользователь, Кассир",
			ТекущаяСтрока.Пользователь, ТекущаяСтрока.Кассир);
	ВыбраннаяСтрока = Неопределено;
	ПроверитьЗаписьНаНаличие(ВыбраннаяСтрока, НетЗаписи, ДанныеЗаписи);
	Если НетЗаписи Тогда
		СтруктураСозданияКода = Новый Структура("Пользователь, ФизическоеЛицо, ПерсональныйКод",
			ТекущаяСтрока.Пользователь, ТекущаяСтрока.Кассир, ТекущаяСтрока.ПерсональныйКод);
	Иначе
		СтруктураСозданияКода = Новый Структура("Ключ",ВыбраннаяСтрока);
	КонецЕсли;
	ОбщегоНазначенияРМККлиентПереопределяемый.ОткрытьФормуСозданияКодаДоступа(СтруктураСозданияКода);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьПользователяИзГруппыДоступа(Команда)
	УдалитьПользователяИзГруппыДоступаКоманда();
КонецПроцедуры

&НаКлиенте
Процедура УдалитьПользователяИзГруппыДоступаКоманда()
	ТекущаяСтрокаДеревоГрупп = Элементы.ДеревоГруппДоступа.ТекущиеДанные;
	Если ТекущаяСтрокаДеревоГрупп.Уровень <> 2 Тогда
		ТекстСообщения = НСтр("ru = 'Пользователь не выбран'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	ВыбранныйПользователь = ТекущаяСтрокаДеревоГрупп.ЭлементДерева;
	ВыбраннаяГруппа = ТекущаяСтрокаДеревоГрупп.ГруппаДоступа;
	
	ТекстВопроса = НСтр("ru = 'Удалить пользователя %1 из группы доступа %2?'");
	ДополнительныеПараметрыВопроса = Новый Структура("ВыбранныйПользователь, ВыбраннаяГруппа", ВыбранныйПользователь, ВыбраннаяГруппа);
	ОповещениеОЗакрытииВопроса = Новый ОписаниеОповещения("УдалитьПользователяОповещениеОЗакрытииВопроса",ЭтаФорма, ДополнительныеПараметрыВопроса);
	СписокЗначенийОтветы = Новый СписокЗначений;
	СписокЗначенийОтветы.Добавить(КодВозвратаДиалога.Да, НСтр("ru= 'Удалить'"));
	СписокЗначенийОтветы.Добавить(КодВозвратаДиалога.Нет, НСтр("ru= 'Отменить'"));
	ПоказатьВопрос(ОповещениеОЗакрытииВопроса, СтрШаблон(ТекстВопроса,ВыбранныйПользователь,ВыбраннаяГруппа), СписокЗначенийОтветы);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьПользователяОповещениеОЗакрытииВопроса(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьПользователяИзГруппыДоступаНаСервере(ДополнительныеПараметры.ВыбранныйПользователь, ДополнительныеПараметры.ВыбраннаяГруппа);
	
	ВыбраннаяГруппаДоступа = ДополнительныеПараметры.ВыбраннаяГруппа;
	
	РазвернутьГруппуДерева();
КонецПроцедуры

&НаСервере
Процедура УдалитьПользователяИзГруппыДоступаНаСервере(ВыбранныйПользователь, ВыбраннаяГруппа)
	
	Если ТипЗнч(ВыбранныйПользователь) = Тип("Строка")
		ИЛИ ТипЗнч(ВыбраннаяГруппа) = Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = НСтр("ru = ''");
	ОбщегоНазначенияРМКПереопределяемый.УдалитьПользователяИзГруппыДоступаПомощникРМК(ВыбранныйПользователь, ВыбраннаяГруппа, ТекстСообщения);
	
	Если НЕ ПустаяСтрока(ТекстСообщения) Тогда
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	ЗаполнитьДеревоГруппыДоступа();
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаПользователейОкончаниеПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка)
	
	ДобавитьПользователяВГруппуДоступаКоманда();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоГруппДоступаОкончаниеПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка)
	
	ТекущийЭлементПеретаскивания = ПараметрыПеретаскивания.Значение;
	Если НЕ ТекущийЭлементПеретаскивания.Свойство("Уровень") Тогда
		Возврат;
	КонецЕсли;
	Если ТекущийЭлементПеретаскивания.Уровень <> 2 Тогда
		ТекстСообщения = НСтр("ru = 'Пользователь не выбран'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	ВыбранныйПользователь = ТекущийЭлементПеретаскивания.ЭлементДерева;
	ВыбраннаяГруппа = ТекущийЭлементПеретаскивания.ГруппаДоступа;
	
	ТекстВопроса = НСтр("ru = 'Удалить пользователя %1 из группы доступа %2?'");
	ДополнительныеПараметрыВопроса = Новый Структура("ВыбранныйПользователь, ВыбраннаяГруппа", ВыбранныйПользователь, ВыбраннаяГруппа);
	ОповещениеОЗакрытииВопроса = Новый ОписаниеОповещения("УдалитьПользователяОповещениеОЗакрытииВопроса",ЭтаФорма, ДополнительныеПараметрыВопроса);
	СписокЗначенийОтветы = Новый СписокЗначений;
	СписокЗначенийОтветы.Добавить(НСтр("ru= 'Удалить'"));
	СписокЗначенийОтветы.Добавить(КодВозвратаДиалога.Нет);
	ПоказатьВопрос(ОповещениеОЗакрытииВопроса, СтрШаблон(ТекстВопроса,ВыбранныйПользователь,ВыбраннаяГруппа), СписокЗначенийОтветы);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПроверитьПользователяАдминистратор(ЕстьПользовательАдминистратор)
	ОбщегоНазначенияРМКПереопределяемый.ПроверитьПользователяАдминистратор(ЕстьПользовательАдминистратор);
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СоздатьПользователяАдминистратор(ТорговыйОбъект, СообщениеОбОшибке)
	ОбщегоНазначенияРМКПереопределяемый.СоздатьПользователяАдминистратор(ТорговыйОбъект, СообщениеОбОшибке);
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПользователяАдминистратора()
	ЕстьПользовательАдминистратор = Ложь;
	
	ПроверитьПользователяАдминистратор(ЕстьПользовательАдминистратор);
	Если НЕ ЕстьПользовательАдминистратор Тогда
		СообщениеОбОшибке = НСтр("ru = ''");
		СоздатьПользователяАдминистратор(Объект.ТорговыйОбъект, СообщениеОбОшибке);
		
		Если Не ПустаяСтрока(СообщениеОбОшибке) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибке);
		КонецЕсли;
		Элементы.ТаблицаПользователей.Обновить();
		ЗаполнитьДеревоГруппыДоступа();
		РазвернутьГруппуДерева();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСотрудникаКПользователю(Команда)
	ТекущаяСтрокаСотрудник = Элементы.ТаблицаСотрудников.ТекущиеДанные;
	ТекущаяСтрокаПользователь = Элементы.ДеревоНастроекСотрудников.ТекущиеДанные;
	Если ТекущаяСтрокаПользователь.Уровень <> 2 Тогда
		СообщениеПользователю = НСтр("ru = 'Сотрудник не добавлен. Активируйте строку с пользователем.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеПользователю);
		Возврат;
	ИначеЕсли НЕ ЗначениеЗаполнено(ТекущаяСтрокаСотрудник.КодСотрудника) Тогда
		ДополнительныеПараметрыОповещения = Новый Структура("Сотрудник", ТекущаяСтрокаСотрудник.Сотрудник);
		ДополнительныеПараметрыОповещения = Новый Структура("Пользователь", ТекущаяСтрокаПользователь.ЭлементДерева);
		ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьСотрудникаКПользователюПослеВводаКода", ЭтаФорма, ДополнительныеПараметрыОповещения);
		ПараметрыОткрытияФормы = Новый Структура;
		ПараметрыОткрытияФормы.Вставить("НастройкаСотрудника", Истина);
		ПараметрыОткрытияФормы.Вставить("Сотрудник", ТекущаяСтрокаСотрудник.Сотрудник);
		ПараметрыОткрытияФормы.Вставить("КодСотрудника", ТекущаяСтрокаСотрудник.КодСотрудника);
		ОбщегоНазначенияРМККлиентПереопределяемый.ОткрытьФормуСозданияКодаДоступа(ПараметрыОткрытияФормы);
	КонецЕсли;
	Результат = Ложь;
	ДобавитьСотрудникаКПользователюСервер(ТекущаяСтрокаСотрудник.Сотрудник, ТекущаяСтрокаПользователь.ЭлементДерева, Результат);
	Если Результат Тогда
		ЗаполнитьДеревоСотрудниковНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСотрудникаКПользователюПослеВводаКода(Результат, ДополнительныеПараметры) Экспорт
	СтатусОбновления = Ложь;
	ДобавитьСотрудникаКПользователюСервер(ДополнительныеПараметры.Сотрудник, ДополнительныеПараметры.Пользователь, СтатусОбновления);
	Если СтатусОбновления Тогда
		ЗаполнитьДеревоСотрудниковНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДобавитьСотрудникаКПользователюСервер(Сотрудник, Пользователь, Результат)
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("СообщениеПользователю", НСтр("ru = ''"));
	СтруктураРезультата.Вставить("Результат", Результат);
	ОбщегоНазначенияРМКПереопределяемый.ДобавитьСотрудникаКПользователю(Сотрудник, Пользователь, СтруктураРезультата);
	Если Не ПустаяСтрока(СтруктураРезультата.СообщениеПользователю) Тогда
		ОбщегоНазначения.СообщитьПользователю(СтруктураРезультата.СообщениеПользователю);
	КонецЕсли;
	Результат = СтруктураРезультата.Результат;
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСотрудника(Команда)
	ТекущаяСтрокаДерево = Элементы.ДеревоНастроекСотрудников.ТекущиеДанные;
	Если ТекущаяСтрокаДерево.Уровень <> 3 Тогда
		СообщениеПользователю = НСтр("ru = 'Сотрудник не удален. Активируйте строку с сотрудником.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеПользователю);
		Возврат;
	КонецЕсли;
	Результат = Ложь;
	УдалитьСотрудникаПользователяСервер(ТекущаяСтрокаДерево.ЭлементДерева, ТекущаяСтрокаДерево.Пользователь, Результат);
	Если Результат Тогда
		ЗаполнитьДеревоСотрудниковНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УдалитьСотрудникаПользователяСервер(Сотрудник, Пользователь, Результат)
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("СообщениеПользователю", НСтр("ru = ''"));
	СтруктураРезультата.Вставить("Результат", Результат);
	ОбщегоНазначенияРМКПереопределяемый.УдалитьСотрудникаПользователя(Сотрудник, Пользователь, СтруктураРезультата);
	Если Не ПустаяСтрока(СтруктураРезультата.СообщениеПользователю) Тогда
		ОбщегоНазначения.СообщитьПользователю(СтруктураРезультата.СообщениеПользователю);
	КонецЕсли;
	Результат = СтруктураРезультата.Результат;
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаСотрудниковВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.ТаблицаСотрудников.ТекущиеДанные;
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("НастройкаСотрудника", Истина);
	ПараметрыОткрытияФормы.Вставить("Сотрудник", ТекущиеДанные.Сотрудник);
	ПараметрыОткрытияФормы.Вставить("КодСотрудника", ТекущиеДанные.КодСотрудника);
	ОбщегоНазначенияРМККлиентПереопределяемый.ОткрытьФормуСозданияКодаДоступа(ПараметрыОткрытияФормы);
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТорговыйОбъект(Команда)
	ТекущаяСтрокаДерево = Элементы.ДеревоНастроекСотрудников.ТекущиеДанные;
	Если ТекущаяСтрокаДерево.Уровень <> 2 Тогда
		СообщениеПользователю = НСтр("ru = 'Торговый объект не установлен. Активируйте строку с пользователем.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеПользователю);
		Возврат;
	КонецЕсли;
	Результат = Ложь;
	УстановитьТорговыйОбъектПользователя(ТекущаяСтрокаДерево.ЭлементДерева, Результат);
	Если Результат Тогда
		ЗаполнитьДеревоСотрудниковНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьТорговыйОбъектПользователя(Пользователь, Результат)
	
	СтруктураРезультата = Новый Структура;
	СтруктураРезультата.Вставить("СообщениеПользователю", НСтр("ru = ''"));
