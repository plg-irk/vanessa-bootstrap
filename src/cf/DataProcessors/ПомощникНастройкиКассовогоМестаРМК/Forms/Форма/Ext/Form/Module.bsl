&НаКлиенте
Процедура ТипПодключенияПриИзменении(Элемент)
	#Если Не ВебКлиент Тогда
		ИмяКомпьютера = ИмяКомпьютера();
	#КонецЕсли
	Элементы.ГруппаЛокальноеПодключение.Видимость = ТипПодключения = "0";
