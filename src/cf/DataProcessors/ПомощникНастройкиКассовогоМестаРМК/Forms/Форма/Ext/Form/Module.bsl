&НаСервере
Процедура ЗаполнитьДанныеПоПлатежнымСистемам()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, 
		"ГруппаТипыПлатежныхСистемВертикальная",       
		"Видимость", 
		НастройкаРМК.ИспользоватьОплатуПлатежнымиСистемами);

	ПолужирноеНачертание = Истина;
	
	// АПК:1036-выкл нет подходящего шрифта
	ШрифтЖирный = Новый Шрифт(, 11, ПолужирноеНачертание);
	// АПК:1036-вкл
	
	Если НастройкаРМК.ИспользоватьОплатуПлатежнымиСистемами Тогда
			
		КоличествоПодключенийСБП 		 = 0;
		КоличествоПодключенийЮКасса 	 = 0;
		
		КоличествоПодключенийСБПВсего 	 = 0;
		КоличествоПодключенийЮКассаВсего = 0;
		
		НастройкиПодключения = РегистрыСведений.СоответствиеНастроекИнтеграцииРМК.НастройкиИнтеграции(
			Объект.Организация,
			Объект.ТорговыйОбъект);

		Если НастройкиПодключения <> Неопределено Тогда
			
			ТипыПлатежнойСистемыККТ = МенеджерОборудованияРМК.ТипыПлатежнойСистемыККТ();
			
			Для Каждого СтрокаНастройки Из НастройкиПодключения Цикл
				
				Если СтрокаНастройки.ПлатежнаяСистема = ТипыПлатежнойСистемыККТ.Получить("СистемаБыстрыхПлатежей") Тогда
					
					КоличествоПодключенийСБП 		 = КоличествоПодключенийСБП + 1;
					КоличествоПодключенийСБПВсего 	 = КоличествоПодключенийСБПВсего + 1;
					
				ИначеЕсли СтрокаНастройки.ПлатежнаяСистема = ТипыПлатежнойСистемыККТ.Получить("ЮКасса") Тогда
					
					КоличествоПодключенийЮКасса 	 = КоличествоПодключенийЮКасса + 1;
					КоличествоПодключенийЮКассаВсего = КоличествоПодключенийЮКассаВсего + 1;
					
				КонецЕсли;
				
			КонецЦикла;
				
		КонецЕсли;
		
		КоличествоПодключений = Новый ФорматированнаяСтрока(Формат(КоличествоПодключенийСБП, "ЧН=0; ЧГ=0"), ШрифтЖирный);
		ВсеПодключения		  = Новый ФорматированнаяСтрока(Формат(КоличествоПодключенийСБПВсего, "ЧН=0; ЧГ=0"), ШрифтЖирный);
		
		МассивСтрок = Новый Массив();
		МассивСтрок.Добавить(КоличествоПодключений);
	
		Элементы.ДекорацияСБП.Заголовок = Новый ФорматированнаяСтрока(МассивСтрок);
		
		КоличествоПодключений = Новый ФорматированнаяСтрока(Формат(КоличествоПодключенийЮКасса, "ЧН=0; ЧГ=0"), ШрифтЖирный);
		ВсеПодключения		  = Новый ФорматированнаяСтрока(Формат(КоличествоПодключенийЮКассаВсего, "ЧН=0; ЧГ=0"), ШрифтЖирный);
		
		МассивСтрок = Новый Массив();
		МассивСтрок.Добавить(КоличествоПодключений);
	
		Элементы.ДекорацияЮКасса.Заголовок = Новый ФорматированнаяСтрока(МассивСтрок);
		
	КонецЕсли;
	
КОнецПроцедуры

&НаСервере
Процедура НастроитьПанельПлатежнойСистемы(ИмяСтраницы)
	
	Если ИмяСтраницы = "СтраницаНастройкаРМКСБП" Тогда
		
		МассивСтрок 		= Новый Массив; 
		ПустаяСтрока		= Новый ФорматированнаяСтрока(НСтр("ru ='
		|
		|'"));
		
		ПоОрганизации 		= Новый Структура("Организация", Объект.Организация);
		СтрокаОрганизации 	= Объект.Организации.НайтиСтроки(ПоОрганизации).Получить(0);
		ИдентификаторСтроки = СтрокаОрганизации.ПолучитьИдентификатор();
		
		НастройкиКассовыхСсылокСБП	= ИнтеграцияСПлатежнымиСистемамиРМКВызовСервера.ИнициализироватьНастройкиКассовыхСсылок(
			Объект.ТорговыйОбъект, 
			Объект.Организация, 
			СтрокаОрганизации.КассаККМ);
		
		Если ЗначениеЗаполнено(НастройкиКассовыхСсылокСБП.НастройкиПодключения) Тогда

			СсылкаНаСписок = Новый ФорматированнаяСтрока(НСтр("ru ='Подключить СБП.'"),,,, "ОткрытьСписокНастроекССБП");

			МассивСтрок.Добавить(СсылкаНаСписок);
			
		Иначе
			
			СсылкаНаПодключение = Новый ФорматированнаяСтрока(НСтр("ru ='Подключить СБП.'"),,,, "ПодключитьСБП");

			МассивСтрок.Добавить(СсылкаНаПодключение);
			
		КонецЕсли;
		
		Если НастройкиКассовыхСсылокСБП.КассовыеСсылки <> Неопределено
			И НастройкиКассовыхСсылокСБП.КассовыеСсылки.ИспользоватьКассовыйQRКодСБП Тогда

			ВидДействия			= "НастроитьКассовыйQRКодСБП_" + Формат(ИдентификаторСтроки, "ЧН=0; ЧГ=");
			СсылкаНаПодключение = Новый ФорматированнаяСтрока(НСтр("ru ='Настроить кассовый QR-код.'"),,,, ВидДействия);

			МассивСтрок.Добавить(ПустаяСтрока);
			МассивСтрок.Добавить(СсылкаНаПодключение);
			
		КонецЕсли;
		
		Элементы.ДекорацияОписаниеСБПКоманды.Заголовок = Новый ФорматированнаяСтрока(МассивСтрок);
		
	ИначеЕсли ИмяСтраницы = "СтраницаНастройкаРМКЮKassa" Тогда
		
		ТипыПлатежнойСистемыККТ = МенеджерОборудованияРМК.ТипыПлатежнойСистемыККТ();
		
		МассивСтрок 		 = Новый Массив;
		ПодключенаЮКасса 	 = Новый Структура("ПлатежнаяСистема", ТипыПлатежнойСистемыККТ.Получить("ЮКасса"));
		НастройкиПодключения = РегистрыСведений.СоответствиеНастроекИнтеграцииРМК.НастройкиИнтеграции(
			Объект.Организация, 
			Объект.ТорговыйОбъект);
			
		Если НастройкиПодключения <> Неопределено
			И НастройкиПодключения.НайтиСтроки(ПодключенаЮКасса).Количество() Тогда

			СсылкаНаСписок = Новый ФорматированнаяСтрока(НСтр("ru ='Подключить ЮKassa.'"),,,, "ОткрытьСписокНастроекЮКасса");

			МассивСтрок.Добавить(СсылкаНаСписок);
			
		Иначе
			
			СсылкаНаСписок = Новый ФорматированнаяСтрока(НСтр("ru ='Подключить ЮKassa.'"),,,, "ПодключитьЮКасса");

			МассивСтрок.Добавить(СсылкаНаСписок);

		КонецЕсли;
		
		Элементы.ДекорацияОписаниеЮКассаКоманды.Заголовок = Новый ФорматированнаяСтрока(МассивСтрок);
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьДрайверыОборудования(ТипОборудования)
	
	ТипыПодключаемогоОборудования = МенеджерОборудованияРМК.ТипыПодключаемогоОборудования();
	
	Если ТипОборудования = "ККТ" Тогда
		ТипОборудованияДляДрайверов = ТипыПодключаемогоОборудования.Получить("ККТ");
	ИначеЕсли ТипОборудования = "ЭквайринговыйТерминал" Тогда
		ТипОборудованияДляДрайверов = ТипыПодключаемогоОборудования.Получить("ЭквайринговыйТерминал");
	Иначе
		ТипОборудованияДляДрайверов = ТипыПодключаемогоОборудования.Получить("ККТ");
	КонецЕсли;
	
	СписокДрайверов = МенеджерОборудованияРМК.СписокДрайверов(ТипОборудованияДляДрайверов);
	
	Возврат СписокДрайверов;
	
КонецФункции

