#Область СлужебныеПроцедурыИФункцииСтраницаНастройкиПользователей
&НаСервере
Процедура ДобавитьПользователяВГруппуДоступаНаСервере(ВыбранныйПользователь, ВыбраннаяГруппа)
	
	Если ТипЗнч(ВыбранныйПользователь) = Тип("Строка")
		ИЛИ ТипЗнч(ВыбраннаяГруппа) = Тип("Строка") Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = НСтр("ru = ''");
	РезультатДобавленияВГруппуДоступа = Ложь;
	ОбщегоНазначенияРМКПереопределяемый.ДобавитьПользователяВГруппуДоступаПомощникРМК(ВыбранныйПользователь, ВыбраннаяГруппа, ТекстСообщения, РезультатДобавленияВГруппуДоступа);
	
	Если НЕ ПустаяСтрока(ТекстСообщения) Тогда
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	ЗаполнитьДеревоГруппыДоступа();
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПользователяОповещениеОЗакрытииВопроса(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	ПрофильКассира = Ложь;
	ОбщегоНазначенияРМККлиентПереопределяемый.ПроверитьПринадлежностьКПрофилюКассир(ДополнительныеПараметры.ВыбраннаяГруппа,ПрофильКассира);
	Если ПрофильКассира
		И Не ЗначениеЗаполнено(ДополнительныеПараметры.КодСотрудника) Тогда
		СтруктураОткрытияФормы = Новый Структура("ГруппаДоступа, Пользователь, Кассир", 
			ДополнительныеПараметры.ВыбраннаяГруппа, ДополнительныеПараметры.ВыбранныйПользователь, ДополнительныеПараметры.ВыбранныйКассир);
		ДобавитьПользователяВГруппуДоступаИПрисвоитьКод(СтруктураОткрытияФормы);
	Иначе
		ДобавитьПользователяВГруппуДоступаНаСервере(ДополнительныеПараметры.ВыбранныйПользователь, ДополнительныеПараметры.ВыбраннаяГруппа);
	КонецЕсли;
	
	ВыбраннаяГруппаДоступа = ДополнительныеПараметры.ВыбраннаяГруппа;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПользователяВГруппуДоступа(Команда)
	ДобавитьПользователяВГруппуДоступаКоманда();
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПользователяВГруппуДоступаКоманда()
	ТекущаяСтрокаПользователь = Элементы.ТаблицаПользователей.ТекущиеДанные;
	ВыбранныйПользователь = ТекущаяСтрокаПользователь.Пользователь;
	ВыбранныйКассир = ТекущаяСтрокаПользователь.Кассир;
	ТекущаяСтрокаГруппаДоступа = Элементы.ДеревоГруппДоступа.ТекущиеДанные;
	ВыбраннаяГруппа = ТекущаяСтрокаГруппаДоступа.ГруппаДоступа;
	
	ТекстВопроса = НСтр("ru = 'Добавить пользователя %1 в группу доступа %2?'");
	ДополнительныеПараметрыВопроса = Новый Структура;
	ДополнительныеПараметрыВопроса.Вставить("ВыбранныйПользователь", ВыбранныйПользователь);
	ДополнительныеПараметрыВопроса.Вставить("ВыбранныйКассир", ВыбранныйКассир);
	ДополнительныеПараметрыВопроса.Вставить("ВыбраннаяГруппа", ВыбраннаяГруппа);
	ДополнительныеПараметрыВопроса.Вставить("КодСотрудника", ТекущаяСтрокаПользователь.ПерсональныйКод);
	ОповещениеОЗакрытииВопроса = Новый ОписаниеОповещения("ДобавитьПользователяОповещениеОЗакрытииВопроса",ЭтаФорма, ДополнительныеПараметрыВопроса);
	СписокЗначенийОтветы = Новый СписокЗначений;
	СписокЗначенийОтветы.Добавить(КодВозвратаДиалога.Да, НСтр("ru= 'Добавить'"));
	СписокЗначенийОтветы.Добавить(КодВозвратаДиалога.Нет, НСтр("ru= 'Отменить'"));
	ПоказатьВопрос(ОповещениеОЗакрытииВопроса, СтрШаблон(ТекстВопроса, ВыбранныйПользователь, ВыбраннаяГруппа),СписокЗначенийОтветы);
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПользователяВГруппуДоступаИПрисвоитьКод(СтруктураОткрытияФормы)
	
	ОбработкаОповещенияЗакрытияФормы = Новый ОписаниеОповещения("ПерезаполнитьСпискиГрупп", ЭтаФорма);
	ОткрытьФорму("Обработка.ПомощникНастройкиКассовогоМестаРМК.Форма.ФормаКодаДоступа",
		СтруктураОткрытияФормы, ЭтаФорма, Новый УникальныйИдентификатор, , , ОбработкаОповещенияЗакрытияФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

