&НаКлиенте
Процедура ИзменитьПорядокСтраницНастроек(ИмяСтраницы, ВключитьВНастройки, ИмяТекущейСтраницы)
	
	ЭлементСписка = СписокИменСтраниц.НайтиПоЗначению(ИмяСтраницы);
	Если НЕ ВключитьВНастройки Тогда
		
		Если НЕ ЭлементСписка = Неопределено Тогда
			СписокИменСтраниц.Удалить(ЭлементСписка)
		КонецЕсли;
		
	Иначе
		
		Если ЭлементСписка = Неопределено Тогда
			
			ИндексСтраницы = СписокИменСтраниц.Индекс(СписокИменСтраниц.НайтиПоЗначению(ИмяТекущейСтраницы));
			СписокИменСтраниц.Вставить(ИндексСтраницы + 1, ИмяСтраницы);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

