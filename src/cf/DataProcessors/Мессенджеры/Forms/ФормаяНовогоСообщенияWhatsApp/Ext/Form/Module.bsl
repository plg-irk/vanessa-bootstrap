
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТипВнешнейСистемы = Параметры.ТипВнешнейСистемы;
	ФормаОткрытаИзОбсуждения = Параметры.ФормаОткрытаИзОбсуждения;
	ОбнаруженаОшибка = Параметры.ОбнаруженаОшибка; 
	
	ИдентификаторОбсуждения = Параметры.ИдентификаторОбсуждения;
	ВнешнийИдентификатор = Параметры.ВнешнийИдентификатор;
	ИдентификаторИнтеграции = Параметры.ИдентификаторИнтеграции;
		
	Элементы.ТекстОшибки.Заголовок = Параметры.ТекстОшибки;
	
 	Элементы.ПанельОшибки.Видимость = ОбнаруженаОшибка;
	Элементы.ГруппаСтраницы.Доступность = Не ОбнаруженаОшибка;
	Элементы.ФормаОтправитьСообщение.Доступность = Не ОбнаруженаОшибка;	

	Если ОбнаруженаОшибка Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторАвторизованногоПользователя = Обсуждения.ПользовательСистемыВзаимодействия(
		Пользователи.АвторизованныйПользователь(), Истина);

	Если ФормаОткрытаИзОбсуждения Тогда
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
		ИдентификаторИнтеграции = Обсуждение.Интеграция;
	Иначе

		Если ИдентификаторОбсуждения <> Неопределено Тогда
			
			УстановитьПривилегированныйРежим(Истина);
			
			Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
			НавигационнаяСсылкаОбсуждения = ПолучитьНавигационнуюСсылку(Обсуждение);
			
			ГраницаДатыПроизвольногоОтвета = СистемаВзаимодействия.ПолучитьВремяОкончанияДоступностиОтвета(
				ИдентификаторОбсуждения);
			
			УстановитьПривилегированныйРежим(Ложь);
			
		КонецЕсли;
		
	КонецЕсли;
	
	ЗаполнитьШаблоны();
	ЗаполнитьПодстановки();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	Если ОбнаруженаОшибка Тогда
		Возврат;
	КонецЕсли;
	
	ДатаСеанса = ОбщегоНазначенияКлиент.ДатаСеанса();
	
	Если Не ФормаОткрытаИзОбсуждения И ИдентификаторОбсуждения <> Неопределено
		И ДатаСеанса < ГраницаДатыПроизвольногоОтвета И Не ПустаяСтрока(НавигационнаяСсылкаОбсуждения) Тогда
			
		ДобавитьПользователяВОбсуждение(ИдентификаторОбсуждения, ИдентификаторАвторизованногоПользователя);
		ПерейтиПоНавигационнойСсылке(НавигационнаяСсылкаОбсуждения);
		Закрыть();
		
	КонецЕсли;
	
	ОбновитьПросмотр();
	АктивироватьКнопки();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ШаблонПриИзменении(Элемент)

	ЗаполнитьПодстановки();

	ОбновитьПросмотр();
	АктивироватьКнопки();
	
КонецПроцедуры

&НаКлиенте
Процедура ТекстОшибкиОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки,
	СтандартнаяОбработка)
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "НастроитьИнтеграцию"
		Или НавигационнаяСсылкаФорматированнойСтроки = "ПодключитьОбсуждения" Тогда
			
		СтандартнаяОбработка = Ложь;
		ОткрытьФорму("Обработка.ПанельАдминистрированияИнтеграцийУНФ.Форма.ЧатИнтеграцияСМессенджерами");
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОтправитьСообщение(Команда)

	ОтправитьСообщениеНаСервере();

	Если Не ПустаяСтрока(НавигационнаяСсылкаОбсуждения) Тогда
		ПоказатьОповещениеПользователя(НСтр("ru='Отправлено'"), НавигационнаяСсылкаОбсуждения,
			НСтр("ru='Открыть обсуждение'"), БиблиотекаКартинок.Готово);
	КонецЕсли;
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПодстановкиПриИзменении(Элемент)
	
	ОбновитьПросмотр();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Добавляет пользователя в список участников обсуждения.
// 
// Параметры: 
//  ИдентификаторОбсуждения - ИдентификаторОбсужденияСистемыВзаимодействия
//  АвторизованныйПользователь - ИдентификаторПользователяСистемыВзаимодействия
&НаСервереБезКонтекста
Процедура ДобавитьПользователяВОбсуждение(Знач ИдентификаторОбсуждения, Знач АвторизованныйПользователь)

	УстановитьПривилегированныйРежим(Истина);
	Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
		
	ПользовательЯвляетсяУчастникомОбсуждения = Обсуждение.Участники.Содержит(
		АвторизованныйПользователь);
	
	Если ПользовательЯвляетсяУчастникомОбсуждения Тогда
		Возврат;
	КонецЕсли;
	
	Обсуждение.Участники.Добавить(АвторизованныйПользователь);
	Обсуждение.Записать();	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПросмотр()
	
	Если Шаблон <> Неопределено Тогда
		
		ЗначенияПодстановок = Новый Массив;
		Для Каждого Подстановка Из Подстановки Цикл
			ЗначенияПодстановок.Добавить(Подстановка.Значение);
		КонецЦикла;
		
		Результат = Шаблон.ПолучитьТекстСПодстановками(ЗначенияПодстановок);
	Иначе
		Результат = СтроковыефункцииКлиент.ФорматированнаяСтрока("");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АктивироватьКнопки()
	
	ТекущаяДатаСеансаКлиент = ОбщегоНазначенияКлиент.ДатаСеанса();
	
	ЭтоВводПроизвольногоТекста = Не ФормаОткрытаИзОбсуждения 
		И ТекущаяДатаСеансаКлиент <= ГраницаДатыПроизвольногоОтвета;
	Элементы.ФормаОтправитьСообщение.Доступность = ЭтоВводПроизвольногоТекста Или Шаблон <> Неопределено;
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьСообщениеНаСервере()

	УстановитьПривилегированныйРежим(Истина);
		
	Если ФормаОткрытаИзОбсуждения Тогда
		
		Сообщение = СистемаВзаимодействия.СоздатьСообщение(ИдентификаторОбсуждения);
		Сообщение.ШаблонСообщения = Шаблон.Идентификатор;
		
		Для Каждого Подстановка Из Подстановки Цикл
			Сообщение.ЗначенияПодстановокШаблонаСообщения.Добавить(Подстановка.Значение);
		КонецЦикла;
		
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
		
		ОтправитьСообщениеВОбсуждение(Обсуждение, Сообщение, ИдентификаторАвторизованногоПользователя);
		Возврат;
		
	КонецЕсли;
	
	Если ИдентификаторОбсуждения <> Неопределено Тогда
		
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
		ДобавитьПользователяВОбсуждение(Обсуждение.Идентификатор, ИдентификаторАвторизованногоПользователя);
		
	Иначе
		
		Обсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
		Обсуждение.Интеграция = ИдентификаторИнтеграции;
		Обсуждение.ВнешнийИдентификатор = ВнешнийИдентификатор;
		
		ИнтеграцияСистемыВзаимодействия = СистемаВзаимодействия.ПолучитьИнтеграцию(ИдентификаторИнтеграции);		
		Для Каждого УчастникИнтеграции Из ИнтеграцияСистемыВзаимодействия.Участники Цикл
			Обсуждение.Участники.Добавить(УчастникИнтеграции);
		КонецЦикла;
		
		Обсуждение.Записать();
		
	КонецЕсли;

	Сообщение = СистемаВзаимодействия.СоздатьСообщение(Обсуждение.Идентификатор);
	Сообщение.ШаблонСообщения = Шаблон.Идентификатор;
	
	Для Каждого Подстановка Из Подстановки Цикл
		Сообщение.ЗначенияПодстановокШаблонаСообщения.Добавить(Подстановка.Значение);
	КонецЦикла;
	
	ОтправитьСообщениеВОбсуждение(Обсуждение, Сообщение, ИдентификаторАвторизованногоПользователя);
	НавигационнаяСсылкаОбсуждения = ПолучитьНавигационнуюСсылку(Обсуждение);
КонецПроцедуры

// Отправляет сообщение в указанное обсуждение.
// 
// Параметры:
//  Обсуждение  - ОбсуждениеСистемыВзаимодействия
//  Сообщение  - СообщениеСистемыВзаимодействия
//  ИдентификаторАвторизованногоПользователя - ИдентификаторПользователяСистемыВзаимодействия - Идентификатор
//     авторизованного пользователя
&НаСервере
Процедура ОтправитьСообщениеВОбсуждение(Обсуждение, Сообщение, ИдентификаторАвторизованногоПользователя)
	
	УстановленРежимНаблюдения = СистемаВзаимодействия.ПолучитьРежимНаблюдения(Обсуждение.Идентификатор, 
		ИдентификаторАвторизованногоПользователя);

	Если УстановленРежимНаблюдения Тогда
		СистемаВзаимодействия.УстановитьРежимНаблюдения(Обсуждение.Идентификатор, Ложь,
			ИдентификаторАвторизованногоПользователя);
	КонецЕсли;	

	Сообщение.Записать();

	Если УстановленРежимНаблюдения Тогда
		СистемаВзаимодействия.УстановитьРежимНаблюдения(Обсуждение.Идентификатор, Истина,
			ИдентификаторАвторизованногоПользователя);
	КонецЕсли;
	
	ИмяСобытия = МессенджерыКлиентСервер.ИмяСобытияЖурналаРегистрации();
	ТекстКомментария = СтрШаблон("%1 %2",
		НСтр("ru='Отправлено сообщение в интеграцию WhatsApp. Идентификатор сообщения:'"),
		Строка(Сообщение.Идентификатор));
	ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация, , ,
		ТекстКомментария);
	
КонецПроцедуры

&НаСервере
Процедура СоздатьЭлементыПодстановок()
	
	ИндексПодстановки = 0;
	
	Пока Истина Цикл
		
		ЭлементПодстановки = Элементы.Найти(
			СтрШаблон("ПолеВводаПодстановки_%1", ИндексПодстановки));
		Если ЭлементПодстановки = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		Элементы.Удалить(ЭлементПодстановки);
		ИндексПодстановки = ИндексПодстановки + 1;
		
	КонецЦикла;

	Для ИндексПодстановки = 0 По Подстановки.Количество() - 1 Цикл
		
		ЭлементПодстановки = Элементы.Добавить(
			СтрШаблон("ПолеВводаПодстановки_%1", ИндексПодстановки),
			Тип("ПолеФормы"), Элементы.ГруппаПодстановки);
			
		ЭлементПодстановки.Вид = ВидПоляФормы.ПолеВвода;
		ЭлементПодстановки.ПутьКДанным = СтрШаблон("Подстановки[%1].Значение",
			Формат(ИндексПодстановки, "ЧН=0; ЧГ=0"));
		ЭлементПодстановки.Заголовок = Подстановки[ИндексПодстановки].Имя;
		ЭлементПодстановки.УстановитьДействие("ПриИзменении", "Подключаемый_ПодстановкиПриИзменении");
		ЭлементПодстановки.АвтоМаксимальнаяШирина = Ложь;
		ЭлементПодстановки.РастягиватьПоГоризонтали = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьШаблоны()
	
	Если ИдентификаторИнтеграции = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ШаблоныОбсуждения = СистемаВзаимодействия.ПолучитьШаблоныСообщения(ИдентификаторИнтеграции);
	Для Каждого ШаблонОбсуждения Из ШаблоныОбсуждения Цикл
		
		ПредставлениеШаблона = ШаблонОбсуждения.Представление;
		Если ПредставлениеШаблона = "" Тогда
			ПредставлениеШаблона = ШаблонОбсуждения.Имя;
			Если ШаблонОбсуждения.КодЯзыка <> "" Тогда
				ПредставлениеШаблона = СтрШаблон("%1 (%2)", ПредставлениеШаблона, ШаблонОбсуждения.КодЯзыка);
			КонецЕсли;
		КонецЕсли;
		
		Элементы.Шаблон.СписокВыбора.Добавить(Строка(ШаблонОбсуждения.Идентификатор), ПредставлениеШаблона);
		
	КонецЦикла;
	
	Если ШаблоныОбсуждения.Количество() = 1 Тогда
		ИдентификаторШаблона = ШаблоныОбсуждения[0].Идентификатор;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПодстановки()

	Подстановки.Очистить();
	
	Если ИдентификаторШаблона = "" Тогда
		Шаблон = Неопределено;
	Иначе
		ИдентификаторШаблонаСВ = Новый ИдентификаторШаблонаСообщенияСистемыВзаимодействия(ИдентификаторШаблона);
		Шаблон = СистемаВзаимодействия.ПолучитьШаблонСообщения(ИдентификаторШаблонаСВ);
		Для ИндексПодстановки = 0 To Шаблон.ПредставленияПодстановок.Количество() - 1 Цикл
			НоваяПодстановка = Подстановки.Добавить();
			НоваяПодстановка.Имя = Шаблон.ПредставленияПодстановок[ИндексПодстановки];
			Если НоваяПодстановка.Имя = "" Тогда
				НоваяПодстановка.Имя = ИндексПодстановки + 1;
			КонецЕсли;
		КонецЦикла;                                                      
	КонецЕсли;
	
	СоздатьЭлементыПодстановок();
	
КонецПроцедуры

#КонецОбласти
