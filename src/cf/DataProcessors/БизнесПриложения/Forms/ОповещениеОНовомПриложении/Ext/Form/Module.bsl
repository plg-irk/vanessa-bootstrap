
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбработатьПараметры(Параметры);
	ЗаполнитьОбычныеРеквизиты();
	
	ОбновитьИнтерфейсФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура ОбновитьИнтерфейсКоманда(Команда)
	
	Если ЕстьОткрытыеОкна() Тогда
		
		ОтветПользователя = Ждать ВопросАсинх(
		НСтр("ru = 'Для обновления будут закрыты все открытые формы. Продолжить?'"),
		РежимДиалогаВопрос.ОКОтмена);
		
		Если ОтветПользователя <> КодВозвратаДиалога.ОК Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьИнтерфейсНаСервере();
	ОбновитьИнтерфейс();
	ЗакрытьВсеОкна();
	
	ПоказатьОповещениеПользователя(, , НСтр("ru = 'Приложение успешно обновлено'"), БиблиотекаКартинок.Информация32);
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура НапомнитьЧерез(Команда)
	
	ВыборПользователя = Ждать ВыбратьИзМенюАсинх(СписокВыбораНапоминания, Элементы.НапомнитьЧерез);
	Если ВыборПользователя = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НапомнитьНаСервере(ДанныеПриложения.Синоним, ВыборПользователя.Значение);
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработкаСобытийФормы

&НаСервере
Процедура ОбработатьПараметры(Параметры)
	
	ОписаниеПриложения = Параметры.ОписаниеПриложения;
	ДополнительнаяИнформация = ТарификацияБизнесКлиентСервер.ДополнительныеДанныеПриложения(ОписаниеПриложения.Имя);
	
	ДанныеПриложения = Новый Структура("Синоним,Описание,Картинка,СсылкаНаСайт");
	ЗаполнитьЗначенияСвойств(ДанныеПриложения, ОписаниеПриложения, "Синоним");
	ЗаполнитьЗначенияСвойств(ДанныеПриложения, ДополнительнаяИнформация, "Описание,Картинка,СсылкаНаСайт");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОбычныеРеквизиты()
	
	СписокВыбораНапоминания.Очистить();
	СписокВыбораНапоминания.Добавить(60 * 5, НСтр("ru = '5 минут'"));
	СписокВыбораНапоминания.Добавить(60 * 15, НСтр("ru = '15 минут'"));
	СписокВыбораНапоминания.Добавить(60 * 30, НСтр("ru = '30 минут'"));
	СписокВыбораНапоминания.Добавить(60 * 60, НСтр("ru = '1 час'"));
	СписокВыбораНапоминания.Добавить(60 * 60 * 2, НСтр("ru = '2 часа'"));
	СписокВыбораНапоминания.Добавить(60 * 60 * 4, НСтр("ru = '4 часа'"));
	
КонецПроцедуры

#КонецОбласти

#Область Интерфейс

&НаСервере
Процедура ОбновитьИнтерфейсФормы()
	
	Элементы.КартинкаПриложения.Картинка = ДанныеПриложения.Картинка;
	Элементы.НазваниеПриложения.Заголовок = ДанныеПриложения.Синоним;
	
	Если ЗначениеЗаполнено(ДанныеПриложения.СсылкаНаСайт) Тогда
		Описание = СтроковыеФункции.ФорматированнаяСтрока(
		НСтр("ru = '%1. <a href=""%2"">Подробнее</a>'"), ДанныеПриложения.Описание, ДанныеПриложения.СсылкаНаСайт);
	Иначе
		Описание = ДанныеПриложения.Описание;
	КонецЕсли;
	
	Элементы.ОписаниеПриложения.Заголовок = Описание;
	
КонецПроцедуры

#КонецОбласти

#Область ЗавершениеРаботыНаФорме

&НаКлиенте
Функция ЕстьОткрытыеОкна()
	
	Окна = ПолучитьОкна();
	Для Каждого ОкноПриложения Из Окна Цикл
		Форма = ОкноПриложения.ПолучитьСодержимое();
		Если Форма <> Неопределено И Форма <> ЭтотОбъект Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура ЗакрытьВсеОкна()
	
	Окна = ПолучитьОкна();
	Для Каждого ОкноПриложения Из Окна Цикл
		Форма = ОкноПриложения.ПолучитьСодержимое();
		Если Форма <> Неопределено Тогда
			Форма.Модифицированность = Ложь;
			Форма.Закрыть();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбновитьИнтерфейсНаСервере()
	
	РабочийСтолУНФ.УстановитьНачальнуюСтраницуИИнтерфейс(, Истина);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура НапомнитьНаСервере(Знач СинонимПриложения, Знач ЧерезСколькоНапомнить)
	
	ВремяНапоминания = ТекущаяДатаСеанса() + ЧерезСколькоНапомнить;
	ТекстНапоминания = СтрШаблон(
	НСтр("ru = 'Подключено новое приложение ""%1"". Перезапустите программу для обновления.'"),
	СинонимПриложения);
	
	НапоминанияПользователя.УстановитьНапоминание(ТекстНапоминания, ВремяНапоминания);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти