#Область ОписаниеПеременных

&НаКлиенте
Перем ЗакрытьССохранением; // Сохранить значение при закрытии формы

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	ОбновитьТекстДекорации();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗакрытьССохранением = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если НЕ ЗавершениеРаботы И ЗакрытьССохранением И ЗапомнитьВыбранноеЗначение Тогда
		СохранитьНастройку();
		ОбновитьПовторноИспользуемыеЗначения();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ЗапомнитьВыбранноеЗначениеПриИзменении(Элемент)
	
	//Элементы.ДекорацияПодсказка.Видимость = ЗапомнитьВыбранноеЗначение;
	СтатистикаИспользованияФормКлиент.ПриИнтерактивномДействии(ЭтотОбъект, Элементы.ЗапомнитьВыбранноеЗначение, "ПриИзменении");
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантРаспределенияПриИзменении(Элемент)
	
	Если НастройкаРаспределенияКорректировки = 1 Тогда
		КорректировкаСуммыЗаСчетРучнойСкидки = Истина;
	Иначе
		КорректировкаСуммыЗаСчетРучнойСкидки = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Применить(Команда)
	
	ЗакрытьССохранением = Истина;
	ЗаписатьИЗакрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Процедура ОбновитьТекстДекорации()

	НастройкиРаспределения = ДокументыУНФКлиентСервер.ПараметрыИзмененияСуммыДокумента();
	ДокументыУНФ.ЗаполнитьНастройкиИзмененияСуммыДокумента(НастройкиРаспределения);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НастройкиРаспределения);
	
	Если КорректировкаСуммыЗаСчетРучнойСкидки Тогда
		НастройкаРаспределенияКорректировки = 1;
	Иначе
		НастройкаРаспределенияКорректировки = 0;
	КонецЕсли;	

КонецПроцедуры

&НаСервере
Процедура СохранитьНастройку()
	
	НазваниеНастройки = "ВариантИзмененияСуммыДокумента";
	Если НастройкаРаспределенияКорректировки = 0 Тогда
		ЗначениеНастройки = Перечисления.ВариантыИзмененияСуммыДокумента.ЗаСчетЦены;
	Иначе
		ЗначениеНастройки = Перечисления.ВариантыИзмененияСуммыДокумента.ЗаСчетРучнойСкидки;
	КонецЕсли;
	
	ПерсональныеНастройкиРУНФ.Установить(ЗначениеНастройки, НазваниеНастройки);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьИЗакрыть()
	
	НастройкаКоличества = Новый Структура();	
	НастройкаКоличества.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", КорректировкаСуммыЗаСчетРучнойСкидки);
	НастройкаКоличества.Вставить("ЗапрашиватьВариантКорректировкиСуммы", НЕ ЗапомнитьВыбранноеЗначение);	
	Закрыть(НастройкаКоличества);

КонецПроцедуры

#КонецОбласти
