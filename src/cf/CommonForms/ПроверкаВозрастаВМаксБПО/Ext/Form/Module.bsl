#Область ОписаниеПеременных

&НаКлиенте
Перем РазрешеноЗакрытиеФормы;
&НаКлиенте
Перем Штрихкод;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	РежимКСО = Параметры.РежимКСО;
	ТокенОрганизации = Параметры.ТокенОрганизации;
	ОтображатьQRКодНаДисплееПокупателя = Параметры.ОтображатьQRКодНаДисплееПокупателя;
	
	ТипыОборудования = МенеджерОборудованияКлиентСервер.ПараметрыТипыОборудования();
	ТипыОборудования.СканерШтрихкода = Истина;
	Если ОтображатьQRКодНаДисплееПокупателя Тогда
		ТипыОборудования.ДисплейПокупателя = Истина;
	КонецЕсли;
	МенеджерОборудования.ПриСозданииНаСервере(ЭтотОбъект, ТипыОборудования);
	
	Если РежимКСО Тогда
		Элементы.ГруппаРежимКСО.Видимость = Истина;
		Элементы.ГруппаРежимКассир.Видимость = Ложь;
	Иначе
		Элементы.ГруппаРежимКСО.Видимость = Ложь;
		Элементы.ГруппаРежимКассир.Видимость = Истина;
	КонецЕсли;
	
	МенеджерОборудованияВызовСервераПереопределяемый.ПроверкаВозрастаМаксПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПодключитьОбработчикОжидания("ПодключениеОборудованияПриОткрытии", 0.1, Истина);
	РазрешеноЗакрытиеФормы = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не РазрешеноЗакрытиеФормы Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	МенеджерОборудованияКлиент.ОтключитьОборудованиеПриЗакрытииФормыАсинх(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			
			Штрихкод = Параметр[0];
			ПодключитьОбработчикОжидания("ЗакрытьФормуПослеПроверки", 0.1, Истина);
			
		ИначеЕсли ИмяСобытия = "ScanDataBase64" Тогда
			
			ШтрихкодBase64 = ?(Параметр[1] = Неопределено, Параметр[0], Параметр[1][1]);
			Штрихкод = МенеджерОборудованияКлиентСервер.Base64ВШтрихкод(ШтрихкодBase64);
			ПодключитьОбработчикОжидания("ЗакрытьФормуПослеПроверки", 0.1, Истина);
			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Отмена(Команда)
	
	Результат = МенеджерОборудованияКлиент.РезультатПроверкиВозрастаВМакс();
	Результат.Результат = МенеджерОборудованияКлиент.ТипРезультатаПроверкиВозрастаВМакс().Отмена;
	РазрешеноЗакрытиеФормы = Истина;
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ПозватьСотрудника(Команда)
	
	Результат = МенеджерОборудованияКлиент.РезультатПроверкиВозрастаВМакс();
	Результат.Результат = МенеджерОборудованияКлиент.ТипРезультатаПроверкиВозрастаВМакс().ПозватьСотрудника;
	РазрешеноЗакрытиеФормы = Истина;
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	
	РазрешеноЗакрытиеФормы = Истина;
	МенеджерОборудованияКлиентПереопределяемый.ПриВыполненииКомандыНаФормеПроверкиВозрастаВМакс(ЭтотОбъект, Команда);
	
КонецПроцедуры

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Асинх Процедура ПодключениеОборудованияПриОткрытии()
	
	РезультатыПодключения = Ждать МенеджерОборудованияКлиент.ПодключитьОборудованиеПриОткрытииФормыАсинх(ЭтотОбъект);
	Если ОтображатьQRКодНаДисплееПокупателя Тогда
		ПараметрыОперации = ОборудованиеДисплеиПокупателяКлиент.ПараметрыОперацииДисплейПокупателя();
		ПараметрыОперации.Операция = "ПроверкаВозраста";
		ОборудованиеДисплеиПокупателяКлиент.НачатьОтображениеИнформацииНаДисплейПокупателя(,УникальныйИдентификатор,,ПараметрыОперации);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьВозраст(Команда)
	
	Результат = МенеджерОборудованияКлиент.РезультатПроверкиВозрастаВМакс();
	Результат.Результат = МенеджерОборудованияКлиент.ТипРезультатаПроверкиВозрастаВМакс().ВозрастПодтвержден;
	РазрешеноЗакрытиеФормы = Истина;
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФормуПослеПроверки()
	
	Результат = МенеджерОборудованияКлиент.ПроверитьВозраст(Штрихкод, ТокенОрганизации);
	РазрешеноЗакрытиеФормы = Истина;
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти





