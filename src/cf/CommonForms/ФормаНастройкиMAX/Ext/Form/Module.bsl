
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначенияРМКПереопределяемый.ПриСозданииНаСервере(ЭтотОбъект, Отказ, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если Не ПустаяСтрока(ТекстОшибкиОткрытияФормы) Тогда
		ПоказатьПредупреждение( , ТекстОшибкиОткрытияФормы);
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Модифицированность Тогда
		Отказ = Истина;
		ОповещенияОЗавершении = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);
		
		КнопкиВопроса = Новый СписокЗначений;
		КнопкиВопроса.Добавить(КодВозвратаДиалога.Да, НСтр("ru='Сохранить'"));
		КнопкиВопроса.Добавить(КодВозвратаДиалога.Нет, НСтр("ru='Отмена'"));
		
		ПоказатьВопрос(ОповещенияОЗавершении,
			НСтр("ru = 'Сохранить параметры подключения?'"),
			КнопкиВопроса, 0, КодВозвратаДиалога.Да);
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТокенПриИзменении(Элемент)
	ПараметрыПодключенияMAX[0].ЕстьИзменения = Истина;
	Модифицированность = Истина;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПараметрыПодключенияMAX

&НаКлиенте
Процедура ПараметрыПодключенияMAXПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Модифицированность = Истина;
	ТекущиеДанные = Элементы.ПараметрыПодключенияMAX.ТекущиеДанные;
	Если Копирование И ТекущиеДанные <> Неопределено Тогда
		Отказ = Истина;
		НовыйПараметрПодключенияMAX = ПараметрыПодключенияMAX.Добавить();
		НовыйПараметрПодключенияMAX.ЕстьИзменения = Истина;
		НовыйПараметрПодключенияMAX.Токен = ТекущиеДанные.Токен;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыПодключенияMAXПередУдалением(Элемент, Отказ)
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыПодключенияMAXОрганизацияПриИзменении(Элемент)
	
	Модифицированность = Истина;
	ТекущиеДанные = Элементы.ПараметрыПодключенияMAX.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ТекущиеДанные.ЕстьИзменения = Истина;
	
	НайденныеПараметры = ПараметрыПодключенияMAX.НайтиСтроки(
		Новый Структура("Организация", ТекущиеДанные.Организация));
		
	Если НайденныеПараметры.Количество() > 1 Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru='Организация ""%1"" уже выбрана.'"),
			Строка(ТекущиеДанные.Организация));
		ТекущиеДанные.Организация = Неопределено;
		ПоказатьПредупреждение( , ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПараметрыПодключенияMAXТокенПриИзменении(Элемент)
	
	Модифицированность = Истина;
	ТекущиеДанные = Элементы.ПараметрыПодключенияMAX.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекущиеДанные.ЕстьИзменения = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СохранитьИзменения(Команда)
	Если Модифицированность Тогда
		Отказ = Ложь;
		СохранитьИзмененияНаСервере(Отказ);
		Если Не Отказ Тогда
			Закрыть();
		КонецЕсли;
	Иначе
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПечатьИнструкцииПокупателей(Команда)
	ИдентификаторПечатнойФормы = "ИнструкцияПокупателейMAX";
	МодульУправлениеПечатьюКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("УправлениеПечатьюКлиент");
	КоллекцияПечатныхФорм = МодульУправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(ИдентификаторПечатнойФормы);
	СформироватьИнструкциюПокупателейMAX(КоллекцияПечатныхФорм, ИдентификаторПечатнойФормы);
	ОбластиОбъектов = Новый СписокЗначений;
	МодульУправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм, ОбластиОбъектов);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		СохранитьИзмененияНаСервере(Отказ);
		Если Не Отказ Тогда
			Закрыть();
		КонецЕсли;
	Иначе
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьИзмененияНаСервере(Отказ = Ложь)
	
	ОбщегоНазначенияРМКПереопределяемый.СохранитьИзмененияПараметровПодключенияMAX(ЭтотОбъект, Отказ);
	Если Не Отказ Тогда
		Модифицированность = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СформироватьИнструкциюПокупателейMAX(КоллекцияПечатныхФорм, ИдентификаторПечатнойФормы)
	
	Макет = ОбщегоНазначенияРМК.МакетИнструкцииПокупателяMAX();
	БуферКоллекцииПечатныхФорм = ОбщегоНазначенияРМК.ПодготовитьКоллекциюПечатныхФорм(ИдентификаторПечатнойФормы);
	СинонимМакета = НСтр("ru = 'Инструкция для покупателей по MAX'");
	
	УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(БуферКоллекцииПечатныхФорм,
		"ИнструкцияПокупателейMAX",
		СинонимМакета,
		Макет);
	
	Если БуферКоллекцииПечатныхФорм.Количество() > 0
		И КоллекцияПечатныхФорм.Количество() > 0 Тогда
		ЗаполнитьЗначенияСвойств(КоллекцияПечатныхФорм[0], БуферКоллекцииПечатныхФорм[0]);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
