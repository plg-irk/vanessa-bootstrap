
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	ВерсияБПОПоддерживаетРаботуСПИоТ = ОбщегоНазначенияИСМП.ВерсияБПОПоддерживаетПроверкуКМЧерезТСПИоТ();
	
	Если ЗначениеЗаполнено(Параметры.ПодключаемоеОборудование) Тогда
		
		ПодключаемоеОборудованиеККТ                      = Параметры.ПодключаемоеОборудование;
		Элементы.ОтборПодключаемоеОборудование.Видимость = Ложь;
		Элементы.ПодключаемоеОборудование.Видимость      = Истина;
		Элементы.ФормаОбновить.Видимость                 = Ложь;
		Элементы.НадписьЛМЧЗНеНастроенПоККТ.Видимость    = Истина;
		Элементы.НадписьЛМЧЗНеНастроен.Видимость         = Ложь;
		
		ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиФормы.Нет;
		
		ПолучитьДанныеПоПодключаемомуОборудованию();
		ЗакрытьФормуПослеПроверки = Истина;
		
	Иначе
		
		Элементы.ОтборПодключаемоеОборудование.Видимость = Истина;
		Элементы.ПодключаемоеОборудование.Видимость      = Ложь;
		Элементы.ФормаОбновить.Видимость                 = Истина;
		Элементы.НадписьЛМЧЗНеНастроенПоККТ.Видимость    = Ложь;
		Элементы.НадписьЛМЧЗНеНастроен.Видимость         = Истина;
		
		ЗакрытьФормуПослеПроверки = Ложь;
		
	КонецЕсли;
	
	Если ТипЗнч(Параметры.ДанныеСтатусаТСПИоТ) = Тип("Структура") Тогда
		
		КонструкторДанных = ИнтеграцияТСПИоТКлиентСервер.КонструкторДаныхСтатусаТСПИоТ();
		ЗаполнитьЗначенияСвойств(КонструкторДанных, Параметры.ДанныеСтатусаТСПИоТ);
		
		ЗаполнитьДанныеСтатусаТСПИоТ(КонструкторДанных);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимостьСостоянийТСПИоТ();
	
	КонструкторДанных = ИнтеграцияТСПИоТКлиентСервер.КонструкторДаныхСтатусаТСПИоТ();
	ЗаполнитьЗначенияСвойств(КонструкторДанных, ЭтотОбъект);
	
	Если ЗначениеЗаполнено(ПодключаемоеОборудованиеККТ)
		И ВерсияБПОПоддерживаетРаботуСПИоТ
		И НастроенВнутреннийТСПИоТ
		И Не ИнтеграцияТСПИоТКлиентСервер.ПроверкаГотовностиТСПИоТаКПроверкеКМ(КонструкторДанных) Тогда
		
		ПодключитьОбработчикОжидания("ПроверкаСтатусаГотовностиТСПИоТ", 0.1, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НадписьЛМЧЗНеНастроенОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "ПодключитьЛокальныйМодуль" Тогда
		
		СтруктураЗаполнения = Новый Структура("Организация, РабочееМесто, Приоритет", Организация, РабочееМесто, 0);
		Отбор               = Новый Структура("Организация, РабочееМесто, Приоритет", Организация, РабочееМесто, 0);
		
		ПослеЗакрытияФормыНастройкиПодключения = Новый ОписаниеОповещения("ПослеЗакрытияФормыНастройкиПодключенияЛокальногоМодуля", ЭтотОбъект);
		
		МодульОбменДанными = ОбщегоНазначенияБПОКлиент.ОбщийМодуль("ОбменДаннымиКлиент");
		МодульОбменДанными.ОткрытьФормуЗаписиРегистраСведенийПоОтбору(Отбор,
			СтруктураЗаполнения,
			"НастройкиПодключенияЛокальныхМодулейИСМП",
			ЭтотОбъект,
			,,
			ПослеЗакрытияФормыНастройкиПодключения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НадписьДействуетАварийныйРежимОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "СрокДействияАварийногоРежима" Тогда
		
		ПослеЗакрытияФормы   = Новый ОписаниеОповещения("ПослеОбработкиФормыУточненияАварийногоРежима", ЭтотОбъект);
	
		ОткрытьФорму("ОбщаяФорма.АварийныйРежимИСМП", 
			Новый Структура("АварийныйРежимВключен, АварийныйРежимДо", Истина, МестноеВремя(АварийныйРежимДо)),
			,,,,
			ПослеЗакрытияФормы,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НадписьСтатусТСПИоТНеГотовОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "ПоказатьПолноеОписаниеОшибкиПодключения" Тогда
		
		ПослеПросмотраТекстаОбщейОшибки = Новый ОписаниеОповещения("ПослеПросмотраТекстаОбщейОшибки", ЭтотОбъект);
		ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияМногострочногоТекста(ПослеПросмотраТекстаОбщейОшибки, ТекстОбщейОшибки, НСтр("ru = 'Описание ошибки'"));
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПодключаемоеОборудованиеПриИзменении(Элемент)
	
	ПолучитьДанныеПоПодключаемомуОборудованию();
	
	КонструкторДанных = ИнтеграцияТСПИоТКлиентСервер.КонструкторДаныхСтатусаТСПИоТ();
	ЗаполнитьЗначенияСвойств(КонструкторДанных, ЭтотОбъект);
	
	Если ЗначениеЗаполнено(ПодключаемоеОборудованиеККТ)
		И ВерсияБПОПоддерживаетРаботуСПИоТ
		И НастроенВнутреннийТСПИоТ
		И Не ИнтеграцияТСПИоТКлиентСервер.ПроверкаГотовностиТСПИоТаКПроверкеКМ(КонструкторДанных) Тогда
		
		ПодключитьОбработчикОжидания("ПроверкаСтатусаГотовностиТСПИоТ", 0.1, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Обновить(Команда)
	
	КонструкторДанных = ИнтеграцияТСПИоТКлиентСервер.КонструкторДаныхСтатусаТСПИоТ();
	ЗаполнитьЗначенияСвойств(КонструкторДанных, ЭтотОбъект);
	
	Если ЗначениеЗаполнено(ПодключаемоеОборудованиеККТ) 
		И ВерсияБПОПоддерживаетРаботуСПИоТ
		И НастроенВнутреннийТСПИоТ
		И Не ИнтеграцияТСПИоТКлиентСервер.ПроверкаГотовностиТСПИоТаКПроверкеКМ(КонструкторДанных) Тогда
		
		ПодключитьОбработчикОжидания("ПроверкаСтатусаГотовностиТСПИоТ", 1, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьСостоянийТСПИоТ()
	
	Элементы.СтраницыАвторизацияПройдена.ТекущаяСтраница = ?(АвторизацияПройдена, Элементы.СтраницаАвторизацияПройдена, Элементы.СтраницаАвторизацияНеПройдена);
	Элементы.СтраницыРегистрацияПройдена.ТекущаяСтраница = ?(РегистрацияПройдена, Элементы.СтраницаРегистрацияПройдена, Элементы.СтраницаРегистрацияНеПройдена);
	Элементы.СтраницыГотовКПроверкеКМ.ТекущаяСтраница    = ?(ГотовКПроверкеКМ, Элементы.СтраницаГотовКПроверкеКМ, Элементы.СтраницаНеГотовКПроверкеКМ);
	
	Если Не ЛМЧЗПодключен Тогда
		Элементы.СтраницыПодключениеЛМЧЗ.ТекущаяСтраница = Элементы.СтраницаЛМЧЗНеПодключен;
	ИначеЕсли ЛМЧЗГотов Тогда
		Элементы.СтраницыПодключениеЛМЧЗ.ТекущаяСтраница = Элементы.СтраницаЛМЧЗГотов;
	Иначе
		Элементы.СтраницыПодключениеЛМЧЗ.ТекущаяСтраница = Элементы.СтраницаЛМЧЗНеГотов;
	КонецЕсли;
	
	Если АварийныйРежим Тогда
		
		СрокДействияАварийногоРежимаСтрокой = СтрШаблон(НСтр("ru = 'до %1'"), Формат(АварийныйРежимДо, "ДФ=dd.MM.yyyy;"));
		
		МассивСтрокДействиеАварийногоРежима = Новый Массив;
		МассивСтрокДействиеАварийногоРежима.Добавить(НСтр("ru = 'Включен аварийный режим. Действует'"));
		МассивСтрокДействиеАварийногоРежима.Добавить(" ");
		МассивСтрокДействиеАварийногоРежима.Добавить(Новый ФорматированнаяСтрока(СрокДействияАварийногоРежимаСтрокой,,,, "СрокДействияАварийногоРежима"));
		
		ТекстНадписьДействуетАварийныйРежим = Новый ФорматированнаяСтрока(МассивСтрокДействиеАварийногоРежима);
		
		Элементы.СтраницыСтатусТСПИоТ.ТекущаяСтраница = Элементы.СтраницаДействуетАварийныйРежим;
		Элементы.НадписьДействуетАварийныйРежим.Заголовок = ТекстНадписьДействуетАварийныйРежим;
		
	ИначеЕсли ГотовКПроверкеКМ Тогда
		Элементы.СтраницыСтатусТСПИоТ.ТекущаяСтраница = Элементы.СтраницаСтатусТСПИоТУспешен;
	ИначеЕсли ПостАварийныйРежим Тогда
		Элементы.СтраницыСтатусТСПИоТ.ТекущаяСтраница = Элементы.СтраницаДействуетПостАварийныйРежим;
	ИначеЕсли ЗначениеЗаполнено(ТекстОбщейОшибки) Тогда
		Элементы.СтраницыСтатусТСПИоТ.ТекущаяСтраница = Элементы.СтраницаСтатусТСПИоТНеУспешен;
	ИначеЕсли Не НастроенВнутреннийТСПИоТ Тогда
		Элементы.СтраницыСтатусТСПИоТ.ТекущаяСтраница = Элементы.СтраницаНеНайденТСПИоТ;
	Иначе
		Элементы.СтраницыСтатусТСПИоТ.ТекущаяСтраница = Элементы.СтраницаСтатусТСПИоТИдетНастройка;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеСтатусаТСПИоТ(КонструкторДанных)
	
	АварийныйРежим          = КонструкторДанных.АварийныйРежим;
	АварийныйРежимДо        = КонструкторДанных.АварийныйРежимДо;
	АвторизацияПройдена     = КонструкторДанных.АвторизацияПройдена;
	ГотовКПроверкеКМ        = КонструкторДанных.ГотовКПроверкеКМ;
	ГотовКПроверкеКМOnline  = КонструкторДанных.ГотовКПроверкеКМOnline;
	ГотовКПроверкеКМOffline = КонструкторДанных.ГотовКПроверкеКМOffline;
	ЛМЧЗГотов               = КонструкторДанных.ЛМЧЗГотов;
	ЛМЧЗСтатус              = КонструкторДанных.ЛМЧЗСтатус;
	ПостАварийныйРежим      = КонструкторДанных.ПостАварийныйРежим;
	РегистрацияПройдена     = КонструкторДанных.РегистрацияПройдена;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьПодключениеЛокальногоМодуля()
	
	НастройкаЛМЧЗ = ОбщегоНазначенияИСМП.НастройкиОсновногоПодключенияЛокальномуМодулюЧестныйЗнакПоОрганизацииРабочемуМесту(Организация, РабочееМесто);
	ЛМЧЗПодключен = НастройкаЛМЧЗ.НастроеноПодключение;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаСтатусаГотовностиТСПИоТ() Экспорт
	
	ОповещениеПослеВыполнения = Новый ОписаниеОповещения("ПослеПроверкиСтатусаГотовностиТСПИоТ", ЭтотОбъект);
	
	МодульМенеджерОборудованияКлиентСервер = ОбщегоНазначенияКлиент.ОбщийМодуль("МенеджерОборудованияКлиентСервер");
	ДополнительныеПараметры = МодульМенеджерОборудованияКлиентСервер.ДополнительныеПараметрыОперации(Истина);
	
	МодульОборудованиеКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ОборудованиеЧекопечатающиеУстройстваКлиент");
	МодульОборудованиеКлиент.НачатьПолучениеСтатусаПИоТ(
		ОповещениеПослеВыполнения,
		УникальныйИдентификатор,
		ПодключаемоеОборудованиеККТ,,
		ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПроверкиСтатусаГотовностиТСПИоТ(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не Результат.Результат Тогда
		// ошибка при подключении компоненты, ошибка при проверке
		
		ТекстОбщейОшибки            = Результат.ОписаниеОшибки;
		УстановитьВидимостьСостоянийТСПИоТ();
		
	ИначеЕсли Результат.Свойство("СтатусСостояния") Тогда
		
		КонструкторДанных = ИнтеграцияТСПИоТКлиентСервер.КонструкторДаныхСтатусаТСПИоТ();
		ЗаполнитьЗначенияСвойств(КонструкторДанных, Результат.СтатусСостояния);
		
		ЗаполнитьДанныеСтатусаТСПИоТ(КонструкторДанных);
		УстановитьВидимостьСостоянийТСПИоТ();
		
		Если Не ИнтеграцияТСПИоТКлиентСервер.ПроверкаГотовностиТСПИоТаКПроверкеКМ(КонструкторДанных) Тогда
			ПодключитьОбработчикОжидания("ПроверкаСтатусаГотовностиТСПИоТ", 0.5, Истина);
		ИначеЕсли ИнтеграцияТСПИоТКлиентСервер.ПроверкаГотовностиТСПИоТаКПроверкеКМ(КонструкторДанных) Тогда
			ПодключитьОбработчикОжидания("ЗакрытьПослеПереходаВСтатусГотовностиПроверкиТСПИоТ", 0.1, Истина);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыНастройкиПодключенияЛокальногоМодуля(Результат, ДополнительныеПараметры) Экспорт
	
	ПроверитьПодключениеЛокальногоМодуля();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОбработкиФормыУточненияАварийногоРежима(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Свойство("АктивностьРежима") Тогда
		
		Если Результат.АктивностьРежима Тогда
			// включение аварийного режима
			ОбщегоНазначенияИСМПВызовСервера.ВключитьАварийныйРежимРазрешительнойСистемы(Результат.СрокДействияВЧасах);
			
		Иначе
			// отключение аварийного режима
			ОбщегоНазначенияИСМПВызовСервера.ОтключитьАварийныйРежимРазрешительнойСистемы();
			
		КонецЕсли;
		
		ПараметрыАварийногоРежима = ПолучитьПараметрыАварийногоРежима();
		
		АварийныйРежим   = ПараметрыАварийногоРежима.Включено;
		АварийныйРежимДо = ПараметрыАварийногоРежима.ДатаОкончания;
		
		УстановитьВидимостьСостоянийТСПИоТ();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПараметрыАварийногоРежима()
	
	ПараметрыАварийногоРежима = ОбщегоНазначенияИСМППовтИсп.ДанныеНастройкиАварийногоРежима();
	
	Возврат ПараметрыАварийногоРежима;
	
КонецФункции

&НаКлиенте
Процедура ПослеПросмотраТекстаОбщейОшибки(Результат, ДополнительныеПараметры) Экспорт
	Возврат;
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьПослеПереходаВСтатусГотовностиПроверкиТСПИоТ() Экспорт
	
	Если Не ЗакрытьФормуПослеПроверки Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть(Истина);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеПоПодключаемомуОборудованию()
	
	СтруктураРеквизитовПодключаемогоОборудования = ОбщегоНазначенияБПО.ЗначенияРеквизитовОбъекта(ПодключаемоеОборудованиеККТ, "Организация, РабочееМесто");
	
	Организация  = СтруктураРеквизитовПодключаемогоОборудования.Организация;
	РабочееМесто = СтруктураРеквизитовПодключаемогоОборудования.РабочееМесто;
	
	ПроверитьПодключениеЛокальногоМодуля();
	
	Если Не ВерсияБПОПоддерживаетРаботуСПИоТ Тогда
		Возврат;
	КонецЕсли;
	
	МодульОборудование = ОбщегоНазначения.ОбщийМодуль("МенеджерОборудованияТСПИоТ");
	НастроенВнутреннийТСПИоТ = ЗначениеЗаполнено(МодульОборудование.ПолучитьТСПИоТ(ПодключаемоеОборудованиеККТ));
	
КонецПроцедуры

