КонецФункции

&НаКлиенте
Функция ПолучитьСтрокуУровня(СтрокиУровня, ИмяОбласти)
	
	РезультатФункции = Неопределено;
	КоличествоСтрок = СтрокиУровня.Количество();
	ИндексСтроки = 0;
	Пока ИндексСтроки < КоличествоСтрок И РезультатФункции = Неопределено Цикл
		СтрокаУровня = СтрокиУровня.Получить(ИндексСтроки);
		Если СтрокаУровня.ИмяОбласти = ИмяОбласти Тогда
			РезультатФункции = СтрокаУровня;
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Процедура СхемаФормыРМКПриНажатииКлиент(Знач EventElement)
	
	ИмяИменногоТэга = "td";
	МассивИменГрупп = Новый Массив;
	Пока Не EventElement = Неопределено Цикл
		Если Нрег(EventElement.tagName) = ИмяИменногоТэга И ЗначениеЗаполнено(EventElement.id) Тогда
			ИмяГруппы = EventElement.id;
			МассивИменГрупп.Вставить(0, ИмяГруппы);
		КонецЕсли;
		EventElement = EventElement.parentElement;
	КонецЦикла;
	КоличествоГрупп = МассивИменГрупп.Количество();
	СтрокаДерева = ?(КоличествоГрупп > 0, ДеревоОбластейФормыРМК, Неопределено);
	ИндексГруппы = 0;
	Пока ИндексГруппы < КоличествоГрупп И Не СтрокаДерева = Неопределено Цикл
		ИмяГруппы = МассивИменГрупп[ИндексГруппы];
		СтрокаДерева = ПолучитьСтрокуУровня(СтрокаДерева.ПолучитьЭлементы(), ИмяГруппы);
		ИндексГруппы = ИндексГруппы + 1;
	КонецЦикла;
	Если Не СтрокаДерева = Неопределено Тогда
		Элементы.ДеревоОбластейФормыРМК.ТекущаяСтрока = СтрокаДерева.ПолучитьИдентификатор();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура НастроитьЭлементыГруппыСМС(ДоступностьГруппыСМС)
	Элементы.ГруппаSMSПодтверждениеНиз.Доступность = ДоступностьГруппыСМС;
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоГорячиеКлавиши

&НаКлиенте
Процедура ДеревоГорячиеКлавишиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	КолонкиРеакции = Новый Массив;
	КолонкиРеакции.Добавить("ДеревоГорячиеКлавишиНомерСтроки");
	КолонкиРеакции.Добавить("ДеревоГорячиеКлавишиДействие");
	КолонкиРеакции.Добавить("ДеревоГорячиеКлавишиИмяРаздела");
	КолонкиРеакции.Добавить("ДеревоГорячиеКлавишиСостояниеНастроек");
	
	СценарийСамообслуживания = ПредопределенноеЗначение("Перечисление.СценарииИспользованияРМК.ТерминалСамообслуживания");
	СтрокаДереваГорячихКлавиш = ДеревоГорячиеКлавиши.НайтиПоИдентификатору(ВыбраннаяСтрока);
	Если СтрокаДереваГорячихКлавиш.СостояниеНастроек > ВозможныеСостоянияНастроек.НеИмеетНастроек
			И (Не КолонкиРеакции.Найти(Поле.Имя) = Неопределено
			Или НастройкаРМК.СценарийИспользования = СценарийСамообслуживания) Тогда
		ПараметрыРедактирования = ПараметрыДляРедактированияЭлементаРМК(СтрокаДереваГорячихКлавиш);
		ОписаниеОповещения = Новый ОписаниеОповещения("РедактированиеНастроекЭлементаЗавершение", ЭтотОбъект, ВыбраннаяСтрока);
		Если ПараметрыРедактирования.Настройки.Количество() > 0 Тогда
			ОткрытьФорму("Обработка.РедактированиеПанелейРМК.Форма.ФормаРедактированияПанели",
				ПараметрыРедактирования, ЭтотОбъект, , , , ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область НастройкиПерсонализации

&НаСервере
Функция ЕстьИзмененныеНастройкиЭлементаФормы(ИмяЭлемента)
	
	РезультатФункции = Ложь;
	
	ОтборСтрокНастроек = Новый Структура();
	ОтборСтрокНастроек.Вставить("ИмяЭлемента", ИмяЭлемента);
	СтрокиНастроек = НастройкиЭлементовФормыРМК.НайтиСтроки(ОтборСтрокНастроек);
	ИндексСтроки = 0;
	Пока ИндексСтроки < СтрокиНастроек.Количество() И Не РезультатФункции Цикл
		СтрокаНастройки = СтрокиНастроек[ИндексСтроки];
		Если Не СтрокаНастройки.ЗначениеСвойства = СтрокаНастройки.ЗначениеПоУмолчанию Тогда
			РезультатФункции = Истина;
		КонецЕсли;
		
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаСервере
Функция ПолучитьИндексСостоянияНастроекОбласти(ЗаголовокОбласти)

	ОтборСтрокНастроек = Новый Структура();
	ОтборСтрокНастроек.Вставить("ЗаголовокОбласти", ЗаголовокОбласти);
	СтрокиНастроекФормы = НастройкиОбластейФормыРМК.НайтиСтроки(ОтборСтрокНастроек);
	ИндексСтроки = 0;
	РезультатФункции = ?(СтрокиНастроекФормы.Количество() > 0,
		ВозможныеСостоянияНастроек.НастройкиПоУмолчанию, ВозможныеСостоянияНастроек.НеИмеетНастроек);
	
	Пока ИндексСтроки < СтрокиНастроекФормы.Количество()
				И Не РезультатФункции = ВозможныеСостоянияНастроек.НастройкиИзменены Цикл
		СтрокаНастройки = СтрокиНастроекФормы[ИндексСтроки];
		Если Не СтрокаНастройки.ЗначениеСвойства = СтрокаНастройки.ЗначениеПоУмолчанию Тогда
			РезультатФункции = ВозможныеСостоянияНастроек.НастройкиИзменены;
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Функция ПараметрыДляРедактированияОбластиРМК(ЗаголовокОбласти)
	
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("ЗаголовокОбъекта", ЗаголовокОбласти);
	РезультатФункции.Вставить("ТипОбъекта", Тип("ГруппаФормы"));
	РезультатФункции.Вставить("СценарийИспользования", НастройкаРМК.СценарийИспользования);
	ОтборСтрокНастроек = Новый Структура();
	ОтборСтрокНастроек.Вставить("ЗаголовокОбласти", ЗаголовокОбласти);
	СтрокиНастроекФормы = НастройкиОбластейФормыРМК.НайтиСтроки(ОтборСтрокНастроек);
	СоответствиеНастроек = Новый Соответствие;
	Для Каждого СтрокаНастройки Из СтрокиНастроекФормы Цикл
		ЗначенияНастройки = Новый Структура();
		ЗначенияНастройки.Вставить("ЗначениеСвойства", СтрокаНастройки.ЗначениеСвойства);
		ЗначенияНастройки.Вставить("ЗначениеПоУмолчанию", СтрокаНастройки.ЗначениеПоУмолчанию);
		СоответствиеНастроек.Вставить(СтрокаНастройки.СвойствоЭлементовОбласти, ЗначенияНастройки);
	КонецЦикла;
	РезультатФункции.Вставить("Настройки", СоответствиеНастроек);
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Функция ПолучитьСтрокуНастройкиЭлементаФормыРМК(СтрокиНастроек, СвойствоЭлементов)
	
	РезультатФункции = Неопределено;
	
	КоличествоНастроек = СтрокиНастроек.Количество();
	ИндексНастройки = 0;
	Пока ИндексНастройки < КоличествоНастроек И РезультатФункции = Неопределено Цикл
		ТекущаяСтрокаНастройки = СтрокиНастроек.Получить(ИндексНастройки);
		Если ТекущаяСтрокаНастройки.СвойствоЭлементов = СвойствоЭлементов Тогда
			РезультатФункции = ТекущаяСтрокаНастройки;
		КонецЕсли;
		ИндексНастройки = ИндексНастройки + 1;
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Функция ПараметрыДляРедактированияЭлементаРМК(СтрокаДереваГорячихКлавиш)
	
	ИмяЭлемента = СтрокаДереваГорячихКлавиш.ИмяЭлемента;
	РезультатФункции = Новый Структура;
	РезультатФункции.Вставить("ЗаголовокОбъекта", СтрокаДереваГорячихКлавиш.Действие);
	РезультатФункции.Вставить("ИмяЭлемента", ИмяЭлемента);
	РезультатФункции.Вставить("ТипОбъекта", Тип("КнопкаФормы"));
	ОтборСтрокНастроек = Новый Структура();
	ОтборСтрокНастроек.Вставить("ИмяЭлемента", ИмяЭлемента);
	СтрокиНастроек = НастройкиЭлементовФормыРМК.НайтиСтроки(ОтборСтрокНастроек);
	СоответствиеНастроек = Новый Соответствие;
	ИмяКнопкиДробногоКоличества = "ТекущийТоварУстановитьДробноеКоличество";
	СвойствоВысотаКнопки = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ВысотаКнопок");
	
	Если ЗначенияНастроекЭлементовПоУмолчанию.ИменаКвадратныхЭлементов.Найти(ИмяЭлемента) = Неопределено Тогда
		ЗначенияНастроекПоУмолчанию = ЗначенияНастроекЭлементовПоУмолчанию.Обычные;
	Иначе
		ЗначенияНастроекПоУмолчанию = ЗначенияНастроекЭлементовПоУмолчанию.Квадратные;
	КонецЕсли;
	
	ИндивидуальныеНастройкиПоУмолчанию = ЗначенияНастроекЭлементовПоУмолчанию.Индивидуальные.Получить(ИмяЭлемента);
	
	ДобавитьНастройкиЭлемента(СоответствиеНастроек, СтрокиНастроек, ЗначенияНастроекПоУмолчанию);
	Если Не ИндивидуальныеНастройкиПоУмолчанию = Неопределено Тогда
		ДобавитьНастройкиЭлемента(СоответствиеНастроек, СтрокиНастроек, ИндивидуальныеНастройкиПоУмолчанию);
	КонецЕсли;
	Если ИмяЭлемента = ИмяКнопкиДробногоКоличества
			И Не СоответствиеНастроек.Получить(СвойствоВысотаКнопки) = Неопределено Тогда
		
		СоответствиеНастроек.Удалить(СвойствоВысотаКнопки);
		
	КонецЕсли;
	РезультатФункции.Вставить("Настройки", СоответствиеНастроек);
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Функция ДобавитьНастройкиЭлемента(СоответствиеНастроек, СтрокиНастроек, ЗначенияНастроекПоУмолчанию)
	
	Для Каждого ДанныеНастройки Из ЗначенияНастроекПоУмолчанию Цикл
		СтрокаНастроекЭлементов = ПолучитьСтрокуНастройкиЭлементаФормыРМК(СтрокиНастроек, ДанныеНастройки.СвойствоЭлементов);
		ЗначенияНастройки = Новый Структура();
		Если СтрокаНастроекЭлементов = Неопределено Тогда
			ЗначенияНастройки.Вставить("ЗначениеСвойства", ДанныеНастройки.ЗначениеСвойства);
		Иначе
			ЗначенияНастройки.Вставить("ЗначениеСвойства", СтрокаНастроекЭлементов.ЗначениеСвойства);
		КонецЕсли;
		ЗначенияНастройки.Вставить("ЗначениеПоУмолчанию", ДанныеНастройки.ЗначениеСвойства);
		СоответствиеНастроек.Вставить(ДанныеНастройки.СвойствоЭлементов, ЗначенияНастройки);
	КонецЦикла;
	
КонецФункции

&НаКлиенте
Процедура РедактированиеНастроекОбластиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		ВключитьКнопкуСброса = Ложь;
		СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиПоУмолчанию;
		ОтборСтрокНастроек = Новый Структура();
		ОтборСтрокНастроек.Вставить("ЗаголовокОбласти", Результат.ЗаголовокОбъекта);
		СтрокиНастроекФормы = НастройкиОбластейФормыРМК.НайтиСтроки(ОтборСтрокНастроек);
		Для Каждого СтрокаНастройки Из СтрокиНастроекФормы Цикл
			
			НовоеЗначение = Результат.Настройки.Получить(СтрокаНастройки.СвойствоЭлементовОбласти);
			Если НовоеЗначение = Неопределено Тогда
				СтрокаНастройки.ЗначениеСвойства = СтрокаНастройки.ЗначениеПоУмолчанию;
			Иначе
				СтрокаНастройки.ЗначениеСвойства = НовоеЗначение;
			КонецЕсли;
			Если Не СтрокаНастройки.ЗначениеСвойства = СтрокаНастройки.ЗначениеПоУмолчанию Тогда
				СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиИзменены;
				ВключитьКнопкуСброса = Истина;
			КонецЕсли;
			
		КонецЦикла;
		СтрокаОбластиДерева = ДеревоОбластейФормыРМК.НайтиПоИдентификатору(ДополнительныеПараметры);
		СтрокаОбластиДерева.СостояниеНастроек = СостояниеНастроек;
		
		АктуализироватьДоступностьКнопкиСбросаНастроекСвойствОбластей(ВключитьКнопкуСброса);
		
		ОбновляемыеЭлементы = Новый Массив;
		ОбновляемыеЭлементы.Добавить(Элементы.ДеревоОбластейФормыРМКСброситьНастройкиСвойствОбластей);
		ОбновитьОтображениеФормыНастроек(ЭтотОбъект, ОбновляемыеЭлементы);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеНастроекЭлементаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		ПараметрыОбновления = Новый Структура();
		ПараметрыОбновления.Вставить("ВключитьКнопкуСброса", Ложь);
		ПараметрыОбновления.Вставить("СостояниеНастроек", ВозможныеСостоянияНастроек.НастройкиПоУмолчанию);
		ПараметрыОбновления.Вставить("ИмяЭлемента", Результат.ИмяЭлемента);
		ОтборСтрокНастроек = Новый Структура();
		ОтборСтрокНастроек.Вставить("ИмяЭлемента", Результат.ИмяЭлемента);
		СтрокиНастроекЭлементов = НастройкиЭлементовФормыРМК.НайтиСтроки(ОтборСтрокНастроек);
		Для Каждого ДанныеНастройки Из Результат.Настройки Цикл
			ОбновитьНастройкуЭлементаФормы(СтрокиНастроекЭлементов, ДанныеНастройки, ПараметрыОбновления);
		КонецЦикла;
		
		СтрокаКлавишиДерева = ДеревоГорячиеКлавиши.НайтиПоИдентификатору(ДополнительныеПараметры);
		СтрокаКлавишиДерева.СостояниеНастроек = ПараметрыОбновления.СостояниеНастроек;
		
		АктуализироватьДоступностьКнопкиСбросаНастроекЭлементов(ПараметрыОбновления.ВключитьКнопкуСброса);
		ОбновляемыеЭлементы = Новый Массив;
		ОбновляемыеЭлементы.Добавить(Элементы.СброситьНастройкиСвойствЭлементов);
		ОбновитьОтображениеФормыНастроек(ЭтотОбъект, ОбновляемыеЭлементы);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНастройкуЭлементаФормы(СтрокиНастроекЭлементов, ДанныеНастройки, ПараметрыОбновления)
	
	СтрокаНастройкиЭлемента = ПолучитьСтрокуНастройкиЭлементаФормыРМК(СтрокиНастроекЭлементов, ДанныеНастройки.Ключ);
	ЗначениеПоУмолчанию = ПолучитьЗначениеПоУмолчаниюНастройкиЭлемента(ПараметрыОбновления.ИмяЭлемента,
		ДанныеНастройки.Ключ);
	Если Не ДанныеНастройки.Значение = ЗначениеПоУмолчанию Тогда
		Если СтрокаНастройкиЭлемента = Неопределено Тогда
			СтрокаНастройкиЭлемента = НастройкиЭлементовФормыРМК.Добавить();
			СтрокаНастройкиЭлемента.ИмяЭлемента = ПараметрыОбновления.ИмяЭлемента;
			СтрокаНастройкиЭлемента.СвойствоЭлементов = ДанныеНастройки.Ключ;
			СтрокаНастройкиЭлемента.ЗначениеПоУмолчанию = ЗначениеПоУмолчанию;
			СтрокаНастройкиЭлемента.ЗначениеСвойства = ДанныеНастройки.Значение;
		Иначе
			СтрокаНастройкиЭлемента.ЗначениеСвойства = ДанныеНастройки.Значение;
		КонецЕсли;
		ПараметрыОбновления.СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиИзменены;
		ПараметрыОбновления.ВключитьКнопкуСброса = Истина;
	ИначеЕсли Не СтрокаНастройкиЭлемента = Неопределено Тогда
		НастройкиЭлементовФормыРМК.Удалить(СтрокаНастройкиЭлемента);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьЗначениеПоУмолчаниюНастройкиЭлемента(ИмяЭлемента, СвойствоЭлементов)
	
	РезультатФункции = Неопределено;
	
	ИндексСвойства = 0;
	Пока ИндексСвойства < ЗначенияНастроекЭлементовПоУмолчанию.Обычные.Количество()
			И РезультатФункции = Неопределено Цикл
		НастройкаПоУмолчанию = ЗначенияНастроекЭлементовПоУмолчанию.Обычные.Получить(ИндексСвойства);
		Если НастройкаПоУмолчанию.СвойствоЭлементов = СвойствоЭлементов Тогда
			РезультатФункции = НастройкаПоУмолчанию.ЗначениеСвойства;
		КонецЕсли;
		ИндексСвойства = ИндексСвойства + 1;
	КонецЦикла;
	Если РезультатФункции = Неопределено Тогда
		ИндивидуальныеНастройкиПоУмолчанию = ЗначенияНастроекЭлементовПоУмолчанию.Индивидуальные.Получить(ИмяЭлемента);
		ИндексСвойства = 0;
		Пока ИндексСвойства < ИндивидуальныеНастройкиПоУмолчанию.Количество() И РезультатФункции = Неопределено Цикл
			ЭлементСвойства = ИндивидуальныеНастройкиПоУмолчанию.Получить(ИндексСвойства);
			Если ЭлементСвойства.СвойствоЭлементов = СвойствоЭлементов Тогда
				РезультатФункции = ЭлементСвойства.ЗначениеСвойства;
			КонецЕсли;
			ИндексСвойства = ИндексСвойства + 1;
		КонецЦикла;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаСервереБезКонтекста
Функция СформироватьСтруктуруПервоначальныхНастроекЭлементов(КвадратныеКнопки)
	
	ДанныеНастроекЭлементов = Новый Массив;
	НастройкиОбычныхЭлементовПоУмолчанию
		= ИнтерфейсРМКСлужебный.ПолучитьПервоначальныеНастройкиЭлементовРМК(КвадратныеКнопки);
	Для Каждого СтрокаНастройкиЭлемента Из НастройкиОбычныхЭлементовПоУмолчанию Цикл
		СтрокаДанных = Новый Структура("СвойствоЭлементов,ЗначениеСвойства", Неопределено, Неопределено);
		ЗаполнитьЗначенияСвойств(СтрокаДанных, СтрокаНастройкиЭлемента);
		ДанныеНастроекЭлементов.Добавить(СтрокаДанных);
	КонецЦикла;
	Возврат ДанныеНастроекЭлементов;
	
КонецФункции

&НаСервереБезКонтекста
Функция СформироватьСтруктуруПервоначальныхИндивидуальныхНастроек()
	
	ИндивидуальныеНастройки = Новый Соответствие();
	
	ТаблицаИндивидуальныхНастроек = ИнтерфейсРМКСлужебный.ПолучитьИндивидуальныеПервоначальныеНастройки();
	ИмяТекущегоЭлемента = "";
	МассивНастроек = Новый Массив;
	Для Каждого СтрокаИндивидуальнойНастройки Из ТаблицаИндивидуальныхНастроек Цикл
		
		Если Не СтрокаИндивидуальнойНастройки.ИмяЭлемента = ИмяТекущегоЭлемента Тогда
			
			ИмяТекущегоЭлемента = СтрокаИндивидуальнойНастройки.ИмяЭлемента;
			МассивНастроек = Новый Массив;
			ИндивидуальныеНастройки.Вставить(ИмяТекущегоЭлемента, МассивНастроек);
			
		КонецЕсли;
		СтрокаДанных = Новый Структура("СвойствоЭлементов,ЗначениеСвойства", Неопределено, Неопределено);
		ЗаполнитьЗначенияСвойств(СтрокаДанных, СтрокаИндивидуальнойНастройки);
		МассивНастроек.Добавить(СтрокаДанных);
		
	КонецЦикла;
	
	Возврат ИндивидуальныеНастройки;
	
КонецФункции

&НаСервере
Функция ПолучитьКэшированноеЗначениеСвойстваПоУмолчанию(КэшСвойствЭлементовПоУмолчанию,
		НастройкиПоУмолчанию, СвойствоЭлементов)
		
	РезультатФункции = Неопределено;
	СтрокаНастройкиПоУмолчанию = КэшСвойствЭлементовПоУмолчанию.Получить(СвойствоЭлементов);
	Если СтрокаНастройкиПоУмолчанию = Неопределено Тогда
		СтрокаНастройкиПоУмолчанию = НастройкиПоУмолчанию.Найти(СвойствоЭлементов, "СвойствоЭлементов");
		Если Не СтрокаНастройкиПоУмолчанию = Неопределено Тогда
			КэшСвойствЭлементовПоУмолчанию.Вставить(СвойствоЭлементов, СтрокаНастройкиПоУмолчанию);
			РезультатФункции = СтрокаНастройкиПоУмолчанию.ЗначениеСвойства;
		КонецЕсли;
	Иначе
		РезультатФункции = СтрокаНастройкиПоУмолчанию.ЗначениеСвойства;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьНастройкиЭлементов()
	
	КэшСвойствЭлементовПоУмолчанию = Новый Соответствие;
	
	НастройкиЭлементовФормыРМК.Очистить();
	НастройкиПоУмолчанию = ИнтерфейсРМКСлужебный.ПолучитьПервоначальныеНастройкиЭлементовРМК();
	ДобавитьИндивидуальныеПервоначальныеНастройки(НастройкиПоУмолчанию);
	Для Каждого СтрокаНастройки Из НастройкаРМК.НастройкиЭлементов Цикл
		ЗначениеПоУмолчанию = ПолучитьКэшированноеЗначениеСвойстваПоУмолчанию(КэшСвойствЭлементовПоУмолчанию,
			НастройкиПоУмолчанию, СтрокаНастройки.СвойствоЭлементов);
		Если Не ЗначениеПоУмолчанию = Неопределено И Не СтрокаНастройки.ЗначениеСвойства = ЗначениеПоУмолчанию Тогда
			НоваяСтрока = НастройкиЭлементовФормыРМК.Добавить();
			НоваяСтрока.ИмяЭлемента = СтрокаНастройки.ИмяЭлемента;
			НоваяСтрока.СвойствоЭлементов = СтрокаНастройки.СвойствоЭлементов;
			НоваяСтрока.ЗначениеСвойства = СтрокаНастройки.ЗначениеСвойства;
			НоваяСтрока.ЗначениеПоУмолчанию = ЗначениеПоУмолчанию;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьИндивидуальныеПервоначальныеНастройки(НастройкиПоУмолчанию)
	
	ИндивидуальныеНастройкиПоУмолчанию
		= ИнтерфейсРМКСлужебный.ПолучитьИндивидуальныеПервоначальныеНастройки();
		
	Для Каждого СтрокаИндивидуальнойНастройки Из ИндивидуальныеНастройкиПоУмолчанию Цикл
		Если НастройкиПоУмолчанию.Найти(СтрокаИндивидуальнойНастройки.СвойствоЭлементов, "СвойствоЭлементов")
				= Неопределено Тогда
				
			НоваяСтрока = НастройкиПоУмолчанию.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИндивидуальнойНастройки);
				
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНастройкиОбластей()
	
	НастройкиОбластейФормыРМК.Загрузить(НастройкаРМК.НастройкиОбластей.Выгрузить());
	НастройкиПоУмолчанию = ИнтерфейсРМКСлужебный.ПолучитьПервоначальныеНастройкиОбластейРМК();
	Для Каждого СтрокаБазовойНастройки Из НастройкиПоУмолчанию Цикл
		ОтборСтрок = Новый Структура();
		ОтборСтрок.Вставить("ЗаголовокОбласти", СтрокаБазовойНастройки.ЗаголовокОбласти);
		ОтборСтрок.Вставить("СвойствоЭлементовОбласти", СтрокаБазовойНастройки.СвойствоЭлементовОбласти);
		СтрокиНастроекФормы = НастройкиОбластейФормыРМК.НайтиСтроки(ОтборСтрок);
		Если СтрокиНастроекФормы.Количество() = 0 Тогда
			НоваяСтрока = НастройкиОбластейФормыРМК.Добавить();
			НоваяСтрока.ЗаголовокОбласти = СтрокаБазовойНастройки.ЗаголовокОбласти;
			НоваяСтрока.СвойствоЭлементовОбласти = СтрокаБазовойНастройки.СвойствоЭлементовОбласти;
			НоваяСтрока.ЗначениеСвойства = СтрокаБазовойНастройки.ЗначениеСвойства;
			НоваяСтрока.ЗначениеПоУмолчанию = СтрокаБазовойНастройки.ЗначениеСвойства;
		Иначе
			СтрокиНастроекФормы[0].ЗначениеПоУмолчанию = СтрокаБазовойНастройки.ЗначениеСвойства;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьПерсонализированныеНастройки()
	
	СохранитьПерсонализированныеНастройкиОбластей();
	СохранитьПерсонализированныеНастройкиЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура СохранитьПерсонализированныеНастройкиОбластей()
	
	НастройкаРМК.НастройкиОбластей.Очистить();
	Для Каждого НастройкаОбласти Из НастройкиОбластейФормыРМК Цикл
		
		Если Не НастройкаОбласти.ЗначениеСвойства = НастройкаОбласти.ЗначениеПоУмолчанию Тогда
			
			НоваяСтрока = НастройкаРМК.НастройкиОбластей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, НастройкаОбласти);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьПерсонализированныеНастройкиЭлементов()
	
	НастройкаРМК.НастройкиЭлементов.Очистить();
	Для Каждого НастройкаЭлемента Из НастройкиЭлементовФормыРМК Цикл
		
		Если Не НастройкаЭлемента.ЗначениеСвойства = НастройкаЭлемента.ЗначениеПоУмолчанию Тогда
			
			НоваяСтрока = НастройкаРМК.НастройкиЭлементов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, НастройкаЭлемента);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЕстьСмещенныеОбласти(СтрокиУровня)
	
	РезультатФункции = Ложь;
	
	КоличествоСтрок = СтрокиУровня.Количество();
	ИндексСтроки = 0;
	Пока ИндексСтроки < КоличествоСтрок И Не РезультатФункции Цикл
		СтрокаБлока = СтрокиУровня[ИндексСтроки];
		Если СтрокиУровня.Индекс(СтрокаБлока) = СтрокаБлока.ИсходныйПорядок - 1 Тогда
			РезультатФункции = ЕстьСмещенныеОбласти(СтрокаБлока.ПолучитьЭлементы());
		Иначе
			РезультатФункции = Истина;
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Функция ЕстьПерсонализированныеНастройкиЭлементов()
	
	РезультатФункции = Ложь;

	СтрокиГрупп = ДеревоГорячиеКлавиши.ПолучитьЭлементы();
	ИндексГруппы = 0;
	Пока ИндексГруппы < СтрокиГрупп.Количество() И Не РезультатФункции Цикл
		СтрокаГруппы = СтрокиГрупп[ИндексГруппы];
		СтрокиКлавиш = СтрокаГруппы.ПолучитьЭлементы();
		ИндексКлавиши = 0;
		Пока ИндексКлавиши < СтрокиКлавиш.Количество() И Не РезультатФункции Цикл
			СтрокаКлавиши = СтрокиКлавиш[ИндексКлавиши];
			Если СтрокаКлавиши.СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиИзменены Тогда
				РезультатФункции = Истина;
			КонецЕсли;
			
			ИндексКлавиши = ИндексКлавиши + 1;
		КонецЦикла;
		ИндексГруппы = ИндексГруппы + 1;
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Функция ЕстьПерсонализированныеНастройкиОбластей(СтрокиУровня)
	
	РезультатФункции = Ложь;
	
	КоличествоСтрок = СтрокиУровня.Количество();
	ИндексСтроки = 0;
	Пока ИндексСтроки < КоличествоСтрок И Не РезультатФункции Цикл
		СтрокаОбласти = СтрокиУровня[ИндексСтроки];
		Если СтрокаОбласти.СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиИзменены Тогда
			РезультатФункции = Истина;
		Иначе
			РезультатФункции = ЕстьПерсонализированныеНастройкиОбластей(СтрокаОбласти.ПолучитьЭлементы());
		КонецЕсли;
		
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаКлиенте
Процедура АктуализироватьДоступностьКнопкиСбросаНастроекСвойствОбластей(ВключитьДоступность = Ложь)

	Если ВключитьДоступность Тогда
		ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствОбластей_Доступность = Истина;
	Иначе
		ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствОбластей_Доступность
			= ЕстьПерсонализированныеНастройкиОбластей(ДеревоОбластейФормыРМК.ПолучитьЭлементы());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура АктуализироватьДоступностьКнопкиСбросаНастроекЭлементов(ВключитьДоступность = Ложь)

	Если ВключитьДоступность Тогда
		ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствЭлементов_Доступность = Истина;
	Иначе
		ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствЭлементов_Доступность
			= ЕстьПерсонализированныеНастройкиЭлементов();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьНастройкиСвойствОбластейКлиент()
	
	ОповещениеСброса = Новый ОписаниеОповещения("ВопросСбросНастроекСвойствОбластейЗавершение", ЭтотОбъект);
	ТекстВопроса = НСтр("ru = 'Настройки элементов областей будут сброшены. Продолжить?'");
	ПоказатьВопрос(ОповещениеСброса, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьНастройкиСвойствЭлементовКлиент()
	
	ОповещениеСброса = Новый ОписаниеОповещения("ВопросСбросНастроекСвойствЭлементовЗавершение", ЭтотОбъект);
	ТекстВопроса = НСтр("ru = 'Настройки кнопок будут сброшены. Продолжить?'");
	ПоказатьВопрос(ОповещениеСброса, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура УбратьИзмененныеСостоянияНастроек(СтрокиУровня)
	
	Для Каждого СтрокаОбласти Из СтрокиУровня Цикл
		Если СтрокаОбласти.СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиИзменены Тогда
			СтрокаОбласти.СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиПоУмолчанию;
		КонецЕсли;
		УбратьИзмененныеСостоянияНастроек(СтрокаОбласти.ПолучитьЭлементы())
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросСбросНастроекСвойствОбластейЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		Для Каждого СтрокаНастройкиОбласти Из НастройкиОбластейФормыРМК Цикл
			СтрокаНастройкиОбласти.ЗначениеСвойства = СтрокаНастройкиОбласти.ЗначениеПоУмолчанию;
		КонецЦикла;
		УбратьИзмененныеСостоянияНастроек(ДеревоОбластейФормыРМК.ПолучитьЭлементы());
		ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствОбластей_Доступность = Ложь;
		
		ОбновляемыеЭлементы = Новый Массив;
		ОбновляемыеЭлементы.Добавить(Элементы.ДеревоОбластейФормыРМКСброситьНастройкиСвойствОбластей);
		ОбновитьОтображениеФормыНастроек(ЭтотОбъект, ОбновляемыеЭлементы);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросСбросНастроекСвойствЭлементовЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		НастройкиЭлементовФормыРМК.Очистить();
		УбратьИзмененныеСостоянияНастроек(ДеревоГорячиеКлавиши.ПолучитьЭлементы());
		ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствЭлементов_Доступность = Ложь;
		
		ОбновляемыеЭлементы = Новый Массив;
		ОбновляемыеЭлементы.Добавить(Элементы.СброситьНастройкиСвойствЭлементов);
		ОбновитьОтображениеФормыНастроек(ЭтотОбъект, ОбновляемыеЭлементы);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ЗаполнитьПорядокОбластейФормы()
	
	ПорядокОбластей.Загрузить(НастройкаРМК.ПорядокОбластей.Выгрузить());
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПорядокИДеревоОбластейФормы()
	
	ЗаполнитьНастройкиОбластей();
	ЗаполнитьПорядокОбластейФормы();
	ЗаполнитьДеревоОбластейФормы();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоОбластейФормы()
	
	ВосстановитьПервоначальноеДеревоОбластейФормы();
	ПрименитьСохраненныйПорядокОбластей();
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьПервоначальноеДеревоОбластейФормы()
	
	ШиринаСхемыРМК = 1;
	ВысотаСхемыРМК = 1;
	
	ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствОбластей_Доступность = Ложь;
	
	ПараметрыЗаполнения = ПараметрыЗаполненияОбластейФормыРМК();
	ДеревоОбластейФормыРМК.ПолучитьЭлементы().Очистить();
	КорневаяГруппа = ?(ГоризонтальныйОриентация, Элементы.ГоризонтальнаяОриентация, Элементы.ВертикальнаяОриентация);
	ДеревоПервоначальногоРасположения
		= ИнтерфейсРМКСлужебный.ПолучитьПервоначальноеРасположениеОбластейФормыРМК(КорневаяГруппа, ПараметрыЗаполнения);
	ДобавитьСтрокиУровняДерева(ДеревоПервоначальногоРасположения.Строки, ДеревоОбластейФормыРМК.ПолучитьЭлементы(), 1,
		ТипГруппировкаВертикальная);
	
КонецПроцедуры

&НаСервере
Функция ПанельИзбранныхИспользуется()
	
	ЕстьБыстрыеТовары = Ложь;
	ЭлементыИерархии = ИерархияТоваров.ПолучитьЭлементы();
	Если (ЭлементыИерархии.Количество() = 1 И ЭлементыИерархии[0].ПолучитьЭлементы().Количество() > 0)
			Или ЭлементыИерархии.Количество() > 1 Тогда
		ЕстьБыстрыеТовары = Истина;
	КонецЕсли;
	
	Возврат (ЕстьБыстрыеТовары Или ЗначениеЗаполнено(НастройкаРМК.СтруктураБыстрыхТоваров));
	
КонецФункции

&НаСервере
Функция ПараметрыЗаполненияОбластейФормыРМК()
	
	РежимПлитки = 2;
	
	ПараметрыЗаполнения = Новый Структура();
	ПараметрыЗаполнения.Вставить("ПокупюрныйВводНаличных", НастройкаРМК.ИспользоватьПанельВводаНаличныхКупюр);
	ПараметрыЗаполнения.Вставить("ПанельИзбранных", ПанельИзбранныхИспользуется());
	ПараметрыЗаполнения.Вставить("ПлиточныйИнтерфейс", НастройкаРМК.РежимНачальнойСтраницы = РежимПлитки);
	
	Возврат ПараметрыЗаполнения;
	
КонецФункции

&НаКлиенте
Процедура РазвернутьСтрокиДерева()
	
	СтрокиДерева = ДеревоОбластейФормыРМК.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		ИдентификаторСтроки = СтрокаДерева.ПолучитьИдентификатор();
		Если Не Элементы.ДеревоОбластейФормыРМК.Развернут(ИдентификаторСтроки) Тогда
			Элементы.ДеревоОбластейФормыРМК.Развернуть(ИдентификаторСтроки, Истина);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокиУровняДерева(ИсходныеСтроки, СтрокиПриемника, Знач ТекущийУровень, ГруппировкаУровня)
	
	КолонкаШирина = "Ширина";
	КолонкаВысота = "Высота";
	КолонкаШиринаВПроцентах = "ШиринаВПроцентах";
	КолонкаВысотаВПроцентах = "ВысотаВПроцентах";
	МаксимальныйПроцент = 100;
	ШиринаГруппы = ПолучитьОбщуюШиринуГруппы(ИсходныеСтроки, ГруппировкаУровня);
	ВысотаГруппы = ПолучитьОбщуюВысотуГруппы(ИсходныеСтроки, ГруппировкаУровня);
	ОбщееЗначениеРазмера = ?(ГруппировкаУровня = ТипГруппировкаВертикальная, ВысотаГруппы, ШиринаГруппы);
	Если ТекущийУровень = 1 Тогда
		ШиринаСхемыРМК = ШиринаГруппы;
		ВысотаСхемыРМК = ВысотаГруппы;
	КонецЕсли;
	
	ИмяКолонкиРаспределения = ?(ГруппировкаУровня = ТипГруппировкаВертикальная, КолонкаВысота, КолонкаШирина);
	ИмяКолонкиРаспределенияВПроцентах
		= ?(ГруппировкаУровня = ТипГруппировкаВертикальная, КолонкаВысотаВПроцентах, КолонкаШиринаВПроцентах);
	
	НаименьшийРазмер = 0;
	НаибольшийРазмер = 0;
	МинимальнаяСтрока = Неопределено;
	МаксимальнаяСтрока = Неопределено;
	РазницаОкругления = 100;
	
	Для Каждого СтрокаИсточника Из ИсходныеСтроки Цикл
		
		ПроцентРазмераДробный = 100 * СтрокаИсточника[ИмяКолонкиРаспределения] / ОбщееЗначениеРазмера;
		ПроцентРазмера = Окр(ПроцентРазмераДробный, 1, РежимОкругления.Окр15как20);
		
		НоваяСтрока = СтрокиПриемника.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточника);
		НоваяСтрока.ИсходныйПорядок = СтрокиПриемника.Индекс(НоваяСтрока) + 1;
		
		Если СтрокаИсточника.ДоступностьГруппы Тогда
			НоваяСтрока.ШиринаВПроцентах = ?(ГруппировкаУровня = ТипГруппировкаВертикальная, МаксимальныйПроцент, ПроцентРазмера);
			НоваяСтрока.ВысотаВПроцентах = ?(ГруппировкаУровня = ТипГруппировкаВертикальная, ПроцентРазмера, МаксимальныйПроцент);
			
			Если НаименьшийРазмер = 0 Или СтрокаИсточника[ИмяКолонкиРаспределения] < НаименьшийРазмер Тогда
				НаименьшийРазмер = СтрокаИсточника[ИмяКолонкиРаспределения];
				МинимальнаяСтрока = НоваяСтрока;
			КонецЕсли;
			Если СтрокаИсточника[ИмяКолонкиРаспределения] > НаибольшийРазмер Тогда
				НаибольшийРазмер = СтрокаИсточника[ИмяКолонкиРаспределения];
				МаксимальнаяСтрока = НоваяСтрока;
			КонецЕсли;
			РазницаОкругления = РазницаОкругления - ПроцентРазмера;
			
			ДобавитьСтрокиУровняДерева(СтрокаИсточника.Строки, НоваяСтрока.ПолучитьЭлементы(), ТекущийУровень + 1,
				СтрокаИсточника.Группировка);
		Иначе
			НоваяСтрока.ШиринаВПроцентах = 0;
			НоваяСтрока.ВысотаВПроцентах = 0;
		КонецЕсли;
		НоваяСтрока.СостояниеНастроек = ПолучитьИндексСостоянияНастроекОбласти(СтрокаИсточника.ЗаголовокОбласти);
		Если НоваяСтрока.СостояниеНастроек = ВозможныеСостоянияНастроек.НастройкиИзменены Тогда
			ДанныеДляОтображенияЭлементов.СброситьНастройкиСвойствОбластей_Доступность = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Если РазницаОкругления <> 100 И РазницаОкругления <> 0 Тогда
		Если РазницаОкругления > 0 И Не МинимальнаяСтрока = Неопределено Тогда
			МинимальнаяСтрока[ИмяКолонкиРаспределенияВПроцентах]
				= МинимальнаяСтрока[ИмяКолонкиРаспределенияВПроцентах] + РазницаОкругления;
		ИначеЕсли РазницаОкругления < 0 И Не МаксимальнаяСтрока = Неопределено Тогда
			МаксимальнаяСтрока[ИмяКолонкиРаспределенияВПроцентах]
				= МаксимальнаяСтрока[ИмяКолонкиРаспределенияВПроцентах] + РазницаОкругления;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОбщуюШиринуГруппы(ИсходныеСтроки, ГруппировкаУровня)
	
	РезультатФункции = 0;
	Если ИсходныеСтроки.Количество() > 0 Тогда
		Если ГруппировкаУровня = ТипГруппировкаВертикальная Тогда
			РезультатФункции = ИсходныеСтроки[0].Ширина;
		Иначе
			Для Каждого СтрокаОбласти Из ИсходныеСтроки Цикл
				Если СтрокаОбласти.ДоступностьГруппы Тогда
					РезультатФункции = РезультатФункции + СтрокаОбласти.Ширина;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если РезультатФункции = 0 Тогда
		РезультатФункции = 1;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаСервере
Функция ПолучитьОбщуюВысотуГруппы(ИсходныеСтроки, ГруппировкаУровня)
	
	РезультатФункции = 0;
	Если ИсходныеСтроки.Количество() > 0 Тогда
		Если ГруппировкаУровня = ТипГруппировкаВертикальная Тогда
			Для Каждого СтрокаОбласти Из ИсходныеСтроки Цикл
				Если СтрокаОбласти.ДоступностьГруппы Тогда
					РезультатФункции = РезультатФункции + СтрокаОбласти.Высота;
				КонецЕсли;
			КонецЦикла;
		Иначе
			РезультатФункции = ИсходныеСтроки[0].Высота;
		КонецЕсли;
	КонецЕсли;
	Если РезультатФункции = 0 Тогда
		РезультатФункции = 1;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаСервере
Процедура ПрименитьСохраненныйПорядокОбластей()
	
	КорневаяГруппа = ?(ГоризонтальныйОриентация, Элементы.ГоризонтальнаяОриентация, Элементы.ВертикальнаяОриентация);
	ПрименитьСохраненныйПорядокДляУровня(КорневаяГруппа.Имя, ДеревоОбластейФормыРМК.ПолучитьЭлементы());
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьСохраненныйПорядокДляУровня(ИмяРодителя, СтрокиУровня)
	
	Для Каждого СтрокаДерева Из СтрокиУровня Цикл
		Если СтрокаДерева.ПолучитьЭлементы().Количество() > 0 Тогда
			ПрименитьСохраненныйПорядокДляУровня(СтрокаДерева.ИмяОбласти, СтрокаДерева.ПолучитьЭлементы());
		КонецЕсли;
	КонецЦикла;
	ПрименитьСохраненныйПорядокДляПодчиненныхСтрокУровня(ИмяРодителя, СтрокиУровня);
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьСохраненныйПорядокДляПодчиненныхСтрокУровня(ИмяРодителя, СтрокиУровня)
	
	ОтборСтрок = Новый Структура("ОбластьРодитель,ВертикальнаяОриентация", ИмяРодителя, (Не ГоризонтальныйОриентация));
	СтрокиПорядка = ПорядокОбластей.НайтиСтроки(ОтборСтрок);
	Для Каждого СтрокаПорядка Из СтрокиПорядка Цикл
		ИндексОбластиВДереве = -1;
		СтрокаОбластиВДереве = ПолучитьСтрокуДереваОбластиПоИмени(СтрокиУровня, СтрокаПорядка.Область, ИндексОбластиВДереве);
		ВПределахГраницы = (СтрокаПорядка.Порядок > 0 И СтрокаПорядка.Порядок <= СтрокиУровня.Количество());
		Если (Не СтрокаОбластиВДереве = Неопределено) И СтрокаПорядка.Порядок <> ИндексОбластиВДереве + 1
				И ВПределахГраницы Тогда
			СтрокиУровня.Сдвинуть(ИндексОбластиВДереве, СтрокаПорядка.Порядок - ИндексОбластиВДереве - 1);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтрокуДереваОбластиПоИмени(СтрокиУровня, ИмяОбласти, ИндексОбластиВДереве)
	
	РезультатФункции = Неопределено;
	
	КоличествоСтрок = СтрокиУровня.Количество();
	ИндексСтроки = 0;
	Пока ИндексСтроки < КоличествоСтрок И РезультатФункции = Неопределено Цикл
		СтрокаОбласти = СтрокиУровня.Получить(ИндексСтроки);
		Если СтрокаОбласти.ИмяОбласти = ИмяОбласти Тогда
			РезультатФункции = СтрокаОбласти;
			ИндексОбластиВДереве = ИндексСтроки;
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	Возврат РезультатФункции;
	
КонецФункции

&НаСервере
Процедура СохранитьПорядокОбластей()
	
	НастройкаРМК.ПорядокОбластей.Загрузить(ПорядокОбластей.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьПорядокОбластейРодителя(ИмяРодителя, СтрокиУровня)
	
	ПорядковыйНомерОбласти = 1;
	Для Каждого СтрокаОбласти Из СтрокиУровня Цикл
		
		ОтборДляПоиска = Новый Структура();
		ОтборДляПоиска.Вставить("Область", СтрокаОбласти.ИмяОбласти);
		ОтборДляПоиска.Вставить("ВертикальнаяОриентация", (Не ГоризонтальныйОриентация));
		
		СтрокиПорядка = ПорядокОбластей.НайтиСтроки(ОтборДляПоиска);
		Если СтрокиПорядка.Количество() > 0 Тогда
			НоваяСтрока = СтрокиПорядка[0];
		Иначе
			НоваяСтрока = ПорядокОбластей.Добавить();
			НоваяСтрока.Область = СтрокаОбласти.ИмяОбласти;
			НоваяСтрока.ВертикальнаяОриентация = Не ГоризонтальныйОриентация;
		КонецЕсли;
		НоваяСтрока.Порядок = ПорядковыйНомерОбласти;
		НоваяСтрока.ОбластьРодитель = ИмяРодителя;
		
		ПорядковыйНомерОбласти = ПорядковыйНомерОбласти + 1;
		ПодчиненныеСтроки = СтрокаОбласти.ПолучитьЭлементы();
		Если ПодчиненныеСтроки.Количество() > 0 Тогда
			ЗаписатьПорядокОбластейРодителя(СтрокаОбласти.ИмяОбласти, ПодчиненныеСтроки);
		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьПорядокОбластейСхемыРМК()
	
	КорневаяГруппа = ?(ГоризонтальныйОриентация, Элементы.ГоризонтальнаяОриентация, Элементы.ВертикальнаяОриентация);
	ЗаписатьПорядокОбластейРодителя(КорневаяГруппа.Имя, ДеревоОбластейФормыРМК.ПолучитьЭлементы());
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьНастройкиПорядкаОбластейКлиент()
	
	ОповещениеВосстановления = Новый ОписаниеОповещения("ВопросВосстановлениеПорядкаОбластейЗавершение", ЭтотОбъект);
	ТекстВопроса = НСтр("ru = 'Сделанные настройки будут сброшены. Продолжить?'");
	ПоказатьВопрос(ОповещениеВосстановления, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросВосстановлениеПорядкаОбластейЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ВосстановитьПервоначальноеДеревоОбластейФормы();
		ПересчитатьПорядокОбластейСхемыРМК();
		РазвернутьСтрокиДерева();
		
		ОбновляемыеЭлементы = Новый Массив;
		ОбновляемыеЭлементы.Добавить(Элементы.ДеревоОбластейФормыРМКВосстановитьНастройкиПорядкаОбластей);
		ОбновитьОтображениеФормыНастроек(ЭтотОбъект, ОбновляемыеЭлементы);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьКартинкуПоУмолчанию(ТекущаяСтрока)
	
	Если ТекущаяСтрока.ЭтоКатегория Тогда
		
		// ПоказатьЗначение(, БиблиотекаКартинок.РМККассаЗеленая);
		КартинкаПоУмолчанию = БиблиотекаКартинок.РМККассаЗеленая;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапомнитьРеквизитыПалитры()
	
	ПараметрыНастройки = Новый Структура();
	ПараметрыНастройки.Вставить("Палитра", НастройкаРМК.СтруктураПлиточногоИнтерфейсаПодбора);
	ПараметрыНастройки.Вставить("ЭтоГоризонтальнаяОриентация", ГоризонтальныйОриентация);
	
	ДанныеРазмеров = ПолучитьРеквизитыПалитры(ПараметрыНастройки);
	ЗаполнитьЗначенияСвойств(РеквизитыПалитры, ДанныеРазмеров);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьРеквизитыПалитры(ПараметрыНастройки)
	
	ИменаРеквизитовЭлемента = "КоличествоЭлементовВРяду,КоличествоРядов";
	ИменаСвойств = "КоличествоЭлементовВРяду,КоличествоРядовНаСтранице";
	РазмерыПалитры = Новый Структура(ИменаСвойств, 0, 0);
	
	Если ЗначениеЗаполнено(ПараметрыНастройки.Палитра) Тогда
		ДанныеПалитры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыНастройки.Палитра, ИменаРеквизитовЭлемента);
		РазмерыПалитры.КоличествоЭлементовВРяду = ДанныеПалитры.КоличествоЭлементовВРяду;
		РазмерыПалитры.КоличествоРядовНаСтранице = ДанныеПалитры.КоличествоРядов;
	КонецЕсли;
	Если РазмерыПалитры.КоличествоЭлементовВРяду = 0 Или РазмерыПалитры.КоличествоРядовНаСтранице = 0 Тогда
		ЭтоВертикальнаяОриентация = (Не ПараметрыНастройки.ЭтоГоризонтальнаяОриентация);
		РазмерыПлиткиПоУмолчанию
			= ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьРазмерыПлиткиПоУмолчанию(ЭтоВертикальнаяОриентация);
		ЗаполнитьЗначенияСвойств(РазмерыПалитры, РазмерыПлиткиПоУмолчанию);
	КонецЕсли;
	
	Возврат РазмерыПалитры;
	
КонецФункции

#Область ГруппыНастроекРМК
&НаКлиенте
Процедура СвернутьРазвернутьГруппу(ИмяГруппы, ДекорацияКартинка)
	Если Элементы[ИмяГруппы].Видимость Тогда
		Элементы[ИмяГруппы].Видимость = Ложь;
		ДекорацияКартинка.Картинка = БиблиотекаКартинок.СтрелкаЗеленаяВправоРМК;
	Иначе
		Элементы[ИмяГруппы].Видимость = Истина;
		ДекорацияКартинка.Картинка = БиблиотекаКартинок.СтрелкаЗеленаяВнизРМК;
	КонецЕсли;
КонецПроцедуры

