#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если НЕ ПустаяСтрока(Параметры.ВидДокумента) Тогда
		АвтоЗаголовок = Ложь;
		УстановитьЗаголовок(Параметры.ВидДокумента);
		ВидДокумента = Параметры.ВидДокумента;
	КонецЕсли;

	Если Параметры.ШиринаФормы <> 0 Тогда
		Ширина = Параметры.ШиринаФормы;
	КонецЕсли;

	Если Параметры.Свойство("ДополнениеПодсказкиПоложениеСклада") Тогда
		ДополнениеПодсказкиПоложениеСклада = Параметры.ДополнениеПодсказкиПоложениеСклада;
	КонецЕсли;
	
	Если Параметры.Свойство("ЗаголовокДекорацияВидимостьКолонок")
		И ЗначениеЗаполнено(Параметры.ЗаголовокДекорацияВидимостьКолонок) Тогда

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияВидимостьКолонок", 
			"Заголовок", Параметры.ЗаголовокДекорацияВидимостьКолонок);		
		
	КонецЕсли;
		
	ЗначенияСвойствПриОткрытии = Новый Структура;
	
	ВидимыеЭлементы = Новый Массив;
	
	СчетчикВидимыхНастроек = 0;
	СчетчикПоказыватьСодержание = 0;
	СчетчикПоказыватьКолонку = 0;
	
	ТолькоПросмотрВладельца = (Параметры.ТолькоПросмотр = Истина);
	
	Для Каждого ТекИмяСвойства Из ИменаВозможныхСвойств() Цикл
		
		Если Не Параметры.Свойство(ТекИмяСвойства) Тогда
			Элементы[ТекИмяСвойства].Видимость = Ложь;
			Продолжить;
		КонецЕсли;
		
		ЭтотОбъект[ТекИмяСвойства] = Параметры[ТекИмяСвойства];
		Если НЕ ЗначениеЗаполнено(ЭтотОбъект[ТекИмяСвойства])
			И ТипЗнч(ЭтотОбъект[ТекИмяСвойства]) = Тип("ПеречислениеСсылка.ПоложениеРеквизитаНаФорме") Тогда
			ЭтотОбъект[ТекИмяСвойства] = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке;
		КонецЕсли; 
		ЗначенияСвойствПриОткрытии.Вставить(ТекИмяСвойства, Параметры[ТекИмяСвойства]);
		Элементы[ТекИмяСвойства].Видимость = Истина;
		
		СчетчикВидимыхНастроек = СчетчикВидимыхНастроек + 1;
		Если СтрНайти(ТекИмяСвойства, "Содержание") <> 0 Тогда
			СчетчикПоказыватьСодержание = СчетчикПоказыватьСодержание + 1;
		КонецЕсли;
		Если СтрНайти(ТекИмяСвойства, "ПоказыватьКолонку") <> 0 Тогда
			СчетчикПоказыватьКолонку = СчетчикПоказыватьКолонку + 1;
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ТекИмяСвойства,
				"ТолькоПросмотр", ТолькоПросмотрВладельца);			
		КонецЕсли;
		Если ТекИмяСвойства = "ПоложениеЯчейкиВКомплектацииЗапасов" Тогда
			Элементы.ПоложениеЯчейкиВКомплектацииЗапасов.ТолькоПросмотр = ЭтотОбъект["ПоложениеСкладаВДокументахПроизводства"]
				= Перечисления.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти;
		КонецЕсли; 
		Если СтрНайти(ТекИмяСвойства, "Валюта") > 0 Тогда
		    Элементы[ТекИмяСвойства].Видимость = Константы.ФункциональнаяУчетВалютныхОпераций.Получить();
		КонецЕсли;
		
		ВидимыеЭлементы.Добавить(ТекИмяСвойства);
	
	КонецЦикла;
	
	Если СчетчикПоказыватьСодержание > 1 Тогда
		Элементы.ДекорацияПоказыватьКолонкуСодержание.Видимость = Истина;
	КонецЕсли;
	
	ВидимостьКолонок = СчетчикПоказыватьКолонку <> 0;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияВидимостьКолонок",
			"Видимость", ВидимостьКолонок);
	
	Если Параметры.Свойство("Заголовки") Тогда
		ОбновитьЗаголовкиСвойств(Параметры.Заголовки);
	КонецЕсли; 
	
	Если Параметры.Свойство("Доступность") Тогда
		НастройкиДоступности = Параметры.Доступность;
	Иначе
		НастройкиДоступности = Новый Структура;
	КонецЕсли; 
	НастроитьДоступностьЭлементов(НастройкиДоступности);
	КлючСохраненияПоложенияОкна = СтрСоединить(ВидимыеЭлементы);
	
	Если Параметры.Свойство("РасширенныеПодсказки") Тогда
		УстановитьРасширенныеПодсказки(Параметры.РасширенныеПодсказки);
	КонецЕсли;
	
	Если Параметры.Свойство("НастройкиСправочников") Тогда
		Элементы.ДекорацияПерсональныеНастройки.Видимость = Ложь;
		Элементы.ДекорацияРазделительНастроек1.Видимость = Ложь;
		Элементы.ДекорацияРазделитель3.Видимость = Ложь;
	КонецЕсли;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуСклад") Тогда
		Элементы.ПоложениеСкладаВДокументахОтгрузки.Видимость = Ложь;
		Элементы.ПоложениеСкладаВДокументахПоступления.Видимость = Ложь;
	КонецЕсли;
	
	Если Параметры.Свойство("ИспользуетсяОформление") Тогда  
		
		ИмяТекущегоПользователя = ПользователиИнформационнойБазы.ТекущийПользователь().Имя;
		ИспользуетсяОформление = Параметры.ИспользуетсяОформление;  						
		
		Если ИспользуетсяОформление Тогда			
			ЗагрузитьНастройкиОформления();	
			УстановитьВидимостьРеквизитовОформления(); 			
		КонецЕсли;

	Иначе
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаНастройкиОформления",
			"Видимость", ИспользуетсяОформление); 
			
	КонецЕсли;
	
	Если Параметры.Свойство("ТаблицаПроекта") Тогда
		ПоложениеВТаблице = Элементы.ПоложениеПроекта.СписокВыбора.НайтиПоЗначению(Перечисления.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти);
		Если ПоложениеВТаблице <> Неопределено Тогда
			ПоложениеВТаблице.Представление = Параметры.ТаблицаПроекта;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_НаборКонстант" Тогда
		НастроитьДоступностьЭлементов(НастройкиДоступности);
	КонецЕсли;
	
	Если ИмяСобытия = "ВыборЦветаОформления_УЦ" Тогда
		ЭтотОбъект[Параметр.ИмяЭлементаОформления] = Параметр.ВыбранныйЦвет; 
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДекорацияПерсональныеНастройкиНажатие(Элемент)
	
	СтруктураПараметров = Новый Структура;
	ОткрытьФорму("Обработка.ПерсональныеНастройки.Форма.ФормаНастройкиПользователя", СтруктураПараметров);
	ИзмененыПерсональныеНастройки = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппаПоложениеСкладаВДокументахРасширеннаяПодсказкаОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПараметрыФормы = Новый Структура("СтрокаПоиска", НавигационнаяСсылкаФорматированнойСтроки);
	ОткрытьФорму("Обработка.НастройкаПрограммы.Форма.НастройкаПрограммы", ПараметрыФормы);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоложениеСкладаВДокументахПоступленияПриИзменении(Элемент)
	
	Элементы.ПоложениеДокументаПоступления.Доступность = ПоложениеСкладаВДокументахПоступления = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке");
	ПоложениеДокументаПоступления = ?(ПоложениеСкладаВДокументахПоступления = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке")
	, ПоложениеДокументаПоступления, ПоложениеСкладаВДокументахПоступления);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоложениеСкладаВДокументахОтгрузкиПриИзменении(Элемент)
	Элементы.ПоложениеДокументаПоступления.Доступность = ПоложениеСкладаВДокументахОтгрузки = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке");
	ПоложениеДокументаПоступления = ?(ПоложениеСкладаВДокументахОтгрузки = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке")
	, ПоложениеДокументаПоступления, ПоложениеСкладаВДокументахОтгрузки);
КонецПроцедуры

&НаКлиенте
Процедура ПредложитеСвоюНажатие(Элемент)
	
	Если НЕ ПустаяСтрока(ВидДокумента) Тогда
		ШаблонДляПисьма = НСтр("ru = 'Опишите, каких настроек вам не хватает для %1:'");
		ВидДокументаТекст = ВидДокументаВРодительномПадеже(ВидДокумента);
		Тэг = ВидДокумента;
		ТекстДляПисьма = СтрШаблон(ШаблонДляПисьма, ВидДокументаТекст);
	Иначе
		ТекстДляПисьма = НСтр("ru = 'Опишите, какие настройки вы бы хотели добавить:'");
		Тэг = НСтр("ru = 'Шапка/Табличная часть'");
	КонецЕсли;
	
	УправлениеНебольшойФирмойКлиент.ПредложитьВозможностьНажатие(Тэг, ТекстДляПисьма);
	
КонецПроцедуры


&НаКлиенте
Процедура ПоложениеСкладаВДокументахПроизводстваПриИзменении(Элемент)
	Если ПоложениеСкладаВДокументахПроизводства = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти") Тогда
		ПоложениеЯчейкиВКомплектацииЗапасов = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти");
		Элементы.ПоложениеЯчейкиВКомплектацииЗапасов.ТолькоПросмотр = Истина;
	Иначе
		ПоложениеЯчейкиВКомплектацииЗапасов = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке");
		Элементы.ПоложениеЯчейкиВКомплектацииЗапасов.ТолькоПросмотр = Ложь;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	Закрыть(ПараметрЗакрытия());
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапомнитьВыбор(Команда)
	
	ЗаписатьНовыеНастройки();
	Закрыть(ПараметрЗакрытия());
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбираемыйЭлементОформленияНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	ДополнительныеПараметрыОповещения = Новый Структура;
	ДополнительныеПараметрыОповещения.Вставить("ИмяЭлементаОформления", Элемент.Имя);
	
	ОписаниеОповещенияПослеЗакрытииФормыОформления = Новый ОписаниеОповещения(
		"ОбработчикОповещенияПослеЗакрытияФормыОформления", ЭтотОбъект, ДополнительныеПараметрыОповещения); 
		
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораЦветаУНФ", ДополнительныеПараметрыОповещения, 
		ЭтотОбъект, , , , ОписаниеОповещенияПослеЗакрытииФормыОформления); 
	
КонецПроцедуры 

&НаКлиенте
Процедура ОбработчикОповещенияПослеЗакрытияФормыОформления(Результат, Параметры) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Результат) ИЛИ НЕ ЗначениеЗаполнено(Параметры) Тогда
		Возврат;
	КонецЕсли;
	
	Если Параметры.Свойство("ИмяЭлементаОформления") Тогда
		
		ЭтотОбъект[Параметры.ИмяЭлементаОформления] = Результат; 
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СтандартныеНастройкиЦвета(Команда)
	
	УстановитьСтандартныеНастройкиЦветов();

КонецПроцедуры

&НаСервере
Процедура УстановитьСтандартныеНастройкиЦветов()
	
	ИменаЭлементовОформленияУстановкиЦен = ПолучитьИменаЭлементовОформленияУстановкиЦен();
	
	Для Каждого ИмяЭлементаОформления Из ИменаЭлементовОформленияУстановкиЦен Цикл 
		Если СтрНайти(ИмяЭлементаОформления, "ЦветШрифт") Тогда 
			// цвет шрифта по умолчанию
			ЭтотОбъект[ИмяЭлементаОформления] = ЦветаСтиля.ЦветШрифтаПоУмолчаниюУЦ.ПолучитьАбсолютный();		
		Иначе
			// цвет фона по умолчанию
			ЭтотОбъект[ИмяЭлементаОформления] = ЦветаСтиля.ЦветФонаПоУмолчаниюУЦ.ПолучитьАбсолютный();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура записывает настройки пользователя в регистр.
//
&НаСервере
Процедура УстановитьНастройку(ИмяНастройки)
	
	ЗначениеНастройки = ЗначениеНастройки(ИмяНастройки, ЭтотОбъект);
	ПерсональныеНастройкиРУНФ.Установить(ЗначениеНастройки, ИмяНастройки);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЗначениеНастройки(ИмяНастройки, Форма)
	
	Если ИмяНастройки = "ПоложениеДокументаПоступления" 
		И Форма.Элементы[ИмяНастройки].Видимость
		И Не Форма.Элементы[ИмяНастройки].Доступность Тогда
		Возврат Форма[ИмяНастройки];
	КонецЕсли;
	
	Если Форма.Элементы[ИмяНастройки].Доступность Тогда
		Возврат Форма[ИмяНастройки];
	КонецЕсли;
	
	Возврат Форма.ЗначенияСвойствПриОткрытии[ИмяНастройки];
	
КонецФункции

&НаСервере
Процедура УстановитьЗаголовок(ВидДокумента)
	
	ТекстЗаголовка = НСтр("ru='Персональная настройка %1'");
	ВидДокументаТекст = ПолучитьСклоненияСтроки(ВидДокумента, "Л=ru_RU", "ПД=Родительный")[0];
	Заголовок = СтрШаблон(ТекстЗаголовка, ВидДокументаТекст);
		
КонецПроцедуры

// Процедура записывает настройки пользователя в регистр.
//
&НаСервере
Процедура ЗаписатьНовыеНастройки()
	
	Для Каждого ТекЭлемент Из ЗначенияСвойствПриОткрытии Цикл
		УстановитьНастройку(ТекЭлемент.Ключ);
	КонецЦикла;
	
	ОбновитьПовторноИспользуемыеЗначения();
	
	Если ИспользуетсяОформление И НЕ ПустаяСтрока(ИмяТекущегоПользователя) Тогда
		ЗапомнитьНастройкиОформления();  
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗапомнитьНастройкиОформления()
	
	НастройкиОФормления = Новый Структура;
	НастройкиОФормления.Вставить("ВыбранныйЦветЦенаНовая"		, ВыбранныйЦветЦенаНовая); 
	НастройкиОФормления.Вставить("ВыбранныйЦветЦенаСтарая"	, ВыбранныйЦветЦенаСтарая);  
	НастройкиОФормления.Вставить("ВыбранныйЦветШрифтЦенаНовая"	, ВыбранныйЦветШрифтЦенаНовая); 
	НастройкиОФормления.Вставить("ВыбранныйЦветШрифтЦенаСтарая", ВыбранныйЦветШрифтЦенаСтарая); 
	
	ХранилищеОбщихНастроек.Сохранить("НастройкаОформление_УстановкаЦен", 
		"НастройкаЦвет_УстановкаЦен", НастройкиОФормления, , ИмяТекущегоПользователя);				
		
КонецПроцедуры

&НаКлиенте
Функция БылиВнесеныИзменения()
	
	Для Каждого ТекЭлемент Из ЗначенияСвойствПриОткрытии Цикл
		Если ЭтотОбъект[ТекЭлемент.Ключ] <> ТекЭлемент.Значение Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Функция ПараметрЗакрытия()
	
	Результат = Новый Структура;
	
	Результат.Вставить("БылиВнесеныИзменения", БылиВнесеныИзменения());
	
	Для Каждого ТекЭлемент Из ЗначенияСвойствПриОткрытии Цикл
		Результат.Вставить(ТекЭлемент.Ключ, ЗначениеНастройки(ТекЭлемент.Ключ, ЭтотОбъект));
	КонецЦикла;
	
	Результат.Вставить("БылиИзмененыПерсональныеНастройки", ИзмененыПерсональныеНастройки);
	
	Если ИспользуетсяОформление Тогда 
		
		Результат.Вставить("ВыбранныйЦветЦенаНовая"			, ВыбранныйЦветЦенаНовая);
		Результат.Вставить("ВыбранныйЦветЦенаСтарая"		, ВыбранныйЦветЦенаСтарая);
		Результат.Вставить("ВыбранныйЦветШрифтЦенаНовая"	, ВыбранныйЦветШрифтЦенаНовая);
		Результат.Вставить("ВыбранныйЦветШрифтЦенаСтарая"	, ВыбранныйЦветШрифтЦенаСтарая);
		
	КонецЕсли;
	
	Возврат Результат
	
КонецФункции

