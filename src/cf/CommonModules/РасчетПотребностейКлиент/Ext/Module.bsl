#Область ПрограммныйИнтерфейс

Процедура ЗаказыПоставщикам(Знач Источник, Знач ПараметрыВыполненияКоманды) Экспорт   

	ПараметрыФормы = РасчетПотребностейВызовСервера.РеквизитыЗаказа(Источник);
	
	Если ПараметрыФормы.Свойство("ЗаказПокупателя")
		И ТипЗнч(ПараметрыФормы.ЗаказПокупателя) = Тип("Массив") Тогда
		
		Если ПараметрыФормы.ЗаказПокупателя.Количество() = 1 Тогда
			ПараметрыФормы.ЗаказПокупателя = ПараметрыФормы.ЗаказПокупателя[0];
		Иначе
			ПараметрыФормы.Удалить("ЗаказПокупателя");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПараметрыФормы.Свойство("ЗаказПокупателя")
		И ПараметрыФормы.Свойство("ВидОперации")
		И РаботаСЗаявкамиКлиентСервер.ЭтоЗаявка(ПараметрыФормы.ВидОперации) Тогда
		ВызватьИсключение РаботаСЗаявкамиКлиентСервер.СообщениеОНеобходимостиПереводаЗаявкиВЗаказ(
		ПараметрыФормы.ЗаказПокупателя);
	КонецЕсли;
	
	ОткрытьФорму(
		"Обработка.РасчетПотребностей.Форма", 
		ПараметрыФормы, 
		ПараметрыВыполненияКоманды.Источник);

	СтатистикаИспользованияФормКлиент.ПроверитьЗаписатьСтатистикуКоманды(
		"РасчетПотребностейКлиент.ЗаказыПоставщикам",
		ПараметрыВыполненияКоманды.Источник);    
		
КонецПроцедуры        

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ОперацииПослеФормирования(Форма, ПараметрыФормы) Экспорт
	
	Если ПараметрыФормы.РезультатФоновогоЗадания.Статус <> "Выполняется" 
		И ПараметрыФормы.РезультатФоновогоЗадания.Статус <> "Ошибка" 
		И Не ПараметрыФормы.ПлоскийСписок Тогда
		
		Для каждого Строка Из Форма.Запасы.ПолучитьЭлементы() Цикл
			Форма.Элементы.Запасы.Свернуть(Строка.ПолучитьИдентификатор());
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция РаспределитьПоИсточнику(ПараметрыФормы, ТекСтр, СтрокаИсточник, Распределить, Пропустить) Экспорт
	
	Изменено 	= (СтрокаИсточник.Заказать <> Распределить);
	Пропустить  = Ложь;
	
	Если Изменено Тогда               
		
		Если СтрокаИсточник.Лимит > 0
			И СтрокаИсточник.СпособПополнения <> ПредопределенноеЗначение("Перечисление.СпособыПополненияЗапасов.Перемещение")
			Тогда
			
			Заказать = СтрокаИсточник.Лимит;
			
		Иначе
			Заказать = Распределить;
		КонецЕсли; 

	Иначе
		Заказать	 = 0;
	КонецЕсли;
	
	Возврат Заказать;
	
КонецФункции

Функция РаспределитьПоЗаказу(ПараметрыФормы, ТекСтр, ВложеннаяСтрока, Распределить, Пропустить) Экспорт

	Пропустить  = Ложь;
	
	Возврат ВложеннаяСтрока.Дефицит;
	
КонецФункции

Функция РаспределитьПоПериоду(ПараметрыФормы, ТекСтр, ВложеннаяСтрока, Распределить, Пропустить) Экспорт
	
	Пропустить  = Ложь;

	Возврат ВложеннаяСтрока.Дефицит;
	
КонецФункции

Функция РаспределитьПоДефициту(ПараметрыФормы, ТекСтр, ВложеннаяСтрока, Распределить, Пропустить) Экспорт
	
	Пропустить  = Ложь;

	Возврат ВложеннаяСтрока.Дефицит;
	
КонецФункции

#КонецОбласти

