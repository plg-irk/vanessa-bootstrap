#Область ПрограммныйИнтерфейс

// Описание контекста выполнения обработчика события в форме объекта.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма, из которой вызывается обработчик.
//  Объект - ДанныеФормыСтруктура - объект данных, связанный с формой.
//  ИмяРеквизита - Строка - имя служебного реквизита, в котором будет храниться состояние отражения объекта.
//                          Если не указан, используется предопределенное название реквизита.
//
// Возвращаемое значение:
//  Структура:
//   * Форма - ФормаКлиентскогоПриложения - форма, из которой вызывается обработчик. 
//   * Объект - ДанныеФормыСтруктура - объект данных, связанный с формой.
//   * ИмяРеквизита - Строка - имя служебного реквизита, в котором будет храниться состояние отражения объекта.
//
Функция КонтекстОбработкиСобытия(Форма, Объект, ИмяРеквизита = "") Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Форма", Форма);
	Результат.Вставить("Объект", Объект);
	Результат.Вставить("ИмяРеквизита", ИмяРеквизита);
	
	Если ПустаяСтрока(Результат.ИмяРеквизита) Тогда
		Результат.ИмяРеквизита = ИмяРеквизитаХраненияПараметровИнформационнойПанели();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ИдентификаторПриложения() Экспорт
	
	Возврат СовместноеИспользованиеКлиентСерверПереопределяемый.ИдентификаторПриложения();
	
КонецФункции

Функция ПрефиксыНавигационныхСсылок() Экспорт
	
	Префиксы = Новый Соответствие;
	
	СовместноеИспользованиеКлиентСерверПереопределяемый.ЗаполнитьПрефиксыНавигационныхСсылок(Префиксы);
	
	Возврат Префиксы;
	
КонецФункции

Функция НавигационнаяСсылкаВнешнегоПриложения(ВнутренняяСсылка, ИдентификаторПриложения) Экспорт
	
	Префикс = "";
	Для Каждого КлючЗначение Из ПрефиксыНавигационныхСсылок() Цикл
		Если КлючЗначение.Значение = ИдентификаторПриложения Тогда
			Префикс = КлючЗначение.Ключ;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Префикс + ВнутренняяСсылка;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИмяРеквизитаХраненияПараметровИнформационнойПанели()
	
	Возврат "ПараметрыИнформационнойПанелиСовместногоИспользования";
	
КонецФункции

#КонецОбласти