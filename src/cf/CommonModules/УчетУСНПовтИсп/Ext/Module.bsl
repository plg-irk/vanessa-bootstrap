Функция ВидНалогаЗадачиКалендаряПодготовкиОтчетности() Экспорт 
	
	ТаблицаСоответствия = Новый ТаблицаЗначений();
	
	ТаблицаСоответствия.Колонки.Добавить("ВидНалога", Новый ОписаниеТипов("СправочникСсылка.ВидыНалогов"));
	ТаблицаСоответствия.Колонки.Добавить("ЗадачаКалендаряПодготовкиОтчетности", Новый ОписаниеТипов("СправочникСсылка.ЗадачиКалендаряПодготовкиОтчетности"));
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.АУСН;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.НалогАУСН;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.ЕНВД;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.ЕдиныйНалогЕНВД;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.Патент;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.НалогПатент;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.ФиксированныеВзносы_СтраховыеВзносыЕдиныйТариф;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.СтраховыеВзносыИП;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.ПФРСвыше300ТР;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.СтраховыеВзносыПриДоходахСвыше300ТР;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.СтраховыеВзносыЕдиныйТариф;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.СтраховыеВзносыЗаСотрудников;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.АвансовыйПлатежПриУСНРасходы;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.АвансовыйПлатежПоУСН;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.АвансовыйПлатежПриУСН;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.АвансовыйПлатежПоУСН;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.ЕдиныйНалогПриУСН;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.ЕдиныйНалог;
	
	НоваяСтрокаТаблицы = ТаблицаСоответствия.Добавить();
	НоваяСтрокаТаблицы.ВидНалога 							= Справочники.ВидыНалогов.ЕдиныйНалогПриУСНРасходы;
	НоваяСтрокаТаблицы.ЗадачаКалендаряПодготовкиОтчетности 	= Справочники.ЗадачиКалендаряПодготовкиОтчетности.ЕдиныйНалог;


	Возврат ТаблицаСоответствия;
	
КонецФункции
	
#КонецОбласти