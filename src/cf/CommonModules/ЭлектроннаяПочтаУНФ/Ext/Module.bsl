#Область ОтправкаПочты

// Поддержка передачи параметров до перехода на БСП
//
// Параметры:
//  ПараметрыПисьма - Структура - содержит всю необходимую информацию о письме.
//
Процедура ОбработатьПараметрыПриОтправке(ПараметрыПисьма)
	
	ОбработатьСтруктуруВложенийПриОтправке(ПараметрыПисьма);
	ОбработатьУстаревшуюПередачуСкрытыхКопий(ПараметрыПисьма);
	
КонецПроцедуры

Процедура ОбработатьСтруктуруВложенийПриОтправке(ПараметрыПисьма)
	
	Вложения = Неопределено;
	Если Не ПараметрыПисьма.Свойство("Вложения", Вложения) Или Вложения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Вложение Из Вложения Цикл
		
		Если ТипЗнч(Вложение) <> Тип("КлючИЗначение") Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(Вложение.Значение) = Тип("Структура") Тогда
			
			ОписаниеВложения = Вложение.Значение;
			Если Не ОписаниеВложения.Свойство("ЭтоПисьмоВложение") Или Не ОписаниеВложения.ЭтоПисьмоВложение Тогда
				Продолжить;
			КонецЕсли;
			
			ИнтернетПочтовоеСообщение = Новый ИнтернетПочтовоеСообщение;
			ИнтернетПочтовоеСообщение.УстановитьИсходныеДанные(ОписаниеВложения.ДвоичныеДанные);
			
			// Изначально при создании может добавиться пустой текст
			Если ИнтернетПочтовоеСообщение.Тексты[0].ТипТекста = ТипТекстаПочтовогоСообщения.ПростойТекст Тогда
				ИнтернетПочтовоеСообщение.Тексты.Удалить(0);
			КонецЕсли;
			
			Если ИнтернетПочтовоеСообщение.Тексты[0].ТипТекста = ТипТекстаПочтовогоСообщения.HTML
				И Не СтрНайти(ИнтернетПочтовоеСообщение.Тексты[0].Текст, "<!DOCTYPE html>") Тогда
				
				ИнтернетПочтовоеСообщение.Тексты[0].Текст = СтрШаблон(
				"<!DOCTYPE html>%1",
				ИнтернетПочтовоеСообщение.Тексты[0].Текст);
				
			КонецЕсли;
			
			Вложения[Вложение.Ключ] = ИнтернетПочтовоеСообщение;
			
			Продолжить;
			
		КонецЕсли;
		
		ПреобразованноеЗначениеВложения = ПреобразованноеВложениеДляВставкиВПисьмо(Вложение.Значение);
		Вложения[Вложение.Ключ] = ПреобразованноеЗначениеВложения;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПреобразованноеВложениеДляВставкиВПисьмо(Вложение)
	
	Если ТипЗнч(Вложение) = Тип("Строка") И ЭтоАдресВременногоХранилища(Вложение) Тогда
		
		Возврат ПреобразованноеВложениеДляВставкиВПисьмо(ПолучитьИзВременногоХранилища(Вложение));
		
	ИначеЕсли ТипЗнч(Вложение) = Тип("Картинка") Тогда
		
		Возврат Вложение.ПолучитьДвоичныеДанные();
		
	ИначеЕсли ТипЗнч(Вложение) = Тип("Файл") И Вложение.Существует() И Вложение.ЭтоФайл() Тогда
		
		Возврат Новый ДвоичныеДанные(Вложение.ПолноеИмя);
		
	Иначе
		Возврат Вложение;
	КонецЕсли;
	
КонецФункции

// Добавляет настройки, которых нет в БСП
//
// Параметры:
//  Письмо - ИнтернетПочтовоеСообщение - письмо
//  ПараметрыПисьма - Структура - параметры письма
//
Процедура ДобавитьНастройкиКПисьмуДляОтправки(Письмо, ПараметрыПисьма)
	
	Если ПараметрыПисьма.Свойство("Заголовки")
		И ТипЗнч(ПараметрыПисьма.Заголовки) = Тип("Соответствие") Тогда
		
		Для Каждого ТекЗаголовок Из ПараметрыПисьма.Заголовки Цикл
			Письмо.УстановитьПолеЗаголовка(
			ТекЗаголовок.Ключ,
			ТекЗаголовок.Значение,
			СпособКодированияНеASCIIСимволовИнтернетПочтовогоСообщения.БезКодирования);
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьУстаревшуюПередачуСкрытыхКопий(ПараметрыПисьма)
	
	СлепыеКопии = Неопределено;
	ПараметрыПисьма.Свойство("СлепыеКопии", СлепыеКопии);
	Если СлепыеКопии = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(СлепыеКопии) = Тип("Строка") Тогда
		
		Если Не ПустаяСтрока(СлепыеКопии) Тогда
			
			СлепыеКопии = ОбщегоНазначенияКлиентСервер.РазобратьСтрокуСПочтовымиАдресами(СлепыеКопии);
			ДобавитьСлепыеКопииВПараметрыПисьма(СлепыеКопии, ПараметрыПисьма);
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(СлепыеКопии) = Тип("Массив") И СлепыеКопии.Количество() Тогда
		ДобавитьСлепыеКопииВПараметрыПисьма(СлепыеКопии, ПараметрыПисьма);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСлепыеКопииВПараметрыПисьма(СлепыеКопии, ПараметрыПисьма)
	
	СкрытыеКопии = Неопределено;
	Если ПараметрыПисьма.Свойство("СкрытыеКопии", СкрытыеКопии) Тогда
		
		Если ТипЗнч(СкрытыеКопии) = Тип("Строка") Тогда
			СкрытыеКопии = ОбщегоНазначенияКлиентСервер.РазобратьСтрокуСПочтовымиАдресами(СкрытыеКопии);
		ИначеЕсли ТипЗнч(СкрытыеКопии) <> Тип("Массив") Тогда
			СкрытыеКопии = Новый Массив;
		КонецЕсли;
		
	Иначе
		СкрытыеКопии = Новый Массив;
	КонецЕсли;
	
	Для Каждого Копия Из СлепыеКопии Цикл
		СкрытыеКопии.Добавить(Копия);
	КонецЦикла;
	
	ПараметрыПисьма.Вставить("СкрытыеКопии", СкрытыеКопии);
	
КонецПроцедуры

#КонецОбласти

#Область ПечатныеФормы

Функция ЭтоПредметШаблона(ПараметрКоманды)
	
	Возврат ЭлектроннаяПочтаУНФКлиентСервер.ЭтоПредметШаблона(ПараметрКоманды);
	
КонецФункции

Функция ВложенияПисьмаПриОтправленииСПечатнымиФормами(
	МассивОбъектов,
	ИдентификаторыКомандПечати,
	УникальныйИдентификатор,
	ИмяФормыОбъектаПечати,
	НастройкиВложений = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("СформированыВложенияССсылкамиНаОбъекты", Ложь);
	Результат.Вставить("Вложения", Новый Массив);
	
	Если ИдентификаторыКомандПечати.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	КомандыПечати = КомандыПечати(ИдентификаторыКомандПечати, ИмяФормыОбъектаПечати);
	
	Если Не НастройкиВложений.Свойство("Подписать") Или Не НастройкиВложений.Подписать Тогда
		
		Вложения = УправлениеПечатью.НапечататьВФайл(КомандыПечати, МассивОбъектов, НастройкиВложений);
		Вложения = ОбработанныеВложенияПослеПечати(Вложения, УникальныйИдентификатор);
		
		Результат.Вставить("Вложения", Вложения);
		
	Иначе
		
		//@skip-check bsl-legacy-check-expression-type
		НастройкиВложений.Удалить("Подписать");
		
		Вложения = Новый Соответствие;
		Для Каждого Объект Из МассивОбъектов Цикл
			
			ДанныеФайлов = УправлениеПечатью.НапечататьВФайл(
			КомандыПечати, ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Объект), НастройкиВложений);
			
			Вложения.Вставить(Объект, ОбработанныеВложенияПослеПечати(ДанныеФайлов, УникальныйИдентификатор));
			
		КонецЦикла;
		
		Результат.Вставить("СформированыВложенияССсылкамиНаОбъекты", Истина);
		Результат.Вставить("Вложения", Вложения);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбработанныеВложенияПослеПечати(ДанныеФайловПослеПечати, УникальныйИдентификатор)
	
	Результат = Новый Массив;
	
	Для каждого ДанныеФайла Из ДанныеФайловПослеПечати Цикл
		
		ОписаниеВложения = Новый Структура;
		ОписаниеВложения.Вставить("Представление", ДанныеФайла.ИмяФайла);
		
		АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДанныеФайла.ДвоичныеДанные, УникальныйИдентификатор);
		ОписаниеВложения.Вставить("АдресВоВременномХранилище", АдресВоВременномХранилище);
		
		Результат.Добавить(ОписаниеВложения);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция КомандыПечати(ИдентификаторыКомандПечати, ИмяФормыОбъектаПечати)
	
	ВыбранныеКомандыПечати = Новый Массив;
	КомандыПечати = КомандыПечатиФормы(ИмяФормыОбъектаПечати);
	
	Для каждого ИдентификаторКоманды Из ИдентификаторыКомандПечати Цикл
		КомандаПечати = КомандыПечати.Найти(ИдентификаторКоманды, "Идентификатор");
		Если КомандаПечати <> Неопределено Тогда
			ВыбранныеКомандыПечати.Добавить(КомандаПечати);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ВыбранныеКомандыПечати;
	
КонецФункции

Функция ДанныеПисьмаПриОтправкеПечатныхФорм(ОбъектыОтправки, ЗаполнитьТолькоАдресаты)
	
	Результат = Новый Структура;
	Результат.Вставить("Текст");
	Результат.Вставить("Тема");
	Результат.Вставить("Получатель", Новый Массив);
	
	Если ЗаполнитьТолькоАдресаты Тогда
		Результат.Получатель = ПодготовленныеЭлектронныеАдресаПолучателей(ОбъектыОтправки);
		Возврат Результат;
	КонецЕсли;
	
	ЗаполнитьПараметрыОтправки(Результат, ОбъектыОтправки);
	Возврат Результат;
	
КонецФункции

Функция ПоместитьФайлыВАрхив(ПечатныеФормыДокументов, УникальныйИдентификатор)
	
	Результат = Новый Массив;
	
	ИмяВременногоКаталога = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(ПолучитьИмяВременногоФайла());
	СоздатьКаталог(ИмяВременногоКаталога);
	
	ИмяАрхива = ПолучитьИмяВременногоФайла("zip");
	ЗаписьZipФайла = Новый ЗаписьZipФайла(ИмяАрхива);
	
	Для Каждого СтруктураФайла Из ПечатныеФормыДокументов Цикл
		
		ДанныеФайла = ПолучитьИзВременногоХранилища(СтруктураФайла.АдресВоВременномХранилище);
		ПолноеИмяФайла = ИмяВременногоКаталога + СтруктураФайла.Представление;
		ПолноеИмяФайла = ФайловаяСистема.УникальноеИмяФайла(ПолноеИмяФайла);
		ДанныеФайла.Записать(ПолноеИмяФайла);
		ЗаписьZipФайла.Добавить(ПолноеИмяФайла);
		
	КонецЦикла;
	
	ЗаписьZipФайла.Записать();
	ДвоичныеДанные = Новый ДвоичныеДанные(ИмяАрхива);
	ПутьВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор);
	ОписаниеФайла = Новый Структура;
	Файл = Новый Файл(ИмяАрхива);
	ОписаниеФайла.Вставить("Представление", Файл.Имя);
	ОписаниеФайла.Вставить("АдресВоВременномХранилище", ПутьВоВременномХранилище);
	Результат.Добавить(ОписаниеФайла);
	УдалитьФайлы(ИмяАрхива);
	
	УдалитьФайлы(ИмяВременногоКаталога);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ДанныеДляТехническойПоддержки

Функция ДанныеДляТехническойПоддержки(ПараметрыВыгрузки)
	
	УчетнаяЗапись = ПараметрыВыгрузки.УчетнаяЗапись;
	НачинаяСДаты = ПараметрыВыгрузки.НачинаяСДаты;
	ВыгружатьЗаголовки = ПараметрыВыгрузки.ВыгружатьЗаголовки;
	
	Результат = Новый Структура;
	Результат.Вставить("ДанныеУчетнойЗаписи", ДанныеУчетнойЗаписи(УчетнаяЗапись));
	Результат.Вставить("НастройкиЗагрузкиПисем", НастройкиЗагрузкиПисем(УчетнаяЗапись));
	Результат.Вставить("ДанныеИзИнтернетПочты", ДанныеИзИнтернетПочты(УчетнаяЗапись, НачинаяСДаты, ВыгружатьЗаголовки));
	Результат.Вставить("ДанныеЛога", ДанныеЛога(УчетнаяЗапись, НачинаяСДаты));
	Результат.Вставить("ИдентификаторыСобытийРезультатЗапроса", ИдентификаторыСобытий(УчетнаяЗапись, НачинаяСДаты));
	Результат.Вставить("ИдентификаторыСообщенийРезультатЗапроса", ИдентификаторыСообщений(УчетнаяЗапись, НачинаяСДаты));
	Результат.Вставить("ДействияСПисьмамиРезультатЗапроса", ДействияСПисьмами(УчетнаяЗапись));
	Результат.Вставить("ОшибкиПодключенияЭлектроннойПочтыРезультатЗапроса", ОшибкиПодключенияЭлектроннойПочты(УчетнаяЗапись));
	Результат.Вставить("ПочтовыеЯщикиРезультатЗапроса", ПочтовыеЯщики());
	Результат.Вставить("ПочтовыеЯщикиУчетныхЗаписейРезультатЗапроса", ПочтовыеЯщикиУчетныхЗаписей(УчетнаяЗапись));
	Результат.Вставить("ИнкрементнаяСинхронизацияПочты", ИнкрементнаяСинхронизацияПочты(УчетнаяЗапись));
	Результат.Вставить("ДанныеИзЖурналаРегистрации", ДанныеИзЖурналаРегистрации());
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеУчетнойЗаписи(УчетнаяЗапись)
	
	Данные = Новый Структура;
	Данные.Вставить("Наименование", "");
	Данные.Вставить("АдресЭлектроннойПочты", "");
	Данные.Вставить("ИмяПользователя", "");
	Данные.Вставить("Пользователь", "");
	Данные.Вставить("АвторизацияСПомощьюПочтовогоСервиса", Ложь);
	Данные.Вставить("СерверВходящейПочты", "");
	Данные.Вставить("СерверИсходящейПочты", "");
	Данные.Вставить("ПортСервераВходящейПочты", 0);
	Данные.Вставить("ПортСервераИсходящейПочты", 0);
	Данные.Вставить("ИспользоватьЗащищенноеСоединениеДляВходящейПочты", Ложь);
	Данные.Вставить("ИспользоватьЗащищенноеСоединениеДляИсходящейПочты", Ложь);
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(УчетнаяЗапись,
	"Наименование,АдресЭлектроннойПочты,ИмяПользователя,Пользователь,АвторизацияСПомощьюПочтовогоСервиса,СерверВходящейПочты,СерверИсходящейПочты,ПортСервераВходящейПочты,ПортСервераИсходящейПочты,ИспользоватьЗащищенноеСоединениеДляВходящейПочты,ИспользоватьЗащищенноеСоединениеДляИсходящейПочты");
	ЗаполнитьЗначенияСвойств(Данные, Реквизиты);
	
	Возврат Данные;
	
КонецФункции

Функция НастройкиЗагрузкиПисем(УчетнаяЗапись)
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользуютсяПочтовыеЯщики", Ложь);
	Результат.Вставить("НастройкиЗагрузкиПисемРезультатЗапроса", Неопределено);
	
	Результат.ИспользуютсяПочтовыеЯщики = ИспользуютсяПочтовыеЯщики(УчетнаяЗапись);
	Результат.НастройкиЗагрузкиПисемРезультатЗапроса = РегистрыСведений.НастройкиЗагрузкиПисем.ВсеНастройкиВЗапросе(УчетнаяЗапись);
	
	Возврат Результат;
	
КонецФункции

