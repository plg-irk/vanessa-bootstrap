КонецФункции

Функция ПочтовыеЯщикиУчетныхЗаписей(УчетнаяЗапись)
	
	Возврат Справочники.ПочтовыеЯщикиУчетныхЗаписей.ДанныеЗапросом(УчетнаяЗапись);
	
КонецФункции

Функция ДанныеИзИнтернетПочты(УчетнаяЗапись, НачинаяСДаты, ВыгружатьЗаголовки)
	
	Результат = Новый Структура;
	Результат.Вставить("ПочтовыеЯщики", Новый Массив);
	Результат.Вставить("ИдентификаторыПоЯщикам", Новый Соответствие);
	Результат.Вставить("Заголовки", Неопределено);
	
	ВыгружатьЗаголовки = ВыгружатьЗаголовки И ЗначениеЗаполнено(НачинаяСДаты);
	Если ВыгружатьЗаголовки Тогда
		
		ОписаниеТиповСтрока = Новый ОписаниеТипов("Строка");
		ОписаниеТиповДата = Новый ОписаниеТипов("Дата");
		ОписаниеТиповЧисло = Новый ОписаниеТипов("Число");
		
		Заголовки = Новый ТаблицаЗначений;
		Заголовки.Колонки.Добавить("ПочтовыйЯщик", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("Важность", Новый ОписаниеТипов("ВажностьИнтернетПочтовогоСообщения"));
		Заголовки.Колонки.Добавить("ДатаОтправления", ОписаниеТиповДата);
		Заголовки.Колонки.Добавить("ДатаПолучения", ОписаниеТиповДата);
		Заголовки.Колонки.Добавить("Заголовок", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("Идентификатор", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("ИдентификаторСообщения", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("ИмяОтправителя", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("Отправитель", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("Получатели", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("Копии", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("СлепыеКопии", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("Тема", ОписаниеТиповСтрока);
		Заголовки.Колонки.Добавить("Размер", ОписаниеТиповЧисло);
		
		Результат.Заголовки = Заголовки;
		
	КонецЕсли;
	
	Попытка
		
		Соединение = РаботаСПочтовымиСообщениями.ПодключениеКПочте(УчетнаяЗапись, Истина);
		Результат.ПочтовыеЯщики = Соединение.ПолучитьПочтовыеЯщики();
		
		Для Каждого ПочтовыйЯщик Из Результат.ПочтовыеЯщики Цикл
			
			Попытка
				Соединение.ТекущийПочтовыйЯщик = ПочтовыйЯщик;
			Исключение
				
				ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Логирование почты'", ОбщегоНазначения.КодОсновногоЯзыка()),
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Документы.Событие, ,
				ТекстОшибки);
				Продолжить;
				
			КонецПопытки;
			
			ПараметрыОтбора = Новый Структура;
			Если ЗначениеЗаполнено(НачинаяСДаты) Тогда
				ПараметрыОтбора.Вставить("ПослеДатыОтправления", НачинаяСДаты);
			КонецЕсли;
			
			Идентификаторы = Соединение.ПолучитьИдентификаторы(, ПараметрыОтбора);
			Если Идентификаторы.Количество() Тогда
				Результат.ИдентификаторыПоЯщикам[ПочтовыйЯщик] = Идентификаторы;
			КонецЕсли;
			
			Если Не ВыгружатьЗаголовки Тогда
				Продолжить;
			КонецЕсли;
			
			ЗаголовкиИзПочты = Соединение.ПолучитьЗаголовки(ПараметрыОтбора);
			Для Каждого ЗаголовокИзПочты Из ЗаголовкиИзПочты Цикл
				
				СтрокаТЗ = Заголовки.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЗ, ЗаголовокИзПочты,
				"Важность,ДатаОтправления,ДатаПолучения,Заголовок,ИдентификаторСообщения,ИмяОтправителя,Тема,Размер");
				СтрокаТЗ.ПочтовыйЯщик = ПочтовыйЯщик;
				СтрокаТЗ.Идентификатор = СтрСоединить(ЗаголовокИзПочты.Идентификатор, ", ");
				
				Если ТипЗнч(ЗаголовокИзПочты.Отправитель) = Тип("Строка") Тогда
					СтрокаТЗ.Отправитель = ЗаголовокИзПочты.Отправитель;
				ИначеЕсли ТипЗнч(ЗаголовокИзПочты.Отправитель) = Тип("ИнтернетПочтовыйАдрес") Тогда
					СтрокаТЗ.Отправитель = ЗаголовокИзПочты.Отправитель.Адрес;
				КонецЕсли;
				
				Если ТипЗнч(ЗаголовокИзПочты.Получатели) = Тип("ИнтернетПочтовыеАдреса") Тогда
					Для Каждого Получатель Из ЗаголовокИзПочты.Получатели Цикл
						Если ТипЗнч(Получатель) = Тип("ИнтернетПочтовыйАдрес") Тогда
							СтрокаТЗ.Получатели = СтрШаблон("%1, %2", Получатель.Адрес, СтрокаТЗ.Получатели);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если ТипЗнч(ЗаголовокИзПочты.Копии) = Тип("ИнтернетПочтовыеАдреса") Тогда
					Для Каждого Получатель Из ЗаголовокИзПочты.Копии Цикл
						Если ТипЗнч(Получатель) = Тип("ИнтернетПочтовыйАдрес") Тогда
							СтрокаТЗ.Копии = СтрШаблон("%1, %2", Получатель.Адрес, СтрокаТЗ.Копии);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				Если ТипЗнч(ЗаголовокИзПочты.СлепыеКопии) = Тип("ИнтернетПочтовыеАдреса") Тогда
					Для Каждого Получатель Из ЗаголовокИзПочты.СлепыеКопии Цикл
						Если ТипЗнч(Получатель) = Тип("ИнтернетПочтовыйАдрес") Тогда
							СтрокаТЗ.СлепыеКопии = СтрШаблон("%1, %2", Получатель.Адрес, СтрокаТЗ.СлепыеКопии);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытияЖР(),
		УровеньЖурналаРегистрации.Ошибка, , ,
		ТекстОшибки);
		ОбменСВнешнимиСистемамиЛогирование.ЗаписатьВЛог(ТекстОшибки, УчетнаяЗапись, Истина);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеИзЖурналаРегистрации()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Дата", Новый ОписаниеТипов("Дата"));
	Результат.Колонки.Добавить("ИмяПользователя", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Комментарий", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Данные");
	
	Отбор = Новый Структура;
	// Используется время на сервере
	//@skip-check use-non-recommended-method
	Отбор.Вставить("ДатаНачала", ТекущаяДата() - 60 * 60 * 24);
	Отбор.Вставить("Событие", ИмяСобытияЖР());
	
	Попытка
		ВыгрузитьЖурналРегистрации(Результат, Отбор, "Дата,ИмяПользователя,Комментарий,Данные");
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытияЖР(),
		УровеньЖурналаРегистрации.Ошибка, , ,
		ТекстОшибки);
		ОбменСВнешнимиСистемамиЛогирование.ЗаписатьВЛог(ТекстОшибки, , Истина);
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ЗагрузитьДанныеДляТехническойПоддержкиВФайлы(ДанныеДляТехническойПоддержки)
	
	РезультатСписокИменФайлов = Новый Массив;
	
	Каталог = КаталогВременныхФайлов();
	ИмяФайлаДанныеУчетнойЗаписи = Каталог + "данные_учетной_записи.json";
	ИмяФайлаНастройкиЗагрузкиПисемMXL = Каталог + "настройки_загрузки_писем.mxl";
	ИмяФайлаНастройкиЗагрузкиПисемJSON = Каталог + "настройки_загрузки_писем.json";
	ИмяФайлаЛога = Каталог + "лог.mxl";
	ИмяФайлаИдентификаторыСобытий = Каталог + "идентификаторы_событий.mxl";
	ИмяФайлаИдентификаторыСообщений = Каталог + "идентификаторы_сообщений.mxl";
	ИмяФайлаОшибкиПодключенияЭлектроннойПочты = Каталог + "ошибки_подключения_электронной_почты.mxl";
	ИмяФайлаДействияСПисьмами = Каталог + "действия_с_письмами.mxl";
	ИмяФайлаПочтовыеЯщики = Каталог + "почтовые_ящики.mxl";
	ИмяФайлаПочтовыеЯщикиУчетныхЗаписей = Каталог + "почтовые_ящики_учетных_записей.mxl";
	ИмяФайлаДанныеПочтовыхЯщиков = Каталог + "данные_почтовых_ящиков.json";
	ИмяФайлаИдентификаторыПоПочтовымЯщикам = Каталог + "идентификаторы_по_почтовым_ящикам.json";
	ИмяФайлаЗаголовкиПисем = Каталог + "заголовки_писем.mxl";
	ИмяФайлаИнкрементнаяСинхронизацияПочты = Каталог + "инкрементная_синхронизация_почты.json";
	ИмяФайлаЖурналРегистрации = Каталог + "журнал_регистрации.mxl";
	
	ДанныеУчетнойЗаписи = ДанныеДляТехническойПоддержки.ДанныеУчетнойЗаписи;
	НастройкиЗагрузкиПисем = ДанныеДляТехническойПоддержки.НастройкиЗагрузкиПисем;
	ДанныеЛога = ДанныеДляТехническойПоддержки.ДанныеЛога;
	ИдентификаторыСобытийРезультатЗапроса = ДанныеДляТехническойПоддержки.ИдентификаторыСобытийРезультатЗапроса;
	ИдентификаторыСообщенийРезультатЗапроса = ДанныеДляТехническойПоддержки.ИдентификаторыСообщенийРезультатЗапроса;
	ДействияСПисьмамиРезультатЗапроса = ДанныеДляТехническойПоддержки.ДействияСПисьмамиРезультатЗапроса;
	ПочтовыеЯщикиРезультатЗапроса = ДанныеДляТехническойПоддержки.ПочтовыеЯщикиРезультатЗапроса;
	ПочтовыеЯщикиУчетныхЗаписейРезультатЗапроса = ДанныеДляТехническойПоддержки.ПочтовыеЯщикиУчетныхЗаписейРезультатЗапроса;
	ОшибкиПодключенияЭлектроннойПочтыРезультатЗапроса = ДанныеДляТехническойПоддержки.ОшибкиПодключенияЭлектроннойПочтыРезультатЗапроса;
	ДанныеИзИнтернетПочты = ДанныеДляТехническойПоддержки.ДанныеИзИнтернетПочты;
	ИнкрементнаяСинхронизацияПочты = ДанныеДляТехническойПоддержки.ИнкрементнаяСинхронизацияПочты;
	ДанныеИзЖурналаРегистрации = ДанныеДляТехническойПоддержки.ДанныеИзЖурналаРегистрации;
	
	ДанныеВФайлJSON(ИмяФайлаДанныеУчетнойЗаписи, ДанныеУчетнойЗаписи);
	ДанныеВФайлJSON(ИмяФайлаДанныеПочтовыхЯщиков, ДанныеИзИнтернетПочты.ПочтовыеЯщики);
	ДанныеВФайлJSON(ИмяФайлаИдентификаторыПоПочтовымЯщикам, ДанныеИзИнтернетПочты.ИдентификаторыПоЯщикам);
	ДанныеВФайлJSON(ИмяФайлаИнкрементнаяСинхронизацияПочты, ИнкрементнаяСинхронизацияПочты);
	ПолеВФайлJSON(ИмяФайлаНастройкиЗагрузкиПисемJSON, "ИспользуютсяПочтовыеЯщики", НастройкиЗагрузкиПисем.ИспользуютсяПочтовыеЯщики);
	
	РезультатЗапросаВФайл(ИмяФайлаНастройкиЗагрузкиПисемMXL, НастройкиЗагрузкиПисем.НастройкиЗагрузкиПисемРезультатЗапроса);
	РезультатЗапросаВФайл(ИмяФайлаЛога, ДанныеЛога);
	РезультатЗапросаВФайл(ИмяФайлаИдентификаторыСобытий, ИдентификаторыСобытийРезультатЗапроса);
	РезультатЗапросаВФайл(ИмяФайлаИдентификаторыСообщений, ИдентификаторыСообщенийРезультатЗапроса);
	РезультатЗапросаВФайл(ИмяФайлаДействияСПисьмами, ДействияСПисьмамиРезультатЗапроса);
	РезультатЗапросаВФайл(ИмяФайлаПочтовыеЯщики, ПочтовыеЯщикиРезультатЗапроса);
	РезультатЗапросаВФайл(ИмяФайлаПочтовыеЯщикиУчетныхЗаписей, ПочтовыеЯщикиУчетныхЗаписейРезультатЗапроса);
	РезультатЗапросаВФайл(ИмяФайлаОшибкиПодключенияЭлектроннойПочты, ОшибкиПодключенияЭлектроннойПочтыРезультатЗапроса);
	
	ТаблицуЗначенийВФайл(ИмяФайлаЖурналРегистрации, ДанныеИзЖурналаРегистрации);
	
	Если ДанныеИзИнтернетПочты.Заголовки <> Неопределено Тогда
		ТаблицуЗначенийВФайл(ИмяФайлаЗаголовкиПисем, ДанныеИзИнтернетПочты.Заголовки);
		РезультатСписокИменФайлов.Добавить(ИмяФайлаЗаголовкиПисем);
	КонецЕсли;
	
	РезультатСписокИменФайлов.Добавить(ИмяФайлаДанныеУчетнойЗаписи);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаНастройкиЗагрузкиПисемMXL);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаНастройкиЗагрузкиПисемJSON);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаЛога);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаИдентификаторыСобытий);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаИдентификаторыСообщений);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаОшибкиПодключенияЭлектроннойПочты);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаДействияСПисьмами);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаПочтовыеЯщики);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаПочтовыеЯщикиУчетныхЗаписей);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаДанныеПочтовыхЯщиков);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаИдентификаторыПоПочтовымЯщикам);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаИнкрементнаяСинхронизацияПочты);
	РезультатСписокИменФайлов.Добавить(ИмяФайлаЖурналРегистрации);
	Возврат РезультатСписокИменФайлов;
	
КонецФункции

