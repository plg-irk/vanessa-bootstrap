	Команда.ТолькоВоВсехДействиях = Ложь;
	
КонецПроцедуры

// Сохраненные настройки вложений, выбранные на форме ОбщаяФорма.ВыборФорматаВложений
// 
// Возвращаемое значение:
//  Структура - см. УправлениеПечатью.НастройкиСохранения
//
Функция НастройкиСохраненияФорматаВложенийПечатныхФормПользователя() Экспорт
	
	НастройкиСохраненияПечатныхФорм = УправлениеПечатью.НастройкиСохранения();
	НастройкиСохраненияПечатныхФорм.Вставить("Подписать", Ложь);
	
	СохраненныеНастройкиФормата = ОбщегоНазначения.ХранилищеСистемныхНастроекЗагрузить(
	"ОбщаяФорма.ВыборФорматаВложений/ТекущиеДанные", "");
	
	Если СохраненныеНастройкиФормата = Неопределено Тогда
		//@skip-check constructor-function-return-section
		Возврат НастройкиСохраненияПечатныхФорм;
	КонецЕсли;
	
	ФорматыСохранения = СохраненныеНастройкиФормата.Получить("ВыбранныеФорматыСохранения");
	УпаковатьВАрхив = СохраненныеНастройкиФормата.Получить("УпаковатьВАрхив");
	ПереводитьИменаФайловВТранслит = СохраненныеНастройкиФормата.Получить("ПереводитьИменаФайловВТранслит");
	Подписать = СохраненныеНастройкиФормата.Получить("Подписать");
	
	Если ФорматыСохранения <> Неопределено Тогда
		НастройкиСохраненияПечатныхФорм.ФорматыСохранения =
		ОбщегоНазначенияКлиентСервер.ОтмеченныеЭлементы(ФорматыСохранения);
	КонецЕсли;
	
	Если УпаковатьВАрхив <> Неопределено Тогда
		НастройкиСохраненияПечатныхФорм.УпаковатьВАрхив = УпаковатьВАрхив;
	КонецЕсли;
	
	Если ПереводитьИменаФайловВТранслит <> Неопределено Тогда
		НастройкиСохраненияПечатныхФорм.ПереводитьИменаФайловВТранслит = ПереводитьИменаФайловВТранслит;
	КонецЕсли;
	
	Если Подписать <> Неопределено Тогда
		НастройкиСохраненияПечатныхФорм.Подписать = Подписать;
	КонецЕсли;
	
	//@skip-check constructor-function-return-section
	Возврат НастройкиСохраненияПечатныхФорм;
	
КонецФункции

