	УстановитьСтиль(ТекстHTML, "html", "background-color", "white");
	УстановитьСтиль(ТекстHTML, "html", "color", "white");
	УстановитьСтиль(ТекстHTML, "body", "margin", "auto");
	УстановитьСтиль(ТекстHTML, "body", "padding", "8px !important");
	УстановитьСтиль(ТекстHTML, "body", "background", "white");
