Функция СтилиШапкиСПараметрами(Стили, ДанныеОРазметке)
	
	МинимальныйОтступКонтентаСтроки = 40;
	
	Если ДанныеОРазметке.ДобавитьОтступСнизу Тогда
		СтилиОтступаСнизу = "margin-top: 10px;";
	Иначе
		СтилиОтступаСнизу = "";
	КонецЕсли;
	
	Если ДанныеОРазметке.УБлокаСправа2Строчки Тогда
		
		СтилиОтступаСправа = СтрШаблон(
		"width: calc(100%% - %1px);", ДанныеОРазметке.ШиринаБлокаСправа + МинимальныйОтступКонтентаСтроки);
		
		Если ДанныеОРазметке.ОтправительДобавлен Тогда
			ОтступСправаУОтправителя = СтилиОтступаСправа;
			ОтступСправаУПолучателей = "";
		Иначе
			ОтступСправаУОтправителя = "";
			ОтступСправаУПолучателей = СтилиОтступаСправа;
		КонецЕсли;
		
	Иначе
		ОтступСправаУОтправителя = "";
		ОтступСправаУПолучателей = "";
	КонецЕсли;
	
	Возврат СтрШаблон(
	Стили,
	ДанныеОРазметке.ШиринаБлокаСправа + МинимальныйОтступКонтентаСтроки,
	СтилиОтступаСнизу,
	ОтступСправаУОтправителя,
	ОтступСправаУПолучателей);
	
КонецФункции

Функция ДанныеДляОтображения(РеквизитыОбъекта)
	
	Ссылка = Неопределено;
	РеквизитыОбъекта.Свойство("Ссылка", Ссылка);
	Если Ссылка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Ссылка);
	
	Важность = Неопределено;
	РеквизитыОбъекта.Свойство("Важность", Важность);
	
	НачалоСобытия = Неопределено;
	РеквизитыОбъекта.Свойство("НачалоСобытия", НачалоСобытия);
	ПоменятьНеопределено(НачалоСобытия, '00010101');
	
	ОкончаниеСобытия = Неопределено;
	РеквизитыОбъекта.Свойство("ОкончаниеСобытия", ОкончаниеСобытия);
	ПоменятьНеопределено(ОкончаниеСобытия, '00010101');
	
	ТипСобытия = Неопределено;
	РеквизитыОбъекта.Свойство("ТипСобытия", ТипСобытия);
	ПоменятьНеопределено(ТипСобытия, Перечисления.ТипыСобытий.ЭлектронноеПисьмо);
	
	Тема = Неопределено;
	РеквизитыОбъекта.Свойство("Тема", Тема);
	ПоменятьНеопределено(Тема, "");
	
	ОтКого = Неопределено;
	РеквизитыОбъекта.Свойство("ОтКого", ОтКого);
	
	Кому = Неопределено;
	РеквизитыОбъекта.Свойство("Кому", Кому);
	ПоменятьНеопределено(Кому, Новый Массив);
	ОбработатьПолученныхКонтактов(Кому);
	
	Копии = Неопределено;
	РеквизитыОбъекта.Свойство("Копии", Копии);
	ПоменятьНеопределено(Копии, Новый Массив);
	ОбработатьПолученныхКонтактов(Копии);
	
	КоличествоВложений = Неопределено;
	РеквизитыОбъекта.Свойство("КоличествоВложений", КоличествоВложений);
	ПоменятьНеопределено(КоличествоВложений, 0);
	
	ЭтоСпам = Неопределено;
	РеквизитыОбъекта.Свойство("ЭтоСпам", ЭтоСпам);
	ПоменятьНеопределено(ЭтоСпам, Ложь);
	
	Результат = Новый Структура;
	Результат.Вставить("НавигационнаяСсылка", НавигационнаяСсылка);
	
	Результат.Вставить("Важность", Важность);
	Результат.Вставить("НачалоСобытия", НачалоСобытия);
	Результат.Вставить("ОкончаниеСобытия", ОкончаниеСобытия);
	Результат.Вставить("ТипСобытия", ТипСобытия);
	Результат.Вставить("Тема", Тема);
	
	Результат.Вставить("ОтКого", ОтКого);
	Результат.Вставить("Кому", Кому);
	Результат.Вставить("Копии", Копии);
	
	Результат.Вставить("КоличествоВложений", КоличествоВложений);
	Результат.Вставить("ЭтоСпам", ЭтоСпам);
	
	Возврат Результат;
	
КонецФункции

Процедура ОбработатьПолученныхКонтактов(Контакты)
	
	УбратьДублиКонтактов(Контакты);
	
	Счетчик = 0;
	Пока Счетчик <= Контакты.ВГраница() Цикл
		
		Если Не ЗначениеЗаполнено(Контакты[Счетчик].Ссылка) Или ТипЗнч(Контакты[Счетчик]) <> Тип("Структура") Тогда
			Контакты.Удалить(Счетчик);
			Продолжить;
		КонецЕсли;
		
		Счетчик = Счетчик + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УбратьДублиКонтактов(Контакты)
	
	Счетчик1 = 0;
	Пока Счетчик1 < Контакты.Количество() Цикл
		
		Контакт1 = Контакты[Счетчик1];
		
		Счетчик2 = Счетчик1 + 1;
		Пока Счетчик2 < Контакты.Количество() Цикл
			
			Контакт2 = Контакты[Счетчик2];
			
			Если Контакт1.КакСвязаться <> Контакт2.КакСвязаться Тогда
				Счетчик2 = Счетчик2 + 1;
				Продолжить;
			КонецЕсли;
			
			Важность1 = ВажностьОтображенияКонтакта(Контакт1.Ссылка, Контакт1.ВидКонтакта);
			Важность2 = ВажностьОтображенияКонтакта(Контакт2.Ссылка, Контакт2.ВидКонтакта);
			
			Если Важность1 > Важность2 Тогда
				Контакты.Удалить(Счетчик2);
				Продолжить;
			Иначе
				Контакты.Удалить(Счетчик1);
				Счетчик1 = Счетчик1 - 1;
				Прервать;
			КонецЕсли;
			
			Счетчик2 = Счетчик2 + 1;
			
		КонецЦикла;
		
		Счетчик1 = Счетчик1 + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДанныеОРазметкеОтображенияМетаданных(
	Данные, УникальныйИдентификатор, ДобавлятьИсторию)
	
	Результат = Новый Структура;
	
	Шаблон = "<div class=""preview"" style=""font-family: Arial;"">%1%2%3%4%5%6%7</div>";
	
	РазметкаДляОкнаВыбораТипаКонтакта = РазметкаДляОкнаВыбораТипаКонтакта();
	
	ДанныеБлокаСправа = ДанныеБлокаСправа(
	Данные.НачалоСобытия,
	Данные.ОкончаниеСобытия,
	Данные.ТипСобытия,
	Данные.КоличествоВложений,
	Данные.НавигационнаяСсылка,
	ДобавлятьИсторию);
	
	РазметкаТемы = РазметкаТемы(Данные.Тема, Данные.Важность);
	РазметкаОтправителя = РазметкаОтправителя(Данные.ОтКого);
	РазметкаДопБлока = РазметкаДопБлока(Данные.ЭтоСпам);
	
	РазметкаКому = РазметкаСпискаКонтактов(Данные.Кому, НСтр("ru = 'Кому'"), УникальныйИдентификатор);
	РазметкаКопии = РазметкаСпискаКонтактов(Данные.Копии, НСтр("ru = 'Копии'"), УникальныйИдентификатор);
	Результат.Вставить("Контент", СтрШаблон(
	Шаблон,
	РазметкаДляОкнаВыбораТипаКонтакта,
	ДанныеБлокаСправа.Контент,
	РазметкаТемы,
	РазметкаОтправителя,
	РазметкаКому,
	РазметкаКопии,
	РазметкаДопБлока));
	
	ДобавитьОтступСнизу = ДанныеБлокаСправа.УБлокаСправа2Строчки
	И ПустаяСтрока(РазметкаКому) И ПустаяСтрока(РазметкаКопии) И ПустаяСтрока(РазметкаОтправителя);
	
	Результат.Вставить("ШиринаБлокаСправа", ДанныеБлокаСправа.ШиринаБлокаСправа);
	Результат.Вставить("УБлокаСправа2Строчки", ДанныеБлокаСправа.УБлокаСправа2Строчки);
	Результат.Вставить("ДобавитьОтступСнизу", ДобавитьОтступСнизу);
	Результат.Вставить("ОтправительДобавлен", Не ПустаяСтрока(РазметкаОтправителя));
	
	Возврат Результат;
	
КонецФункции

Функция РазметкаДляОкнаВыбораТипаКонтакта()
	
	Шаблон = "
	|<div class=""preview__contact-modal hide"">
	|	<ul>
	|		<li class=""preview__contact-modal__item"" data-name=""Контрагент"">
	|			<img src=""%1"" alt=""Контрагент"" /><span>%4</span>
	|		</li>
	|		<li class=""preview__contact-modal__item"" data-name=""Контакт"">
	|			<img src=""%2"" alt=""Контакт"" /><span>%5</span>
	|		</li>
	|		<li class=""preview__contact-modal__item"" data-name=""Лид"">
	|			<img src=""%3"" alt=""Лид"" /><span>%6</span>
	|		</li>
	|	</ul>
	|</div>";
	
	Возврат СтрШаблон(Шаблон,
	ПутьBase64Картинки(БиблиотекаКартинок.КоллекцияКонтрагентыКомпания),
	ПутьBase64Картинки(БиблиотекаКартинок.ИконкаКонтактногоЛица),
	ПутьBase64Картинки(БиблиотекаКартинок.КонтактнаяИнформацияЭлПочта),
	НСтр("ru = 'Создать контрагента'"),
	НСтр("ru = 'Создать контакт'"),
	НСтр("ru = 'Создать лид'"));
	
КонецФункции

Функция ДанныеБлокаСправа(
	НачалоСобытия,
	ОкончаниеСобытия,
	ТипСобытия,
	КоличествоВложений,
	НавигационнаяСсылка,
	ДобавлятьИсторию)
	
	Результат = Новый Структура;
	ШиринаБлокаСправа = 0;
	
	Результат.Вставить("УБлокаСправа2Строчки",
	(ДобавлятьИсторию Или КоличествоВложений <> 0) И НачалоСобытия <> '00010101');
	
	ЭлементСправа = "<div class=""preview__right-block"">%1%2</div>";
	
	ШиринаСсылкиСКартинкой = 80;
	Если ДобавлятьИсторию Или КоличествоВложений <> 0 Тогда
		
		ЭлементВложений = ЭлементВложений(
		КоличествоВложений, НавигационнаяСсылка, ШиринаБлокаСправа, ШиринаСсылкиСКартинкой);
		ЭлементИстории = ЭлементИстории(
		ДобавлятьИсторию, НавигационнаяСсылка, ШиринаБлокаСправа, ШиринаСсылкиСКартинкой);
		
		ЭлементИсторииИВложений = СтрШаблон(
		"<div class=""preview__right-block__links"">%1%2</div>", ЭлементВложений, ЭлементИстории);
		
	КонецЕсли;
	
	ЭлементДаты = ЭлементДаты(ШиринаБлокаСправа, ТипСобытия, НачалоСобытия, ОкончаниеСобытия, ШиринаСсылкиСКартинкой);
	
	Результат.Вставить("Контент", СтрШаблон(ЭлементСправа, ЭлементИсторииИВложений, ЭлементДаты));
	Результат.Вставить("ШиринаБлокаСправа", ШиринаБлокаСправа);
	
	Возврат Результат;
	
КонецФункции

Функция ЭлементВложений(КоличествоВложений, НавигационнаяСсылка, ШиринаБлокаСправа, ШиринаСсылкиСКартинкой)
	
	Если КоличествоВложений = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ШиринаБлокаСправа = ШиринаСсылкиСКартинкой;
	
	Возврат СтрШаблон("
	|<span data-href=""%1"" class=""preview__files"">
	|	<img src=""%2"" alt="""" />
	|	<div class=""link"">%3 (%4)</div>
	|</span>",
	НавигационнаяСсылка,
	ПутьBase64Картинки(БиблиотекаКартинок.Скрепка),
	НСтр("ru = 'Файлы'"),
	КоличествоВложений);
	
КонецФункции

Функция ЭлементИстории(ДобавлятьИсторию, НавигационнаяСсылка, ШиринаБлокаСправа, ШиринаСсылкиСКартинкой)
	
	Если Не ДобавлятьИсторию Тогда
		Возврат "";
	КонецЕсли;
	
	ШиринаБлокаСправа = ШиринаБлокаСправа + ШиринаСсылкиСКартинкой;
	
	Возврат СтрШаблон("
	|<span data-href=""%1"" class=""preview__history"">
	|	<img src=""%2"" alt="""" />
	|	<div class=""link"">%3</div>
	|</span>",
	НавигационнаяСсылка,
	ПутьBase64Картинки(БиблиотекаКартинок.Переписка),
	НСтр("ru = 'История'"));
	
КонецФункции

Функция ЭлементДаты(ШиринаБлокаСправа, ТипСобытия, НачалоСобытия, ОкончаниеСобытия, ШиринаСсылкиСКартинкой)
	
	ШаблонЭлементаДаты = "<div class=""preview__right-block__date"">%1</div>";
	
	Если НачалоСобытия = '00010101' Тогда
		
		ШиринаБлокаСправа = Макс(ШиринаБлокаСправа, ШиринаСсылкиСКартинкой);
		Возврат СтрШаблон(ШаблонЭлементаДаты, НСтр("ru = 'Черновик'"));
		
	КонецЕсли;
	
	Если ТипСобытия <> Перечисления.ТипыСобытий.ЭлектронноеПисьмо
		И ОкончаниеСобытия <> '00010101'
		И ОкончаниеСобытия <> НачалоСобытия Тогда
		
		Если День(НачалоСобытия) = День(ОкончаниеСобытия)
			И Месяц(НачалоСобытия) = Месяц(ОкончаниеСобытия)
			И Год(НачалоСобытия) = Год(ОкончаниеСобытия) Тогда
			
			ПредставлениеДаты = СтрШаблон("%1 &ndash; %2",
			Формат(НачалоСобытия, "ДЛФ=DT"), Формат(ОкончаниеСобытия, "ДЛФ=T"));
			ШиринаБлокаСправа = 180;
			
		Иначе
			
			ПредставлениеДаты = СтрШаблон("%1 &ndash; %2", НачалоСобытия, ОкончаниеСобытия);
			ШиринаБлокаСправа = 250;
			
		КонецЕсли;
		
	Иначе
		
		ПредставлениеДаты = НачалоСобытия;
		ШиринаБлокаСправа = Макс(ШиринаБлокаСправа, 130);
		
	КонецЕсли;
	
	Возврат СтрШаблон(ШаблонЭлементаДаты, ПредставлениеДаты);
	
КонецФункции

Функция РазметкаТемы(Тема, Важность)
	
	СодержаниеПустойТемы = НСтр("ru = '&lt;Без темы&gt;'");
	
	Если ПустаяСтрока(Тема) Тогда
		Тема = СодержаниеПустойТемы;
	Иначе
		
		Последние3Символа = Прав(Тема, 3);
		
		Если Последние3Символа = "Re:" Или Последние3Символа = "Fw:" Или Прав(Тема, 4) = "Fwd:" Тогда
			Тема = СтрШаблон("%1 %2", Тема, СодержаниеПустойТемы);
		КонецЕсли;
		
	КонецЕсли;
	
	ВысокаяВажность =
	Важность <> Неопределено
	И Важность = ПредопределенноеЗначение("Перечисление.ВариантыВажности.Высокая");
	
	Если ВысокаяВажность Тогда
		КартинкаВажности = СтрШаблон(
		"<img src=""%1"" alt=""%2"" />",
		ПутьBase64Картинки(БиблиотекаКартинок.ВосклицательныйЗнакКрасный),
		НСтр("ru = 'Высокая важность'"));
	Иначе
		КартинкаВажности = "";
	КонецЕсли;
	
	Заголовок = НСтр("ru = 'Тема'");
	Контент = СтрШаблон("%1<span>%2</span>", КартинкаВажности, Тема);
	
	Возврат БлокСтрокиСДанными(Заголовок, Контент, "preview__theme preview__row_first");
	
КонецФункции

Функция РазметкаОтправителя(ОтКого)
	
	Если Не ЗначениеЗаполнено(ОтКого.Ссылка) Тогда
		Возврат "";
	КонецЕсли;
	
	Заголовок = НСтр("ru = 'От'");
	Контент = ЭлементСсылкиКонтакта(ОтКого);
	
	Возврат БлокСтрокиСДанными(Заголовок, Контент, "preview__sender");
	
КонецФункции

Функция РазметкаСпискаКонтактов(Список, Заголовок, УникальныйИдентификатор)
	
	КоличествоКонтактов = Список.Количество();
	Если КоличествоКонтактов = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Контент = "";
	
	МаксимальноеКоличествоПоказанныхКонтактов = 3;
	Счетчик = 0;
	Для Каждого Контакт Из Список Цикл
		
		Если Счетчик = КоличествоКонтактов - 1 Или Счетчик = МаксимальноеКоличествоПоказанныхКонтактов - 1 Тогда
			РазметкаКонтакта = ЭлементСсылкиКонтакта(Контакт);
		Иначе
			РазметкаКонтакта = ЭлементСсылкиКонтакта(Контакт, ",");
		КонецЕсли;
		
		Контент = СтрШаблон("%1%2", Контент, РазметкаКонтакта);
		
		Счетчик = Счетчик + 1;
		Если Счетчик = МаксимальноеКоличествоПоказанныхКонтактов Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Счетчик = МаксимальноеКоличествоПоказанныхКонтактов
		И КоличествоКонтактов > МаксимальноеКоличествоПоказанныхКонтактов Тогда
		
		СсылкаНаВсеКонтакты = ВерсткаСсылкиНаВсеКонтакты(Контент, Список, УникальныйИдентификатор, КоличествоКонтактов);
		Контент = СтрШаблон("%1 %2", Контент, СсылкаНаВсеКонтакты);
		
	КонецЕсли;
	
	Возврат БлокСтрокиСДанными(Заголовок, Контент, "preview__main-getter");
	
КонецФункции

Функция ВерсткаСсылкиНаВсеКонтакты(Верстка, Список, УникальныйИдентификатор, КоличествоКонтактов)
	
	ОписаниеТиповСтрока = Новый ОписаниеТипов("Строка");
	
	ДанныеКонтактов = Новый ТаблицаЗначений;
	ДанныеКонтактов.Колонки.Добавить("ИндексКартинки", Новый ОписаниеТипов("Число"));
	ДанныеКонтактов.Колонки.Добавить("Контакт", Новый ОписаниеТипов("СправочникСсылка.АдресатыПисем, Строка"));
	ДанныеКонтактов.Колонки.Добавить("КонтактСтрокой", ОписаниеТиповСтрока);
	ДанныеКонтактов.Колонки.Добавить("КакСвязаться", ОписаниеТиповСтрока);
	
	ОписаниеТиповКонтактов = Новый ОписаниеТипов(
	"СправочникСсылка.Лиды, СправочникСсылка.КонтактыЛидов, СправочникСсылка.КонтактныеЛица, СправочникСсылка.Контрагенты, СправочникСсылка.ФизическиеЛица");
	ДанныеКонтактов.Колонки.Добавить("КонтактCRM", ОписаниеТиповКонтактов);
	
	Счетчик = 0;
	Для Каждого Контакт Из Список Цикл
		
		НоваяСтрока = ДанныеКонтактов.Добавить();
		СтруктураДанных = СтруктураКонтактаДляОтображенияВСписке(Контакт);
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураДанных);
		
		Счетчик = Счетчик + 1;
		
	КонецЦикла;
	
	СсылкаНаТЗ = ПоместитьВоВременноеХранилище(ДанныеКонтактов, УникальныйИдентификатор);
	
	ПредставлениеСловаПолучатели = ПредставлениеСлова(
	КоличествоКонтактов,
	НСтр("ru = 'получатель'"),
	НСтр("ru = 'получателя'"),
	НСтр("ru = 'получателей'"));
	
	Возврат СтрШаблон("
	|<div class=""preview__other-contacts"" data-href=""%1"">
	|	%2 <span class=""link"">%3 %4</span>)
	|</div>",
	СсылкаНаТЗ,
	НСтр("ru = 'и другие (всего'"),
	Счетчик,
	ПредставлениеСловаПолучатели);
	
КонецФункции

Функция РазметкаДопБлока(ЭтоСпам)
	
	Если ЭтоСпам Тогда
		БлокСпама = СтрШаблон("<div class=""preview__spam"">%1</div>",
		НСтр("ru = 'Это письмо находится в папке Спам. Если оно попало в нее по ошибке, то перенесите в другую папку.'"));
	Иначе
		БлокСпама = "";
	КонецЕсли;
	
	Возврат СтрШаблон("<div class=""preview__additional"">%1<hr class=""preview__hr"" /></div>", БлокСпама);
	
КонецФункции

Функция БлокСтрокиСДанными(Заголовок, Контент, ДопКлассы = "")
	
	Возврат СтрШаблон("
	|<div class=""preview__row %1"">
	|	<div class=""preview__title"">%2</div>
	|	<div class=""preview__content"">%3</div>
	|</div>",
	ДопКлассы,
	Заголовок,
	Контент);
	
КонецФункции

Функция ПутьBase64Картинки(Картинка)
	
	Base64Картинки = Base64Строка(Картинка.ПолучитьДвоичныеДанные());
	
	Если Картинка.Формат() = ФорматКартинки.SVG Тогда
		Возврат СтрШаблон("data:image/svg+xml;base64,%1", Base64Картинки);
	КонецЕсли;
	
	Возврат СтрШаблон("data:image/jpg;base64,%1", Base64Картинки);
	
КонецФункции

Функция ПредставлениеСлова(Количество, Предмет, Предмета, Предметов)
	
	ЧислоПоМодулю100 = Количество % 100;
	ЧислоПоМодулю10 = Количество % 10;
	
	Если ЧислоПоМодулю10 = 1 Тогда
		
		Если ЧислоПоМодулю100 = 11 Тогда
			Возврат Предметов;
		Иначе
			Возврат Предмет;
		КонецЕсли;
		
	ИначеЕсли ЧислоПоМодулю10 = 2 Или ЧислоПоМодулю10 = 3 Или ЧислоПоМодулю10 = 4 Тогда
		
		Если ЧислоПоМодулю100 = 12 Или ЧислоПоМодулю100 = 13 Или ЧислоПоМодулю100 = 14 Тогда
			Возврат Предметов;
		Иначе
			Возврат Предмета;
		КонецЕсли;
		
	Иначе
		
		Возврат Предметов;
		
	КонецЕсли;
	
КонецФункции

Функция СтруктураКонтактаДляОтображенияВСписке(ДанныеКонтакта)
	
	Результат = Новый Структура;
	
	Результат.Вставить("КонтактCRM", ДанныеКонтакта.Ссылка);
	Результат.Вставить("Контакт", ДанныеКонтакта.КонтактВПисьме);
	Результат.Вставить("КонтактСтрокой", ДанныеКонтакта.Представление);
	Результат.Вставить("КакСвязаться", ДанныеКонтакта.КакСвязаться);
	ИндексКартинки = НомерКартинкиУчастникаПоТипуКонтакта(
	ДанныеКонтакта.Ссылка, ДанныеКонтакта.ВидКонтакта, ДанныеКонтакта.ПометкаУдаления, 1);
	Результат.Вставить("ИндексКартинки", ИндексКартинки);
	
	Возврат Результат;
	
КонецФункции

Функция ЭлементСсылкиКонтакта(Контакт, Постфикс = "")
	
	Если Не ЗначениеЗаполнено(Контакт.Ссылка) Тогда
		Возврат "";
	КонецЕсли;
	
	ТипКонтакта = ТипЗнч(Контакт.Ссылка);
	
	Если ТипКонтакта = Тип("СправочникСсылка.УчетныеЗаписиЭлектроннойПочты") Тогда
		
		Возврат СтрШаблон("
		|<div class=""preview__contact"">
		|	<a href=""%1"" class=""link"" header-link>%2 &lt;%3&gt;%4</a>
		|</div>",
		ПолучитьНавигационнуюСсылку(Контакт.Ссылка),
		Контакт.Представление,
		Контакт.КакСвязаться,
		Постфикс);
		
	КонецЕсли;
	
	Если ТипКонтакта = Тип("СправочникСсылка.АдресатыПисем") Или ТипКонтакта = ТИп("Строка") Тогда
		
		Если ТипКонтакта = Тип("СправочникСсылка.АдресатыПисем") Тогда
			ЗначениеАтрибутаСсылки = ПолучитьНавигационнуюСсылку(Контакт.Ссылка);
			КлассНесуществующегоКонтакта = "preview__contact_null";
			КлассСсылки = "class=""link""";
		Иначе
			ЗначениеАтрибутаСсылки = Контакт.Ссылка;
			КлассНесуществующегоКонтакта = "";
			КлассСсылки = "";
		КонецЕсли;
		
		Возврат СтрШаблон(
		"<div class=""preview__contact %7"" data-href=""%1"" data-how-to-connect=""%2"">
		|	<span %6 header-link>%3 &lt;%4&gt;%5</span>
		|</div>",
		ЗначениеАтрибутаСсылки,
		Контакт.КакСвязаться,
		Контакт.Представление,
		Контакт.КакСвязаться,
		Постфикс,
		КлассСсылки,
		КлассНесуществующегоКонтакта);
		
	КонецЕсли;
	
	НазваниеКартинкиКонтакта = НазваниеКартинкиКонтакта(Контакт);
	Если НазваниеКартинкиКонтакта = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СтрШаблон("
	|<div class=""preview__contact"">
	|	<img src=""%1"" alt=""%2"" />
	|	<a href=""%3"" class=""link"" header-link>%4 &lt;%5&gt;%6</a>
	|</div>",
	ПутьBase64Картинки(БиблиотекаКартинок[НазваниеКартинкиКонтакта]),
	НазваниеКартинкиКонтакта,
	ПолучитьНавигационнуюСсылку(Контакт.Ссылка),
	Контакт.Представление,
	Контакт.КакСвязаться,
	Постфикс);
	
КонецФункции

Функция НазваниеКартинкиКонтакта(Контакт)
	
	ТипКонтакта = ТипЗнч(Контакт.Ссылка);
	
	Если ТипКонтакта = Тип("СправочникСсылка.Контрагенты") Тогда
		
		Если Контакт.ВидКонтакта = Перечисления.ВидыКонтрагентов.ФизическоеЛицо
			Или Контакт.ВидКонтакта = Перечисления.ВидыКонтрагентов.ИндивидуальныйПредприниматель Тогда
			Возврат "КоллекцияКонтрагентыФизическоеЛицо";
		Иначе
			Возврат "КоллекцияКонтрагентыКомпания";
		КонецЕсли;
		
	ИначеЕсли ТипКонтакта = Тип("СправочникСсылка.Лиды") Тогда
		
		Если Контакт.ВидКонтакта = Перечисления.ВидыЛидов.ПовторноеОбращение Тогда
			Возврат "ПовторныйЛид";
		Иначе
			Возврат "ПервичныйЛид";
		КонецЕсли;
		
	ИначеЕсли ТипКонтакта = Тип("СправочникСсылка.КонтактныеЛица") Тогда
		Возврат "ИконкаКонтактногоЛица";
	ИначеЕсли ТипКонтакта = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Возврат "ФизическоеЛицо";
	ИначеЕсли НЕ ЗначениеЗаполнено(Контакт.Ссылка)
		Или ТипКонтакта = Тип("СправочникСсылка.АдресатыПисем")
		Или ТипКонтакта = Тип("СправочникСсылка.УчетныеЗаписиЭлектроннойПочты") Тогда
		Возврат Неопределено;
	Иначе
		Возврат "ЭлектроннаяПочта";
	КонецЕсли;
	
КонецФункции

Процедура ПоместитьШапку(ТекстHTML, РазметкаШапки, СтилиПараметром)
	
	ПозицияДляВставки = ПозицияДляВставкиШапки(ТекстHTML);
	
	КонтентДоШапки = Сред(ТекстHTML, 1, ПозицияДляВставки - 1);
	
	КонтентПослеШапки = Сред(ТекстHTML, ПозицияДляВставки);
	Если СтилиПараметром <> Неопределено Тогда
		КонтентПослеШапки = СтрШаблон("<div %1>%2</div>", СтилиПараметром, КонтентПослеШапки);
	КонецЕсли;
	
	ТекстHTML = СтрШаблон("%1
	|<!-- Начало шапки -->
	|%2
	|<!-- Конец шапки -->
	|%3",
	КонтентДоШапки,
	РазметкаШапки,
	КонтентПослеШапки);
	
КонецПроцедуры

Функция ПозицияДляВставкиШапки(ТекстHTML)
	
	НРегТекстHTML = НРег(ТекстHTML);
	
	ПозицияBody = СтрНайти(НРегТекстHTML, "<body");
	Если ПозицияBody Тогда
		ПозицияПравойКавычки = СтрНайти(НРегТекстHTML, ">", , ПозицияBody);
		Возврат ПозицияПравойКавычки + 1;
	КонецЕсли;
	
	Возврат 1;
	
КонецФункции

Процедура УстановитьСтиль(ТекстHTML, НазваниеТега, Стиль, Значение = "auto")
	
	НачалоТега = СтрНайти(ТекстHTML, СтрШаблон("<%1", НазваниеТега));
	КонецТега = СтрНайти(ТекстHTML, ">", , НачалоТега);
	Тег = Сред(ТекстHTML, НачалоТега, КонецТега - НачалоТега + 1);
	
	НачалоСтилей = СтрНайти(Тег, "style");
	Если НачалоСтилей Тогда
		
		ИндексПервойКавычки = СтрНайти(Тег, """", , НачалоСтилей);
		ИндексВторойКавычки = СтрНайти(Тег, """", , ИндексПервойКавычки + 1);
		Стили = Сред(Тег, ИндексПервойКавычки + 1, ИндексВторойКавычки - ИндексПервойКавычки - 1);
		
	Иначе
		
		Стили = "";
		
	КонецЕсли;
	
	НовыеСтили = ДобавитьСтиль(Стили, Стиль, Значение);
	
	Если НачалоСтилей Тогда
		ТегСНовымиСтилями = СтрЗаменить(Тег, Стили, НовыеСтили);
	Иначе
		ТегСНовымиСтилями = СтрЗаменить(Тег, ">", СтрШаблон(" style=""%1"">", НовыеСтили));
	КонецЕсли;
	
	ТекстHTML = СтрЗаменить(ТекстHTML, Тег, ТегСНовымиСтилями);
	
КонецПроцедуры

Функция ДобавитьСтиль(Знач Стили, Стиль, Значение = "auto")
	
	Стили = НРег(Стили);
	
	Если Не ЗначениеЗаполнено(Стили) Тогда
		Возврат СтрШаблон("%1: %2;", Стиль, Значение);
	КонецЕсли;
	
	ИндексСтиля = СтрНайти(Стили, Стиль);
	Если ИндексСтиля = 0 Тогда
		Возврат СтрШаблон("%1: %2;%3", Стиль, Значение, Стили);
	КонецЕсли;
	
	Если ИндексСтиля <> 1 Тогда
		
		СимволДоСтиля = "";
		Пока Истина Цикл
			
			СимволДоСтиля = Сред(Стили, ИндексСтиля - 1, 1);
			
			Если СимволДоСтиля = " " Или СимволДоСтиля = ";" Тогда
				Прервать;
			КонецЕсли;
			
			ИндексСтиля = СтрНайти(Стили, Стиль, , ИндексСтиля + 1);
			Если ИндексСтиля = 0 Тогда
				Возврат СтрШаблон("%1: %2;%3", Стиль, Значение, Стили);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ИндексТочкиСЗапятой = СтрНайти(Стили, ";", , ИндексСтиля);
	СтилиДоНайденного = Сред(Стили, 1, ИндексСтиля - 1);
	Если ИндексТочкиСЗапятой = 0 Тогда
		Возврат СтрШаблон("%1%2: %3;", СтилиДоНайденного, Стиль, Значение);
	КонецЕсли;
	
	Возврат СтрШаблон("%1%2: %3;%4", СтилиДоНайденного, Стиль, Значение, Сред(Стили, ИндексТочкиСЗапятой + 1));
	
КонецФункции

Функция СтилиПараметром(ТекстHTML, НазваниеТега)
	
	НачалоТега = СтрНайти(ТекстHTML, СтрШаблон("<%1", НазваниеТега));
	КонецТега = СтрНайти(ТекстHTML, ">", , НачалоТега);
	Тег = Сред(ТекстHTML, НачалоТега, КонецТега - НачалоТега);
	
	НачалоСтилей = СтрНайти(Тег, "style");
	Если НачалоСтилей Тогда
		
		ИндексПервойКавычки = СтрНайти(Тег, """", , НачалоСтилей);
		ИндексВторойКавычки = СтрНайти(Тег, """", , ИндексПервойКавычки + 1);
		
		Возврат Сред(Тег, НачалоСтилей, ИндексВторойКавычки);
		
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

