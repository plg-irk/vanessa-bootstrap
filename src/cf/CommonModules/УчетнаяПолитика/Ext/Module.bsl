Функция ДатаНачалаУплатыНДСНаУСН(Организация, Период) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ДатаСреза", Период);
	Запрос.УстановитьПараметр("ДатаНачалаПримененияНДСнаУСН", Дата(2025, 1, 1));
	Запрос.Текст =
	"ВЫБРАТЬ
	|    МАКСИМУМ(НастройкиСистемыНалогообложения.Период) КАК Период
	|ПОМЕСТИТЬ ПериодБезНДС
	|ИЗ
	|    РегистрСведений.СистемыНалогообложенияОрганизаций КАК НастройкиСистемыНалогообложения
	|ГДЕ
	|    НастройкиСистемыНалогообложения.Организация = &Организация
	|    И НастройкиСистемыНалогообложения.Период МЕЖДУ &ДатаНачалаПримененияНДСнаУСН И &ДатаСреза
	|    И НЕ НастройкиСистемыНалогообложения.ПлательщикНДСПрименяющийУСН
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|    МИНИМУМ(НастройкиСистемыНалогообложения.Период) КАК Период
	|ИЗ
	|    РегистрСведений.СистемыНалогообложенияОрганизаций КАК НастройкиСистемыНалогообложения
	|        ЛЕВОЕ СОЕДИНЕНИЕ ПериодБезНДС КАК ПериодБезНДС
	|        ПО НастройкиСистемыНалогообложения.Период > ЕСТЬNULL(ПериодБезНДС.Период, &ДатаНачалаПримененияНДСнаУСН)
	|ГДЕ
	|    НастройкиСистемыНалогообложения.Организация = &Организация
	|    И НастройкиСистемыНалогообложения.Период <= &ДатаСреза
	|    И НастройкиСистемыНалогообложения.ПлательщикНДСПрименяющийУСН";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Период;
	Иначе
		Возврат '00010101';
	КонецЕсли;

КонецФункции

