Процедура ПОД_Справочник_ПрайсЛистПалитра_Отправка_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	
	ПравилоПрайсЛистПалитра
		= КомпонентыОбмена.ПравилаОбработкиДанных.Найти("Справочник_ПрайсЛистПалитра_Отправка", "Имя");
	Если ПравилоПрайсЛистПалитра <> Неопределено Тогда
		Для Каждого СтрокаСостава Из ДанныеИБ.Состав Цикл
			Если ЗначениеЗаполнено(СтрокаСостава.Палитра)
					И КомпонентыОбмена.ВыгруженныеОбъекты.Найти(СтрокаСостава.Палитра) = Неопределено Тогда
				ВложеннаяПалитраОбъект = СтрокаСостава.Палитра.ПолучитьОбъект();
				Если Не ВложеннаяПалитраОбъект = Неопределено Тогда
					ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, ВложеннаяПалитраОбъект, ПравилоПрайсЛистПалитра);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПОД_Справочник_ШтрихкодыУпаковокТоваров_Отправка_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК"  Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаПКПД = КомпонентыОбмена.ПравилаКонвертацииПредопределенныхДанных.Найти("ТипыШтрихкодов", "ИмяПКПД");
	СоответствиеПКПД = СтрокаПКПД.КонвертацииЗначенийПриОтправке;
	
	Если СоответствиеПКПД[ДанныеИБ.ТипШтрихкода] = Неопределено Тогда
	   	ИспользованиеПКО.Справочник_ШтрихкодыУпаковокТоваров_Отправка = Ложь;
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеПеречисленияФорматаОбмена(КомпонентыОбмена, "ТипыШтрихкодов."+СоответствиеПКПД[ДанныеИБ.ТипШтрихкода]) Тогда
	   	ИспользованиеПКО.Справочник_ШтрихкодыУпаковокТоваров_Отправка = Ложь;
		Возврат;
	КонецЕсли;

КонецПроцедуры

Процедура ДобавитьПОД_Справочник_ШтрихкодыНоменклатуры_Отправка(ПравилаОбработкиДанных)    
	
	ПравилоОбработки                         = ПолучитьПравилоОбработки(ПравилаОбработкиДанных, "Справочник_ШтрихкодыНоменклатуры_Отправка");
	ПравилоОбработки.ПриОбработке            = "ПОД_Справочник_ШтрихкодыНоменклатуры_Отправка_ПриОбработке";
	
КонецПроцедуры

Процедура ПОД_Справочник_ШтрихкодыНоменклатуры_Отправка_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)

	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК"  Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеИБ.ДополнительныеСвойства.Свойство("ВыгрузитьУдалениеШтрихкодаНастроеннойНоменклатуры") Тогда
		Возврат;
	КонецЕсли;
	
	//Если это Настроенная номенклатура, то её штрихкоды выгружаются с номенклатурой частичного выбытия.
	//Кроме алкогольной продукции.
	ТекстЗапроса = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Т.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ТаблицаНоменклатуры
	|ИЗ
	|	РегистрСведений.НастройкиЧастичногоВыбытияПродукцииИС КАК Т
	|ГДЕ
	|	Т.Номенклатура = &Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	1 КАК Поле1
	|ИЗ
	|	ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
	|		ПО ТаблицаНоменклатуры.Номенклатура = НоменклатураСпр.Ссылка
	|ГДЕ
	|	НЕ НоменклатураСпр.ВидПродукцииИС = &ВидыПродукцииИСАлкогольная";

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Номенклатура", ДанныеИБ.Отбор.Номенклатура.Значение);
	Запрос.УстановитьПараметр("ВидыПродукцииИСАлкогольная", Перечисления.ВидыПродукцииИС.Алкогольная);
	РезультатЗапроса = Запрос.Выполнить();
	ИспользованиеПКО.Справочник_ШтрихкодыНоменклатуры_Отправка = РезультатЗапроса.Пустой();
	
КонецПроцедуры

Процедура ДобавитьПОД_Справочник_ХранилищеШаблоновРМК_Отправка(ПравилаОбработкиДанных)
	
	ПравилоОбработки                         = ПравилаОбработкиДанных.Добавить();
	ПравилоОбработки.Имя                     = "Справочник_ХранилищеШаблоновРМК_Отправка";
	ПравилоОбработки.ОбъектВыборкиМетаданные = Метаданные.Справочники.ХранилищеШаблоновРМК;
	ПравилоОбработки.ПриОбработке            = "ПОД_Справочник_ХранилищеШаблоновРМК_Отправка_ПриОбработке";
	ПравилоОбработки.ОчисткаДанных           = Ложь;
	
КонецПроцедуры

Процедура ПОД_Справочник_ХранилищеШаблоновРМК_Отправка_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ КомпонентыОбмена.ЭтоОбменЧерезПланОбмена Тогда
		Возврат;
	КонецЕсли;
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВыгруженыШаблоныЧеков Тогда
		Возврат;
	КонецЕсли;
	
	// ХранилищеШаблоновРМК выгружается через КассуККМ
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ОбменСУРМККассыККМ.КассаККМ КАК КассаККМ
		|ИЗ
		|	(ВЫБРАТЬ
		|		КОЛИЧЕСТВО(КассыККМИзменения.Ссылка) КАК КоличествоРегистраций
		|	ИЗ
		|		Справочник.КассыККМ.Изменения КАК КассыККМИзменения
		|	ГДЕ
		|		КассыККМИзменения.Узел = &УзелОбмена) КАК РегистрацииКассККМ,
		|	ПланОбмена.ОбменСУРМК.КассыККМ КАК ОбменСУРМККассыККМ
		|ГДЕ
		|	ОбменСУРМККассыККМ.Ссылка = &УзелОбмена
		|	И РегистрацииКассККМ.КоличествоРегистраций = 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	КассаККМ";
	
	Запрос.УстановитьПараметр("УзелОбмена", КомпонентыОбмена.УзелКорреспондента);
	Выборка = Запрос.Выполнить().Выбрать();
	КассаККМ = Неопределено;
	Пока Выборка.Следующий() Цикл
		КассаККМ = Выборка.КассаККМ;
	КонецЦикла;
	
	ПравилоКассыККМОтправка = КомпонентыОбмена.ПравилаОбработкиДанных.Найти("Справочник_КассыККМ_Отправка", "Имя");
	Если КассаККМ <> Неопределено И ПравилоКассыККМОтправка <> Неопределено Тогда
		КассаККМОбъект = КассаККМ.ПолучитьОбъект();
		ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, КассаККМОбъект, ПравилоКассыККМОтправка);
	КонецЕсли;
	
КонецПроцедуры

