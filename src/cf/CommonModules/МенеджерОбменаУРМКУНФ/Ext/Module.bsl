Процедура АлгоритмПоиска_НайтиКассовуюСмену(ДанныеИБ, ПолученныеДанные, КомпонентыОбмена)
	
	ТекстЗапроса = 

	"ВЫБРАТЬ
	|	КассоваяСмена.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И КассоваяСмена.КассаККМ = &КассаККМ
	|	И КассоваяСмена.НомерСменыККТ = &НомерСменыККТ
	|	И КассоваяСмена.Статус = &Статус
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КассоваяСмена.Ссылка
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.НачалоКассовойСмены МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
	|	И КассоваяСмена.КассаККМ = &КассаККМ
	|	И КассоваяСмена.НомерСменыККТ = &НомерСменыККТ
	|	И КассоваяСмена.Статус = &Статус";

	Если ДанныеИБ = Неопределено Тогда

		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Дата", 			ПолученныеДанные.Дата);
		Запрос.УстановитьПараметр("КассаККМ", 		ПолученныеДанные.КассаККМ);
		Запрос.УстановитьПараметр("НомерСменыККТ", 	ПолученныеДанные.НомерСменыККТ);
		
		Запрос.УстановитьПараметр("Статус",			Перечисления.СтатусыКассовойСмены.Открыта);
		Если ЗначениеЗаполнено(ПолученныеДанные.ОкончаниеКассовойСмены) Тогда
			Запрос.УстановитьПараметр("Статус", 	Перечисления.СтатусыКассовойСмены.Закрыта);
		КонецЕсли;
		
		Запрос.Текст = ТекстЗапроса;

		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();

		Если ВыборкаЗапроса.Следующий() Тогда
			ДанныеИБ = ВыборкаЗапроса.Ссылка;
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

Процедура АлгоритмПоиска_НайтиОРП(ДанныеИБ, ПолученныеДанные, КомпонентыОбмена)

	Если ДанныеИБ = Неопределено Тогда
		
		Если ЗначениеЗаполнено(ПолученныеДанные.КассоваяСмена) Тогда
			
			Менеджер = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени("Документ.ОтчетОРозничныхПродажах");
			ОтчетОРозничныхПродажах = Менеджер.ПолучитьОтчетОРозничныхПродажахПоКассовойСмене(ПолученныеДанные.КассоваяСмена);
			
			Если ОбщегоНазначения.СсылкаСуществует(ОтчетОРозничныхПродажах) Тогда
				ДанныеИБ = ОтчетОРозничныхПродажах;
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ОтчетОРозничныхПродажах.Ссылка
			|ИЗ
			|	Документ.ОтчетОРозничныхПродажах КАК ОтчетОРозничныхПродажах
			|ГДЕ
			|	ОтчетОРозничныхПродажах.НачалоКассовойСмены МЕЖДУ НАЧАЛОПЕРИОДА(&Дата, ДЕНЬ) И КОНЕЦПЕРИОДА(&Дата, ДЕНЬ)
			|	И ОтчетОРозничныхПродажах.КассаККМ = &КассаККМ
			|	И ОтчетОРозничныхПродажах.НомерКассовойСменыККМ = &НомерКассовойСменыККМ
			|
			|УПОРЯДОЧИТЬ ПО
			|	ОтчетОРозничныхПродажах.НачалоКассовойСмены УБЫВ
			|";
		Запрос.УстановитьПараметр("Дата", ПолученныеДанные.Дата);
		Запрос.УстановитьПараметр("КассаККМ", ПолученныеДанные.КассаККМ);
		Запрос.УстановитьПараметр("НомерКассовойСменыККМ", ПолученныеДанные.НомерКассовойСменыККМ);
		
		ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
		
		Если ВыборкаЗапроса.Следующий() Тогда
			ДанныеИБ = ВыборкаЗапроса.Ссылка;
			
			Если ЗначениеЗаполнено(ПолученныеДанные.КассоваяСмена)
				И ЗначениеЗаполнено(ДанныеИБ.КассоваяСмена) Тогда
				Если ПолученныеДанные.КассоваяСмена <> ДанныеИБ.КассоваяСмена Тогда
					ДанныеИБ = Неопределено;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

