	ПравилоОбработки                         = ПравилаОбработкиДанных.Добавить();
	ПравилоОбработки.Имя                     = "Справочник_ПартииНоменклатуры_Отправка";
	ПравилоОбработки.ОбъектВыборкиМетаданные = Метаданные.Справочники.ПартииНоменклатуры;
	ПравилоОбработки.ПриОбработке            = "ПОД_Справочник_ПартииНоменклатуры_Отправка_ПриОбработке";
	ПравилоОбработки.ОчисткаДанных           = Ложь;
КонецПроцедуры

Процедура ПОД_Справочник_ПартииНоменклатуры_Отправка_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)

	ВыгружатьПартииКомиссионныхТоваров = Ложь;
	Если КомпонентыОбмена.ЭтоОбменЧерезПланОбмена Тогда
		ВыгружатьПартииКомиссионныхТоваров = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			КомпонентыОбмена.УзелКорреспондента,
			"ВыгружатьПартииКомиссионныхТоваров");
    КонецЕсли;

	Если ВыгружатьПартииКомиссионныхТоваров
		И ЗначениеЗаполнено(ДанныеИБ.ВладелецПартии)
		И ДанныеИБ.Статус = Перечисления.СтатусыПартий.ТоварыНаКомиссии Тогда
		
		ИспользованиеПКО.Вставить("Справочник_ПартииНоменклатуры_Отправка", Истина);
		
		ПОДДоговора = КомпонентыОбмена.ПравилаОбработкиДанных.Найти("Справочник_ДоговорыКонтрагентов_Отправка", "Имя");
		
		Если ПОДДоговора <> Неопределено Тогда
			
			ТекстЗапроса = "
				|ВЫБРАТЬ
				|	ОсновныеДоговорыКонтрагента.Договор КАК Договор
				|ИЗ
				|	РегистрСведений.ОсновныеДоговорыКонтрагента КАК ОсновныеДоговорыКонтрагента
				|ГДЕ
				|	ОсновныеДоговорыКонтрагента.Контрагент = &ВладелецПартии
				|	И ОсновныеДоговорыКонтрагента.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоров.СКомитентом)
				|";

			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапроса;

			Запрос.УстановитьПараметр("ВладелецПартии", ДанныеИБ.ВладелецПартии);

			ВыборкаЗапроса = Запрос.Выполнить().Выбрать();

			Если ВыборкаЗапроса.Следующий()
				И КомпонентыОбмена.ВыгруженныеОбъекты.Найти(ВыборкаЗапроса.Договор) = Неопределено Тогда
				ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, ВыборкаЗапроса.Договор, ПОДДоговора);
			КонецЕсли;

		КонецЕсли;

	КонецЕсли;
КонецПроцедуры

