Процедура ПКО_Справочник_Справочник_Пользователи_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыУзла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КомпонентыОбмена.УзелКорреспондента, "ВыгружатьФизическихЛиц, ВыгружатьФизическихЛицЧастично");
	ВыгружатьФизЛиц = РеквизитыУзла.ВыгружатьФизическихЛиц Или РеквизитыУзла.ВыгружатьФизическихЛицЧастично;
	Если НЕ ВыгружатьФизЛиц Тогда
		
		СтруктураФизЛица = Новый Структура;
		СтруктураФизЛица.Вставить("ФИО", ДанныеИБ.Наименование);
		Инструкция = Новый Структура;
		Инструкция.Вставить("ИмяПКО",   "Справочник_ФизическиеЛицаИзСтруктуры_Отправка");
		Инструкция.Вставить("Значение", СтруктураФизЛица);
		ДанныеXDTO.КлючевыеСвойства.Вставить("ФизическоеЛицо", Инструкция);
		
	КонецЕсли;
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ОбменСУРМКТаблицаНастройкиПользователей.Роль КАК Роль,
	|	ОбменСУРМКТаблицаНастройкиПользователей.ФизическоеЛицо КАК ФизическоеЛицо
	|ИЗ
	|	ПланОбмена.ОбменСУРМК.ТаблицаНастройкиПользователей КАК ОбменСУРМКТаблицаНастройкиПользователей
	|ГДЕ
	|	ОбменСУРМКТаблицаНастройкиПользователей.Ссылка = &ТекущийУзел
	|	И ОбменСУРМКТаблицаНастройкиПользователей.ПользовательСсылка = &ПользовательСсылка");
	Запрос.УстановитьПараметр("ПользовательСсылка", ДанныеИБ.Ссылка);
	Запрос.УстановитьПараметр("ТекущийУзел", КомпонентыОбмена.УзелКорреспондента);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда
			Если НЕ Выборка.ФизическоеЛицо.Пустая()
				И ВыгружатьФизЛиц Тогда
				ДанныеXDTO.КлючевыеСвойства.Вставить("ФизическоеЛицо", Выборка.ФизическоеЛицо);
			КонецЕсли;
			ДанныеXDTO.Вставить("AdditionalInfo", Новый Структура("Профиль", Выборка.Роль));
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

