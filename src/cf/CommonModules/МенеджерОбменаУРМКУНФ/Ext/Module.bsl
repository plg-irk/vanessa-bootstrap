Процедура ЗаполнитьПатент(Объект)

	Объект.СпециальныйНалоговыйРежим = НалогиУНФ.СпециальныйНалоговыйРежим(
		Объект.Организация, 
		Объект.СтруктурнаяЕдиница, 
		Объект.Дата);
		
	Если Объект.СпециальныйНалоговыйРежим = Перечисления.СпециальныеНалоговыеРежимы.ПСН Тогда

		Объект.Патент = НалогиУНФ.ПатентПоСкладу(
			Объект.Организация, 
			Объект.СтруктурнаяЕдиница, 
			Объект.Дата);
			
			Если Не ЗначениеЗаполнено(Объект.Патент) Тогда
				
			Объект.Патент = Справочники.Патенты.ПолучитьПатентПоУмолчанию(
				Объект.Организация, 
				Объект.Дата);
				
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьКонтрагентаВЧеке(ПолученныеДанные)

	Если ЗначениеЗаполнено(ПолученныеДанные.ДисконтнаяКарта) Тогда

		ВладелецДК = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПолученныеДанные.ДисконтнаяКарта, "ВладелецКарты");
		Если ЗначениеЗаполнено(ВладелецДК) Тогда
			ПолученныеДанные.Контрагент = ВладелецДК;
		КонецЕсли;

	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПолученныеДанные.Контрагент) 
		И ЗначениеЗаполнено(ПолученныеДанные.Организация) Тогда
		
		СписокВидовДоговора = Новый Массив;
		СписокВидовДоговора.Добавить(Перечисления.ВидыДоговоров.СПокупателем);
	
		ПолученныеДанные.Договор = Справочники.ДоговорыКонтрагентов.ПоКонтрагентуПоОрганизации(
			ПолученныеДанные.Контрагент, 
			ПолученныеДанные.Организация, 
			СписокВидовДоговора);

	КонецЕсли;		

КонецПроцедуры

Функция ПолучитьФО(КомпонентыОбмена, ИмяОпции)
	
	ПараметрыКонвертации = КомпонентыОбмена.ПараметрыКонвертации;
	
	Если ПараметрыКонвертации.Свойство("КешЗначенийФО") Тогда
		КешЗначенийФО = ПараметрыКонвертации.КешЗначенийФО
	Иначе
		КешЗначенийФО = Новый Структура;
	КонецЕсли;
	
	Если КешЗначенийФО.Свойство(ИмяОпции) Тогда
		ЗначениеОпции = КешЗначенийФО.ИмяОпции;
	Иначе
		ЗначениеОпции = ПолучитьФункциональнуюОпцию(ИмяОпции);
		КешЗначенийФО.Вставить(ИмяОпции, ЗначениеОпции);
		КомпонентыОбмена.Вставить("КешЗначенийФО", КешЗначенийФО);
	КонецЕсли;
	
	Возврат ЗначениеОпции;
	
КонецФункции

Процедура ЗаполнитьДисконтнуюКартуПоУникальномуИдентификатору(ПолученныеДанные, СтрокаГУИД)
	
	СсылкаДК = НайтиДисконтнуюКартуПоУникальномуИдентификатору(СтрокаГУИД);
	Если ОбщегоНазначения.СсылкаСуществует(СсылкаДК) Тогда
		ПолученныеДанные.ДисконтнаяКарта = СсылкаДК;
	КонецЕсли;
	
КонецПроцедуры

Функция НайтиДисконтнуюКартуПоНомеру(НомерКарты)
	
	КартаЛояльности = Неопределено;
	
	Если Не (НомерКарты) = "" Тогда
		
		ЗапросКарты = Новый Запрос;
		ЗапросКарты.Текст =
		"ВЫБРАТЬ
		|	ДисконтныеКарты.Ссылка КАК Карта
		|ИЗ
		|	Справочник.ДисконтныеКарты КАК ДисконтныеКарты
		|ГДЕ
		|	ДисконтныеКарты.КодКартыШтрихкод = &НомерКарты
		|	И НЕ ДисконтныеКарты.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ДисконтныеКарты.Ссылка
		|ИЗ
		|	Справочник.ДисконтныеКарты КАК ДисконтныеКарты
		|ГДЕ
		|	ДисконтныеКарты.КодКартыМагнитный = &НомерКарты
		|	И НЕ ДисконтныеКарты.ПометкаУдаления";
		ЗапросКарты.УстановитьПараметр("НомерКарты", НомерКарты);
		
		РезультатЗапроса = ЗапросКарты.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			
			ВыборкаКарт = РезультатЗапроса.Выбрать();
			ВыборкаКарт.Следующий();
			КартаЛояльности = ВыборкаКарт.Карта;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат КартаЛояльности;
	
КонецФункции

Функция ПолучитьВладельцаКартыПоФИОДатеРождения(ДанныеВладельца)
	ВладелецКарты = Справочники.Контрагенты.ПустаяСсылка();
	
	ЗапросКлиента = Новый Запрос;
	ЗапросКлиента.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Клиент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформацияТелефон
	|		ПО Контрагенты.Ссылка = КонтрагентыКонтактнаяИнформацияТелефон.Ссылка
	|			И (КонтрагентыКонтактнаяИнформацияТелефон.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформацияЭлПочта
	|		ПО Контрагенты.Ссылка = КонтрагентыКонтактнаяИнформацияЭлПочта.Ссылка
	|			И (КонтрагентыКонтактнаяИнформацияЭлПочта.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
	|ГДЕ
	|	НЕ Контрагенты.ПометкаУдаления
	|	И Контрагенты.Наименование = &КлиентФИО
	|	И Контрагенты.ДатаРождения = &ДатаРождения
	|	И Контрагенты.ВидКонтрагента = ЗНАЧЕНИЕ(Перечисление.ВидыКонтрагентов.ФизическоеЛицо)
	|	И (КонтрагентыКонтактнаяИнформацияТелефон.Ссылка ЕСТЬ NULL
	|			ИЛИ КонтрагентыКонтактнаяИнформацияТелефон.НомерТелефона = """")
	|	И (КонтрагентыКонтактнаяИнформацияЭлПочта.Ссылка ЕСТЬ NULL
	|			ИЛИ КонтрагентыКонтактнаяИнформацияЭлПочта.АдресЭП = """")";
	ЗапросКлиента.УстановитьПараметр("КлиентФИО", ДанныеВладельца.Клиент);
	ЗапросКлиента.УстановитьПараметр("ДатаРождения", ДанныеВладельца.ДатаРождения);
	РезультатЗапроса = ЗапросКлиента.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаКлиента = РезультатЗапроса.Выбрать();
		ВыборкаКлиента.Следующий();
		ВладелецКарты = ВыборкаКлиента.Клиент;
	КонецЕсли;
	
	Возврат ВладелецКарты;
КонецФункции

Функция ПолучитьВладельцаДисконтнойКарты(ДанныеВладельцаКарты, ДополнительнаяИнформация)
	ВладелецКарты = Справочники.Контрагенты.ПустаяСсылка();
	
	Если Не ДополнительнаяИнформация = Неопределено Тогда
		
		ДанныеВладельца = ПодготовитьДанныеПоискаСозданияВладельцаКарты(ДанныеВладельцаКарты, ДополнительнаяИнформация);
		Если ДанныеВладельца.НомерТелефона = "" И ДанныеВладельца.АдресЭП = "" Тогда
			ВладелецКарты = ПолучитьВладельцаКартыПоФИОДатеРождения(ДанныеВладельца);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ВладелецКарты) Тогда
			РезультатПолучения = СерверЛояльностиПоставщикДанныхУНФ.ПолучитьВладельцаКарты(ДанныеВладельца);
			ВладелецКарты = РезультатПолучения.ВладелецКарты;
			Если РезультатПолучения.СтатусПолучения = "создан" Тогда
				Попытка
					ЗащитаПерсональныхДанныхУНФ.ЗарегистрироватьСогласиеНаОбработкуПД(ВладелецКарты);
				Исключение
					Описание = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
					ЗаписьЖурналаРегистрации("МенеджерОбменаУРМКУНФ.ПолучитьВладельцаДисконтнойКарты", , , , Описание);						
					ВладелецКарты = Справочники.Контрагенты.ПустаяСсылка(); // Нельзя создавать карту, если мы не имеем права хранить перснальные данные
				КонецПопытки
			КонецЕсли;			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВладелецКарты;
КонецФункции

Функция ПодготовитьДанныеПоискаСозданияВладельцаКарты(ДанныеВладельцаКарты, ДополнительнаяИнформация)
	ДанныеВладельца = Новый Структура();
	ДатаРожденияВладельца = Дата(1, 1, 1);
	Если ДанныеВладельцаКарты.Свойство("Датарождения") Тогда
		ДатаРожденияВладельца = ДанныеВладельцаКарты.ДатаРождения;
	КонецЕсли;
	КлиентФИО = "";
	Если ДанныеВладельцаКарты.Свойство("ФИО") Тогда
		КлиентФИО = СокрЛП(ДанныеВладельцаКарты.ФИО)
	ИначеЕсли ДанныеВладельцаКарты.Свойство("Наименование") Тогда
		КлиентФИО = СокрЛП(ДанныеВладельцаКарты.Наименование);
	КонецЕсли;
	
	ДанныеВладельца.Вставить("НомерТелефона", СокрЛП(ДополнительнаяИнформация.НомерТелефона));
	ДанныеВладельца.Вставить("АдресЭП", СокрЛП(ДополнительнаяИнформация.АдресЭП));
	ДанныеВладельца.Вставить("Клиент", КлиентФИО);
	ДанныеВладельца.Вставить("ДатаРождения", ДатаРожденияВладельца);
	
	Возврат ДанныеВладельца;
КонецФункции

Функция ПолучитьДисконтнуюКартуПоНомеру(КомпонентыОбмена, КартаЛояльностиСвойства, ДополнительнаяИнформация = Неопределено)
	
	КартаЛояльности = Справочники.ДисконтныеКарты.ПустаяСсылка();
	КартаГУИД = Новый УникальныйИдентификатор(КартаЛояльностиСвойства.Ссылка.Значение);
	КартаСсылка = Справочники.ДисконтныеКарты.ПолучитьСсылку(КартаГУИД);
	Если Не ОбщегоНазначения.СсылкаСуществует(КартаСсылка) Тогда
		НомерКарты = СокрЛП(КартаЛояльностиСвойства.НомерКарты);
		Если Не НомерКарты = "" Тогда
			КартаЛояльности = НайтиДисконтнуюКартуПоНомеру(НомерКарты);
			Если Не ЗначениеЗаполнено(КартаЛояльности) Тогда
				
				ВладелецКарты = ПолучитьВладельцаДисконтнойКарты(КартаЛояльностиСвойства.ВладелецКарты, ДополнительнаяИнформация);
				КартаОбъект = Справочники.ДисконтныеКарты.СоздатьЭлемент();
				КартаОбъект.КодКартыШтрихкод  = НомерКарты;
				КартаОбъект.КодКартыМагнитный = НомерКарты;
				КартаОбъект.Владелец = СерверЛояльностиПоставщикДанныхУНФ.ПолучитьВидДисконтнойКарты();
				КартаОбъект.ВладелецКарты = ВладелецКарты;
				КартаОбъект.Наименование = ДисконтныеКартыУНФСервер.УстановитьНаименованиеДисконтнойКарты(КартаОбъект.Владелец,
					ВладелецКарты, НомерКарты, НомерКарты);
				КартаОбъект.УстановитьСсылкуНового(КартаСсылка);
				КартаОбъект.ДополнительныеСвойства.Вставить("ОтключитьМеханизмРегистрацииОбъектов");
				КартаОбъект.Записать();
				
				Если ДополнительнаяИнформация = Неопределено И Не ЗначениеЗаполнено(ВладелецКарты) Тогда
					СтрокаНовойКарты = КомпонентыОбмена.ЗагруженныеОбъекты.Добавить();
					СтрокаНовойКарты.ИмяОбработчика = "ДобавлениеКартыИзЧека";
					СтрокаНовойКарты.СсылкаНаОбъект = КартаСсылка;
					СтрокаНовойКарты.Объект = КартаОбъект;
				КонецЕсли;
				КартаЛояльности = КартаСсылка;
				
			КонецЕсли;
		КонецЕсли;
	Иначе
		КартаЛояльности = КартаСсылка;
	КонецЕсли;
	
	Возврат КартаЛояльности;
	
КонецФункции

Процедура ДописатьПокупателяВЧек(ЗагруженныеОбъекты, КартаСсылка, ВладелецКарты)
	Для Каждого СтрокаЧека Из ЗагруженныеОбъекты Цикл
		Если ТипЗнч(СтрокаЧека.СсылкаНаОбъект) = Тип("ДокументСсылка.ЧекККМ")
				Или ТипЗнч(СтрокаЧека.СсылкаНаОбъект) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
				
			Если СтрокаЧека.Объект.ДисконтнаяКарта = КартаСсылка И Не ЗначениеЗаполнено(СтрокаЧека.Объект.Контрагент) Тогда
				СтрокаЧека.Объект.Контрагент = ВладелецКарты;
				СтрокаЧека.Объект.Записать();
			КонецЕсли;
				
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьВЧекеДисконтнуюКартуПриНеобходимости(КомпонентыОбмена, ДанныеXDTO, ПолученныеДанные)
	Если ДанныеXDTO.Свойство("КартаЛояльности") И ЗначениеЗаполнено(ДанныеXDTO.КартаЛояльности)
			И Не (ЗначениеЗаполнено(ПолученныеДанные.ДисконтнаяКарта)
				И ОбщегоНазначения.СсылкаСуществует(ПолученныеДанные.ДисконтнаяКарта)) Тогда
				
		ПолученныеДанные.ДисконтнаяКарта
			= ПолучитьДисконтнуюКартуПоНомеру(КомпонентыОбмена, ДанныеXDTO.КартаЛояльности);
				
	КонецЕсли;
КонецПроцедуры

Процедура ДополнитьЧекДополнительнойИнформацией(ДанныеXDTO, ПолученныеДанные)
	
	Если ДанныеXDTO.Свойство("AdditionalInfo") 
		И ТипЗнч(ДанныеXDTO.AdditionalInfo) = Тип("Структура") Тогда
	
		Если ДанныеXDTO.AdditionalInfo.Свойство("Комментарий") Тогда
		
			ПолученныеДанные.Комментарий = ДанныеXDTO.AdditionalInfo.Комментарий;
		
		КонецЕсли;
		Если Не (ЗначениеЗаполнено(ПолученныеДанные.ДисконтнаяКарта)
				И ОбщегоНазначения.СсылкаСуществует(ПолученныеДанные.ДисконтнаяКарта)) Тогда
				
			Если ДанныеXDTO.AdditionalInfo.Свойство("ИдентификаторКарты") Тогда
				ЗаполнитьДисконтнуюКартуПоУникальномуИдентификатору(ПолученныеДанные,
					ДанныеXDTO.AdditionalInfo.ИдентификаторКарты);
			ИначеЕсли ДанныеXDTO.AdditionalInfo.Свойство("НомерКарты") Тогда
				ДисконтнаяКарта = НайтиДисконтнуюКартуПоНомеру(ДанныеXDTO.AdditionalInfo.НомерКарты);
				Если ЗначениеЗаполнено(ДисконтнаяКарта) Тогда
					ПолученныеДанные.ДисконтнаяКарта = ДисконтнаяКарта;
				КонецЕсли;
			КонецЕсли;
				
		КонецЕсли;
		
		Если ДанныеXDTO.AdditionalInfo.Свойство("ПримененныеКартыЛояльности") Тогда
			КоличествоДобавленныхОплат = 0;
			Для Каждого Строка Из ДанныеXDTO.AdditionalInfo.ПримененныеКартыЛояльности Цикл
				ДисконтнаяКартаСсылка = НайтиДисконтнуюКартуПоУникальномуИдентификатору(Строка.ИдентификаторКарты);
				Если НЕ ОбщегоНазначения.СсылкаСуществует(ДисконтнаяКартаСсылка) Тогда
					ДисконтнаяКартаСсылка = НайтиДисконтнуюКартуПоНомеру(Строка.КодКарты);
				КонецЕсли;
				Если ЗначениеЗаполнено(ДисконтнаяКартаСсылка) Тогда
					НоваяСтрокаОплатыЧекККМ = ПолученныеДанные.БезналичнаяОплата.Добавить();
					НоваяСтрокаОплатыЧекККМ.ВидОплаты = Перечисления.ВидыБезналичныхОплат.Бонусы;
					НоваяСтрокаОплатыЧекККМ.БонуснаяКарта = ДисконтнаяКартаСсылка;
					НоваяСтрокаОплатыЧекККМ.СуммаБонусов = Строка.СуммаРаспределения;
					НоваяСтрокаОплатыЧекККМ.Сумма = 0;
					КоличествоДобавленныхОплат = КоличествоДобавленныхОплат + 1;
				КонецЕсли;
			КонецЦикла;
			ПолученныеДанные.СписатьБаллыПоВладельцу = КоличествоДобавленныхОплат > 0;
		КонецЕсли;
		ДополнительныеДанные = ДанныеXDTO.AdditionalInfo;
		Если ДополнительныеДанные.Свойство("ТаблицаЧековККМПоЗаказуРМК") Тогда
			ПолученныеДанные.ДополнительныеСвойства.Вставить("ТаблицаЧековККМПоЗаказуРМК",
				ДополнительныеДанные.ТаблицаЧековККМПоЗаказуРМК);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьПризнакиОбменУРМК(ДанныеXDTO, КомпонентыОбмена)
	
	УзелСсылка = КомпонентыОбмена.УзелКорреспондента;
	
	Организации = КомпонентыОбмена.ПараметрыКонвертации.МассивОрганизаций;
	
	ИспользоватьДисконтныеКарты = Константы.ФункциональнаяОпцияИспользоватьДисконтныеКарты.Получить();
	
	ВыгружатьФизическихЛиц = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УзелСсылка, "ВыгружатьФизическихЛиц");
	ВыгружатьФизическихЛицЧастично
		= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УзелСсылка, "ВыгружатьФизическихЛицЧастично");
	
	НеВыгружатьФизическихЛиц = НЕ ВыгружатьФизическихЛицЧастично И НЕ ВыгружатьФизическихЛиц;
	
	ВыгружатьСерии = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УзелСсылка, "ВыгружатьСерии");
	
	ТокеныАвторизации = Новый Соответствие;

	Если Организации.Количество() = 0 Тогда
		Организации = Новый Массив;
		Организации.Добавить(Справочники.Организации.ОрганизацияПоУмолчанию());
	КонецЕсли;
	
	Для Каждого Организация Из Организации Цикл
		Если ЗначениеЗаполнено(Организация) Тогда
			Токен = ИнтерфейсАвторизацииИСМПСлужебный.ПроверитьОбновитьКлючСессии(
				ИнтерфейсИСМПОбщегоНазначенияКлиентСервер.ПараметрыЗапросаКлючаСессииИСМПРозница(Организация));
			Если ЗначениеЗаполнено(Токен) Тогда
				ТокеныАвторизации.Вставить(Организация.Ссылка, Токен);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	AdditionalInfo = Новый Структура(
		"ИспользоватьДисконтныеКарты,
		|НеВыгружатьФизическихЛиц,
		|ВыгружатьСерии",
		ИспользоватьДисконтныеКарты,
		НеВыгружатьФизическихЛиц,
		ВыгружатьСерии);
		
	Если ТокеныАвторизации.Количество() > 0 Тогда
		AdditionalInfo.Вставить("ТокеныАвторизации", ТокеныАвторизации);
	КонецЕсли;
	
	ДанныеXDTO.Вставить("AdditionalInfo", AdditionalInfo);
	
КонецПроцедуры

Функция ЗначениеПеречисленияФорматаОбмена(КомпонентыОбмена, ПеречислениеФормата)
	Результат = Ложь;
	
	ПространствоИмен = КомпонентыОбмена.XMLСхема;
	
	МассивСтрок = ОбщегоНазначенияКлиентСервер.РазложитьСтрокуПоТочкамИСлэшам(ПеречислениеФормата);
	
	Если МассивСтрок.Количество() > 1 Тогда
		ИмяОбъектаXDTO = МассивСтрок[0];
		ТипФабрики = ФабрикаXDTO.Тип(Новый ТипДанныхXML(ИмяОбъектаXDTO, ПространствоИмен));
		
		Если ТипФабрики <> Неопределено Тогда
			Для каждого ФасетФабрики Из ТипФабрики.Фасеты Цикл
				Если ФасетФабрики.Значение = МассивСтрок[1] Тогда
					Возврат Истина;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция СвойствоФорматаОбмена(КомпонентыОбмена, ИмяСвойства)
	Результат = Ложь;
	
	ПространствоИмен = КомпонентыОбмена.XMLСхема;
	
	Если ФабрикаXDTO.Тип(Новый ТипДанныхXML(ИмяСвойства, ПространствоИмен)) <> Неопределено Тогда
		Результат = Истина;
	Иначе
		МассивСтрок = ОбщегоНазначенияКлиентСервер.РазложитьСтрокуПоТочкамИСлэшам(ИмяСвойства);
		
		Если МассивСтрок.Количество() > 1 Тогда
			ИмяОбъекта = МассивСтрок[0] + "." + МассивСтрок[1];
			ТипФабрики = ФабрикаXDTO.Тип(Новый ТипДанныхXML(ИмяОбъекта, ПространствоИмен));
			Если ТипФабрики <> Неопределено Тогда
				Для Сч = 2 По МассивСтрок.Количество() - 1 Цикл
					ИмяТекОбъекта = МассивСтрок[Сч];
					Если ТипЗнч(ТипФабрики) = Тип("СвойствоXDTO") Тогда
						ТипФабрики = ТипФабрики.Тип.Свойства.Получить(ИмяТекОбъекта);
					Иначе
						ТипФабрики = ТипФабрики.Свойства.Получить(ИмяТекОбъекта);
					КонецЕсли;
					Если ТипФабрики = Неопределено Тогда
						Возврат Ложь;
					КонецЕсли
				КонецЦикла;
				Результат = ТипФабрики <> Неопределено;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция СотрудникПоФизЛицу(ФизЛицо)
	Сотрудник = Неопределено;
		
	Если Не ЗначениеЗаполнено(ФизЛицо)
		ИЛИ Не ОбщегоНазначения.СсылкаСуществует(ФизЛицо) Тогда
		Возврат Сотрудник;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Сотрудники.Ссылка КАК Сотрудник
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Физлицо = &ФизЛицо";
	
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Сотрудник;
	КонецЕсли;
	
	Возврат Сотрудник;
КонецФункции

Процедура ЗарегистрироватьПродукциюИСМП(КомпонентыОбмена)
	
	ТекстЗапроса = "
		|ВЫБРАТЬ
		|	Настройки.ВидПродукции КАК ВидПродукции
		|ПОМЕСТИТЬ втВидыПродукции
		|ИЗ
		|	РегистрСведений.НастройкиУчетаМаркируемойПродукцииИСМП КАК Настройки
		|ГДЕ
		|	Настройки.ВестиУчетПродукции
		|	И Настройки.ДатаКонтрольПроизводства = НАЧАЛОПЕРИОДА(&ДатаСеансаОбмена, ДЕНЬ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втВидыПродукции КАК ВидыПродукции
		|		ПО Номенклатура.ВидПродукцииИС = ВидыПродукции.ВидПродукции
		|";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ДатаСеансаОбмена", ТекущаяДатаСеанса());
	
	МассивОбъектыДляРегистрации = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Если МассивОбъектыДляРегистрации.Количество() > 0 Тогда
		ПланыОбмена.ЗарегистрироватьИзменения(КомпонентыОбмена.УзелКорреспондента, МассивОбъектыДляРегистрации);
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоНоменклатураПалитры(КомпонентыОбмена, НоменклатураСсылка)
	
	ПалитрыУзла = ПалитрыУзла(КомпонентыОбмена);
	
	Если ПалитрыУзла.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	ТекстЗапроса = "
		|ВЫБРАТЬ
		|	ПалитраТоваровРМКСостав.Номенклатура КАК Номенклатура
		|ИЗ
		|	Справочник.ПалитраТоваровРМК.Состав КАК ПалитраТоваровРМКСостав
		|ГДЕ
		|	ПалитраТоваровРМКСостав.Ссылка В(&ПалитрыУзла)
		|	И ПалитраТоваровРМКСостав.Номенклатура = &Номенклатура
		|";

	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;

	Запрос.УстановитьПараметр("Номенклатура", НоменклатураСсылка);
	Запрос.УстановитьПараметр("ПалитрыУзла", ПалитрыУзла);

	РезультатЗапроса = Запрос.Выполнить();

	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура СократитьЗаписиСоставомПалитры(КомпонентыОбмена, Записи)
	
	ВыгружатьТолькоТоварыПалитры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			КомпонентыОбмена.УзелКорреспондента,
			"ВыгружатьТолькоТоварыПалитры");
		
	Если Не ВыгружатьТолькоТоварыПалитры Тогда
		Возврат;
	КонецЕсли;

	ПалитрыУзла = ПалитрыУзла(КомпонентыОбмена);
	
	МассивНоменклатуры = Записи.ВыгрузитьКолонку("Номенклатура");
	
	Записи.Индексы.Добавить("Номенклатура");
	
	ТекстЗапроса = "
		|ВЫБРАТЬ
		|	ПалитраТоваровРМКСостав.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ втТоварыПалитры
		|ИЗ
		|	Справочник.ПалитраТоваровРМК.Состав КАК ПалитраТоваровРМКСостав
		|ГДЕ
		|	ПалитраТоваровРМКСостав.Ссылка В(&ПалитрыУзла)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СправочникНоменклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК СправочникНоменклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ втТоварыПалитры КАК втТоварыПалитры
		|		ПО СправочникНоменклатура.Ссылка = втТоварыПалитры.Номенклатура
		|ГДЕ
		|	СправочникНоменклатура.Ссылка В(&Номенклатура)
		|	И втТоварыПалитры.Номенклатура ЕСТЬ NULL
		|";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;

	Запрос.УстановитьПараметр("Номенклатура", МассивНоменклатуры);
	Запрос.УстановитьПараметр("ПалитрыУзла", ПалитрыУзла);
	
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаЗапроса.Следующий() Цикл
		
		СтрокиНаУдаление = Записи.НайтиСтроки(Новый Структура("Номенклатура", ВыборкаЗапроса.Ссылка));
		
		Для Каждого СтрокаНаУдаление Из СтрокиНаУдаление Цикл
			Записи.Удалить(СтрокаНаУдаление);
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры

Функция ПалитрыУзла(КомпонентыОбмена)
	
	ПалитрыУзла = Новый Массив;
	
	Если КомпонентыОбмена.ЭтоОбменЧерезПланОбмена Тогда

		ПалитрыТоваровДляВыгрузки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
				КомпонентыОбмена.УзелКорреспондента,
				"ПалитрыТоваровДляВыгрузки");
	
		Если ПалитрыТоваровДляВыгрузки.Пустой() Тогда
			Возврат ПалитрыУзла;
		КонецЕсли;
		
		КорневыеПалитры = ПалитрыТоваровДляВыгрузки.Выгрузить().ВыгрузитьКолонку("ПалитраТоваровРМК");
	КонецЕсли;
	
	ВложенныеПалитры = ИнтерфейсРМКСлужебный.ПолучитьВложенныеПалитры(КорневыеПалитры);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ПалитрыУзла, КорневыеПалитры);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ПалитрыУзла, ВложенныеПалитры, Истина);

	Возврат ПалитрыУзла;
	
КонецФункции

Функция УстановленПризнакНачальнойВыгрузкиДанных(Знач УзелИнформационнойБазы)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	1 КАК Поле1
	|ИЗ
	|	РегистрСведений.ОбщиеНастройкиУзловИнформационныхБаз КАК ОбщиеНастройкиУзловИнформационныхБаз
	|ГДЕ
	|	ОбщиеНастройкиУзловИнформационныхБаз.УзелИнформационнойБазы = &УзелИнформационнойБазы
	|	И ОбщиеНастройкиУзловИнформационныхБаз.НачальнаяВыгрузкаДанных";
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("УзелИнформационнойБазы", УзелИнформационнойБазы);
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

Функция СтавкаНДСПолучение(СтавкаНДС, КомпонентыОбмена)
	
	Если СвойствоФорматаОбмена(КомпонентыОбмена, "Справочник.СтавкиНДС") Тогда
		
		ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая;
		
		Если СтавкаНДС.НеОблагается Тогда
			ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.БезНДС;
		ИначеЕсли СтавкаНДС.ВидСтавки.Значение = "Нулевая" Тогда
			ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Нулевая;
		ИначеЕсли СтавкаНДС.Свойство("Ставка") Тогда
			Если СтавкаНДС.РасчетнаяСтавка
				ИЛИ СтавкаНДС.ВидСтавки.Значение = "ОбщаяРасчетная" Тогда
				Ставка = Строка(СтавкаНДС.Ставка);
				СтавкаНДСЗначение = "НДС"+Ставка+"_1"+Ставка;
				Возврат СтавкаНДСПоСтроке(СтавкаНДСЗначение);
			Иначе
				Ставка = Строка(СтавкаНДС.Ставка);
				СтавкаНДСЗначение = "НДС"+Ставка;
				Возврат СтавкаНДСПоСтроке(СтавкаНДСЗначение);
			КонецЕсли;
		ИначеЕсли СтавкаНДС.ВидСтавки.Значение = "Пониженная" Тогда
			ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Пониженная;
		ИначеЕсли СтавкаНДС.ВидСтавки.Значение = "ПониженнаяРасчетная" Тогда
			ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная;
		Иначе
			Возврат Справочники.СтавкиНДС.СтавкаНДС(ВидСтавкиНДС);
		КонецЕсли;
		
		Возврат Справочники.СтавкиНДС.СтавкаНДС(ВидСтавкиНДС);
		
	Иначе		
		Возврат СтавкаНДСПоСтроке(СтавкаНДС.Значение);
	КонецЕсли;
	
КонецФункции

Функция НайтиДисконтнуюКартуПоУникальномуИдентификатору(СтрокаГУИД)
	
	ИдентификаторДисконтнойКарты = Новый УникальныйИдентификатор(СтрокаГУИД);
	СсылкаДК = Справочники.ДисконтныеКарты.ПолучитьСсылку(ИдентификаторДисконтнойКарты);
	
	Возврат СсылкаДК;
КонецФункции

Функция ДанныеШаблонаЧека(ШаблонЧека, СокращенныйВариант = Ложь)
	
	ДанныеШаблонаЧека = Неопределено;
	
	Если НЕ(ЗначениеЗаполнено(ШаблонЧека) И ОбщегоНазначения.СсылкаСуществует(ШаблонЧека)) Тогда
		Возврат ДанныеШаблонаЧека;
	КонецЕсли;
	
	ИдентификаторШаблонаЧека = Строка(ШаблонЧека.УникальныйИдентификатор());
	ТекстНаименование = "Наименование";
	ТекстСсылка = "Ссылка";
	
	ДанныеШаблонаЧека = Новый Структура;
	ДанныеШаблонаЧека.Вставить(ТекстСсылка, ИдентификаторШаблонаЧека);
	ДанныеШаблонаЧека.Вставить(ТекстНаименование);
	
	Если СокращенныйВариант Тогда
		ДанныеШаблонаЧека.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ШаблонЧека, ТекстНаименование);
		Возврат ДанныеШаблонаЧека;
	КонецЕсли;
	
	ТекстШаблон = "Шаблон";
	ТекстШиринаЧека = "ШиринаЧека";
	ТипСтруктура = Тип("Структура");
	
	РеквизитыШаблонаЧека = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ШаблонЧека,
		"Наименование, Шаблон, Условия, ПометкаУдаления");
	
	ДанныеШаблонаЧека.Наименование = РеквизитыШаблонаЧека.Наименование;
	
	Шаблон = Неопределено;
	Если ЗначениеЗаполнено(РеквизитыШаблонаЧека.Шаблон) Тогда
		Шаблон = РеквизитыШаблонаЧека.Шаблон.Получить();
	КонецЕсли;
	Если ТипЗнч(Шаблон) = ТипСтруктура
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Шаблон, ТекстШаблон)
		И ТипЗнч(Шаблон.Шаблон) = Тип("ДеревоЗначений") Тогда
		
		ДанныеШаблонаЧека.Вставить(ТекстШаблон, Шаблон.Шаблон);
		
		ИмяКолонкиОписаниеТипа = "ОписаниеТипа";
		Если ДанныеШаблонаЧека.Шаблон.Колонки.Найти(ИмяКолонкиОписаниеТипа) <> Неопределено Тогда
			ДанныеШаблонаЧека.Шаблон.Колонки.Удалить(ИмяКолонкиОписаниеТипа);
		КонецЕсли;
		ДанныеШаблонаЧека.Шаблон.Колонки.Добавить(ИмяКолонкиОписаниеТипа, Новый ОписаниеТипов("ОписаниеТипов"));
		
		// Переопределим колонку ПустоеЗначение для замены ссылочных значений на строковое представление
		ИмяКолонкиПустоеЗначение = "ПустоеЗначение";
		ИмяКолонкиУдалениеПустоеЗначение = "УдалениеПустоеЗначение";
		ТекстСтрока = "Строка";
		ТекстБулево = "Булево";
		Если ДанныеШаблонаЧека.Шаблон.Колонки.Найти(ИмяКолонкиПустоеЗначение) = Неопределено Тогда
			ДанныеШаблонаЧека.Шаблон.Колонки.Добавить(ИмяКолонкиУдалениеПустоеЗначение);
		Иначе
			ДанныеШаблонаЧека.Шаблон.Колонки.ПустоеЗначение.Имя = ИмяКолонкиУдалениеПустоеЗначение;
		КонецЕсли;
		РазрешенныеТипы = Новый Массив;
		РазрешенныеТипы.Добавить(Тип(ТекстБулево));
		РазрешенныеТипы.Добавить(Тип(ТекстСтрока));
		РазрешенныеТипы.Добавить(Тип("Дата"));
		РазрешенныеТипы.Добавить(Тип("Число"));
		ОписаниеТипаКолонкиПустоеЗначение = Новый ОписаниеТипов(РазрешенныеТипы);
		ДанныеШаблонаЧека.Шаблон.Колонки.Добавить(ИмяКолонкиПустоеЗначение, ОписаниеТипаКолонкиПустоеЗначение);
		
		ИмяКолонкиЭтоГруппа = "ЭтоГруппа";
		ИмяКолонкиЭлемент = "Элемент";
		ИмяКолонкиЗаголовок = "Заголовок";
		ОписаниеТипаСтрока = Новый ОписаниеТипов(ТекстСтрока);
		Если ДанныеШаблонаЧека.Шаблон.Колонки.Найти(ИмяКолонкиЭтоГруппа) = Неопределено Тогда
			ДанныеШаблонаЧека.Шаблон.Колонки.Добавить(ИмяКолонкиЭтоГруппа, Новый ОписаниеТипов(ТекстБулево));
		КонецЕсли;
		Если ДанныеШаблонаЧека.Шаблон.Колонки.Найти(ИмяКолонкиЭлемент) = Неопределено Тогда
			ДанныеШаблонаЧека.Шаблон.Колонки.Добавить(ИмяКолонкиЭлемент, ОписаниеТипаСтрока);
		КонецЕсли;
		Если ДанныеШаблонаЧека.Шаблон.Колонки.Найти(ИмяКолонкиЗаголовок) = Неопределено Тогда
			ДанныеШаблонаЧека.Шаблон.Колонки.Добавить(ИмяКолонкиЗаголовок, ОписаниеТипаСтрока);
		КонецЕсли;
		
		// Обработаем поля шаблона
		КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
		ПараметрыОтбораСтрок = Новый Структура;
		ПараметрыОтбораСтрок.Вставить(ИмяКолонкиЭтоГруппа, Ложь);
		ПараметрыОтбораСтрок.Вставить("ИмяКолонки", "Текст");
		НайденныеСтрокиШаблона = ДанныеШаблонаЧека.Шаблон.Строки.НайтиСтроки(ПараметрыОтбораСтрок, Истина);
		Для каждого СтрокаШаблона Из НайденныеСтрокиШаблона Цикл
			// Заменим ссылочные значения на строковое представление в переопределяемой колонке ПустоеЗначение
			ТипЗначенияКолонкиУдалениеПустоеЗначение = ТипЗнч(СтрокаШаблона.УдалениеПустоеЗначение);
			Если СтрокаШаблона.УдалениеПустоеЗначение <> Неопределено
				И РазрешенныеТипы.Найти(ТипЗначенияКолонкиУдалениеПустоеЗначение) = Неопределено Тогда
				
				СтрокаШаблона.ПустоеЗначение = Строка(СтрокаШаблона.УдалениеПустоеЗначение);
			Иначе
				СтрокаШаблона.ПустоеЗначение = СтрокаШаблона.УдалениеПустоеЗначение;
			КонецЕсли;
			
			// Заменим пути и заголовки
			Если СтрокаШаблона.Элемент = "НоменклатураВидПродукцииИС" Тогда
				СтрокаШаблона.Элемент = "НоменклатураОсобенностьУчета";
				СтрокаШаблона.Заголовок = НСтр("ru = 'Номенклатура.Особенность учета'", КодОсновногоЯзыка);
			ИначеЕсли СтрокаШаблона.Элемент = "НоменклатураКатегорияНоменклатуры" Тогда
				СтрокаШаблона.Элемент = "НоменклатураВидНоменклатуры";
				СтрокаШаблона.Заголовок = НСтр("ru = 'Номенклатура.Вид номенклатуры'", КодОсновногоЯзыка);
			ИначеЕсли СтрокаШаблона.Элемент = "КонтрагентНаименование" Тогда
				СтрокаШаблона.Заголовок = НСтр("ru = 'Покупатель.Наименование'", КодОсновногоЯзыка);
			ИначеЕсли СтрокаШаблона.Элемент = "Автор" ИЛИ СтрокаШаблона.Элемент = "Ответственный" Тогда
				СтрокаШаблона.Элемент = "Кассир";
				СтрокаШаблона.Заголовок = НСтр("ru = 'Кассир'", КодОсновногоЯзыка);
			Иначе
				// Замена не требуется
			КонецЕсли;
			
		КонецЦикла;
		
		ДанныеШаблонаЧека.Шаблон.Колонки.Удалить(ИмяКолонкиУдалениеПустоеЗначение);
		
	КонецЕсли;
	Если ТипЗнч(Шаблон) = ТипСтруктура
		И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Шаблон, ТекстШиринаЧека) Тогда
		
		ДанныеШаблонаЧека.Вставить(ТекстШиринаЧека, Шаблон.ШиринаЧека);
	КонецЕсли;
	
	ДанныеШаблонаЧека.Вставить("Условия", РеквизитыШаблонаЧека.Условия.Выгрузить());
	ДанныеШаблонаЧека.Условия.Колонки.Удалить("НомерСтроки");
	ДанныеШаблонаЧека.Условия.Колонки.Удалить(ТекстСсылка);
	
	ДанныеШаблонаЧека.Вставить("ПометкаУдаления", РеквизитыШаблонаЧека.ПометкаУдаления);
	
	Возврат ДанныеШаблонаЧека;
	
КонецФункции

#КонецОбласти

