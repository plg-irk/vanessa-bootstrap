	СвойствоШапки = СвойстваШапки.НайтиСтроки(Новый Структура("СвойствоФормата", "ФизическоеЛицо"));
	Если СвойствоШапки.Количество() > 0 Тогда
		СвойствоШапки[0].ИспользуетсяАлгоритмКонвертации = Истина;
	КонецЕсли;
	
	СвойствоШапки = СвойстваШапки.НайтиСтроки(Новый Структура("СвойствоФормата", "ГоловнаяОрганизация"));
	Если СвойствоШапки.Количество() > 0 Тогда
		СвойствоШапки[0].ИспользуетсяАлгоритмКонвертации = Истина;
	КонецЕсли;
КонецПроцедуры

Процедура ПКО_Справочник_Сотрудники_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;
	РеквизитыУзла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КомпонентыОбмена.УзелКорреспондента, "ВыгружатьФизическихЛиц, ВыгружатьФизическихЛицЧастично");
	ВыгружатьФизЛиц = РеквизитыУзла.ВыгружатьФизическихЛиц Или РеквизитыУзла.ВыгружатьФизическихЛицЧастично;
	Если НЕ ВыгружатьФизЛиц Тогда
		
		РеквизитыФизЛица = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеИБ.Физлицо, "Наименование, ИНН");
		СтруктураФизЛица = Новый Структура;
		СтруктураФизЛица.Вставить("ФИО", РеквизитыФизЛица.Наименование);
		СтруктураФизЛица.Вставить("ИНН", РеквизитыФизЛица.ИНН);
		Инструкция = Новый Структура;
		Инструкция.Вставить("ИмяПКО",   "Справочник_ФизическиеЛицаИзСтруктуры_Отправка");
		Инструкция.Вставить("Значение", СтруктураФизЛица);
		ДанныеXDTO.КлючевыеСвойства.Вставить("ФизическоеЛицо", Инструкция);
		
	КонецЕсли;
	
	МассивОрганизаций = КомпонентыОбмена.ПараметрыКонвертации.МассивОрганизаций;
	Если МассивОрганизаций.Количество() > 0 Тогда
		Организация = МассивОрганизаций[0];
	Иначе
		Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	КонецЕсли;
	Инструкция = Новый Структура;
	Инструкция.Вставить("ИмяПКО",   "Справочник_Организации_Отправка");
	Инструкция.Вставить("Значение", Организация);
	ДанныеXDTO.КлючевыеСвойства.Вставить("ГоловнаяОрганизация", Инструкция);
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ОбменСУРМКТаблицаНастройкиПользователей.КодСотрудника КАК КодСотрудника,
	|	ОбменСУРМКТаблицаНастройкиПользователей.ПользовательСсылка КАК ПользовательСсылка,
	|	ОбменСУРМКТаблицаНастройкиПользователей.ПользовательСтрока КАК ПользовательСтрока,
	|	ОбменСУРМКТаблицаНастройкиПользователей.Роль КАК Роль
	|ИЗ
	|	ПланОбмена.ОбменСУРМК.ТаблицаНастройкиПользователей КАК ОбменСУРМКТаблицаНастройкиПользователей
	|ГДЕ
	|	ОбменСУРМКТаблицаНастройкиПользователей.СотрудникСсылка = &СотрудникСсылка
	|	И ОбменСУРМКТаблицаНастройкиПользователей.Ссылка = &ТекущийУзел");
	Запрос.УстановитьПараметр("СотрудникСсылка", ДанныеИБ.Ссылка);
	Запрос.УстановитьПараметр("ТекущийУзел", КомпонентыОбмена.УзелКорреспондента);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда
			Пользователь = Неопределено;
			Если НЕ ПустаяСтрока(Выборка.ПользовательСтрока) Тогда
				ИмяПКО = "Справочник_Пользователи_ИзСтруктуры_Отправка";
				СтруктураПользователь = Новый Структура("Наименование", Выборка.ПользовательСтрока);
				ЗначениеПользователь = СтруктураПользователь;
			Иначе
				ИмяПКО = "Справочник_Пользователи_Отправка";
				ЗначениеПользователь = Выборка.ПользовательСсылка;
			КонецЕсли;
			Инструкция = Новый Структура;
			Инструкция.Вставить("ИмяПКО", ИмяПКО);
			Инструкция.Вставить("Значение", ЗначениеПользователь);
			ДанныеXDTO.Вставить("Ответственный", Инструкция);
			ДанныеXDTO.Вставить("СостояниеОбъекта", "Актуальный");
			ДанныеXDTO.Вставить("AdditionalInfo", Новый Структура("КодСотрудника, Профиль", Выборка.КодСотрудника, Выборка.Роль));
		Иначе
			ДанныеXDTO.Вставить("СостояниеОбъекта", "Устаревший");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

