Процедура ПКО_Справочник_ЭквайринговыеТерминалы_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК"  Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеИБ.Тип = Перечисления.ТипыСпособовОплат.СБП Тогда
		ВидПлатежнойСистемы = Новый Структура("ВидПлатежнойСистемы",
			XMLСтрока(Перечисления.ТипыПлатежнойСистемыККТ.СистемаБыстрыхПлатежей));
	ИначеЕсли ДанныеИБ.Тип = Перечисления.ТипыСпособовОплат.ЮKassa Тогда
		ВидПлатежнойСистемы = Новый Структура("ВидПлатежнойСистемы",
			XMLСтрока(Перечисления.ТипыПлатежнойСистемыККТ.ЮКасса));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидПлатежнойСистемы) Тогда
		ДанныеXDTO.Вставить("AdditionalInfo", ВидПлатежнойСистемы);
	КонецЕсли;
	
	Если СвойствоФорматаОбмена(КомпонентыОбмена, "Справочник.ЭквайринговыеТерминалы.Эквайер") Тогда
		ДанныеXDTO.Вставить("Эквайер", ДанныеИБ.Эквайрер);
	Иначе
		ДанныеXDTO.Вставить("Эквайрер", ДанныеИБ.Эквайрер);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПКО_Справочник_СерииНоменклатуры(ПравилаКонвертации)

	ПравилоКонвертации = ПолучитьПравилоКонвертации(ПравилаКонвертации, "Справочник_СерииНоменклатуры");
	ПравилоКонвертации.ИмяПКО            = "Справочник_СерииНоменклатуры";
	ПравилоКонвертации.ОбъектДанных      = Метаданные.Справочники.СерииНоменклатуры;
	ПравилоКонвертации.ОбъектФормата     = "Справочник.СерииНоменклатуры";
	ПравилоКонвертации.ПриОтправкеДанных = "ПКО_Справочник_СерииНоменклатуры_ПриОтправкеДанных";
	
	ДобавитьПКС(ПравилоКонвертации.Свойства, "",        "Номенклатура", 1, "Справочник_Номенклатура_Отправка");
	ДобавитьПКС(ПравилоКонвертации.Свойства, "",        "ВидНоменклатуры", 1, "Справочник_КатегорииНоменклатурыВН_Отправка");
	ДобавитьПКС(ПравилоКонвертации.Свойства, "ГоденДо", "ГоденДо");
	
КонецПроцедуры

Процедура ПКО_Справочник_СерииНоменклатуры_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеИБ.Владелец) = Тип("СправочникСсылка.Номенклатура") Тогда
		ДанныеXDTO.КлючевыеСвойства.Вставить("Номенклатура", 	ДанныеИБ.Владелец);
	Иначе
		ДанныеXDTO.КлючевыеСвойства.Вставить("ВидНоменклатуры", 	ДанныеИБ.Владелец);
		ДанныеXDTO.КлючевыеСвойства.Вставить("Номенклатура", 	Справочники.Номенклатура.ПустаяСсылка());
	КонецЕсли;
		
	ДанныеXDTO.КлючевыеСвойства.Вставить("СерийныйНомер", 	ДанныеИБ.Наименование);
	
	ДополнительныеДанные = Новый Структура;
	ДополнительныеДанные.Вставить("Продан", ДанныеИБ.Продан);
	
	ДанныеXDTO.Вставить("AdditionalInfo", ДополнительныеДанные);
	
КонецПроцедуры

Процедура ПКО_Справочник_КассыККМ_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)

	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;
	
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.7") Тогда
		
		Кеш = Неопределено;
		Если ИнициализироватьРасширенныйРежим(КомпонентыОбмена) Тогда
			Кеш = КомпонентыОбмена.ПараметрыКонвертации.КешРасширенногоРежима;
		КонецЕсли;
		
		НастройкиУзлаКорреспондента = Неопределено;
		Если КомпонентыОбмена.ЭтоОбменЧерезПланОбмена Тогда
			НастройкиУзлаКорреспондента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КомпонентыОбмена.УзелКорреспондента,
				"ТорговыйОбъект, ВыгружатьШаблоныЧеков, ШаблонЧекаПродажи, ШаблонЧекаВозврата");
		КонецЕсли;
		
		ТорговыйОбъект = Неопределено;
		Если НастройкиУзлаКорреспондента <> Неопределено Тогда
			ТорговыйОбъект = НастройкиУзлаКорреспондента.ТорговыйОбъект;
		КонецЕсли;
		СистемаНалогообложения = СистемаНалогообложения(ДанныеИБ.Владелец, ТорговыйОбъект, Кеш);

		Если СистемаНалогообложения <> Неопределено Тогда
			ДанныеXDTO.Вставить("СистемаНалогообложения", СистемаНалогообложения);
		КонецЕсли;
		
		НастройкиАвтоинкассации = Новый Структура;
		НастройкиАвтоинкассации.Вставить("Организация", ДанныеИБ.Владелец);
		НастройкиАвтоинкассации.Вставить("ТорговыйОбъект", ТорговыйОбъект);
		НастройкиАвтоинкассации.Вставить("СоздаватьВыемку", ДанныеИБ.СоздаватьВыемку);
		НастройкиАвтоинкассации.Вставить("МинимальныйОстатокВКассеККМ", ДанныеИБ.МинимальныйОстатокВКассеККМ);
		
		ДополнительнаяИнформация = Новый Структура;
		ДополнительнаяИнформация.Вставить("НастройкиАвтоинкассации", НастройкиАвтоинкассации);
		
		Если НастройкиУзлаКорреспондента <> Неопределено
			И НастройкиУзлаКорреспондента.ВыгружатьШаблоныЧеков
			И НЕ КомпонентыОбмена.ПараметрыКонвертации.ВыгруженыШаблоныЧеков Тогда
			
			ШаблонЧекаПродажиСокращенныйВариант = ДанныеШаблонаЧека(НастройкиУзлаКорреспондента.ШаблонЧекаПродажи, Истина);
			ШаблонЧекаВозвратаСокращенныйВариант = ДанныеШаблонаЧека(НастройкиУзлаКорреспондента.ШаблонЧекаВозврата, Истина);
			
			ШаблоныЧеков = Новый Массив;
			Если ШаблонЧекаПродажиСокращенныйВариант <> Неопределено Тогда
				ШаблонЧека = ДанныеШаблонаЧека(НастройкиУзлаКорреспондента.ШаблонЧекаПродажи);
				ШаблоныЧеков.Добавить(ШаблонЧека);
			КонецЕсли;
			Если ШаблонЧекаВозвратаСокращенныйВариант <> Неопределено
				И НастройкиУзлаКорреспондента.ШаблонЧекаПродажи <> НастройкиУзлаКорреспондента.ШаблонЧекаВозврата Тогда
				
				ШаблонЧека = ДанныеШаблонаЧека(НастройкиУзлаКорреспондента.ШаблонЧекаВозврата);
				ШаблоныЧеков.Добавить(ШаблонЧека);
			КонецЕсли;

			НастройкиШаблоновЧеков = Новый Структура;
			НастройкиШаблоновЧеков.Вставить("ШаблонЧекаПродажи", ШаблонЧекаПродажиСокращенныйВариант);
			НастройкиШаблоновЧеков.Вставить("ШаблонЧекаВозврата", ШаблонЧекаВозвратаСокращенныйВариант);
			НастройкиШаблоновЧеков.Вставить("ШаблоныЧеков", ШаблоныЧеков);
			
			ДополнительнаяИнформация.Вставить("НастройкиШаблоновЧеков", НастройкиШаблоновЧеков);
			
			КомпонентыОбмена.ПараметрыКонвертации.ВыгруженыШаблоныЧеков = Истина;
		КонецЕсли;
		
		ДанныеXDTO.Вставить("AdditionalInfo", ДополнительнаяИнформация);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПКО_Справочник_ФизическиеЛица_Получение(ПравилаКонвертации)

	ПравилоКонвертации = ПолучитьПравилоКонвертации(ПравилаКонвертации, "Справочник_ФизическиеЛица_Получение");
	ПравилоКонвертации.АлгоритмПоиска = "АлгоритмПоиска_НайтиКассира";
	
КонецПроцедуры

Процедура АлгоритмПоиска_НайтиКассира(ДанныеИБ, ПолученныеДанные, КомпонентыОбмена)
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ФизическиеЛица.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.Наименование = &Наименование
		|	И НЕ ФизическиеЛица.ПометкаУдаления
		|";
	
	Запрос.УстановитьПараметр("Наименование", ПолученныеДанные.Наименование);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ДанныеИБ = Выборка.Ссылка;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПКО_Справочник_ШтрихкодыУпаковокТоваровИзСтр_Получение(ПравилаКонвертации)

	ПравилоКонвертации = ОбменДаннымиXDTOСервер.ИнициализироватьПравилоКонвертацииОбъекта(ПравилаКонвертации);
	ПравилоКонвертации.ИмяПКО                       = "Справочник_ШтрихкодыУпаковокТоваровИзСтр_Получение";
