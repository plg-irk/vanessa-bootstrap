
#Область ПрограммныйИнтерфейс

// См. МенеджерОбменаЧерезУниверсальныйФормат.ПередКонвертацией.
//
Процедура ПередКонвертацией(КомпонентыОбмена) Экспорт

	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;
	
	Если КомпонентыОбмена.НаправлениеОбмена = "Отправка" Тогда
		
		Если КомпонентыОбмена.ЭтоОбменЧерезПланОбмена Тогда
			
			ВыгружатьТолькоТоварыПалитры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
					КомпонентыОбмена.УзелКорреспондента,
					"ВыгружатьТолькоТоварыПалитры");
			
			Если ВыгружатьТолькоТоварыПалитры Тогда
				КомпонентыОбмена.ПропускатьОбъектыСОшибкамиПроверкиПоСхеме = Истина;
			КонецЕсли;

			ЗарегистрироватьПродукциюИСМП(КомпонентыОбмена);
			
			ПравилоТорговыйОбъект = КомпонентыОбмена.ПравилаОбработкиДанных.Найти("Справочник_СтруктурныеЕдиницы_Отправка", "Имя");  
			Если ПравилоТорговыйОбъект <> Неопределено Тогда
				ТорговыйОбъектСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КомпонентыОбмена.УзелКорреспондента, "ТорговыйОбъект");
				ТорговыйОбъект = ТорговыйОбъектСсылка.ПолучитьОбъект();
				ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, ТорговыйОбъект, ПравилоТорговыйОбъект);
				
				Если ТорговыйОбъектСсылка.ТипСтруктурнойЕдиницы = Перечисления.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов Тогда
					
					МассивСкладов = КомпонентыОбмена.ПараметрыКонвертации.МассивСкладов;
					
					МенеджерСтруктурныеЕдиницы = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ТорговыйОбъектСсылка);
					ВыборкаСкладов = МенеджерСтруктурныеЕдиницы.ВыбратьИерархически(ТорговыйОбъектСсылка);
					
					Пока ВыборкаСкладов.Следующий() Цикл
						СкладВыборки = ВыборкаСкладов.ПолучитьОбъект();
						МассивСкладов.Добавить(СкладВыборки.Ссылка);
						
						ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, СкладВыборки, ПравилоТорговыйОбъект);
				    КонецЦикла;
				КонецЕсли;
				
			КонецЕсли;
			
			КомпонентыОбмена.ПараметрыКонвертации.Вставить("ВыгруженыШаблоныЧеков", Ложь);
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// См. МенеджерОбменаЧерезУниверсальныйФормат.ПослеКонвертации.
//
Процедура ПослеКонвертации(КомпонентыОбмена) Экспорт

	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;

	Если КомпонентыОбмена.НаправлениеОбмена = "Отправка" Тогда
		
		МассивВидовЦен = КомпонентыОбмена.ПараметрыКонвертации.МассивВидовЦен;
		Если МассивВидовЦен.Количество() <> 1 Тогда
			Возврат;
		КонецЕсли;
		
		ПравилоУстановкаЦенОтправка = КомпонентыОбмена.ПравилаОбработкиДанных.Найти("Документ_УстановкаЦенНоменклатуры_Отправка", "Имя");  
		Если ПравилоУстановкаЦенОтправка = Неопределено Тогда
			Возврат;
		КонецЕсли;

		ПравилоОбработкиSKU = КомпонентыОбмена.ПравилаОбработкиДанных.Найти("Справочник_КодыТоваровSKU_Отправка", "Имя");
		Если ПравилоОбработкиSKU = Неопределено Тогда
			Возврат;
		КонецЕсли;
			
		НомерПринятого = 0;
		Если КомпонентыОбмена.ЭтоОбменЧерезПланОбмена Тогда
			УзелКорреспондента = КомпонентыОбмена.УзелКорреспондента;
			НомерПринятого = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УзелКорреспондента, "НомерПринятого");
		КонецЕсли;
		
		Если НомерПринятого > 0 Тогда
			АлгоритмВыборки = ПравилоОбработкиSKU.ВыборкаДанных;
			
			СтруктураПараметров = Новый Структура;
			СтруктураПараметров.Вставить("КомпонентыОбмена", КомпонентыОбмена);

			МассивКодыSKU = ВыполнитьФункциюМодуляМенеджера(АлгоритмВыборки, СтруктураПараметров);
			
			Если МассивКодыSKU.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
			
			ТаблицаКодовSKU = РегистрыСведений.КодыТоваровSKU.СоздатьНаборЗаписей().Выгрузить();
			
			Для Каждого Элемент Из МассивКодыSKU Цикл
				НоваяСтрока = ТаблицаКодовSKU.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Элемент);
			КонецЦикла;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
				|	КодыТоваровSKU.SKU КАК SKU,
				|	КодыТоваровSKU.Номенклатура КАК Номенклатура,
				|	КодыТоваровSKU.Характеристика КАК Характеристика
				|ПОМЕСТИТЬ втКодыТоваровSKU
				|ИЗ
				|	&ТаблицаКодовSKU КАК КодыТоваровSKU
                |;
				|//////////////////////////////////////
				|ВЫБРАТЬ
				|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
				|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
				|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
				|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
				|	&ПериодЦен КАК Период,
				|	ВЫРАЗИТЬ(ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК Справочник.ЕдиницыИзмерения) КАК Упаковка,
				|	ВЫРАЗИТЬ(КодыТоваровSKU.SKU КАК ЧИСЛО(9, 0)) КАК SKU
				|ИЗ
				|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
				|			&ПериодЦен,
				|			ВидЦен = &ВидЦен
				|				И Номенклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга))
				|				И НЕ Номенклатура.ПометкаУдаления
				|				И НЕ Номенклатура.Недействителен) КАК ЦеныНоменклатурыСрезПоследних
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втКодыТоваровSKU КАК КодыТоваровSKU
				|		ПО (КодыТоваровSKU.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура)
				|			И (КодыТоваровSKU.Характеристика = ЦеныНоменклатурыСрезПоследних.Характеристика)";
			
			Запрос.УстановитьПараметр("ТаблицаКодовSKU", ТаблицаКодовSKU);
			Запрос.УстановитьПараметр("ВидЦен", МассивВидовЦен[0]);
			Запрос.УстановитьПараметр("ПериодЦен", ТекущаяДатаСеанса());

			РезультатЗапроса = Запрос.Выполнить();
			
			Если Не РезультатЗапроса.Пустой() Тогда
				
				НомерДокумента = 1;
				
				ШаблонТаблицаТоваров = Новый ТаблицаЗначений;
				Для Каждого КолонкаРезультата Из РезультатЗапроса.Колонки Цикл
					ШаблонТаблицаТоваров.Колонки.Добавить(КолонкаРезультата.Имя, КолонкаРезультата.ТипЗначения);
				КонецЦикла;
				
				ДанныеИБСтруктура = Новый Структура;
				ДанныеИБСтруктура.Вставить("Дата", ТекущаяДатаСеанса());
				ДанныеИБСтруктура.Вставить("ТипЦен",  МассивВидовЦен[0]);
				
				Префикс = Константы["ПрефиксУзлаРаспределеннойИнформационнойБазы"].Получить(); 
	
				Если ПустаяСтрока(Префикс) Тогда
					ОбменДаннымиПереопределяемый.ПриОпределенииПрефиксаИнформационнойБазыПоУмолчанию(Префикс);
				КонецЕсли;

				ШаблонПрефикса = Префикс + "-" + "А";
				НомерДокумента = ШаблонПрефикса + СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка(НомерДокумента), 11 - СтрДлина(ШаблонПрефикса));
				
				ДанныеИБСтруктура.Вставить("Номер", НомерДокумента);
				
				ТаблицаТоваров = ШаблонТаблицаТоваров.Скопировать();
				
				ВыборкаЦен = РезультатЗапроса.Выбрать();
				
				Пока ВыборкаЦен.Следующий() Цикл
					СтрокаЗаписи = ТаблицаТоваров.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаЗаписи, ВыборкаЦен);
				КонецЦикла;	

				ДанныеИБСтруктура.Вставить("Товары", ТаблицаТоваров);

				ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, ДанныеИБСтруктура, ПравилоУстановкаЦенОтправка);
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// См. МенеджерОбменаЧерезУниверсальныйФормат.ЗаполнитьПравилаОбработкиДанных.
