Процедура ПКО_Справочник_ОписаниеМаркированнойПродукции_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	
	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК" Тогда
		Возврат;
	КонецЕсли;
	
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;

	Если ТипЗнч(ДанныеXDTO) = Тип("Структура")
		И ДанныеXDTO.Свойство("КлючевыеСвойства") Тогда

		КлючевыеСвойства = ДанныеXDTO.КлючевыеСвойства;
		НоменклатураУпаковки = Неопределено;
		
		Если КлючевыеСвойства.Свойство("Номенклатура")
			И ЗначениеЗаполнено(КлючевыеСвойства.Номенклатура) Тогда
			НоменклатураУпаковки = КлючевыеСвойства.Номенклатура;
		КонецЕсли;
		
		Если НоменклатураУпаковки = Неопределено Тогда
			ДанныеXDTO = Неопределено;
			Возврат;
		КонецЕсли;
		
		Если ДанныеXDTO.Свойство("ПотребительскаяУпаковка")
			И ЗначениеЗаполнено(ДанныеXDTO.ПотребительскаяУпаковка) Тогда
			
			ПотребительскаяУпаковка = ДанныеXDTO.ПотребительскаяУпаковка;
			
			Если Не ПотребительскаяУпаковка.Свойство("Номенклатура") Тогда
				ПотребительскаяУпаковка.Вставить("Номенклатура", НоменклатураУпаковки);
			КонецЕсли;
		КонецЕсли;

		Если ДанныеXDTO.Свойство("УпаковкаЧастичногоВыбытия")
			И ЗначениеЗаполнено(ДанныеXDTO.УпаковкаЧастичногоВыбытия) Тогда

			УпаковкаЧастичногоВыбытия = ДанныеXDTO.УпаковкаЧастичногоВыбытия;

			Если Не УпаковкаЧастичногоВыбытия.Свойство("Номенклатура") Тогда
				УпаковкаЧастичногоВыбытия.Вставить("Номенклатура", НоменклатураУпаковки);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

