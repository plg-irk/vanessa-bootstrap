	ПравилоОбработки.ОчисткаДанных           = Ложь;
КонецПроцедуры

Процедура ПОД_СистемыНалогообложенияОрганизаций_Отправка_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)

	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК"  Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеИБ) = Тип("Структура") Тогда
		ИспользованиеПКО.Вставить("Справочник_ИсторияНалогообложения_ИзСтруктуры_Отправка", Истина);
		Возврат;
	КонецЕсли;

	ЗаписиДанныеИБ = ДанныеИБ.Выгрузить();
	
	ПравилоОбработки = КомпонентыОбмена.ПравилаОбработкиДанных.Найти("СистемыНалогообложенияОрганизаций_Отправка", "Имя");  
	Если Не ПравилоОбработки = Неопределено
		И ЗаписиДанныеИБ.Количество() = 1 Тогда
		
		ДанныеИБСтруктура = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ЗаписиДанныеИБ[0]);
		Если Не ДанныеИБСтруктура.ПлательщикНДСПрименяющийУСН Тогда
			
            Записи = Новый ТаблицаЗначений;
			Записи.Колонки.Добавить("СистемаНалогообложения");
			Записи.Колонки.Добавить("СтавкаНДС");
			
			МодульСНО = ОбщегоНазначения.ОбщийМодуль("РегистрыСведений.СистемыНалогообложенияОрганизаций");
			СистемНалогообложенияККТ = МодульСНО.ПолучитьТипСистемыНалогообложенияККТОрганизации(
				ДанныеИБСтруктура.Организация,
				ДанныеИБСтруктура.Период);
			
			Инструкция = Новый Структура();
			Инструкция.Вставить("ИмяПКО", 	"СистемыНалогообложения");
			Инструкция.Вставить("Значение",  СистемНалогообложенияККТ);

			НоваяСтрока = Записи.Добавить();
			НоваяСтрока.СистемаНалогообложения = Инструкция;
			НоваяСтрока.СтавкаНДС = Неопределено; // Если Не ПлательщикНДСПрименяющийУСН очищаем ставку в корреспонденте.
			
			ДанныеИБСтруктура.Вставить("Записи", Записи);
			
			ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, ДанныеИБСтруктура, ПравилоОбработки);
		КонецЕсли;
	КонецЕсли;
	
	ИспользованиеПКО.Вставить("Справочник_ИсторияНалогообложения_ИзСтруктуры_Отправка", Ложь);
	
КонецПроцедуры

Процедура ДобавитьПОД_НастройкиУчетаНДС_Отправка(ПравилаОбработкиДанных)
	ПравилоОбработки                         = ПравилаОбработкиДанных.Добавить();
	ПравилоОбработки.Имя                     = "НастройкиУчетаНДС_Отправка";
	ПравилоОбработки.ОбъектВыборкиМетаданные = Метаданные.РегистрыСведений.НастройкиУчетаНДС;
	ПравилоОбработки.ПриОбработке            = "ПОД_НастройкиУчетаНДС_Отправка_ПриОбработке";
	ПравилоОбработки.ОчисткаДанных           = Ложь;
КонецПроцедуры

Процедура ПОД_НастройкиУчетаНДС_Отправка_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)

	Если КомпонентыОбмена.ПараметрыКонвертации.ВариантНастройки <> "ОбменУРМК"  Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеИБ) = Тип("Структура") Тогда
		ИспользованиеПКО.Вставить("Справочник_ИсторияНалогообложения_ИзСтруктуры_Отправка", Истина);
		Возврат;
	КонецЕсли;

	ЗаписиДанныеИБ = ДанныеИБ.Выгрузить();
	
	ПравилоОбработки = КомпонентыОбмена.ПравилаОбработкиДанных.Найти("НастройкиУчетаНДС_Отправка", "Имя");  
	Если Не ПравилоОбработки = Неопределено
		И ЗаписиДанныеИБ.Количество() = 1 Тогда
		
		ДанныеИБСтруктура = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ЗаписиДанныеИБ[0]);
		
		МодульСНО = ОбщегоНазначения.ОбщийМодуль("РегистрыСведений.СистемыНалогообложенияОрганизаций");
		СистемНалогообложенияККТ = МодульСНО.ПолучитьТипСистемыНалогообложенияККТОрганизации(
			ДанныеИБСтруктура.Организация,
			ДанныеИБСтруктура.Период);
		
		Записи = Новый ТаблицаЗначений;
		Записи.Колонки.Добавить("СистемаНалогообложения");
		Записи.Колонки.Добавить("СтавкаНДС");
		
		МодульСтавкиНДС = ОбщегоНазначения.ОбщийМодуль("Справочники.СтавкиНДС");
		
		Если СвойствоФорматаОбмена(КомпонентыОбмена, "Справочник.СтавкиНДС") Тогда
			СтавкаНДССсылка = МодульСтавкиНДС.СтавкаНДС(ДанныеИБСтруктура.СтавкаНалогообложенияПриУСН);
			СтавкаНДССтруктура = Новый Структура("ИмяПКО, Значение", "Справочник_СтавкиНДС_Отправка", СтавкаНДССсылка);
		Иначе
			СтавкаНДССтруктура = Неопределено;
		КонецЕсли;

		Инструкция = Новый Структура();
		Инструкция.Вставить("ИмяПКО", 	"СистемыНалогообложения");
		Инструкция.Вставить("Значение",  СистемНалогообложенияККТ);
		
		НоваяСтрока = Записи.Добавить();
		НоваяСтрока.СистемаНалогообложения = Инструкция;
		НоваяСтрока.СтавкаНДС = СтавкаНДССтруктура;
		
		ДанныеИБСтруктура.Вставить("Записи", Записи);
		
		ОбменДаннымиXDTOСервер.ВыгрузкаОбъектаВыборки(КомпонентыОбмена, ДанныеИБСтруктура, ПравилоОбработки);
	КонецЕсли;
	
	ИспользованиеПКО.Вставить("Справочник_ИсторияНалогообложения_ИзСтруктуры_Отправка", Ложь);

КонецПроцедуры

