КонецПроцедуры

Процедура ПКО_Справочник_ВидыПодарочныхСертификатов_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)

	ДанныеXDTO.КлючевыеСвойства.Вставить("Валюта", 					 Константы.ВалютаУчета.Получить());
	ДанныеXDTO.КлючевыеСвойства.Вставить("РазрешитьЧастичнуюОплату", ДанныеИБ.ЧастичноеПогашение);
	
	ТипПериодаДействия = Неопределено;
	КоличествоПериодовДействия = Неопределено;

	Если ДанныеИБ.ТипСрокаДействия = Перечисления.СрокДействияПодарочныхСертификатов.БезОграниченияСрока Тогда
		ТипПериодаДействия 		   = "Месяц";
		КоличествоПериодовДействия = 999;
	
	Иначе
	
		Если ДанныеИБ.Периодичность = Перечисления.Периодичность.Неделя Тогда
			ТипПериодаДействия = "День";
			КоличествоПериодовДействия = ДанныеИБ.КоличествоПериодовДействия * 7;
		ИначеЕсли ДанныеИБ.Периодичность = Перечисления.Периодичность.Декада Тогда
			ТипПериодаДействия = "День";
			КоличествоПериодовДействия = ДанныеИБ.КоличествоПериодовДействия * 10;
		ИначеЕсли ДанныеИБ.Периодичность = Перечисления.Периодичность.Месяц Тогда
			ТипПериодаДействия = "Месяц";
			КоличествоПериодовДействия = ДанныеИБ.КоличествоПериодовДействия;
		ИначеЕсли ДанныеИБ.Периодичность = Перечисления.Периодичность.Квартал Тогда
			ТипПериодаДействия = "Месяц";
			КоличествоПериодовДействия = ДанныеИБ.КоличествоПериодовДействия * 3;
		ИначеЕсли ДанныеИБ.Периодичность = Перечисления.Периодичность.Полугодие Тогда
			ТипПериодаДействия = "Месяц";
			КоличествоПериодовДействия = ДанныеИБ.КоличествоПериодовДействия * 6;
		ИначеЕсли ДанныеИБ.Периодичность = Перечисления.Периодичность.Год Тогда
			ТипПериодаДействия = "Месяц";
			КоличествоПериодовДействия = ДанныеИБ.КоличествоПериодовДействия * 12;
		Иначе // день
			ТипПериодаДействия = "День";
			КоличествоПериодовДействия = ДанныеИБ.КоличествоПериодовДействия;
		КонецЕсли;

	КонецЕсли;
	
	ДанныеXDTO.Вставить("ТипПериодаДействия", ТипПериодаДействия);
	ДанныеXDTO.Вставить("КоличествоПериодовДействия", КоличествоПериодовДействия);
	
	СтруктураДопРеквизитов = Новый Структура;
	СтруктураДопРеквизитов.Вставить("ИспользоватьСерии", ДанныеИБ.ИспользоватьСерииНоменклатуры);
	Если ДанныеИБ.ПодарочныйСертификатПринимаетКОплатеТолькоОрганизациеяЭмитент Тогда
		СтруктураДопРеквизитов.Вставить("КонтрольОрганизации", ДанныеИБ.ПодарочныйСертификатПринимаетКОплатеТолькоОрганизациеяЭмитент);
	КонецЕсли;
	
	ТорговыйОбъект = Неопределено;
	Если КомпонентыОбмена.ЭтоОбменЧерезПланОбмена Тогда
		ТорговыйОбъект = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КомпонентыОбмена.УзелКорреспондента, "ТорговыйОбъект");
	КонецЕсли;
	МассивОрганизаций = КомпонентыОбмена.УзелКорреспондентаОбъект.Организации.ВыгрузитьКолонку("Организация");
	
	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	|	ЕСТЬNULL(ПолитикиУчетаСерий.ПолитикаУчетаСерий, ВЫБОР
	|			КОГДА Номенклатура.ИспользоватьСерииИзКатегории
	|				ТОГДА КатегорииНоменклатуры.ПолитикаУчетаСерий
	|			ИНАЧЕ Номенклатура.ПолитикаУчетаСерий
	|		КОНЕЦ) КАК ПолитикаУчетаСерий,
	|	Номенклатура.ИспользоватьУникальныеСерии КАК ИспользоватьУникальныеСерии,
	|	Номенклатура.ИспользоватьСерииНоменклатуры КАК ИспользоватьСерииНоменклатуры,
	|	Номенклатура.ИспользоватьСерииИзКатегории КАК ИспользоватьСерииИзКатегории,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(КатегорииНоменклатуры.ИспользоватьСерииИзКатегории, ЛОЖЬ)
	|			ТОГДА КатегорииНоменклатуры.ИспользоватьСерииНоменклатуры
	|		ИНАЧЕ Номенклатура.ИспользоватьСерииНоменклатуры
	|	КОНЕЦ КАК НастройкаИспользованияСерий,
	|	Номенклатура.Ссылка КАК Номенклатура,
	|	ЕСТЬNULL(КатегорииНоменклатуры.ИспользоватьХарактеристики, ЛОЖЬ) КАК ИспользоватьХарактеристикиИзВида,
	|	Номенклатура.ИспользоватьХарактеристики КАК ИспользоватьХарактеристики
	|ПОМЕСТИТЬ втНастройкиНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КатегорииНоменклатуры КАК КатегорииНоменклатуры
	|		ПО Номенклатура.КатегорияНоменклатуры = КатегорииНоменклатуры.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПолитикиУчетаСерий КАК ПолитикиУчетаСерий
	|		ПО Номенклатура.Ссылка = ПолитикиУчетаСерий.Владелец
	|			И (ПолитикиУчетаСерий.СтруктурнаяЕдиница = &ТорговыйОбъект)
	|			И (ПолитикиУчетаСерий.Организация В (&МассивОрганизаций))
	|ГДЕ
	|	Номенклатура.Ссылка = &ТекущаяСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втНастройкиНоменклатуры.ИспользоватьУникальныеСерии КАК ИспользоватьУникальныеСерии,
	|	втНастройкиНоменклатуры.ИспользоватьСерииНоменклатуры КАК ИспользоватьСерииНоменклатуры,
	|	втНастройкиНоменклатуры.ИспользоватьСерииИзКатегории КАК ИспользоватьСерииИзКатегории,
	|	втНастройкиНоменклатуры.НастройкаИспользованияСерий КАК НастройкаИспользованияСерий,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(спрПолитикаУчетаСерий.ТипПолитики, ЗНАЧЕНИЕ(Перечисление.ТипыПолитикУказанияСерий.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.ТипыПолитикУказанияСерий.УправлениеОстаткамиСерий)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СерияОбязательнаКЗаполнению
	|ИЗ
	|	втНастройкиНоменклатуры КАК втНастройкиНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПолитикаУчетаСерий КАК спрПолитикаУчетаСерий
	|		ПО втНастройкиНоменклатуры.ПолитикаУчетаСерий = спрПолитикаУчетаСерий.Ссылка";
	
	Запрос.УстановитьПараметр("ТекущаяСсылка", ДанныеИБ.Ссылка);
	Запрос.УстановитьПараметр("ТорговыйОбъект", ТорговыйОбъект);
	Запрос.УстановитьПараметр("МассивОрганизаций", МассивОрганизаций);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Если Выборка.НастройкаИспользованияСерий Тогда
		СтруктураДопРеквизитов.Вставить("СерияОбязательнаКЗаполнению", Выборка.СерияОбязательнаКЗаполнению);
		СтруктураДопРеквизитов.Вставить("НеИспользоватьСерииВида", НЕ Выборка.ИспользоватьСерииИзКатегории);
		СтруктураДопРеквизитов.Вставить("ИспользоватьНеуникальныеСерии", НЕ Выборка.ИспользоватьУникальныеСерии);
	КонецЕсли;
	
	ЗаполнитьДополнительныеРеквизиты(СтруктураДопРеквизитов, ДанныеXDTO);
	
КонецПроцедуры

Процедура ДобавитьПКО_Справочник_БонусныеПрограммы_Отправка(ПравилаКонвертации)

	ПравилоКонвертации = ПолучитьПравилоКонвертации(ПравилаКонвертации, "Справочник_БонусныеПрограммы_Отправка");
