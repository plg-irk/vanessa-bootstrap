	Сведения.Колонки.Добавить("СтоимостьБезНДСПослеИзменения", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15,2)));
	Сведения.Колонки.Добавить("СтоимостьБезНДСУвеличение", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15,2)));
	Сведения.Колонки.Добавить("СтоимостьБезНДСУменьшение", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15,2)));
	Возврат Сведения;
КонецФункции

Функция СведенияПрослеживаемостиКорректировки(ИдентификаторСтроки, Ссылка, МассивОснований)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка КАК Ссылка,
	|	КорректировкаРеализацииСведенияПрослеживаемости.РНПТ КАК РНПТ,
	|	СУММА(КорректировкаРеализацииСведенияПрослеживаемости.Количество) КАК Количество,
	|	СУММА(КорректировкаРеализацииСведенияПрослеживаемости.КоличествоПрослеживаемости) КАК КоличествоПрослеживаемости,
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка.ДокументОснование КАК ДокументОснование,
	|	КорректировкаРеализацииСведенияПрослеживаемости.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	КорректировкаРеализацииСведенияПрослеживаемости.Сумма КАК Сумма
	|ПОМЕСТИТЬ ДоИзменения
	|ИЗ
	|	Документ.КорректировкаРеализации.СведенияПрослеживаемости КАК КорректировкаРеализацииСведенияПрослеживаемости
	|ГДЕ
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка = &Ссылка
	|	И КорректировкаРеализацииСведенияПрослеживаемости.ИдентификаторСтроки = &ИдентификаторСтроки
	|
	|СГРУППИРОВАТЬ ПО
	|	КорректировкаРеализацииСведенияПрослеживаемости.РНПТ,
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка,
	|	КорректировкаРеализацииСведенияПрослеживаемости.ИдентификаторСтроки,
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка.ДокументОснование,
	|	КорректировкаРеализацииСведенияПрослеживаемости.Сумма
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасходнаяНакладнаяСведенияПрослеживаемости.Ссылка КАК Ссылка,
	|	РасходнаяНакладнаяСведенияПрослеживаемости.РНПТ КАК РНПТ,
	|	СУММА(РасходнаяНакладнаяСведенияПрослеживаемости.Количество) КАК Количество,
	|	СУММА(РасходнаяНакладнаяСведенияПрослеживаемости.КоличествоПрослеживаемости) КАК КоличествоПрослеживаемости,
	|	РасходнаяНакладнаяСведенияПрослеживаемости.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	РасходнаяНакладнаяСведенияПрослеживаемости.Сумма КАК Сумма
	|ПОМЕСТИТЬ ДанныеОснований
	|ИЗ
	|	Документ.РасходнаяНакладная.СведенияПрослеживаемости КАК РасходнаяНакладнаяСведенияПрослеживаемости
	|ГДЕ
	|	РасходнаяНакладнаяСведенияПрослеживаемости.Ссылка В(&МассивОснований)
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходнаяНакладнаяСведенияПрослеживаемости.Ссылка,
	|	РасходнаяНакладнаяСведенияПрослеживаемости.РНПТ,
	|	РасходнаяНакладнаяСведенияПрослеживаемости.ИдентификаторСтроки,
	|	РасходнаяНакладнаяСведенияПрослеживаемости.Сумма
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка,
	|	КорректировкаРеализацииСведенияПрослеживаемости.РНПТ,
	|	СУММА(КорректировкаРеализацииСведенияПрослеживаемости.Количество),
	|	СУММА(КорректировкаРеализацииСведенияПрослеживаемости.КоличествоПрослеживаемости),
	|	КорректировкаРеализацииСведенияПрослеживаемости.ИдентификаторСтроки,
	|	КорректировкаРеализацииСведенияПрослеживаемости.Сумма
	|ИЗ
	|	Документ.КорректировкаРеализации.СведенияПрослеживаемости КАК КорректировкаРеализацииСведенияПрослеживаемости
	|ГДЕ
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка В(&МассивОснований)
	|
	|СГРУППИРОВАТЬ ПО
	|	КорректировкаРеализацииСведенияПрослеживаемости.Ссылка,
	|	КорректировкаРеализацииСведенияПрослеживаемости.РНПТ,
	|	КорректировкаРеализацииСведенияПрослеживаемости.ИдентификаторСтроки,
	|	КорректировкаРеализацииСведенияПрослеживаемости.Сумма
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоИзменения.Ссылка КАК Ссылка,
	|	ДоИзменения.РНПТ КАК РНПТ,
	|	ДоИзменения.Количество КАК Количество,
	|	ДоИзменения.КоличествоПрослеживаемости КАК КоличествоПрослеживаемости,
	|	ДоИзменения.ДокументОснование КАК ДокументОснование,
	|	ДанныеОснований.Количество КАК КоличествоОснование,
	|	ДанныеОснований.КоличествоПрослеживаемости КАК КоличествоПрослеживаемостиОснование,
	|	ДанныеОснований.Сумма КАК СтоимостьБезНДСОснование,
	|	ДоИзменения.Сумма КАК СтоимостьБезНДС,
	|	ДоИзменения.ИдентификаторСтроки КАК ИдентификаторСтроки
	|ИЗ
	|	ДоИзменения КАК ДоИзменения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеОснований КАК ДанныеОснований
	|		ПО ДоИзменения.РНПТ = ДанныеОснований.РНПТ
	|			И ДоИзменения.ДокументОснование = ДанныеОснований.Ссылка
	|			И ДоИзменения.ИдентификаторСтроки = ДанныеОснований.ИдентификаторСтроки";
	
	Запрос.УстановитьПараметр("ИдентификаторСтроки", ИдентификаторСтроки);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("МассивОснований", МассивОснований);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

Процедура ЗаполнитьСведенияОПрослеживаемостиВЭлектронномДокументе(Приемник, СведенияОТоваре, ЭтоФормат502 = Ложь)
	
	Попытка
	
	Если СведенияОТоваре.Владелец().Колонки.Найти("СведенияОПрослеживаемости") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не СведенияОТоваре.ПрослеживаемыйТовар
		ИЛИ Не ЗначениеЗаполнено(СведенияОТоваре.ИдентификаторСтроки) Тогда
		Возврат;
	КонецЕсли;
	
	СведенияОПрослеживаемости = СведенияОТоваре.СведенияОПрослеживаемости;
	
	Если Не ЗначениеЗаполнено(СведенияОПрослеживаемости) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого Строка Из СведенияОПрослеживаемости Цикл
		ТНВЭДЕдиницаИзмерения = Неопределено;
		Если ЗначениеЗаполнено(Приемник.Номенклатура) Тогда
			ТНВЭДЕдиницаИзмерения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Приемник.Номенклатура, "ТоварнаяНоменклатураВЭД.ЕдиницаИзмерения");
		КонецЕсли;
		Если ЗначениеЗаполнено(ТНВЭДЕдиницаИзмерения) Тогда
			Строка.ЕдиницаИзмеренияКод = ТНВЭДЕдиницаИзмерения.Код;
			Строка.ЕдиницаИзмеренияНаименование = ТНВЭДЕдиницаИзмерения.Наименование;
		Иначе
			Строка.ЕдиницаИзмеренияКод = Приемник.ЕдиницаИзмеренияКод;
			Строка.ЕдиницаИзмеренияНаименование = Приемник.ЕдиницаИзмеренияНаименование;
		КонецЕсли;
		
		Если Не ДействуютПравилаЗаполненияПоПроектуПостановления1137() Тогда
			Строка.СтоимостьБезНДС = Окр(Строка.СтоимостьБезНДС);
		КонецЕсли;

	КонецЦикла;
	
	Приемник.СведенияОПрослеживаемости = СведенияОПрослеживаемости;
	
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОПрослеживаемостиВЭлектронномДокументеУКД(Приемник, СведенияОТоваре)
	
	Попытка
	
	Если СведенияОТоваре.Владелец().Колонки.Найти("ПрослеживаемыйТовар") = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Если Не СведенияОТоваре.ПрослеживаемыйТовар
		ИЛИ Не ЗначениеЗаполнено(СведенияОТоваре.ИдентификаторСтроки) Тогда
		Возврат;
	КонецЕсли;
	
	Если СведенияОТоваре.Владелец().Колонки.Найти("СведенияОПрослеживаемости") <> Неопределено
		И СведенияОТоваре.СведенияОПрослеживаемости <> Неопределено Тогда
		
		СведенияОПрослеживаемости = СведенияОТоваре.СведенияОПрослеживаемости;
		СведенияОПрослеживаемости.Колонки.Добавить("КоличествоОснование");
		СведенияОПрослеживаемости.Колонки.Добавить("КоличествоПрослеживаемостиОснование");
		СведенияОПрослеживаемости.Колонки.Добавить("СтоимостьБезНалогаОснование");
		
		Для каждого СтрокаОснование Из СведенияОТоваре.СведенияОПрослеживаемостиДоИзменения Цикл
			
			МассивСтрок = СведенияОПрослеживаемости.НайтиСтроки(Новый Структура("ИдентификаторСтроки,РНПТ", СтрокаОснование.ИдентификаторСтроки, СтрокаОснование.РНПТ));
			Если МассивСтрок.Количество() = 0 Тогда
				СтрокаТаблицы = СведенияОПрослеживаемости.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаОснование); 
				СтрокаТаблицы.Количество = 0;
				СтрокаТаблицы.КоличествоПрослеживаемости = 0;
				СтрокаТаблицы.СтоимостьБезНалога = 0;
			Иначе
				СтрокаТаблицы = МассивСтрок[0];
			КонецЕсли;
			
			СтрокаТаблицы.КоличествоОснование = СтрокаОснование.Количество;
			СтрокаТаблицы.КоличествоПрослеживаемостиОснование = СтрокаОснование.КоличествоПрослеживаемости;
			СтрокаТаблицы.СтоимостьБезНалогаОснование = СтрокаОснование.СтоимостьБезНалога;
			
		КонецЦикла;
		
	Иначе 
		
		ДокОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СведенияОТоваре.Ссылка, "ДокументОснование");
		РезультатЗапроса = СведенияПрослеживаемостиКорректировки(СведенияОТоваре.ИдентификаторСтроки, СведенияОТоваре.Ссылка, ДокОснование);
		Если Не ЗначениеЗаполнено(СведенияОПрослеживаемости) Тогда
			Возврат;
		КонецЕсли;
		
		Отбор = Новый Структура("ИдентификаторСтроки", СведенияОТоваре.ИдентификаторСтроки);
		СведенияОПрослеживаемости = РезультатЗапроса.НайтиСтроки(Отбор);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОПрослеживаемости) Тогда
		Приемник.СведенияОПрослеживаемости = НоваяКорректировкаСведенийОПрослеживаемости();
		Для Каждого ТекущиеСведения Из СведенияОПрослеживаемости Цикл
			
			СтрокаПрослеживаемости = Приемник.СведенияОПрослеживаемости.Добавить();
			СтрокаПрослеживаемости.НомерТовара = ТекущиеСведения.РНПТ;
			СтрокаПрослеживаемости.ЕдиницаИзмеренияКод = Приемник.ЕдиницаИзмеренияКод;
			
			СтрокаПрослеживаемости.КоличествоТовараДоИзменения = ТекущиеСведения.КоличествоОснование;
			СтрокаПрослеживаемости.КоличествоТовараПослеИзменения = ТекущиеСведения.Количество;
			
			СтрокаПрослеживаемости.КоличествоТовараУчетноеДоИзменения = Приемник.КоличествоДоКорректировки;
			СтрокаПрослеживаемости.КоличествоТовараУчетноеПослеИзменения = Приемник.Количество;
			
			СтрокаПрослеживаемости.СтоимостьБезНДСДоИзменения = ТекущиеСведения.СтоимостьБезНалогаОснование;
			СтрокаПрослеживаемости.СтоимостьБезНДСПослеИзменения = ТекущиеСведения.СтоимостьБезНалога;
			
			Разница = СтрокаПрослеживаемости.КоличествоТовараУчетноеДоИзменения - СтрокаПрослеживаемости.КоличествоТовараУчетноеПослеИзменения;
			РазницаПрослеживаемость = СтрокаПрослеживаемости.КоличествоТовараДоИзменения - СтрокаПрослеживаемости.КоличествоТовараПослеИзменения;
			РазницаСтоимостьБезНДС = СтрокаПрослеживаемости.СтоимостьБезНДСДоИзменения - СтрокаПрослеживаемости.СтоимостьБезНДСПослеИзменения;
			
			Если Разница > 0 Тогда
				СтрокаПрослеживаемости.КоличествоТовараУчетноеУменьшение = Разница;
				СтрокаПрослеживаемости.КоличествоТовараУчетноеУвеличение = 0;
			Иначе
				СтрокаПрослеживаемости.КоличествоТовараУчетноеУменьшение = 0;
				СтрокаПрослеживаемости.КоличествоТовараУчетноеУвеличение = -Разница;
			КонецЕсли;
			
			Если РазницаПрослеживаемость > 0 Тогда
				СтрокаПрослеживаемости.КоличествоТовараУменьшение = РазницаПрослеживаемость;
				СтрокаПрослеживаемости.КоличествоТовараУвеличение = 0;
			Иначе
				СтрокаПрослеживаемости.КоличествоТовараУменьшение = 0;
				СтрокаПрослеживаемости.КоличествоТовараУвеличение = -РазницаПрослеживаемость;
			КонецЕсли;
			
			Если РазницаСтоимостьБезНДС > 0 Тогда
				СтрокаПрослеживаемости.СтоимостьБезНДСУменьшение = РазницаСтоимостьБезНДС;
				СтрокаПрослеживаемости.СтоимостьБезНДСУвеличение = 0;
			Иначе
				СтрокаПрослеживаемости.СтоимостьБезНДСУменьшение = 0;
				СтрокаПрослеживаемости.СтоимостьБезНДСУвеличение = -РазницаСтоимостьБезНДС;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Процедура ПодготовитьСведенияОПрослеживаемостиДляДокументаИБ_УПД(Приемник, СтрокаТовары, СведенияОТоваре)
	
	Данные = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(
		СведенияОТоваре, "СведенияОТоварах.НомерСтроки.СведенияОПрослеживаемости");
	
	Если Не (ТипЗнч(Данные) = Тип("ТаблицаЗначений") И ЗначениеЗаполнено(Данные)) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаТовары.ИдентификаторСтроки = Новый УникальныйИдентификатор;
	СтрокаТовары.ПрослеживаемыйТовар = Истина;
	СведенияПрослеживаемости = Приемник.СкопироватьКолонки();
	Для Каждого СтрокаДанных Из Данные Цикл
		СтрокаПрослеживаемости = СведенияПрослеживаемости.Добавить();
		СтрокаПрослеживаемости.ИдентификаторСтроки        = СтрокаТовары.ИдентификаторСтроки;
		СтрокаПрослеживаемости.РНПТ                       = НомерТДПолучитьСсылку(СтрокаДанных.НомерТовара);
		СтрокаПрослеживаемости.КоличествоПрослеживаемости = СтрокаДанных.Количество;
		СтрокаПрослеживаемости.Количество                 = СтрокаДанных.КоличествоУчетное;
		СтрокаПрослеживаемости.Сумма                      = СтрокаДанных.СтоимостьБезНДС;
	КонецЦикла;
	
	РассчитатьПропорциональноУчетноеКоличество(СведенияПрослеживаемости, СтрокаТовары.Количество);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СведенияПрослеживаемости, Приемник);
	
КонецПроцедуры

Процедура ПодготовитьСведенияОПрослеживаемостиДляДокументаИБ_УКД(Приемник, СтрокаТовары, СведенияОТоваре)
	
	Попытка
		Данные = ЭлектронноеВзаимодействие.ДанныеЭлементаДереваЭлектронногоДокумента(
			СведенияОТоваре, "СведенияОТоварах.НомерСтроки.СведенияОПрослеживаемости");
	Исключение
		Возврат;
	КонецПопытки;
	
	Если Не (ТипЗнч(Данные) = Тип("ТаблицаЗначений") И ЗначениеЗаполнено(Данные)) Тогда
		Возврат;
	КонецЕсли;
	
	СведенияПрослеживаемости = Приемник.СкопироватьКолонки();
	Для Каждого СтрокаДанных Из Данные Цикл
		СтрокаПрослеживаемости = СведенияПрослеживаемости.Добавить();
		СтрокаПрослеживаемости.Номенклатура               = СтрокаТовары.Номенклатура;
		СтрокаПрослеживаемости.СтавкаНДС                  = СтрокаТовары.СтавкаНДС;
		СтрокаПрослеживаемости.РНПТ                       = НомерТДПолучитьСсылку(СтрокаДанных.НомерТовара);
		СтрокаПрослеживаемости.КоличествоПрослеживаемости = СтрокаДанных.КоличествоТовараПослеИзменения;
		СтрокаПрослеживаемости.Количество                 = СтрокаДанных.КоличествоТовараУчетноеПослеИзменения;
		СтрокаПрослеживаемости.Сумма                      = СтрокаДанных.СтоимостьБезНДСПослеИзменения;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СведенияПрослеживаемости, Приемник);
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОПрослеживаемостиВДокументеИБ_УКД(Приемник, Источник, Товары)
	
	Результат = Приемник.ВыгрузитьКолонки();
	Для Каждого СтрокаТовары Из Товары Цикл
		Если Не СтрокаТовары.ПрослеживаемыйТовар Тогда
			Возврат;
		КонецЕсли;
		
		ПараметрыПоиска = Новый Структура;
		ПараметрыПоиска.Вставить("Номенклатура", СтрокаТовары.Номенклатура);
		ПараметрыПоиска.Вставить("СтавкаНДС"   , СтрокаТовары.СтавкаНДС);
		СведенияПрослеживаемостиЭД = Источник.НайтиСтроки(ПараметрыПоиска);
		Если Не ЗначениеЗаполнено(СведенияПрослеживаемостиЭД) Тогда
			ПараметрыПоиска = Новый Структура;
			ПараметрыПоиска.Вставить("ИдентификаторСтроки", СтрокаТовары.ИдентификаторСтроки);
			СведенияПрослеживаемостиИБ = Приемник.Выгрузить(ПараметрыПоиска);
		Иначе
			ПараметрыПоиска = Новый Структура;
			ПараметрыПоиска.Вставить("ИдентификаторСтроки", СтрокаТовары.ИдентификаторСтроки);
			СведенияПрослеживаемостиИБ = Приемник.Выгрузить(ПараметрыПоиска);
			УдаляемыеСтрокиПрослеживаемости = Новый Массив;
			Для Каждого СтрокаПрослеживаемостиЭД Из СведенияПрослеживаемостиЭД Цикл
				ПараметрыПоиска = Новый Структура;
				ПараметрыПоиска.Вставить("РНПТ", СтрокаПрослеживаемостиЭД.РНПТ);
				НайденныеСтроки = СведенияПрослеживаемостиИБ.НайтиСтроки(ПараметрыПоиска);
				Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
					СтрокаПрослеживаемостиИБ = НайденныеСтроки[0];
					Если СтрокаПрослеживаемостиЭД.КоличествоПрослеживаемости = 0 Тогда
						УдаляемыеСтрокиПрослеживаемости.Добавить(СтрокаПрослеживаемостиИБ);
					Иначе
						ЗаполнитьЗначенияСвойств(СтрокаПрослеживаемостиИБ, СтрокаПрослеживаемостиЭД, "КоличествоПрослеживаемости, Количество");
					КонецЕсли;
				Иначе
					СтрокаПрослеживаемостиИБ = СведенияПрослеживаемостиИБ.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаПрослеживаемостиИБ, СтрокаПрослеживаемостиЭД);
				КонецЕсли;
			КонецЦикла;
			
			Для Каждого СтрокаНаУдаление Из УдаляемыеСтрокиПрослеживаемости Цикл
				СведенияПрослеживаемостиИБ.Удалить(СтрокаНаУдаление);
			КонецЦикла;
			
			РассчитатьПропорциональноУчетноеКоличество(СведенияПрослеживаемостиИБ, СтрокаТовары.Количество);
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СведенияПрослеживаемостиИБ, Результат);
	КонецЦикла;
	
	Приемник.Загрузить(Результат);
	
КонецПроцедуры

Процедура РассчитатьПропорциональноУчетноеКоличество(СведенияПрослеживаемости, КоличествоТовара)
	
	// Количество учетное получено из данных электронного документа, рассчитывать не нужно. 
	Если СведенияПрослеживаемости.Итог("Количество") > 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВсегоКоличествоПрослеживаемости = СведенияПрослеживаемости.Итог("КоличествоПрослеживаемости");
	
	// Если количество прослеживаемости равно количеству товара в строке, то скорее всего единица измерения
	// прослеживаемости совпадает с учетной единицей измерения и количество учетное равно количеству прослеживаемости.
	Если ВсегоКоличествоПрослеживаемости = КоличествоТовара Тогда
		Для Каждого СтрокаПрослеживаемости Из СведенияПрослеживаемости Цикл
			СтрокаПрослеживаемости.Количество = СтрокаПрослеживаемости.КоличествоПрослеживаемости;
		КонецЦикла;
		
		Возврат;
		
	КонецЕсли;
	
	СведенияПрослеживаемости.Колонки.Добавить("Порядок");
	Порядок = 0;
	Для Каждого СтрокаПрослеживаемости Из СведенияПрослеживаемости Цикл
		Порядок = Порядок + 1;
		СтрокаПрослеживаемости.Порядок = Порядок;
	КонецЦикла;
	
	СведенияПрослеживаемости.Сортировать("КоличествоПрослеживаемости");
	Распределено = 0;
	Для Каждого СтрокаПрослеживаемости Из СведенияПрослеживаемости Цикл
		Если СведенияПрослеживаемости.Индекс(СтрокаПрослеживаемости) + 1 = СведенияПрослеживаемости.Количество() Тогда
			СтрокаПрослеживаемости.Количество = КоличествоТовара - Распределено;
		Иначе 
			СтрокаПрослеживаемости.Количество = ?(ВсегоКоличествоПрослеживаемости = 0, 0,
				СтрокаПрослеживаемости.КоличествоПрослеживаемости * КоличествоТовара / ВсегоКоличествоПрослеживаемости);
			Распределено = Распределено + СтрокаПрослеживаемости.Количество;
		КонецЕсли;
	КонецЦикла;
	
	СведенияПрослеживаемости.Сортировать("Порядок");
	
КонецПроцедуры

#КонецОбласти

