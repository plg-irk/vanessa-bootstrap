			НоваяСтрока.НалоговаяСтавка           = Строка.СтавкаНДС;
			НоваяСтрока.СуммаНалога               = Строка.СуммаНДС;
			НоваяСтрока.СтоимостьТоваровСНалогом  = Строка.СуммаСНДС;
