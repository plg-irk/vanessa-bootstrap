Функция ЭтоВходящаяСчетФактураНаАванс_5_02(ДанныеЭД)
	
	Результат = Ложь;
	ОбстоятельстваФормированияСФ = ДанныеЭД.СведенияОСчетеФактуре.ДополнительныеСведенияОбУчастниках.ОбстоятельстваФормированияСФ;
	Если ОбстоятельстваФормированияСФ = "2" Тогда
		Результат = Истина;
	ИначеЕсли Не ЗначениеЗаполнено(ОбстоятельстваФормированияСФ)
			И ДанныеЭД.ТаблицаСчетаФактуры.ВсегоКОплате.СтоимостьБезНалога = 0 Тогда
		// Тег ОбстоятельстваФормированияСФ в документах из роуминга может быть не заполнен,
		// поэтому определяем вид счета-фактуры по косвенным признакам.
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

