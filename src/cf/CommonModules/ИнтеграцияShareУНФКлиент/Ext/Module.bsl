// См. ИнтеграцияShareКлиентПереопределяемый.ПриОпределенииПараметровОтправкиЭлектронногоПисьма
Процедура ПриОпределенииПараметровОтправкиЭлектронногоПисьма(ПараметрыОтправки, Знач ПараметрыДокумента) Экспорт 
	
	ПараметрыОтправки.Вставить("ПолучателиВыбраныИнтерактивно", Ложь); 
	
	Если СтрНайти(ПараметрыОтправки.Текст, "<!DOCTYPE html>") = 0 Тогда
		
		ПараметрыОтправки.Текст = СтрШаблон("<!DOCTYPE html> %1 %2", Символы.ПС, ПараметрыОтправки.Текст);
		
	КонецЕсли;
	
КонецПроцедуры

