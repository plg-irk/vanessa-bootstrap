Функция ИмпортИзЯндексМаркетВыбратьНеЗаписанныеВ1СИдентификаторы( УчетнаяЗаписьМаркетплейса, Параметры )

	// выборка только новых идентификаторов с сайта, которые ещё не записаны в 1С
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаИдентификаторовТоваров.УчетнаяЗаписьМаркетплейса КАК УчетнаяЗаписьМаркетплейса,
	|	ТаблицаИдентификаторовТоваров.ИдентификаторПубликации КАК ИдентификаторПубликации,
	|	ТаблицаИдентификаторовТоваров.ИдентификаторОбъектаМаркетплейса КАК ИдентификаторОбъектаМаркетплейса
	|ПОМЕСТИТЬ ТаблицаИдентификаторовТоваров
	|ИЗ
	|	&ТаблицаИдентификаторовТоваров КАК ТаблицаИдентификаторовТоваров
	|
	|ИНДЕКСИРОВАТЬ ПО 
	|	ИдентификаторПубликации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ 
	|	ТаблицаИдентификаторовТоваров.УчетнаяЗаписьМаркетплейса КАК УчетнаяЗаписьМаркетплейса,
	|	ТаблицаИдентификаторовТоваров.ИдентификаторПубликации КАК ИдентификаторПубликации,
	|	ТаблицаИдентификаторовТоваров.ИдентификаторОбъектаМаркетплейса КАК ИдентификаторОбъектаМаркетплейса
	|ИЗ
	|	ТаблицаИдентификаторовТоваров КАК ТаблицаИдентификаторовТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПубликацииТоваровЯндексМаркет КАК СтатусыПубликацииТоваровЯндексМаркет
	|		ПО (СтатусыПубликацииТоваровЯндексМаркет.УчетнаяЗаписьМаркетплейса = &УчетнаяЗаписьМаркетплейса)
	|			И ТаблицаИдентификаторовТоваров.ИдентификаторПубликации = СтатусыПубликацииТоваровЯндексМаркет.ИдентификаторПубликации
	|ГДЕ
	|	СтатусыПубликацииТоваровЯндексМаркет.УчетнаяЗаписьМаркетплейса ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТаблицаИдентификаторовТоваров";
	
	Запрос.УстановитьПараметр("УчетнаяЗаписьМаркетплейса", УчетнаяЗаписьМаркетплейса);
	Запрос.УстановитьПараметр("ТаблицаИдентификаторовТоваров", Параметры.ИдентификаторыТоваров );
	
	
	УстановитьПривилегированныйРежим( Истина );
	
	ВыборкаДанных = Запрос.Выполнить().Выбрать();
	
	УстановитьПривилегированныйРежим( Ложь );
	
	Возврат ВыборкаДанных;
КонецФункции

// Возвращает простые типы.
// 
// Возвращаемое значение:
//  Массив из Строка, Число, Дата, Булево - массив простых типов.
//
Функция ПростыеТипы()

	Результат = Новый Массив;
	Результат.Добавить(Тип("Строка"));
	Результат.Добавить(Тип("Число"));
	Результат.Добавить(Тип("Дата"));
	Результат.Добавить(Тип("Булево"));

	Возврат Результат;

КонецФункции

// Определяет текущую сопоставленную категорию для указанной номенклатуры.
//
// Параметры:                                                                   
//   УчетнаяЗаписьМаркетплейса - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//   Номенклатура              - СправочникСсылка.Номенклатура - номенклатура, для которой требуется найти категорию.
//   ИдентификаторКатегории    - Строка - искомый идентификатор категории маркетплейса;
//   ИсточникКатегории         - ПеречислениеСсылка.ИсточникиКатегорийДляМаркетплейса - источник категории из настроек сопоставления.
//
// Возвращаемое значение:
//   Структура - результат поиска категории:
//     * ИсточникКатегории      - СправочникСсылка.КатегорииНоменклатуры, СправочникСсылка.Номенклатура -
//                                  источник категории 1С;
//                              - Неопределено - источник категории не найден;
//     * Категория              - СправочникСсылка.КатегорииНоменклатуры, СправочникСсылка.Номенклатура -
//                                  подобранная категория 1С;
//                              - Неопределено - категория не найдена;
//     * ИдентификаторКатегории - Строка - идентификатор сопоставленной категории маркетплейса;
//     * НаименованиеКатегории  - Строка - наименование сопоставленной категории маркетплейса.
//
Функция ОпределитьТекущуюСопоставленнуюКатегориюМаркетплейсаПоНоменклатуре(УчетнаяЗаписьМаркетплейса, Номенклатура, ИдентификаторКатегории, ИсточникКатегории) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить( "ИсточникКатегории", Неопределено );
	Результат.Вставить( "Категория", Неопределено );
	Результат.Вставить( "ИдентификаторКатегории", "" );
	Результат.Вставить( "НаименованиеКатегории", "" );
	
	Если НЕ ЗначениеЗаполнено( Номенклатура ) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Объект1С = Неопределено;
	
	Если ИсточникКатегории = Неопределено Тогда
		ИсточникКатегории = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УчетнаяЗаписьМаркетплейса, "ИсточникКатегории");
	КонецЕсли;
	
	Если ИсточникКатегории = ПредопределенноеЗначение("Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры") Тогда
		Объект1С = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "КатегорияНоменклатуры");
	ИначеЕсли ИсточникКатегории = ПредопределенноеЗначение("Перечисление.ИсточникиКатегорийДляМаркетплейса.ИерархияНоменклатуры") Тогда
		Объект1С = Номенклатура;
	КонецЕсли;
	
	Если ЗначениеЗаполнено( Объект1С ) Тогда
		
		Результат.Вставить( "ИсточникКатегории", Объект1С );
		Результат.Вставить( "Категория", Объект1С );

		Если ТипЗнч( Объект1С ) = Тип( "СправочникСсылка.Номенклатура" ) Тогда
			НоменклатураЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта( Объект1С, "ЭтоГруппа, Родитель" );
			Если НоменклатураЗначенияРеквизитов.ЭтоГруппа = Ложь Тогда
				Результат.Вставить( "ИсточникКатегории", НоменклатураЗначенияРеквизитов.Родитель );
				Результат.Вставить( "Категория", НоменклатураЗначенияРеквизитов.Родитель );
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Процедура ДеревоТоваровСтрокаПоНоменклатуреДозаполнить( ОписанияТоваровСтрока, Параметры )
	
	ТекущиеДанные = ОписанияТоваровСтрока;

	НоменклатураЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта( ТекущиеДанные.Номенклатура, "Родитель, КатегорияНоменклатуры, ЕдиницаИзмерения, ИспользоватьХарактеристики" );
	
	Если Параметры.ИсточникКатегории = ПредопределенноеЗначение( "Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры" ) Тогда
		НоменклатураДляПоискаСопоставленияКатегории = ТекущиеДанные.Номенклатура;
	Иначе
		НоменклатураДляПоискаСопоставленияКатегории = НоменклатураЗначенияРеквизитов.Родитель;
	КонецЕсли;
	
	ТекущаяКатегория  = ОпределитьТекущуюСопоставленнуюКатегориюМаркетплейсаПоНоменклатуре(
	Параметры.УчетнаяЗаписьМаркетплейса,
	НоменклатураДляПоискаСопоставленияКатегории,
	ТекущиеДанные.ИдентификаторКатегорииМаркетплейса,
	Параметры.ИсточникКатегории );

	ТекущиеДанные.Категория = НоменклатураЗначенияРеквизитов.КатегорияНоменклатуры;
	
	ТекущиеДанные.ИсточникКатегорииМаркетплейса = ТекущаяКатегория.ИсточникКатегории;
	ТекущиеДанные.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = ТекущаяКатегория.ИсточникКатегории;
	
	Если Не ЗначениеЗаполнено( ТекущиеДанные.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет ) Тогда
		Если Параметры.ИсточникКатегории = ПредопределенноеЗначение( "Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры" ) Тогда
			ТекущиеДанные.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = ТекущиеДанные.Категория;
		Иначе
			ТекущиеДанные.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = НоменклатураЗначенияРеквизитов.Родитель;
		КонецЕсли;
	КонецЕсли;
	
	ТекущиеДанные.ТекущееИдентификаторКатегорииМаркетплейса = ТекущаяКатегория.ИдентификаторКатегории;
	ТекущиеДанные.ТекущееНаименованиеКатегорииМаркетплейса = ТекущаяКатегория.НаименованиеКатегории;
		
	ТекущиеДанные.ЕдиницаИзмерения = НоменклатураЗначенияРеквизитов.ЕдиницаИзмерения;
	ТекущиеДанные.ХарактеристикиИспользуются = НоменклатураЗначенияРеквизитов.ИспользоватьХарактеристики;
	
КонецПроцедуры

Функция ТоварыНайти( Параметры ) Экспорт

	Результат = Новый Структура;
	Результат.Вставить( "ПоискВыполнен", Ложь );
	Результат.Вставить( "ИмпортируемыеТовары", Неопределено );

	// заполним описания товаров из элементов формы в параметры поиска
	ФормаИмпортируемыеТовары = Параметры.ИмпортируемыеТовары;
	
	ФормаОписанияТоваровДляПоиска = ФормаИмпортируемыеТовары.Строки.НайтиСтроки( Новый Структура( "Пометка", Истина ), Истина );
	Если ФормаОписанияТоваровДляПоиска.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыКонтекст = ОбменСВнешнимиСистемамиНоменклатура.ТоварыНайтиПараметрыКонтекстСоздать();

	ПараметрыКонтекст.ИспользоватьПоискПоБазеДанных1С = Истина;
	ПараметрыКонтекст.ИспользоватьПолнотекстовыйПоиск = Истина;

	ПараметрыКонтекст.ПоискПоНоменклатуре = Истина;
	ПараметрыКонтекст.ПоискПоХарактеристикамНоменклатуры = Истина;
	ПараметрыКонтекст.ПоискПоШтрихкодам = Истина;
	
	ПараметрыКонтекст.ПоискПоНаименованиям = Истина;

	ПараметрыКонтекст.КоличествоОписанийТоваровВОднойПорции = 10;
	ПараметрыКонтекст.ОтладкаВключена = Ложь;
	
	ПараметрыКонтекст.Вставить( "УчетнаяЗапись", Параметры.УчетнаяЗаписьМаркетплейса );
	
	Для Каждого ФормаОписанияТоваровСтрока Из ФормаОписанияТоваровДляПоиска Цикл
	
		Если Не ЗначениеЗаполнено( ФормаОписанияТоваровСтрока.ИдентификаторОбъектаМаркетплейса ) Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеТовараЭлемент = ОбменСВнешнимиСистемамиНоменклатура.ТоварыНайтиОписанияТоваровЭлементСоздать( ПараметрыКонтекст.ОписанияТоваров );
		
		ОписаниеТовараЭлемент.ИдентификаторЭлемента = ФормаОписанияТоваровСтрока.ИдентификаторОбъектаМаркетплейса;
		ОписаниеТовараЭлемент.Наименование = ФормаОписанияТоваровСтрока.ПредставлениеОбъектаМаркетплейса;
		
		ОписаниеТовараЭлемент.Категория = ФормаОписанияТоваровСтрока.Категория;
		
		ДеревоРеквизитовАртикулСтроки = ФормаОписанияТоваровСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "НаименованиеАтрибутаМаркетплейса", "Артикул" ), Истина );
		Если ДеревоРеквизитовАртикулСтроки.Количество() > 0 Тогда
			ОписаниеТовараЭлемент.Артикул = ДеревоРеквизитовАртикулСтроки[ 0 ].ЗначениеАтрибутаМаркетплейса;
		КонецЕсли;

		ФормаШтрихкодыСтроки = ФормаОписанияТоваровСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "НаименованиеАтрибутаМаркетплейса", "Штрихкоды" ), Истина );
		Если ФормаШтрихкодыСтроки.Количество() > 0 Тогда

			ФормаШтрихкоды = ФормаШтрихкодыСтроки[ 0 ].ЗначенияАтрибутаМаркетплейса;
			
			Для Каждого ФормаШтрихкод Из ФормаШтрихкоды Цикл
				Штрихкод = ОписаниеТовараЭлемент.Штрихкоды.Добавить();
				Штрихкод.Имя = "-";
				Штрихкод.Значение = ФормаШтрихкод.Значение;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПоискВыполнен = ОбменСВнешнимиСистемамиНоменклатура.ТоварыНайти( ПараметрыКонтекст );
	
	Если ПоискВыполнен = Истина Тогда
		// заполним результаты поиска в элементы формы
		
		ОтборПоИдентификатору = Новый Структура( "ИдентификаторОбъектаМаркетплейса" );
		Для Каждого ОписаниеТовараЭлемент Из ПараметрыКонтекст.ОписанияТоваров Цикл
			
			ОтборПоИдентификатору.ИдентификаторОбъектаМаркетплейса = ОписаниеТовараЭлемент.ИдентификаторЭлемента;
			ФормаОписанияТоваровСтроки = ФормаИмпортируемыеТовары.Строки.НайтиСтроки( ОтборПоИдентификатору, Истина );
			
			Если ФормаОписанияТоваровСтроки.Количество() = 0 Тогда
				ОбщегоНазначения.СообщитьПользователю( "Не найден элемент по идентификатору " + ОтборПоИдентификатору.ИдентификаторОбъектаМаркетплейса );
				Продолжить;
			КонецЕсли;
			
			ФормаОписанияТоваровСтрока = ФормаОписанияТоваровСтроки[ 0 ];
			
			ФормаОписанияТоваровСтрока.ПоискВыполнен = Истина;

			ФормаРезультатыПоиска = ФормаОписанияТоваровСтрока.РезультатыПоиска;
			ФормаРезультатыПоиска.Очистить();
			
			РезультатыПоиска = ОписаниеТовараЭлемент.РезультатыПоиска;
			
			РезультатПоискаКоличество = 0;
			Для Каждого РезультатПоиска Из РезультатыПоиска Цикл
				РезультатПоискаКоличество = РезультатПоискаКоличество + 1;
				
				ФормаРезультатПоиска = ФормаРезультатыПоиска.Добавить();
				
				ФормаРезультатПоиска.Номенклатура = РезультатПоиска.Номенклатура;
				ФормаРезультатПоиска.Характеристика = РезультатПоиска.Характеристика;
				
				ФормаРезультатПоиска.МетодПоиска = РезультатПоиска.МетодПоиска;
				ФормаРезультатПоиска.Описание = РезультатПоиска.Описание;
				ФормаРезультатПоиска.ВероятностьСовпадения = РезультатПоиска.ВероятностьСовпадения;
				ФормаРезультатПоиска.ВесПоиска = РезультатПоиска.ВесПоиска;
			КонецЦикла;
			
			ФормаОписанияТоваровСтрока.РезультатПоискаКоличество = РезультатПоискаКоличество;
			
			ФормаОписанияТоваровСтрока.РезультатПоискаНоменклатура = ОписаниеТовараЭлемент.РезультатПоискаНоменклатура;
			ФормаОписанияТоваровСтрока.РезультатПоискаХарактеристика = ОписаниеТовараЭлемент.РезультатПоискаХарактеристика;
			ФормаОписанияТоваровСтрока.РезультатПоискаВероятностьСовпадения = ОписаниеТовараЭлемент.РезультатПоискаВероятностьСовпадения;
			ФормаОписанияТоваровСтрока.РезультатПоискаВесПоиска = ОписаниеТовараЭлемент.РезультатПоискаВесПоиска;
			ФормаОписанияТоваровСтрока.РезультатПоискаОписание = ОписаниеТовараЭлемент.РезультатПоискаОписание;
			
			Если ЗначениеЗаполнено( ФормаОписанияТоваровСтрока.РезультатПоискаНоменклатура )
			Или ЗначениеЗаполнено( ФормаОписанияТоваровСтрока.РезультатПоискаХарактеристика ) Тогда
				ФормаОписанияТоваровСтрока.РезультатПоискаКнопкаВыбрать = 1;
			Иначе
				ФормаОписанияТоваровСтрока.РезультатПоискаКнопкаВыбрать = -1;
			КонецЕсли;

            // Заполним Номенклатуру и Характеристику результатами поиска
			Если Не ЗначениеЗаполнено( ФормаОписанияТоваровСтрока.Номенклатура ) Тогда
			
				Если ЗначениеЗаполнено( ОписаниеТовараЭлемент.РезультатПоискаНоменклатура )
					ИЛИ ЗначениеЗаполнено( ОписаниеТовараЭлемент.РезультатПоискаХарактеристика ) Тогда
					
					ФормаОписанияТоваровСтрока.Номенклатура = ОписаниеТовараЭлемент.РезультатПоискаНоменклатура;
					ФормаОписанияТоваровСтрока.Характеристика = ОписаниеТовараЭлемент.РезультатПоискаХарактеристика;
					
					ДеревоТоваровСтрокаПоНоменклатуреДозаполнить( ФормаОписанияТоваровСтрока, Параметры );
					
					ФормаОписанияТоваровСтрока.Пометка = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Результат.ПоискВыполнен = ПоискВыполнен;
	Результат.ИмпортируемыеТовары = ФормаИмпортируемыеТовары;
	
	Возврат Результат;
КонецФункции

