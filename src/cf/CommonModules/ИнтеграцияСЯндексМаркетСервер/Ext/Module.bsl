	ТипОбъектПубликации.Добавить(Тип("СправочникСсылка.ХарактеристикиНоменклатурыПрисоединенныеФайлы"));
	Результат.Колонки.Добавить("ОбъектПубликации", Новый ОписаниеТипов(ТипОбъектПубликации));

