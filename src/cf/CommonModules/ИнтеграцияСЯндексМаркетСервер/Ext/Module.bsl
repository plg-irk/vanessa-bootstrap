КонецФункции

// Записывает загруженные данные с торговой площадки в информационную базу.
//
// Параметры:
//   УчетнаяЗаписьМаркетплейса - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису;
//   ДеревоТоваров             - ДеревоЗначений - структура дерева описана в реквизите "ИмпортируемыеТовары", 
//   Параметры                 - Структура - параметры выполнения функции:
//     * ВариантЗагрузкиДанных          - Число - вариант загрузки данных из сервиса, см. реквизит "ВариантЗагрузкиДанных" в
//     * ЗагрузитьЦеныПродажи           - Булево - признак записи цен, см. реквизит "ЗагрузитьЦеныПродажи" в
//     * ЗаписатьТолькоЦены             - Булево - Истина, если необходимо записать только цены товаров.
//     * ТолькоСоздатьНоменклатуру      - Булево - Истина, если необходимо только создать элементы справочника "Номенклатура".
//     * ЗагрузитьИзображения           - Булево - Истина, если необходимо загрузить изображения товаров.
//     * ИмяИдентификатора              - Строка - имя ключевого поля идентификаторов. Может принимать значения:
//                                          "ИдентификаторОбъектаМаркетплейса" и "ИдентификаторПубликации". 
//     * РазмерПорцииЗагрузкиДанных     - Число - размер порции загрузки данных с торговой площадки за один запрос;
//                                      - Неопределено - размер порции для загрузки не ограничен.
//     * СоздатьЭлементыНоменклатуры    - Булево - Истина, если несопоставленные элементы справочника "Номенклатура" необходимо создать.
//     * СортироватьСтрокиДереваТоваров - Булево - Истина, если после загрузки требуется отсортировать строки второго уровня дерева товаров.
//     * ОтображатьСопоставленные       - Число - установленный фильтр по сопоставленным позициям дерева товаров.
//     * ОтображатьПоСтатусу            - Число - установленный фильтр по статусу позиций дерева товаров.
//
// Возвращаемое значение:
//   Структура - результат выполнения функции:
//     * Ошибка         - Структура - код и описание ошибки при выполнении функции, 
//                          см. ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка.
//     * ДеревоТоваров  - ДеревоЗначений - заполненное дерево товаров, см. реквизит "ИмпортируемыеТовары" в 
//     * Записано       - Число - количество записанных данных;
//     * ВТомЧислеНовых - Число - количество новых записанных данных;
//     * НеЗаписано     - Число - количество данных с ошибками записи;
//     * Пропущено      - Массив Из Структура - информация о пропущенных записях:
//       ** НомерСтроки   - Число - номер строки дерева товаров;
//       ** Сообщение     - Строка - описание ошибки.
//     * ЗагруженыЦены  - Булево - в результате выполнения функции были загружены цены товаров.
//
Функция ИмпортИзЯндексМаркетЗаписатьЗагруженныеДанныеСТорговойПлощадки(Знач УчетнаяЗаписьМаркетплейса, ДеревоТоваров, Знач Параметры ) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить( "Ошибка", ИнтеграцияСМаркетплейсамиСервер.НоваяОшибка());
    Результат.Вставить( "ДеревоТоваров", ДеревоТоваров);
    Результат.Вставить( "Записано", 0);
    Результат.Вставить( "ВТомЧислеНовых", 0);
    Результат.Вставить( "НеЗаписано", 0);
    Результат.Вставить( "Пропущено", Новый Массив);
	Результат.Вставить( "ЗагруженыЦены", Параметры.ЗагрузитьЦеныПродажи ИЛИ Параметры.ЗаписатьТолькоЦены);
	
	Результат.Вставить( "НоменклатураКоличествоСоздано", 0 );
	Результат.Вставить( "НоменклатураКоличествоОбновлено", 0 );
	Результат.Вставить( "ХарактеристикиКоличествоСоздано", 0 );
	Результат.Вставить( "ХарактеристикиКоличествоОбновлено", 0 );
	Результат.Вставить( "ФайлыКоличествоСоздано", 0 );
	Результат.Вставить( "ШтрихкодыКоличествоСоздано", 0 );
	Результат.Вставить( "КатегорииНоменклатурыСоздано", 0 );
	
	СопоставлениеКатегорий = КатегорииИзДеревоТоварыПолучить( ДеревоТоваров );

	// Поиск категорий по коду и наименованию
	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить( "СопоставлениеКатегорий", СопоставлениеКатегорий );
	ПараметрыФункции.Вставить( "ИсточникКатегории", Параметры.ИсточникКатегории );
	Категории1СПоНаименованиюКатегорииМаркетплейсаНайтиИЗаполнить( ПараметрыФункции );
	ПараметрыФункции = Неопределено;
	
	Если Параметры.СоздатьЭлементыНоменклатуры = Истина Тогда
		
		Если Параметры.СоздатьКатегорииНоменклатуры = Истина Тогда

			КатегорииСоздатьИерархию = Параметры.СоздатьИерархиюКатегорийНоменклатуры;
			
			// Создание категорий
			ПараметрыФункции = Категории1СПоКатегориямМаркетплейсаПараметрыНовый();
			ПараметрыФункции.СопоставлениеКатегорий = СопоставлениеКатегорий;
			ПараметрыФункции.ИсточникКатегории = Параметры.ИсточникКатегории;
			ПараметрыФункции.СоздатьИерархию = КатегорииСоздатьИерархию;
			ПараметрыФункции.УчетнаяЗапись = УчетнаяЗаписьМаркетплейса;
			ПараметрыФункции.КэшКатегорийДерево = Параметры.КэшКатегорийДерево;

			Категории1СПоКатегориямМаркетплейсаСоздать( ПараметрыФункции );

			Параметры.КатегорииНоменклатурыСоздано = ПараметрыФункции.КатегорииНоменклатурыСоздано;
			
			ПараметрыФункции = Неопределено;

			ДеревоТоваровКатегорииПоСопоставлениюЗаполнить( ДеревоТоваров, СопоставлениеКатегорий, Параметры );
			
		КонецЕсли;
		
		ИмпортируемыеТоварыНоменклатураКлючЗаполнить( ДеревоТоваров );
		
		Если Параметры.СоздатьИерархиюНоменклатуры = Истина Тогда
		
			ПараметрыФункции = Новый Структура;
			ПараметрыФункции.Вставить( "СопоставлениеКатегорий", СопоставлениеКатегорий );
			ПараметрыФункции.Вставить( "УчетнаяЗапись", УчетнаяЗаписьМаркетплейса );
			ПараметрыФункции.Вставить( "КэшКатегорийДерево", Параметры.КэшКатегорийДерево );
			ПараметрыФункции.Вставить( "ДеревоТоваров", ДеревоТоваров );
			
			ИерархияНоменклатурыПоИерархииКатегорийМаркетплейсаВДеревеТоваровЗаполнить( ПараметрыФункции );
			
			ПараметрыФункции = Неопределено;
		КонецЕсли;
		
		ТоварыСоздать( ДеревоТоваров, Параметры );
		
		Результат.НоменклатураКоличествоСоздано = Параметры.НоменклатураКоличествоСоздано;
		Результат.НоменклатураКоличествоОбновлено = Параметры.НоменклатураКоличествоОбновлено;
		Результат.ХарактеристикиКоличествоСоздано = Параметры.ХарактеристикиКоличествоСоздано;
		Результат.ХарактеристикиКоличествоОбновлено = Параметры.ХарактеристикиКоличествоОбновлено;
		Результат.ФайлыКоличествоСоздано = Параметры.ФайлыКоличествоСоздано;
		Результат.ШтрихкодыКоличествоСоздано = Параметры.ШтрихкодыКоличествоСоздано;
		Результат.КатегорииНоменклатурыСоздано = Параметры.КатегорииНоменклатурыСоздано;
		
	КонецЕсли;
	
	
	ДеревоТоваровКатегорияИлиНоменклатураДляСопоставленияКатегорииМаркетплейсаЗаполнить( ДеревоТоваров, Параметры );

	Если НЕ ЗначениеЗаполнено(УчетнаяЗаписьМаркетплейса) Тогда
		Результат.Ошибка.КодОшибки      = КодыОшибокРегистраСтатусовПубликацииТоваров().ОшибкаПрочие;
		Результат.Ошибка.ОписаниеОшибки = НСтр("ru = 'Не указана учетная запись торговой площадки для импорта данных по товарам.'");
		//@skip-check constructor-function-return-section
		Возврат Результат;
	КонецЕсли; 
	
	ДоступнаУстановкаЦен = ПравоДоступа("Проведение", Метаданные.Документы.УстановкаЦенНоменклатуры);
	
	Если НЕ ДоступнаУстановкаЦен Тогда
		Результат.Вставить("ЗагруженыЦены", Ложь);
		
		Если Параметры.ЗаписатьТолькоЦены Тогда
			Результат.Ошибка.КодОшибки      = КодыОшибокРегистраСтатусовПубликацииТоваров().ОшибкаПрочие;
			Результат.Ошибка.ОписаниеОшибки = НСтр("ru = 'Для пользователя не доступна установка цен номенклатуры.'");
			//@skip-check constructor-function-return-section
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Отказ = Ложь;
	
	Попытка
		ТаблицаТоваров    = СведенияОВыгруженныхДанных();
		Идентификаторы    = Новый Массив;
		ИмяИдентификатора = Параметры.ИмяИдентификатора;
		
		МассивПолейТаблицыТоваров = Новый Массив;
		Для Каждого Колонка Из ТаблицаТоваров.Колонки Цикл
			МассивПолейТаблицыТоваров.Добавить(Колонка.Имя);
		КонецЦикла;
		ПоляТаблицыТоваров = СтрСоединить(МассивПолейТаблицыТоваров, ", ");
		
		ВсегоОтмечено       = 0;
		ВсегоНеПолучено     = 0;
		ВсегоНеСопоставлено = 0;
		
		Для каждого СтрокаДереваПервогоУровня Из ДеревоТоваров.Строки Цикл
			Если СтрокаДереваПервогоУровня.ВариантЗагрузки = ВариантЗагрузкиОбновитьСопоставленныеКарточкиТоваров() Тогда
				// СтрокаДереваГруппаОбновить 
			ИначеЕсли СтрокаДереваПервогоУровня.ВариантЗагрузки = ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда
				// СтрокаДереваГруппаЗагрузить 
			Иначе
				Продолжить;
			КонецЕсли;	
				
			Индекс = 0;
			Пока Индекс < СтрокаДереваПервогоУровня.Строки.Количество() Цикл
				СтрокаДереваВторогоУровня = СтрокаДереваПервогоУровня.Строки[Индекс];
				
				// Дополнительные фильтры
				Если Параметры.ОтображатьСопоставленные = 1
					 И (НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Номенклатура) 
					 	ИЛИ СтрокаДереваВторогоУровня.ХарактеристикиИспользуются
					        И НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Характеристика)
					 	ИЛИ НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Категория)) Тогда
					Индекс = Индекс + 1;
					Продолжить;
					
				ИначеЕсли Параметры.ОтображатьСопоставленные = 2
					 	  И ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Номенклатура) 
					 	  И (НЕ СтрокаДереваВторогоУровня.ХарактеристикиИспользуются
					         ИЛИ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Характеристика))
					 	  И ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Категория) Тогда
					Индекс = Индекс + 1;
					Продолжить;
				КонецЕсли;
				
				Если Параметры.ОтображатьПоСтатусу <> -1
					 И СтрокаДереваВторогоУровня.ИндексСтатуса <> Параметры.ОтображатьПоСтатусу Тогда
					Индекс = Индекс + 1;
					Продолжить;
				КонецЕсли;

				// Отмеченные позиции
				Если СтрокаДереваВторогоУровня.Пометка Тогда
					ВсегоОтмечено = ВсегоОтмечено + 1;
					Если СтрокаДереваВторогоУровня.ИндексСтатуса = 5 Тогда
						ВсегоНеПолучено = ВсегоНеПолучено + 1;
					КонецЕсли;
					Если НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Номенклатура) И НЕ Параметры.СоздатьЭлементыНоменклатуры Тогда
						ВсегоНеСопоставлено = ВсегоНеСопоставлено + 1;
					КонецЕсли;
				КонецЕсли;				
				
				Если НЕ СтрокаДереваВторогоУровня.Пометка 
					 ИЛИ НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.ИдентификаторПубликации)
					 
					 ИЛИ (СтрокаДереваВторогоУровня.ВариантЗагрузки = ВариантЗагрузкиОбновитьСопоставленныеКарточкиТоваров()
					 	И Параметры.ВариантЗагрузкиДанных = ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров())
					 	
					 ИЛИ (СтрокаДереваВторогоУровня.ВариантЗагрузки = ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() 
					 И Параметры.ВариантЗагрузкиДанных = ВариантЗагрузкиОбновитьСопоставленныеКарточкиТоваров())
					 
					 ИЛИ СтрокаДереваВторогоУровня.ВариантЗагрузки = 3 
					 ИЛИ СтрокаДереваВторогоУровня.ИндексСтатуса = 4 
					 ИЛИ СтрокаДереваВторогоУровня.ИндексСтатуса = 5
					 ИЛИ НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Номенклатура) И НЕ Параметры.СоздатьЭлементыНоменклатуры Тогда
					Индекс = Индекс + 1;
					Продолжить;
				КонецЕсли;
				
				Если Параметры.ЗаписатьТолькоЦены 
					 И НЕ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.Номенклатура) Тогда
					Индекс = Индекс + 1;
					Продолжить;
				КонецЕсли;
				
				Если Параметры.ТолькоСоздатьНоменклатуру Тогда
					СтрокаДереваВторогоУровня.Пометка = Ложь;
					СтрокаДереваВторогоУровня.ИндексСтатуса = СтрокаДереваВторогоУровня.ИндексСтатуса - 100;
					
					Индекс = Индекс + 1;
					Продолжить;
				КонецЕсли;
				
				Если Параметры.ЗагрузитьЦеныПродажи ИЛИ Параметры.ЗаписатьТолькоЦены Тогда
					ЗаполнитьЗначенияСвойств(ТаблицаТоваров.Добавить(), СтрокаДереваВторогоУровня);
					Идентификаторы.Добавить(СтрокаДереваВторогоУровня[ИмяИдентификатора]);
				
					Если Параметры.ЗаписатьТолькоЦены Тогда
						СтрокаДереваВторогоУровня.Пометка       = Ложь;
						СтрокаДереваВторогоУровня.ИндексСтатуса = СтрокаДереваВторогоУровня.ИндексСтатуса - 100;
						
						Индекс = Индекс + 1;
						Продолжить;
					КонецЕсли;
				КонецЕсли;
				
				// Запись данных объекта 
				НачатьТранзакцию();
				
				Попытка  
					// Корректировка данных
					
					Если СтрокаДереваВторогоУровня.ВариантЗагрузки = ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда
					
						СтрокаДереваВторогоУровня.ДатаСоздания = ТекущаяДатаСеанса();
						СтрокаДереваВторогоУровня.НаименованиеОбъектаМаркетплейса = ПредставлениеТоварнойПозиции(
							СтрокаДереваВторогоУровня.Номенклатура, 
							СтрокаДереваВторогоУровня.Характеристика, 
							СтрокаДереваВторогоУровня.Упаковка);
							
					Иначе
						СтрокаДереваВторогоУровня.ДатаОбновления = ТекущаяДатаСеанса();
					КонецЕсли;
					
					// РегистрСведений.СтатусыПубликацииТоваровЯндексМаркет
					БлокировкаДанных = Новый БлокировкаДанных;
					ЭлементБлокировкиДанных = БлокировкаДанных.Добавить( "РегистрСведений.СтатусыПубликацииТоваровЯндексМаркет" );
					ЭлементБлокировкиДанных.УстановитьЗначение( "УчетнаяЗаписьМаркетплейса", СтрокаДереваВторогоУровня.УчетнаяЗаписьМаркетплейса);
					ЭлементБлокировкиДанных.УстановитьЗначение( "Номенклатура", СтрокаДереваВторогоУровня.Номенклатура);
					ЭлементБлокировкиДанных.УстановитьЗначение( "Характеристика", СтрокаДереваВторогоУровня.Характеристика);
					БлокировкаДанных.Заблокировать();

					
					НаборЗаписей = РегистрыСведений.СтатусыПубликацииТоваровЯндексМаркет.СоздатьНаборЗаписей();
					
					НаборЗаписей.Отбор.УчетнаяЗаписьМаркетплейса.Установить( СтрокаДереваВторогоУровня.УчетнаяЗаписьМаркетплейса );
					НаборЗаписей.Отбор.Номенклатура.Установить( СтрокаДереваВторогоУровня.Номенклатура );
					НаборЗаписей.Отбор.Характеристика.Установить( СтрокаДереваВторогоУровня.Характеристика );
					
					НаборЗаписей.Прочитать();
					
					Если НаборЗаписей.Количество() = 0 Тогда

						Запись = НаборЗаписей.Добавить();
						
					ИначеЕсли СтрокаДереваВторогоУровня.ВариантЗагрузки = ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда
					
						ОтменитьТранзакцию();
						
						Результат.Пропущено.Добавить(Новый Структура("НомерСтроки, Сообщение", 
							Индекс + 1, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
								НСтр("ru = 'Товарная позиция «%1» не записана, т.к. уже существует другая позиция с таким набором ключевых полей: %2, %3, %4.'"),
								СтрокаДереваВторогоУровня.ПредставлениеОбъектаМаркетплейса,
								СтрокаДереваВторогоУровня.Номенклатура,
								СтрокаДереваВторогоУровня.Характеристика,
								СтрокаДереваВторогоУровня.Упаковка)));
						Результат.НеЗаписано = Результат.НеЗаписано + 1;
						Индекс = Индекс + 1;
						
						// Удаление дубля товара
						Отбор = Новый Структура(ПоляТаблицыТоваров);
						ЗаполнитьЗначенияСвойств(Отбор, СтрокаДереваВторогоУровня);
						СтрокиТовара = ТаблицаТоваров.НайтиСтроки(Отбор);
						Для Каждого СтрокаТовара Из СтрокиТовара Цикл
							ТаблицаТоваров.Удалить(СтрокаТовара);
							Прервать;
						КонецЦикла;
						
						Продолжить;
						
					Иначе

						Запись = НаборЗаписей[0];
						
					КонецЕсли;
									 
					Если СтрокаДереваВторогоУровня.ВариантЗагрузки = ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда
						
						ЗаполнитьЗначенияСвойств( Запись, СтрокаДереваВторогоУровня );
						
						Если ЗначениеЗаполнено( СтрокаДереваВторогоУровня.ТекущееИдентификаторКатегорииМаркетплейса ) Тогда
							
							Запись.ИдентификаторКатегорииМаркетплейса = СтрокаДереваВторогоУровня.ТекущееИдентификаторКатегорииМаркетплейса;
							Запись.НаименованиеКатегорииМаркетплейса  = СтрокаДереваВторогоУровня.ТекущееНаименованиеКатегорииМаркетплейса;
							
						КонецЕсли;
									   
					КонецЕсли;
					
					Запись.Категория = СтрокаДереваВторогоУровня.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет;
					
					Запись.ПредставлениеТовара = СтрокаДереваВторогоУровня.ПредставлениеОбъектаМаркетплейса;
					Запись.ИдентификаторТовараПлощадки = СтрокаДереваВторогоУровня.ИдентификаторТовараПлощадки;
					Запись.НаименованиеТовараПлощадки = СтрокаДереваВторогоУровня.ПредставлениеОбъектаМаркетплейса;
					Запись.НаименованиеКатегорииПлощадки = СтрокаДереваВторогоУровня.НаименованиеКатегорииМаркетплейса;
					Запись.ИдентификаторКатегорииМаркетплейса = СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса;
					Запись.НаименованиеМоделиПлощадки = СтрокаДереваВторогоУровня.НаименованиеМоделиПлощадки;
					Запись.КатегорияНоменклатуры = СтрокаДереваВторогоУровня.НаименованиеКатегорииМаркетплейса;
					Запись.МаркерСтатуса = 0;
					Запись.ЕстьИдентификаторПлощадки = Истина;
					
					
					НаборЗаписей.Записать(Истина);					
					
					ЗафиксироватьТранзакцию();
					
				Исключение
				
				    ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки( ИнформацияОбОшибке() );
				    
					Если ТранзакцияАктивна() Тогда
						ОтменитьТранзакцию();
					КонецЕсли;
					
					ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'При записи сведений по товарной позиции «%1» возникла ошибка: %2.'", 
					ОбщегоНазначения.КодОсновногоЯзыка()),
					СтрокаДереваВторогоУровня.ПредставлениеОбъектаМаркетплейса,
					ТекстОшибки);
						
					ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации(),
					УровеньЖурналаРегистрации.Ошибка,,,
					ТекстСообщения);
						
					ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );
					
					ОбменСВнешнимиСистемамиЛогирование.ЗаписатьВЛог( ТекстСообщения, УчетнаяЗаписьМаркетплейса, Истина );
					
					Результат.Пропущено.Добавить( 
					Новый Структура( "НомерСтроки, Сообщение", 
					Индекс + 1, СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'При записи сведений по товарной позиции «%1» возникли ошибки.'"),
					СтрокаДереваВторогоУровня.ПредставлениеОбъектаМаркетплейса)));
						    
					Результат.НеЗаписано = Результат.НеЗаписано + 1;
					Индекс = Индекс + 1;
					Продолжить;
				КонецПопытки;
			
				Результат.Записано = Результат.Записано + 1;
				Если СтрокаДереваВторогоУровня.ВариантЗагрузки = ВариантЗагрузкиЗагрузитьНесопоставленныеКарточкиТоваров() Тогда
					Результат.ВТомЧислеНовых = Результат.ВТомЧислеНовых + 1;
					СтрокаДереваВторогоУровня.Пометка = Ложь;
				Иначе	
					СтрокаДереваВторогоУровня.Пометка = Истина;
				КонецЕсли;

				СтрокаДереваВторогоУровня.ВариантЗагрузки = ВариантЗагрузкиОбновитьСопоставленныеКарточкиТоваров();
				СтрокаДереваВторогоУровня.ИндексСтатуса   = -999;
				
				Индекс = Индекс + 1;
			КонецЦикла;
		КонецЦикла;
		
		Для каждого СтрокаДереваПервогоУровня Из ДеревоТоваров.Строки Цикл
			Для каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.Строки Цикл
				Если СтрокаДереваВторогоУровня.ИндексСтатуса < 0 Тогда
					Если СтрокаДереваВторогоУровня.ИндексСтатуса = -999 Тогда
						Если СтрокаДереваВторогоУровня.Статус = Перечисления.СтатусыВыгрузкиТоваровЯндексМаркет.ЗагруженСОшибками 
							 ИЛИ ЗначениеЗаполнено(СтрокаДереваВторогоУровня.ОписаниеОшибки)
								 И СтрокаДереваВторогоУровня.Статус <> Перечисления.СтатусыВыгрузкиТоваровЯндексМаркет.ВАрхиве Тогда
							СтрокаДереваВторогоУровня.ИндексСтатуса = 0;
						ИначеЕсли СтрокаДереваВторогоУровня.Статус = Перечисления.СтатусыВыгрузкиТоваровЯндексМаркет.СозданиеНового Тогда
							СтрокаДереваВторогоУровня.ИндексСтатуса = 1;
						ИначеЕсли СтрокаДереваВторогоУровня.Статус = Перечисления.СтатусыВыгрузкиТоваровЯндексМаркет.НаМодерации Тогда
							СтрокаДереваВторогоУровня.ИндексСтатуса = 1;
						ИначеЕсли СтрокаДереваВторогоУровня.Статус = Перечисления.СтатусыВыгрузкиТоваровЯндексМаркет.ВАрхиве Тогда
							СтрокаДереваВторогоУровня.ИндексСтатуса = 2;
						ИначеЕсли СтрокаДереваВторогоУровня.Статус = Перечисления.СтатусыВыгрузкиТоваровЯндексМаркет.МодерацияПройдена Тогда
							СтрокаДереваВторогоУровня.ИндексСтатуса = 3;
						ИначеЕсли СтрокаДереваВторогоУровня.Статус = Перечисления.СтатусыВыгрузкиТоваровЯндексМаркет.МодерацияНеПройдена Тогда
							СтрокаДереваВторогоУровня.ИндексСтатуса = 0;
						КонецЕсли;
					Иначе
						СтрокаДереваВторогоУровня.ИндексСтатуса = СтрокаДереваВторогоУровня.ИндексСтатуса + 100;
					КонецЕсли;
					
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		ИмпортИзМаркетплейсаЗаполнитьНаименованияГруппДереваТоваров(
			ДеревоТоваров, 
			Ложь, 
			Параметры.ОтображатьСопоставленные,
			Параметры.ОтображатьПоСтатусу);
		
		Результат.Вставить("ДеревоТоваров", ДеревоТоваров);
		
		Если Результат.Записано = 0 И Результат.НеЗаписано = 0 Тогда
			Результат.Ошибка.КодОшибки = КодыОшибокРегистраСтатусовПубликацииТоваров().ОшибкаПрочие;
			Результат.Ошибка.ОписаниеОшибки = НСтр("ru = 'Не найдено данных для записи.'");
			
			Если ВсегоОтмечено > 0 
				 И (ВсегоНеПолучено > 0 ИЛИ ВсегоНеСопоставлено > 0) Тогда
				Результат.Ошибка.ОписаниеОшибки = НСтр("ru = 'Данные не записаны, так как для отмеченных позиций'");
				Если ВсегоНеПолучено > 0 Тогда
					Результат.Ошибка.ОписаниеОшибки = Результат.Ошибка.ОписаниеОшибки + " " + НСтр("ru = 'не получены обновленные данные с торговой площадки'");
				КонецЕсли;
				Если ВсегоНеСопоставлено > 0 Тогда
					Если ВсегоНеПолучено > 0 Тогда
						Результат.Ошибка.ОписаниеОшибки = Результат.Ошибка.ОписаниеОшибки + " " + НСтр("ru = 'или'");
					КонецЕсли;
					Результат.Ошибка.ОписаниеОшибки = Результат.Ошибка.ОписаниеОшибки + " " + НСтр("ru = 'не выполнено сопоставление данным учетной системы 1С'");
				КонецЕсли;
				Результат.Ошибка.ОписаниеОшибки = Результат.Ошибка.ОписаниеОшибки + ".";
			КонецЕсли;
		КонецЕсли;
		
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Отказ = Истина;
		ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстОшибки);
	КонецПопытки;

	Если Отказ Тогда
		Результат.Ошибка.КодОшибки 	    = КодыОшибокРегистраСтатусовПубликацииТоваров().ОшибкаПрочие;
		Результат.Ошибка.ОписаниеОшибки = ТекстОшибки;
	КонецЕсли;
	
	//@skip-check constructor-function-return-section
	Возврат Результат;

КонецФункции

Функция КатегорииИзДеревоТоварыПолучить( ДеревоТоваров )
	
	Категории = Новый Соответствие;
	
	Для Каждого ДеревоТоваровСтрока Из ДеревоТоваров.Строки Цикл
		Для Каждого ДеревоТоваровСтрокаВторогоУровня Из ДеревоТоваровСтрока.Строки Цикл

			Если ДеревоТоваровСтрокаВторогоУровня.Пометка <> Истина Тогда
				Продолжить;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено( ДеревоТоваровСтрокаВторогоУровня.ИдентификаторКатегорииМаркетплейса ) Тогда
				Продолжить;
			КонецЕсли;
			
			Если Категории.Получить( ДеревоТоваровСтрокаВторогоУровня.ИдентификаторКатегорииМаркетплейса ) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			КатегорииЭлемент = Новый Структура;
			КатегорииЭлемент.Вставить( "ИдентификаторКатегорииМаркетплейса", ДеревоТоваровСтрокаВторогоУровня.ИдентификаторКатегорииМаркетплейса );
			КатегорииЭлемент.Вставить( "НаименованиеКатегорииМаркетплейса", ДеревоТоваровСтрокаВторогоУровня.НаименованиеКатегорииМаркетплейса );
			КатегорииЭлемент.Вставить( "ПолноеНаименованиеКатегорииМаркетплейса", "" );
			КатегорииЭлемент.Вставить( "Категория", ДеревоТоваровСтрокаВторогоУровня.Категория ); // Категория 1С для заполнения номенклатуры
			КатегорииЭлемент.Вставить( "КатегорияИерархия", ДеревоТоваровСтрокаВторогоУровня.КатегорияИерархия );
			КатегорииЭлемент.Вставить( "КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет", ДеревоТоваровСтрокаВторогоУровня.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет );
			
			Категории.Вставить( ДеревоТоваровСтрокаВторогоУровня.ИдентификаторКатегорииМаркетплейса, КатегорииЭлемент );
		КонецЦикла;
	КонецЦикла;
	
	Возврат Категории;
КонецФункции

Функция Категории1СПоНаименованиюКатегорииМаркетплейсаНайтиИЗаполнить( Параметры ) Экспорт

	КатегорииДанные = Новый ТаблицаЗначений;
	ОписаниеТиповСтрока50 = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки( 50, ДопустимаяДлина.Переменная));
	ОписаниеТиповСтрока250 = Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки( 250, ДопустимаяДлина.Переменная));
	КатегорииДанные.Колонки.Добавить( "Наименование", ОписаниеТиповСтрока50 );
	КатегорииДанные.Колонки.Добавить( "Код", ОписаниеТиповСтрока250 );
	
	ТипСоответствие = (ТипЗнч( Параметры.СопоставлениеКатегорий ) = Тип( "Соответствие" ));
	
	КатегорииПоиск = Новый Структура( "Код, Наименование" );
	Для Каждого СопоставлениеКатегорийЭлемент Из Параметры.СопоставлениеКатегорий Цикл
		
		Если ТипСоответствие = Истина Тогда
			СопоставлениеКатегорийСтрока = СопоставлениеКатегорийЭлемент.Значение;
		Иначе
			СопоставлениеКатегорийСтрока = СопоставлениеКатегорийЭлемент;
		КонецЕсли;
		
		Если ЗначениеЗаполнено( СопоставлениеКатегорийСтрока.Категория ) Тогда
			Продолжить
		КонецЕсли;
		
		КатегорииПоиск.Код = СопоставлениеКатегорийСтрока.ИдентификаторКатегорииМаркетплейса;
		КатегорииПоиск.Наименование = СопоставлениеКатегорийСтрока.НаименованиеКатегорииМаркетплейса;
		
		КатегорииДанныеСтроки = КатегорииДанные.НайтиСтроки( КатегорииПоиск );
		Если КатегорииДанныеСтроки.Количество() > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		КатегорииДанныеСтрока = КатегорииДанные.Добавить();
		КатегорииДанныеСтрока.Код = СопоставлениеКатегорийСтрока.ИдентификаторКатегорииМаркетплейса;
		КатегорииДанныеСтрока.Наименование = СопоставлениеКатегорийСтрока.НаименованиеКатегорииМаркетплейса;
	КонецЦикла;
	
	ЗапросТекст =
	"ВЫБРАТЬ
	|	КатегорииДанные.Код КАК Код,
	|	КатегорииДанные.Наименование КАК Наименование
	|ПОМЕСТИТЬ КатегорииДанные
	|ИЗ
	|	&КатегорииДанные КАК КатегорииДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КатегорииНоменклатуры.Ссылка КАК Ссылка,
	|	КатегорииНоменклатуры.Код КАК Код,
	|	КатегорииНоменклатуры.Наименование КАК Наименование
	|ИЗ
	|	Справочник.КатегорииНоменклатуры КАК КатегорииНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КатегорииДанные КАК КатегорииДанные
	|		ПО КатегорииНоменклатуры.Наименование = КатегорииДанные.Наименование
	|			И КатегорииНоменклатуры.Код = КатегорииДанные.Код
	|ГДЕ
	|	КатегорииНоменклатуры.ПометкаУдаления = ЛОЖЬ
	|	И КатегорииНоменклатуры.ЭтоГруппа = ЛОЖЬ";

	ЗапросОбъект = Новый Запрос( ЗапросТекст );
	ЗапросОбъект.УстановитьПараметр( "КатегорииДанные", КатегорииДанные );
	Категории1С = ЗапросОбъект.Выполнить().Выгрузить();
	
	ИсточникКатегорииКатегория = ( Параметры.ИсточникКатегории = Перечисления.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры );
	Для Каждого СопоставлениеКатегорийЭлемент Из Параметры.СопоставлениеКатегорий Цикл

		Если ТипСоответствие = Истина Тогда
			СопоставлениеКатегорийСтрока = СопоставлениеКатегорийЭлемент.Значение;
		Иначе
			СопоставлениеКатегорийСтрока = СопоставлениеКатегорийЭлемент;
		КонецЕсли;
		
		Если ЗначениеЗаполнено( СопоставлениеКатегорийСтрока.Категория ) Тогда
			Продолжить;
		КонецЕсли;
		
		КатегорииПоиск.Код = СопоставлениеКатегорийСтрока.ИдентификаторКатегорииМаркетплейса;
		КатегорииПоиск.Наименование = СопоставлениеКатегорийСтрока.НаименованиеКатегорииМаркетплейса;

		Категории1ССтроки = Категории1С.НайтиСтроки( КатегорииПоиск );
		Если Категории1ССтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СопоставлениеКатегорийСтрока.Категория = Категории1ССтроки[ 0 ].Ссылка;
		
		Если ИсточникКатегорииКатегория = Истина Тогда
			СопоставлениеКатегорийСтрока.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = СопоставлениеКатегорийСтрока.Категория;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция Категории1СПоКатегориямМаркетплейсаПараметрыНовый() Экспорт

	ПараметрыФункции = Новый Структура;
	ПараметрыФункции.Вставить( "СопоставлениеКатегорий", Неопределено );
	ПараметрыФункции.Вставить( "ИсточникКатегории", Неопределено );
	ПараметрыФункции.Вставить( "СоздатьИерархию", Ложь );
	ПараметрыФункции.Вставить( "УчетнаяЗапись", Неопределено );
	ПараметрыФункции.Вставить( "КэшКатегорийДерево", Неопределено );
	ПараметрыФункции.Вставить( "КатегорииНоменклатурыСоздано", 0 );
	
	Возврат ПараметрыФункции;
КонецФункции

Функция Категории1СПоКатегориямМаркетплейсаСоздать( Параметры ) Экспорт
    
    СопоставлениеКатегорийТипСоответствие = (ТипЗнч( Параметры.СопоставлениеКатегорий ) = Тип( "Соответствие" ));
    ИсточникКатегорииКатегория = (Параметры.ИсточникКатегории = ПредопределенноеЗначение( "Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры" ) = Истина);
	
	КатегорияДанные = ОбменСВнешнимиСистемамиНоменклатура.КатегорияДанныеНовый();
	
	КоличествоЗаписано = 0;
	Для Каждого СопоставлениеКатегорийЭлемент Из Параметры.СопоставлениеКатегорий Цикл
		
		Если СопоставлениеКатегорийТипСоответствие = Истина Тогда
			СопоставлениеКатегории = СопоставлениеКатегорийЭлемент.Значение;
		Иначе
			СопоставлениеКатегории = СопоставлениеКатегорийЭлемент;
		КонецЕсли;
		
		Если ЗначениеЗаполнено( СопоставлениеКатегории.Категория ) Тогда
			Продолжить;
		КонецЕсли;
		
		КатегорияДанные.Наименование = СопоставлениеКатегории.НаименованиеКатегорииМаркетплейса;
		КатегорияДанные.Код = СопоставлениеКатегории.ИдентификаторКатегорииМаркетплейса;
		КатегорияДанные.Иерархия = СопоставлениеКатегории.КатегорияИерархия;
		КатегорияДанные.СоздатьИерархию = Параметры.СоздатьИерархию;
		
		КатегорияСсылка = ОбменСВнешнимиСистемамиНоменклатура.КатегорияНоменклатурыПоНаименованиюНайти( КатегорияДанные.Наименование, Ложь );
		Если ЗначениеЗаполнено( КатегорияСсылка ) Тогда
			СопоставлениеКатегории.Категория = КатегорияСсылка;
			
			Если ИсточникКатегорииКатегория Тогда
				Если Не ЗначениеЗаполнено( СопоставлениеКатегории.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет ) Тогда
					СопоставлениеКатегории.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = КатегорияСсылка;
				КонецЕсли;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		КатегорияСсылка = ОбменСВнешнимиСистемамиНоменклатура.КатегорияНоменклатурыСоздать( КатегорияДанные, Параметры );
		Если Не ЗначениеЗаполнено( КатегорияСсылка ) Тогда
			Возврат Ложь;
		КонецЕсли;
		
		СопоставлениеКатегории.Категория = КатегорияСсылка;
		
		Если ИсточникКатегорииКатегория Тогда
			Если Не ЗначениеЗаполнено( СопоставлениеКатегории.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет ) Тогда
				СопоставлениеКатегории.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = КатегорияСсылка;
			КонецЕсли;
		КонецЕсли;
		
		
		КоличествоЗаписано  = КоличествоЗаписано + 1;
	КонецЦикла;
	
	Параметры.КатегорииНоменклатурыСоздано = КоличествоЗаписано;
	
	Возврат Истина;
КонецФункции

Процедура ДеревоТоваровКатегорииПоСопоставлениюЗаполнить( ДеревоТоваров, Категории, Параметры )
	
	ИсточникКатегорииКатегория = (Параметры.ИсточникКатегории = ПредопределенноеЗначение( "Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры" ));
	Для Каждого СтрокаДереваПервогоУровня Из ДеревоТоваров.Строки Цикл
		Для Каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.Строки Цикл
			
			Если СтрокаДереваВторогоУровня.Пометка <> Истина Тогда
				Продолжить;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено( СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса ) Тогда
				Продолжить;
			КонецЕсли;
			
			СопоставлениеКатегории = Категории.Получить( СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса );
			Если СопоставлениеКатегории = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаДереваВторогоУровня.Категория = СопоставлениеКатегории.Категория;
			
			Если ИсточникКатегорииКатегория = Истина Тогда
				СтрокаДереваВторогоУровня.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = СопоставлениеКатегории.Категория;
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ИмпортируемыеТоварыНоменклатураКлючЗаполнить( ДеревоТоваров )
	
	Для Каждого ИмпортируемыеТоварыСтрока Из ДеревоТоваров.Строки Цикл
		Для Каждого ИмпортируемыеТоварыВторойУровеньСтрока Из ИмпортируемыеТоварыСтрока.Строки Цикл
			Если ЗначениеЗаполнено( ИмпортируемыеТоварыВторойУровеньСтрока.Номенклатура ) Тогда
				ИмпортируемыеТоварыВторойУровеньСтрока.НоменклатураКлюч = 
				ИмпортируемыеТоварыВторойУровеньСтрока.Номенклатура.УникальныйИдентификатор();
			Иначе
				ИмпортируемыеТоварыВторойУровеньСтрока.НоменклатураКлюч = Новый УникальныйИдентификатор;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

Процедура ИерархияНоменклатурыПоИерархииКатегорийМаркетплейсаВДеревеТоваровЗаполнить( Параметры )
	
	Для Каждого СтрокаДереваПервогоУровня Из Параметры.ДеревоТоваров.Строки Цикл
		Для Каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.Строки Цикл
			
			Если СтрокаДереваВторогоУровня.Пометка = Ложь Тогда
				Продолжить;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено( СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса ) Тогда
				
				ТекстОшибки = "ИерархияНоменклатурыПоИерархииКатегорийМаркетплейсаВДеревеТоваровЗаполнить: Ошибка: "
				+ СтрокаДереваВторогоУровня.ПредставлениеОбъектаМаркетплейса
				+ ": Не задан идентификатор категории Яндекс Маркет.";
				
				ОбщегоНазначения.СообщитьПользователю( ТекстОшибки );
				
				ОбменСВнешнимиСистемамиЛогирование.ЗаписатьВЛог( ТекстОшибки, Параметры.УчетнаяЗапись, Истина );
				
				Продолжить;
			КонецЕсли;
			
			СопоставлениеКатегорийЭлемент = Параметры.СопоставлениеКатегорий.Получить( СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса );
			Если СопоставлениеКатегорийЭлемент = Неопределено Тогда
				ВызватьИсключение "ИерархияНоменклатурыПоИерархииКатегорийМаркетплейсаВДеревеТоваровЗаполнить: Ошибка при заполнении иерархии категорий: Не найден идентификатор категории";
			КонецЕсли;
			
			СтрокаДереваВторогоУровня.НоменклатураИерархия = ОбщегоНазначения.СкопироватьРекурсивно( СопоставлениеКатегорийЭлемент.КатегорияИерархия );
			
			// Добавление самой категории в иерархию групп Номенклатуры
			НоменклатураИерархияСтрока = СтрокаДереваВторогоУровня.НоменклатураИерархия.Добавить();
			НоменклатураИерархияСтрока.Код = СопоставлениеКатегорийЭлемент.ИдентификаторКатегорииМаркетплейса;
			НоменклатураИерархияСтрока.Наименование = СопоставлениеКатегорийЭлемент.НаименованиеКатегорииМаркетплейса;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ТоварыСоздать( ДеревоТоваров, Параметры )
	
	// заполним описания товаров из элементов формы в параметры поиска
	ДеревоТоваровДляСоздания = ДеревоТоваров.Строки.НайтиСтроки( Новый Структура( "Пометка, ПоискВыполнен", Истина, Истина ), Истина );
	Если ДеревоТоваровДляСоздания.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;

	ПараметрыКонтекст = ОбменСВнешнимиСистемамиНоменклатура.ТоварыСоздатьПараметрыКонтекстНовый();
	
	ПараметрыКонтекст.ГруппаДляСозданияНовыхТоваров = Параметры.ГруппаДляСозданияНовыхТоваров;
	ПараметрыКонтекст.ЗаписатьФайлы = Параметры.ЗагрузитьИзображения;

	ПараметрыКонтекст.УчетнаяЗапись = Параметры.УчетнаяЗаписьМаркетплейса;
	ПараметрыКонтекст.ПерезаполнитьЗначенияРеквизитовНоменклатуры = Параметры.ПерезаполнитьЗначенияРеквизитовНоменклатуры;

	Для Каждого ДеревоТоваровДляСозданияСтрока Из ДеревоТоваровДляСоздания Цикл
	
		Если Не ЗначениеЗаполнено( ДеревоТоваровДляСозданияСтрока.ИдентификаторОбъектаМаркетплейса ) Тогда
			Продолжить;
		КонецЕсли;
		
		ОписаниеТовараЭлемент = ОбменСВнешнимиСистемамиНоменклатура.ТоварыСоздатьОписанияТоваровЭлементНовый( ПараметрыКонтекст.ОписанияТоваров );
		
		ОписаниеТовараЭлемент.ИдентификаторЭлемента = ДеревоТоваровДляСозданияСтрока.ИдентификаторОбъектаМаркетплейса;
		ОписаниеТовараЭлемент.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас;

		ОписаниеТовараЭлемент.КатегорияНоменклатуры = ДеревоТоваровДляСозданияСтрока.Категория;

		ОписаниеТовараЭлемент.Наименование = ДеревоТоваровДляСозданияСтрока.ПредставлениеОбъектаМаркетплейса;
		ОписаниеТовараЭлемент.НаименованиеПолное = ДеревоТоваровДляСозданияСтрока.ПредставлениеОбъектаМаркетплейса;
	
		ОписаниеТовараЭлемент.Номенклатура = ДеревоТоваровДляСозданияСтрока.Номенклатура;
		ОписаниеТовараЭлемент.Характеристика = ДеревоТоваровДляСозданияСтрока.Характеристика;
		ОписаниеТовараЭлемент.СоздатьХарактеристику = ДеревоТоваровДляСозданияСтрока.СоздатьХарактеристику;
		ОписаниеТовараЭлемент.НоменклатураКлюч = ДеревоТоваровДляСозданияСтрока.НоменклатураКлюч;
		
		Если ОписаниеТовараЭлемент.СоздатьХарактеристику = Истина Тогда
			ОписаниеТовараЭлемент.НоменклатураНаименование = СокрЛП( ДеревоТоваровДляСозданияСтрока.ЗначениеОбъединенияВОднуКарточку );
			Если ПустаяСтрока( ОписаниеТовараЭлемент.НоменклатураНаименование ) Тогда
				ОписаниеТовараЭлемент.НоменклатураНаименование = ОписаниеТовараЭлемент.Наименование;
			КонецЕсли;
		КонецЕсли;

		// Артикул
		ДеревоРеквизитовАртикулСтроки = ДеревоТоваровДляСозданияСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "НаименованиеАтрибутаМаркетплейса", "Артикул" ), Истина );
		Если ДеревоРеквизитовАртикулСтроки.Количество() > 0 Тогда
			ОписаниеТовараЭлемент.Артикул = ДеревоРеквизитовАртикулСтроки[ 0 ].ЗначениеАтрибутаМаркетплейса;
		КонецЕсли;
		
		// Вес
		ДеревоРеквизитовАртикулСтроки = ДеревоТоваровДляСозданияСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "ИдентификаторАтрибута1С", "ВесБруттоКг" ), Истина );
		Если ДеревоРеквизитовАртикулСтроки.Количество() > 0 Тогда
			ОписаниеТовараЭлемент.Вес = ДеревоРеквизитовАртикулСтроки[ 0 ].ЗначениеАтрибутаМаркетплейса;
		КонецЕсли;

		// Высота
		ДеревоРеквизитовАртикулСтроки = ДеревоТоваровДляСозданияСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "ИдентификаторАтрибута1С", "ВысотаСм" ), Истина );
		Если ДеревоРеквизитовАртикулСтроки.Количество() > 0 Тогда
			ОписаниеТовараЭлемент.Высота = ДеревоРеквизитовАртикулСтроки[ 0 ].ЗначениеАтрибутаМаркетплейса;
		КонецЕсли;

		// Длина
		ДеревоРеквизитовАртикулСтроки = ДеревоТоваровДляСозданияСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "ИдентификаторАтрибута1С", "ДлинаСм" ), Истина );
		Если ДеревоРеквизитовАртикулСтроки.Количество() > 0 Тогда
			ОписаниеТовараЭлемент.Длина = ДеревоРеквизитовАртикулСтроки[ 0 ].ЗначениеАтрибутаМаркетплейса;
		КонецЕсли;

		// Ширина
		ДеревоРеквизитовАртикулСтроки = ДеревоТоваровДляСозданияСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "ИдентификаторАтрибута1С", "ШиринаСм" ), Истина );
		Если ДеревоРеквизитовАртикулСтроки.Количество() > 0 Тогда
			ОписаниеТовараЭлемент.Ширина = ДеревоРеквизитовАртикулСтроки[ 0 ].ЗначениеАтрибутаМаркетплейса;
		КонецЕсли;

		// Описание
		ОписаниеТовараЭлемент.Комментарий = ДеревоТоваровДляСозданияСтрока.ОписаниеОбъектаМаркетплейса;
        
        // Штрихкоды
		ФормаШтрихкодыСтроки = ДеревоТоваровДляСозданияСтрока.ДеревоРеквизитов.Строки.НайтиСтроки( Новый Структура( "НаименованиеАтрибутаМаркетплейса", "Штрихкоды" ), Истина );
		Если ФормаШтрихкодыСтроки.Количество() > 0 Тогда

			ФормаШтрихкоды = ФормаШтрихкодыСтроки[ 0 ].ЗначенияАтрибутаМаркетплейса;
			
			Для Каждого ФормаШтрихкод Из ФормаШтрихкоды Цикл
				Штрихкод = ОписаниеТовараЭлемент.Штрихкоды.Добавить();
				Штрихкод.Имя = "-";
				Штрихкод.Значение = ФормаШтрихкод.Значение;
			КонецЦикла;
			
		КонецЕсли;
		
		// Файлы
		Для Каждого ФормаИзображение Из ДеревоТоваровДляСозданияСтрока.Изображения Цикл
			
			Файл = ОписаниеТовараЭлемент.Файлы.Добавить();
			
			Файл.Имя = ФормаИзображение.ПутьКФайлу;
			Файл.URL = ФормаИзображение.ПутьКФайлу;
		КонецЦикла;
		
		Если Параметры.СоздатьИерархиюНоменклатуры = Истина Тогда
			ПараметрыКонтекст.СоздатьИерархиюНоменклатуры = Истина;
			
			ОписаниеТовараЭлемент.Иерархия = ДеревоТоваровДляСозданияСтрока.НоменклатураИерархия;
		КонецЕсли;
	КонецЦикла;

	
	ТоварыСозданы = ОбменСВнешнимиСистемамиНоменклатура.ТоварыСоздать( ПараметрыКонтекст );// создание элементов справочников, включая файлы
	
	
	Если ТоварыСозданы = Истина Тогда

		ОтборПоИдентификатору = Новый Структура( "ИдентификаторОбъектаМаркетплейса" );
		ОтборПоURL = Новый Структура( "URL" );
		Для Каждого ОписаниеТовараЭлемент Из ПараметрыКонтекст.ОписанияТоваров Цикл
			
			ОтборПоИдентификатору.ИдентификаторОбъектаМаркетплейса = ОписаниеТовараЭлемент.ИдентификаторЭлемента;
			ДеревоТоваровСтроки = ДеревоТоваров.Строки.НайтиСтроки( ОтборПоИдентификатору, Истина );
			
			Если ДеревоТоваровСтроки.Количество() = 0 Тогда
				ОбщегоНазначения.СообщитьПользователю( "ТоварыСоздать: Не найден элемент по идентификатору "
				+ ОтборПоИдентификатору.ИдентификаторОбъектаМаркетплейса );
				Продолжить;
			КонецЕсли;
			
			ДеревоТоваровДляСозданияСтрока = ДеревоТоваровСтроки[ 0 ];
			
			ДеревоТоваровДляСозданияСтрока.Номенклатура = ОписаниеТовараЭлемент.Номенклатура;
			ДеревоТоваровДляСозданияСтрока.Характеристика = ОписаниеТовараЭлемент.Характеристика;
			
			// заполнение ссылок на файлы в дереве товаров в таблицу изображения
			Для Каждого ДеревоТоваровИзображенияСтрока Из ДеревоТоваровДляСозданияСтрока.Изображения Цикл
				
				Если ПустаяСтрока( ДеревоТоваровИзображенияСтрока.ПутьКФайлу ) Тогда
					Продолжить;
				КонецЕсли;
				
				ОтборПоURL.URL = ДеревоТоваровИзображенияСтрока.ПутьКФайлу;
				ОписаниеТовараЭлементФайлыСтроки = ОписаниеТовараЭлемент.Файлы.НайтиСтроки( ОтборПоURL );
				Если ОписаниеТовараЭлементФайлыСтроки.Количество() = 0 Тогда
					Продолжить;
				КонецЕсли;
				
				ДеревоТоваровИзображенияСтрока.ФайлСсылка = ОписаниеТовараЭлементФайлыСтроки[ 0 ].ФайлСсылка;
			КонецЦикла;
			
			ДеревоТоваровСтрокаПоНоменклатуреДозаполнить( ДеревоТоваровДляСозданияСтрока, Параметры );
		КонецЦикла;
		
		Параметры.НоменклатураКоличествоСоздано = ПараметрыКонтекст.НоменклатураКоличествоСоздано;
		Параметры.НоменклатураКоличествоОбновлено = ПараметрыКонтекст.НоменклатураКоличествоОбновлено;
		Параметры.ХарактеристикиКоличествоСоздано = ПараметрыКонтекст.ХарактеристикиКоличествоСоздано;
		Параметры.ХарактеристикиКоличествоОбновлено = ПараметрыКонтекст.ХарактеристикиКоличествоОбновлено;
		Параметры.ФайлыКоличествоСоздано = ПараметрыКонтекст.ФайлыКоличествоСоздано;
		Параметры.ШтрихкодыКоличествоСоздано = ПараметрыКонтекст.ШтрихкодыКоличествоСоздано;
		
	КонецЕсли;
	
	Возврат ТоварыСозданы;
КонецФункции

Процедура ДеревоТоваровКатегорияИлиНоменклатураДляСопоставленияКатегорииМаркетплейсаЗаполнить( ДеревоТоваров, Параметры )
	
	ИсточникКатегорииКатегория = (Параметры.ИсточникКатегории = ПредопределенноеЗначение( "Перечисление.ИсточникиКатегорийДляМаркетплейса.ВидНоменклатуры" ));
	Для Каждого СтрокаДереваПервогоУровня Из ДеревоТоваров.Строки Цикл
		Для Каждого СтрокаДереваВторогоУровня Из СтрокаДереваПервогоУровня.Строки Цикл
			
			Если СтрокаДереваВторогоУровня.Пометка <> Истина Тогда
				Продолжить;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено( СтрокаДереваВторогоУровня.ИдентификаторКатегорииМаркетплейса ) Тогда
				Продолжить;
			КонецЕсли;
			
			Если ИсточникКатегорииКатегория = Истина Тогда
				СтрокаДереваВторогоУровня.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = СтрокаДереваВторогоУровня.Категория;
			Иначе
				
				// Родитель или сама номенклатура
				Если ЗначениеЗаполнено( СтрокаДереваВторогоУровня.Номенклатура ) Тогда
					//@skip-check bsl-legacy-check-string-literal
					Родитель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта( СтрокаДереваВторогоУровня.Номенклатура, "Родитель" );
					Если ЗначениеЗаполнено( Родитель ) Тогда
						СтрокаДереваВторогоУровня.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = Родитель;
					Иначе
						СтрокаДереваВторогоУровня.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет = СтрокаДереваВторогоУровня.Номенклатура;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено( СтрокаДереваВторогоУровня.ИсточникКатегорииМаркетплейса ) Тогда
				СтрокаДереваВторогоУровня.ИсточникКатегорииМаркетплейса = СтрокаДереваВторогоУровня.КатегорияИлиНоменклатураДляСопоставленияКатегорииЯндексМаркет;
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// Конструктор таблицы значений для сведений о выгруженных данных.
// 
// Возвращаемое значение:
//	 ТаблицаЗначений - таблица с колонками:
//     * УчетнаяЗаписьМаркетплейса - СправочникСсылка.УчетныеЗаписиМаркетплейсов - учетная запись подключения к сервису.
//     * Номенклатура              - СправочникСсылка.Номенклатура - найденная номенклатура;
//     * Характеристика            - СправочникСсылка.ХарактеристикиНоменклатуры - найденная характеристика;
//     * Упаковка                  - СправочникСсылка.ЕдиницыИзмерения - найденная упаковка;
//     * ВидОбъектаМаркетплейса    - ПеречислениеСсылка.ВидыОбъектовМаркетплейсов - вид объекта маркетплейса;
//     * ОбъектПубликации          - СправочникСсылка.НоменклатураПрисоединенныеФайлы - объект публикации.
//
Функция СведенияОВыгруженныхДанных() Экспорт

	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("УчетнаяЗаписьМаркетплейса", Новый ОписаниеТипов("СправочникСсылка.УчетныеЗаписиМаркетплейсов"));
	Результат.Колонки.Добавить("Номенклатура",              Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Результат.Колонки.Добавить("Характеристика",            Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	Результат.Колонки.Добавить("Упаковка",                  Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения"));
