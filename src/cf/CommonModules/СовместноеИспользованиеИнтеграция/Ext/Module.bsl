#Область СлужебныйПрограммныйИнтерфейс

Функция НовоеПодключениеКСервису(ПараметрыПодключения, Таймаут = 60) Экспорт
	
	СтрокаАутентификации = СтрокаАутентификацииВСервисе(ПараметрыПодключения);
	
	Если ПустаяСтрока(ПараметрыПодключения.АдресПриложения) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОписаниеПодключения = Новый Структура;
	ОписаниеПодключения.Вставить("Соединение", Неопределено);
	ОписаниеПодключения.Вставить("БазовыйURI", "");
	ОписаниеПодключения.Вставить("СтрокаАутентификации", СтрокаАутентификации);
	ОписаниеПодключения.Вставить("ИдентификаторСеанса", "");
	ОписаниеПодключения.Вставить("ЗавершитьСеанс", Ложь);
	
	СтруктураАдреса = ОбщегоНазначенияКлиентСервер.СтруктураURI(ПараметрыПодключения.АдресПриложения);
	
	ОписаниеПодключения.БазовыйURI = СтруктураАдреса.ПутьНаСервере;
	
	ЗащищенноеСоединение = Неопределено;
	Если ВРег(СтруктураАдреса.Схема) = "HTTPS" Тогда
		ЗащищенноеСоединение = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
	КонецЕсли;
	
	ОписаниеПодключения.Соединение = Новый HTTPСоединение(
		СтруктураАдреса.Хост,
		СтруктураАдреса.Порт,
		,
		,
		ПолучениеФайловИзИнтернета.ПолучитьПрокси(СтруктураАдреса.Схема),
		Таймаут,
		ЗащищенноеСоединение);
	
	Возврат ОписаниеПодключения;
	
КонецФункции

Функция ВерсияИнтерфейса(ОписаниеПодключения) Экспорт
	
	ОписаниеЗапроса = НовыйЗапросКСервису(
		"/version",
		"GET");
	
	Ответ = ВыполнитьЗапросКСервису(ОписаниеПодключения, ОписаниеЗапроса);
	
	Если Ответ.КодСостояния <> 200 Тогда
		ЗаписатьОшибкуВызоваСервисаВЖурналРегистрации(ОписаниеЗапроса, Ответ.КодСостояния);
		Возврат Неопределено;
	КонецЕсли;
	
	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8");
	
	Возврат ОбщегоНазначения.JSONВЗначение(ТелоОтвета, , Ложь);
	
КонецФункции

Функция ПодготовитьСпискиИзмененийСинхронизируемыхОбъектов(ОписаниеПодключения, НастройкаОтражения) Экспорт
	
	ПроверитьИдентификаторСеанса(ОписаниеПодключения);
	
	КодНастройки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НастройкаОтражения, "Код");
	
	ДанныеЗапроса = Новый Структура;
	ДанныеЗапроса.Вставить("ИдентификаторНастройки", КодНастройки);
	
	ОписаниеЗапроса = НовыйЗапросКСервису(
		"/v1/change-records-snapshots",
		"POST",
		ОбщегоНазначения.ЗначениеВJSON(ДанныеЗапроса));
	ОписаниеЗапроса.Заголовки.Вставить("Content-Type", "application/json");
	
	Ответ = ВыполнитьЗапросКСервису(ОписаниеПодключения, ОписаниеЗапроса);
	
	Если Ответ.КодСостояния <> 200 Тогда
		ЗаписатьОшибкуВызоваСервисаВЖурналРегистрации(ОписаниеЗапроса, Ответ.КодСостояния);
		Возврат Неопределено;
	КонецЕсли;
	
	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8");
	
	Возврат ОбщегоНазначения.JSONВЗначение(ТелоОтвета, , Ложь);
	
КонецФункции

Функция ПолучитьИзмененияСинхронизируемыхОбъектов(ОписаниеПодключения, ИдентификаторСписка) Экспорт
	
	ПроверитьИдентификаторСеанса(ОписаниеПодключения);
	
	ОписаниеЗапроса = НовыйЗапросКСервису(
		СтрШаблон("/v1/change-records-snapshots/%1", ИдентификаторСписка),
		"GET");
	
	Ответ = ВыполнитьЗапросКСервису(ОписаниеПодключения, ОписаниеЗапроса);
	
	Если Ответ.КодСостояния <> 200 Тогда
		ЗаписатьОшибкуВызоваСервисаВЖурналРегистрации(ОписаниеЗапроса, Ответ.КодСостояния);
		Возврат Неопределено;
	КонецЕсли;
	
	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку("UTF-8");
	
	Возврат JSONВТаблицуЗначений(ТелоОтвета);
	
КонецФункции

Функция УдалитьРегистрациюИзмененийСинхронизируемыхОбъектов(ОписаниеПодключения, ИдентификаторСписка) Экспорт
	
