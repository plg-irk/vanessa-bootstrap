Функция УстановитьНастройкиСовместногоИспользования(ОписаниеПодключения, ОписаниеНастройки, СвойстваУзлаОбмена) Экспорт
	
	ПроверитьИдентификаторСеанса(ОписаниеПодключения);
	
	ДанныеЗапроса = Новый Структура;
	ДанныеЗапроса.Вставить("Идентификатор", ОписаниеНастройки.Идентификатор);
	ДанныеЗапроса.Вставить("ДатаНачалаОтражения", ОписаниеНастройки.ДатаНачалаОтражения);
	ДанныеЗапроса.Вставить("ОтражениеВключено", ОписаниеНастройки.ОтражениеВключено);
	
	ДанныеЗапроса.Вставить("Организации", Новый Массив);
	
	ТаблицаИдентификаторы = СовместноеИспользование.ПубличныеИдентификаторыСинхронизируемыхОбъектов(
		ОписаниеНастройки.УзелОбмена, ОписаниеНастройки.Организации);
	Для Каждого СтрокаИдентификаторы Из ТаблицаИдентификаторы Цикл
		ДанныеЗапроса.Организации.Добавить(СтрокаИдентификаторы.Идентификатор);
	КонецЦикла;
	
	ДанныеЗапроса.Вставить("РазделыУчета", ОбщегоНазначения.СкопироватьРекурсивно(ОписаниеНастройки.РазделыУчета));
	
	КодЭтогоУзла = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПланыОбмена.СинхронизацияДанныхЧерезУниверсальныйФормат.ЭтотУзел(), "Код");
	
	ДанныеЗапроса.Вставить("УзелОбмена", Новый Структура);
	ДанныеЗапроса.УзелОбмена.Вставить("Идентификатор", КодЭтогоУзла);
	ДанныеЗапроса.УзелОбмена.Вставить("ДатаНачалаВыгрузкиДокументов", ОписаниеНастройки.ДатаНачалаОтражения);
	
	Для Каждого КлючЗначение Из СвойстваУзлаОбмена Цикл
		ДанныеЗапроса.УзелОбмена.Вставить(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;
	
	ОписаниеЗапроса = НовыйЗапросКСервису(
		СтрШаблон("/v1/application-links/%1", ОписаниеНастройки.Идентификатор),
		"PUT",
		ОбщегоНазначения.ЗначениеВJSON(ДанныеЗапроса));
	ОписаниеЗапроса.Заголовки.Вставить("Content-Type", "application/json");
	
	Ответ = ВыполнитьЗапросКСервису(ОписаниеПодключения, ОписаниеЗапроса);
	
	Если Ответ.КодСостояния <> 200 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

