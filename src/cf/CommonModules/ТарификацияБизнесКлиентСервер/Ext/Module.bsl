#Область СлужебныйПрограммныйИнтерфейс

Функция ИмяСерверногоОповещения() Экспорт
	
	Возврат "Тарификация.Бизнес";
	
КонецФункции

Функция СсылкаНаСайт() Экспорт
	
	Возврат "https://bizkub.ru/home";
	
КонецФункции

// Обычные данные описаны в ТарификацияБизнес.ОписаниеВсехПриложений.
// Здесь возвращаются дополнительные данные.
// 
// Параметры:
//  ИмяПриложения - Строка - имя приложения, см ТарификацияБизнес.ОписаниеВсехПриложений
// 
// Возвращаемое значение:
//  - Неопределено - если приложение не найдено по имени
//  - Структура:
//     * Описание - Строка - строчное описание приложения
//     * Картинка - Картинка - иконка приложения
//     * ИмяКатегории - Строка - идентификатор категории приложения
//     * СсылкаНаСайт - Строка - ссылка на лендинг по приложению
//     * Порядок - Число - порядок расположения приложений друг за другом 
//                         (использовать, если нужно расположить приложения по "порядку")
//
Функция ДополнительныеДанныеПриложения(ИмяПриложения) Экспорт
	
	Результат = НовыеДополнительныеДанныеПриложения();
	
	Если ИмяПриложения = "ПоискИПроверкаКонтрагентов" Тогда
		Описание = НСтр("ru = 'Достоверная информация о компаниях, поиск и анализ клиентов'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеПоискИПроверкаКонтрагентов;
		ИмяКатегории = "Клиенты";
		РасположениеНаСайте = "proverka-kontragentov";
		Порядок = 0;
	ИначеЕсли ИмяПриложения = "ВыставлениеСчетов" Тогда
		Описание = НСтр("ru = 'Выставление счетов с подписью, печатью и отправкой по почте для оплаты'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеВыставлениеСчетов;
		ИмяКатегории = "Клиенты";
		РасположениеНаСайте = "vystavleniye-schetov";
		Порядок = 1;
	ИначеЕсли ИмяПриложения = "CRM" Тогда
		Описание = НСтр("ru = 'Удобное взаимодействие с клиентом и анализ продаж'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеCRM;
		ИмяКатегории = "Клиенты";
		РасположениеНаСайте = "crm";
		Порядок = 2;
	ИначеЕсли ИмяПриложения = "ОптовыеПродажи" Тогда
		Описание = НСтр("ru = 'Продажи оптом со склада и под заказ с контролем от получения до отгрузки'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеОптовыеПродажи;
		ИмяКатегории = "Продажи";
		РасположениеНаСайте = "optovyye-prodazhi";
		Порядок = 3;
	ИначеЕсли ИмяПриложения = "РозничныеПродажи" Тогда
		Описание = НСтр("ru = 'Розничные продажи с торговым оборудованием и надежным ОФД'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеРозничныеПродажи;
		ИмяКатегории = "Продажи";
		РасположениеНаСайте = "roznichnyye-prodazhi";
		Порядок = 4;
	ИначеЕсли ИмяПриложения = "ОнлайнПродажи" Тогда
		Описание = НСтр("ru = 'Продажи онлайн на сайте, в мобильном приложении, на маркетплейсах'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеОнлайнПродажи;
		ИмяКатегории = "Продажи";
		РасположениеНаСайте = "onlayn-prodazhi";
		Порядок = 5;
	ИначеЕсли ИмяПриложения = "Услуги" Тогда
		Описание = НСтр("ru = 'Оказание услуг и выполнение работ по заказам, биллинг и ремонт'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеУслуги;
		ИмяКатегории = "УслугиИПроизводство";
		РасположениеНаСайте = "uslugi";
		Порядок = 6;
	ИначеЕсли ИмяПриложения = "Производство" Тогда
		Описание = НСтр("ru = 'Учет производства по заказам от планирования до выпуска'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеПроизводство;
		ИмяКатегории = "УслугиИПроизводство";
		РасположениеНаСайте = "proizvodstvo";
		Порядок = 7;
	ИначеЕсли ИмяПриложения = "Бухгалтерия" Тогда
		Описание = НСтр("ru = 'Бухгалтерский учет и сдача регламентированной отчетности'");
		Картинка = БиблиотекаКартинок.БизнесПриложениеБухгалтерия;
		ИмяКатегории = "УчетИОтчетность";
		РасположениеНаСайте = "bukhgalteriya";
		Порядок = 8;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Результат.Вставить("Описание", Описание);
	Результат.Вставить("Картинка", Картинка);
	Результат.Вставить("ИмяКатегории", ИмяКатегории);
	Результат.Вставить("СсылкаНаСайт", СтрШаблон("%1?state=%2", СсылкаНаСайт(), РасположениеНаСайте));
	Результат.Вставить("Порядок", Порядок);
	
	Возврат Результат;
	
КонецФункции

// Имена (идентификаторы) категорий
// 
// Возвращаемое значение:
//  Массив из Строка
//
Функция ИменаКатегорий() Экспорт
	
	Результат = Новый Массив;
	
	Результат.Добавить("Клиенты");
	Результат.Добавить("Продажи");
	Результат.Добавить("УслугиИПроизводство");
	
	Возврат Результат;
	
КонецФункции

// Возвращает данные категории бизнес приложений
//
// Параметры:
//  ИмяКатегории - Строка - см ИменаКатегорий
// 
// Возвращаемое значение:
//  - Неопределено - если категория не найдена по имени
//  - Структура:
//     * Имя - Строка - наименование (идентификатор) категории
//     * Синоним - Строка - представление названия категории
//     * Порядок - Число - порядок расположения категорий приложений друг за другом 
//                          (использовать, если нужно расположить категории по "порядку")
//
Функция ДанныеКатегории(ИмяКатегории) Экспорт
	
	Результат = НовыеДанныеКатегории();
	
	Если ИмяКатегории = "Клиенты" Тогда
		Синоним = НСтр("ru = 'Клиенты'");
		Порядок = 0;
	ИначеЕсли ИмяКатегории = "Продажи" Тогда
		Синоним = НСтр("ru = 'Продажи'");
		Порядок = 1;
	ИначеЕсли ИмяКатегории = "УслугиИПроизводство" Тогда
		Синоним = НСтр("ru = 'Услуги и производство'");
		Порядок = 2;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Результат.Вставить("Имя", ИмяКатегории);
	Результат.Вставить("Синоним", Синоним);
	Результат.Вставить("Порядок", Порядок);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыеДополнительныеДанныеПриложения()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Описание", "");
	Результат.Вставить("Картинка", Новый Картинка);
	Результат.Вставить("ИмяКатегории", "");
	Результат.Вставить("СсылкаНаСайт", "");
	Результат.Вставить("Порядок", -1);
	
	Возврат Результат;
	
КонецФункции

Функция НовыеДанныеКатегории()
	
	Результат = Новый Структура;
	
	Результат.Вставить("Имя", "");
	Результат.Вставить("Синоним", "");
	Результат.Вставить("Порядок", -1);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти