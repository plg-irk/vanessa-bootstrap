// Устанавливает видимость элементов доступных остатков по признаку
//
// Параметры:
//  Форма			 - ФормаКлиентскогоПриложения	 - Форма рабочего места кассира.
//  НастройкиФормы	 - Структура					 - Настройки формы.
//
Процедура УстановитьДополнительнуюВидимостьЭлементов(Форма, НастройкиФормы) Экспорт
	
	ЭлементыФормы = Форма.Элементы;
	ОтображатьОстаток = НЕ НастройкиФормы.ВыборПодарочногоСертификата И НастройкиФормы.ОтображатьОстаток;
	ЭлементыФормы.ДополнительныйСписокТоваровДоступно.Видимость = ОтображатьОстаток;
	ЭлементыФормы.ДополнительныйСписокТоваровВРезерве.Видимость = ОтображатьОстаток;
	
КонецПроцедуры

#Область ВыборСкладаИЯчейкиПриПродаже

Процедура ЗафиксироватьВыборСкладаЯчейкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("Структура")
		ИЛИ ТипЗнч(ДополнительныеПараметры) <> Тип("Структура") Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Результат.Значение = КодВозвратаДиалога.Да Тогда
		
		ДополнительныеПараметры.Форма.НеЗадаватьВопросПриВыбореЯчейки = Результат.БольшеНеЗадаватьЭтотВопрос;
		
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("ДанныеСтроки", ДополнительныеПараметры.ДанныеСтроки);
		
		ДополнительныеПараметры.Форма.Закрыть(СтруктураСтроки);
		
	КонецЕсли;
КонецПроцедуры

// Открывает форму выбора Торгового объекта. При завершении событие должно вызывать процедуру
// "ВыборТорговыйОбъектЗавершение" на форме рабочего места кассира.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма рабочего места кассира.
//  СтандартнаяОбработка - Булево - признак стандартной обработки события.
//
Процедура ОткрытьФормуВыбораТорговогоОбъекта(Форма, СтандартнаяОбработка) Экспорт
	СтандартнаяОбработка = Ложь;
	
	ОбработкаОповещения = Новый ОписаниеОповещения("ВыборТорговыйОбъектЗавершение", Форма);
	МассивОтбора = Новый Массив;
	
	МассивОтбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыСтруктурныхЕдиниц.Склад"));
	МассивОтбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыСтруктурныхЕдиниц.Розница"));
	МассивОтбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыСтруктурныхЕдиниц.РозницаСуммовойУчет"));
	
	СтруктураОтбора = Новый Структура("ТипСтруктурнойЕдиницы", МассивОтбора);

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отбор", СтруктураОтбора);
	ПараметрыФормы.Вставить("РежимВыбора", Истина);

	ОткрытьФорму("Справочник.СтруктурныеЕдиницы.ФормаСписка", ПараметрыФормы, Форма,,,,ОбработкаОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры
#КонецОбласти

#КонецОбласти

