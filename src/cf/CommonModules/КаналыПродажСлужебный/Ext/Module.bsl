#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПодписокНаСобытия

Процедура ПриЗаписиУзлаПланаОбмена( Источник, Отказ ) Экспорт
    
	Если Источник.ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;

    Если Отказ = Истина Тогда
    	Возврат;
    КонецЕсли;

	Если Не Источник.ПометкаУдаления Тогда
		Возврат;
	КонецЕсли;
	
	ТипИсточника = ТипЗнч( Источник.Ссылка );
	ТипыПлановОбменаКаналовПродаж = КаналыПродажСлужебныйПовтИсп.ТипыПлановОбменаКаналовПродажПолучить();
	Если ТипыПлановОбменаКаналовПродаж.Найти( ТипИсточника ) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПланыОбмена.УдалитьРегистрациюИзменений( Источник.Ссылка );
	
КонецПроцедуры

Процедура ПередЗаписьюСправочника( Источник, Отказ ) Экспорт

	Если Источник.ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;

    Если Отказ = Истина Тогда
    	Возврат;
    КонецЕсли;

	ОбменДаннымиПолучателиНеактуальныеИсключить( Источник );
	
КонецПроцедуры

Процедура ПередЗаписьюДокумента( Источник, Отказ, РежимЗаписи, РежимПроведения ) Экспорт

	Если Источник.ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;

    Если Отказ = Истина Тогда
    	Возврат;
    КонецЕсли;

	ОбменДаннымиПолучателиНеактуальныеИсключить( Источник );
	
КонецПроцедуры

Процедура ПередЗаписьюРегистра( Источник, Отказ, Замещение ) Экспорт

	Если Источник.ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;

    Если Отказ = Истина Тогда
    	Возврат;
    КонецЕсли;

	ОбменДаннымиПолучателиНеактуальныеИсключить( Источник );
	
КонецПроцедуры

#КонецОбласти

Функция ТипыПлановОбменаКаналовПродажПолучить() Экспорт
	Результат = Новый Массив;

	Результат.Добавить( Тип( "ПланОбменаСсылка.ИнтеграцияСИнтернетМагазиномЗаказы" ) );
	Результат.Добавить( Тип( "ПланОбменаСсылка.ИнтеграцияСИнтернетМагазиномТовары" ) );
	Результат.Добавить( Тип( "ПланОбменаСсылка.ИнтеграцияСИнтернетМагазиномУслуги" ) );
	Результат.Добавить( Тип( "ПланОбменаСсылка.ИнтеграцияСМагазинамиСоцСетей" ) );

	Возврат Результат;
КонецФункции

Функция НеактуальныеУзлыПлановОбменаПолучить() Экспорт
	
	Результат = Новый Соответствие;
	
	ЗапросТекст = 
	"ВЫБРАТЬ
	|	ИнтеграцияСИнтернетМагазиномЗаказы.Ссылка КАК Ссылка
	|ИЗ
	|	ПланОбмена.ИнтеграцияСИнтернетМагазиномЗаказы КАК ИнтеграцияСИнтернетМагазиномЗаказы
	|ГДЕ
	|	ИнтеграцияСИнтернетМагазиномЗаказы.ПометкаУдаления = ИСТИНА
	|	И ИнтеграцияСИнтернетМагазиномЗаказы.ЭтотУзел = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ИнтеграцияСИнтернетМагазиномТовары.Ссылка
	|ИЗ
	|	ПланОбмена.ИнтеграцияСИнтернетМагазиномТовары КАК ИнтеграцияСИнтернетМагазиномТовары
	|ГДЕ
	|	ИнтеграцияСИнтернетМагазиномТовары.ПометкаУдаления = ИСТИНА
	|	И ИнтеграцияСИнтернетМагазиномТовары.ЭтотУзел = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ИнтеграцияСИнтернетМагазиномУслуги.Ссылка
	|ИЗ
	|	ПланОбмена.ИнтеграцияСИнтернетМагазиномУслуги КАК ИнтеграцияСИнтернетМагазиномУслуги
	|ГДЕ
	|	ИнтеграцияСИнтернетМагазиномУслуги.ПометкаУдаления = ИСТИНА
	|	И ИнтеграцияСИнтернетМагазиномУслуги.ЭтотУзел = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ИнтеграцияСМагазинамиСоцСетей.Ссылка
	|ИЗ
	|	ПланОбмена.ИнтеграцияСМагазинамиСоцСетей КАК ИнтеграцияСМагазинамиСоцСетей
	|ГДЕ
	|	ИнтеграцияСМагазинамиСоцСетей.ПометкаУдаления = ИСТИНА
	|	И ИнтеграцияСМагазинамиСоцСетей.ЭтотУзел = ЛОЖЬ";
	
	ЗапросОбъект = Новый Запрос( ЗапросТекст );
	ЗапросРезультат = ЗапросОбъект.Выполнить();
	Если ЗапросРезультат.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЗапросВыборка = ЗапросРезультат.Выбрать();
	Пока ЗапросВыборка.Следующий() Цикл
		Результат.Вставить( ЗапросВыборка.Ссылка, Истина );
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ТипыОбъектовКаналовПродажДляРегистрацииИзмененийПолучить() Экспорт
	
	Результат = Новый Соответствие;
	
	Результат.Вставить( Тип( "СправочникОбъект.Номенклатура" ), Истина );
	Результат.Вставить( Тип( "СправочникОбъект.НоменклатураПоставщиков" ), Истина );
	Результат.Вставить( Тип( "СправочникОбъект.НоменклатураПрисоединенныеФайлы" ), Истина );
	Результат.Вставить( Тип( "СправочникОбъект.ХарактеристикиНоменклатуры" ), Истина );
	Результат.Вставить( Тип( "СправочникОбъект.ХарактеристикиНоменклатурыПрисоединенныеФайлы" ), Истина );
	
	Результат.Вставить( Тип( "СправочникОбъект.ВиртуальныеКаталогиТоваровМагазиновСоцСетей" ), Истина );
	
	Результат.Вставить( Тип( "СправочникОбъект.КлючевыеРесурсы" ), Истина );
	Результат.Вставить( Тип( "СправочникОбъект.КлючевыеРесурсыПрисоединенныеФайлы" ), Истина );

	Результат.Вставить( Тип( "ДокументОбъект.ЗаказПокупателя" ), Истина );
	
	Результат.Вставить( Тип( "РегистрСведенийНаборЗаписей.ОстаткиТоваров" ), Истина );
	Результат.Вставить( Тип( "РегистрСведенийНаборЗаписей.ОстаткиТоваровПоставщиков" ), Истина );
	Результат.Вставить( Тип( "РегистрСведенийНаборЗаписей.ЦеныНоменклатуры" ), Истина );
	
	Результат.Вставить( Тип( "РегистрСведенийНаборЗаписей.НоменклатураХарактеристикДляМагазинаСоцСетей" ), Истина );
	Результат.Вставить( Тип( "РегистрСведенийНаборЗаписей.НоменклатураХарактеристикДляМагазинаСоцСетейВиртуальныеКаталоги" ), Истина );
	
	Результат.Вставить( Тип( "РегистрСведенийНаборЗаписей.ГрафикиРаботыРесурсов" ), Истина );
	Результат.Вставить( Тип( "РегистрСведенийНаборЗаписей.ОтклоненияОтГрафиковРаботыРесурсов" ), Истина );
	
	Результат.Вставить( Тип( "РегистрНакопленияНаборЗаписей.ЗаказыПокупателей" ), Истина );
	Результат.Вставить( Тип( "РегистрНакопленияНаборЗаписей.ОплатаСчетовИЗаказов" ), Истина );
	
	Возврат Результат;
КонецФункции

Процедура ОбменДаннымиПолучателиНеактуальныеИсключить( Источник ) Экспорт
	
	УстановитьПривилегированныйРежим( Истина );

	Попытка

		ИсточникОбменДанными = ОбменСВнешнимиСистемамиЛогирование.ПолучитьЗначениеПоля( Источник, "ОбменДанными", Неопределено );
		Если ИсточникОбменДанными = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Если ТипЗнч( ИсточникОбменДанными ) <> Тип( "ПараметрыОбменаДанными" ) Тогда
			Возврат;
		КонецЕсли;

		ТипИсточника = ТипЗнч( Источник );
		ТипыОбъектовКаналовПродажДляРегистрацииИзменений = КаналыПродажСлужебныйПовтИсп.ТипыОбъектовКаналовПродажДляРегистрацииИзмененийПолучить();
		Если ТипыОбъектовКаналовПродажДляРегистрацииИзменений.Получить( ТипИсточника ) <> Истина Тогда
			Возврат;
		КонецЕсли;
		
		НеактуальныеУзлыПлановОбмена = КаналыПродажСлужебныйПовтИсп.НеактуальныеУзлыПлановОбменаПолучить();
		Для Каждого ПолучательЭлемент Из НеактуальныеУзлыПлановОбмена Цикл
			
			Получатель = ПолучательЭлемент.Ключ;
			
			Если ИсточникОбменДанными.Получатели.Содержит( Получатель ) = Истина Тогда
				ИсточникОбменДанными.Получатели.Удалить( Получатель );
			КонецЕсли;
			
		КонецЦикла;
		
	Исключение
	
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки( ИнформацияОбОшибке() );
		Комментарий = НСтр( "ru = 'Ошибка при исключении из получателей неактуальных узлов обмена'" )
		+ ": " + Источник + ": " + ТекстОшибки;
		ЗаписьЖурналаРегистрации( "Обмен данными", УровеньЖурналаРегистрации.Ошибка, , , Комментарий );
		
	КонецПопытки;
	УстановитьПривилегированныйРежим( Ложь );
	
КонецПроцедуры

Процедура УзлыОбменаНеактуальныеОчиститьРегистрациюИзменений() Экспорт
    
    ИмяСобытияЖурнала = НСТр( "ru = 'Обмен данными'" );
	СообщениеТекст = НСтр( "ru = 'Начало: Удаление регистрации изменений для помеченных на удаление узлов каналов продаж'" );
	ЗаписьЖурналаРегистрации( ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Информация, , , СообщениеТекст );
	
	УстановитьПривилегированныйРежим( Истина );
	
	НеактуальныеУзлыПлановОбмена = НеактуальныеУзлыПлановОбменаПолучить();
	СсылкиКоличество = НеактуальныеУзлыПлановОбмена.Количество();
	Если СсылкиКоличество = 0 Тогда
		СообщениеТекст = НСтр( "ru = 'Окончание: Удаление регистрации изменений для помеченных на удаление узлов каналов продаж'" );
		ЗаписьЖурналаРегистрации( ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Информация, , , СообщениеТекст );
	
		Возврат;
	КонецЕсли;
	
	НомерПП = 0;
	Для Каждого УзелЭлемент Из НеактуальныеУзлыПлановОбмена Цикл
		
		НомерПП = НомерПП + 1;
		
		Узел = УзелЭлемент.Ключ;
		
		СообщениеШаблон = НСтр( "ru = '%1 -> %2) Узел <%3>. Начало: %4'" );
		СообщениеТекст = СтрШаблон( СообщениеШаблон, НомерПП, СсылкиКоличество, Узел, ТекущаяДатаСеанса() );
		ОбщегоНазначения.СообщитьПользователю( СообщениеТекст );
		ЗаписьЖурналаРегистрации( ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Информация, , Узел, СообщениеТекст );
		
		Время1 = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		ПланыОбмена.УдалитьРегистрациюИзменений( Узел );
		
		Время2 = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ДлительностьС = (Время2 - Время1)/1000;
		
		СообщениеШаблон = НСтр( "ru = 'Регистрация изменений очищена: <%1>. Окончание: %2. Длительность, с: %3'" );
		СообщениеТекст = СтрШаблон( СообщениеШаблон, Узел, ТекущаяДатаСеанса(), ДлительностьС );
		ОбщегоНазначения.СообщитьПользователю( СообщениеТекст );
		ЗаписьЖурналаРегистрации( ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Информация, , Узел, СообщениеТекст );
		
	КонецЦикла;
	
	УстановитьПривилегированныйРежим( Ложь );

	СообщениеТекст = НСтр( "ru = 'Окончание: Удаление регистрации изменений для помеченных на удаление узлов каналов продаж'" );
	ЗаписьЖурналаРегистрации( ИмяСобытияЖурнала, УровеньЖурналаРегистрации.Информация, , , СообщениеТекст );
	
КонецПроцедуры

