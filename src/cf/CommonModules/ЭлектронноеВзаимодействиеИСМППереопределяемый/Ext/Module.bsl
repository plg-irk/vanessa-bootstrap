//При записи документа ЭДО может измениться статус оформления документа, по которому происходит электронный документооборот:
//   * Для прямого обмена с ИС МП (документ "Отгрузка товаров") указание кодов маркировки требуется или в ЭДО, или в отгрузке.
//   * Подразумевается, что документ ЭДО не может изменить свой документ-основание (API ЭДО v1).
//
// Параметры:
//  ЭлектронныйДокументИсходящийОбъект - ДокументОбъект.ЭлектронныйДокументИсходящий - записываемый документ.
//  ДокументыТребующиеПересчета - Массив Из см. РасчетСтатусовОформленияИСМП.РассчитатьСтатусыОформленияДокументов - 
//   документы, связанные с записываемым электронным, для которых требуется пересчитать статус оформления.
//
Процедура ТребуетсяПересчетСтатусовОформления(ЭлектронныйДокументИсходящийОбъект, ДокументыТребующиеПересчета) Экспорт
	
	Попытка
		ИнтеграцияИСМПУНФ.ТребуетсяПересчетСтатусовОформления(ЭлектронныйДокументИсходящийОбъект, ДокументыТребующиеПересчета);
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

//Предназачена для модификации текста запроса по расчету неоформленных документов ЭДО.
//   Сценарий использования: заменить текст запроса на требуемый (требующие оформления
//   с помощью ЭДО документы продажи с маркируемой продукцией).
//
//Параметры:
//  ТекстЗапроса - Строка - Текст запроса
//
Процедура ПриПолученииТекстаЗапросаНеоформленныхДокументовЭДО(ТекстЗапроса) Экспорт
	
	ИнтеграцияИСМПУНФ.ПриПолученииТекстаЗапросаНеоформленныхДокументовЭДО(ТекстЗапроса);
	
КонецПроцедуры

// Переопределяет параметры открытия панели электронного документооборота.
//
// Параметры:
//  ПараметрыОткрытияОбработкиЭДО - Структура - Параметры открытия формы
//
Процедура ДополнитьПараметрыОткрытияПанелиЭДОИзИСМП(ПараметрыОткрытияОбработкиЭДО) Экспорт
	
	ПараметрыОткрытияОбработкиЭДО.Вставить("ОтборВходящихДокументов", Новый Массив);
	ПараметрыОткрытияОбработкиЭДО.Вставить("ОтборИсходящихДокументов", Новый Массив);
	ПараметрыОткрытияОбработкиЭДО.ОтборВходящихДокументов.Добавить(Новый Структура("Поле,ВидСравнения,Значение",
		"ЭлектронныйДокумент.СодержитМаркируемыеТовары", ВидСравненияКомпоновкиДанных.Равно, Истина));
	ПараметрыОткрытияОбработкиЭДО.ОтборИсходящихДокументов.Добавить(Новый Структура("Поле,ВидСравнения,Значение",
		"ЭлектронныйДокумент.СодержитМаркируемыеТовары", ВидСравненияКомпоновкиДанных.Равно, Истина));
	
КонецПроцедуры

// Дополнить сведения об адресах участников обмена 5_02.
// 
// Параметры:
//  СтруктураДанных              - Структура - произвольная структура данных для формирования электронного документа.
//  Источник                     - ДокументСсылка - ссылка на прикладной документ
//  СтруктураАдресов             - см. ЭлектронноеВзаимодействиеИСМП.СтруктураАдресовУчастниковОбмена
//  Отказ                        - Булево - Истина, если в процессе заполнения были обнаружены ошибки
//  ВыводитьСообщение            - Булево - Истина, если нужно выводить сообщение пользователю.
//
Процедура ЗаполнитьСведенияОбАдресахУчастниковОбмена_5_02(СтруктураДанных, Источник, СтруктураАдресов, Отказ, ВыводитьСообщение = Истина) Экспорт
	
	ВидыКИПоТипамВладельцев = Новый Соответствие;
	ВидыКИПоТипамВладельцев.Вставить(Тип("СправочникСсылка.Организации"), Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации);
	ВидыКИПоТипамВладельцев.Вставить(Тип("СправочникСсылка.Контрагенты"), Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента);
	ВидыКИПоТипамВладельцев.Вставить(Тип("СправочникСсылка.СтруктурныеЕдиницы"), Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);
	
	ОбъектПокупатель = Неопределено;
	ОбъектПродавец   = Неопределено;
	
	ТипИсточника = ТипЗнч(Источник);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтруктураДанных, "РеквизитыШапки") Тогда
		
		ДанныеДляФормированияЭД = СтруктураДанных;
		ДанныеШапки = СтруктураДанных.РеквизитыШапки;
		
		ДокументРеализации = Неопределено;
		Если ТипЗнч(ДанныеДляФормированияЭД.ДокументыОснования) = Тип("Массив") Тогда
			Для Каждого Документ Из ДанныеДляФормированияЭД.ДокументыОснования Цикл
				ТипДокумента = ТипЗнч(Документ);
				Если ТипДокумента = Тип("ДокументСсылка.РасходнаяНакладная")
					Или ТипДокумента = Тип("ДокументСсылка.КорректировкаРеализации")
					Или ТипДокумента = Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями") Тогда
					
					ДокументРеализации = Документ;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДокументРеализации) Тогда
			Возврат;
		КонецЕсли;
		
		СтруктураАдресов.Продавец.УчастникОбмена   = ДанныеШапки.Поставщик;
		СтруктураАдресов.Покупатель.УчастникОбмена = ДанныеШапки.Покупатель;
		
		Если ЗначениеЗаполнено(ДанныеШапки.Грузополучатель)
			И Не ВидыКИПоТипамВладельцев.Получить(ТипЗнч(ДанныеШапки.Грузополучатель)) = Неопределено Тогда
			ОбъектПокупатель                                              = ДанныеШапки.Грузополучатель;
			СтруктураАдресов.Покупатель.УполномоченноеЛицоЗаПоставкуГруза = ОбъектПокупатель;
		Иначе
			ОбъектПокупатель = ДанныеШапки.Покупатель;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеШапки.Грузоотправитель)
			И Не ВидыКИПоТипамВладельцев.Получить(ТипЗнч(ДанныеШапки.Грузоотправитель)) = Неопределено Тогда
			ОбъектПродавец                                              = ДанныеШапки.Грузоотправитель;
			СтруктураАдресов.Продавец.УполномоченноеЛицоЗаПоставкуГруза = ОбъектПродавец;
		Иначе
			ОбъектПродавец = ДанныеШапки.Поставщик;
		КонецЕсли;
		
		ДанныеДокументаРеализации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументРеализации, "СтруктурнаяЕдиница, АдресДоставки, АдресДоставкиЗначение, АдресДоставкиЗначенияПолей");
		Если ЗначениеЗаполнено(ДанныеДокументаРеализации.АдресДоставкиЗначенияПолей) Тогда
			
			СтруктураАдресов.Покупатель.АвтоматическоеЗаполнение = Ложь;
			СтруктураАдресов.Покупатель.АдресСтрокой             = ДанныеДокументаРеализации.АдресДоставки;
			СтруктураАдресов.Покупатель.АдресЗначенияПолей       = ДанныеДокументаРеализации.АдресДоставкиЗначенияПолей;
			
		ИначеЕсли ЗначениеЗаполнено(ДанныеДокументаРеализации.АдресДоставкиЗначение) Тогда
			
			СтруктураАдресов.Покупатель.АвтоматическоеЗаполнение = Ложь;
			СтруктураАдресов.Покупатель.АдресСтрокой             = ДанныеДокументаРеализации.АдресДоставки;
			СтруктураАдресов.Покупатель.АдресЗначениеJSON        = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияВJSON(ДанныеДокументаРеализации.АдресДоставкиЗначение);
			
		Иначе
			
			СтруктураАдресов.Покупатель.АвтоматическоеЗаполнение     = Истина;
			СтруктураАдресов.Покупатель.ВладелецКонтактнойИнформации = ОбъектПокупатель;
			СтруктураАдресов.Покупатель.ВидКонтактнойИнформации      = ВидыКИПоТипамВладельцев.Получить(ТипЗнч(ОбъектПокупатель));
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеДокументаРеализации.СтруктурнаяЕдиница)
			И Не ВидыКИПоТипамВладельцев.Получить(ТипЗнч(ДанныеДокументаРеализации.СтруктурнаяЕдиница)) = Неопределено Тогда
			
			СтруктураАдресов.Продавец.АвтоматическоеЗаполнение = Истина;
			СтруктураАдресов.Продавец.ВладелецКонтактнойИнформации = ДанныеДокументаРеализации.СтруктурнаяЕдиница;
			СтруктураАдресов.Продавец.ВидКонтактнойИнформации      = ВидыКИПоТипамВладельцев.Получить(ТипЗнч(ДанныеДокументаРеализации.СтруктурнаяЕдиница));
			
		Иначе
			
			СтруктураАдресов.Продавец.АвтоматическоеЗаполнение     = Истина;
			СтруктураАдресов.Продавец.ВладелецКонтактнойИнформации = ОбъектПродавец;
			СтруктураАдресов.Продавец.ВидКонтактнойИнформации      = ВидыКИПоТипамВладельцев.Получить(ТипЗнч(ОбъектПродавец));
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Добавить сведения о перевозочных документах в формате УПД 5_02.
// 
// Параметры:
//  СтруктураДанных              - Структура - произвольная структура данных для формирования электронного документа.
//  Источник                     - ДокументСсылка - ссылка на прикладной документ
//  ДанныеПеревозочныхДокументов - см. ЭлектронноеВзаимодействиеИСМП.СтруктураДанныхПоПеревозочнымДокументам
Процедура ДобавитьСведенияОПеревозочныхДокументах_5_02(СтруктураДанных, Источник, ДанныеПеревозочныхДокументов) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтруктураДанных, "РеквизитыШапки") Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеДляФормированияЭД = СтруктураДанных;
	ДанныеШапки = СтруктураДанных.РеквизитыШапки;
	
	ДокументРеализации = Неопределено;
	Если ТипЗнч(ДанныеДляФормированияЭД.ДокументыОснования) = Тип("Массив") Тогда
		Для Каждого Документ Из ДанныеДляФормированияЭД.ДокументыОснования Цикл
			ТипДокумента = ТипЗнч(Документ);
			Если ТипДокумента = Тип("ДокументСсылка.РасходнаяНакладная")
				Или ТипДокумента = Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями") Тогда
				
				ДокументРеализации = Документ;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДокументРеализации) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументРеализации", ДокументРеализации);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасходнаяНакладная.Дата КАК Дата,
	|	РасходнаяНакладная.Номер КАК Номер,
	|	РасходнаяНакладная.Ссылка КАК Ссылка,
	|	РасходнаяНакладная.Автомобиль КАК Автомобиль
	|ПОМЕСТИТЬ втДокументРеализации
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Ссылка = &ДокументРеализации
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПередачаТоваровМеждуОрганизациями.Дата,
	|	ПередачаТоваровМеждуОрганизациями.Номер,
	|	ПередачаТоваровМеждуОрганизациями.Ссылка,
	|	ПередачаТоваровМеждуОрганизациями.Автомобиль
	|ИЗ
	|	Документ.ПередачаТоваровМеждуОрганизациями КАК ПередачаТоваровМеждуОрганизациями
	|ГДЕ
	|	ПередачаТоваровМеждуОрганизациями.Ссылка = &ДокументРеализации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДокументРеализации.Дата КАК Дата,
	|	втДокументРеализации.Номер КАК Номер,
	|	втДокументРеализации.Ссылка КАК Ссылка,
	|	втДокументРеализации.Автомобиль КАК Автомобиль,
	|	ТТНИсходящаяЕГАИС.НомерТТН КАК НомерТранспортногоДокумента,
	|	ТТНИсходящаяЕГАИС.ДатаТТН КАК ДатаТранспортногоДокумента,
	|	ТранспортныеСредства.Код КАК РегНомерТС
	|ИЗ
	|	втДокументРеализации КАК втДокументРеализации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ТТНИсходящаяЕГАИС КАК ТТНИсходящаяЕГАИС
	|		ПО втДокументРеализации.Ссылка = ТТНИсходящаяЕГАИС.ДокументОснование
	|			И (ТТНИсходящаяЕГАИС.Проведен)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТранспортныеСредства КАК ТранспортныеСредства
	|		ПО втДокументРеализации.Автомобиль = ТранспортныеСредства.Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	ЗаполнитьЗначенияСвойств(ДанныеПеревозочныхДокументов, Выборка);
	
	Если Не ЗначениеЗаполнено(ДанныеПеревозочныхДокументов.НомерТранспортногоДокумента) Тогда
		
		ДанныеПеревозочныхДокументов.НомерТранспортногоДокумента = ПрефиксацияОбъектовКлиентСервер.УдалитьПрефиксыИзНомераОбъекта(Выборка.Номер, Истина, Истина);
		ДанныеПеревозочныхДокументов.ДатаТранспортногоДокумента  = Выборка.Дата;
		
		Запрос = Новый Запрос;
		Запрос.Текст = Обработки.ЭлектронныеПеревозочныеДокументы.ЗапросПоДокументуОснования();
		
		Обработки.ЭлектронныеПеревозочныеДокументы.ЗаполнитьОбязательныеПараметрыЗапроса(Запрос.Параметры);
		
		Запрос.УстановитьПараметр("ДокументОснование", ДокументРеализации);
		Запрос.УстановитьПараметр("НачалоПериода",     Дата(1, 1, 1));
		Запрос.УстановитьПараметр("КонецПериода",      Дата(1, 1, 1));
		
		УстановитьПривилегированныйРежим(Истина);
		ВыборкаЭПД = Запрос.Выполнить().Выбрать();
		УстановитьПривилегированныйРежим(Ложь);
		
		Если ВыборкаЭПД.Следующий() Тогда
			
			ДанныеПеревозочныхДокументов.ИдентификаторЭПД = ВыборкаЭПД.НомерЭПД;
			
			ДанныеФормирования                      = ОбменСГИСЭПД.ДанныеРеквизитовЭПД(ВыборкаЭПД.Ссылка);
			ДанныеПеревозочныхДокументов.РегНомерТС = ДанныеФормирования.ТитулГрузоотправителяТранспортноеСредствоРегистрационныйНомер;
			
			РеквизитыДокументаЭПД = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВыборкаЭПД.Ссылка, "УИДМинтранс, ТитулГрузоотправителяИдентификаторФайла");
			
			Если ЗначениеЗаполнено(РеквизитыДокументаЭПД.УИДМинтранс) Тогда
				ИдентификаторДокумента = РеквизитыДокументаЭПД.УИДМинтранс;
			Иначе
				ИдентификаторДокумента = РеквизитыДокументаЭПД.ТитулГрузоотправителяИдентификаторФайла;
			КонецЕсли;
			
			ДанныеПеревозочныхДокументов.ИдентификаторЭПД = ИдентификаторДокумента;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Заполнить данные по отправителю и получателю при перемещении между МОД в формате УПД 5_02.
// 
// Параметры:
//  СтруктураДанных - см. Документы.ПеремещениеМеждуМОДИСМП.СтруктураДанныхЮрФизЛица
//  Источник - ОпределяемыйТип.УчастникПеремещенияМеждуМОД
//  ДатаСведений - Дата - дата получения данных
//  ДополнительныеПараметры - Структура - произвольные данные для уточнения данных по отправителю/получателю.
Процедура ЗаполнитьДанныеУчастниковПеремещенияМеждуМОД_5_02(СтруктураДанных, Источник, ДатаСведений = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Организация = Неопределено;
	Если ТипЗнч(Источник) = Тип("СправочникСсылка.СтруктурныеЕдиницы") Тогда
		ДанныеСтруктурнойЕдиницы = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Источник, "Организация, КПП");
		Организация = ДанныеСтруктурнойЕдиницы.Организация;
		СтруктураДанных.КПП = ДанныеСтруктурнойЕдиницы.КПП;
	ИначеЕсли ТипЗнч(Источник) = Тип("СправочникСсылка.Организации") Тогда
		Организация = Источник;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Организации.ЮридическоеФизическоеЛицо КАК ЮридическоеФизическоеЛицо,
	|	Организации.Наименование КАК Наименование,
	|	Организации.НаименованиеПолное КАК НаименованиеПолное,
	|	Организации.ИНН КАК ИНН,
	|	Организации.КПП КАК КПП,
	|	Организации.КодПоОКПО КАК КодПоОКПО,
	|	Организации.НаименованиеСокращенное КАК НаименованиеСокращенное,
	|	Организации.ОГРН КАК ОГРН,
	|	Организации.СвидетельствоСерияНомер КАК СвидетельствоСерияНомер,
	|	Организации.СвидетельствоДатаВыдачи КАК СвидетельствоДатаВыдачи,
	|	ФИОФизическихЛицСрезПоследних.Фамилия КАК Фамилия,
	|	ФИОФизическихЛицСрезПоследних.Имя КАК Имя,
	|	ФИОФизическихЛицСрезПоследних.Отчество КАК Отчество
	|ИЗ
	|	Справочник.Организации КАК Организации
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизическихЛиц.СрезПоследних КАК ФИОФизическихЛицСрезПоследних
	|		ПО Организации.ФизическоеЛицо = ФИОФизическихЛицСрезПоследних.ФизическоеЛицо
	|ГДЕ
	|	Организации.Ссылка = &Организация";
	
	ЗначенияРеквизитов = Запрос.Выполнить().Выбрать();
	ЗначенияРеквизитов.Следующий();
	
	ЗаполнитьЗначенияСвойств(СтруктураДанных, ЗначенияРеквизитов,, "КПП");
	Если Не ЗначениеЗаполнено(СтруктураДанных.КПП) Тогда
		СтруктураДанных.КПП = ЗначенияРеквизитов.КПП;
	КонецЕсли;
	
	СтруктураДанных.ПолноеНаименование      = ЗначенияРеквизитов.НаименованиеПолное;
	СтруктураДанных.СокращенноеНаименование = ЗначенияРеквизитов.НаименованиеСокращенное;
	
КонецПроцедуры

// Процедура осуществляет заполнение переопределяемых данных для формирования электронного документа
//  по документу Перемещение между МОД ИСМП. Осуществляется запись СтруктураДанных данными из номенклатуры.
//
// Параметры:
//  СтруктураДанных - Соответствие из КлючИЗначение:
//  	* Ключ - Число - идентификатор строки из таблицы ТаблицаДляПолученияДанных. Является уникальным идентификатором для
//  		определения полученных данных
//  	* Значение - см. ЭлектронноеВзаимодействиеИСМП.СтруктураДанныхПоНоменклатуреДляФормированияЭД
//  ТаблицаДляПолученияДанных - см. ЭлектронноеВзаимодействиеИСМП.ТаблицаДляПолученияДанныхДляФормированияЭлектронногоДокумента
//  Документ                  - ДокументСсылка.ПеремещениеМеждуМОДИСМП - ссылка на документ.
Процедура ПриПолученииДанныхПоНоменклатуреДляФормированияЭлектронногоДокументаПоПеремещениюМеждуМОДИСМП(СтруктураДанных, ТаблицаДляПолученияДанных, Документ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТаблицаДанных.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|	ТаблицаДанных.Номенклатура        КАК Номенклатура,
		|	ТаблицаДанных.Характеристика      КАК Характеристика,
		|	ТаблицаДанных.Упаковка            КАК Упаковка
		|ПОМЕСТИТЬ ВТ_ТаблицаДляПолученияДанных
		|ИЗ
		|	&ТаблицаДанных КАК ТаблицаДанных
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТаблицаДляПолученияДанных.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|	ВТ_ТаблицаДляПолученияДанных.Номенклатура        КАК Номенклатура,
		|	ВТ_ТаблицаДляПолученияДанных.Характеристика      КАК Характеристика,
		|	ВТ_ТаблицаДляПолученияДанных.Упаковка            КАК Упаковка,
		|	СписокНоменклатура.ЕдиницаИзмерения              КАК ЕдиницаИзмеренияНоменклатуры,
		|	СписокНоменклатура.НаименованиеПолное            КАК НоменклатураНаименованиеПолное,
		|	СписокНоменклатура.Код                           КАК НоменклатураКод
		|ПОМЕСТИТЬ ВТ_ДанныеПоНоменклатуре
		|ИЗ
		|	ВТ_ТаблицаДляПолученияДанных КАК ВТ_ТаблицаДляПолученияДанных
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СписокНоменклатура
		|		ПО СписокНоменклатура.Ссылка = ВТ_ТаблицаДляПолученияДанных.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ИтоговаяТаблица.ИдентификаторСтроки            КАК ИдентификаторСтроки,
		|	ВТ_ИтоговаяТаблица.Номенклатура                   КАК Номенклатура,
		|	ВТ_ИтоговаяТаблица.НоменклатураНаименованиеПолное КАК НоменклатураНаименованиеПолное,
		|	ВТ_ИтоговаяТаблица.НоменклатураКод                КАК НоменклатураКод,
		|	ВТ_ИтоговаяТаблица.ЕдиницаИзмеренияНоменклатуры   КАК ЕдиницаИзмерения,
		|	СписокЕдиницыИзмерения.Наименование               КАК ЕдиницаИзмеренияНаименование,
		|	СписокЕдиницыИзмерения.Код                        КАК ЕдиницаИзмеренияКод,
		|	ВТ_ИтоговаяТаблица.Упаковка                       КАК Упаковка,
		|	СписокУпаковки.Наименование                       КАК УпаковкаНаименование,
		|	СписокУпаковки.ЕдиницаИзмеренияПоКлассификатору.Код КАК УпаковкаКод
		|ИЗ
		|	ВТ_ДанныеПоНоменклатуре КАК ВТ_ИтоговаяТаблица
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК СписокУпаковки
		|		ПО ВТ_ИтоговаяТаблица.Упаковка = СписокУпаковки.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторЕдиницИзмерения КАК СписокЕдиницыИзмерения
		|		ПО ВТ_ИтоговаяТаблица.ЕдиницаИзмеренияНоменклатуры = СписокЕдиницыИзмерения.Ссылка";
	
	Запрос.УстановитьПараметр("ТаблицаДанных", ТаблицаДляПолученияДанных);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтруктураДанныхПоНоменклатуре = ЭлектронноеВзаимодействиеИСМП.СтруктураДанныхПоНоменклатуреДляФормированияЭД();
		
		СтруктураДанныхПоНоменклатуре.НалоговаяСтавка                = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
		СтруктураДанныхПоНоменклатуре.НоменклатураКод                = ВыборкаДетальныеЗаписи.НоменклатураКод;
		СтруктураДанныхПоНоменклатуре.НоменклатураНаименованиеПолное = ВыборкаДетальныеЗаписи.НоменклатураНаименованиеПолное;
		
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Упаковка) Тогда
			
			СтруктураДанныхПоНоменклатуре.ЕдиницаИзмерения               = ВыборкаДетальныеЗаписи.Упаковка;
			СтруктураДанныхПоНоменклатуре.ЕдиницаИзмеренияКод            = ?(ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.УпаковкаКод), ВыборкаДетальныеЗаписи.УпаковкаКод, "0000");
			СтруктураДанныхПоНоменклатуре.ЕдиницаИзмеренияНаименование   = ВыборкаДетальныеЗаписи.УпаковкаНаименование;
			
		Иначе
			
			СтруктураДанныхПоНоменклатуре.ЕдиницаИзмерения               = ВыборкаДетальныеЗаписи.ЕдиницаИзмерения;
			СтруктураДанныхПоНоменклатуре.ЕдиницаИзмеренияКод            = ВыборкаДетальныеЗаписи.ЕдиницаИзмеренияКод;
			СтруктураДанныхПоНоменклатуре.ЕдиницаИзмеренияНаименование   = ВыборкаДетальныеЗаписи.ЕдиницаИзмеренияНаименование;
			
		КонецЕсли;
		
		СтруктураДанных.Вставить(ВыборкаДетальныеЗаписи.ИдентификаторСтроки, СтруктураДанныхПоНоменклатуре);
		
	КонецЦикла;
	
КонецПроцедуры

// Процедура осуществляет проверку на заполнение акцизных марок при формировании ЭД.
// 
// Параметры:
//  Источник                  - ДокументСсылка - ссылка на документ
//  Отказ                     - Булево - Истина, если проверка на заполнение акцизных марок не пройдена
//  ВыдаватьСообщенияОбОшибке - Булево - Выдавать сообщения об ошибке
//  СтандартнаяОбработка      - Булево - признак стандартной обработки.
Процедура ПроверитьЗаполнениеЭлектронногоДокументаНаАкцизныеМарки(Источник, Отказ, ВыдаватьСообщенияОбОшибке = Истина, СтандартнаяОбработка = Истина) Экспорт
	
	Возврат;
	
КонецПроцедуры

#Область УстаревшиеПроцедурыИФункции

// Устарела. При необходимости перед формированием документа ЭДО выполняет проверку соответствия маркируемой продукции и
// товарной части документа.
//
// Параметры:
//  Ссылка - ДокументСсылка - проверяемый документ
//  Отказ  - Булево - флаг отказа от дальнейших действий
Процедура ПроверитьМаркируемуюПродукциюДокумента(Ссылка, Отказ) Экспорт
	
	Если Не ИнтеграцияМОТПУНФ.ПроверитьМаркируемуюПродукциюДокумента(Ссылка) Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

// Процедуры и функции для работы с другими версиями БЭД
//
#Область СлужебныйПрограммныйИнтерфейс

// Для встраивания УПП
// Предназначена для формирования конструктора параметров обработки ошибок
//
// Параметры:
//  ПараметрыОбработкиОшибки - см. ОбщегоНазначенияБЭДКлиентСервер.НовыеПараметрыОшибки
//  СтандартнаяОбработка     - Булево - признак стандартной обработки (установить Ложь для переопределенных)
//  КлючДанных			     - ЛюбаяСсылка - ключ данных для обработки через сообщение пользователю (см. СообщениеПользователю).
//  ПутьКДанным			     - Строка - путь к данным для обработки через сообщение пользователю (см. СообщениеПользователю).
