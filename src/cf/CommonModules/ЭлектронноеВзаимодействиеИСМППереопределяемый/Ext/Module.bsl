#Область ПрограммныйИнтерфейс

// (См. ЭлектронноеВзаимодействиеИСМП.ЗаполнитьСведенияОМаркировке)
// Переопределяет заполнение сведений о маркировке. Установить СтандартнаяОбработка=Ложь для переопределенных вызовов.
Процедура ЗаполнитьСведенияОМаркировке(Приемник, Источник, ДанныеШтрихкодовУпаковок, СтандартнаяОбработка) Экспорт
	
	Если ТипЗнч(ДанныеШтрихкодовУпаковок) = Тип("ТаблицаЗначений")
		И ДанныеШтрихкодовУпаковок.Количество() > 0 Тогда
		
		Если ДанныеШтрихкодовУпаковок.Колонки.Найти("Ссылка") <> Неопределено Тогда
			ЕстьЧекККМ = УправлениеНебольшойФирмойЭлектронныеДокументыСервер.ЕстьЧекККМ(ДанныеШтрихкодовУпаковок[0].Ссылка);
			Если ЕстьЧекККМ = Истина Тогда // маркировки переданы в ЧЗ чеком (исключаются из УПД)
				ДанныеШтрихкодовУпаковок.Очистить();
				СтандартнаяОбработка = Ложь;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

