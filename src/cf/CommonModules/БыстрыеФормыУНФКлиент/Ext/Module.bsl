Процедура ОткрытьБыструюФормуПодписи(Элемент, ВыбранноеЗначение, СтандартнаяОбработка) Экспорт
	
	ПараметрыСоздания = Новый Структура;
	ПараметрыСоздания.Вставить("БыстроеСоздание", Истина);
	ПараметрыСоздания.Вставить("РежимВыбора", Истина);
	ПараметрыСоздания.Вставить("Наименование", СокрЛП(ВыбранноеЗначение.Наименование));
	
	ОткрытьФорму("Справочник.Подписи.Форма.ФормаЭлементаУпрощенно", ПараметрыСоздания, Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
