Процедура ОткрытьБыструюФормуНоменклатуры(Элемент, ВыбранноеЗначение, СтандартнаяОбработка, ПараметрыОбъекта = Неопределено) Экспорт
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыСоздания = Новый Структура;
	
	//МассивТипов = Новый Массив;
	//МассивТипов.Добавить(ВыбранноеЗначение.ТипНоменклатуры);
	
	ЗначенияЗаполнения = Новый Структура("ТипНоменклатуры, Наименование, НаименованиеПолное", ВыбранноеЗначение.ТипНоменклатуры, ВыбранноеЗначение.Наименование, ВыбранноеЗначение.Наименование);
	
	ПараметрыСоздания.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	ПараметрыСоздания.Вставить("БыстроеСоздание", Истина);
	ПараметрыСоздания.Вставить("РежимВыбора",     Истина);
		
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаЭлементаБыстрая", ПараметрыСоздания, Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

