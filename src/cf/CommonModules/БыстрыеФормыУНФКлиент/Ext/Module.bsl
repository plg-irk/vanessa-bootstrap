Процедура ОткрытьБыструюФормуБанковскогоСчета(Элемент, ВыбранноеЗначение, СтандартнаяОбработка, ПараметрыОбъекта, ПоказыватьБанковскийСчет = Ложь) Экспорт
	
	Если (ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Или ТипЗнч(ВыбранноеЗначение) = Тип("Структура"))
		И (Не ЗначениеЗаполнено(Элемент.ОграничениеТипа)
		Или Элемент.ОграничениеТипа.СодержитТип(Тип("СправочникСсылка.БанковскиеСчета"))) Тогда
		
		
		ПараметрыСоздания = Новый Структура;
		ПараметрыСоздания.Вставить("НомерСчета", СокрЛП(ВыбранноеЗначение.НомерСчета));
		ПараметрыСоздания.Вставить("Владелец", ПараметрыОбъекта.Владелец);
		ПараметрыСоздания.Вставить("Банк", ПараметрыОбъекта.Банк);
		ПараметрыСоздания.Вставить("БыстроеСоздание", Истина);
		ПараметрыСоздания.Вставить("РежимВыбора",     Истина);
		
		ОткрытьФорму("Справочник.БанковскиеСчета.Форма.ФормаЭлемента", ПараметрыСоздания, Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры

