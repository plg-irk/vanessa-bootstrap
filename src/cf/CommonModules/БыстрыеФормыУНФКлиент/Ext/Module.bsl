#Область СлужебныеПроцедурыИФункции

Процедура КонтрагентАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка) Экспорт
	
	Если НЕ ПустаяСтрока(Текст) 
		И (НЕ ЗначениеЗаполнено(Элемент.ОграничениеТипа)
		ИЛИ Элемент.ОграничениеТипа.СодержитТип(Тип("СправочникСсылка.Контрагенты"))) Тогда
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = БыстрыеФормыУНФВызовСервера.ДанныеВыбораКонтрагента(ПараметрыПолученияДанных, Ложь);
	КонецЕсли;
	
КонецПроцедуры

Процедура КонтрагентОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка) Экспорт
	
	Если НЕ ПустаяСтрока(Текст) 
		И (НЕ ЗначениеЗаполнено(Элемент.ОграничениеТипа)
		ИЛИ Элемент.ОграничениеТипа.СодержитТип(Тип("СправочникСсылка.Контрагенты"))) Тогда
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = БыстрыеФормыУНФВызовСервера.ДанныеВыбораКонтрагента(ПараметрыПолученияДанных, Истина);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОткрытьБыструюФормуКонтрагента(Элемент, ВыбранноеЗначение, СтандартнаяОбработка, ПараметрыОбъекта, ПоказыватьБанковскийСчет = Ложь) Экспорт
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") И Не ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		СтандартнаяОбработка = Ложь;
		Возврат
	КонецЕсли;
	
	Если (ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Или ТипЗнч(ВыбранноеЗначение) = Тип("Структура"))
		И (Не ЗначениеЗаполнено(Элемент.ОграничениеТипа)
		Или Элемент.ОграничениеТипа.СодержитТип(Тип("СправочникСсылка.Контрагенты"))) Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ВидОперации = ПараметрыОбъекта.ВидОперации;
		
		ПараметрыСоздания = Новый Структура;
		ЗначенияЗаполнения = Новый Структура();
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("ВидОперацииДокумента", ВидОперации);
		
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
			
			ЗначенияЗаполнения.Вставить("ВидКонтрагента", ВыбранноеЗначение.ВидКонтрагента);
			ЗначенияЗаполнения.Вставить("ИНН", "");
			ЗначенияЗаполнения.Вставить("Наименование", ВыбранноеЗначение.Наименование);
			ЗначенияЗаполнения.Вставить("НаименованиеПолное", ВыбранноеЗначение.Наименование);
			
			Если ВыбранноеЗначение.Самозанятый Тогда
				ДополнительныеПараметры.Вставить("ВыплатыСамозанятым", Истина);
			КонецЕсли;
			
		Иначе
			
			ВыбранноеЗначение = СокрЛП(ВыбранноеЗначение);
			
			Если СтрДлина(ВыбранноеЗначение) = 10 Тогда
				ЗначенияЗаполнения.Вставить("ВидКонтрагента", ПредопределенноеЗначение("Перечисление.ВидыКонтрагентов.ЮридическоеЛицо"));
			Иначе
				ЗначенияЗаполнения.Вставить("ВидКонтрагента", ПредопределенноеЗначение("Перечисление.ВидыКонтрагентов.ИндивидуальныйПредприниматель"));
			КонецЕсли;
			
			ЗначенияЗаполнения.Вставить("ИНН", ВыбранноеЗначение);
			ЗначенияЗаполнения.Вставить("Наименование", СтрШаблон(НСтр("ru='%1 новый контрагент'"), ВыбранноеЗначение));
			ЗначенияЗаполнения.Вставить("НаименованиеПолное", СтрШаблон(НСтр("ru='%1 новый контрагент'"), ВыбранноеЗначение));
			
		КонецЕсли;
		
		Для Каждого ПараметрВыбора Из Элемент.ПараметрыВыбора Цикл
			
			Если СтрНачинаетсяС(ПараметрВыбора.Имя, "Отбор.") Тогда
				ЗначенияЗаполнения.Вставить(СтрЗаменить(ПараметрВыбора.Имя, "Отбор.", ""), ПараметрВыбора.Значение);
			КонецЕсли;
			
			Если СтрНачинаетсяС(ПараметрВыбора.Имя, "Дополнительно.") Тогда
				ДополнительныеПараметры.Вставить(СтрЗаменить(ПараметрВыбора.Имя, "Дополнительно.", ""), ПараметрВыбора.Значение);
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого СвязьПараметраВыбора Из Элемент.СвязиПараметровВыбора Цикл
			
			Если СтрНачинаетсяС(СвязьПараметраВыбора.Имя, "Дополнительно.") Тогда
				
				Если СтрНайти(СвязьПараметраВыбора.Имя, "ВидОперации") > 0 Тогда
					ДополнительныеПараметры.Вставить("ВидОперации", ВидОперации);
				КонецЕсли;
				
				Если СтрНайти(СвязьПараметраВыбора.Имя, "ВыплатыСамозанятым") > 0 Тогда
					ДополнительныеПараметры.Вставить("ВыплатыСамозанятым", Истина);
				КонецЕсли;
				
				Если СтрНайти(СвязьПараметраВыбора.Имя, "ЧекККМ") > 0 Тогда
					ДополнительныеПараметры.Вставить("ЧекККМ", Истина);
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ПараметрыСоздания.Вставить("БыстроеСоздание", Истина);
		ПараметрыСоздания.Вставить("РежимВыбора",     Истина);
		ПараметрыСоздания.Вставить("ПоказыватьБанковскийСчет", ПоказыватьБанковскийСчет);
		
		ПараметрыСоздания.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
		ПараметрыСоздания.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
		
		ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлементаБыстрая", ПараметрыСоздания, Элемент,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры

