
#Область ПрограммныйИнтерфейс

Процедура ТаблицаСвойствОбновитьЗависимостиДополнительныхРеквизитов(Форма, Объект = Неопределено) Экспорт
	
	Если Не Форма.Свойства_ИспользоватьСвойства Тогда
		Возврат;
	КонецЕсли;
	
	Параметры = Новый Структура("Форма, ОписаниеОбъекта, ЗначенияПараметров", Форма, Объект, Новый Соответствие);
	Если Параметры.ОписаниеОбъекта = Неопределено Тогда
		Параметры.ОписаниеОбъекта = Форма.Объект;
	КонецЕсли;	
	
	Для Каждого ОписаниеЗависимогоРеквизита Из Форма.Свойства_ОписаниеЗависимыхДополнительныхРеквизитов Цикл
		
		ОтборПоСвойству = Новый Структура("Свойство", ОписаниеЗависимогоРеквизита.Свойство); 
		
		Если ОписаниеЗависимогоРеквизита.УсловиеДоступности <> Неопределено Тогда
			
			Если Не ОписаниеЗависимогоРеквизита.Доступен Тогда
				Продолжить;
			КонецЕсли;
			
			Параметры.ЗначенияПараметров = ОписаниеЗависимогоРеквизита.УсловиеДоступности.ЗначенияПараметров;
			Результат = Вычислить(ОписаниеЗависимогоРеквизита.УсловиеДоступности.КодУсловия);
			
			Строки = Форма.Свойства_ТаблицаСвойстваИЗначения.НайтиСтроки(ОтборПоСвойству);
			Для каждого Стр Из Строки Цикл
				Стр.Доступен = Результат;
			КонецЦикла;
			
		КонецЕсли;
		
		Если ОписаниеЗависимогоРеквизита.УсловиеВидимости <> Неопределено Тогда
			
			Если Не ОписаниеЗависимогоРеквизита.Виден Тогда
				Продолжить;
			КонецЕсли;
			
			Параметры.ЗначенияПараметров = ОписаниеЗависимогоРеквизита.УсловиеВидимости.ЗначенияПараметров;
			Результат = Вычислить(ОписаниеЗависимогоРеквизита.УсловиеВидимости.КодУсловия);
			
			Строки = Форма.Свойства_ТаблицаСвойстваИЗначения.НайтиСтроки(ОтборПоСвойству);
			Для каждого Стр Из Строки Цикл
				Стр.Виден = Результат;
			КонецЦикла;
			
		КонецЕсли;
		
		Если ОписаниеЗависимогоРеквизита.УсловиеОбязательностиЗаполнения <> Неопределено Тогда
			
			Если Не ОписаниеЗависимогоРеквизита.ЗаполнятьОбязательно Тогда
				Продолжить;
			КонецЕсли;
			
			Параметры.ЗначенияПараметров = ОписаниеЗависимогоРеквизита.УсловиеОбязательностиЗаполнения.ЗначенияПараметров;
			Результат = Вычислить(ОписаниеЗависимогоРеквизита.УсловиеОбязательностиЗаполнения.КодУсловия);
			
			Строки = Форма.Свойства_ТаблицаСвойстваИЗначения.НайтиСтроки(ОтборПоСвойству);
			Для каждого Стр Из Строки Цикл
				Стр.ЗаполнятьОбязательно = Результат;
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ТаблицаСвойствПередУдалением(Элемент, Отказ, Модифицированность) Экспорт
	
	Отказ = Истина;
	Элемент.ТекущиеДанные.Значение = Элемент.ТекущиеДанные.ТипЗначенияСвойства.ПривестиЗначение(Неопределено);
	Модифицированность = Истина;
	
КонецПроцедуры // ТаблицаСвойствПередУдалением()

Процедура ТаблицаСвойствПередНачаломДобавления(Отказ) Экспорт
	
	Отказ = Истина;
	
КонецПроцедуры

