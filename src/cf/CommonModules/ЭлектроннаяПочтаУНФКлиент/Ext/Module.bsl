Асинх Процедура СоздатьЛидНаОснованииСобытия(Событие = Неопределено, Форма = Неопределено) Экспорт
	
	Если Форма = Неопределено Тогда
		Данные = ЭлектроннаяПочтаУНФВызовСервера.СозданиеКонтактаНаОснованииСобытия(Событие);
		Контрагент = Данные.ПервыйУчастник.Контакт;
		СтрокаКонтакт = Данные.ВторойУчастник;
		ИсточникПривлечения = Данные.ИсточникПривлечения;
		Ссылка = Событие;
	Иначе
		
		Контрагент = Форма.Контрагент;
		Элементы = Форма.Элементы;
		Контакты = Форма.Контакты;
		ИсточникПривлечения = Форма.Объект.ИсточникПривлечения;
		Ссылка = Форма.Объект.Ссылка;
		
		Если Элементы.Контакты.ТекущиеДанные <> Неопределено Тогда
			СтрокаКонтакт = Элементы.Контакты.ТекущиеДанные;
		ИначеЕсли Контакты.Количество() <> 0 Тогда
			СтрокаКонтакт = Контакты[0];
		КонецЕсли;
		
	КонецЕсли;
	
	Если СтрокаКонтакт = Неопределено Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Список контактов не заполнен.'"),, "Контакты");
		Возврат;
	КонецЕсли;
	
	Если НЕ ПроверитьМожноСоздатьКонтакт(Контрагент, Форма, "Контрагент") Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Контрагент) = Тип("СправочникСсылка.Контрагенты") И ЗначениеЗаполнено(Контрагент) Тогда
		
		Если Форма <> Неопределено И Форма.Модифицированность Тогда
			
			Кнопки = Новый СписокЗначений;
			Кнопки.Добавить("Да", НСтр("ru = 'Записать и продолжить'"));
			Кнопки.Добавить("Отмена", НСтр("ru = 'Отмена'"));
			
			ОтветПользователя = Ждать ВопросАсинх(
			НСтр("ru = 'Для выполнения команды ""Создать лида на основании"" данные будут записаны. Продолжить?'"),
			Кнопки, ,
			"Да");
			
			Если ОтветПользователя <> "Да" Тогда
				Возврат;
			КонецЕсли;
			
			Форма.Записать();
			
		КонецЕсли;
		
		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("Контрагент", Контрагент);
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Контрагент", Контрагент);
		ПараметрыФормы.Вставить("ЗаписьПовторногоЛидаИзОбычногоСобытия", Истина);
		ПараметрыФормы.Вставить("СобытиеОснование", Ссылка);
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ОткрытьФорму("Справочник.Лиды.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект);
		
		Возврат;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполненоКакСвязаться(СтрокаКонтакт, Форма) Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма = Неопределено Тогда
		Поле = "";
	Иначе
		Поле = СтрШаблон("Контакты[%1].Контакт", Формат(Контакты.Индекс(СтрокаКонтакт), "ЧГ="));
	КонецЕсли;
	Если НЕ ПроверитьМожноСоздатьКонтакт(СтрокаКонтакт.Контакт, Поле, Форма) Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма <> Неопределено Тогда
		Форма.СопоставитьКонтактКакСвязаться = СтрокаКонтакт.КакСвязаться;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("КонтактКакСвязаться", Новый Структура);
	ПараметрыФормы.КонтактКакСвязаться.Вставить("Контакт", СтрокаКонтакт.Контакт);
	ПараметрыФормы.КонтактКакСвязаться.Вставить("КакСвязаться", СтрокаКонтакт.КакСвязаться);
	ПараметрыФормы.КонтактКакСвязаться.Вставить("ТипКИ", ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон"));
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("ИсточникПривлечения", ИсточникПривлечения);
	
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	ОткрытьФорму("Справочник.Лиды.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

Процедура ВыгрузитьДанныеДляТехническойПоддержки(Форма, ПараметрыВыгрузки) Экспорт
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("УчетнаяЗапись", ПараметрыВыгрузки.УчетнаяЗапись);
	ДополнительныеПараметры.Вставить("НачинаяСДаты", ПараметрыВыгрузки.НачинаяСДаты);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;
	ПараметрыОжидания.Заголовок = НСтр("ru = 'Подготовка данных для технической поддержки'");
	ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Операция может занять несколько минут.'");
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ВыгрузитьДанныеДляТехническойПоддержкиЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ДлительнаяОперация = ЭлектроннаяПочтаУНФВызовСервера.ВыгрузитьДанныеДляТехническойПоддержки(
	Форма.УникальныйИдентификатор, ПараметрыВыгрузки);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

Процедура ВыгрузитьДанныеДляТехподдержкиНаФормеУчетнойЗаписи(УчетнаяЗапись) Экспорт
	
	ПараметрыФормы = Новый Структура("УчетнаяЗапись", УчетнаяЗапись);
	ОткрытьФорму("Документ.Событие.Форма.ВыгрузкаДанныхДляТехническойПоддержки", ПараметрыФормы);
	
КонецПроцедуры

Процедура ВключитьВыключитьЛогНаФормеУчетнойЗаписи(УчетнаяЗапись, Форма) Экспорт
	
	Ответ = ЭлектроннаяПочтаУНФВызовСервера.ВключитьВыключитьЛогНаФормеУчетнойЗаписи(УчетнаяЗапись);
	
	ЗаголовокКнопки = НСтр("ru = 'Включить логирование'");
	Если Ответ.ЛогированиеВключено Тогда
		ЗаголовокКнопки = НСтр("ru = 'Выключить логирование'");
	КонецЕсли;
	
	Форма.Элементы.ВключитьВыключитьЛог.Заголовок = ЗаголовокКнопки;
	
	Если Ответ.ЛогированиеВключено Тогда
		ТекстОповещения = НСтр("ru = 'Логирование включено'");
	Иначе
		ТекстОповещения = НСтр("ru = 'Логирование выключено'");
	КонецЕсли;
	ПоказатьОповещениеПользователя(НСтр("ru = 'Логирование'"), , ТекстОповещения, БиблиотекаКартинок.ВыполненоУспешно);
	
КонецПроцедуры

