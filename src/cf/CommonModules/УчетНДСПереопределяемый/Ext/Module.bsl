    |УНИЧТОЖИТЬ ВТ_ДанныеСчетовФактур";
    
    Если НЕ ЭтоОтчет Тогда // используем остатки для заполнения документа
        ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
