    Если Не ЗначениеЗаполнено(Организация) Тогда
        ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ДатыОплатВКнигеПокупок.Организация В (&Организация)", "ИСТИНА");
    КонецЕсли;
        
    Запрос.Текст = ТекстЗапроса;
    Запрос.Выполнить();

    ТекстЗапроса =
