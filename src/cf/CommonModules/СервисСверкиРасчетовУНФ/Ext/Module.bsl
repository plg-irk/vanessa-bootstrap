Функция ТекстЗапросаРасчетыСКонтрагентами()
	
	Возврат
	ТекстЗапросаТаблицаРасчетов() +
	"ВЫБРАТЬ
	|	ВТ_Расчеты.Период КАК Дата,
	|	ДанныеПервичныхДокументов.НомерРегистратора КАК Номер,
	|	ВТ_Расчеты.Регистратор КАК Документ,
	|	ВТ_Расчеты.СуммаОборот КАК СуммаОборот,
	|	ЕСТЬNULL(ДанныеПервичныхДокументов.Номер, НЕОПРЕДЕЛЕНО) КАК НомерВходящегоДокумента,
	|	ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, НЕОПРЕДЕЛЕНО) КАК ДатаВходящегоДокумента,
	|	ВТ_Расчеты.Организация КАК Организация,
	|	ВТ_Расчеты.Контрагент КАК Контрагент
	|ИЗ
	|	ВТ_Расчеты КАК ВТ_Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
	|		ПО (ДанныеПервичныхДокументов.Организация В (&МассивОрганизаций))
	|			И ВТ_Расчеты.Регистратор = ДанныеПервичныхДокументов.Документ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СервисСверкиРасчетовРеестрДокументов КАК СервисСверкиРасчетовРеестрДокументов
	|		ПО ВТ_Расчеты.Организация = СервисСверкиРасчетовРеестрДокументов.Организация
	|			И ВТ_Расчеты.Контрагент = СервисСверкиРасчетовРеестрДокументов.Контрагент
	|			И ВТ_Расчеты.Регистратор = СервисСверкиРасчетовРеестрДокументов.Документ
	|			И (&ТолькоНеОтправленныеНаСверку)
	|ГДЕ
	|	ВТ_Расчеты.СуммаОборот <> 0
	|	И ВЫБОР
	|			КОГДА &ТолькоНеОтправленныеНаСверку
	|				ТОГДА СервисСверкиРасчетовРеестрДокументов.Документ ЕСТЬ NULL
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Документ";
	
