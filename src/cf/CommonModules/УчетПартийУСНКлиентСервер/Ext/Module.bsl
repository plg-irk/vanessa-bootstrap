// Описание операции признания расходов на услуги от самозанятых для КУДиР
//
// Параметры:
//  НомерРеестра - Строка	- номер реестра на выплату самозанятым
//  ДатаРеестра	 - Дата		- дата реестра на выплату самозанятым
// 
// Возвращаемое значение:
//   - Строка
//
Функция СодержаниеОплатаСамозанятым(НомерРеестра = "", ДатаРеестра = '00010101') Экспорт
	
	Если ЗначениеЗаполнено(НомерРеестра) И ЗначениеЗаполнено(ДатаРеестра) Тогда
		НомерНаПечать = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(НомерРеестра, Истина, Истина);
		ОписаниеОснования = СтрШаблон(НСтр("ru = 'Оплата услуг самозанятых по реестру %1 от %2'"),
			НомерНаПечать, Формат(ДатаРеестра, "ДЛФ=D"));
	Иначе
		ОписаниеОснования = НСтр("ru = 'Оплата услуг самозанятых'");
	КонецЕсли;
	
	Возврат СтрШаблон(НСтр("ru = '%1. Признаны расходы на услуги сторонних организаций.'"), ОписаниеОснования);
	
КонецФункции

