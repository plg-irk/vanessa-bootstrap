#Область ТекстСодержаниеОпераций

// Описание операции оплаты поставщику за поставленные товары для КУДиР
//
// Параметры:
//  Наличные	 - Булево
//  Контрагент	 - Строка	- представление контрагента-поставщика
// 
// Возвращаемое значение:
//   - Строка
//
Функция СодержаниеОплатаПоставщикуЗаТовары(Наличные, Контрагент) Экспорт
	
	Если Наличные Тогда
		Содержание = НСтр("ru = 'Оплачено наличными поставщику ""%1"" за товары.'");
	Иначе
		Содержание = НСтр("ru = 'Оплачено с банковского счета поставщику ""%1"" за товары.'");
	КонецЕсли;
	
	Возврат СтрШаблон(Содержание, Контрагент);
	
КонецФункции

// Описание операции оплаты поставщику за оказанные услуги или поставленные материалы для КУДиР
//
// Параметры:
//  Наличные	 - Булево
//  Контрагент	 - Строка	- представление контрагента-поставщика
// 
// Возвращаемое значение:
//   - Строка
//
Функция СодержаниеОплатаПоставщикуЗаУслуги(Наличные, Контрагент) Экспорт
	
	Содержание = НСтр("ru = 'Расход %1 денежных средств на оплату поставщику ""%2""'");	
	ВидОплаты = ?(Наличные, НСтр("ru = 'наличных'"), НСтр("ru = 'безналичных'"));
	
	Возврат СтрШаблон(Содержание, ВидОплаты, Контрагент);
	
КонецФункции

// Описание операции признания расходов на товары для КУДиР
//
// Возвращаемое значение:
//   - Строка
//
Функция СодержаниеРасходыНаТовары() Экспорт
	
