КонецФункции

// Описание операции признания расходов на услуги/материалы для КУДиР
//
// Параметры:
//   Контрагент - Строка - представление контрагента-поставщика
// Возвращаемое значение:
//   - Строка
//
Функция СодержаниеРасходыНаУслуги(Контрагент = "") Экспорт
	
	ТекстРасходы = НСтр("ru = 'Признаны расходы на оплату поставщику'");
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Возврат СтрШаблон("%1 %2", ТекстРасходы, Контрагент);
	Иначе
		Возврат СтрШаблон("%1.", ТекстРасходы);
	КонецЕсли;

КонецФункции

// Описание операции признания расходов на поступившие услуги/материалы
//
// Параметры:
//  ЕстьМатериалы - Булево
//  ЕстьУслуги	- Булево
//
// Возвращаемое значение:
//   - Строка
//
Функция СодержаниеРасходыЛичныеСредства(ЕстьМатериалы, ЕстьУслуги) Экспорт
	
	Если ЕстьМатериалы И НЕ ЕстьУслуги Тогда
		ТекстСодержания = НСтр("ru = 'расходы на материалы'");
	ИначеЕсли НЕ ЕстьМатериалы И ЕстьУслуги Тогда
		ТекстСодержания = НСтр("ru = 'расходы на услуги'");
	ИначеЕсли ЕстьМатериалы И ЕстьУслуги Тогда
		ТекстСодержания = НСтр("ru = 'расходы на материалы и услуги'");
	Иначе
		ТекстСодержания = НСтр("ru = 'расходы'");
	КонецЕсли;
	
	Возврат СтрШаблон(НСтр("ru = 'Признаны %1 за счет личных средств'"), ТекстСодержания);

КонецФункции

// Описание операции признания расходов на поступившие услуги/материалы
//
// Параметры:
//  ЕстьМатериалы - Булево
//  ЕстьУслуги	- Булево
//  Контрагент 	- Строка	- представление контрагента-поставщика
//
// Возвращаемое значение:
//   - Строка
//
Функция СодержаниеРасходыПредоплата(ЕстьМатериалы, ЕстьУслуги, Контрагент) Экспорт
	
	Если ЕстьМатериалы И НЕ ЕстьУслуги Тогда
		ТекстСодержания = НСтр("ru = 'Поступили материалы от поставщика'");
	ИначеЕсли НЕ ЕстьМатериалы И ЕстьУслуги Тогда
		ТекстСодержания = НСтр("ru = 'Оказаны услуги поставщиком'");
	ИначеЕсли ЕстьМатериалы И ЕстьУслуги Тогда
		ТекстСодержания = НСтр("ru = 'Поступили материалы и услуги от поставщика'");
	Иначе
		ТекстСодержания = НСтр("ru = 'Признаны расходы на оплату поставщику'");
	КонецЕсли;
	
	Возврат СтрШаблон(НСтр("ru = '%1 ""%2"" в счет предварительной оплаты'"), ТекстСодержания, Контрагент);

КонецФункции

