				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ВТЭквайрингПоДокументам.ДенежныйДокумент КАК ДенежныйДокумент,
				   |   СУММА(ВТЭквайрингПоДокументам.СуммаРасчетов - ВТЭквайрингПоДокументам.СуммаВозврата) КАК Сумма,
				   |   СУММА(ВЫБОР
				   |       КОГДА ВТЭквайрингПоДокументам.СуммаРасчетов = ВТДокументыРасчетовЭквайринга.ПродажиСумма
				   |           ТОГДА ВТДокументыРасчетовЭквайринга.ПродажиНДС
				   |       КОГДА ВТДокументыРасчетовЭквайринга.ПродажиСумма = 0
				   |           ТОГДА 0
				   |       ИНАЧЕ ВТЭквайрингПоДокументам.СуммаРасчетов * ВТДокументыРасчетовЭквайринга.ПродажиНДС /
				   |           ВТДокументыРасчетовЭквайринга.ПродажиСумма
				   |   КОНЕЦ - ВЫБОР
				   |       КОГДА ВТЭквайрингПоДокументам.СуммаВозврата = ВТДокументыРасчетовЭквайринга.ВозвратыСумма
				   |           ТОГДА ВТДокументыРасчетовЭквайринга.ВозвратыНДС
				   |       КОГДА ВТДокументыРасчетовЭквайринга.ВозвратыСумма = 0
				   |           ТОГДА 0
				   |       ИНАЧЕ ВТЭквайрингПоДокументам.СуммаВозврата * ВТДокументыРасчетовЭквайринга.ВозвратыНДС /
				   |           ВТДокументыРасчетовЭквайринга.ВозвратыСумма
				   |   КОНЕЦ) КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТСуммыПоДетализации
				   |ИЗ
				   |   ВТЭквайрингПоДокументам КАК ВТЭквайрингПоДокументам
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыРасчетовЭквайринга КАК ВТДокументыРасчетовЭквайринга
				   |       ПО ВТЭквайрингПоДокументам.ДенежныйДокумент = ВТДокументыРасчетовЭквайринга.ДенежныйДокумент
				   |       И ВТЭквайрингПоДокументам.ДокументРасчетов = ВТДокументыРасчетовЭквайринга.ДокументРасчетов
				   |СГРУППИРОВАТЬ ПО
				   |   ВТЭквайрингПоДокументам.ДенежныйДокумент
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТДокументыРасчетовЭквайринга
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТЭквайрингПоДокументам
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ВТСуммыПоДетализации.ДенежныйДокумент КАК Документ,
				   |   ВТСуммыПоДетализации.Сумма,
				   |   ВТСуммыПоДетализации.СуммаНДС,
				   |   0 КАК СуммаКомиссии
				   |ПОМЕСТИТЬ ВТДоходыЭквайрингПредварительно
				   |ИЗ
				   |   ВТСуммыПоДетализации КАК ВТСуммыПоДетализации
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ВТОплатыПоКартам.Ссылка,
				   |   ВТОплатыПоКартам.Сумма - ВТОплатыПоКартам.Возврат - ЕСТЬNULL(ВТСуммыПоДетализации.Сумма, 0),
				   |   ВЫБОР
				   |       КОГДА ВТОплатыПоКартам.Сумма - ВТОплатыПоКартам.Возврат = ЕСТЬNULL(ВТСуммыПоДетализации.Сумма, 0)
				   |           ТОГДА 0
				   |       ИНАЧЕ ВТОплатыПоКартам.СуммаНДС - ВТОплатыПоКартам.ВозвратНДС - ЕСТЬNULL(ВТСуммыПоДетализации.СуммаНДС, 0)
				   |   КОНЕЦ,
				   |   ВТОплатыПоКартам.СуммаКомиссии
				   |ИЗ
				   |   ВТОплатыПоКартам КАК ВТОплатыПоКартам
				   |       ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыПоДетализации
				   |       ПО ВТОплатыПоКартам.Ссылка = ВТСуммыПоДетализации.ДенежныйДокумент
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТОплатыПоКартам
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТСуммыПоДетализации
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ВТДоходыЭквайрингПредварительно.Документ,
				   |   СУММА(ВТДоходыЭквайрингПредварительно.Сумма) КАК Сумма,
				   |   СУММА(ВТДоходыЭквайрингПредварительно.СуммаНДС) КАК СуммаНДС,
				   |   СУММА(ВТДоходыЭквайрингПредварительно.СуммаКомиссии) КАК СуммаКомиссии
				   |ПОМЕСТИТЬ ВТДоходыЭквайринг
				   |ИЗ
				   |   ВТДоходыЭквайрингПредварительно КАК ВТДоходыЭквайрингПредварительно
				   |СГРУППИРОВАТЬ ПО
				   |   ВТДоходыЭквайрингПредварительно.Документ
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТДоходыЭквайрингПредварительно";

	Запрос.Выполнить();

КонецПроцедуры

Функция ТекстКоличествоЗаписей(Количество)

	Текст = НСтр("ru='Сформировано записей: %1'");
	Возврат СтрШаблон(Текст, Строка(Количество));

КонецФункции

Функция ПродолжительностьИнтервала(Интервал)

	Возврат День(Интервал.ДатаОкончания) - День(Интервал.ДатаНачала) + 1;

КонецФункции

Процедура ПолучитьВТДенежныеДокументыДоходы(МенеджерВременныхТаблиц, Организация, НачалоПериода, ОкончаниеПериода,
	ВидыОпераций)

	ПолучитьВТДенежныеДокументыНалогообложениеВТаблице(МенеджерВременныхТаблиц, Организация, НачалоПериода,
		ОкончаниеПериода);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|   &КомментарийПоступлениеВКассу КАК Комментарий,
	|   ПоступлениеВКассу.Ссылка КАК Ссылка,
	|   ПоступлениеВКассу.ВидОперации КАК ВидОперации,
	|   ПоступлениеВКассу.ВалютаДенежныхСредств КАК ВалютаДенежныхСредств,
	|   ПоступлениеВКассу.СуммаДокумента КАК СуммаДокумента,
	|   0 КАК СуммаКомиссииДокумента,
	|   ПоступлениеВКассу.Контрагент КАК Контрагент,
	|   ПоступлениеВКассу.Подотчетник КАК Подотчетник,
	|   ПоступлениеВКассу.ПоложениеНастроекНалоговогоУчета КАК ПоложениеНастроекНалоговогоУчета,
	|   ПоступлениеВКассу.УчитыватьВНУ КАК УчитыватьВНУ,
	|   ПоступлениеВКассу.Патент КАК Патент,
	|   ПоступлениеВКассу.Дата КАК ДатаПервичногоДокумента,
	|   ПоступлениеВКассу.Номер КАК НомерПервичногоДокумента,
	|   ПоступлениеВКассу.Дата КАК Период,
	|   """" КАК НомерВходящегоДокумента,
	|   """" КАК НазначениеПлатежа,
	|   НАЧАЛОПЕРИОДА(ПоступлениеВКассу.Дата, ДЕНЬ) КАК ДатаНачалоДня
	|ПОМЕСТИТЬ ВТВсеДенежныеДокументы
	|ИЗ
	|   Документ.ПоступлениеВКассу КАК ПоступлениеВКассу
	|ГДЕ
	|   ПоступлениеВКассу.Организация = &Организация
	|   И ПоступлениеВКассу.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|   И ПоступлениеВКассу.Проведен
	|   И ПоступлениеВКассу.ВидОперации В(&МассивИспользуемыхВидовОпераций)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|   &КомментарийПоступлениеНаСчет,
	|   ПоступлениеНаСчет.Ссылка,
	|   ПоступлениеНаСчет.ВидОперации,
	|   ПоступлениеНаСчет.ВалютаДенежныхСредств,
	|   ПоступлениеНаСчет.СуммаДокумента + ПоступлениеНаСчет.СуммаКомиссииДокумента,
	|   ПоступлениеНаСчет.СуммаКомиссииДокумента,
	|   ПоступлениеНаСчет.Контрагент,
	|   ПоступлениеНаСчет.Подотчетник,
	|   ПоступлениеНаСчет.ПоложениеНастроекНалоговогоУчета,
	|   ПоступлениеНаСчет.УчитыватьВНУ,
	|   ПоступлениеНаСчет.Патент,
	|   ВЫБОР
	|       КОГДА ПоступлениеНаСчет.ДатаВходящегоДокумента = ДАТАВРЕМЯ(1, 1, 1)
	|           ТОГДА ПоступлениеНаСчет.Дата
	|       ИНАЧЕ ПоступлениеНаСчет.ДатаВходящегоДокумента
	|   КОНЕЦ,
	|   ПоступлениеНаСчет.Номер,
	|   ПоступлениеНаСчет.Дата,
	|   ПоступлениеНаСчет.НомерВходящегоДокумента,
	|   ПоступлениеНаСчет.НазначениеПлатежа,
	|   НАЧАЛОПЕРИОДА(ПоступлениеНаСчет.Дата, ДЕНЬ)
	|ИЗ
	|   Документ.ПоступлениеНаСчет КАК ПоступлениеНаСчет
	|ГДЕ
	|   ПоступлениеНаСчет.Организация = &Организация
	|   И ПоступлениеНаСчет.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|   И ПоступлениеНаСчет.Проведен
	|   И ПоступлениеНаСчет.ВидОперации В(&МассивИспользуемыхВидовОпераций)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|   &КомментарийРасходИзКассы,
	|   РасходИзКассы.Ссылка,
	|   РасходИзКассы.ВидОперации,
	|   РасходИзКассы.ВалютаДенежныхСредств,
	|   -РасходИзКассы.СуммаДокумента,
	|   0,
	|   РасходИзКассы.Контрагент,
	|   РасходИзКассы.Подотчетник,
	|   РасходИзКассы.ПоложениеНастроекНалоговогоУчета,
	|   РасходИзКассы.УчитыватьВНУ,
	|   РасходИзКассы.Патент,
	|   РасходИзКассы.Дата,
	|   РасходИзКассы.Номер,
	|   РасходИзКассы.Дата,
	|   """",
	|   """",
	|   НАЧАЛОПЕРИОДА(РасходИзКассы.Дата, ДЕНЬ)
	|ИЗ
	|   Документ.РасходИзКассы КАК РасходИзКассы
	|ГДЕ
	|   РасходИзКассы.Организация = &Организация
	|   И РасходИзКассы.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|   И РасходИзКассы.Проведен
	|   И РасходИзКассы.ВидОперации В(&МассивИспользуемыхВидовОпераций)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|   &КомментарийРасходСоСчета,
	|   РасходСоСчета.Ссылка,
	|   РасходСоСчета.ВидОперации,
	|   NULL,
	|   -РасходСоСчета.СуммаДокумента,
	|   РасходСоСчета.СуммаКомиссииДокумента,
	|   РасходСоСчета.Контрагент,
	|   РасходСоСчета.Подотчетник,
	|   РасходСоСчета.ПоложениеНастроекНалоговогоУчета,
	|   РасходСоСчета.УчитыватьВНУ,
	|   ЗНАЧЕНИЕ(Справочник.Патенты.ПустаяСсылка),
	|   ВЫБОР
	|       КОГДА РасходСоСчета.ДатаВходящегоДокумента = ДАТАВРЕМЯ(1, 1, 1)
	|           ТОГДА РасходСоСчета.Дата
	|       ИНАЧЕ РасходСоСчета.ДатаВходящегоДокумента
	|   КОНЕЦ,
	|   РасходСоСчета.Номер,
	|   РасходСоСчета.Дата,
	|   РасходСоСчета.НомерВходящегоДокумента,
	|   РасходСоСчета.НазначениеПлатежа,
	|   НАЧАЛОПЕРИОДА(РасходСоСчета.Дата, ДЕНЬ)
	|ИЗ
	|   Документ.РасходСоСчета КАК РасходСоСчета
	|ГДЕ
	|   РасходСоСчета.Организация = &Организация
	|   И РасходСоСчета.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|   И РасходСоСчета.Проведен
	|   И РасходСоСчета.ВидОперации В(&МассивИспользуемыхВидовОпераций)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|   ВТВсеДенежныеДокументы.Ссылка КАК Ссылка,
	|   ВТВсеДенежныеДокументы.ВидОперации КАК ВидОперации,
	|   ВТВсеДенежныеДокументы.ВалютаДенежныхСредств КАК ВалютаДенежныхСредств,
	|   ВТВсеДенежныеДокументы.СуммаДокумента КАК СуммаДокумента,
	|   ВТВсеДенежныеДокументы.СуммаКомиссииДокумента КАК СуммаКомиссииДокумента,
	|   ВТВсеДенежныеДокументы.Контрагент КАК Контрагент,
	|   ВТВсеДенежныеДокументы.Подотчетник КАК Подотчетник,
	|   ВТВсеДенежныеДокументы.ПоложениеНастроекНалоговогоУчета КАК ПоложениеНастроекНалоговогоУчета,
	|   ВТВсеДенежныеДокументы.УчитыватьВНУ КАК УчитыватьВНУ,
	|   ВТВсеДенежныеДокументы.Патент КАК Патент,
	|   НЕ ДенежныеДокументыНалогообложениеВТаблице.ВидОперации ЕСТЬ NULL КАК НалогообложениеВТаблице,
	|   ЕСТЬNULL(Контрагенты.НаименованиеПолное, """") КАК ЮридическоеНазваниеКонтрагента,
	|   ВТВсеДенежныеДокументы.ДатаПервичногоДокумента КАК ДатаПервичногоДокумента,
	|   ВТВсеДенежныеДокументы.НомерПервичногоДокумента КАК НомерПервичногоДокумента,
	|   ВТВсеДенежныеДокументы.Период КАК Период,
	|   ВТВсеДенежныеДокументы.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	|   ВТВсеДенежныеДокументы.НазначениеПлатежа КАК НазначениеПлатежа,
	|   ВТВсеДенежныеДокументы.ДатаНачалоДня КАК ДатаНачалоДня,
	|   ВТВсеДенежныеДокументы.Комментарий КАК Комментарий
	|ПОМЕСТИТЬ ВТДенежныеДокументы
	|ИЗ
	|   ВТВсеДенежныеДокументы КАК ВТВсеДенежныеДокументы
	|       ЛЕВОЕ СОЕДИНЕНИЕ ВТДенежныеДокументыНалогообложениеВТаблице КАК ДенежныеДокументыНалогообложениеВТаблице
	|       ПО ВТВсеДенежныеДокументы.Ссылка = ДенежныеДокументыНалогообложениеВТаблице.ДенежныйДокумент
	|       ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|       ПО ВТВсеДенежныеДокументы.Контрагент = Контрагенты.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТВсеДенежныеДокументы";

	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ОкончаниеПериода);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("МассивИспользуемыхВидовОпераций", ВидыОпераций);

	ТекстКомментарии = ТекстКомментарииДоходыУСН();
	Для Каждого Элемент Из ТекстКомментарии Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Значение);
	КонецЦикла;

	Запрос.Выполнить();

	УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц, "ВТДенежныеДокументыНалогообложениеВТаблице");

КонецПроцедуры

Функция ТекстКомментарииДоходыУСН()

	Результат = Новый Структура;
	Результат.Вставить("КомментарийПоступлениеВКассу", НСтр(
		"ru='0. Поступление в кассу с видами операций, которые входят в массив'"));
	Результат.Вставить("КомментарийОтчетОРозничныхПродажах", НСтр("ru='1. ОРП'"));
	Результат.Вставить("КомментарийПоступлениеНаСчет", НСтр(
		"ru='2. Поступление на счет с видами операций, которые входят в массив'"));
	Результат.Вставить("КомментарийПоступлениеНаСчетКурьерФакт", НСтр(
		"ru='3. Поступление на счет от курьерской компании или почты (фактическая сумма)'"));
	Результат.Вставить("КомментарийПоступлениеНаСчетКурьерУдержано", НСтр(
		"ru='4. Поступление на счет от курьерской компании или почты (удержаная сумма)'"));
	Результат.Вставить("КомментарийРасходСоСчета", НСтр("ru='5. Расход со счета с операциями из массива'"));
	Результат.Вставить("КомментарийРасходИзКассы", НСтр("ru='6. Расход из кассы с операциями из массива'"));
	Результат.Вставить("КомментарийОтчетКомиссионера", НСтр(
		"ru='7. Отчет комиссионера, в котором удержано вознаграждение'"));
	Результат.Вставить("КомментарийОтчетКомитенту", НСтр("ru='8. Отчет комитенту, в котором удержано вознаграждение'"));
	Результат.Вставить("КомментарийВзаимозачет", НСтр("ru='9. Взаимозачет с операцией Взаимозачет'"));
