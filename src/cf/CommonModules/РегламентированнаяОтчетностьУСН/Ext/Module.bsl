Процедура ПолучитьВТДенежныеДокументыНалогообложениеВТаблице(МенеджерВременныхТаблиц, Организация, НачалоПериода,
	ОкончаниеПериода)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ
				   |    ПоступлениеНаСчет.Ссылка КАК ДенежныйДокумент,
				   |    ПоступлениеНаСчет.ВидОперации КАК ВидОперации
				   |ПОМЕСТИТЬ ВТДенежныеДокументыНалогообложениеВТаблице
				   |ИЗ
				   |    Документ.ПоступлениеНаСчет КАК ПоступлениеНаСчет
				   |ГДЕ
				   |    ПоступлениеНаСчет.Проведен
				   |    И ПоступлениеНаСчет.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |    И ПоступлениеНаСчет.Организация = &Организация
				   |    И ПоступлениеНаСчет.ВидОперации В(&ВидыОперацийНалоговыйУчетВРасшифровкеПлатежа)
				   |    И ПоступлениеНаСчет.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |    ПоступлениеВКассу.Ссылка,
				   |    ПоступлениеВКассу.ВидОперации
				   |ИЗ
				   |    Документ.ПоступлениеВКассу КАК ПоступлениеВКассу
				   |ГДЕ
				   |    ПоступлениеВКассу.Проведен
				   |    И ПоступлениеВКассу.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |    И ПоступлениеВКассу.Организация = &Организация
				   |    И ПоступлениеВКассу.ВидОперации В(&ВидыОперацийНалоговыйУчетВРасшифровкеПлатежа)
				   |    И ПоступлениеВКассу.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |    РасходСоСчета.Ссылка,
				   |    РасходСоСчета.ВидОперации
				   |ИЗ
				   |    Документ.РасходСоСчета КАК РасходСоСчета
				   |ГДЕ
				   |    РасходСоСчета.Проведен
				   |    И РасходСоСчета.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |    И РасходСоСчета.Организация = &Организация
				   |    И РасходСоСчета.ВидОперации В(&ВидыОперацийНалоговыйУчетВРасшифровкеПлатежа)
				   |    И РасходСоСчета.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |    РасходИзКассы.Ссылка,
				   |    РасходИзКассы.ВидОперации
				   |ИЗ
				   |    Документ.РасходИзКассы КАК РасходИзКассы
				   |ГДЕ
				   |    РасходИзКассы.Проведен
				   |    И РасходИзКассы.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |    И РасходИзКассы.Организация = &Организация
				   |    И РасходИзКассы.ВидОперации В(&ВидыОперацийНалоговыйУчетВРасшифровкеПлатежа)
				   |    И РасходИзКассы.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)";

	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ОкончаниеПериода);

	Запрос.УстановитьПараметр("ВидыОперацийНалоговыйУчетВРасшифровкеПлатежа",
		РегламентированнаяОтчетностьУСНКлиентСервер.ВидыОперацийНалоговыйУчетВРасшифровкеПлатежа());

	Запрос.Выполнить();

КонецПроцедуры

Процедура ДополнитьТаблицуМесяцамиИзПериода(Результат, СтрокаИсточник, Период)
    
    // Рассчитываем количество полных месяцев между двумя периодами
	Если НачалоМесяца(Период) = НачалоДня(Период) Тогда
		КоличествоДобавляемыхМесяцев = Месяц(Период) - Месяц(СтрокаИсточник.ДатаНачала) - 1;
	Иначе
		КоличествоДобавляемыхМесяцев = Месяц(Период) - Месяц(СтрокаИсточник.ДатаНачала);
	КонецЕсли;

	Если КоличествоДобавляемыхМесяцев <= 0 Тогда
		СтрокаИсточник.ДатаОкончания = Период - 1;
		РассчитатьПоказателиТарифаЗаПериод(СтрокаИсточник);
	Иначе
		СтрокаИсточник.ДатаОкончания = КонецМесяца(СтрокаИсточник.ДатаНачала);
		РассчитатьПоказателиТарифаЗаПериод(СтрокаИсточник);
		Для ТекущийМесяц = 1 По КоличествоДобавляемыхМесяцев Цикл
			ДобавляемаяСтрока = Результат.Добавить();
			ДобавляемаяСтрока.ДатаНачала = ДобавитьМесяц(НачалоМесяца(СтрокаИсточник.ДатаНачала), ТекущийМесяц);
			ДобавляемаяСтрока.Тариф = СтрокаИсточник.Тариф;
			ДобавляемаяСтрока.МесячныйРазмер = СтрокаИсточник.МесячныйРазмер;
			Если КоличествоДобавляемыхМесяцев - ТекущийМесяц > 0 Тогда
				ДобавляемаяСтрока.ДатаОкончания = КонецМесяца(ДобавляемаяСтрока.ДатаНачала);
			Иначе
				ДобавляемаяСтрока.ДатаОкончания = Период - 1;
			КонецЕсли;
			РассчитатьПоказателиТарифаЗаПериод(ДобавляемаяСтрока);
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

Процедура ПолучитьВТОтчетыКомиссионераДоходПоДате(МенеджерВременныхТаблиц, Организация, НачалоПериода, ОкончаниеПериода)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ОкончаниеПериода);

	Запрос.Текст = "ВЫБРАТЬ
				   |	НастройкиУчета.Период КАК ПериодНачало,
				   |	МИНИМУМ(ЕСТЬNULL(НастройкиУчетаСледующие.Период, ДАТАВРЕМЯ(3999, 12, 31))) КАК ПериодОкончание
				   |ПОМЕСТИТЬ ВТПериодыНастроекУчета
				   |ИЗ
				   |	РегистрСведений.НастройкиУчетаУСН КАК НастройкиУчета
				   |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиУчетаУСН КАК НастройкиУчетаСледующие
				   |		ПО НастройкиУчета.Период < НастройкиУчетаСледующие.Период
				   |ГДЕ
				   |	НастройкиУчета.Период <= &ОкончаниеПериода
				   |СГРУППИРОВАТЬ ПО
				   |	НастройкиУчета.Период
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	РасчетыСПокупателямиОбороты.Документ КАК Документ
				   |ПОМЕСТИТЬ ВТОплатаОтчетовКомиссионера
				   |ИЗ
				   |	РегистрНакопления.РасчетыСПокупателями.Обороты(&НачалоПериода, &ОкончаниеПериода, Регистратор,
				   |		ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Долг)
				   |	И Документ ССЫЛКА Документ.ОтчетКомиссионера) КАК РасчетыСПокупателямиОбороты
				   |ГДЕ
				   |	НЕ РасчетыСПокупателямиОбороты.Регистратор ССЫЛКА Документ.ОтчетКомиссионера
				   |СГРУППИРОВАТЬ ПО
				   |	РасчетыСПокупателямиОбороты.Документ
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	ОтчетКомиссионера.Ссылка КАК ОтчетКомиссионераСсылка,
				   |	ИСТИНА КАК ДоходПоДатеОтчета
				   |ПОМЕСТИТЬ ВТОтчетыКомиссионераДоходПоДате
				   |ИЗ
				   |	Документ.ОтчетКомиссионера КАК ОтчетКомиссионера
				   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыНастроекУчета КАК ВТПериодыНастроекУчета
				   |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиУчетаУСН КАК НастройкиУчетаУСН
				   |			ПО ВТПериодыНастроекУчета.ПериодНачало = НастройкиУчетаУСН.Период
				   |			И НастройкиУчетаУСН.ПризнаватьДоходОтКомиссионераНаДатуОтчета
				   |		ПО ОтчетКомиссионера.Дата >= ВТПериодыНастроекУчета.ПериодНачало
				   |		И ОтчетКомиссионера.Дата <= ВТПериодыНастроекУчета.ПериодОкончание
				   |ГДЕ
				   |	ОтчетКомиссионера.Организация = &Организация
				   |	И ОтчетКомиссионера.УчитыватьВНУ
				   |	И ОтчетКомиссионера.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |	И ОтчетКомиссионера.Проведен
				   |	И НастройкиУчетаУСН.ПризнаватьДоходОтКомиссионераНаДатуОтчета
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |	ОтчетКомиссионера.Ссылка,
				   |	ИСТИНА
				   |ИЗ
				   |	Документ.ОтчетКомиссионера КАК ОтчетКомиссионера
				   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыНастроекУчета КАК ВТПериодыНастроекУчета
				   |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиУчетаУСН КАК НастройкиУчетаУСН
				   |			ПО ВТПериодыНастроекУчета.ПериодНачало = НастройкиУчетаУСН.Период
				   |			И НастройкиУчетаУСН.ПризнаватьДоходОтКомиссионераНаДатуОтчета
				   |		ПО ОтчетКомиссионера.Дата >= ВТПериодыНастроекУчета.ПериодНачало
				   |		И ОтчетКомиссионера.Дата <= ВТПериодыНастроекУчета.ПериодОкончание
				   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОплатаОтчетовКомиссионера КАК ВТОплатаОтчетовКомиссионера
				   |		ПО ОтчетКомиссионера.Ссылка = ВТОплатаОтчетовКомиссионера.Документ
				   |		И ОтчетКомиссионера.Организация = &Организация
				   |		И ОтчетКомиссионера.УчитыватьВНУ
				   |		И ОтчетКомиссионера.Дата < &НачалоПериода
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТПериодыНастроекУчета
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТОплатаОтчетовКомиссионера";

	Запрос.Выполнить();

КонецПроцедуры

// Создает временную таблицу ВТДоходыОтчетовКомиссионера с полями:
//  ОтчетКомиссионераСсылка
//  Дата
//  Номер
//  ВалютаДокумента
//  Контрагент
//  Сумма
//  СуммаНДС
//  ДоходПоДатеОтчета
//
// Параметры:
//  МенеджерВременныхТаблиц  - МенеджерВременныхТаблиц
//  Организация              - СправочникСсылка.Организации
//  НачалоПериода            - Дата
//  ОкончаниеПериода         - Дата
//
Процедура ПолучитьВТДоходыОтчетовКомиссионера(МенеджерВременныхТаблиц, Организация, НачалоПериода, ОкончаниеПериода)

	ПолучитьВТОтчетыКомиссионераДоходПоДате(МенеджерВременныхТаблиц, Организация, НачалоПериода, ОкончаниеПериода);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ОкончаниеПериода);

	ВидыОперацийПродажа = Новый Массив;
	ВидыОперацийПродажа.Добавить(Перечисления.ВидыОперацийОтчетКомиссионера.ОтчетКомиссионера);
	ВидыОперацийПродажа.Добавить(Перечисления.ВидыОперацийОтчетКомиссионера.ПродажаИВозврат);
	Запрос.УстановитьПараметр("ОперацииПродажа", ВидыОперацийПродажа);

	Запрос.Текст = "ВЫБРАТЬ
				   |   ОтчетКомиссионера.Ссылка КАК Ссылка,
				   |   ОтчетКомиссионера.Номер КАК Номер,
				   |   ОтчетКомиссионера.Дата КАК Дата,
				   |   ОтчетКомиссионера.ВалютаДокумента КАК ВалютаДокумента,
				   |   ОтчетКомиссионера.СуммаВознаграждения КАК СуммаВознаграждения,
				   |   ОтчетКомиссионера.ВидОперации КАК ВидОперации,
				   |   ОтчетКомиссионера.Контрагент КАК Контрагент,
				   |   ОтчетКомиссионера.СуммаДокумента КАК СуммаДокумента,
				   |   ЕСТЬNULL(ОтчетыКомиссионераДоходПоДате.ДоходПоДатеОтчета, ЛОЖЬ) КАК ДоходНаДатуОтчета
				   |ПОМЕСТИТЬ ВТОтчетыКомиссионера
				   |ИЗ
				   |   Документ.ОтчетКомиссионера КАК ОтчетКомиссионера
				   |       ЛЕВОЕ СОЕДИНЕНИЕ ВТОтчетыКомиссионераДоходПоДате КАК ОтчетыКомиссионераДоходПоДате
				   |       ПО ОтчетКомиссионера.Ссылка = ОтчетыКомиссионераДоходПоДате.ОтчетКомиссионераСсылка
				   |ГДЕ
				   |   ОтчетКомиссионера.Организация = &Организация
				   |   И ОтчетКомиссионера.УчитыватьВНУ
				   |   И ОтчетКомиссионера.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |   И ОтчетКомиссионера.Проведен
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   РасчетыСПокупателями.Период КАК Период,
				   |   ВТОтчетыКомиссионера.Ссылка КАК ОтчетКомиссионераСсылка,
				   |   РасчетыСПокупателями.Документ КАК ДокументАванса,
				   |   СУММА(РасчетыСПокупателями.Сумма) КАК Сумма
				   |ПОМЕСТИТЬ ВТЗачтенныеАвансы
				   |ИЗ
				   |   ВТОтчетыКомиссионера КАК ВТОтчетыКомиссионера
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСПокупателями КАК РасчетыСПокупателями
				   |       ПО ВТОтчетыКомиссионера.Ссылка = РасчетыСПокупателями.Регистратор
				   |       И (РасчетыСПокупателями.ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс))
				   |       И (ВТОтчетыКомиссионера.ДоходНаДатуОтчета)
				   |       И НЕ (РасчетыСПокупателями.Документ ССЫЛКА Документ.ОтчетКомиссионера)
				   |СГРУППИРОВАТЬ ПО
				   |   РасчетыСПокупателями.Период,
				   |   РасчетыСПокупателями.Документ,
				   |   ВТОтчетыКомиссионера.Ссылка
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ВТЗачтенныеАвансы.Период КАК Период,
				   |   ВТЗачтенныеАвансы.ОтчетКомиссионераСсылка КАК ОтчетКомиссионераСсылка,
				   |   СУММА(ВТЗачтенныеАвансы.Сумма) КАК ЗачтеноСумма,
				   |   СУММА(РасчетыСПокупателями.СуммаНДС) КАК АвансВсегоНДС,
				   |   СУММА(РасчетыСПокупателями.Сумма) КАК АвансВсего
				   |ПОМЕСТИТЬ ВТПредоплаты
				   |ИЗ
				   |   ВТЗачтенныеАвансы КАК ВТЗачтенныеАвансы
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСПокупателями КАК РасчетыСПокупателями
				   |       ПО (РасчетыСПокупателями.ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс))
				   |       И ВТЗачтенныеАвансы.ДокументАванса = РасчетыСПокупателями.Регистратор
				   |       И (РасчетыСПокупателями.Регистратор = РасчетыСПокупателями.Документ)
				   |СГРУППИРОВАТЬ ПО
				   |   ВТЗачтенныеАвансы.ОтчетКомиссионераСсылка,
				   |   ВТЗачтенныеАвансы.Период
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТЗачтенныеАвансы
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ВТОтчетыКомиссионера.Ссылка КАК ОтчетКомиссионераСсылка,
				   |   СУММА(Продажи.Сумма) КАК Сумма,
				   |   СУММА(Продажи.СуммаНДС) КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТСуммыПродаж
				   |ИЗ
				   |   ВТОтчетыКомиссионера КАК ВТОтчетыКомиссионера
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи КАК Продажи
				   |       ПО ВТОтчетыКомиссионера.Ссылка = Продажи.Регистратор
				   |       И (ВТОтчетыКомиссионера.ДоходНаДатуОтчета)
				   |СГРУППИРОВАТЬ ПО
				   |   ВТОтчетыКомиссионера.Ссылка
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ВТСуммыПродаж.ОтчетКомиссионераСсылка КАК ОтчетКомиссионераСсылка,
				   |   ВТСуммыПродаж.Сумма КАК Сумма,
				   |   ВТСуммыПродаж.СуммаНДС КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТСуммыДоходов
				   |ИЗ
				   |   ВТСуммыПродаж КАК ВТСуммыПродаж
				   |       ЛЕВОЕ СОЕДИНЕНИЕ ВТПредоплаты КАК ВТПредоплаты
				   |       ПО ВТСуммыПродаж.ОтчетКомиссионераСсылка = ВТПредоплаты.ОтчетКомиссионераСсылка
				   |ГДЕ
				   |   ВТПредоплаты.ЗачтеноСумма ЕСТЬ NULL
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ВТСуммыПродаж.ОтчетКомиссионераСсылка,
				   |   0,
				   |   0
				   |ИЗ
				   |   ВТСуммыПродаж КАК ВТСуммыПродаж
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПредоплаты КАК ВТПредоплаты
				   |       ПО ВТСуммыПродаж.ОтчетКомиссионераСсылка = ВТПредоплаты.ОтчетКомиссионераСсылка
				   |ГДЕ
				   |   ВТПредоплаты.ЗачтеноСумма >= ВТСуммыПродаж.Сумма
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ВТСуммыПродаж.ОтчетКомиссионераСсылка,
				   |   ВТСуммыПродаж.Сумма - ВТПредоплаты.ЗачтеноСумма,
				   |   ВТСуммыПродаж.СуммаНДС - ВТПредоплаты.ЗачтеноСумма * ВТПредоплаты.АвансВсегоНДС / ВТПредоплаты.АвансВсего
				   |ИЗ
				   |   ВТСуммыПродаж КАК ВТСуммыПродаж
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПредоплаты КАК ВТПредоплаты
				   |       ПО ВТСуммыПродаж.ОтчетКомиссионераСсылка = ВТПредоплаты.ОтчетКомиссионераСсылка
				   |ГДЕ
				   |   ВТПредоплаты.ЗачтеноСумма < ВТСуммыПродаж.Сумма
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТПредоплаты
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТСуммыПродаж
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ВТОтчетыКомиссионера.Ссылка КАК ОтчетКомиссионераСсылка,
				   |   ВТОтчетыКомиссионера.Номер КАК Номер,
				   |   ВТОтчетыКомиссионера.Дата КАК Дата,
				   |   ВТОтчетыКомиссионера.ВалютаДокумента КАК ВалютаДокумента,
				   |   ВТОтчетыКомиссионера.Контрагент КАК Контрагент,
				   |   ВТОтчетыКомиссионера.Контрагент.НаименованиеПолное КАК КонтрагентНаименованиеПолное,
				   |   ЕСТЬNULL(ВТСуммыДоходов.Сумма, ВТОтчетыКомиссионера.СуммаДокумента) КАК Сумма,
				   |   ЕСТЬNULL(ВТСуммыДоходов.СуммаНДС, 0) КАК СуммаНДС,
				   |   ИСТИНА КАК ДоходПоДатеОтчета
				   |ПОМЕСТИТЬ ВТДоходыОтчетовКомиссионера
				   |ИЗ
				   |   ВТОтчетыКомиссионера КАК ВТОтчетыКомиссионера
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСуммыДоходов КАК ВТСуммыДоходов
				   |       ПО ВТОтчетыКомиссионера.Ссылка = ВТСуммыДоходов.ОтчетКомиссионераСсылка
				   |       И (ВТОтчетыКомиссионера.ДоходНаДатуОтчета)
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ВТОтчетыКомиссионера.Ссылка,
				   |   ВТОтчетыКомиссионера.Номер,
				   |   ВТОтчетыКомиссионера.Дата,
				   |   ВТОтчетыКомиссионера.ВалютаДокумента,
				   |   ВТОтчетыКомиссионера.Контрагент,
				   |   ВТОтчетыКомиссионера.Контрагент.НаименованиеПолное,
				   |   ВТОтчетыКомиссионера.СуммаВознаграждения,
				   |   0,
				   |   ЛОЖЬ
				   |ИЗ
				   |   ВТОтчетыКомиссионера КАК ВТОтчетыКомиссионера
				   |ГДЕ
				   |   НЕ ВТОтчетыКомиссионера.ДоходНаДатуОтчета
				   |   И ВТОтчетыКомиссионера.ВидОперации В (&ОперацииПродажа)
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ВТОтчетыКомиссионера.Ссылка,
				   |   ВТОтчетыКомиссионера.Номер,
				   |   ВТОтчетыКомиссионера.Дата,
				   |   ВТОтчетыКомиссионера.ВалютаДокумента,
				   |   ВТОтчетыКомиссионера.Контрагент,
				   |   ВТОтчетыКомиссионера.Контрагент.НаименованиеПолное,
				   |   -ВТОтчетыКомиссионера.СуммаВознаграждения,
				   |   0,
				   |   ЛОЖЬ
				   |ИЗ
				   |   ВТОтчетыКомиссионера КАК ВТОтчетыКомиссионера
				   |ГДЕ
				   |   НЕ ВТОтчетыКомиссионера.ДоходНаДатуОтчета
				   |   И НЕ ВТОтчетыКомиссионера.ВидОперации В (&ОперацииПродажа)
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТСуммыДоходов
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТОтчетыКомиссионера";

	Запрос.Выполнить();

	УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц, "ВТОтчетыКомиссионераДоходПоДате");

КонецПроцедуры

Процедура ПолучитьВТИсключеннаяОплатаОтПокупателя(МенеджерВременныхТаблиц, Организация, НачалоПериода, ОкончаниеПериода)

	ПолучитьВТОтчетыКомиссионераДоходПоДате(МенеджерВременныхТаблиц, Организация, НачалоПериода, ОкончаниеПериода);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ОкончаниеПериода);

	Запрос.Текст = "ВЫБРАТЬ
				   |	РасчетыСПокупателями.Регистратор КАК ПлатежныйДокумент,
				   |	РасчетыСПокупателями.Документ КАК ДокументРасчетов,
				   |	РасчетыСПокупателями.ИндексСтрокиДокумента + 1 КАК НомерСтроки,
				   |	РасчетыСПокупателями.Сумма КАК Сумма,
				   |	РасчетыСПокупателями.СуммаНДС КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТИсключеннаяОплатаПредварительно
				   |ИЗ
				   |	РегистрНакопления.РасчетыСПокупателями КАК РасчетыСПокупателями
				   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтчетыКомиссионераДоходПоДате КАК ОтчетыКомиссионераДоходПоДате
				   |		ПО РасчетыСПокупателями.Документ = ОтчетыКомиссионераДоходПоДате.ОтчетКомиссионераСсылка
				   |		И РасчетыСПокупателями.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |		И НЕ РасчетыСПокупателями.Регистратор ССЫЛКА Документ.ОтчетКомиссионера
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	ВТИсключеннаяОплатаПредварительно.ПлатежныйДокумент КАК ПлатежныйДокумент,
				   |	ВТИсключеннаяОплатаПредварительно.ДокументРасчетов КАК ДокументРасчетов,
				   |	0 КАК НомерСтроки,
				   |	СУММА(ВТИсключеннаяОплатаПредварительно.Сумма) КАК Сумма,
				   |	СУММА(ВТИсключеннаяОплатаПредварительно.СуммаНДС) КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТИсключеннаяОплатаОтПокупателя
				   |ИЗ
				   |	ВТИсключеннаяОплатаПредварительно КАК ВТИсключеннаяОплатаПредварительно
				   |СГРУППИРОВАТЬ ПО
				   |	ВТИсключеннаяОплатаПредварительно.ПлатежныйДокумент,
				   |	ВТИсключеннаяОплатаПредварительно.ДокументРасчетов
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |	ВТИсключеннаяОплатаПредварительно.ПлатежныйДокумент,
				   |	НЕОПРЕДЕЛЕНО,
				   |	ВТИсключеннаяОплатаПредварительно.НомерСтроки,
				   |	СУММА(ВТИсключеннаяОплатаПредварительно.Сумма),
				   |	СУММА(ВТИсключеннаяОплатаПредварительно.СуммаНДС)
				   |ИЗ
				   |	ВТИсключеннаяОплатаПредварительно КАК ВТИсключеннаяОплатаПредварительно
				   |СГРУППИРОВАТЬ ПО
				   |	ВТИсключеннаяОплатаПредварительно.ПлатежныйДокумент,
				   |	ВТИсключеннаяОплатаПредварительно.НомерСтроки
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТИсключеннаяОплатаПредварительно";

	Запрос.Выполнить();

	УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц, "ВТОтчетыКомиссионераДоходПоДате");

КонецПроцедуры

Процедура ПолучитьВТДоходыЭквайринг(МенеджерВременныхТаблиц, Организация, НачалоПериода, ОкончаниеПериода)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ОкончаниеПериода);
    
    // ВТОплатыПоКартам - Суммы документов, которые должны быть отражены в НУ, определяются по Расшифровке платежа.
    // ВТЭквайрингПоДокументам - Денежный документ с детализация до документа расчета.
    // ВТДокументыРасчетовЭквайринга - данные документов из детализации - общая сумма и сумма НДС.
    // ВТСуммыПоДетализации - ВТЭквайрингПоДокументам соединяется с ВТДокументыРасчетовЭквайринга, 
    //      получается сумма - по денежному документу, а сумма НДС пересчитывается, исходя из общей суммы и суммы НДС 
    //      расчетного документа.
    // ВТДоходыЭквайринг - итоговая таблица, объединяет сумму по детализации и остатка сумм из ВТОплатыПоКартам,
    //      которые не получилось определить по документам расчетов. Сумма комиссии берется из ВТОплатыПоКартам.0

	Запрос.Текст = "ВЫБРАТЬ
				   |   ПоступлениеНаСчет.Ссылка КАК Ссылка,
				   |   ЛОЖЬ КАК НастройкиУчетаПоСтрокам,
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии) КАК Сумма,
				   |   СУММА(ВЫБОР
				   |       КОГДА ЕСТЬNULL(СтавкиНДС.Ставка, 0) = 0
				   |           ТОГДА 0
				   |       ИНАЧЕ (ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии) * СтавкиНДС.Ставка / (100 +
				   |           СтавкиНДС.Ставка)
				   |   КОНЕЦ) КАК СуммаНДС,
				   |   0 КАК Возврат,
				   |   0 КАК ВозвратНДС,
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетовКомиссии) КАК СуммаКомиссии
				   |ПОМЕСТИТЬ ВТОплатыПоКартам
				   |ИЗ
				   |   Документ.ПоступлениеНаСчет КАК ПоступлениеНаСчет
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеНаСчет.РасшифровкаПлатежа КАК ТаблицаРасшифровка
				   |           ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтавкиНДС КАК СтавкиНДС
				   |           ПО ТаблицаРасшифровка.СтавкаНДС = СтавкиНДС.Ссылка
				   |       ПО ПоступлениеНаСчет.Ссылка = ТаблицаРасшифровка.Ссылка
				   |       И ПоступлениеНаСчет.Организация = &Организация
				   |       И ПоступлениеНаСчет.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |       И ПоступлениеНаСчет.Проведен
				   |       И ПоступлениеНаСчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеНаСчет.ПоступлениеОплатыПоКартам)
				   |       И ПоступлениеНаСчет.УчитыватьВНУ
				   |       И
				   |           ПоступлениеНаСчет.ПоложениеНастроекНалоговогоУчета <> ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |СГРУППИРОВАТЬ ПО
				   |   ПоступлениеНаСчет.Ссылка
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ПоступлениеНаСчет.Ссылка,
				   |   ИСТИНА,
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии),
				   |   СУММА(ВЫБОР
				   |       КОГДА ЕСТЬNULL(СтавкиНДС.Ставка, 0) = 0
				   |           ТОГДА 0
				   |       ИНАЧЕ (ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии) * СтавкиНДС.Ставка / (100 +
				   |           СтавкиНДС.Ставка)
				   |   КОНЕЦ),
				   |   0,
				   |   0,
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетовКомиссии)
				   |ИЗ
				   |   Документ.ПоступлениеНаСчет КАК ПоступлениеНаСчет
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеНаСчет.РасшифровкаПлатежа КАК ТаблицаРасшифровка
				   |           ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтавкиНДС КАК СтавкиНДС
				   |           ПО ТаблицаРасшифровка.СтавкаНДС = СтавкиНДС.Ссылка
				   |       ПО ПоступлениеНаСчет.Ссылка = ТаблицаРасшифровка.Ссылка
				   |       И ПоступлениеНаСчет.Организация = &Организация
				   |       И ПоступлениеНаСчет.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |       И ПоступлениеНаСчет.Проведен
				   |       И ПоступлениеНаСчет.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоступлениеНаСчет.ПоступлениеОплатыПоКартам)
				   |       И
				   |           ПоступлениеНаСчет.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |       И ТаблицаРасшифровка.УчитыватьВНУ
				   |СГРУППИРОВАТЬ ПО
				   |   ПоступлениеНаСчет.Ссылка
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   РасходСоСчета.Ссылка,
				   |   ЛОЖЬ,
				   |   0,
				   |   0,
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии),
				   |   СУММА(ВЫБОР
				   |       КОГДА ЕСТЬNULL(СтавкиНДС.Ставка, 0) = 0
				   |           ТОГДА 0
				   |       ИНАЧЕ (ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии) * СтавкиНДС.Ставка / (100 +
				   |           СтавкиНДС.Ставка)
				   |   КОНЕЦ),
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетовКомиссии)
				   |ИЗ
				   |   Документ.РасходСоСчета КАК РасходСоСчета
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходСоСчета.РасшифровкаПлатежа КАК ТаблицаРасшифровка
				   |           ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтавкиНДС КАК СтавкиНДС
				   |           ПО ТаблицаРасшифровка.СтавкаНДС = СтавкиНДС.Ссылка
				   |       ПО РасходСоСчета.Ссылка = ТаблицаРасшифровка.Ссылка
				   |       И РасходСоСчета.Организация = &Организация
				   |       И РасходСоСчета.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |       И РасходСоСчета.Проведен
				   |       И РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ВозвратОплатыНаПлатежныеКарты)
				   |       И РасходСоСчета.УчитыватьВНУ
				   |       И РасходСоСчета.ПоложениеНастроекНалоговогоУчета <> ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |СГРУППИРОВАТЬ ПО
				   |   РасходСоСчета.Ссылка
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   РасходСоСчета.Ссылка,
				   |   ИСТИНА,
				   |   0,
				   |   0,
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии),
				   |   СУММА(ВЫБОР
				   |       КОГДА ЕСТЬNULL(СтавкиНДС.Ставка, 0) = 0
				   |           ТОГДА 0
				   |       ИНАЧЕ (ТаблицаРасшифровка.СуммаРасчетов + ТаблицаРасшифровка.СуммаРасчетовКомиссии) * СтавкиНДС.Ставка / (100 +
				   |           СтавкиНДС.Ставка)
				   |   КОНЕЦ),
				   |   СУММА(ТаблицаРасшифровка.СуммаРасчетовКомиссии)
				   |ИЗ
				   |   Документ.РасходСоСчета КАК РасходСоСчета
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходСоСчета.РасшифровкаПлатежа КАК ТаблицаРасшифровка
				   |           ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтавкиНДС КАК СтавкиНДС
				   |           ПО ТаблицаРасшифровка.СтавкаНДС = СтавкиНДС.Ссылка
				   |       ПО РасходСоСчета.Ссылка = ТаблицаРасшифровка.Ссылка
				   |       И РасходСоСчета.Организация = &Организация
				   |       И РасходСоСчета.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |       И РасходСоСчета.Проведен
				   |       И РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ВозвратОплатыНаПлатежныеКарты)
				   |       И ТаблицаРасшифровка.УчитыватьВНУ
				   |       И РасходСоСчета.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |СГРУППИРОВАТЬ ПО
				   |   РасходСоСчета.Ссылка
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ПоступлениеНаСчет.Ссылка КАК ДенежныйДокумент,
				   |   ТаблицаДокумента.Документ КАК ДокументРасчетов,
				   |   СУММА(ТаблицаДокумента.СуммаРасчетов) КАК СуммаРасчетов,
				   |   СУММА(ТаблицаДокумента.СуммаРасчетовВозврата) КАК СуммаВозврата
				   |ПОМЕСТИТЬ ВТЭквайрингПоДокументам
				   |ИЗ
				   |   ВТОплатыПоКартам КАК ПоступлениеНаСчет
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеНаСчет.ЭквайринговыеОперации КАК ТаблицаДокумента
				   |       ПО ПоступлениеНаСчет.Ссылка = ТаблицаДокумента.Ссылка
				   |       И НЕ ПоступлениеНаСчет.НастройкиУчетаПоСтрокам
				   |СГРУППИРОВАТЬ ПО
				   |   ПоступлениеНаСчет.Ссылка,
				   |   ТаблицаДокумента.Документ
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ПоступлениеНаСчет.Ссылка,
				   |   ТаблицаДокумента.Документ,
				   |   СУММА(ТаблицаДокумента.СуммаРасчетов),
				   |   СУММА(ТаблицаДокумента.СуммаРасчетовВозврата)
				   |ИЗ
				   |   ВТОплатыПоКартам КАК ПоступлениеНаСчет
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеНаСчет.ЭквайринговыеОперации КАК ТаблицаДокумента
				   |       ПО ПоступлениеНаСчет.Ссылка = ТаблицаДокумента.Ссылка
				   |       И ПоступлениеНаСчет.НастройкиУчетаПоСтрокам
				   |       И ТаблицаДокумента.УчитыватьВНУ
				   |СГРУППИРОВАТЬ ПО
				   |   ПоступлениеНаСчет.Ссылка,
				   |   ТаблицаДокумента.Документ
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   РасходСоСчета.Ссылка,
				   |   ТаблицаДокумента.Документ,
				   |   0,
				   |   СУММА(ТаблицаДокумента.СуммаРасчетовВозврата)
				   |ИЗ
				   |   ВТОплатыПоКартам КАК РасходСоСчета
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходСоСчета.ЭквайринговыеОперации КАК ТаблицаДокумента
				   |       ПО РасходСоСчета.Ссылка = ТаблицаДокумента.Ссылка
				   |       И НЕ РасходСоСчета.НастройкиУчетаПоСтрокам
				   |СГРУППИРОВАТЬ ПО
				   |   РасходСоСчета.Ссылка,
				   |   ТаблицаДокумента.Документ
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   РасходСоСчета.Ссылка,
				   |   ТаблицаДокумента.Документ,
				   |   0,
				   |   СУММА(ТаблицаДокумента.СуммаРасчетовВозврата)
				   |ИЗ
				   |   ВТОплатыПоКартам КАК РасходСоСчета
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходСоСчета.ЭквайринговыеОперации КАК ТаблицаДокумента
				   |       ПО РасходСоСчета.Ссылка = ТаблицаДокумента.Ссылка
				   |       И РасходСоСчета.НастройкиУчетаПоСтрокам
