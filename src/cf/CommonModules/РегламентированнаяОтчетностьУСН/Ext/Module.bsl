			ИначеЕсли Строка.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтКурьерскойКомпанииПочты Тогда
				Строка.Содержание = НСтр(
					"ru = 'Поступление безналичных денежных средств от курьерской компании или почты'");
			ИначеЕсли Строка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Покупателю Тогда
				НазваниеКонтрагента = "";
				Если ЗначениеЗаполнено(Строка.ЮридическоеНазваниеКонтрагента) Тогда
					НазваниеКонтрагента = СокрЛП(Строка.ЮридическоеНазваниеКонтрагента);
				Иначе
					НазваниеКонтрагента = СокрЛП(Строка.Контрагент);
				КонецЕсли;

				Строка.Содержание = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
                    НСтр("ru = 'Списание с банковского счета: возврат денежных средств покупателю ""%1""'"),
					НазваниеКонтрагента);
			ИначеЕсли Строка.ВидОперации = Перечисления.ВидыОперацийРасходИзКассы.Покупателю Тогда
				НазваниеКонтрагента = "";
				Если ЗначениеЗаполнено(Строка.ЮридическоеНазваниеКонтрагента) Тогда
					НазваниеКонтрагента = СокрЛП(Строка.ЮридическоеНазваниеКонтрагента);
				Иначе
					НазваниеКонтрагента = СокрЛП(Строка.Контрагент);
				КонецЕсли;

				Строка.Содержание = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
                    НСтр("ru = 'Выдача из кассы: возврат денежных средств покупателю ""%1""'"), НазваниеКонтрагента);
			КонецЕсли;

			Если ЗначениеЗаполнено(Строка.НазначениеПлатежа) Тогда
				Строка.Содержание = Строка.Содержание + ", " + Символы.ПС + СокрЛП(Строка.НазначениеПлатежа);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	ДокументФормирования.ЗаписиКнигаДоходовПатент.Загрузить(РезультатЗапроса);
	ДокументФормирования.Записать(РежимЗаписиДокумента.Проведение);

КонецПроцедуры

// Выполняет формирование записей патента в фоновом режиме.
//
// Параметры:
//   Параметры - Структура
//     * Патент - СправочникСсылка.Патенты
//   ВременноеХранилищеРезультата - УникальныйИдентификатор
//
Процедура ВыполнитьФормированияЗаписейПатента_ФоновоеЗадание(Параметры, ВременноеХранилищеРезультата) Экспорт
	Перем Патент;

	Если Параметры <> Неопределено Тогда
		Параметры.Свойство("Патент", Патент);
	КонецЕсли;

	Если Патент = Неопределено Тогда
		ЗаписиСформированы = Истина;
	Иначе
		ВыполнитьФормированияЗаписейПатента(Патент);
		ЗаписиСформированы = Истина;
	КонецЕсли;

	ПоместитьВоВременноеХранилище(ЗаписиСформированы, ВременноеХранилищеРезультата);

КонецПроцедуры

#КонецОбласти


// Считывает текст из двоичных данных, используя поток в памяти.
//
// Параметры:
//   ДвоичныеДанные - ДвоичныеДанные - Двоичные данные текста.
//   Кодировка - КодировкаТекста - Кодировка текста.
//
// Возвращаемое значение:
//   Строка - Результат чтения текста из двоичных данных.
//
Функция ДвоичныеДанныеВСтроку(ДвоичныеДанные, Кодировка)
	БуферДвоичныхДанных = ПолучитьБуферДвоичныхДанныхИзДвоичныхДанных(ДвоичныеДанные);
	ПотокВПамяти = Новый ПотокВПамяти(БуферДвоичныхДанных);
	ЧтениеТекста = Новый ЧтениеТекста(ПотокВПамяти, Кодировка);
	Возврат ЧтениеТекста.Прочитать();
КонецФункции

// Загружает классификатор из веб-сервиса и возвращает его "Распакованные" данные.
//
// Параметры:
//   Идентификатор - Строка - Идентификатор классификатора в веб-сервисе.
//
// Возвращаемое значение:
//   Структура - Данные классификатора.
//
Функция ПолучитьДанныеКлассификатораИзСервиса(Идентификатор)
	МодульРаботаСКлассификаторами = ОбщегоНазначения.ОбщийМодуль("РаботаСКлассификаторами");

	Идентификаторы = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Идентификатор);
	РезультатПолученияФайлов = МодульРаботаСКлассификаторами.ПолучитьФайлыКлассификаторов(Идентификаторы);

	Если РезультатПолученияФайлов.КодОшибки = "ОбновлениеНеТребуется" Тогда
		Возврат Неопределено;
	КонецЕсли;

	Значение = Неопределено;
	Если Не ЗначениеЗаполнено(РезультатПолученияФайлов.КодОшибки) И ТипЗнч(
		РезультатПолученияФайлов.ДанныеКлассификаторов) = Тип("ТаблицаЗначений") Тогда
		СтрокаТаблицы = РезультатПолученияФайлов.ДанныеКлассификаторов.Найти(Идентификатор, "Идентификатор");
		Если СтрокаТаблицы <> Неопределено Тогда
			Попытка
				ДвоичныеДанные = ПолучитьИзВременногоХранилища(СтрокаТаблицы.АдресФайла);
				ТекстXML = ДвоичныеДанныеВСтроку(ДвоичныеДанные, КодировкаТекста.UTF8);
				Значение = ОбщегоНазначения.ЗначениеИзСтрокиXML(ТекстXML);
			Исключение
				Значение = Неопределено;
				ИнформацияОбОшибке = ИнформацияОбОшибке();
				РезультатПолученияФайлов.КодОшибки = "ОшибкаИзвлеченияЗначенияИзФайла";
				РезультатПолученияФайлов.СообщениеОбОшибке = ОбработкаОшибок.КраткоеПредставлениеОшибки(
					ИнформацияОбОшибке);
				РезультатПолученияФайлов.ИнформацияОбОшибке = ОбработкаОшибок.ПодробноеПредставлениеОшибки(
					ИнформацияОбОшибке);
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;

	Если Значение = Неопределено Тогда
		УровеньЖурнала = УровеньЖурналаРегистрации.Ошибка;
		ТекстЖурнала = НСтр("ru = 'При получении классификатора %1 из веб-сервиса возникла ошибка:
							|Код: %2
							|Краткая информация: %3
							|Подробная информация:
							|%4'");
		ТекстЖурнала = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстЖурнала, Идентификатор, Строка(
			РезультатПолученияФайлов.КодОшибки), Строка(РезультатПолученияФайлов.СообщениеОбОшибке), Строка(
			РезультатПолученияФайлов.ИнформацияОбОшибке));
	Иначе
		УровеньЖурнала = УровеньЖурналаРегистрации.Информация;
		ТекстЖурнала = СтрШаблон(НСтр("ru = 'Файл классификатора %1 получен из веб-сервиса.'"), Идентификатор);
	КонецЕсли;
	ЗаписьЖурналаРегистрации(
        НСтр("ru = 'Нормативно-правовая информация БЗК'", ОбщегоНазначения.КодОсновногоЯзыка()), УровеньЖурнала, , ,
		ТекстЖурнала);

	Возврат Значение;
КонецФункции

Процедура ПолучитьВТПредоплатаПоЧекамККМ(МенеджерВременныхТаблиц, Организации, НачалоПериода, ОкончаниеПериода)

	ПолучитьВТПериодыСтавокНДСНаУСН(МенеджерВременныхТаблиц, Организации, НачалоПериода, ОкончаниеПериода);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", ОкончаниеПериода);
	Запрос.УстановитьПараметр("Организации", Организации);

	Запрос.Текст =
	"ВЫБРАТЬ
	|   ОтчетОРозничныхПродажах.Организация КАК Организация,
	|   ОтчетОРозничныхПродажах.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТДокументыОРП_ФР
	|ИЗ
	|   Документ.ОтчетОРозничныхПродажах КАК ОтчетОРозничныхПродажах
	|ГДЕ
	|   ОтчетОРозничныхПродажах.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|   И ОтчетОРозничныхПродажах.Проведен
	|   И ОтчетОРозничныхПродажах.Организация В (&Организации)
	|   И ОтчетОРозничныхПродажах.КассаККМ.ТипКассы = ЗНАЧЕНИЕ(Перечисление.ТипыКассККМ.ФискальныйРегистратор)
	|   И ОтчетОРозничныхПродажах.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|   ОтчетОРозничныхПродажах.Организация,
	|   ОтчетОРозничныхПродажах.Ссылка
	|ИЗ
	|   Документ.ОтчетОРозничныхПродажах КАК ОтчетОРозничныхПродажах
	|ГДЕ
	|   ОтчетОРозничныхПродажах.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
	|   И ОтчетОРозничныхПродажах.Проведен
	|   И ОтчетОРозничныхПродажах.Организация В (&Организации)
	|   И ОтчетОРозничныхПродажах.КассаККМ.ТипКассы = ЗНАЧЕНИЕ(Перечисление.ТипыКассККМ.ФискальныйРегистратор)
	|   И ОтчетОРозничныхПродажах.ПоложениеНастроекНалоговогоУчета <> ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
	|   И ОтчетОРозничныхПродажах.Патент = ЗНАЧЕНИЕ(Справочник.Патенты.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|   ЧекиККМИЧекиККМНаВозврат.Ссылка.КассоваяСмена КАК КассоваяСмена,
	|   ЧекиККМИЧекиККМНаВозврат.Организация КАК Организация,
	|   ЧекиККМИЧекиККМНаВозврат.Ссылка КАК ЧекККМ,
	|   ЧекиККМИЧекиККМНаВозврат.ПолученаПредоплата КАК ПолученаПредоплата,
	|   0 КАК СуммаПредоплаты,
	|   ЧекиККМИЧекиККМНаВозврат.СуммаНДС КАК СуммаНДСПолученнойПредоплаты,
	|   0 КАК СуммаНДСПредоплаты,
	|   ЧекиККМИЧекиККМНаВозврат.Патент КАК Патент
	|ПОМЕСТИТЬ ВТ_ДанныеИзЧеков
	|ИЗ
	|   (ВЫБРАТЬ
	|       ВТДокументыОРП_ФР.Организация КАК Организация,
	|       ЧекККМ.Ссылка КАК Ссылка,
	|       ЧекККМ.СуммаДокумента КАК ПолученаПредоплата,
	|       ВЫБОР КОГДА ЕСТЬNULL(ПериодыСтавокУСН.ЗначениеСтавкиНДС, 0) = 0 ТОГДА 0
	|           ИНАЧЕ ЧекККМ.СуммаДокумента * ПериодыСтавокУСН.ЗначениеСтавкиНДС / (100 + ПериодыСтавокУСН.ЗначениеСтавкиНДС)
	|       КОНЕЦ КАК СуммаНДС,
	|       ЧекККМ.Патент КАК Патент
	|   ИЗ
	|       Документ.ЧекККМ КАК ЧекККМ
	|           ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыОРП_ФР КАК ВТДокументыОРП_ФР
	|           ПО (ВТДокументыОРП_ФР.Ссылка = ЧекККМ.КассоваяСмена)
	|               И (ЧекККМ.Проведен)
	|               И (ЧекККМ.НомерЧекаККМ > 0)
	|               И (ЧекККМ.ОперацияСДенежнымиСредствами)
	|               И ЧекККМ.ПоложениеПатента <> ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
	|           ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыСтавокНДСНаУСН КАК ПериодыСтавокУСН
	|               ПО ЧекККМ.Организация = ПериодыСтавокУСН.Организация
	|                   И ЧекККМ.Патент = ЗНАЧЕНИЕ(Справочник.Патенты.ПустаяСсылка)
	|                   И ЧекККМ.Дата МЕЖДУ ПериодыСтавокУСН.ПериодНачало И ПериодыСтавокУСН.ПериодОкончание
	|   
	|   ОБЪЕДИНИТЬ ВСЕ
	|   
	|   ВЫБРАТЬ
	|       ВТДокументыОРП_ФР.Организация,
	|       ЧекККМ.Ссылка,
	|       СУММА(ЧекККМЗапасы.Сумма),
	|       СУММА(ЧекККМЗапасы.СуммаНДС),
	|       ЧекККМЗапасы.Патент
	|   ИЗ
	|       Документ.ЧекККМ КАК ЧекККМ
	|           ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыОРП_ФР КАК ВТДокументыОРП_ФР
	|           ПО (ВТДокументыОРП_ФР.Ссылка = ЧекККМ.КассоваяСмена)
	|               И (ЧекККМ.Проведен)
	|               И (ЧекККМ.НомерЧекаККМ > 0)
	|               И (ЧекККМ.ОперацияСДенежнымиСредствами)
	|               И ЧекККМ.ПоложениеПатента = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
	|           ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Запасы КАК ЧекККМЗапасы
	|           ПО ЧекККМ.Ссылка = ЧекККМЗапасы.Ссылка
	|   
	|   СГРУППИРОВАТЬ ПО
	|       ВТДокументыОРП_ФР.Организация,
	|       ЧекККМ.Ссылка,
	|       ЧекККМЗапасы.Патент
	|   
	|   ОБЪЕДИНИТЬ ВСЕ
	|   
	|   ВЫБРАТЬ
	|       ВТДокументыОРП_ФР.Организация,
	|       ЧекККМВозврат.Ссылка,
	|       -ЧекККМВозврат.СуммаДокумента,
	|       ВЫБОР КОГДА ЕСТЬNULL(ПериодыСтавокУСН.ЗначениеСтавкиНДС, 0) = 0 ТОГДА 0
	|           ИНАЧЕ -ЧекККМВозврат.СуммаДокумента * ПериодыСтавокУСН.ЗначениеСтавкиНДС / (100 + ПериодыСтавокУСН.ЗначениеСтавкиНДС)
	|       КОНЕЦ,
	|       ЧекККМВозврат.ЧекККМ.Патент
	|   ИЗ
	|       Документ.ЧекККМВозврат КАК ЧекККМВозврат
	|           ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыОРП_ФР КАК ВТДокументыОРП_ФР
	|           ПО (ВТДокументыОРП_ФР.Ссылка = ЧекККМВозврат.КассоваяСмена)
	|               И (ЧекККМВозврат.Проведен)
	|               И (ЧекККМВозврат.НомерЧекаККМ > 0)
	|               И (ЧекККМВозврат.ОперацияСДенежнымиСредствами)
	|               И ЧекККМВозврат.ПоложениеПатента <> ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
	|           ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыСтавокНДСНаУСН КАК ПериодыСтавокУСН
	|               ПО ЧекККМВозврат.Организация = ПериодыСтавокУСН.Организация
	|                   И ЧекККМВозврат.Дата МЕЖДУ ПериодыСтавокУСН.ПериодНачало И ПериодыСтавокУСН.ПериодОкончание
	|                   И ЧекККМВозврат.ЧекККМ.Патент = ЗНАЧЕНИЕ(Справочник.Патенты.ПустаяСсылка)
	|   
	|   ОБЪЕДИНИТЬ ВСЕ
	|   
	|   ВЫБРАТЬ
	|       ВТДокументыОРП_ФР.Организация,
	|       ЧекККМВозврат.Ссылка,
	|       -СУММА(ЧекККМВозвратЗапасы.Сумма),
	|       -СУММА(ЧекККМВозвратЗапасы.СуммаНДС),
	|       ЧекККМВозвратЗапасы.Патент
	|   ИЗ
	|       Документ.ЧекККМВозврат КАК ЧекККМВозврат
	|           ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыОРП_ФР КАК ВТДокументыОРП_ФР
	|           ПО (ВТДокументыОРП_ФР.Ссылка = ЧекККМВозврат.КассоваяСмена)
	|               И (ЧекККМВозврат.Проведен)
	|               И (ЧекККМВозврат.НомерЧекаККМ > 0)
	|               И (ЧекККМВозврат.ОперацияСДенежнымиСредствами)
	|               И ЧекККМВозврат.ПоложениеПатента = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
	|           ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМВозврат.Запасы КАК ЧекККМВозвратЗапасы
	|           ПО ЧекККМВозврат.Ссылка = ЧекККМВозвратЗапасы.Ссылка
	|   
	|   СГРУППИРОВАТЬ ПО
	|       ВТДокументыОРП_ФР.Организация,
	|       ЧекККМВозврат.Ссылка,
	|       ЧекККМВозвратЗапасы.Патент) КАК ЧекиККМИЧекиККМНаВозврат
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|   ЧекККМ.КассоваяСмена,
	|   ВТДокументыОРП_ФР.Организация,
	|   ЧекККМПредоплата.Ссылка,
	|   0,
	|   ЧекККМПредоплата.СуммаРасчетов,
	|   0,
	|   ВЫБОР КОГДА ЕСТЬNULL(ПериодыСтавокУСН.ЗначениеСтавкиНДС, 0) = 0
	|       ТОГДА 0
	|       ИНАЧЕ ЧекККМПредоплата.СуммаРасчетов * ПериодыСтавокУСН.ЗначениеСтавкиНДС / (100 + ПериодыСтавокУСН.ЗначениеСтавкиНДС)
	|   КОНЕЦ,
	|   ЧекККМПредоплата.Ссылка.Патент
	|ИЗ
	|   Документ.ЧекККМ КАК ЧекККМ
	|       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Предоплата КАК ЧекККМПредоплата
	|       ПО ЧекККМ.Ссылка = ЧекККМПредоплата.Ссылка
	|       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыОРП_ФР КАК ВТДокументыОРП_ФР
	|       ПО (ВТДокументыОРП_ФР.Ссылка = ЧекККМ.КассоваяСмена)
	|           И (ЧекККМ.Проведен)
	|           И (ЧекККМ.НомерЧекаККМ > 0)
	|           И (НЕ ЧекККМ.ОперацияСДенежнымиСредствами)
	|       ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыСтавокНДСНаУСН КАК ПериодыСтавокУСН
	|       ПО ЧекККМ.Организация = ПериодыСтавокУСН.Организация
	|           И ЧекККМ.Дата МЕЖДУ ПериодыСтавокУСН.ПериодНачало И ПериодыСтавокУСН.ПериодОкончание
	|           И ЧекККМ.Патент = ЗНАЧЕНИЕ(Справочник.Патенты.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|   ЧекККМВозврат.КассоваяСмена,
	|   ВТДокументыОРП_ФР.Организация,
	|   ЧекККМВозвратПредоплата.Ссылка,
	|   0,
	|   -ЧекККМВозвратПредоплата.СуммаРасчетов,
	|   0,
	|   ВЫБОР КОГДА ЕСТЬNULL(ПериодыСтавокУСН.ЗначениеСтавкиНДС, 0) = 0
	|       ТОГДА 0
	|       ИНАЧЕ -ЧекККМВозвратПредоплата.СуммаРасчетов * ПериодыСтавокУСН.ЗначениеСтавкиНДС / (100 + ПериодыСтавокУСН.ЗначениеСтавкиНДС)
	|   КОНЕЦ,
	|   ЧекККМВозвратПредоплата.Ссылка.Патент
	|ИЗ
	|   Документ.ЧекККМВозврат КАК ЧекККМВозврат
	|       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМВозврат.Предоплата КАК ЧекККМВозвратПредоплата
	|       ПО ЧекККМВозврат.Ссылка = ЧекККМВозвратПредоплата.Ссылка
	|       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыОРП_ФР КАК ВТДокументыОРП_ФР
	|       ПО (ВТДокументыОРП_ФР.Ссылка = ЧекККМВозврат.КассоваяСмена)
	|           И (ЧекККМВозврат.Проведен)
	|           И (ЧекККМВозврат.НомерЧекаККМ > 0)
	|           И (НЕ ЧекККМВозврат.ОперацияСДенежнымиСредствами)
	|       ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыСтавокНДСНаУСН КАК ПериодыСтавокУСН
	|       ПО ЧекККМВозврат.Организация = ПериодыСтавокУСН.Организация
	|           И ЧекККМВозврат.Дата МЕЖДУ ПериодыСтавокУСН.ПериодНачало И ПериодыСтавокУСН.ПериодОкончание
	|           И ЧекККМВозврат.Патент = ЗНАЧЕНИЕ(Справочник.Патенты.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|   ВТ_ДанныеИзЧеков.КассоваяСмена КАК ОтчетРП,
	|   ВТ_ДанныеИзЧеков.Организация КАК Организация,
	|   ВТ_ДанныеИзЧеков.Патент КАК Патент,
	|   СУММА(ВТ_ДанныеИзЧеков.СуммаПредоплаты) КАК СуммаПредоплаты,
	|   СУММА(ВТ_ДанныеИзЧеков.ПолученаПредоплата) КАК ПолученаПредоплата,
	|   СУММА(ВТ_ДанныеИзЧеков.СуммаНДСПредоплаты) КАК СуммаНДСПредоплаты,
	|   СУММА(ВТ_ДанныеИзЧеков.СуммаНДСПолученнойПредоплаты) КАК СуммаНДСПолученнойПредоплаты
	|ПОМЕСТИТЬ ВТПредоплатаПоЧекамККМ
	|ИЗ
	|   ВТ_ДанныеИзЧеков КАК ВТ_ДанныеИзЧеков
	|
	|СГРУППИРОВАТЬ ПО
	|   ВТ_ДанныеИзЧеков.Организация,
	|   ВТ_ДанныеИзЧеков.КассоваяСмена,
	|   ВТ_ДанныеИзЧеков.Патент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТДокументыОРП_ФР
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ДанныеИзЧеков";

	Запрос.Выполнить();

	УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц, "ВТПериодыСтавокНДСНаУСН");

