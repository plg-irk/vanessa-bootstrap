// Процедура формирует записи по прочим доходам
//
// Параметры:
//      Организация - СправочникСсылка - Организация, по которой необходимо провести формирования
//      ПериодФормирования - Дата - дата окончания квартала, за который нужно провести формирования
//      Результат - Структура - структура результата
//      МенеджерВТ - МенеджерВременныхТаблиц 
//
Процедура ВыполнитьФормированиеПоДоходам(Организация, ПериодФормирования, Результат, МенеджерВТ) Экспорт

	ДокументФормирования = Результат.ДокументФормирования;
	НачалоПериода = НачалоКвартала(ПериодФормирования);
	КонецПериода = КонецДня(ПериодФормирования);

	ПолучитьВТДенежныеДокументыДоходы(МенеджерВТ, Организация, НачалоПериода, КонецПериода,
		РегламентированнаяОтчетностьУСНКлиентСервер.ВидыОперацийДоходыУСН());
	ПолучитьВТДоходыОтчетовКомиссионера(МенеджерВТ, Организация, НачалоПериода, КонецПериода);
	ПолучитьВТИсключеннаяОплатаОтПокупателя(МенеджерВТ, Организация, НачалоПериода, КонецПериода);
	ПолучитьВТПериодыСтавокНДСНаУСН(МенеджерВТ, Организация, НачалоПериода, КонецПериода);
	ПолучитьВТДоходыЭквайринг(МенеджерВТ, Организация, НачалоПериода, КонецПериода);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст = "ВЫБРАТЬ
				   |   ТаблицаОплатаПлатежнымиКартами.Ссылка КАК Ссылка,
				   |   СУММА(ЕСТЬNULL(ТаблицаОплатаПлатежнымиКартами.Сумма, 0)) КАК СуммаБезналичнойОплаты
				   |ПОМЕСТИТЬ ВТРозницаОплатаКартами
				   |ИЗ
				   |   Документ.ОтчетОРозничныхПродажах.БезналичнаяОплата КАК ТаблицаОплатаПлатежнымиКартами
				   |ГДЕ
				   |   (ТаблицаОплатаПлатежнымиКартами.Ссылка.УчитыватьВНУ
				   |               И ТаблицаОплатаПлатежнымиКартами.Ссылка.ПоложениеНастроекНалоговогоУчета <> ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |           ИЛИ ТаблицаОплатаПлатежнымиКартами.Ссылка.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |               И ТаблицаОплатаПлатежнымиКартами.УчитыватьВНУ)
				   |   И ТаблицаОплатаПлатежнымиКартами.Ссылка.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
				   |   И НЕ ТаблицаОплатаПлатежнымиКартами.Ссылка.ПометкаУдаления
				   |   И ТаблицаОплатаПлатежнымиКартами.Ссылка.Проведен
				   |   И ТаблицаОплатаПлатежнымиКартами.Ссылка.Организация = &Организация
				   |   И ТаблицаОплатаПлатежнымиКартами.ВидОплаты <> ЗНАЧЕНИЕ(Перечисление.ВидыБезналичныхОплат.ВыдачаНаличных)
				   |
				   |СГРУППИРОВАТЬ ПО
				   |   ТаблицаОплатаПлатежнымиКартами.Ссылка
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ОплатаОбороты.Регистратор КАК ДокументОплаты,
				   |   ОплатаОбороты.Документ КАК ДокументРасчетов,
				   |   СУММА(ОплатаОбороты.СуммаОплатыОборот) КАК СуммаОплаты
				   |ПОМЕСТИТЬ ВТСуммыОплатыПоДокументам
				   |ИЗ
				   |   РегистрНакопления.ОплатаДокументов.Обороты(&НачалоПериода, &ОкончаниеПериода, Регистратор) КАК ОплатаОбороты
				   |СГРУППИРОВАТЬ ПО
				   |   ОплатаОбороты.Регистратор,
				   |   ОплатаОбороты.Документ
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ПродажиОбороты.Регистратор КАК Документ,
				   |   ПродажиОбороты.СуммаБезНДСОборот + ПродажиОбороты.НДСОборот КАК Сумма,
				   |   ПродажиОбороты.НДСОборот КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТСуммыНДСПоДокументамДетально
				   |ИЗ
				   |   РегистрНакопления.НДСЗаписиКнигиПродаж.Обороты(&НачалоПериода, &ОкончаниеПериода, Регистратор,) КАК ПродажиОбороты
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ПокупкиОбороты.Регистратор,
				   |   -ПокупкиОбороты.СуммаБезНДСОборот - ПокупкиОбороты.НДСОборот,
				   |   -ПокупкиОбороты.НДСОборот
				   |ИЗ
				   |   РегистрНакопления.НДСЗаписиКнигиПокупок.Обороты(&НачалоПериода, &ОкончаниеПериода, Регистратор,) КАК ПокупкиОбороты
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |   ПродажиПредыдущие.Регистратор,
				   |   СУММА(ПродажиПредыдущие.СуммаБезНДС + ПродажиПредыдущие.НДС),
				   |   СУММА(ПродажиПредыдущие.НДС)
				   |ИЗ
				   |   РегистрНакопления.НДСЗаписиКнигиПродаж КАК ПродажиПредыдущие
				   |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСуммыОплатыПоДокументам
				   |	   ПО ПродажиПредыдущие.Регистратор = ВТСуммыОплатыПоДокументам.ДокументРасчетов
				   |       И ПродажиПредыдущие.Период < &НачалоПериода
				   |СГРУППИРОВАТЬ ПО
				   |   ПродажиПредыдущие.Регистратор
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТСуммыОплатыПоДокументам
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ДетальныеЗаписи.Документ КАК Документ,
				   |   СУММА(ДетальныеЗаписи.Сумма) КАК Сумма,
				   |   СУММА(ДетальныеЗаписи.СуммаНДС) КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТСуммыНДСПоДокументам
				   |ИЗ
				   |   ВТСуммыНДСПоДокументамДетально КАК ДетальныеЗаписи
				   |
				   |СГРУППИРОВАТЬ ПО
				   |   ДетальныеЗаписи.Документ
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТСуммыНДСПоДокументамДетально
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   БезналРозница.Ссылка КАК Ссылка,
				   |   БезналРозница.СуммаБезналичнойОплаты КАК СуммаБезналичнойОплаты,
				   |   ВЫБОР
				   |       КОГДА ЕСТЬNULL(СуммыНДС.СуммаНДС, 0) = 0 ТОГДА 0
				   |       КОГДА ЕСТЬNULL(СуммыНДС.Сумма, 0) = 0 ТОГДА 0
				   |       КОГДА СуммыНДС.Сумма = БезналРозница.СуммаБезналичнойОплаты ТОГДА СуммыНДС.СуммаНДС
				   |       ИНАЧЕ ВЫРАЗИТЬ(СуммыНДС.СуммаНДС * БезналРозница.СуммаБезналичнойОплаты / СуммыНДС.Сумма КАК ЧИСЛО(15, 2))
				   |   КОНЕЦ КАК СуммаНДСБезналичнойОплаты
				   |ПОМЕСТИТЬ ВТОплатаКартами
				   |ИЗ
				   |   ВТРозницаОплатаКартами КАК БезналРозница
				   |       ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыНДСПоДокументам КАК СуммыНДС
				   |       ПО БезналРозница.Ссылка = СуммыНДС.Документ
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ ВТРозницаОплатаКартами
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |   ОтчетОРозничныхПродажахЗапасы.Ссылка КАК Ссылка,
				   |   СУММА(ЕСТЬNULL(ОтчетОРозничныхПродажахЗапасы.Всего, 0)) КАК СуммаДокумента,
				   |   СУММА(ЕСТЬNULL(ОтчетОРозничныхПродажахЗапасы.СуммаНДС, 0)) КАК СуммаНДС
				   |ПОМЕСТИТЬ ВТЗапасы
				   |ИЗ
				   |   Документ.ОтчетОРозничныхПродажах.Запасы КАК ОтчетОРозничныхПродажахЗапасы
				   |ГДЕ
				   |   (ОтчетОРозничныхПродажахЗапасы.Ссылка.УчитыватьВНУ
				   |               И ОтчетОРозничныхПродажахЗапасы.Ссылка.ПоложениеНастроекНалоговогоУчета <> ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |           ИЛИ ОтчетОРозничныхПродажахЗапасы.Ссылка.ПоложениеНастроекНалоговогоУчета = ЗНАЧЕНИЕ(Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти)
				   |               И ОтчетОРозничныхПродажахЗапасы.УчитыватьВНУ)
				   |   И ОтчетОРозничныхПродажахЗапасы.Ссылка.Дата МЕЖДУ &НачалоПериода И &ОкончаниеПериода
