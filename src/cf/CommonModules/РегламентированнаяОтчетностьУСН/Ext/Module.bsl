// Уничтожает временные таблицы в менеджере временных таблиц
//
// Параметры:
//  МенеджерВременныхТаблиц  - МенеджерВременныхТаблиц
//  СписокТаблиц             - Строка    - список имен таблиц, разделенных запятыми
//
Процедура УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц, СписокТаблиц)

	СхемаЗапроса = Новый СхемаЗапроса;

	ИменаТаблиц = СтрРазделить(СписокТаблиц, ",", Ложь);
	Для Каждого ИмяТаблицы Из ИменаТаблиц Цикл
		ЗапросУничтожения = СхемаЗапроса.ПакетЗапросов.Добавить(Тип("ЗапросУничтоженияТаблицыСхемыЗапроса"));
		ЗапросУничтожения.ИмяТаблицы = СокрЛП(ИмяТаблицы);
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	Запрос.Выполнить();

КонецПроцедуры

