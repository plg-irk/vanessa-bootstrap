Процедура ЗарегистрироватьИзмененияОбъектовСПредопределеннымиЭлементами(ПараметрыОбработчика) Экспорт
	
	Если ОбщегоНазначения.ЭтоПодчиненныйУзелРИБ() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	АвтономнаяРабота.Ссылка КАК Ссылка
	|ИЗ
	|	ПланОбмена.АвтономнаяРабота КАК АвтономнаяРабота
	|ГДЕ
	|	НЕ АвтономнаяРабота.ЭтотУзел
	|	И НЕ АвтономнаяРабота.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Полный.Ссылка
	|ИЗ
	|	ПланОбмена.Полный КАК Полный
	|ГДЕ
	|	НЕ Полный.ЭтотУзел
	|	И НЕ Полный.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СОтборами.Ссылка
	|ИЗ
	|	ПланОбмена.СОтборами КАК СОтборами
	|ГДЕ
	|	НЕ СОтборами.ЭтотУзел
	|	И НЕ СОтборами.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ПланыОбмена.ЗарегистрироватьИзменения(Выборка.Ссылка, Метаданные.ПланыВидовХарактеристик.ОбъектыАдресацииЗадач);
		ПланыОбмена.ЗарегистрироватьИзменения(Выборка.Ссылка, Метаданные.Справочники.РолиИсполнителей);
	КонецЦикла;
	
КонецПроцедуры

