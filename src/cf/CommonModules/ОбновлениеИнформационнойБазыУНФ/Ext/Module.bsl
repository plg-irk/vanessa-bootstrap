Процедура ОбновитьОсновныеСведенияКонтрагентов(Параметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ОсновныеСведенияАктуализированы = ЛОЖЬ";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Параметры.ОбработкаЗавершена = Ложь;
	МетаданныеСправочника = Метаданные.Справочники.Контрагенты;
	ПолноеИмяОбъекта = МетаданныеСправочника.ПолноеИмя();
	
	ПроблемныхОбъектов = 0;
	ОбъектовОбработано = 0;
	ПлохиеДанные = Новый Соответствие;
	
	Пока Выборка.Следующий() Цикл
		НачатьТранзакцию(); 
		Попытка             

			ПричинаИсключения = "Блокировка";
			
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяОбъекта);
			ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Ссылка);
			Блокировка.Заблокировать();
			
			КонтрагентОбъект = Выборка.Ссылка.ПолучитьОбъект();
			КонтрагентОбъект.ОбменДанными.Загрузка = Истина;
			
			// Если объект ранее был удален или обработан другими сеансами, пропускаем его.
			Если КонтрагентОбъект = Неопределено
				Или КонтрагентОбъект.ОсновныеСведенияАктуализированы <> Ложь Тогда
				ЗафиксироватьТранзакцию();
				Продолжить;
			КонецЕсли;
			КонтрагентОбъект.ОсновныеСведения = "";
			КонтрагентОбъект.СформироватьОсновныеСведения();
			КонтрагентОбъект.ОсновныеСведенияАктуализированы = Истина;
			
			ПричинаИсключения = "Запись";
			Если КонтрагентОбъект.Модифицированность() Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(КонтрагентОбъект);
			КонецЕсли;
			
			ОбъектовОбработано = ОбъектовОбработано + 1;
			ЗафиксироватьТранзакцию();
			
		Исключение
			ОтменитьТранзакцию();
			
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось обработать контрагента по причине:
			|%1'"), ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), УровеньЖурналаРегистрации.Предупреждение,
			Метаданные.Справочники.Контрагенты, КонтрагентОбъект.Ссылка, ТекстСообщения);
			
			// Если не удалось обработать какой-либо заказ из-за конфликта блокировки, повторяем попытку снова.
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			Если ПричинаИсключения <> "Блокировка" Тогда
				ВызватьИсключение ТекстСообщения;
			КонецЕсли;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов <> 0 Тогда
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Процедуре ОбновитьОсновныеСведенияКонтрагентов не удалось обработать некоторых контрагентов (пропущены): %1'"),
		ПроблемныхОбъектов);
		ВызватьИсключение ТекстСообщения;
	Иначе
		ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(), УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Контрагенты,,
		НСтр("ru = 'Процедура ОбновитьОсновныеСведенияКонтрагентов обработала очередную порцию контрагентов.'"));
		Для Каждого НеобработанныйОбъект Из ПлохиеДанные Цикл
			ОбновлениеИнформационнойБазы.ЗарегистрироватьПроблемуСДанными(НеобработанныйОбъект.Ключ,
			НеобработанныйОбъект.Значение);
		КонецЦикла;
	КонецЕсли;
	
	Если ОбъектовОбработано = 0 И ПроблемныхОбъектов = 0 Тогда
		Параметры.ОбработкаЗавершена = Истина;
	КонецЕсли;
	
КонецПроцедуры

