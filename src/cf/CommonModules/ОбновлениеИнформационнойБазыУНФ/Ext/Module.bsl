Процедура ОбновитьМакетыИПоляШаблоновЧека(Параметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХранилищеШаблоновРМК.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ХранилищеШаблоновРМК КАК ХранилищеШаблоновРМК
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Параметры.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
	Выборка = РезультатЗапроса.Выбрать();
	НачатьТранзакцию();
	Попытка
		Пока Выборка.Следующий() Цикл
			ШаблонЧекаСсылка = Выборка.Ссылка;
			ШаблонЧекаОбъект = ШаблонЧекаСсылка.ПолучитьОбъект();
			
			ШаблонЧекаОбъект.Заблокировать();
			
			// Обновление макета
			СКД = Новый СхемаКомпоновкиДанных;
			ОбщегоНазначенияРМКПереопределяемый.ЗаполнитьМакетШаблонаЧека(СКД);
			ШаблонЧекаОбъект.СхемаКомпоновкиДанных = Новый ХранилищеЗначения(СКД);
			
			// Обновление полей шаблона
			ИзмененыСтрокиШаблона = Ложь;
			ДанныеШаблона = Неопределено;
			Шаблон = Неопределено;
			ВычисляемыеСтрокиШаблона = Новый Массив;
			
			Если ЗначениеЗаполнено(ШаблонЧекаОбъект.Шаблон) Тогда
				ДанныеШаблона = ШаблонЧекаОбъект.Шаблон.Получить();
			КонецЕсли;
			Если ТипЗнч(ДанныеШаблона) = Тип("Структура")
				И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДанныеШаблона, "Шаблон") Тогда
				
				Шаблон = ДанныеШаблона.Шаблон;
			КонецЕсли;
			Если ТипЗнч(Шаблон) = Тип("ДеревоЗначений") Тогда
				ИмяКолонкиВычислять = "Вычислять";
				ИмяКолонкиЭлемент = "Элемент";
				ИмяКолонкиЗаголовок = "Заголовок";
				ОписаниеТипаСтрока = Новый ОписаниеТипов("Строка");
				Если Шаблон.Колонки.Найти(ИмяКолонкиВычислять) = Неопределено Тогда
					Шаблон.Колонки.Добавить(ИмяКолонкиВычислять, Новый ОписаниеТипов("Булево"));
				КонецЕсли;
				Если Шаблон.Колонки.Найти(ИмяКолонкиЭлемент) = Неопределено Тогда
					Шаблон.Колонки.Добавить(ИмяКолонкиЭлемент, ОписаниеТипаСтрока);
				КонецЕсли;
				Если Шаблон.Колонки.Найти(ИмяКолонкиЗаголовок) = Неопределено Тогда
					Шаблон.Колонки.Добавить(ИмяКолонкиЗаголовок, ОписаниеТипаСтрока);
				КонецЕсли;
				Если Шаблон.Строки.Количество() Тогда
					ПараметрыОтбора = Новый Структура;
					ПараметрыОтбора.Вставить(ИмяКолонкиВычислять, Истина);
					ПараметрыОтбора.Вставить("ИмяКолонки", "Текст");
					ВычисляемыеСтрокиШаблона = Шаблон.Строки.НайтиСтроки(ПараметрыОтбора, Истина);
				КонецЕсли;
			КонецЕсли;
			
			Для каждого СтрокаШаблона Из ВычисляемыеСтрокиШаблона Цикл
				Если СтрокаШаблона.Элемент = "СтруктурнаяЕдиница" Тогда
					СтрокаШаблона.Элемент = "ТорговыйОбъект";
					СтрокаШаблона.Заголовок = НСтр("ru = 'Торговый объект'", КодОсновногоЯзыка);
					ИзмененыСтрокиШаблона = Истина;
				ИначеЕсли СтрокаШаблона.Элемент = "Наименование" Тогда
					СтрокаШаблона.Элемент = "НоменклатураНаименование";
					СтрокаШаблона.Заголовок = НСтр("ru = 'Номенклатура.Наименование'", КодОсновногоЯзыка);
					ИзмененыСтрокиШаблона = Истина;
				Иначе
					// Действие не требуется
				КонецЕсли;
			КонецЦикла;
			
			Если ИзмененыСтрокиШаблона Тогда
				ДанныеШаблона.Шаблон = Шаблон;
				ШаблонЧекаОбъект.Шаблон = Новый ХранилищеЗначения(ДанныеШаблона);
			КонецЕсли;
			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ШаблонЧекаОбъект, Ложь, Ложь);
			
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ВызватьИсключение ТекстОшибки;
	КонецПопытки;
		
	Параметры.ОбработкаЗавершена = Истина;
	
КонецПроцедуры

Процедура ЗаполнитьСчетУчетаЛичныхСредствПредпринимателя() Экспорт
	
	НачатьТранзакцию();
	Попытка
		ВыборкаОрганизации = Справочники.Организации.Выбрать();
		Пока ВыборкаОрганизации.Следующий() Цикл
			ОрганизацияОбъект = ВыборкаОрганизации.ПолучитьОбъект();
			ОрганизацияОбъект.СчетУчетаЛичныхСредствПредпринимателя =
				ПредопределенноеЗначение("ПланСчетов.Управленческий.НераспределеннаяПрибыль");
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ОрганизацияОбъект);
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Заполнение счета учета личных средств предпринимателя.'", ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки);
		
		Возврат;
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ОбновитьШаблоныСообщений(Параметры) Экспорт
	
	ИдентификаторыДляЗамены = ИдентификаторыДляЗамены();
	СписокКлючей = Новый Массив;
	Для каждого Элемент Из ИдентификаторыДляЗамены Цикл
		СписокКлючей.Добавить(Элемент.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 100
	|	ШаблоныСообщенийПечатныеФормыИВложения.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШаблоныСообщений.ПечатныеФормыИВложения КАК ШаблоныСообщенийПечатныеФормыИВложения
	|ГДЕ
	|	ШаблоныСообщенийПечатныеФормыИВложения.Идентификатор В(&Идентификаторы)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка";
	
	Запрос.УстановитьПараметр("Идентификаторы", СписокКлючей);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Параметры.ОбработкаЗавершена = Истина;
		Возврат;
	Иначе
		Параметры.ОбработкаЗавершена = Ложь;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЭлементСправочника = Выборка.Ссылка;
		ШаблоныОбъект = ЭлементСправочника.ПолучитьОбъект();
		
		Для каждого СтрокаТаблицы Из ШаблоныОбъект.ПечатныеФормыИВложения Цикл
			Если Не СписокКлючей.Найти(СтрокаТаблицы.Идентификатор) = Неопределено Тогда
				СтрокаТаблицы.Идентификатор = ИдентификаторыДляЗамены[СтрокаТаблицы.Идентификатор];
			КонецЕсли;
		КонецЦикла;
		
		ШаблоныОбъект.ПодписьИПечать = Истина;
		ШаблоныОбъект.Записать();
	КонецЦикла;
	
КонецПроцедуры

