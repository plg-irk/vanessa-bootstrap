	НачатьТранзакцию();
	Попытка

		Блокировка.Заблокировать();
		
		Выборка 	  = РезультатЗапроса.Выбрать();
	
		Пока Выборка.Следующий() Цикл

			НастройкаОнлайнОплаты 	= Выборка.Ссылка.ПолучитьОбъект();
			ДополнительнаяНастройка	= НастройкаОнлайнОплаты.ДополнительныеНастройки.Добавить();

