Процедура ВКонтактеПеренестиТокеныВБезопасноеХранилище(ПараметрыОбработчика) Экспорт
	
	ЗапросТекст =
	"ВЫБРАТЬ
	|	ИнтеграцияСМагазинамиСоцСетей.Ссылка КАК Ссылка
	|ИЗ
	|	ПланОбмена.ИнтеграцияСМагазинамиСоцСетей КАК ИнтеграцияСМагазинамиСоцСетей
	|ГДЕ
	|	ПОДСТРОКА(ИнтеграцияСМагазинамиСоцСетей.УдалитьТокенДоступа, 1, 10) > """"";

	ЗапросОбъект = Новый Запрос(ЗапросТекст);
	
	НачатьТранзакцию();
	
	Попытка
		
		ЗапросВыборка = ЗапросОбъект.Выполнить().Выбрать();
		Если ЗапросВыборка.Количество() = 0 Тогда
			ОтменитьТранзакцию();
			ПараметрыОбработчика.ОбработкаЗавершена = Истина;
			Возврат;
		КонецЕсли;
		
		АвторизацияВКонтактеПараметры = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.АвторизацияВКонтактеПараметрыНовый(
		ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииOAUTH());
		
		Пока ЗапросВыборка.Следующий() Цикл
        
			Объект = ЗапросВыборка.Ссылка.ПолучитьОбъект();
        	
        	// запись в безопасное хранилище
        	АвторизацияВКонтактеПараметры.access_token = Объект.УдалитьТокенДоступа;
			АвторизацияВКонтактеПараметры.ОкончанияДействияТокенаДоступа = Объект.УдалитьОкончанияДействияТокенаДоступа;

			АвторизацияВКонтактеПараметры.access_token_community = Объект.УдалитьТокенДоступаСообщества;
			АвторизацияВКонтактеПараметры.ОкончанияДействияТокенДоступаСообщества = Объект.УдалитьОкончанияДействияТокенДоступаСообщества;

			ИнтеграцияСМагазинамиСоцСетейСервер.АвторизацияВКонтактеПараметрыВБезопасноеХранилищеЗаписать( 
			ЗапросВыборка.Ссылка, АвторизацияВКонтактеПараметры );
		
			// удаление значений в объекте
			
			Объект.УдалитьТокенДоступа = "";
			Объект.УдалитьОкончанияДействияТокенаДоступа = "";

			Объект.УдалитьТокенДоступаСообщества = "";
			Объект.УдалитьОкончанияДействияТокенДоступаСообщества = "";
			
			Объект.УдалитьСтрокаАвторизации = "";
			Объект.УдалитьСтрокаАвторизацииСообщества = "";
			
			
			Объект.ОбменДанными.Загрузка = Истина;
			Объект.Записать();
			
		КонецЦикла;
		ЗафиксироватьТранзакцию();
		
		ПараметрыОбработчика.ОбработкаЗавершена = Истина;
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
КонецПроцедуры

Процедура УстановитьПрефиксыШтучныхФасованныхТоваров(ПараметрыОбработчика) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПравилаОбменаСПодключаемымОборудованиемOffline.Ссылка
	|ИЗ
	|	Справочник.ПравилаОбменаСПодключаемымОборудованиемOffline КАК ПравилаОбменаСПодключаемымОборудованиемOffline
	|ГДЕ
	|	ПравилаОбменаСПодключаемымОборудованиемOffline.ПрефиксШтучногоФасованногоТовара = 0");
	
	НачатьТранзакцию();
	
	Попытка
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			ПравилоОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ПравилоОбъект.ПрефиксШтучногоФасованногоТовара = 3;
			
