// Процедура - Установить служебные функциональные опции возможностей приложений
//	
//	Предназначена для заполнения служебных опций при обновлении с 3.0.9 на 3.0.10
//	
Процедура УстановитьСлужебныеФункциональныеОпцииВозможностейПриложений() Экспорт
	
	Если ОбщегоНазначения.ЭтоПодчиненныйУзелРИБ() Тогда
		Возврат;
	КонецЕсли;
	
	Если ПустаяСтрока( ВидыПриложенийСервер.ИмяТекущегоВидаПриложения() ) Тогда
		ВозможностиПриложения.УстановитьВидПриложенияПустое(Неопределено);
		Константы.ТребуетсяКонтрольДоговоровКонтрагентовВДенежныхДокументах.Установить(Истина);
		Возврат;
	КонецЕсли;
	
	ЭтоБизнесПриложение = ВозможностиПриложения.ЭтоБизнесПриложение();
	ЭтоРозница = ВозможностиПриложения.ЭтоРозница();

	Константы.ПереносАдресатовЗавершен.Установить(Истина);
	Константы.ПереносКонтактовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносКонтактовЛидовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносКонтрагентовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносЛидовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносФизическихЛицВАдресатыЗавершен.Установить(Истина);
	
	Если ЭтоБизнесПриложение Тогда
		
	Иначе
	
		Константы.ИспользоватьАвансовыеОтчеты.Установить(Истина);
		Константы.ИспользоватьГоловнуюОрганизацию.Установить(Истина);
		Константы.ИспользоватьДоставкуВЗаказеПокупателя.Установить(Истина);
		Константы.ИспользоватьЗагрузкуДанныхИзБП3.Установить(Истина);
		Константы.ИспользоватьЗагрузкуДанныхИзИнтернетМагазина.Установить(Истина);
		Константы.ИспользоватьЗагрузкуДанныхИзРТ23.Установить(Истина);
		Константы.ИспользоватьЗагрузкуДанныхИзУТ103.Установить(Истина);
		Константы.ИспользоватьИнтеграцииСистемыВзаимодействия.Установить(Истина);
		Константы.ИспользоватьИсториюРеквизитов.Установить(Истина);
		Константы.ИспользоватьКассы.Установить(Истина);
		Константы.ИспользоватьКатегорииНоменклатуры.Установить(Истина);
		Константы.ИспользоватьКомплектации.Установить(Истина);
