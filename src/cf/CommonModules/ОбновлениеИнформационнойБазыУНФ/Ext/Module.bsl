Процедура ЗаполнитьВидыПоступленияОплатыСПБ(ПараметрыОбработчика) Экспорт
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	СоответствиеНастроекИнтеграции.ТорговыйОбъект КАК ТорговыйОбъект,
	|	СоответствиеНастроекИнтеграции.Организация КАК Организация,
	|	СоответствиеНастроекИнтеграции.СпособОплаты КАК СпособОплаты,
	|	СоответствиеНастроекИнтеграции.Интеграция КАК Интеграция,
	|	СоответствиеНастроекИнтеграции.Интеграция.ИдентификаторУчастника КАК ИдентификаторУчастника
	|ИЗ
	|	РегистрСведений.СоответствиеНастроекИнтеграцииУНФ КАК СоответствиеНастроекИнтеграции
	|ГДЕ
	|	СоответствиеНастроекИнтеграции.ВидПоступленияОплаты = ЗНАЧЕНИЕ(Перечисление.ВидыПоступленияОплатыСБПb2b.ПустаяСсылка)";
	
	Запрос = Новый Запрос(ТекстЗапроса);    
	
	НачатьТранзакцию();
	
	Попытка
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			НастройкиИнтеграции = РегистрыСведений.СоответствиеНастроекИнтеграцииУНФ.СоздатьНаборЗаписей();
			
			НастройкиИнтеграции.Отбор.Организация.Установить(Выборка.Организация);
			НастройкиИнтеграции.Отбор.ТорговыйОбъект.Установить(Выборка.ТорговыйОбъект);
			НастройкиИнтеграции.Отбор.СпособОплаты.Установить(Выборка.СпособОплаты);
			
			Если ЗначениеЗаполнено(Выборка.Интеграция) Тогда
				НастройкиИнтеграции.Прочитать();
			КонецЕсли;
			
			Если НастройкиИнтеграции.Количество() Тогда
				
				Запись					= НастройкиИнтеграции[0];
				НастройкиУчастникаСБП  = СистемаБыстрыхПлатежейСлужебный.НастройкиУчастникаСБП(Выборка.ИдентификаторУчастника);
				
				Если ЗначениеЗаполнено(НастройкиУчастникаСБП) Тогда
					ВидПоступленияb2b = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(НастройкиУчастникаСБП, "ВидПоступленияb2b");
				КонецЕсли;
				
			КонецЕсли;
			
			Если ВидПоступленияb2b = "PAYMENT_FROM_THE_BUYER" Тогда
				Запись.ВидПоступленияОплаты = Перечисления.ВидыПоступленияОплатыСБПb2b.ОплатаОтПокупателя;
			ИначеЕсли ВидПоступленияb2b = "ACQUIRING" Тогда
				Запись.ВидПоступленияОплаты = Перечисления.ВидыПоступленияОплатыСБПb2b.Эквайринг;
			Иначе
				Запись.ВидПоступленияОплаты = Перечисления.ВидыПоступленияОплатыСБПb2b.Эквайринг;
			КонецЕсли;
			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НастройкиИнтеграции);
			
		КонецЦикла;
		ЗафиксироватьТранзакцию();
		
		ПараметрыОбработчика.ОбработкаЗавершена = Истина;
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
КонецПроцедуры

