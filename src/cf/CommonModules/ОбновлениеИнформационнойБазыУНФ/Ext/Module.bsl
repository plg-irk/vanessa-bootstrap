		КонецЦикла;
	
		ЗафиксироватьТранзакцию();
		
		ПараметрыОбработчика.ОбработкаЗавершена = Истина;
		
	Исключение

		ОтменитьТранзакцию();
		
		ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
КонецПроцедуры

Процедура НастроитьАвтоматическуюРучнуюСкидку(ПараметрыОбработчика) Экспорт
	
