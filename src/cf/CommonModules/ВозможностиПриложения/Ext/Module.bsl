// Установить вид приложения "Управление нашей фирмой"
// 
// Параметры:
//  РезультатОбработки - Неопределено, Структура - См. ВидыПриложенийСервер.НовыйРезультатОбработки
//
Процедура УстановитьВидПриложенияУНФ(РезультатОбработки) Экспорт
	
	УстановитьТекущийРежимРаботыУНФ();
	
	РежимЗапускаУНФ = Константы.ТекущийРежимЗапускаУНФ.Получить();
	
	ЭтоНастольноеПриложениеУНФ 	= РежимЗапускаУНФ = Перечисления.РежимыЗапускаУНФ.НастольноеПриложение;
	ЭтоМобильноеПриложениеУНФ 	= РежимЗапускаУНФ = Перечисления.РежимыЗапускаУНФ.МобильноеПриложение;
	ЭтоМобильноеПриложениеУНФ20 = РежимЗапускаУНФ = Перечисления.РежимыЗапускаУНФ.МобильноеПриложение20;
	
	#Область УНФ_ПодсистемаCRM_ПриПервомЗапуске
	
	Константы.ИспользоватьШаблоныСообщений.Установить(Истина);
	Константы.ИспользоватьНапоминанияПользователя.Установить(Истина);
	Константы.ФункциональнаяОпцияКонтрольДоговоров.Установить(Перечисления.ВидыКонтроляДоговоровПриПроведении.НеПроводить);
	Константы.ИспользоватьПодсистемуCRM.Установить(Истина);
	Константы.ИспользоватьЛиды.Установить(Истина);
	Константы.ИспользоватьЗадачиСотрудников.Установить(Истина);
	Константы.ИспользоватьИсточникиПривлечения.Установить(Истина);
	Константы.ИспользоватьЗаданияНаРаботу.Установить(Истина);
	Константы.ИспользоватьЗагрузкуЭлектроннойПочты.Установить(Истина);
	Константы.ИспользоватьОбменСGoogleCalendar.Установить(Истина);
	Константы.ИспользоватьАссистентаУправления.Установить(Истина);
	Константы.ИспользоватьШаблоныПечатиОфисныхДокументов.Установить(Истина);
	Константы.ИспользоватьИнтеграцииСистемыВзаимодействия.Установить(Истина);
	Константы.ИспользоватьЗакрытиеМесяца.Установить(Истина);
	
	Константы.ПереносАдресатовЗавершен.Установить(Истина);
	Константы.ПереносКонтактовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносКонтактовЛидовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносКонтрагентовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносЛидовВАдресатыЗавершен.Установить(Истина);
	Константы.ПереносФизическихЛицВАдресатыЗавершен.Установить(Истина);
		
	// включение констант используемых только в настольном приложении
	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ИспользоватьДоговорыКонтрагентов.Установить(Истина);
		Константы.ИспользоватьПрисоединенныеФайлы.Установить(Истина);
		Константы.ОтображатьПереходКСпискуПокупателей.Установить(Истина);
		Константы.ИспользоватьКалендариСотрудников.Установить(Истина);
		Константы.ИспользоватьСобытия.Установить(Истина);
	КонецЕсли;
	
	
	Константы.ИспользоватьПодсистемуКаналыПродаж.Установить( Истина );
	Константы.ИспользоватьРабочиеПроцессы.Установить( Истина );
	
	#КонецОбласти
	
	
	#Область УНФ_ПодсистемаЗакупки_ПриПервомЗапуске
	
	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ИспользоватьПодсистемуЗакупки.Установить(Истина);
		Константы.ОтображатьДокументыПоЗакупкам.Установить(Истина);
	КонецЕсли;

	#КонецОбласти

	
	#Область УНФ_ПодсистемаКомпания_ПриПервомЗапуске

	Константы.ИспользоватьАнализБизнеса.Установить(Истина);
	Константы.ИспользоватьФинансовыеОперации.Установить(Истина);
	Константы.ИспользоватьРасчетФинансовогоРезультата.Установить(Истина);
	Константы.ИспользоватьРаспределениеЗатрат.Установить(Истина);
	Константы.КонтролироватьОстаткиПриПроведении.Установить(Истина);
	Константы.ИспользоватьДополнительныеРеквизитыИСведения.Установить(Истина);
	Константы.ИспользоватьЗагрузкуДанныхИзБП3.Установить(Истина);
	Константы.ИспользоватьЗагрузкуДанныхИзРТ23.Установить(Истина);
	Константы.ИспользоватьЗагрузкуДанныхИзУТ103.Установить(Истина);
	Константы.ИспользоватьЗагрузкуДанныхИзИнтернетМагазина.Установить(Истина);
	
	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ОтображатьСчетаУчета.Установить(Истина);
		Константы.ИспользоватьПодсистемуКомпания.Установить(Истина);
		Константы.ОтображатьПульсБизнеса.Установить(Истина);
		Константы.ОтображатьТекущиеДела.Установить(Истина);
	КонецЕсли;
	
	#КонецОбласти

	
	#Область УНФ_ПодсистемаМетодическаяПоддержка_ПриПервомЗапуске

	Константы.ИспользоватьВидеоматериалы.Установить(Истина);
	
	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ОтображатьМакетОписанияИзменений.Установить(Истина);
		Константы.ОтображатьПереходКПанелиОтчетовОсновнойРаздел.Установить(Истина);
		Константы.ИспользоватьФормуИнформационногоЦентра.Установить(Истина);
		Константы.ОтображатьБыстрыеДействия.Установить(Истина);
		Константы.ОтображатьПодсказкиРазделовЕБВ.Установить(Истина);
	КонецЕсли;
	
	#КонецОбласти

	
	#Область УНФ_ПодсистемаМобильныеПриложения_ПриПервомЗапуске
	
	Если ЭтоНастольноеПриложениеУНФ ИЛИ ЭтоМобильноеПриложениеУНФ Тогда
		Константы.ОтображатьКомандуПереходаКМП.Установить(Истина);
	КонецЕсли;
	
	Если ЭтоМобильноеПриложениеУНФ20 Тогда
		Константы.ОтображатьМусорнуюКорзину.Установить(Истина);
		Константы.ИспользоватьФормуВиджетаНаНачальнойСтранице.Установить(Истина);
		Константы.ИспользоватьСинхронизациюМП.Установить(Истина);
		Константы.ИспользоватьПодсистемуКомпанияМП.Установить(Истина);
		Константы.ИспользоватьПодсистемуПродажиМП.Установить(Истина);
		Константы.ИспользоватьПодсистемуПроизводствоМП.Установить(Истина);
	КонецЕсли;
	
	Если ЭтоМобильноеПриложениеУНФ Тогда
		Константы.ИспользоватьФормуВиджетаНаНачальнойСтранице.Установить(Истина);
	КонецЕсли;
	
	#КонецОбласти

	
	#Область УНФ_ПодсистемаПродажи_ПриПервомЗапуске	
	Константы.ИспользоватьАктыВыполненныхРабот.Установить(Истина);
	Константы.ИспользоватьПроцессыСостояний.Установить(Истина);
	Константы.ИспользоватьСчетаНаОплату.Установить(Истина);
	Константы.ФункциональнаяОпцияУчетЦенПродажи.Установить(Истина); 
	Константы.ИспользоватьУстановкуЦен.Установить(Истина);
	
	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ИспользоватьПодсистемуПродажи.Установить(Истина); 
		Константы.ИспользоватьВидыЦен.Установить(Истина);
		Константы.ИспользоватьАналогиНоменклатуры.Установить(Истина);
		Константы.ОтображатьДокументыПоПродажам.Установить(Истина);
		Константы.ОтображатьПереходКСпискуНоменклатурыВГлавном.Установить(Истина);
	КонецЕсли;
		
	#КонецОбласти

	
	#Область УНФ_ПодсистемаСклад_ПриПервомЗапуске
	
	Константы.СчетУчетаЗапасовДляНоменклатурыПоУмолчанию.Установить(ПланыСчетов.Управленческий.СырьеИМатериалы);
	Константы.ИспользоватьПередачуВЭксплуатацию.Установить(Истина);
	Константы.ИспользоватьВозвратИзЭксплуатации.Установить(Истина);
	
	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ИспользоватьПодсистемуСклад.Установить(Истина);
		Константы.ИспользоватьУправлениеЗапасами.Установить(Истина);
		Константы.ОтображатьДокументыПоЗапасам.Установить(Истина);
		Константы.ОтображатьДокументыПоСкладу.Установить(Истина);
	КонецЕсли;
	
	#КонецОбласти

	
	#Область УНФ_ПодсистемаДеньги_ПриПервомЗапуске
	
	Константы.ВестиРасчетыПоДоговорам.Установить(Истина);
	Константы.ВестиРасчетыПоДокументам.Установить(Истина);
	Константы.ВестиРасчетыПоЗаказам.Установить(Истина);
	Константы.ВестиУчетОплатыПоСчетам.Установить(Истина);
	Константы.ИспользоватьАвансовыеОтчеты.Установить(Истина);

	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ИспользоватьПолныеВозможностиБанковскихСчетов.Установить(Истина);
		Константы.ОтображатьДокументыПоБанку.Установить(Истина); 
		Константы.ИспользоватьБанкИКассу.Установить(Истина);
		Константы.ИспользоватьПодсистемуДеньги.Установить(Истина);
		Константы.ОтображатьСпискиДенежныхДокументов.Установить(Истина);
	КонецЕсли;
	
	#КонецОбласти
	
	
	#Область УНФ_ПодсистемаНастройки_ПриПервомЗапуске
	
	Если ЭтоНастольноеПриложениеУНФ Тогда
		Константы.ИспользоватьПодсистемуНастройки.Установить(Истина);
	КонецЕсли;
	
	Константы.ИспользоватьРаботуСНовостями.Установить(Истина);
	Константы.ИспользоватьСервисыИнтеграций.Установить(Истина);
