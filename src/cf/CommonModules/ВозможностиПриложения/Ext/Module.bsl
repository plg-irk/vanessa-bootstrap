// Проверяет, что текущий вид приложения это УправлениеНебольшойФирмой
// 
// Параметры:
//  ОбластьДанных             - Число, Неопределено - номер области данных или Неопределено для неразделенных значений
//                                или при работе в коробке;
// Возвращаемое значение:
//  Булево - признак является ли текущая конфигурация конфигурацией УправлениеНебольшойФирмой
//
Функция ЭтоУНФ(ОбластьДанных = Неопределено) Экспорт
	
	ИмяТекущегоПриложения = ВидыПриложенийУНФ.ИмяТекущегоВидаПриложения(ОбластьДанных);
	ЭтоУНФ = ИмяТекущегоПриложения = ИмяКонфигурацииУНФ()
		ИЛИ ИмяТекущегоПриложения = ИмяКонфигурацииУНФБазовая();
			
	Возврат ЭтоУНФ;
	
КонецФункции

// Проверяет, что текущий вид приложения это Розница
// 
// Параметры:
//  ОбластьДанных             - Число, Неопределено - номер области данных или Неопределено для неразделенных значений
//                                или при работе в коробке;
// Возвращаемое значение:
//  Булево - признак является ли текущая конфигурация конфигурацией Розница
//
Функция ЭтоРозница(ОбластьДанных = Неопределено) Экспорт
	
	ИмяТекущегоПриложения = ВидыПриложенийУНФ.ИмяТекущегоВидаПриложения(ОбластьДанных);
	ЭтоРозница = ИмяТекущегоПриложения = ИмяКонфигурацииРозница()
		ИЛИ ИмяТекущегоПриложения = ИмяКонфигурацииРозницаБазовая();
		
	Если НЕ ЭтоРозница Тогда
		ВозможностиПриложенияПереопределяемый.ЭтоОтраслевоеРешениеРозница(ЭтоРозница);
	КонецЕсли;
	
	Возврат ЭтоРозница;
	
КонецФункции

// Проверяет, что текущий вид приложения это КомбинированноеПриложение
// 
// Параметры:
//  ОбластьДанных             - Число, Неопределено - номер области данных или Неопределено для неразделенных значений
//                                или при работе в коробке;
// Возвращаемое значение:
//  Булево - Это комбинированное приложение
Функция ЭтоКомбинированноеПриложение(ОбластьДанных = Неопределено) Экспорт
	
	Возврат ВидыПриложенийУНФ.ИмяТекущегоВидаПриложения(ОбластьДанных) = "КомбинированноеПриложение"
		Или ВидыПриложенийУНФ.УстановленРежимЗапускаКомбинированноеПриложение();
	
КонецФункции

// Проверяет, что текущий вид приложения это Бизнес
// 
// Параметры:
//  ОбластьДанных             - Число, Неопределено - номер области данных или Неопределено для неразделенных значений
//                                или при работе в коробке;
// Возвращаемое значение:
//  Булево - Это бизнес приложение
Функция ЭтоБизнесПриложение(ОбластьДанных = Неопределено) Экспорт
	
	Возврат ВидыПриложенийУНФ.ИмяТекущегоВидаПриложения(ОбластьДанных) = "Бизнес"
		Или ВидыПриложенийУНФ.УстановленРежимЗапускаКомбинированноеПриложение();
	
КонецФункции

// Это демо приложение.
// 
// Возвращаемое значение:
//  Булево - Это демо приложение
Функция ЭтоДемоПриложение() Экспорт
	
	Возврат Константы.РежимИспользованияИнформационнойБазы.Получить() =
	Перечисления.РежимыИспользованияИнформационнойБазы.Демонстрационный;
	
КонецФункции

// Возвращает список имен конфигураций семейства Розница / Управление нашей фирмой
//
// Возвращаемое значение:
//  Массив из Строка
Функция ВсеИменаСемействаКонфигураций() Экспорт
	
	Результат = Новый Массив; 
	ВозможностиПриложенияПереопределяемый.ПриОпределенииСпискаИменСемействаКонфигураций(Результат);
	
	Результат.Добавить(ИмяКонфигурацииРозница());
	Результат.Добавить(ИмяКонфигурацииРозницаБазовая());
	Результат.Добавить("УправлениеНебольшойФирмой");
	Результат.Добавить("УправлениеНебольшойФирмойБазовая");
	
	Возврат Результат;
	
КонецФункции

