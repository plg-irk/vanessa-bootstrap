// Проверяет параметр запуска и устанавливает необходимое бизнес-приложение
// 
// Параметры:
//  ПараметрыЗапускаКлиента - Массив из Строка, Неопределено - Параметры запуска клиента
Процедура УстановитьВидПриложенияПоПараметруЗапуска(ПараметрыЗапускаКлиента = Неопределено) Экспорт
	
	Если Не ЭтоБизнесПриложение() Или Не ЭтоДемоПриложение() Тогда
		Возврат;
	КонецЕсли;
	
	Если ПараметрыЗапускаКлиента = Неопределено Тогда
		
		ПараметрыЗапускаКлиента = СтандартныеПодсистемыСервер.ПараметрыКлиентаНаСервере().Получить("ПараметрЗапуска");
		Если ПараметрыЗапускаКлиента = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ПараметрыЗапускаКлиента = СтрРазделить(ПараметрыЗапускаКлиента, ";");
		
	КонецЕсли;
	
	ОписанияПриложений = ОписанияПриложенийПоПараметрамЗапуска(ПараметрыЗапускаКлиента);
	Если ОписанияПриложений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПричинаПодключения = ПричинаПодключенияПриложенияПоПараметру();
	ТарификацияБизнес.ОтключитьВсеПриложения(ПричинаПодключения);
	
	Для Каждого ОписаниеПриложения Из ОписанияПриложений Цикл
		ТарификацияБизнес.ОбработатьПодключениеПриложения(ОписаниеПриложения, ПричинаПодключения, Ложь, , Ложь);
	КонецЦикла;
	
КонецПроцедуры

// Определяет является ли текущая конфигурация конфигурацией УправлениеНебольшойФирмой
// 
// Возвращаемое значение:
//  Булево - признак является ли текущая конфигурация конфигурацией УправлениеНебольшойФирмой
//
Функция БазовыйВидПриложенияЭтоУНФ() Экспорт
	
	ИмяБазовогоВида = ВидыПриложенийСервер.БазовыйВидПриложения().Имя;
	ЭтоУНФ = ИмяБазовогоВида = ИмяКонфигурацииУНФ()
		Или ИмяБазовогоВида = ИмяКонфигурацииУНФБазовая();
			
	Возврат ЭтоУНФ;
	
КонецФункции

// Определяет является ли текущая конфигурация конфигурацией Розница
// 
// Возвращаемое значение:
//  Булево - признак является ли текущая конфигурация конфигурацией Розница
//
Функция БазовыйВидПриложенияЭтоРозница() Экспорт
	
	ИмяБазовогоВида = ВидыПриложенийСервер.БазовыйВидПриложения().Имя;
	ЭтоРозница = ИмяБазовогоВида = ИмяКонфигурацииРозница()
		Или ИмяБазовогоВида = ИмяКонфигурацииРозницаБазовая();
		
	Если Не ЭтоРозница Тогда
		ВозможностиПриложенияПереопределяемый.ЭтоОтраслевоеРешениеРозница(ЭтоРозница);
	КонецЕсли;
	
	Возврат ЭтоРозница;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОписанияПриложенийПоПараметрамЗапуска(ПараметрыЗапускаКлиента)
	
	Результат = Новый Массив;
	
	ПрефиксПараметра = ВозможностиПриложенияКлиентСервер.ПрефиксПараметраКлиентаДляУстановкиБизнесПриложения();
	ДлинаПрефикса = СтрДлина(ПрефиксПараметра);
	
	ОписаниеПриложений = ТарификацияБизнес.ОписаниеВсехПриложений();
	
	Для Каждого ПараметрЗапускаКлиента Из ПараметрыЗапускаКлиента Цикл
		
		Параметр = СокрЛП(ПараметрЗапускаКлиента);
		
		Если Не СтрНачинаетсяС(Параметр, ПрефиксПараметра) Тогда
			Продолжить;
		КонецЕсли;
		
		Параметр = Сред(Параметр, ДлинаПрефикса + 1);
		
		Для Каждого ОписаниеПриложения Из ОписаниеПриложений Цикл
			Если СтрНачинаетсяС(Параметр, ОписаниеПриложения.Имя) Тогда
				Результат.Добавить(ОписаниеПриложения);
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

