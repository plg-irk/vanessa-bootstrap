#Область ПроверкаВключенияФункциональности

// Обработчик события перед записью констант приложения
//
// Параметры:
//  Источник - КонстантаМенеджерЗначения - изменяемая константа
//  Отказ	 - Булево - если константу нельзя включить в приложении Отказ = Истина
//
Процедура ФункциональностьПриложенияПриИзмененииПередЗаписью(Источник, Отказ) Экспорт
	
	ИмяИсточника = Сред(Источник, СтрДлина("КонстантаМенеджерЗначения.") + 1);
	НедоступнаяФункциональность = НедоступнаяВПриложенииФункциональность();
	
	Если НедоступнаяФункциональность.Найти(ИмяИсточника) <> Неопределено
		И Источник.Значение = Истина Тогда
		ТекстИсключения = СтрШаблон(НСтр("ru = 'Функциональность ""%1"" недоступна для включения.'"), ИмяИсточника);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
КонецПроцедуры

// Константа доступна в приложении.
// 
// Параметры:
//  ИмяКонстанты - Строка - Имя константы
// 
// Возвращаемое значение:
//  Булево - Константа доступна в приложении
Функция КонстантаДоступнаВПриложении(ИмяКонстанты) Экспорт
	
	Если ЭтоБизнесПриложение() Тогда
		СписокПриложений = ТарификацияБизнес.ДоступныеПриложения(Истина);
		Для Каждого ОписаниеПриложения Из СписокПриложений Цикл
			МодульПриложения = ОбщегоНазначения.ОбщийМодуль(ОписаниеПриложения.МодульПриложения);
			ТаблицаВозможностейПриложения = МодульПриложения.ФункциональныеВозможностиПриложения();
			КонстантаДоступна = ТаблицаВозможностейПриложения.НайтиСтроки(Новый Структура("Имя", ИмяКонстанты));
			Если КонстантаДоступна.Количество() <> 0 Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
		
		Возврат Ложь;
	КонецЕсли;

	Если ОбщегоНазначенияУНФ.ЭтоУНФ() Тогда
		НедоступныеКонстанты = КонстантыНедоступныеДляВключенияВУНФ();
		Если НедоступныеКонстанты.Найти(ИмяКонстанты) = Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
		Возврат Ложь;
	КонецЕсли;
	
	Если ОбщегоНазначенияУНФ.ЭтоРозница() Тогда
		НедоступныеКонстанты = КонстантыНедоступныеДляВключенияВРознице();
		Если НедоступныеКонстанты.Найти(ИмяКонстанты) = Неопределено Тогда
			Возврат Истина;
		КонецЕсли;
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Ложь;

КонецФункции

// Список доступных констант.
// 
// Параметры:
//  СписокВсехКонстант - Соответствие из КлючИЗначение - Список всех констант
// 
// Возвращаемое значение:
//  Массив из Строка - Список доступных констант
Функция СписокДоступныхКонстант(СписокВсехКонстант) Экспорт
	
	ДоступныеКонстанты = Новый Массив;
	
	Если ЭтоБизнесПриложение() Тогда
		СписокПриложений = ТарификацияБизнес.ДоступныеПриложения(Истина);
		Для Каждого ОписаниеПриложения Из СписокПриложений Цикл
			МодульПриложения = ОбщегоНазначения.ОбщийМодуль(ОписаниеПриложения.МодульПриложения);
			ТаблицаВозможностейПриложения = МодульПриложения.ФункциональныеВозможностиПриложения();
			
			Для Каждого Константа Из СписокВсехКонстант Цикл
				КонстантаДоступна = ТаблицаВозможностейПриложения.НайтиСтроки(Новый Структура("Имя", Константа.Значение));
				Если КонстантаДоступна.Количество() <> 0 Тогда
					ДоступныеКонстанты.Добавить(Константа.Значение);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		Возврат ДоступныеКонстанты;
	КонецЕсли;

	Если ОбщегоНазначенияУНФ.ЭтоУНФ() Тогда
		НедоступныеКонстанты = КонстантыНедоступныеДляВключенияВУНФ();
		
		Для Каждого Константа Из СписокВсехКонстант Цикл
			КонстантаДоступна =  НедоступныеКонстанты.Найти(Константа.Значение) = Неопределено;
			Если КонстантаДоступна Тогда
				ДоступныеКонстанты.Добавить(Константа.Значение);
			КонецЕсли;
		КонецЦикла;

		Возврат ДоступныеКонстанты;
	КонецЕсли;
	
	Если ОбщегоНазначенияУНФ.ЭтоРозница() Тогда
		НедоступныеКонстанты = КонстантыНедоступныеДляВключенияВРознице();
		Для Каждого Константа Из СписокВсехКонстант Цикл
			КонстантаДоступна =  НедоступныеКонстанты.Найти(Константа.Значение) = Неопределено;
			Если КонстантаДоступна Тогда
				ДоступныеКонстанты.Добавить(Константа.Значение);
			КонецЕсли;
		КонецЦикла;

		Возврат ДоступныеКонстанты;
		
	КонецЕсли;
	
КонецФункции

#КонецОбласти

