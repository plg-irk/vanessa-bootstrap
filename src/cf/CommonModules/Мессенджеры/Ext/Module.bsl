#Область ПрограммныйИнтерфейс

// Добавляет команду формирования сообщений в настройки контактной информации.
// Для вызова из УправлениеКонтактнойИнформациейУНФ.ПриОпределенииНастроек
// См. УправлениеКонтактнойИнформациейПереопределяемый.ПриОпределенииНастроек
// 
// Параметры:
//  Настройки - Структура - Настройки:
//  Телефон - ПеречислениеСсылка.ТипыКонтактнойИнформации
Процедура ПриОпределенииНастроекПанелиКонтактнойИнформации(Настройки, Телефон) Экспорт

	ИнтеграцииДоступны = ПолучитьФункциональнуюОпцию("ИспользоватьИнтеграцииСистемыВзаимодействия");
	Если ИнтеграцииДоступны Тогда
		Настройки.ОписаниеКоманд[Телефон].Вставить("НаписатьВМессенджерWhatsApp", Новый Структура);
		КомандаНаписатьВWhatsApp = Настройки.ОписаниеКоманд[Телефон].НаписатьВМессенджерWhatsApp;
		КомандаНаписатьВWhatsApp.Вставить("Заголовок", НСтр("ru='Написать в WhatsApp'"));
		КомандаНаписатьВWhatsApp.Вставить("Подсказка", НСтр("ru='Написать в мессенджер WhatsApp'"));
		КомандаНаписатьВWhatsApp.Вставить("Картинка", БиблиотекаКартинок.ЛоготипWhatsApp);
		КомандаНаписатьВWhatsApp.Вставить("Действие",
			"УправлениеКонтактнойИнформациейУНФКлиент.ОбработчикДействияНаписатьВМессенджерWhatsApp");		
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Тип внешней системы интеграции обсудения.
// 
// Параметры:
//  ИдентификаторОбсуждения - ИдентификаторОбсужденияСистемыВзаимодействия
// 
// Возвращаемое значение:
//  Строка, Неопределено - Тип внешней системы 
Функция ТипВнешнейСистемыИнтеграцииОбсудения(ИдентификаторОбсуждения) Экспорт
	
	Результат = Неопределено;
	
	Если Не ЗначениеЗаполнено(ИдентификаторОбсуждения) Тогда
		Возврат Результат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(ИдентификаторОбсуждения);
	Если Обсуждение.Интеграция = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИнтеграцияОбсуждения = СистемаВзаимодействия.ПолучитьИнтеграцию(Обсуждение.Интеграция);
	ИнтеграцияСистемыВзаимодействия = СистемаВзаимодействия.ПолучитьИнтеграцию(ИнтеграцияОбсуждения.Идентификатор);
	
	Возврат ИнтеграцияСистемыВзаимодействия.ТипВнешнейСистемы;	
	
КонецФункции

// Возвращает первое найденное обсуждение указанной интеграции с заголовком
// 
// Параметры:
//  Интеграция - ИдентификаторИнтеграцииСистемыВзаимодействия
//  Заголовок - Строка - Заголовок обсуждения
// 
// Возвращаемое значение:
//  Неопределено, ИдентификаторОбсужденияСистемыВзаимодействия - Результат поиска
Функция ОбсуждениеСАбонентомИнтеграцииПоЗаголовку(Интеграция, Заголовок) Экспорт
	
	Обсуждение = Неопределено;
	
	Отбор = Новый ОтборОбсужденийСистемыВзаимодействия;
	Отбор.Интеграция = Интеграция;
	
	НайденныеОбсуждения = СистемаВзаимодействия.ПолучитьОбсуждения(Отбор);	
	Для Каждого НайденноеОбсуждение Из НайденныеОбсуждения Цикл
		Если НайденноеОбсуждение.Заголовок = Заголовок Тогда
			Обсуждение = НайденноеОбсуждение.Идентификатор;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Обсуждение;
	
КонецФункции

// Возвращает первое найденное обсуждение указанной интеграции с заголовком 
// 
// Параметры:
//  Интеграция - ИдентификаторИнтеграцииСистемыВзаимодействия
//  ВнешнийИдентификатор - Строка - Заголовок обсуждения
// 
// Возвращаемое значение:
//  Неопределено, ИдентификаторОбсужденияСистемыВзаимодействия - Результат поиска
Функция ОбсуждениеСАбонентомИнтеграцииПоВнешнемуИдентификатору(Интеграция, ВнешнийИдентификатор) Экспорт
	
	Обсуждение = Неопределено;
	
	Отбор = Новый ОтборОбсужденийСистемыВзаимодействия;
	Отбор.Интеграция = Интеграция;
	Отбор.ВнешнийИдентификатор = ВнешнийИдентификатор;
	
	НайденныеОбсуждения = СистемаВзаимодействия.ПолучитьОбсуждения(Отбор);	
	Для Каждого НайденноеОбсуждение Из НайденныеОбсуждения Цикл
		Если НайденноеОбсуждение.Заголовок = ВнешнийИдентификатор Тогда
			Обсуждение = НайденноеОбсуждение.Идентификатор;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Обсуждение;
	
КонецФункции

// Возвращает тип внешней системы интеграции, тип внешней системы пользователя системы взаимодействия.
// 
// Параметры:
//  ИдентификаторИнтеграции - ИдентификаторИнтеграцииСистемыВзаимодействия
//  ИдентификаторПользователя - ИдентификаторПользователяСистемыВзаимодействия - Авторизованный пользователь
// 
// Возвращаемое значение:
//  Структура - Описание внешней системы обсуждения:
// * ТипВнешнейСистемыИнтеграции - Строка
// * ТипВнешнейСистемыПользователя - Строка 
Функция ОписаниеВнешнейСистемыОбсужденияИнтеграции(ИдентификаторИнтеграции, ИдентификаторПользователя) Экспорт
	
	ИнтеграцияСВ = СистемаВзаимодействия.ПолучитьИнтеграцию(ИдентификаторИнтеграции);
	ПользовательСВ = СистемаВзаимодействия.ПолучитьПользователя(ИдентификаторПользователя);
	
	Результат = Новый Структура;
	Результат.Вставить("ТипВнешнейСистемыИнтеграции", ИнтеграцияСВ.ТипВнешнейСистемы);
	Результат.Вставить("ТипВнешнейСистемыПользователя", ПользовательСВ.ТипВнешнейСистемы);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
