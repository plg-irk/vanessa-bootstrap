// Открывает форму созданного на основании документа
// 
// Параметры:
//   Результат - Структура - сведения о выбранных параметрах количества
//       * АдресТовары - Строка - адрес сохраненной таблицы
//       * Основание - ДокументСсылка - ссылка на документ-основание
//       * КоличествоИзделий - Число - указанное количество
//   ДополнительныеПараметры - Структура - сведения о контексте исполнения:
//       * Форма - ФормаКлиентскогоПриложения - вызывающая форма
//       * Источник - ДанныеФормыСтруктура - сведения об основном объекте формы
//       * ТребуетсяЗапись - Булево - необходимо ли выполнить действие при вызове данной команды
//       * ТребуетсяПроведение - Булево - необходимо ли выполнить действие при вызове данной команды
//       * ТребуетсяРаботаСФайлами - Булево - необходимо ли выполнить действие при вызове данной команды
//
Процедура СоздатьСборкаЗапасовЗаказовПослеУточнения(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Основание = Новый Структура();
	Основание.Вставить("АдресТовары", Результат.АдресТовары);
	Основание.Вставить("Основание", Результат.Основание);
	
	ПараметрыОткрытия = Новый Структура("Основание", Основание);
	
		ОткрытьФорму("Документ.СборкаЗапасов.Форма.ФормаДокумента",
		ПараметрыОткрытия,
		,
		Новый УникальныйИдентификатор);
	
КонецПроцедуры

