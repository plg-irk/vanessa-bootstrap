	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС120() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("20% / 120%");
		
		ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС5() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("5%");
		
	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС105() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("5% / 105%");
		
	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС7() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("7%");
		
	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС107() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("7% / 107%");
	
	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС22() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("22%");
	
	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС122() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("22% / 122%");
		
	КонецЕсли;
	
КонецФункции

