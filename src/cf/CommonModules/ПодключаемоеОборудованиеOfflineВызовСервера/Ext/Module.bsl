		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("Без НДС");
		
	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС0() Тогда
		
		Возврат Справочники.СтавкиНДС.НайтиПоНаименованию("0%");
		
	ИначеЕсли СтавкаНДСККМ = МенеджерОфлайнОборудования.СтавкаНДС10() Тогда
		
