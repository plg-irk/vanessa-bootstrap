Функция ОбработчикДействияНастроитьСвойстваАдреса(КонтактнаяИнформация, ДополнительныеПараметры) Экспорт
    
	КИОписаниеДополнительныхРеквизитов =
	ДополнительныеПараметры.Форма.КонтактнаяИнформацияОписаниеДополнительныхРеквизитов;
	Если КИОписаниеДополнительныхРеквизитов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Отбор = Новый Структура( "Вид", КонтактнаяИнформация.Вид );
    КИОписаниеДополнительныхРеквизитовСтроки = КИОписаниеДополнительныхРеквизитов.НайтиСтроки( Отбор );
    Если КИОписаниеДополнительныхРеквизитовСтроки.Количество() = 0 Тогда
    	Возврат Неопределено;
    КонецЕсли;

   	КИОписаниеДополнительныхРеквизитовСтрока = КИОписаниеДополнительныхРеквизитовСтроки[0];	
	ИмяЭлементаДляРазмещения = КИОписаниеДополнительныхРеквизитовСтрока.ИмяЭлементаДляРазмещения;

	ДополнительныеПараметры.Вставить( "ИмяЭлементаДляРазмещения", ИмяЭлементаДляРазмещения);
    ДополнительныеПараметры.Вставить( "ВидКонтактнойИнформации", КонтактнаяИнформация.Вид );
    
   	Если КИОписаниеДополнительныхРеквизитовСтрока.ХранитьИсториюИзменений = Ложь Тогда
   	
	    // если хранение истории не включено, то предложим включить и поменять вид поля на "Диалог",
    	// так как в текущей версии БСП хранение истории допустимо только для "Диалог"
    	
		ОповещениеОЗавершении = Новый ОписаниеОповещения( 
		"НастроитьСвойстваАдресаПослеВопросаВключенияИстории", 
		УправлениеКонтактнойИнформациейУНФКлиент, 
		ДополнительныеПараметры);
   		
   		ВопросШаблон = НСтр( "ru = 'Для включения хранения истории вида адреса ""%1"" необходимо поменять способ ввода на ""Диалог"".
                              |Продолжить ?'" );
   		ВопросТекст = СтрШаблон( ВопросШаблон, КонтактнаяИнформация.Вид );
   		ПоказатьВопрос( ОповещениеОЗавершении, ВопросТекст, РежимДиалогаВопрос.ДаНетОтмена, , , 
   		НСтр( "ru = 'Включение истории для адреса'" ) );
   	КонецЕсли;
   	
    Возврат Неопределено;
	
КонецФункции

Функция ОбработчикДействияНаписатьВМессенджерWhatsApp(КонтактнаяИнформация, ДополнительныеПараметры) Экспорт
	
	МессенджерыWhatsAppКлиент.ОбработчикДействияНаписатьВМессенджерWhatsApp(КонтактнаяИнформация,
		ДополнительныеПараметры);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФукнции

Процедура НастроитьСвойстваАдресаПослеЗавершения(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
    
    Результат = Неопределено;
    УправлениеКонтактнойИнформациейКлиент.ПослеЗакрытияФормыСпискаВидыКонтактнойИнформации(Результат,
    	ДополнительныеПараметры);
		
КонецПроцедуры

Процедура НастроитьСвойстваАдресаПослеВопросаВключенияИстории(РезультатВопроса, ДополнительныеПараметры) Экспорт
    
	Если РезультатВопроса <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Если КонтактнаяИнформацияУНФВызовСервера.АдресВключитьХранениеИстории( 
		ДополнительныеПараметры.ВидКонтактнойИнформации ) <> Истина Тогда
		Возврат;
	КонецЕсли;
	
	Результат = Неопределено;
	УправлениеКонтактнойИнформациейКлиент.ПослеЗакрытияФормыСпискаВидыКонтактнойИнформации(Результат,
		ДополнительныеПараметры);
	
КонецПроцедуры

Функция ТипСобытияПоТипуКонтактнойИнформации(ТипКИ)
	
	Если ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Skype") Тогда
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Прочее");
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес") Тогда
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ЛичнаяВстреча");
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты") Тогда
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ЭлектронноеПисьмо");
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.ВебСтраница") Тогда
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Прочее");
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Другое") Тогда
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.Прочее");
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон") Тогда
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ТелефонныйЗвонок");
	ИначеЕсли ТипКИ = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Факс") Тогда
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ТелефонныйЗвонок");
	Иначе
		ТипСобытия = ПредопределенноеЗначение("Перечисление.ТипыСобытий.ПустаяСсылка");
	КонецЕсли;
	
	Возврат ТипСобытия;
	
КонецФункции

#КонецОбласти
