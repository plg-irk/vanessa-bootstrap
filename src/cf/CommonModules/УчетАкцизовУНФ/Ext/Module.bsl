#Область ПрограммныйИнтерфейс

// Возвращает единицу измерения по ставке акциза
//
// Параметры:
//  КодВидаПодакцизногоТовара- СправочникСсылка.КодыВидовПодакцизногоТовара - ссылка на справочник для получения единицы измерения из регистра
// 
// Возвращаемое значение:
//  СправочникСсылка.ЕдиницыИзмерения - единица измерения по ставке акциза
//
Функция ПолучитьЕдиницуИзмеренияПоСтавкеАкциза(КодВидаПодакцизногоТовара) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("КодТовара", КодВидаПодакцизногоТовара);
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СтавкиАкцизаСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ИЗ
	|	РегистрСведений.СтавкиАкциза.СрезПоследних(&Дата, КодВидаПодакцизногоТовара = &КодТовара) КАК СтавкиАкцизаСрезПоследних";
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Возврат Результат.ЕдиницаИзмерения;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Возвращает список производимых подакцизных товаров
//
// Параметры:
//  Организация- СправочникСсылка.Организации - ссылка на справочник для получения производимых подакцизных товаров
// 
// Возвращаемое значение:
//  Массив - Массив видов подакцизных товаров по организации
//
Функция СписокПроизводимыхПодакцизныхТоваров(Организация) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПорядокУплатыАкцизов.ВидТовара КАК ВидТовара
	|ИЗ
	|	РегистрСведений.ПорядокУплатыАкцизов КАК ПорядокУплатыАкцизов
	|ГДЕ
	|	ПорядокУплатыАкцизов.Организация = &Организация
	|	И ПорядокУплатыАкцизов.Производство = ИСТИНА";
	Запрос.УстановитьПараметр("Организация", Организация);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Список = Новый СписокЗначений();
	Список = Результат.ВыгрузитьКолонку("ВидТовара");
	
	Возврат Список;
	
КонецФункции

// Возвращает список производимых подакцизных товаров
//
// Параметры:
//  Организация- СправочникСсылка.Организации - ссылка на справочник для получения производимых подакцизных товаров
// 
// Возвращаемое значение:
//  Булево - Есть настройки уплаты акцизов по организациям
//
Функция ЕстьНастройкиПоАкцизамПоПроизводству(Организация = Неопределено) Экспорт
	
	Запрос = Новый Запрос();
	
	Если Организация = Неопределено Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПорядокУплатыАкцизов.ВидТовара КАК ВидТовара
		|ИЗ
		|	РегистрСведений.ПорядокУплатыАкцизов КАК ПорядокУплатыАкцизов
		|ГДЕ
		|	ПорядокУплатыАкцизов.Производство = ИСТИНА";
		
	Иначе
		
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПорядокУплатыАкцизов.ВидТовара КАК ВидТовара
		|ИЗ
		|	РегистрСведений.ПорядокУплатыАкцизов КАК ПорядокУплатыАкцизов
		|ГДЕ
		|	ПорядокУплатыАкцизов.Производство = ИСТИНА
		|	И ПорядокУплатыАкцизов.Организация = &Организация";
		
		Запрос.УстановитьПараметр("Организация",Организация);
		
	КонецЕсли;
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

