// Возвращает ставку акциза по виду подакцизного товара
//
// Параметры:
//  КодВидаПодакцизногоТовара- СправочникСсылка.КодыВидовПодакцизногоТовара - ссылка на справочник для получения единицы измерения из регистра
//  Дата - Дата - дата на которую получается ставка
// 
// Возвращаемое значение:
//  Структура - структура ставки акциза на дату
Функция ПолучитьСтавкуАкциза(КодВидаПодакцизногоТовара, Дата) Экспорт
	
	СтруктураВозврата = Новый Структура("Ставка, ОкруглятьДоЦелого", 0, Ложь);
	Запрос = Новый Запрос();
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СтавкиАкцизаСрезПоследних.Сумма КАК Сумма,
	|	СтавкиАкцизаСрезПоследних.ОкруглятьДоЦелого КАК ОкруглятьДоЦелого
	|ИЗ
	|	РегистрСведений.СтавкиАкциза.СрезПоследних(&Дата, КодВидаПодакцизногоТовара = &КодВидаПодакцизногоТовара) КАК СтавкиАкцизаСрезПоследних";
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("КодВидаПодакцизногоТовара", КодВидаПодакцизногоТовара);
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		СтруктураВозврата.Ставка            = Результат.Сумма;
		СтруктураВозврата.ОкруглятьДоЦелого = Результат.ОкруглятьДоЦелого;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
		
КонецФункции

// Возвращает структуру параметров заполнения данных по акцизам
//
// Возвращаемое значение:
//  Структура - структура параметров заполнения данных по акцизам
Функция ПараметрыДляЗаполненияДанныхПоАкцизам(Параметры = Неопределено) Экспорт
	
	Если Параметры = Неопределено Тогда
		Параметры = Новый Структура();
	КонецЕсли;

	Параметры.Вставить("Импорт",               Ложь);
	Параметры.Вставить("ЭкспортПриРеализации", Ложь);
	Параметры.Вставить("Корректировка",        Ложь);
	Параметры.Вставить("ЗаявлениеОВвозе",      Ложь);
	Параметры.Вставить("ЭтоПередачаТоваров",   Ложь);
	Параметры.Вставить("ДатаПолученияСтавки",  '00010101');
	
	Возврат Параметры;

КонецФункции

// Заполняет табличную часть данными по акцизам
//
// Параметры:
//  ТаблицаТовары- ТабличнаяЧасть - табличная часть документа для заполнения
//  Организация- СправочникСсылка.Организации - ссылка на организацию из документа
//  Дата - Дата - дата на которую получается ставка
//  ПараметрыДляЗаполнения- Структура - структура параметров для  заполнения табличной части
// 
Процедура ЗаполнитьДанныеПоАкцизам(ТаблицаТовары, Организация, Дата, ПараметрыДляЗаполнения) Экспорт
	
	Если ТаблицаТовары = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПорядокУплатыАкцизов.ВидТовара КАК ВидТовара
		|ПОМЕСТИТЬ СписокУчитываемыхПодакцизныхТоваров
		|ИЗ
		|	РегистрСведений.ПорядокУплатыАкцизов КАК ПорядокУплатыАкцизов
		|ГДЕ
		|	ПорядокУплатыАкцизов.Организация = &Организация
		|	И ПорядокУплатыАкцизов.Производство = &Производство
		|	И ПорядокУплатыАкцизов.Импорт = &Импорт
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.КодВидаПодакцизногоТовара КАК КодВидаПодакцизногоТовара,
		|	Номенклатура.КоэффициентПересчета КАК КоэффициентПересчета,
		|	КодыВидовПодакцизныхТоваров.ВидТовара КАК ВидТовара,
		|	Номенклатура.ЕдиницаИзмеренияДляРасчетаАкциза КАК ЕдиницаИзмеренияДляРасчетаАкциза
		|ПОМЕСТИТЬ СписокНоменклатуры
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КодыВидовПодакцизныхТоваров КАК КодыВидовПодакцизныхТоваров
		|		ПО Номенклатура.КодВидаПодакцизногоТовара = КодыВидовПодакцизныхТоваров.Ссылка
		|ГДЕ
		|	Номенклатура.Ссылка В(&СписокНоменклатуры)
		|	И ВЫБОР
		|			КОГДА КодыВидовПодакцизныхТоваров.ДействуетС = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ КодыВидовПодакцизныхТоваров.ДействуетС <= &Дата
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА КодыВидовПодакцизныхТоваров.ДействуетПо = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ КодыВидовПодакцизныхТоваров.ДействуетПо >= &Дата
		|		КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СписокУчитываемыхПодакцизныхТоваров.ВидТовара КАК ВидТовара,
		|	СписокНоменклатуры.Ссылка КАК Ссылка,
		|	СписокНоменклатуры.КодВидаПодакцизногоТовара КАК КодВидаПодакцизногоТовара,
		|	СписокНоменклатуры.КоэффициентПересчета КАК КоэффициентПересчета,
		|	СписокНоменклатуры.ЕдиницаИзмеренияДляРасчетаАкциза КАК ЕдиницаИзмеренияДляРасчетаАкциза
		|ПОМЕСТИТЬ СписокНоменклатурыУчитываемойВТекОрганизации
		|ИЗ
		|	СписокУчитываемыхПодакцизныхТоваров КАК СписокУчитываемыхПодакцизныхТоваров
		|		ЛЕВОЕ СОЕДИНЕНИЕ СписокНоменклатуры КАК СписокНоменклатуры
		|		ПО СписокУчитываемыхПодакцизныхТоваров.ВидТовара = СписокНоменклатуры.ВидТовара
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СписокНоменклатурыУчитываемойВТекОрганизации.Ссылка КАК Номенклатура,
		|	СписокНоменклатурыУчитываемойВТекОрганизации.КодВидаПодакцизногоТовара КАК КодВидаПодакцизногоТовара,
		|	СписокНоменклатурыУчитываемойВТекОрганизации.КоэффициентПересчета КАК КоэффициентПересчета,
		|	СписокНоменклатурыУчитываемойВТекОрганизации.ВидТовара КАК ВидТовара,
		|	СтавкиАкцизаСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	СтавкиАкцизаСрезПоследних.Сумма КАК Сумма,
		|	СтавкиАкцизаСрезПоследних.ОкруглятьДоЦелого КАК ОкруглятьДоЦелого,
		|	СписокНоменклатурыУчитываемойВТекОрганизации.ЕдиницаИзмеренияДляРасчетаАкциза.Код КАК ЕдиницаИзмеренияАкциза
		|ИЗ
		|	СписокНоменклатурыУчитываемойВТекОрганизации КАК СписокНоменклатурыУчитываемойВТекОрганизации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтавкиАкциза.СрезПоследних(&Дата, ) КАК СтавкиАкцизаСрезПоследних
		|		ПО СписокНоменклатурыУчитываемойВТекОрганизации.КодВидаПодакцизногоТовара = СтавкиАкцизаСрезПоследних.КодВидаПодакцизногоТовара";
	
	Запрос.УстановитьПараметр("Организация",        Организация);
	Запрос.УстановитьПараметр("Дата",               Дата);
	Запрос.УстановитьПараметр("СписокНоменклатуры", ОбщегоНазначения.ВыгрузитьКолонку(ТаблицаТовары, "Номенклатура", Истина));
	Запрос.УстановитьПараметр("Импорт",             ПараметрыДляЗаполнения.Импорт);
	Запрос.УстановитьПараметр("Производство",       Не ПараметрыДляЗаполнения.Импорт);

	Если ТипЗнч(ТаблицаТовары) = Тип("ТаблицаЗначений")
		И ТаблицаТовары.Колонки.Найти("Партия") = Неопределено Тогда
		ТаблицаТовары.Колонки.Добавить("Партия");
	КонецЕсли;

	Результат = Запрос.Выполнить().Выгрузить();
	Для Каждого Строка Из ТаблицаТовары Цикл
		СтрокаПоАкцизу = Результат.Найти(Строка.Номенклатура, "Номенклатура");
		
		СобственныйЗапас = Истина;
		Если ЗначениеЗаполнено(Строка.Партия) И НЕ Строка.Партия.Статус = Перечисления.СтатусыПартий.СобственныеЗапасы Тогда
			СобственныйЗапас = Ложь;
		КонецЕсли;
				
		Если СтрокаПоАкцизу <> Неопределено И СобственныйЗапас Тогда 
			Строка.КоэффициентПересчета      = СтрокаПоАкцизу.КоэффициентПересчета;
			Строка.ЕдиницаИзмеренияАкциза    = СтрокаПоАкцизу.ЕдиницаИзмеренияАкциза;
			Строка.СтавкаАкциза = СтрокаПоАкцизу.Сумма;
			Строка.ОкруглятьДоЦелого         = СтрокаПоАкцизу.ОкруглятьДоЦелого;
			Строка.ПодакцизныйТовар = Истина;
			
			Если Строка.Свойство("ЕдиницаИзмерения") И ЗначениеЗаполнено(Строка.ЕдиницаИзмерения)
				И Не ТипЗнч(Строка.ЕдиницаИзмерения) = Тип("СправочникСсылка.КлассификаторЕдиницИзмерения") Тогда
				ЗначенияРекизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Строка.ЕдиницаИзмерения, "Коэффициент");
				Коэффициент = ?(Не ЗначениеЗаполнено(ЗначенияРекизитов.Коэффициент), 1, ЗначенияРекизитов.Коэффициент);
				Строка.СтавкаАкциза = Строка.СтавкаАкциза * Коэффициент;
			КонецЕсли;
						
			УчетАкцизовУНФКлиентСервер.РассчитатьСуммуАкцизаВТабЧасти(Строка, ПараметрыДляЗаполнения.ЭкспортПриРеализации,
			ПараметрыДляЗаполнения.Импорт, ПараметрыДляЗаполнения.ЭтоПередачаТоваров);
		Иначе
			Строка.КоэффициентПересчета      = 0;
			Строка.ЕдиницаИзмеренияАкциза = "";
			Если ПараметрыДляЗаполнения.ЗаявлениеОВвозе Тогда
				Строка.ТвердаяСтавкаАкциза = 0;
				
			Иначе
				Строка.СтавкаАкциза          = 0;
			КонецЕсли;
			Строка.ОкруглятьДоЦелого         = 0;
			Строка.ПодакцизныйТовар          = Ложь;
			Строка.СуммаАкциза               = 0;
			Если ПараметрыДляЗаполнения.Корректировка Тогда
				Строка.СуммаАкцизаДоИзменения     = 0;
				Строка.СуммаАкцизаДоКорректировки = 0;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Заполняет список выбора видов подакцизного товара в зависимости от настроек
// 
// Параметры:
//  ЭлементФормы - ЭлементФормы - поле формы заполняемого списка.
//
Процедура ЗаполнитьСписокВидовПодакцизногоТовара(ЭлементФормы) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПорядокУплатыАкцизов.ВидТовара КАК ВидТовара,
	|	ПРЕДСТАВЛЕНИЕ(ПорядокУплатыАкцизов.ВидТовара) КАК Представление
	|ИЗ
	|	РегистрСведений.ПорядокУплатыАкцизов КАК ПорядокУплатыАкцизов
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокУплатыАкцизов.ВидТовара.Порядок";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СтрокаСпискаВыбора = ЭлементФормы.СписокВыбора.Добавить();
		СтрокаСпискаВыбора.Значение = Выборка.ВидТовара;
		СтрокаСпискаВыбора.Представление = Выборка.Представление;
	КонецЦикла;
	
КонецПроцедуры

// Заполняет строку табличной части данными акцизов
// 
// Параметры:
//  СтрокаТабличнойЧасти - СтрокаТабличнойЧасти - строка для заполнения.
//  ВидыПроизведенныхПодакцизныхТоваров - СписокЗначений - список видов произведенных подакцизных товаров.
//  ЭкспортПриРеализации - Булево - признак отгрузки в другую страну;
//  ЭтоПередачаТоваров - Булево - признак передачи товаров другому контрагенту;
//  ДатаОбработки - Дата - дата на которую получаются значения ставки акциза;
//
Процедура ЗаполнитьСтрокуДаннымиАкцизов(СтрокаТабличнойЧасти, ВидыПроизведенныхПодакцизныхТоваров, ЭкспортПриРеализации, ЭтоПередачаТоваров, ДатаОбработки) Экспорт
	
	СтруктураДанные = Новый Структура;
	
	СобстственныеЗапасы = Истина;
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Партия) И Не СтрокаТабличнойЧасти.Партия.Статус = Перечисления.СтатусыПартий.СобственныеЗапасы Тогда
		СобстственныеЗапасы = Ложь;
	КонецЕсли;
	
	СтруктураДанные.Вставить("ПодакцизныйТовар", Ложь);
	СтруктураДанные.Вставить("СуммаАкциза", 0);
	СтруктураДанные.Вставить("КоэффициентПересчета", 0);
	СтруктураДанные.Вставить("СтавкаАкциза", 0);
	СтруктураДанные.Вставить("ОкруглятьДоЦелого", 0);
	СтруктураДанные.Вставить("ЕдиницаИзмеренияАкциза", "");
	
	Если СобстственныеЗапасы Тогда
		
		КодВидаПодакцизногоТовара = СтрокаТабличнойЧасти.Номенклатура.КодВидаПодакцизногоТовара;
		
		СтруктураДанные.Вставить("КоэффициентПересчета", СтрокаТабличнойЧасти.Номенклатура.КоэффициентПересчета);
		СтруктураДанные.Вставить("ЕдиницаИзмеренияДляРасчетаАкциза", СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмеренияДляРасчетаАкциза);
		СтруктураДанные.КоэффициентПересчета = СтруктураДанные.КоэффициентПересчета;
		Если ЗначениеЗаполнено(СтруктураДанные.ЕдиницаИзмеренияДляРасчетаАкциза) Тогда
			ЕдиницаИзмеренияАкциза = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураДанные.ЕдиницаИзмеренияДляРасчетаАкциза, "Код");
		Иначе
			ЕдиницаИзмеренияАкциза = "";
		КонецЕсли;
		Если ЗначениеЗаполнено(КодВидаПодакцизногоТовара) Тогда
			
			ВидТовара = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КодВидаПодакцизногоТовара, "ВидТовара");
			АкцизПоНоменклатуреНачисляется = ВидыПроизведенныхПодакцизныхТоваров.НайтиПоЗначению(ВидТовара);
			
			Если Не АкцизПоНоменклатуреНачисляется = Неопределено Тогда
				СтруктураДанные.ПодакцизныйТовар       = Истина;
				СтруктураДанные.ЕдиницаИзмеренияАкциза = ЕдиницаИзмеренияАкциза;
			КонецЕсли;
			
			Если СтруктураДанные.ПодакцизныйТовар И Не ЭкспортПриРеализации Тогда
				СтруктураРасчетаАкциза = УчетАкцизовУНФ.ПолучитьСтавкуАкциза(КодВидаПодакцизногоТовара, ДатаОбработки);
				СтруктураДанные.СтавкаАкциза      = СтруктураРасчетаАкциза.Ставка;
				СтруктураДанные.ОкруглятьДоЦелого = СтруктураРасчетаАкциза.ОкруглятьДоЦелого;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтруктураДанные);
	УчетАкцизовУНФКлиентСервер.РассчитатьСуммуАкцизаВТабЧасти(СтрокаТабличнойЧасти, ЭкспортПриРеализации, Ложь, ЭтоПередачаТоваров);
	
КонецПроцедуры

#КонецОбласти

