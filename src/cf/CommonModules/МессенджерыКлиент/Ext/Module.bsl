
#Область ПрограммныйИнтерфейс

// Обработчик выбора шаблона сообщения обсуждения. Вызывается из модуля приложения из метода 
// ОбработкаВыбораШаблонаСообщенияСистемыВзаимодействия
// 
// Параметры:
//  Обсуждение - ИдентификаторОбсужденияСистемыВзаимодействия
//  СтандартнаяОбработка - Булево
Процедура ОбработкаВыбораШаблонаСообщенияСистемыВзаимодействия(Обсуждение, СтандартнаяОбработка) Экспорт
	
	ТипВнешнейСистемы = МессенджерыВызовСервера.ТипВнешнейСистемыИнтеграцииОбсудения(Обсуждение);
	
	ОбработчикиОбсуждений = МессенджерыКлиентСервер.ОбработчикиОбсужденийПоТипуВнешнейСистемы();
	ОбработчикОбсуждения = ОбработчикиОбсуждений.Получить(ТипВнешнейСистемы);
	
	Если ОбработчикОбсуждения <> Неопределено Тогда
		Обработчик = ОбщегоНазначенияКлиент.ОбщийМодуль(ОбработчикОбсуждения);
		Обработчик.ОбработкаВыбораШаблонаСообщенияСистемыВзаимодействия(Обсуждение, СтандартнаяОбработка);
	КонецЕсли;
	
КонецПроцедуры

// См. ОбщегоНазначенияКлиентПереопределяемый.ПослеНачалаРаботыСистемы
Процедура ПослеНачалаРаботыСистемы() Экспорт
	
	ПодключитьОбработчикФормированияКомандОбсуждений();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ПриФормированииКоманд(Параметры, Команды, КомандаПОУмолчанию, ДополнительныеПараметры) Экспорт
	
	Если Параметры.Обсуждение.Интеграция <> Неопределено
		И Параметры.Источник = ИсточникКомандСистемыВзаимодействия.Пользователь Тогда
		
		ДанныеОбсужденияСПользователем = МессенджерыВызовСервера.ОписаниеВнешнейСистемыОбсужденияИнтеграции(
			Параметры.Обсуждение.Интеграция, Параметры.Пользователь);
		ТипВнешнийСистемыWhatsApp = МессенджерыКлиентСервер.ТипВнешнийСистемыWhatsApp();
			
		Если ДанныеОбсужденияСПользователем.ТипВнешнейСистемыИнтеграции = ТипВнешнийСистемыWhatsApp
			И ДанныеОбсужденияСПользователем.ТипВнешнейСистемыПользователя = ТипВнешнийСистемыWhatsApp Тогда
			
			ПараметрыКоманды = Новый Структура;
			ПараметрыКоманды.Вставить("Параметры", Параметры);
			ПараметрыКоманды.Вставить("Команды", Команды);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаОткрытияСпискаКонтактов",
				МессенджерыКлиент, ПараметрыКоманды);
			
			Команда = Новый ОписаниеКомандыСистемыВзаимодействия(ОписаниеОповещения, НСтр("ru='Найти контакт'"));
			Команда.Картинка = БиблиотекаКартинок.ИконкаКонтактногоЛица;
			Команды.Добавить(Команда);
			
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОбработкаОткрытияСпискаКонтактов(ПараметрыКоманды) Экспорт

	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("НомерТелефона", ПараметрыКоманды.Параметры.Обсуждение.Заголовок);
	
	ОткрытьФорму("Обработка.Мессенджеры.Форма.ФормаКонтактовАбонента", ПараметрыОткрытия);
	
КонецПроцедуры

Процедура ПодключитьОбработчикФормированияКомандОбсуждений()
	
	Вызов = Новый ОписаниеОповещения("ПриФормированииКоманд", МессенджерыКлиент);
	СистемаВзаимодействия.ПодключитьОбработчикФормированияКоманд(Вызов);
	
КонецПроцедуры

#КонецОбласти