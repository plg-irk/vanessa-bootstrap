#Область ОтправкаСообщений

// См. ОнлайнЗаказыПереопределяемый.ПриОпределенииПредопределенныхШаблоновСообщенийОнлайнЗаказовПоТипам.
//
Процедура ПриОпределенииПредопределенныхШаблоновСообщенийОнлайнЗаказовПоТипам(Шаблоны) Экспорт 
	
	ИменаОснованийЗаказа 	  = Новый Массив;
	ПриОпределенииОснованияЗаказа(ИменаОснованийЗаказа);

	// подготовка макета шаблона
	Шаблон				  = Новый Структура("Тело, Тема, ЗначенияРеквизитов");
	МакетШаблона 		  = ПолучитьОбщийМакет("ШаблонСообщенияОплатаСБП");
	Тело 		 		  = МакетШаблона.ПолучитьТекст();
	Тема	 	 		  = НСтр("ru = 'Счет на оплату номер [ТипОснования.Номер] на сумму [ТипОснования.СуммаДокумента] руб.'");

	Тело 		 		  = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		Тело,
		НСтр("ru='Благодарим за заказ и просим оплатить счет'"),
		НСтр("ru='Номер заказа:'"),
		НСтр("ru='Идентификатор плательщика:'"),
		НСтр("ru='Сумма:'"),
		НСтр("ru='Для оплаты счета перейдите по ссылке'"));
		
	ЗначенияРеквизитов 	  = Новый Структура;
	ЗначенияРеквизитов.Вставить("Номер", 					"Номер");
	ЗначенияРеквизитов.Вставить("СуммаДокумента", 			"СуммаОнлайнЗаказа");
	ЗначенияРеквизитов.Вставить("Покупатель", 				"Покупатель");          
	ЗначенияРеквизитов.Вставить("КнопкаОплатитьЧерезСБП", 	"ПредставлениеСсылкиОнлайнЗаказ");          

	Шаблон.Тело				  = Тело;
	Шаблон.Тема				  = Тема;
	Шаблон.ЗначенияРеквизитов = ЗначенияРеквизитов;

	Наименование		  	  = НСтр("ru = 'Счет на оплату через СБП (%1)'");
	ИменаОснованийПлатежа 	  = Новый Массив;
	ПриОпределенииОснованияЗаказа(ИменаОснованийЗаказа);	

	Для каждого ПолноеИмя Из ИменаОснованийПлатежа Цикл
		
		МетаданныеОбъекта   = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
		ИмяОбъекта 			= МетаданныеОбъекта.Имя;
		Представление   	= МетаданныеОбъекта.Синоним;

		ТелоШаблона			= Шаблон.Тело;
		ТемаШаблона			= Шаблон.Тема;
		
		Для Каждого ПараметрШаблона Из Шаблон.ЗначенияРеквизитов Цикл
		
        	ТелоШаблона = СтрЗаменить(ТелоШаблона, 
				"[ТипОснования." + ПараметрШаблона.Ключ + "]", 
				"[" + ИмяОбъекта + "." + ПараметрШаблона.Значение + "]");
			
        	ТемаШаблона = СтрЗаменить(ТемаШаблона, 
				"[ТипОснования." + ПараметрШаблона.Ключ + "]", 
				"[" + ИмяОбъекта + "." + ПараметрШаблона.Значение + "]");
		
		КонецЦикла;

		Если ИмяОбъекта = "АктВыполненныхРабот" Тогда //Для акта недоступно поле "Покупатель"
			ТелоШаблона = СтрЗаменить(ТелоШаблона, ИмяОбъекта + ".Покупатель", ИмяОбъекта + ".Контрагент"); 
		КонецЕсли; 
		
		ШаблонДокумента 			= Новый Структура();
		ШаблонДокумента.Вставить("ТипШаблона", 				"Письмо");
		ШаблонДокумента.Вставить("ПолноеИмяТипаНазначения",	ПолноеИмя);
		ШаблонДокумента.Вставить("Наименование", 			СтрШаблон(Наименование, Представление));
		ШаблонДокумента.Вставить("Тема", 					ТемаШаблона);
		ШаблонДокумента.Вставить("Текст", 					ТелоШаблона);

		Шаблоны.Добавить(ШаблонДокумента);
		
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция QRКодПоРеквизитам(ДанныеШапки, СведенияОбОрганизации)
	
	РеквизитыПлатежа = НовыйРеквизитыПлатежаУФЭБС();
	
	РеквизитыПлатежа.ТекстПолучателя             = СведенияОбОрганизации.ПолноеНаименование;
	РеквизитыПлатежа.НомерСчетаПолучателя        = СведенияОбОрганизации.НомерСчета;
	РеквизитыПлатежа.НаименованиеБанкаПолучателя = Строка(СведенияОбОрганизации.Банк);
	РеквизитыПлатежа.БИКБанкаПолучателя          = СведенияОбОрганизации.БИК;
	РеквизитыПлатежа.СчетБанкаПолучателя         = СведенияОбОрганизации.КоррСчет;
	
	РеквизитыПлатежа.ИННПолучателя               = СведенияОбОрганизации.ИНН;
	РеквизитыПлатежа.КПППолучателя               = СведенияОбОрганизации.КПП;
	
	СуммаКОплате = ДанныеШапки.СуммаДокумента;
	СуммаНДС = ДанныеШапки.СуммаНДС;
	
	РеквизитыПлатежа.СуммаЧислом = СуммаКОплате;
	
	Если СуммаНДС > 0 Тогда
		ТекстПроНДС = НСтр("ru = 'В том числе НДС %1'");
		ТекстПроНДС = СтрШаблон(ТекстПроНДС, Формат(СуммаНДС, "ЧЦ=15; ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ="));
	Иначе
		ТекстПроНДС = НСтр("ru = 'Без налога (НДС)'");
	КонецЕсли;
	
	РеквизитыПлатежа.НазначениеПлатежа = СтрШаблон(НСтр("ru = 'Оплата по счету № %1 от %2. Сумма %3. %4.'"),
		ДанныеШапки.Номер,
		Формат(ДанныеШапки.Дата, "ДФ=dd.MM.yyyy"),
		Формат(СуммаКОплате, "ЧЦ=15; ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ="),
		ТекстПроНДС);
	
	QRСтрока = УправлениеПечатьюРФ.ФорматнаяСтрокаУФЭБС(РеквизитыПлатежа);
	Если ПустаяСтрока(QRСтрока) Тогда
		Возврат Неопределено; // Возникли ошибки
	КонецЕсли;
	
	Возврат QRСтрока;
	
Конецфункции

// Формирует новое описание свойств для формирования форматной строки УФЭБС.
//
// Возвращаемое значение:
//  Структура - содержит описание свойств.
//
Функция НовыйРеквизитыПлатежаУФЭБС()
	
	Возврат Новый Структура(
		"ТекстПолучателя,
		|НомерСчетаПолучателя,
		|НаименованиеБанкаПолучателя,
		|БИКБанкаПолучателя,
		|СчетБанкаПолучателя,
		|ИндексПлатежногоДокумента,
		|ИННПолучателя,
		|КПППолучателя,
		|СуммаЧислом,
		|НазначениеПлатежа");
	
КонецФункции

// Имена форм, в которые не должны быть добавлены команды
// 
// Возвращаемое значение:
//  Массив из Строка - Имена исключаемых форм
Функция ИменаИсключаемыхФорм()
	
	ИсключаемыеФормы = Новый Массив;
	ИсключаемыеФормы.Добавить("ФормаСпискаЗаказНаряда");
	
	Возврат ИсключаемыеФормы;
	
КонецФункции

Функция ТипыОбъектовСУсловиемВидимости()
	
	ТипыОбъектовСУсловиемВидимости = Новый Массив;
	ТипыОбъектовСУсловиемВидимости.Добавить(Тип("ДокументСсылка.ЗаказПокупателя"));
	
	Возврат ТипыОбъектовСУсловиемВидимости;
	
КонецФункции

Процедура УстановитьУсловиеВидимости(ТипыИсточников, ТипыОбъектовСУсловиемВидимости, Команды)
	
	Для Каждого ТипыОбъектаСУсловиемВидимости Из ТипыОбъектовСУсловиемВидимости Цикл
		Если ТипыИсточников.Найти(ТипыОбъектаСУсловиемВидимости) <> Неопределено Тогда
			ПодключаемыеКомандыУНФ.ДобавитьУсловиеВидимостиКомандыОбъекта(Команды, "ОнлайнЗаказы", "ОнлайнЗаказы",
				"ВидОперации", Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд, ВидСравненияКомпоновкиДанных.НеРавно);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
 