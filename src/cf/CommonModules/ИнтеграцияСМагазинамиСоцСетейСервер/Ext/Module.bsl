Функция АвторизацияVKIDStateПолучить()

	Результат = Строка( Новый УникальныйИдентификатор );

	Возврат Результат;
КонецФункции

Функция АвторизацияVKIDCodeChallengeПолучить( Знач Значение )

	Результат = ИнтеграцияИС.ХешированиеДанныхSHA256( Значение );
	
	Результат = СтрЗаменить( Результат, "=", "" );
	Результат = СтрЗаменить( Результат, "+", "-" );
	Результат = СтрЗаменить( Результат, "/", "_" );

	Возврат Результат;
КонецФункции

Функция АвторизацияVKIDCodeVerifierНовый()

	Результат = Строка( Новый УникальныйИдентификатор )	+ Строка( Новый УникальныйИдентификатор );
	
	Возврат Результат;
КонецФункции

Функция АвторизацияVKIDПоменятьКодНаТокен( АвторизацияVKIDПараметры ) Экспорт
	
	Таймаут = 10;
	Заголовки = Новый Соответствие;
	Заголовки.Вставить( "Content-Type", "application/x-www-form-urlencoded" );
	Соединение = Новый HTTPСоединение( АвторизацияVKIDИмяСервера(), , , , , Таймаут, Новый ЗащищенноеСоединениеOpenSSL );
	
	ЗапросТело = 
	"grant_type=authorization_code"
	+ "&code_verifier=" + АвторизацияVKIDПараметры.code_verifier
	+ "&redirect_uri=" + АвторизацияVKIDПараметры.redirect_uri
	+ "&code=" + АвторизацияVKIDПараметры.code
	+ "&client_id=" + АвторизацияVKIDПараметры.client_id
	+ "&device_id=" + АвторизацияVKIDПараметры.device_id
	+ "&state=" + АвторизацияVKIDПараметры.state;
	
	HTTPЗапрос = Новый HTTPЗапрос( АвторизацияVKIDАдресРесурса(), Заголовки );
	
	HTTPЗапрос.УстановитьТелоИзСтроки( ЗапросТело );

	HTTPОтвет = Соединение.ОтправитьДляОбработки( HTTPЗапрос );
	HTTPОтветТелоКакСтрока = HTTPОтвет.ПолучитьТелоКакСтроку();
	
	ОтветДанные = JSONВДанные( HTTPОтветТелоКакСтрока );

	Если ОтветДанные.Свойство( "error" ) Тогда
	
		ОшибкаТекстДополнение = 
		ОбменСВнешнимиСистемамиЛогирование.БазаЗнанийСовпаденияНайтиСтрокойПолучить(
		"ВКонтакте: " + ОтветДанные.error_description );
		
		ОшибкаТекстДополнение = ОшибкаТекстДополнение + ?(ПустаяСтрока( ОшибкаТекстДополнение ), "", " " )
		+ НСтр( "ru = 'Ответ сайта ВКонтакте'" );
	
		ОшибкаШаблон = НСтр( "ru = 'Ошибка при обновлении токена доступа ВКонтакте: %1: %2: %3'" );
		ОшибкаТекст = СтрШаблон( ОшибкаШаблон, ОшибкаТекстДополнение, ОтветДанные.error, ОтветДанные.error_description );
		
		ОбщегоНазначения.СообщитьПользователю( ОшибкаТекст );
		
		ОбменСВнешнимиСистемамиЛогирование.ЗаписатьВЛог( ОшибкаТекст, АвторизацияVKIDПараметры.УчетнаяЗапись, Истина );
		
	КонецЕсли;
	
	Возврат ОтветДанные;
КонецФункции

Функция АвторизацияVKIDОбновитьТокенПоТокенуОбновления( АвторизацияVKIDПараметры ) Экспорт
	
	Таймаут = 10;
	Заголовки = Новый Соответствие;
	Заголовки.Вставить( "Content-Type", "application/x-www-form-urlencoded" );
	Соединение = Новый HTTPСоединение( АвторизацияVKIDИмяСервера(), , , , , Таймаут, Новый ЗащищенноеСоединениеOpenSSL );
	
	ЗапросТело = 
	"grant_type=refresh_token"
	+ "&refresh_token=" + АвторизацияVKIDПараметры.refresh_token
	+ "&client_id=" + АвторизацияVKIDПараметры.client_id
	+ "&device_id=" + АвторизацияVKIDПараметры.device_id
	+ "&state=" + АвторизацияVKIDПараметры.state;
	
	HTTPЗапрос = Новый HTTPЗапрос( АвторизацияVKIDАдресРесурса(), Заголовки );
	
	HTTPЗапрос.УстановитьТелоИзСтроки( ЗапросТело );

	HTTPОтвет = Соединение.ОтправитьДляОбработки( HTTPЗапрос );
	HTTPОтветТелоКакСтрока = HTTPОтвет.ПолучитьТелоКакСтроку();
	
	ОтветДанные = JSONВДанные( HTTPОтветТелоКакСтрока );
	
	Возврат ОтветДанные;
КонецФункции

Процедура АвторизацияVKIDТокенДоступаОбновить( ОписаниеУзелОбмена ) Экспорт

	УчетнаяЗапись = ОписаниеУзелОбмена.Ссылка;
	
	АвторизацияПараметры = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.АвторизацияВКонтактеПараметрыНовый(
	ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииVKID() );
	
	АвторизацияВКонтактеПараметрыИзБезопасногоХранилищеПолучить( УчетнаяЗапись, АвторизацияПараметры );
	
	ТекущаяДатаСеанса = ТекущаяДатаСеанса();
	
	ОтветДанные = АвторизацияVKIDОбновитьТокенПоТокенуОбновления( АвторизацияПараметры );

	Если ОтветДанные.Свойство( "error" ) Тогда
	
		ОшибкаТекстДополнение = 
		ОбменСВнешнимиСистемамиЛогирование.БазаЗнанийСовпаденияНайтиСтрокойПолучить(
		"ВКонтакте: " + ОтветДанные.error_description );
		
		ОшибкаТекстДополнение = ОшибкаТекстДополнение + ?(ПустаяСтрока( ОшибкаТекстДополнение ), "", " " )
		+ НСтр( "ru = 'Ответ сайта ВКонтакте'" );
	
		ОшибкаШаблон = НСтр( "ru = 'Ошибка при обновлении токена доступа ВКонтакте: %1: %2: %3'" );
		ОшибкаТекст = СтрШаблон( ОшибкаШаблон, ОшибкаТекстДополнение, ОтветДанные.error, ОтветДанные.error_description );
		
		ОбщегоНазначения.СообщитьПользователю( ОшибкаТекст );
		
		ОбменСВнешнимиСистемамиЛогирование.ЗаписатьВЛог( ОшибкаТекст, УчетнаяЗапись, Истина );
		
		Возврат;
	КонецЕсли;
	
	АвторизацияПараметры.access_token = ОтветДанные.access_token;
	АвторизацияПараметры.refresh_token = ОтветДанные.refresh_token;
	АвторизацияПараметры.ОкончанияДействияТокенаДоступа = ТекущаяДатаСеанса + ОтветДанные.expires_in;
	
	АвторизацияВКонтактеПараметрыВБезопасноеХранилищеЗаписать( УчетнаяЗапись, АвторизацияПараметры );
	
	ОписаниеУзелОбмена.ТокенДоступа = АвторизацияПараметры.access_token;
	ОписаниеУзелОбмена.ОкончанияДействияТокенаДоступа = АвторизацияПараметры.ОкончанияДействияТокенаДоступа;
	
КонецПроцедуры

Функция JSONВДанные(СтрокаJSON, ПрочитатьВСоответствие = Ложь, ИменаСвойствСоЗначениямиДата = Неопределено)

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку( СтрокаJSON );
	Результат = ПрочитатьJSON( ЧтениеJSON, ПрочитатьВСоответствие, ИменаСвойствСоЗначениямиДата);
	ЧтениеJSON.Закрыть();

	Возврат Результат;

КонецФункции

#КонецОбласти

Процедура ЗарегистрироватьВсеДанныеКОбменуНаСервере(УзелИнформационнойБазы, ТолькоЦенаИКоличество = Ложь) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НоменклатураХарактеристикДляМагазинаСоцСетей.Номенклатура КАК СсылкаДанные
		|ИЗ
		|	РегистрСведений.НоменклатураХарактеристикДляМагазинаСоцСетей КАК НоменклатураХарактеристикДляМагазинаСоцСетей
		|ГДЕ
		|	НЕ &ТолькоЦенаИКоличество
		|			И НоменклатураХарактеристикДляМагазинаСоцСетей.УзелИнформационнойБазы = &УзелИнформационнойБазы
		|	И НоменклатураХарактеристикДляМагазинаСоцСетей.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НоменклатураХарактеристикДляМагазинаСоцСетей.Характеристика
		|ИЗ
		|	РегистрСведений.НоменклатураХарактеристикДляМагазинаСоцСетей КАК НоменклатураХарактеристикДляМагазинаСоцСетей
		|ГДЕ
		|	НЕ &ТолькоЦенаИКоличество
		|			И НоменклатураХарактеристикДляМагазинаСоцСетей.УзелИнформационнойБазы = &УзелИнформационнойБазы
		|	И НоменклатураХарактеристикДляМагазинаСоцСетей.Характеристика <> ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НоменклатураХарактеристикДляМагазинаСоцСетейВиртуальныеКаталоги.ВиртуальныйКаталог
		|ИЗ
		|	РегистрСведений.НоменклатураХарактеристикДляМагазинаСоцСетейВиртуальныеКаталоги КАК НоменклатураХарактеристикДляМагазинаСоцСетейВиртуальныеКаталоги
		|ГДЕ
		|	НЕ &ТолькоЦенаИКоличество
		|			И НоменклатураХарактеристикДляМагазинаСоцСетейВиртуальныеКаталоги.УзелИнформационнойБазы = &УзелИнформационнойБазы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Период КАК Период,
		|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			,
		|			ВидЦен В
		|					(ВЫБРАТЬ
		|						ИнтеграцияСМагазинамиСоцСетей.ВидЦеныНоменклатуры КАК ВидЦены
		|					ИЗ
		|						ПланОбмена.ИнтеграцияСМагазинамиСоцСетей КАК ИнтеграцияСМагазинамиСоцСетей
		|					ГДЕ
		|						ИнтеграцияСМагазинамиСоцСетей.Ссылка = &УзелИнформационнойБазы
		|			
		|					ОБЪЕДИНИТЬ ВСЕ
		|			
		|					ВЫБРАТЬ
		|						ИнтеграцияСМагазинамиСоцСетей.ВидЦеныНоменклатурыСтарая
		|					ИЗ
		|						ПланОбмена.ИнтеграцияСМагазинамиСоцСетей КАК ИнтеграцияСМагазинамиСоцСетей
		|					ГДЕ
		|						ИнтеграцияСМагазинамиСоцСетей.Ссылка = &УзелИнформационнойБазы)
		|				И (Номенклатура, Характеристика) В
		|					(ВЫБРАТЬ
		|						НоменклатураХарактеристикДляМагазинаСоцСетей.Номенклатура КАК Номенклатура,
		|						НоменклатураХарактеристикДляМагазинаСоцСетей.Характеристика КАК Характеристика
		|					ИЗ
		|						РегистрСведений.НоменклатураХарактеристикДляМагазинаСоцСетей КАК НоменклатураХарактеристикДляМагазинаСоцСетей
		|					ГДЕ
		|						НоменклатураХарактеристикДляМагазинаСоцСетей.УзелИнформационнойБазы = &УзелИнформационнойБазы)) КАК ЦеныНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("УзелИнформационнойБазы", УзелИнформационнойБазы);
	Запрос.УстановитьПараметр("ТолькоЦенаИКоличество", ТолькоЦенаИКоличество);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Если НЕ ТолькоЦенаИКоличество Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса[0].Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ПланыОбмена.ЗарегистрироватьИзменения(УзелИнформационнойБазы, ВыборкаДетальныеЗаписи.СсылкаДанные);
		КонецЦикла;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса[1].Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(ВыборкаДетальныеЗаписи.Период);
		НаборЗаписей.Отбор.ВидЦен.Установить(ВыборкаДетальныеЗаписи.ВидЦен);
		НаборЗаписей.Отбор.Номенклатура.Установить(ВыборкаДетальныеЗаписи.Номенклатура);
		НаборЗаписей.Отбор.Характеристика.Установить(ВыборкаДетальныеЗаписи.Характеристика);
		
		ПланыОбмена.ЗарегистрироватьИзменения(УзелИнформационнойБазы, НаборЗаписей);
	КонецЦикла;
	
	Если НЕ ТолькоЦенаИКоличество Тогда
		НаборЗаписей = РегистрыСведений.ХешКонтролируемыхРеквизитовДляМагазинаСоцСетей.СоздатьНаборЗаписей();
		НаборЗаписей.Записать();
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.ОстаткиТоваровМагазинаСоцСетей.СоздатьНаборЗаписей();
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура АвторизацияВКонтактеПараметрыВБезопасноеХранилищеЗаписать( УчетнаяЗапись, АвторизацияПараметры ) Экспорт

	Ключи = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.АвторизацияВКонтактеБезопасноеХранилищеКлючиПолучить( АвторизацияПараметры.СпособАвторизации );
	ДанныеДляЗаписи = Новый Структура( Ключи );
	ЗаполнитьЗначенияСвойств( ДанныеДляЗаписи, АвторизацияПараметры );
	
	УстановитьПривилегированныйРежим(Истина);
	ОбщегоНазначения.ЗаписатьДанныеВБезопасноеХранилище(УчетнаяЗапись, ДанныеДляЗаписи, Неопределено);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Процедура АвторизацияВКонтактеПараметрыИзБезопасногоХранилищеПолучить( УчетнаяЗапись, АвторизацияПараметры ) Экспорт

	Ключи = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.АвторизацияВКонтактеБезопасноеХранилищеКлючиПолучить( АвторизацияПараметры.СпособАвторизации );
	УстановитьПривилегированныйРежим(Истина);
	ДанныеИзБезопасногоХранилища = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(УчетнаяЗапись, Ключи);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ТипЗнч( ДанныеИзБезопасногоХранилища ) <> Тип( "Структура" ) Тогда
		Возврат;
	КонецЕсли;

	ЗаполнитьЗначенияСвойств( АвторизацияПараметры, ДанныеИзБезопасногоХранилища );
	
КонецПроцедуры

#КонецОбласти