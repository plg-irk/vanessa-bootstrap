Функция ЛогОпределитьДействиеПоАдресуРесурсаЗапроса( АдресРесурса )
	
	Если СтрНайти( АдресРесурса, "method/execute" ) > 0 
	И СтрНайти( АдресРесурса, "API.market.edit" ) > 0 Тогда
	
		Возврат Перечисления.ОбменСВнешнимиСистемамиЛогированиеДействия.ВыгрузкаТоваровИз1С;
	
	ИначеЕсли СтрНайти( АдресРесурса, "method/photos.getMarketUploadServer" ) > 0 Тогда
	
		Возврат Перечисления.ОбменСВнешнимиСистемамиЛогированиеДействия.ВыгрузкаИзображенийИз1С;
		
	ИначеЕсли СтрНайти( АдресРесурса, "method/photos.saveMarketPhoto" ) > 0 Тогда
	
		Возврат Перечисления.ОбменСВнешнимиСистемамиЛогированиеДействия.ВыгрузкаИзображенийИз1С;
		
	ИначеЕсли СтрНайти( АдресРесурса, "method/market.getGroupOrders" ) > 0 Тогда
	
		Возврат Перечисления.ОбменСВнешнимиСистемамиЛогированиеДействия.ЗагрузкаЗаказовВ1С;
		
	ИначеЕсли СтрНайти( АдресРесурса, "method/groups.get" ) > 0 Тогда
	
		Возврат Перечисления.ОбменСВнешнимиСистемамиЛогированиеДействия.Прочее;
		
	КонецЕсли;
	
	Возврат Перечисления.ОбменСВнешнимиСистемамиЛогированиеДействия.Прочее;
	
КонецФункции

Процедура СопоставлениеИдентификаторовМагазиновСоцСетейПоИдентификаторуУдалить( СсылкаНаУзелОбмена, ТипИдентификатора, Идентификатор ) Экспорт
	
	ЗапросТекст = 
	"ВЫБРАТЬ
	|	СопоставлениеИдентификаторовМагазиновСоцСетей.УзелИнформационнойБазы КАК УзелИнформационнойБазы,
	|	СопоставлениеИдентификаторовМагазиновСоцСетей.Ссылка КАК Ссылка,
	|	СопоставлениеИдентификаторовМагазиновСоцСетей.ТипИдентификатора КАК ТипИдентификатора,
	|	СопоставлениеИдентификаторовМагазиновСоцСетей.Идентификатор КАК Идентификатор,
	|	СопоставлениеИдентификаторовМагазиновСоцСетей.ДатаЗагрузки КАК ДатаЗагрузки
	|ИЗ
	|	РегистрСведений.СопоставлениеИдентификаторовМагазиновСоцСетей КАК СопоставлениеИдентификаторовМагазиновСоцСетей
	|ГДЕ
	|	СопоставлениеИдентификаторовМагазиновСоцСетей.УзелИнформационнойБазы = &СсылкаНаУзелОбмена
	|	И СопоставлениеИдентификаторовМагазиновСоцСетей.ТипИдентификатора = &ТипИдентификатора
	|	И СопоставлениеИдентификаторовМагазиновСоцСетей.Идентификатор = &Идентификатор";
	
	ЗапросОбъект = Новый Запрос( ЗапросТекст );
	
	ЗапросОбъект.УстановитьПараметр( "СсылкаНаУзелОбмена", СсылкаНаУзелОбмена );
	ЗапросОбъект.УстановитьПараметр( "ТипИдентификатора", ТипИдентификатора );
	ЗапросОбъект.УстановитьПараметр( "Идентификатор", Идентификатор );
	
	ЗапросВыборка = ЗапросОбъект.Выполнить().Выбрать();
	Если ЗапросВыборка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	НаборЗаписей = РегистрыСведений.СопоставлениеИдентификаторовМагазиновСоцСетей.СоздатьНаборЗаписей();

	НаборЗаписей.Отбор.УзелИнформационнойБазы.Установить( СсылкаНаУзелОбмена );
	НаборЗаписей.Отбор.ТипИдентификатора.Установить( ТипИдентификатора );

	Пока ЗапросВыборка.Следующий() Цикл
		
		НаборЗаписей.Отбор.Ссылка.Установить( ЗапросВыборка.Ссылка );
		НаборЗаписей.Записать( Истина );
		
	КонецЦикла;

КонецПроцедуры

#Область АвторизацияVKID

// https://id.vk.com/about/business/go/docs/ru/vkid/latest/vk-id/connection/api-description
// code - действует 10 минут
// access_token - действует 1 час
// refresh_token - обновляет пару access_token и refresh_token

Процедура АвторизацияVKIDПараметрыЗаполнитьПоУмолчанию( Результат, ИдентификаторПриложения ) Экспорт

	Результат.СпособАвторизации = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииVKID();
	
	Результат.client_id = Формат( ИдентификаторПриложения, "ЧГ=0" ); // идентификатор приложения
	Результат.redirect_uri = "https://oauth.vk.com/blank.html"; // адрес перенаправления, должен совпадать с настройками приложения
	Результат.state = АвторизацияVKIDStateПолучить(); // произвольная строка состояния
	Результат.scope = "groups,market,photos,offline,docs"; // список доступов

	Результат.code_verifier = АвторизацияVKIDCodeVerifierНовый(); // параметр для защиты передаваемых данных
	Результат.code_challenge = АвторизацияVKIDCodeChallengeПолучить( Результат.code_verifier ); // преобразованный code_verifier
	Результат.code_challenge_method = "S256"; // метод преобразования code_verifier

	АвторизацияСтрокаURL = 
	"https://id.vk.com/authorize?response_type=code"
	+ "&client_id=" + Результат.client_id
	+ "&redirect_uri=" + Результат.redirect_uri
	+ "&state=" + Результат.state
	+ "&code_challenge=" + Результат.code_challenge
	+ "&code_challenge_method=" + Результат.code_challenge_method
	+ "&scope=" + Результат.scope;
	
	Результат.АвторизацияСтрокаURL = АвторизацияСтрокаURL;
	
КонецПроцедуры

