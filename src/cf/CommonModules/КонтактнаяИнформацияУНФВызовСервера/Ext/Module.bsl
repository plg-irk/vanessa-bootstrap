
#Область ПрограммныйИнтерфейс

// Если XMLСтрока еще не задана, то ОжидаемыйВид - обязательный параметр
//
Процедура УстановитьКомментарийКонтактнойИнформации(XMLСтрока, Комментарий, ОжидаемыйВид = Неопределено) Экспорт
	
	Если ПустаяСтрока(XMLСтрока) Тогда
		XMLСтрока = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению("", ОжидаемыйВид);
	КонецЕсли;
	
	УправлениеКонтактнойИнформацией.УстановитьКомментарийКонтактнойИнформации(XMLСтрока, Комментарий);
	
КонецПроцедуры

// Описание см. УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению()
//
Функция КонтактнаяИнформацияПоПредставлению(Представление, ОжидаемыйВид) Экспорт
	
	Возврат УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Представление, ОжидаемыйВид);
	
КонецФункции

// Строка - строка для обработки
//
Функция ПолучитьXMLСтрока(Строка) Экспорт
	
	Возврат КонтактнаяИнформацияУНФ.ПолучитьXMLСтрока(Строка);
	
КонецФункции

// Возвращает структуру параметров доступных команд для вызова меню контактной информацмм
// 
// Возвращаемое значение:
//  Структура - параметры контактной информации
Функция ПолучитьПараметрыКонтактнойИнформацииНаСервере() Экспорт

	ПараметрыКИ = Новый Структура;      
	ПараметрыКИ.Вставить("ОписаниеКоманд", УправлениеКонтактнойИнформацией.ОписаниеКоманд());  
	
	// Определяем доступность отправки SMS
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ОтправкаSMS") Тогда
		МодульОтправкаSMS  = ОбщегоНазначения.ОбщийМодуль("ОтправкаSMS");
		МожноОтправлятьSMS = МодульОтправкаSMS.ДоступнаОтправкаSMS();
	Иначе
		МожноОтправлятьSMS = Ложь;
	КонецЕсли;
	ПараметрыКИ.Вставить("МожноОтправлятьSMS", МожноОтправлятьSMS); 
	
	// Разрешаем открытие веб-ссылок
	ПараметрыКИ.Вставить("ОбработкаНавигационнойСсылки", Ложь);
    
	// Добавляем в структуру вспомогательные параметры, используемые в УправлениеКонтактнойИнформациейУНФ.ПриОпределенииНастроек
	ПараметрыКИ.Вставить("ШиринаПоляКомментарий", 0);
	ПараметрыКИ.Вставить("ПоложениеКнопкиДобавить", Неопределено);
	УправлениеКонтактнойИнформациейУНФ.ПриОпределенииНастроек(ПараметрыКИ);   
	// Очищаем значение параметра ПоложениеКнопкиДобавить, чтобы отработало клиент-серверное взаимодействие
	ПараметрыКИ.Вставить("ПоложениеКнопкиДобавить", Неопределено);

	Возврат ПараметрыКИ;
	
КонецФункции    

#КонецОбласти

#Область СлужебныеПроцедурыИФукнции

Функция АдресВключитьХранениеИстории( ВидКонтактнойИнформации ) Экспорт
	Возврат УправлениеКонтактнойИнформациейУНФ.АдресВключитьХранениеИстории( ВидКонтактнойИнформации );
КонецФункции

#КонецОбласти