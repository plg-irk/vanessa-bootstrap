#Область ПрограммныйИнтерфейс

// Обработчик команд, добавленных динамически и подключенных к обработчику "Подключаемый_Команда".
// Пример добавления команды см. ОтчетыПереопределяемый.ПриСозданииНаСервере().
//
// Параметры:
//   ФормаОтчета - ФормаКлиентскогоПриложения
//               - РасширениеУправляемойФормыДляОтчета - форма отчета:
//                   * Отчет - ОтчетОбъект - структура данных формы аналогичная объекту отчета.
//
//   Команда     - КомандаФормы     - команда, которая была вызвана.
//   Результат   - Булево           - Истина, если вызов команды обработан.
//
Процедура ОбработчикКоманды(ФормаОтчета, Команда, Результат) Экспорт
	
	Если Команда.Имя = "СоздатьЗадачуПоРезультатамОтчета" Тогда
		
		Если ФормаОтчета.КонтактыОтчета.Количество() = 0 Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Нет данных для экспорта'"));
			Возврат;
		КонецЕсли;
		
		МассивКонтактов = Новый Массив;
		Для Каждого Контакт Из ФормаОтчета.КонтактыОтчета Цикл
			МассивКонтактов.Добавить(Контакт.Контакт);
		КонецЦикла;
		
		ЗначенияЗаполнения = Новый Структура;
		ЗначенияЗаполнения.Вставить("Основание", МассивКонтактов);
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ОткрытьФорму("Документ.ЗадачаСотрудника.ФормаОбъекта", ПараметрыФормы); 
		
	ИначеЕсли Команда.Имя = "ЭкспортироватьКонтактыОтчета" Тогда
		
		Если ФормаОтчета.КонтактыОтчета.Количество() = 0 Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Нет данных для экспорта'"));
			Возврат;
		КонецЕсли;
		
		МассивКонтактов = Новый Массив;
		Для Каждого Контакт Из ФормаОтчета.КонтактыОтчета Цикл
			МассивКонтактов.Добавить(Контакт.Контакт);
		КонецЦикла;
		
		МассовыеРассылкиКлиент.ЭкспортКонтактовВСервисРассылок(МассивКонтактов);

	ИначеЕсли Команда.Имя = "ВключитьРезультатВЕмейлРассылку" Тогда
		
		Если ФормаОтчета.КонтактыОтчета.Количество() = 0 Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Нет данных для экспорта'"));
			Возврат;
		КонецЕсли;
		
		МассивКонтактов = Новый Массив;
		Для Каждого Контакт Из ФормаОтчета.КонтактыОтчета Цикл
			МассивКонтактов.Добавить(Контакт.Контакт);
		КонецЦикла;
		
		МассовыеРассылкиКлиент.ДобавитьКонтактыВМассовыеРассылки(МассивКонтактов,
			ФормаОтчета.ВидСвязиЕмейл);	
		
	ИначеЕсли Команда.Имя = "ВключитьРезультатВСмсРассылку" Тогда
		
		Если ФормаОтчета.КонтактыОтчета.Количество() = 0 Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'Нет данных для экспорта'"));
			Возврат;
		КонецЕсли;
		
		МассивКонтактов = Новый Массив;
		Для Каждого Контакт Из ФормаОтчета.КонтактыОтчета Цикл
			МассивКонтактов.Добавить(Контакт.Контакт);
		КонецЦикла;
		
		МассовыеРассылкиКлиент.ДобавитьКонтактыВМассовыеРассылки(МассивКонтактов, 
			ФормаОтчета.ВидСвязиСмс);	 
			
	ИначеЕсли Команда.Имя = "РасширитьСегментыКонтрагентовПоРезультатамОтчета" Тогда
		
		МассивКонтрагентов = Новый Массив;
		
		Для Каждого ЭлементКонтакта Из ФормаОтчета.КонтактыОтчета Цикл  
			Контакт = ЭлементКонтакта.Контакт;  
			Если ТипЗнч(Контакт) = Тип("СправочникСсылка.Контрагенты") Тогда
				МассивКонтрагентов.Добавить(Контакт);
			КонецЕсли;
		КонецЦикла;
		Если МассивКонтрагентов.Количество() = 0 Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'В отчете не найдены контрагенты'"));	
			Возврат;
		КонецЕсли;  
		
		СтруктураЗаполнения = Новый Структура;
		СтруктураЗаполнения.Вставить("МассивКонтрагентов",МассивКонтрагентов);
		
		ОткрытьФорму("Справочник.СегментыКонтрагентов.Форма.ДобавлениеКонтрагентовВСегменты", СтруктураЗаполнения,ФормаОтчета,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
	ИначеЕсли Команда.Имя = "РасширитьСегментыНоменклатурыПоРезультатамОтчета" Тогда
		
		МассивНоменклатуры = Новый Массив;
		
		Для Каждого ЭлементНоменклатура Из ФормаОтчета.НоменклатураОтчета Цикл  
			Номенклатура = ЭлементНоменклатура.Номенклатура;  
			Если ТипЗнч(Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
				МассивНоменклатуры.Добавить(Номенклатура);
			КонецЕсли;
		КонецЦикла;
		Если МассивНоменклатуры.Количество() = 0 Тогда
			ПоказатьПредупреждение(,НСтр("ru = 'В отчете не найдена номенклатура'"));	
			Возврат;
		КонецЕсли;  
		
		СтруктураЗаполнения = Новый Структура;
		СтруктураЗаполнения.Вставить("МассивНоменклатуры",МассивНоменклатуры);
		
		ОткрытьФорму("Справочник.СегментыНоменклатуры.Форма.ДобавлениеНоменклатурыВСегменты", СтруктураЗаполнения,ФормаОтчета,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			
	КонецЕсли;
	
	УправлениеНебольшойФирмойОтчетыКлиент.ОбработчикКоманды(ФормаОтчета, Команда, Результат);
	
	// ИнтеграцияЕГАИС
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ФормаОтчета, "ОтчетСформирован") Тогда
		ОтчетыЕГАИСКлиент.ОбработчикКоманды(ФормаОтчета, Команда, Результат);
	КонецЕсли;
	// Конец ИнтеграцияЕГАИС
	
КонецПроцедуры

#КонецОбласти
