
#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// см. ТарификацияПереопределяемый.ПриФормированииСпискаУслуг
//
Процедура ПриФормированииСпискаУслуг(ПоставщикиУслуг) Экспорт
	
	Возврат;
	
КонецПроцедуры

// см. ТарификацияПереопределяемый.ПриИзмененииСостоянияАктивацииЛицензии
//
Процедура ПриИзмененииСостоянияАктивацииЛицензии(ДанныеОЛицензии, ЛицензияАктивирована) Экспорт
	
	Возврат;
	
КонецПроцедуры

// см. ТарификацияПереопределяемый.ПриОбновленииДоступныхЛицензий
//
Процедура ПриОбновленииДоступныхЛицензий(ПараметрыЛицензии) Экспорт
	
	ИмяТекущегоВидаПриложения = ВидыПриложенийСервер.ИмяТекущегоВидаПриложения();
	
	Если ИмяТекущегоВидаПриложения = "" Тогда
		Возврат;
	КонецЕсли;
	
	Если ИмяТекущегоВидаПриложения <> "Бизнес" Тогда
		Возврат;
	КонецЕсли;
	
	ОбновленнаяУслуга = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыЛицензии.Услуга, "Идентификатор");
	СписокПриложений = ПриложенияПоИдентификаторамУслуг(ОбновленнаяУслуга);
	Если СписокПриложений.Количество() = 0 Тогда
		// Услуга, которая не является составляющей комбинированного приложения, ничего делать не требуется.
		Возврат;
	КонецЕсли;
	
	ОписаниеНовогоПриложения = СписокПриложений[0];
	
	// Проверяем - если приложение уже подключено, то повторное подключение не выполняем	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПодключениеКомбинированныхПриложенийСрезПоследних.Статус КАК Статус
		|ИЗ
		|	РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних(, 
		|				ИмяПриложения = &ИмяПриложения) КАК ПодключениеКомбинированныхПриложенийСрезПоследних";
	
	Запрос.УстановитьПараметр("ИмяПриложения", ОписаниеНовогоПриложения.Имя);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда     
		// Если приложение уже подключено, тогда ничего не делаем
		Если ВыборкаДетальныеЗаписи.Статус = Перечисления.СтатусКомбинированногоПриложения.Подключено Тогда
			Возврат;	
		КонецЕсли;
	КонецЕсли;
	
	ВключитьРегламентноеЗаданиеАктуализацияСостоянийПодключенныхПодписок();
	
	ОписаниеСобытия = НСтр("ru='Обновление доступной лицензии: ""%1""; Номер подписки:""%2""; Приложение: ""%3"".'");
	ОписаниеСобытия = СтрШаблон(ОписаниеСобытия, ОбновленнаяУслуга, ПараметрыЛицензии.НомерПодписки, ОписаниеНовогоПриложения.Имя);              

	ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Информация,,, ОписаниеСобытия);
	
	ПроверятьЛицензии = Истина;
	ОтправлятьОповещение = Истина;
	ОбработатьПодключениеПриложения(ОписаниеНовогоПриложения, ОписаниеСобытия, ПроверятьЛицензии, ОтправлятьОповещение);
	
КонецПроцедуры

// см. ТарификацияПереопределяемый.ПриУдаленииДоступныхЛицензий
//
Процедура ПриУдаленииДоступныхЛицензий(ПараметрыЛицензии) Экспорт
	
	ИмяТекущегоВидаПриложения = ВидыПриложенийСервер.ИмяТекущегоВидаПриложения();
	
	Если ИмяТекущегоВидаПриложения = "" Тогда
		Возврат;
	КонецЕсли;
	
	Если ИмяТекущегоВидаПриложения <> "Бизнес" Тогда
		Возврат;
	КонецЕсли;
	
	ОтключаемаяУслуга = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыЛицензии.Услуга, "Идентификатор");
	СписокПриложений = ПриложенияПоИдентификаторамУслуг(ОтключаемаяУслуга);
	Если СписокПриложений.Количество() = 0 Тогда
		// Услуга, которая не является составляющей комбинированного приложения, ничего делать не требуется.
		Возврат;
	КонецЕсли;
	
	ОписаниеОтключаемогоПриложения = СписокПриложений[0];
	
	ИдентификаторПоставщика = ТарификацияУНФ.ИдентификаторПоставщикаУНФ();
	Если ЗарегистрированаАльтернативнаяЛицензияБезлимитнойУслуги(ИдентификаторПоставщика, 
								ОтключаемаяУслуга, ПараметрыЛицензии.НомерПодписки) = Истина Тогда
		Возврат;
	КонецЕсли;

	ОписаниеСобытия = НСтр("ru='Удаление доступной лицензии: ""%1""; Номер подписки:""%2""; Приложение: ""%3"".'");
	ОписаниеСобытия = СтрШаблон(ОписаниеСобытия, ОтключаемаяУслуга, ПараметрыЛицензии.НомерПодписки, ОписаниеОтключаемогоПриложения.Имя);
	ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Информация,,, ОписаниеСобытия);
	
	ПроверятьЛицензии = Истина;
	ОтправлятьОповещение = Истина;
	ОбработатьОтключениеПриложения(
	ОписаниеОтключаемогоПриложения, ОписаниеСобытия, ПроверятьЛицензии, ОтправлятьОповещение);
	
КонецПроцедуры

// См. ОбщегоНазначенияПереопределяемый.ПриДобавленииСерверныхОповещений
//
Процедура ПриДобавленииСерверныхОповещений(Оповещения) Экспорт
	
	Оповещение = СерверныеОповещения.НовоеСерверноеОповещение(ТарификацияБизнесКлиентСервер.ИмяСерверногоОповещения());
	Оповещение.ИмяМодуляПолучения = "ТарификацияБизнесКлиент";
	Оповещения.Вставить(Оповещение.Имя, Оповещение);
	
КонецПроцедуры

#КонецОбласти

// Список услуг.
// 
// Возвращаемое значение:
//  Массив из Структура:
//   * Идентификатор - Строка
//   * Наименование - Строка
//   * ТипУслуги - ПеречислениеСсылка.ТипыУслуг
//
Функция СписокУслуг() Экспорт
	
	Услуги = Новый Массив;
	
	// Мини-приложения
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеВыставлениеСчетов());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеВыставлениеСчетов());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеПоискИПроверкаКонтрагентов());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеПоискИПроверкаКонтрагентов());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	// Приложения
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеCRM());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеCRM());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеОнлайнПродажи());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеОнлайнПродажи());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеОптовыеПродажи());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеОптовыеПродажи());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеПроизводство());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеПроизводство());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеРозничныеПродажи());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеРозничныеПродажи());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеУслуги());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеУслуги());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Услуга = Новый Структура;
	Услуга.Вставить("Идентификатор", ИдентификаторУслугиПриложениеБухгалтерия());
	Услуга.Вставить("Наименование", ИдентификаторУслугиПриложениеБухгалтерия());
	Услуга.Вставить("ТипУслуги", Перечисления.ТипыУслуг.Лимитированная);
	Услуги.Добавить(Услуга);
	
	Возврат Услуги;
	
КонецФункции

// Доступные приложения.
// 
// Параметры:
//  ПроверятьЛицензии - Булево - Проверять лицензии
//  ТолькоБизнесПриложения - Булево - Только бизнес приложения
// 
// Возвращаемое значение:
//  Массив из Структура - Доступные приложения
Функция ДоступныеПриложения(ПроверятьЛицензии, ТолькоБизнесПриложения = Ложь) Экспорт
	
	ВыбратьСПроверкойЛицензий =
	ПроверятьЛицензии
	И ОбщегоНазначения.РазделениеВключено()
	И Константы.РежимИспользованияИнформационнойБазы.Получить() <>
	Перечисления.РежимыИспользованияИнформационнойБазы.Демонстрационный;
	
	Если ВыбратьСПроверкойЛицензий Тогда
		ПодключенныеУслуги = ПодключенныеУслугиПриложений();
		ОписаниеДоступныхПриложений = ПриложенияПоИдентификаторамУслуг(ПодключенныеУслуги);
	Иначе
		ОписаниеДоступныхПриложений = РегистрыСведений.ПодключениеКомбинированныхПриложений.ПодключенныеПриложения();
	КонецЕсли;
	
	Если НЕ ТолькоБизнесПриложения Тогда
		Возврат ОписаниеДоступныхПриложений;
	КонецЕсли;
	
	ОписаниеДоступныхБизнесПриложений = Новый Массив;
	
	Для Каждого Приложение Из ОписаниеДоступныхПриложений Цикл
			
		Если Приложение.ЭтоБизнесПриложение Тогда
			ОписаниеДоступныхБизнесПриложений.Добавить(Приложение);
		КонецЕсли;
			
	КонецЦикла;
	
	Возврат ОписаниеДоступныхБизнесПриложений;
	
КонецФункции

// Новая таблица возможностей.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Новая таблица возможностей:
// * Имя - Строка - 
// * ЗначениеПоУмолчанию - Произвольный
Функция НоваяТаблицаВозможностей() Экспорт
	
	ТипыЗначений = Новый Массив;
	ТипыЗначений.Добавить(Тип("Булево"));
	ТипыЗначений.Добавить(Тип("Число"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.ВидыКонтроляДоговоровПриПроведении"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.КодыНоменклатурыВДокументах"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.СпособОтображенияСкидок"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.ВариантыВыводаСуммыБезСкидки"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.КонтактнаяИнформацияТоварногоЧека"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.ПечатьПользовательскихЕдиницИзмерения"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.ВариантыПечатиДоставки"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.ДаНет"));
	ТипыЗначений.Добавить(Тип("ПеречислениеСсылка.ВидыНаименованийДляПечатиДокументов"));
	
	ТаблицаВозможностей = Новый ТаблицаЗначений;
	ТаблицаВозможностей.Колонки.Добавить("Имя", Новый ОписаниеТипов("Строка"));
	
	ТаблицаВозможностей.Колонки.Добавить("ЗначениеПоУмолчанию", Новый ОписаниеТипов(ТипыЗначений));
	
	Возврат ТаблицаВозможностей;
	
КонецФункции

Функция ДобавитьВозможностьВПриложение(ТаблицаВозможностей, ИмяВозможности, ЗначениеПоУмолчанию) Экспорт
	НоваяВозможность = ТаблицаВозможностей.Добавить();
	НоваяВозможность.Имя = ИмяВозможности;
	НоваяВозможность.ЗначениеПоУмолчанию = ЗначениеПоУмолчанию;
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ИмяЖР() Экспорт
	
	Возврат НСтр("ru='ТарификацияБизнес'", ОбщегоНазначения.КодОсновногоЯзыка())
	
КонецФункции

Функция ОписаниеВсехПриложений() Экспорт
	
	ДоступныеПриложения = Новый Массив;
	
	// Мини-приложения
	
	ОписаниеПриложения = НовыйОписаниеПриложения();
	ОписаниеПриложения.Имя = "ВыставлениеСчетов";
	ОписаниеПриложения.Синоним = НСтр("ru='Выставление счетов'");
	ОписаниеПриложения.ИдентификаторУслугиСервиса = ИдентификаторУслугиПриложениеВыставлениеСчетов();
	ОписаниеПриложения.МодульПриложения = "БизнесПриложениеВыставлениеСчетов";
	ОписаниеПриложения.ЗамещаетПриложения.Добавить("ПоискИПроверкаКонтрагентов"); 
	ОписаниеПриложения.ЭтоБизнесПриложение = Истина;
	ДоступныеПриложения.Добавить(ОписаниеПриложения);
	
	ОписаниеПриложения = НовыйОписаниеПриложения();
	ОписаниеПриложения.Имя = "ПоискИПроверкаКонтрагентов";
	ОписаниеПриложения.Синоним = НСтр("ru='Проверка контрагентов'");
	ОписаниеПриложения.ИдентификаторУслугиСервиса = ИдентификаторУслугиПриложениеПоискИПроверкаКонтрагентов();
	ОписаниеПриложения.МодульПриложения = "БизнесПриложениеПоискИПроверкаКонтрагентов";
	ОписаниеПриложения.ЭтоБизнесПриложение = Истина;
	ДоступныеПриложения.Добавить(ОписаниеПриложения);
	
	// Приложения
	
	ОписаниеПриложения = НовыйОписаниеПриложения();
	ОписаниеПриложения.Имя = "CRM";
	ОписаниеПриложения.Синоним = НСтр("ru='CRM'");
	ОписаниеПриложения.ИдентификаторУслугиСервиса = ИдентификаторУслугиПриложениеCRM();
	ОписаниеПриложения.МодульПриложения = "БизнесПриложениеCRM";
	ОписаниеПриложения.ЗамещаетПриложения.Добавить("ПоискИПроверкаКонтрагентов");
	ОписаниеПриложения.ЗамещаетПриложения.Добавить("ВыставлениеСчетов");
	ОписаниеПриложения.СовместныеПриложения.Добавить("Бухгалтерия");
	ОписаниеПриложения.ЭтоБизнесПриложение = Истина;
	ДоступныеПриложения.Добавить(ОписаниеПриложения);
	
	ОписаниеПриложения = НовыйОписаниеПриложения();
	ОписаниеПриложения.Имя = "ОнлайнПродажи";
	ОписаниеПриложения.Синоним = НСтр("ru='Онлайн-продажи'");
	ОписаниеПриложения.ИдентификаторУслугиСервиса = ИдентификаторУслугиПриложениеОнлайнПродажи();
	ОписаниеПриложения.МодульПриложения = "БизнесПриложениеОнлайнПродажи";
