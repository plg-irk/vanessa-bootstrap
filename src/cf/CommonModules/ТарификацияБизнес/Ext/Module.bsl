Процедура ОбработатьПодключениеПриложения(
	ОписаниеНовогоПриложения,
	ПричинаПодключения,
	ПроверятьЛицензии,
	ОтправлятьОповещение = Ложь,
	ОчищатьНастройкиПользователя = Истина) Экспорт
	
	ОписаниеДоступныхПриложений = ДоступныеПриложения(ПроверятьЛицензии, Истина);
	ОписаниеДоступныхПриложений = УдалитьПриложениеИзСписка(ОписаниеДоступныхПриложений, ОписаниеНовогоПриложения.Имя);
	
	ПодключенноеПриложениеАктуально = Истина;   
	Если ПроверятьЛицензии = Истина Тогда
		ПодключенноеПриложениеАктуально = Тарификация.ЗарегистрированаЛицензияБезлимитнойУслуги(
												ТарификацияУНФ.ИдентификаторПоставщикаУНФ(), ОписаниеНовогоПриложения.ИдентификаторУслугиСервиса);
	КонецЕсли;
	
	ПриложенияДляОтключения = Новый Массив;
	ПриложенияДляПодключения = Новый Массив;
	
	ЗамещаемыеПриложенияПодключаемогоПриложения = ОписаниеНовогоПриложения.ЗамещаетПриложения;
	ОписаниеЗамещаемыхПриложений = ОписаниеВыбранныхПриложений(ОписаниеДоступныхПриложений, ЗамещаемыеПриложенияПодключаемогоПриложения);
	СовместныеПриложенияПодключаемогоПриложения = ОписаниеНовогоПриложения.СовместныеПриложения;
	ОписаниеСовместныхПриложений = ОписаниеВыбранныхПриложений(ОписаниеДоступныхПриложений, СовместныеПриложенияПодключаемогоПриложения);
	
	КоличествоДоступныхПриложений = ОписаниеДоступныхПриложений.Количество() - ОписаниеСовместныхПриложений.Количество();
	ЭтоЗамещениеПриложения = ОписаниеЗамещаемыхПриложений.Количество() >= КоличествоДоступныхПриложений;
	
	ЗамещаемыеПриложенияПодключенныхПриложений = ЗамещаемыеПриложенияПодключенныхПриложений(ОписаниеДоступныхПриложений);
	ПодключаетсяЗамещаемоеПриложение = ЗамещаемыеПриложенияПодключенныхПриложений.Найти(ОписаниеНовогоПриложения.Имя) <> Неопределено;
	
	Если ОчищатьНастройкиПользователя И ЭтоЗамещениеПриложения И ПодключенноеПриложениеАктуально = Истина Тогда
		ПриложенияДляОтключения = ОписаниеЗамещаемыхПриложений;
		РабочийСтолУНФ.ОчиститьРабочийСтол();
		РабочийСтолУНФ.ОчиститьНастройкиСоставаИнтерфейса();
	КонецЕсли;
	
	Если НЕ ПодключаетсяЗамещаемоеПриложение И ПодключенноеПриложениеАктуально = Истина Тогда       
		ПриложенияДляПодключения.Добавить(ОписаниеНовогоПриложения);
	КонецЕсли;
	
	ДоступныеВозможностиПриложений = ДоступныеВозможностиПриложений(ОписаниеДоступныхПриложений, ЗамещаемыеПриложенияПодключаемогоПриложения);
	ОтключитьПриложения(ПриложенияДляОтключения, ПричинаПодключения, ДоступныеВозможностиПриложений);
	ПодключитьПриложения(ПриложенияДляПодключения, ПричинаПодключения);
	
	Если ОтправлятьОповещение И НЕ ПодключаетсяЗамещаемоеПриложение Тогда
		ОповеститьОПодключенномПриложении(ОписаниеНовогоПриложения);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьОтключениеПриложения(
	ОписаниеОтключаемогоПриложения,
	ПричинаОтключения,
	ПроверятьЛицензии,
	ОтправлятьОповещение = Ложь,
	ОчищатьНастройкиПользователя = Истина) Экспорт
	
	ПриложенияДляОтключения = Новый Массив;
	ПриложенияДляПодключения = Новый Массив;
	
	ОписаниеДоступныхПриложений = ДоступныеПриложения(ПроверятьЛицензии, Истина);      
	ОписаниеДоступныхПриложений = УдалитьПриложениеИзСписка(ОписаниеДоступныхПриложений, ОписаниеОтключаемогоПриложения.Имя);
	
	ЗамещаемыеПриложенияОтключаемогоПриложения = ОписаниеОтключаемогоПриложения.ЗамещаетПриложения;
	ОписаниеЗамещаемыхПриложений = ОписаниеВыбранныхПриложений(ОписаниеДоступныхПриложений, ЗамещаемыеПриложенияОтключаемогоПриложения);
	СовместныеПриложенияОтключаемогоПриложения = ОписаниеОтключаемогоПриложения.СовместныеПриложения;
	ОписаниеСовместныхПриложений = ОписаниеВыбранныхПриложений(ОписаниеДоступныхПриложений, СовместныеПриложенияОтключаемогоПриложения);
	
	КоличествоДоступныхПриложений = ОписаниеДоступныхПриложений.Количество() - ОписаниеСовместныхПриложений.Количество();
	ЭтоЗамещениеПриложения = ОписаниеЗамещаемыхПриложений.Количество() >= КоличествоДоступныхПриложений;
	
	Если ОчищатьНастройкиПользователя И ЭтоЗамещениеПриложения Тогда
		ПриложенияДляОтключения = ОписаниеСовместныхПриложений;
		РабочийСтолУНФ.ОчиститьРабочийСтол();
		РабочийСтолУНФ.ОчиститьНастройкиСоставаИнтерфейса();
	КонецЕсли;
	
	ПриложенияДляОтключения.Добавить(ОписаниеОтключаемогоПриложения);
	
	ДоступныеВозможностиПриложений = ДоступныеВозможностиПриложений(ОписаниеДоступныхПриложений);
	ОтключитьПриложения(ПриложенияДляОтключения, ПричинаОтключения, ДоступныеВозможностиПриложений);
	
	//новое подключение
	Если ЭтоЗамещениеПриложения Тогда
		ПолучитьВерхнеуровневоеПриложение(ОписаниеЗамещаемыхПриложений);	
		ПодключитьПриложения(ОписаниеЗамещаемыхПриложений, ПричинаОтключения);
	КонецЕсли;
	
	Если ОтправлятьОповещение И Не ЭтоПриложениеЗамещено(ОписаниеОтключаемогоПриложения) Тогда
		ОповеститьОбОтключенномПриложении(ОписаниеОтключаемогоПриложения);
	КонецЕсли;
	
КонецПроцедуры

Функция ПриложениеМожетБытьПодключено(ОписаниеПриложения) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Результат", Истина);
	Результат.Вставить("Причина", "");
	
	Если Не ОбщегоНазначения.РазделениеВключено() Тогда
		Если ВозможностиПриложения.ЭтоБизнесПриложение() Тогда
			Возврат Результат;
		Иначе
			Результат.Результат = Ложь;
			Результат.Причина = НСтр("ru='Приложение может быть подключено только в режиме запуска комбинированного приложения.'");
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	ЗарегистрированаЛицензия = Тарификация.ЗарегистрированаЛицензияБезлимитнойУслуги(
		ТарификацияУНФ.ИдентификаторПоставщикаУНФ(), ОписаниеПриложения.ИдентификаторУслугиСервиса);
	
	Если Не ЗарегистрированаЛицензия Тогда
		Результат.Результат = Ложь;
		Результат.Причина = НСтр("ru='Не подключена услуга ""%1"".'");
		Результат.Причина = СтрШаблон(Результат.Причина, ОписаниеПриложения.ИдентификаторУслугиСервиса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ОтключитьВсеПриложения(Причина, ПроверятьЛицензии = Ложь, ТолькоБизнесПриложения = Ложь) Экспорт
	
	ОписаниеПриложений = ДоступныеПриложения(ПроверятьЛицензии);
	Для Каждого ОписаниеПриложения Из ОписаниеПриложений Цикл
		
		Если Не ОписаниеПриложения.ЭтоБизнесПриложение Тогда
			Продолжить;
		КонецЕсли;
		
		ОбработатьОтключениеПриложения(ОписаниеПриложения, Причина, ПроверятьЛицензии, , Ложь);
		
	КонецЦикла;
	
КонецПроцедуры

