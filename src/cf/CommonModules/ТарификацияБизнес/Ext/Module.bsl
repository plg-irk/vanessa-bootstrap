Процедура ПодключитьПриложения(СписокПриложений, ОписаниеПричины)
	
	Если СписокПриложений.Количество() = 0 Тогда
		Комментарий = НСтр("ru='Подключение приложений не выполнялось, передан пустой список приложений.'");
		ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Информация,,, Комментарий);
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Для каждого ОписаниеПриложения Из СписокПриложений Цикл
		НачатьТранзакцию();
		Попытка
			Блокировка = Новый БлокировкаДанных;
			Блокировка.Добавить("РегистрСведений.ПодключениеКомбинированныхПриложений");
			Блокировка.Заблокировать();
			
			МодульПриложения = ОбщегоНазначения.ОбщийМодуль(ОписаниеПриложения.МодульПриложения);
			МодульПриложения.ВключитьВозможностиПриложения();
			
			ОписаниеСобытия = НСтр("ru='Подключено приложение: %1'");
			ОписаниеСобытия = СтрШаблон(ОписаниеСобытия, ОписаниеПриложения.Имя);
			
			РегистрыСведений.ПодключениеКомбинированныхПриложений.ЗарегистрироватьСобытие(ОписаниеПриложения.Имя, Перечисления.СтатусКомбинированногоПриложения.Подключено, ОписаниеПричины);
			ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Информация,,, ОписаниеСобытия);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			Комментарий = НСтр("ru='Ошибка при попытке подключить приложение ""%1"" по причине:
			|%2.'");
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			Комментарий = СтрШаблон(Комментарий, ОписаниеПриложения.Имя, ТекстОшибки);
			ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Ошибка,,, Комментарий);
			ВызватьИсключение;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Процедура ОтключитьПриложения(СписокПриложений, ОписаниеПричины, ДоступныеВозможностиПриложений)
	
	Если СписокПриложений.Количество() = 0 Тогда
		Комментарий = НСтр("ru='Отключение приложений не выполнялось, передан пустой список приложений.'");
		ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Информация,,, Комментарий);
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Для каждого ОписаниеПриложения Из СписокПриложений Цикл
		НачатьТранзакцию();
		Попытка
			Блокировка = Новый БлокировкаДанных;
			Блокировка.Добавить("РегистрСведений.ПодключениеКомбинированныхПриложений");
			Блокировка.Заблокировать();
			
			МодульПриложения = ОбщегоНазначения.ОбщийМодуль(ОписаниеПриложения.МодульПриложения);
			МодульПриложения.ОтключитьВозможностиПриложения(ДоступныеВозможностиПриложений);
			
			ОписаниеСобытия = НСтр("ru='Отключено приложение: %1'");
			ОписаниеСобытия = СтрШаблон(ОписаниеСобытия, ОписаниеПриложения.Имя);
			
			РегистрыСведений.ПодключениеКомбинированныхПриложений.ЗарегистрироватьСобытие(ОписаниеПриложения.Имя, Перечисления.СтатусКомбинированногоПриложения.Отключено, ОписаниеПричины);
			ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Информация,,, ОписаниеСобытия);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			Комментарий = НСтр("ru='Ошибка при попытке отключить приложение ""%1"" по причине:
			|%2.'");
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			Комментарий = СтрШаблон(Комментарий, ОписаниеПриложения.Имя, ТекстОшибки);
			ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Ошибка,,, Комментарий);
			ВызватьИсключение;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Функция УдалитьПриложениеИзСписка(СписокПриложений, ИмяПриложения)
	
	Результат = Новый Массив;
	
	Для каждого ОписаниеПриложения Из СписокПриложений Цикл
		Если ОписаниеПриложения.Имя <> ИмяПриложения Тогда
			Результат.Добавить(ОписаниеПриложения);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДоступныеВозможностиПриложений(ОписаниеДоступныхПриложений, ЗамещаемыеПриложения = Неопределено)
	
	ДоступныеВозможностиПриложений = Новый Массив;
	Если ОписаниеДоступныхПриложений.Количество() = 0 Тогда
		Возврат ДоступныеВозможностиПриложений;
	КонецЕсли;
	
	Если ЗамещаемыеПриложения = Неопределено Тогда
		ЗамещаемыеПриложения = Новый Массив;
	КонецЕсли;
	
	Для каждого ОписаниеПриложения Из ОписаниеДоступныхПриложений Цикл
		
		Попытка
			
			Если ЗамещаемыеПриложения.Найти(ОписаниеПриложения.Имя) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			МодульПриложения = ОбщегоНазначения.ОбщийМодуль(ОписаниеПриложения.МодульПриложения);
			ДоступныеВозможностиПриложения = МодульПриложения.ФункциональныеВозможностиПриложения();
			МассивВозможностей = ДоступныеВозможностиПриложения.ВыгрузитьКолонку("Имя");
			
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ДоступныеВозможностиПриложений, МассивВозможностей, Истина);
			
		Исключение
			
			Комментарий = НСтр("ru='Ошибка при попытке сформировать список доступных возможностей по причине:
			|%2.'");
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			Комментарий = СтрШаблон(Комментарий, ОписаниеПриложения.Имя, ТекстОшибки);
			ЗаписьЖурналаРегистрации(ИмяЖР(), УровеньЖурналаРегистрации.Ошибка,,, Комментарий);
			ВызватьИсключение;
			
		КонецПопытки;
	КонецЦикла;
	
	Возврат ДоступныеВозможностиПриложений;
	
КонецФункции

Функция ЗамещаемыеПриложенияПодключенныхПриложений(ОписаниеДоступныхПриложений)
	
	ЗамещаемыеПриложения = Новый Массив;
	
	Для Каждого ОписаниеПриложения Из ОписаниеДоступныхПриложений Цикл
		Для Каждого Приложение Из ОписаниеПриложения.ЗамещаетПриложения Цикл
			Если ЗамещаемыеПриложения.Найти(Приложение) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ЗамещаемыеПриложения.Добавить(Приложение);
		КонецЦикла;
	КонецЦикла;
	
	Возврат ЗамещаемыеПриложения;
	
КонецФункции

Функция ОписаниеВыбранныхПриложений(ОписаниеДоступныхПриложений, ВыбранныеПриложенияПодключаемогоПриложения)
	
	ВыбранныеПриложения = Новый Массив;
	
	Для Каждого Приложение Из ОписаниеДоступныхПриложений Цикл
		Если ВыбранныеПриложенияПодключаемогоПриложения.Найти(Приложение.Имя) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ВыбранныеПриложения.Добавить(Приложение);
	КонецЦикла;
	
	Возврат ВыбранныеПриложения;
	
КонецФункции

Процедура ОповеститьОПодключенномПриложении(ОписаниеПриложения)
	
	ОповеститьОПодключенииОтключенииПриложения(ОписаниеПриложения, Истина);
	
КонецПроцедуры

Процедура ОповеститьОбОтключенномПриложении(ОписаниеПриложения)
	
	ОповеститьОПодключенииОтключенииПриложения(ОписаниеПриложения, Ложь);
	
КонецПроцедуры

Процедура ОповеститьОПодключенииОтключенииПриложения(ОписаниеПриложения, ПриложениеБылоПодключено)
	
	ИмяОповещения = ТарификацияБизнесКлиентСервер.ИмяСерверногоОповещения();
	
	Данные = Новый Структура;
	Данные.Вставить("ОписаниеПриложения", ОписаниеПриложения);
	Данные.Вставить("ПриложениеБылоПодключено", ПриложениеБылоПодключено);
	
	СерверныеОповещения.ОтправитьСерверноеОповещение(ИмяОповещения, Данные, Неопределено, Истина);
	
КонецПроцедуры

#КонецОбласти

Функция НовыйОписаниеПриложения()
	
	ОписаниеПриложения = Новый Структура;
	ОписаниеПриложения.Вставить("Имя", "");
	ОписаниеПриложения.Вставить("Синоним", "");
	ОписаниеПриложения.Вставить("ИдентификаторУслугиСервиса", "");
	ОписаниеПриложения.Вставить("МодульПриложения", "");
	ОписаниеПриложения.Вставить("ЗамещаетПриложения", Новый Массив);
	ОписаниеПриложения.Вставить("СовместныеПриложения", Новый Массив);
	ОписаниеПриложения.Вставить("ЭтоБизнесПриложение", Ложь);
	Возврат ОписаниеПриложения;
	
КонецФункции

Функция ПодключенныеУслугиПриложений()
	
	ИдентификаторПоставщикаУНФ = ТарификацияУНФ.ИдентификаторПоставщикаУНФ();
	
	ВсеУслугиПриложений = СписокУслуг();
	Результат = Новый Массив;
	
	Для каждого ОписаниеУслуги Из ВсеУслугиПриложений Цикл
		Если Тарификация.ЗарегистрированаЛицензияБезлимитнойУслуги(ИдентификаторПоставщикаУНФ, ОписаниеУслуги.Идентификатор) Тогда
			Результат.Добавить(ОписаниеУслуги.Идентификатор);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПриложенияПоИдентификаторамУслуг(ИдентификаторыУслуг)
	
	Если ТипЗнч(ИдентификаторыУслуг) <> Тип("Массив") Тогда
		ОтборИдентификаторыУслуг = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИдентификаторыУслуг);
	Иначе
		ОтборИдентификаторыУслуг = ИдентификаторыУслуг;
	КонецЕсли;
	
	Результат = Новый Массив;
	ОписаниеПриложений = ОписаниеВсехПриложений();
	
	Для каждого ОписаниеПриложения Из ОписаниеПриложений Цикл
		Если ОтборИдентификаторыУслуг.Найти(ОписаниеПриложения.ИдентификаторУслугиСервиса) <> Неопределено Тогда
			Результат.Добавить(ОписаниеПриложения);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЭтоПриложениеЗамещено(
	ОписаниеПриложения, ОписаниеВсехПриложений = Неопределено, ОписаниеПриложенийДляПроверки = Неопределено)
	
	Если ОписаниеВсехПриложений = Неопределено Тогда
		ОписаниеВсехПриложений = ОписаниеВсехПриложений();
	КонецЕсли;
	
	Если ОписаниеПриложенийДляПроверки = Неопределено Тогда
		ОписаниеПриложенийДляПроверки = РегистрыСведений.ПодключениеКомбинированныхПриложений.ПодключенныеПриложения();
	КонецЕсли;
	
	НовыеПриложенияДляПроверки = Новый Массив;
	Для Каждого Приложение Из ОписаниеПриложенийДляПроверки Цикл
		
		Для Каждого ЗамещаемоеПриложение Из Приложение.ЗамещаетПриложения Цикл
			
			Если ЗамещаемоеПриложение = ОписаниеПриложения.Имя Тогда
				Возврат Истина;
			КонецЕсли;
			
			ОписаниеПриложенияДляПроверки = ОписаниеПриложенияПоИмени(ЗамещаемоеПриложение, ОписаниеВсехПриложений);
			НовыеПриложенияДляПроверки.Добавить(ОписаниеПриложенияДляПроверки);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если НовыеПриложенияДляПроверки.Количество() Тогда
		Возврат ЭтоПриложениеЗамещено(ОписаниеПриложения, ОписаниеВсехПриложений, НовыеПриложенияДляПроверки);
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ОписаниеПриложенияПоИмени(Имя, ОписаниеВсехПриложений)
	
	Для Каждого Описание Из ОписаниеВсехПриложений Цикл
		Если Описание.Имя = Имя Тогда
			Возврат Описание;
		КонецЕсли;
	КонецЦикла;
	
КонецФункции

Процедура ПолучитьВерхнеуровневоеПриложение(ОписаниеЗамещаемыхПриложений)
	
	МассивВложенныхПриложений = Новый Массив;
	Для Каждого Приложение Из ОписаниеЗамещаемыхПриложений Цикл     
		Для Каждого ЗамещаемоеПриложение Из Приложение.ЗамещаетПриложения Цикл
			МассивВложенныхПриложений.Добавить(ЗамещаемоеПриложение);	
		КонецЦикла;
	КонецЦикла; 
	ИтоговоеОписаниеПриложений = Новый Массив;
	Для Каждого ОписаниеПриложения Из ОписаниеЗамещаемыхПриложений Цикл
		Если МассивВложенныхПриложений.Найти(ОписаниеПриложения.Имя) = Неопределено Тогда
			ИтоговоеОписаниеПриложений.Добавить(ОписаниеПриложения); 	
		КонецЕсли;
	КонецЦикла;    
	
	ОписаниеЗамещаемыхПриложений = ИтоговоеОписаниеПриложений;
	
КонецПроцедуры

Функция ЗарегистрированаАльтернативнаяЛицензияБезлимитнойУслуги(ИдентификаторПоставщика,
		ИдентификаторУслуги, НомерИсключаемойПодписки)

	// Если услуга не найдена, тогда возвращается ЛОЖЬ.
	Услуга = Тарификация.УслугаПоИдентификаторуИИдентификаторуПоставщика(
		ИдентификаторУслуги, ИдентификаторПоставщика, Ложь); // СправочникСсылка.УслугиСервиса
		
	Если Услуга = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	// Если услуга не тарифицируется, тогда возвращается ИСТИНА.
	УслугаТарифицируется = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Услуга, "Тарифицируется");
	Если Не УслугаТарифицируется Тогда
		Возврат Истина;
	КонецЕсли;

	// Если есть подписка на услугу, тогда возвращается ИСТИНА, иначе - ЛОЖЬ.
	Запрос = Новый Запрос("ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДоступныеЛицензии.ИдентификаторПодписки КАК ИдентификаторПодписки
	|ИЗ
	|	РегистрСведений.ДоступныеЛицензии КАК ДоступныеЛицензии
	|ГДЕ
	|	ДоступныеЛицензии.Услуга = &Услуга
	|	И &ДатаЗапроса МЕЖДУ ДоступныеЛицензии.ДатаНачалаДействия И ДоступныеЛицензии.ДатаОкончанияДействия
	|	И ДоступныеЛицензии.НомерПодписки <> &НомерИсключаемойПодписки");
	Запрос.УстановитьПараметр("Услуга", Услуга);
	Запрос.УстановитьПараметр("ДатаЗапроса", ТекущаяУниверсальнаяДата());
	Запрос.УстановитьПараметр("НомерИсключаемойПодписки", НомерИсключаемойПодписки);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции

#Область РегламентноеЗадание   

Процедура АктуализацияСостоянийПодключенныхПодписок() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.АктуализацияСостоянийПодключенныхПодписок);
	
	АктуализироватьСостояниеПодписок();
	
КонецПроцедуры  

Процедура АктуализироватьСостояниеПодписок() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);  
	ДоступныеПриложения = ОписаниеВсехПриложений();
	
	ТаблицаВсеПриложения = Новый ТаблицаЗначений;
	ТаблицаВсеПриложения.Колонки.Добавить("Имя", Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(255)));
	ТаблицаВсеПриложения.Колонки.Добавить("ИдентификаторУслугиСервиса", Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(255)));   
	Для Каждого ОписаниеПриложения Из ДоступныеПриложения Цикл
		СтрокаПриложения = ТаблицаВсеПриложения.Добавить();
    	ЗаполнитьЗначенияСвойств(СтрокаПриложения, ОписаниеПриложения);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	втОписаниеПриложений.Имя КАК Имя,
		|	втОписаниеПриложений.ИдентификаторУслугиСервиса КАК ИдентификаторУслугиСервиса
		|ПОМЕСТИТЬ втОписаниеВсехПриложения
		|ИЗ
		|	&втОписаниеПриложений КАК втОписаниеПриложений
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втОписаниеВсехПриложения.Имя КАК Имя,
		|	ДоступныеЛицензии.ИдентификаторПодписки КАК ИдентификаторПодписки,
		|	ДоступныеЛицензии.Услуга КАК Услуга,
		|	&ТекДата >= ДоступныеЛицензии.ДатаНачалаДействия
		|		И &ТекДата <= ДоступныеЛицензии.ДатаОкончанияДействия КАК ПодпискаАктуальнаПоРегистру,
		|	ДоступныеЛицензии.ДатаНачалаДействия КАК ДатаНачалаДействия,
		|	ДоступныеЛицензии.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
		|	ДоступныеЛицензии.НомерПодписки КАК НомерПодписки
		|ПОМЕСТИТЬ втДоступныеЛицензииСИменами
		|ИЗ
		|	РегистрСведений.ДоступныеЛицензии КАК ДоступныеЛицензии
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УслугиСервиса КАК УслугиСервиса
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втОписаниеВсехПриложения КАК втОписаниеВсехПриложения
		|			ПО УслугиСервиса.Идентификатор = втОписаниеВсехПриложения.ИдентификаторУслугиСервиса
		|		ПО ДоступныеЛицензии.Услуга = УслугиСервиса.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втДоступныеЛицензииСИменами.Услуга КАК Услуга,
		|	втДоступныеЛицензииСИменами.ДатаНачалаДействия КАК ДатаНачалаДействия,
		|	втДоступныеЛицензииСИменами.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
		|	втДоступныеЛицензииСИменами.НомерПодписки КАК НомерПодписки,
		|	втДоступныеЛицензииСИменами.ПодпискаАктуальнаПоРегистру КАК ПодпискаАктуальнаПоРегистру
		|ИЗ
		|	РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних КАК ПодключениеКомбинированныхПриложенийСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втДоступныеЛицензииСИменами КАК втДоступныеЛицензииСИменами
		|		ПО ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения = втДоступныеЛицензииСИменами.Имя,
		|	втОписаниеВсехПриложения КАК втОписаниеВсехПриложения
		|ГДЕ
		|	ПодключениеКомбинированныхПриложенийСрезПоследних.Статус = &СтатусПодключено
		|	И втДоступныеЛицензииСИменами.ПодпискаАктуальнаПоРегистру = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	УслугиСервиса.Ссылка,
		|	ДОБАВИТЬКДАТЕ(&ТекДата, НЕДЕЛЯ, 1),
		|	ДОБАВИТЬКДАТЕ(&ТекДата, НЕДЕЛЯ, 2),
		|	""НомерУдален"",
		|	ЛОЖЬ
		|ИЗ
		|	РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних КАК ПодключениеКомбинированныхПриложенийСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ втДоступныеЛицензииСИменами КАК втДоступныеЛицензииСИменами
		|		ПО ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения = втДоступныеЛицензииСИменами.Имя
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втОписаниеВсехПриложения КАК втОписаниеВсехПриложения
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УслугиСервиса КАК УслугиСервиса
		|			ПО втОписаниеВсехПриложения.ИдентификаторУслугиСервиса = УслугиСервиса.Идентификатор
		|		ПО ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения = втОписаниеВсехПриложения.Имя
		|ГДЕ
		|	втДоступныеЛицензииСИменами.Услуга ЕСТЬ NULL
		|	И ПодключениеКомбинированныхПриложенийСрезПоследних.Статус = &СтатусПодключено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	втДоступныеЛицензииСИменами.Услуга,
		|	втДоступныеЛицензииСИменами.ДатаНачалаДействия,
		|	втДоступныеЛицензииСИменами.ДатаОкончанияДействия,
		|	втДоступныеЛицензииСИменами.НомерПодписки,
		|	втДоступныеЛицензииСИменами.ПодпискаАктуальнаПоРегистру
		|ИЗ
		|	втДоступныеЛицензииСИменами КАК втДоступныеЛицензииСИменами
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних КАК ПодключениеКомбинированныхПриложенийСрезПоследних
		|		ПО втДоступныеЛицензииСИменами.Имя = ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения
		|ГДЕ
		|	втДоступныеЛицензииСИменами.ПодпискаАктуальнаПоРегистру = ИСТИНА
		|	И ПодключениеКомбинированныхПриложенийСрезПоследних.Статус <> &СтатусПодключено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	втДоступныеЛицензииСИменами.Услуга,
		|	втДоступныеЛицензииСИменами.ДатаНачалаДействия,
		|	втДоступныеЛицензииСИменами.ДатаОкончанияДействия,
		|	втДоступныеЛицензииСИменами.НомерПодписки,
		|	втДоступныеЛицензииСИменами.ПодпискаАктуальнаПоРегистру
		|ИЗ
		|	втДоступныеЛицензииСИменами КАК втДоступныеЛицензииСИменами
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних КАК ПодключениеКомбинированныхПриложенийСрезПоследних
		|		ПО втДоступныеЛицензииСИменами.Имя = ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения
		|ГДЕ
		|	втДоступныеЛицензииСИменами.ПодпискаАктуальнаПоРегистру = ИСТИНА
		|	И ПодключениеКомбинированныхПриложенийСрезПоследних.Статус ЕСТЬ NULL";
	Запрос.УстановитьПараметр("ТекДата",ТекущаяУниверсальнаяДата());
	Запрос.УстановитьПараметр("СтатусПодключено", Перечисления.СтатусКомбинированногоПриложения.Подключено);
	Запрос.УстановитьПараметр("втОписаниеПриложений", ТаблицаВсеПриложения);
	
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		ПараметрыЛицензии = Новый Структура;
		ПараметрыЛицензии.Вставить("Услуга", Выборка.Услуга);
		ПараметрыЛицензии.Вставить("ДатаНачалаДействия", Выборка.ДатаНачалаДействия);
		ПараметрыЛицензии.Вставить("ДатаОкончанияДействия", Выборка.ДатаОкончанияДействия);
		ПараметрыЛицензии.Вставить("НомерПодписки", Выборка.НомерПодписки);
		// Реализация по аналогии с методами БТС
       	//@skip-check query-in-loop
       	ПриУдаленииДоступныхЛицензий(ПараметрыЛицензии);
		Если Выборка.ПодпискаАктуальнаПоРегистру = Истина Тогда
	       	//@skip-check query-in-loop		
       		ПриОбновленииДоступныхЛицензий(ПараметрыЛицензии);
		КонецЕсли;
	КонецЦикла;        
	
	УстановитьПривилегированныйРежим(Ложь);  
	
КонецПроцедуры	

Процедура ВключитьРегламентноеЗаданиеАктуализацияСостоянийПодключенныхПодписок()
	
	РегламентноеЗадание = Метаданные.РегламентныеЗадания.АктуализацияСостоянийПодключенныхПодписок;
	Задание = РегламентныеЗаданияСервер.Задание(РегламентноеЗадание);
	Если Задание = Неопределено Тогда
		ПараметрыЗадания = Новый Структура;
		ПараметрыЗадания.Вставить("Метаданные", РегламентноеЗадание);
		ПараметрыЗадания.Вставить("Использование", Истина);
		ПараметрыЗадания.Вставить("Расписание", РасписаниеРегламентногоЗаданияАктуализацияСостоянийПодключенныхПодписок());
		ПараметрыЗадания.Вставить("ИнтервалПовтораПриАварийномЗавершении", ?(ОбщегоНазначения.РежимОтладки(), 20, 3600));
		ПараметрыЗадания.Вставить("КоличествоПовторовПриАварийномЗавершении", 3);  
		Если ЗначениеЗаполнено(РегламентноеЗадание.Ключ) Тогда
			ПараметрыЗадания.Вставить("Ключ", РегламентноеЗадание.Ключ);
		КонецЕсли;		
		РегламентныеЗаданияСервер.ДобавитьЗадание(ПараметрыЗадания);
	КонецЕсли;

КонецПроцедуры
 
Функция РасписаниеРегламентногоЗаданияАктуализацияСостоянийПодключенныхПодписок()
	
	Месяцы = Новый Массив;
	Месяцы.Добавить(1);
	Месяцы.Добавить(2);
	Месяцы.Добавить(3);
	Месяцы.Добавить(4);
	Месяцы.Добавить(5);
	Месяцы.Добавить(6);
	Месяцы.Добавить(7);
	Месяцы.Добавить(8);
	Месяцы.Добавить(9);
	Месяцы.Добавить(10);
	Месяцы.Добавить(11);
	Месяцы.Добавить(12);
	
	ДниНедели = Новый Массив;
	ДниНедели.Добавить(1);
	ДниНедели.Добавить(2);
	ДниНедели.Добавить(3);
	ДниНедели.Добавить(4);
	ДниНедели.Добавить(5);
