		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%УсловиеОрганизация%", СтрШаблон("И ((%1) ИЛИ &БезОтбораПоОрганизацииЕГАИС)", СтрСоединить(УсловияОрганизация, " ИЛИ ")));
