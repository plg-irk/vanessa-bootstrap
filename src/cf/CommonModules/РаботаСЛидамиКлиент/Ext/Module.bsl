
#Область СлужебныйПрограммныйИнтерфейс

#Область ПереводЛида

// Вопрос, который нужно задать перед обычным переводом лида в качественного
//
// Параметры:
//  ДанныеЛида - Структура:
//   * Ссылка - СправочникСсылка.Лиды
//   * Представление - Строка
//   * Вид - Строка - ПеречислениеСсылка.ВидыЛидов
//   * ВариантЗавершения - Неопределено, ПеречислениеСсылка.ВариантЗавершенияРаботыСЛидом
//   * Контрагент - Неопределено, СправочникСсылка.Контрагенты
//   * ПредставлениеКонтрагента - Неопределено, Строка
//  РезультатПеревода - Строка - "Покупатель" | "ЗаказПокупателя" | "ЗаказНаряд"
//  НаличиеЗаявокВРаботеПоЛидуПоВидуОперации - см РаботаСЗаявками.НаличиеЗаявокВРаботеПоЛидуПоВидуОперации
// 
// Возвращаемое значение:
//  Булево - можно переводить лида в качественного
//
Асинх Функция ВопросПередПереводомЛидаАсинх(
	ДанныеЛида, РезультатПеревода, НаличиеЗаявокВРаботеПоЛидуПоВидуОперации) Экспорт
	
	Если ДанныеЛида.Свойство("ВариантЗавершения") Тогда
		ВариантЗавершения = ДанныеЛида.ВариантЗавершения;
	Иначе
		ВариантЗавершения = Неопределено;
	КонецЕсли;
	Если ДанныеЛида.Свойство("Контрагент") Тогда
		Контрагент = ДанныеЛида.Контрагент;
	Иначе
		Контрагент = Неопределено;
	КонецЕсли;
	
	ЕстьЗаявкиПоЛиду = НаличиеЗаявокВРаботеПоЛидуПоВидуОперации[ВидОперацииЗаказНаПродажу()]
	Или НаличиеЗаявокВРаботеПоЛидуПоВидуОперации[ВидОперацииЗаказНаряд()];
	
	Если ЗначениеЗаполнено(ВариантЗавершения) Тогда
		ПоказатьПредупреждениеОЗавершенномЛиде(ДанныеЛида.Ссылка, ДанныеЛида.Представление);
		Возврат Ложь;
	КонецЕсли;
	
	Если РезультатПеревода = "Покупатель" И ЗначениеЗаполнено(Контрагент) Тогда
		ПоказатьПредупреждениеОСвязанномКонтрагенте(Контрагент, ДанныеЛида.ПредставлениеКонтрагента);
		Возврат Ложь;
	КонецЕсли;
	
	Если ЕстьЗаявкиПоЛиду Тогда
		
		Если РезультатПеревода = "Покупатель" Тогда
			ТекстВопроса =
			НСтр("ru = 'По лиду есть заявки в работе. Перейти к заявкам или продолжить создание нового покупателя?'");
		ИначеЕсли РезультатПеревода = "ЗаказПокупателя" Тогда
			ТекстВопроса =
			НСтр("ru = 'По лиду есть заявки в работе. Перейти к заявкам или продолжить создание нового покупателя и заказ?'");
		ИначеЕсли РезультатПеревода = "ЗаказНаряд" Тогда
			ТекстВопроса =
			НСтр("ru = 'По лиду есть заявки в работе. Перейти к заявкам или продолжить создание нового покупателя и заказ-наряд?'");
		КонецЕсли;
		
	Иначе
		
		Если РезультатПеревода = "Покупатель" Тогда
			ТекстВопроса = НСтр("ru = 'Будет создан новый покупатель. Продолжить?'");
		ИначеЕсли РезультатПеревода = "ЗаказПокупателя" Тогда
			ТекстВопроса = НСтр("ru = 'Будет создан новый покупатель и заказ. Продолжить?'");
		ИначеЕсли РезультатПеревода = "ЗаказНаряд" Тогда
			ТекстВопроса = НСтр("ru = 'Будет создан новый покупатель и заказ-наряд. Продолжить?'");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЕстьЗаявкиПоЛиду Тогда
		Возврат Ждать ВопросПроНаличиеЗаявокПередПереводомЛидаАсинх(
		ДанныеЛида.Ссылка, НаличиеЗаявокВРаботеПоЛидуПоВидуОперации, ТекстВопроса);
	КонецЕсли;
	
	Если РезультатПеревода = "ЗаказПокупателя" Или РезультатПеревода = "ЗаказНаряд" Тогда
		Если ДанныеЛида.Вид = ПредопределенноеЗначение("Перечисление.ВидыЛидов.ПовторноеОбращение") Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	
	ОтветПользователя = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Если ОтветПользователя = КодВозвратаДиалога.Да Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Функция - Вопрос перед переводом лида в качественного для проверки существования заявок
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  НаличиеЗаявок - см РаботаСЗаявками.НаличиеЗаявокВРаботеПоЛидуПоВидуОперации
//  ТекстВопроса - Строка
// 
// Возвращаемое значение:
//  Булево - можно переводить лида в качественного
//
Асинх Функция ВопросПроНаличиеЗаявокПередПереводомЛидаАсинх(Лид, НаличиеЗаявок, ТекстВопроса = "") Экспорт
	
	Если Не ЗначениеЗаполнено(ТекстВопроса) Тогда
		ТекстВопроса =
		НСтр("ru = 'По лиду есть заявки в работе. Перейти к заявкам или продолжить перевод лида в качественного?'");
	КонецЕсли;
	
	КнопкиВопроса = Новый СписокЗначений;
	КнопкиВопроса.Добавить("ПерейтиКЗаявкам", НСтр("ru = 'Перейти к заявкам'"));
	КнопкиВопроса.Добавить("Продолжить", НСтр("ru = 'Продолжить'"));
	КнопкиВопроса.Добавить("Отмена", НСтр("ru = 'Отмена'"));
	
	ОтветОтПользователя = Ждать ВопросАсинх(ТекстВопроса, КнопкиВопроса, , "ПерейтиКЗаявкам");
	Если ОтветОтПользователя = "ПерейтиКЗаявкам" Тогда
		ОткрытьЗаявкиПоЛиду(Лид, , НаличиеЗаявок);
		Возврат Ложь;
	КонецЕсли;
	
	Если ОтветОтПользователя <> "Продолжить" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Процедура - Вопрос с оповещением перед переводом лида в качественного для проверки существования заявок
//
// Параметры:
//  ОписаниеОповещения - ОписаниеОповещения
//  ТекстВопроса - Строка
//
Процедура ВопросСОповещениемПроНаличиеЗаявокПередПереводомЛида(ОписаниеОповещения, ТекстВопроса = "") Экспорт
	
	Если Не ЗначениеЗаполнено(ТекстВопроса) Тогда
		ТекстВопроса = НСтр("ru = 'По лиду есть заявки в работе. Перейти к заявкам или продолжить перевод лида в качественного?'");
	КонецЕсли;
	
	КнопкиВопроса = Новый СписокЗначений;
	КнопкиВопроса.Добавить("ПерейтиКЗаявкам", НСтр("ru = 'Перейти к заявкам'"));
	КнопкиВопроса.Добавить("Продолжить", НСтр("ru = 'Продолжить'"));
	КнопкиВопроса.Добавить("Отмена", НСтр("ru = 'Отмена'"));
	
	ПараметрыВопросаПользователю = СтандартныеПодсистемыКлиент.ПараметрыВопросаПользователю();
	ПараметрыВопросаПользователю.ПредлагатьБольшеНеЗадаватьЭтотВопрос = Ложь;
	СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(
	ОписаниеОповещения, ТекстВопроса, КнопкиВопроса, ПараметрыВопросаПользователю);
	
КонецПроцедуры

// Процедура - Открыть покупателя или заказ после перевода лида
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  РезультатПеревода - Строка - "Покупатель" | "ЗаказПокупателя" | "ЗаказНаряд"
//  Контрагент - СправочникСсылка.Контрагенты - контрагент после перевода
//
Процедура ОткрытьРезультатПослеПереводаЛида(Лид, РезультатПеревода, Контрагент) Экспорт
	
	Если РезультатПеревода = "Покупатель" Тогда
		ОткрытьЗначениеАсинх(Контрагент);
	ИначеЕсли РезультатПеревода = "ЗаказПокупателя" Тогда
		
		ПараметрыФормы = Новый Структура;
		СтруктураЗаполнения = Новый Структура;
		СтруктураЗаполнения.Вставить("Контрагент", Контрагент);
		СтруктураЗаполнения.Вставить("Лид", Лид);
		СтруктураЗаполнения.Вставить("ВидОперации", ВидОперацииЗаказНаПродажу());
		
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", СтруктураЗаполнения);
		ПараметрыФормы.Вставить("МожноИспользоватьЗавершенногоЛида");
		ОткрытьФорму("Документ.ЗаказПокупателя.ФормаОбъекта", ПараметрыФормы);
		
	ИначеЕсли РезультатПеревода = "ЗаказНаряд" Тогда
		
		ПараметрыФормы = Новый Структура;
		СтруктураЗаполнения = Новый Структура;
		СтруктураЗаполнения.Вставить("Контрагент", Контрагент);
		СтруктураЗаполнения.Вставить("Лид", Лид);
		СтруктураЗаполнения.Вставить("ВидОперации", ВидОперацииЗаказНаряд());
		
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", СтруктураЗаполнения);
		ПараметрыФормы.Вставить("МожноИспользоватьЗавершенногоЛида");
		ОткрытьФорму("Документ.ЗаказПокупателя.ФормаОбъекта", ПараметрыФормы);
		
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

// Функция - Вопрос перед созданием контрагента по лиду
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
// 
// Возвращаемое значение:
//  Булево
//
Асинх Функция СоздатьКонтрагентаПоЛидуНажатиеАсинх(Лид) Экспорт
	
	Если Не ЗначениеЗаполнено(Лид) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	НавигационнаяСсылкаЛида = ПолучитьНавигационнуюСсылку(Лид);
	ПредставлениеЛида = Строка(Лид);
	
	ТекстВопроса = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
	НСтр("ru='Лид <a href=""%1"">%2</a> будет завершен и переведен в нового покупателя. Продолжить?'"),
	НавигационнаяСсылкаЛида, ПредставлениеЛида);
	
	ОтветПользователя = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Если ОтветПользователя <> КодВозвратаДиалога.Да Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область ОповещениеОбИзменении

// Оповестить об изменении
//
// Параметры:
//  Ссылка - СправочникСсылка.Лиды
//
Процедура ОповеститьОбИзмененном(Ссылка) Экспорт
	
	Оповестить(РаботаСЛидамиКлиентСервер.КлючОповещения(), Ссылка);
	
КонецПроцедуры

#КонецОбласти

// Процедура - Открыть заявки по лиду
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
//  НаличиеЗаявок - см РаботаСЗаявками.НаличиеЗаявокВРаботеПоЛидуПоВидуОперации
//
Процедура ОткрытьЗаявкиПоЛиду(Лид, ВидОперации = Неопределено, НаличиеЗаявок = Неопределено) Экспорт
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Лид", Лид);
	
	Если Не ЗначениеЗаполнено(ВидОперации) И ЗначениеЗаполнено(НаличиеЗаявок) Тогда
		ВидОперации = ВидОперацииПоНаличиюЗаявок(НаличиеЗаявок);
	КонецЕсли;
	
	Если ВидОперации = ВидОперацииЗаказНаряд() Тогда
		ОткрытьФорму("Документ.ЗаказПокупателя.Форма.ФормаСпискаЗаказНаряда", ПараметрыФормы, , Истина);
	Иначе
		ОткрытьФорму("Документ.ЗаказПокупателя.Форма.ФормаСписка", ПараметрыФормы, , Истина);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПоказатьПредупреждениеОЗавершенномЛиде(Ссылка, Представление) Экспорт
	
	ТекстПредупреждения = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
	НСтр("ru = 'Работа с лидом <a href=""%1"">%2</a> уже завершена'"),
	ПолучитьНавигационнуюСсылку(Ссылка), Представление);
	
	ПредупреждениеАсинх(ТекстПредупреждения);
	
КонецПроцедуры

Процедура ПоказатьПредупреждениеОСвязанномКонтрагенте(Контрагент, ПредставлениеКонтрагента) Экспорт
	
	ТекстПредупреждения = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
	НСтр("ru = 'Лид уже связан с покупателем <a href=""%1"">%2</a>'"),
	ПолучитьНавигационнуюСсылку(Контрагент), ПредставлениеКонтрагента);
	
	ПредупреждениеАсинх(ТекстПредупреждения);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ВидОперацииПоНаличиюЗаявок(НаличиеЗаявокВРаботеПоЛидуПоВидуОперации)
	
	ВидОперацииЗаказНаПродажу = ВидОперацииЗаказНаПродажу();
	ВидОперацииЗаказНаряд = ВидОперацииЗаказНаряд();
	Если НаличиеЗаявокВРаботеПоЛидуПоВидуОперации[ВидОперацииЗаказНаПродажу] Тогда
		Возврат ВидОперацииЗаказНаПродажу;
	Иначе
		Возврат ВидОперацииЗаказНаряд;
	КонецЕсли;
	
КонецФункции

Функция ВидОперацииЗаказНаПродажу()
	
	Возврат ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу");
	
КонецФункции

Функция ВидОперацииЗаказНаряд()
	
	Возврат ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд");
	
КонецФункции

#КонецОбласти