#Область ПереводЛида

// Перевод лида в качественного
//
// Параметры:
//  ЛидОбъект - СправочникОбъект.Лиды
//  КонтрагентДляСвязи - СправочникСсылка.Контрагенты - если передается, то при переводе лид привязывается к этому
//                                                      контрагенту
// 
// Возвращаемое значение:
//  Структура:
//   * Контрагент - СправочникСсылка.Контрагенты
//   * Лид - СправочникСсылка.Лиды
//
Функция ПеревестиЛида(ЛидОбъект, КонтрагентДляСвязи = Неопределено) Экспорт
	
	Если ЛидОбъект.Вид = Перечисления.ВидыЛидов.ПовторноеОбращение Тогда
		
		ЛидОбъект.Заполнить(Новый Структура("ПереводВКачественныйЛид", Истина));
		Если Не ЛидОбъект.ПроверитьЗаполнение() Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КонтрагентДляСвязи) Тогда
			ЛидОбъект.ДополнительныеСвойства.Вставить("Контрагент", КонтрагентДляСвязи);
		КонецЕсли;
		
		ЛидОбъект.Записать();
		
		КонтрагентПослеПеревода = Справочники.Лиды.СвязанныйКонтрагент(ЛидОбъект.Ссылка);
		
	Иначе
		КонтрагентПослеПеревода = Справочники.Лиды.ПеревестиЛидаВПокупателя(ЛидОбъект);
		Если КонтрагентПослеПеревода = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Контрагент", КонтрагентПослеПеревода);
	Результат.Вставить("Лид", ЛидОбъект.Ссылка);
	
	Возврат Результат;
	
КонецФункции

// Проверка данных лида, прежде чем переводить его в качественного
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
// 
// Возвращаемое значение:
//  Булево
//
Функция МожноПеревестиВКлиента(Лид) Экспорт
	
	Результат = Истина;
	КонтактыЛида = Справочники.КонтактыЛидов.КонтактыЛида(Лид);
	
	Для каждого ДанныеКонтакта Из КонтактыЛида Цикл
		
		Если ЗначениеЗаполнено(ДанныеКонтакта.Наименование) Тогда
			Продолжить;
		КонецЕсли;
		
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Поле ""Имя Фамилия"" заполнено не у всех контактов лида'"));
		Результат = Ложь;
		
	КонецЦикла;
	
	ЛидОбъект = Лид.ПолучитьОбъект();
	Если НЕ ЛидОбъект.ПроверитьЗаполнение() Тогда
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область РаботаНаФормах

// Действия после чтения заказа для работы с лидами
//
// Параметры:
//  Ссылка - ДокументСсылка.ЗаказПокупателя
//  ЭлементЛидОснование - ДекорацияФормы - куда помещается ссылка на лид-основание заказа
//
Процедура ДействияПослеЧтенияЗаказа(Ссылка, ЭлементЛидОснование) Экспорт
	
	ЛидОснование = РегистрыСведений.СвязиКонтрагентЛид.ЛидПоЗаказу(Ссылка);
	Если Не ЗначениеЗаполнено(ЛидОснование) Тогда
		Возврат;
	КонецЕсли;
	
	НавигационнаяСсылкаЛида = ПолучитьНавигационнуюСсылку(ЛидОснование);
	ПредставлениеЛида = Строка(ЛидОснование);
	
	ЭлементЛидОснование.Видимость = Истина;
	ЭлементЛидОснование.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(
	НСтр("ru = 'Заказ создан от лида <a href=""%1"">%2</a>'"), НавигационнаяСсылкаЛида, ПредставлениеЛида);
	
КонецПроцедуры

#КонецОбласти

#Область Заявки

// Отменить все заявки лида в работе по лиду
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  ДанныеОтмены - Структура:
//   * ПричинаОтмены - СправочникСсылка.ПричиныОтменыЗаказа
//   * Заметки - Строка
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка.ЗаказПокупателя - заявки лида в работе
//
Функция ОтменитьВсеЗаявкиЛидаВРаботе(Лид, ДанныеОтмены) Экспорт
	
	Заявки = РаботаСЗаявками.ЗаявкиЛидаВРаботе(Лид);
	
	Если Не Заявки.Количество() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Для Каждого Заявка Из Заявки Цикл
		
		ЗаявкаОбъект = Заявка.ПолучитьОбъект();
		
		Попытка
			ЗаявкаОбъект.Заблокировать();
		Исключение
			
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			
			ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			ТекстОшибки = СтрШаблон(НСтр("ru = 'Не удалось заблокировать объект %1
			|
			|Описание ошибки:
			|%2'"),
			ЗаявкаОбъект,
			ТекстОшибки);
			
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Блокировки.Ошибка'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка, Метаданные.Документы.ЗаказПокупателя, ЗаявкаОбъект,
			ТекстОшибки);
			
			ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке));
			
		КонецПопытки;
		
		Если ЗаявкаОбъект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд Тогда
			СостояниеЗаказа = Справочники.СостоянияЗаказНарядов.Завершен;
		Иначе
			СостояниеЗаказа = Справочники.СостоянияЗаказовПокупателей.Завершен;
		КонецЕсли;
		
		ЗаявкаОбъект.СостояниеЗаказа = СостояниеЗаказа;
		ЗаявкаОбъект.ВариантЗавершения = ПредопределенноеЗначение("Перечисление.ВариантыЗавершенияЗаказа.Отменен");
		ЗаявкаОбъект.ПричинаОтмены = ДанныеОтмены.ПричинаОтмены;
		ЗаявкаОбъект.Заметки = ДанныеОтмены.Заметки;
		
		ЗаявкаОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		
	КонецЦикла;
	
	Возврат Заявки;
	
КонецФункции

#КонецОбласти

#Область Заказы

Функция ЕстьЗаказПоЛиду(Лид, Заказы) Экспорт
	
	Если ТипЗнч(Заказы) = Тип("Массив") Тогда
		
		ДанныеЗаказов = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Заказы, "Лид");
		Для Каждого КлючЗначение Из ДанныеЗаказов Цикл
			Если КлючЗначение.Значение = Лид Тогда
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
		
	Иначе
		
		Возврат (Лид = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Заказы, "Лид"));
		
	КонецЕсли;
	
КонецФункции

