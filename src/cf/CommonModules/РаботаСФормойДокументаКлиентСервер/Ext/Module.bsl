#Область ПрограммныйИнтерфейс

// Возвращает форматированную строку представления счет-фактуры
// 
// Параметры:
//  НайденныйСчетФактура - Ссылка на найденную счет-фактуру
//  Полученный - Признак вида счет-фактуры
//  СчетФактураТекст - Строка
//  УПД - Признак использования УПД в документе
//  Корректировочный - Признак вида корректировочного счет-фактуры
// 
// Возвращаемое значение:
//  ФорматированнаяСтрока - представление счет-фактуры
Функция СформироватьНадписьСчетФактура(НайденныйСчетФактура, Полученный = Ложь, СчетФактураТекст="", УПД = Ложь, Корректировочный = Ложь) Экспорт

	КомпонентыФС = Новый Массив;
	
	ТекстИмяДокумента = "";
	Если Корректировочный Тогда
		
		ТекстИмяДокумента = НСтр("ru = 'Счет-фактура (корректировочный)'");
		
	ИначеЕсли Полученный Тогда
		
		Если ЗначениеЗаполнено(НайденныйСчетФактура) Тогда
			ТекстИмяДокумента = НСтр("ru = 'Счет-фактура (полученный)'");
		КонецЕсли;
		
	Иначе
		ТекстИмяДокумента = НСтр("ru = 'Счет-фактура'");
	КонецЕсли;
	
	Если НЕ УПД И НЕ ПустаяСтрока(ТекстИмяДокумента) Тогда
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(СтрШаблон("%1: ", ТекстИмяДокумента)));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НайденныйСчетФактура) Тогда
		
		ДанныеДокумента = Новый Структура("Ссылка, Номер, Дата");
		Если ТипЗнч(НайденныйСчетФактура) = Тип("Структура") Тогда
			ЗаполнитьЗначенияСвойств(ДанныеДокумента, НайденныйСчетФактура);
		Иначе
			ДанныеДокумента.Ссылка = НайденныйСчетФактура;
		КонецЕсли;
		
		Если ТипЗнч(ДанныеДокумента.Ссылка) = Тип("ДокументСсылка.СчетФактура") Тогда
			НомерДатаДокумента = СчетаФактурыУНФВызовСервера.ДатаНомерДляПечатиСчетаФактуры(ДанныеДокумента.Ссылка);
			ЗаполнитьЗначенияСвойств(ДанныеДокумента, НомерДатаДокумента);
			СчетФактураТекст = СчетаФактурыУНФКлиентСервер.ПредставлениеСчетаФактуры(НомерДатаДокумента.Дата,
				НомерДатаДокумента.Номер, Истина);
		
		ИначеЕсли ЗначениеЗаполнено(ДанныеДокумента.Номер) Тогда
			
			ДатаСФ = ?(ТипЗнч(ДанныеДокумента.Дата) = Тип("Дата"), ДанныеДокумента.Дата, Неопределено);
			СчетФактураТекст = СчетаФактурыУНФКлиентСервер.ПредставлениеСчетаФактуры(ДанныеДокумента.Дата,
				ДанныеДокумента.Номер, Истина);
				
		Иначе
			// для строки
			СчетФактураТекст = СтрЗаменить(ДанныеДокумента.Ссылка, НСтр("ru = 'Счет-фактура'"), "№");
			СчетФактураТекст = СтрЗаменить(СчетФактураТекст, НСтр("ru = '(удален)'"), "");
			СчетФактураТекст = СтрЗаменить(СчетФактураТекст, НСтр("ru = '(не проведен)'"), "");
			СчетФактураТекст = СокрЛП(СчетФактураТекст);
		КонецЕсли;
		
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(СчетФактураТекст, , , , "открыть"));
		
	Иначе
		
		Если Не УПД Тогда
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока("создать", , , , "создать"));
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока(КомпонентыФС);
	
КонецФункции

Функция СформироватьНадписьДокументОснование(Знач ДокОснование, Знач пТолькоПросмотр = Ложь) Экспорт
	
	КомпонентыФС = Новый Массив;
	
	ПредставлениеДокОснования = РаботаСФормойДокумента.ПредставлениеДокументаОснования(ДокОснование);
	
	Если ПредставлениеДокОснования = "НетОбъекта" Тогда
		
		КомпонентыФС = Новый Массив;
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Основание: находится в автономном рабочем месте'")));
		
	ИначеЕсли ЗначениеЗаполнено(ДокОснование) Тогда
		
		// Для документов, у которых "номер входящего документа" указывается в отдельном поле, например Счет-фактура входящий
		Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.СчетФактураПолученный") Тогда
			РеквизитыДокОснования = РаботаСФормойДокумента.РеквизитыДокументаОснования(ДокОснование);
			
			ПредставлениеДокОснования = СтрЗаменить(ПредставлениеДокОснования, 
				НСтр("ru = 'Счет-фактура (полученный) '")+ПолучитьКороткийНомерДокумента(РеквизитыДокОснования.Номер),
				НСтр("ru = 'Счет-фактура (полученный) '")+РеквизитыДокОснования.НомерВходящегоДокумента);
			ПредставлениеДокОснования = СтрЗаменить(ПредставлениеДокОснования,
				Формат(РеквизитыДокОснования.Дата,"ДФ=dd.MM.yyyy"),
				Формат(РеквизитыДокОснования.ДатаВходящегоДокумента,"ДФ=dd.MM.yyyy"));
		КонецЕсли;
		
		ДокОснованиеТекст = ПредставлениеДокОснования;
		
		ДокОснованиеТекст = СтрЗаменить(ДокОснованиеТекст, НСтр("ru = ' (удален)'"),"");
		ДокОснованиеТекст = СтрЗаменить(ДокОснованиеТекст, НСтр("ru = ' (не проведен)'"),"");

		КомпонентыФС = Новый Массив;
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Основание: '")));
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(ДокОснованиеТекст, , , , "открыть"));
		Если НЕ пТолькоПросмотр Тогда
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(" "));
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.ЗаполнитьПоОснованию12х12, , , , "заполнить"));
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(" "));
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Очистить, , , , "удалить"));
		КонецЕсли;
	Иначе
		КомпонентыФС = Новый Массив;
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Основание: '")));
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока("выбрать", , , , "выбрать"));
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока(КомпонентыФС);

КонецФункции

Функция ПолучитьЗаголовокПредоплаты(Знач ТабЧасть, Знач ВалютаДокумента) Экспорт
	
	Если ТабЧасть.Количество()>0 Тогда
		Возврат НСтр("ru = 'Предоплата: '") + ТабЧасть.Итог("СуммаРасчетов") + " " + УправлениеНебольшойФирмойПовтИсп.ПолучитьСимвольноеПредставлениеВалюты(ВалютаДокумента); 
	Иначе
		Возврат НСтр("ru = 'Предоплата'");
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЗаголовокОплаты(Знач СпособЗачета, Знач ТабЧасть) Экспорт
	
	Если СпособЗачета = ПредопределенноеЗначение("Перечисление.СпособыЗачетаИРаспределенияПлатежей.Авто") Тогда
		Возврат НСтр("ru = 'Оплата ('") + СпособЗачета + ")";
	Иначе
		Если ТабЧасть.Количество() > 0 Тогда
			Возврат НСтр("ru = 'Оплата ('") + ТабЧасть.Количество() + ")";
		Иначе
			Возврат НСтр("ru = 'Оплата ('") + СпособЗачета + ")";
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

Функция КраткоеПредставлениеТипаНалогообложенияНДС(НалогообложениеНДС) Экспорт
	
	Если НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС") Тогда
		Возврат НСтр("ru = 'с НДС'");
	ИначеЕсли НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НеОблагаетсяНДС") Тогда
		Возврат НСтр("ru = 'без НДС'");
	ИначеЕсли НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НаЭкспорт") Тогда
		Возврат НСтр("ru = '0% НДС'");
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Функция ПолучитьКороткийНомерДокумента(Знач НомерДок) Экспорт
	
	СоответствиеЧисел = Новый Соответствие();
	СоответствиеЧисел.Вставить("1",1);
	СоответствиеЧисел.Вставить("2",2);
	СоответствиеЧисел.Вставить("3",3);
	СоответствиеЧисел.Вставить("4",4);
	СоответствиеЧисел.Вставить("5",5);
	СоответствиеЧисел.Вставить("6",6);
	СоответствиеЧисел.Вставить("7",7);
	СоответствиеЧисел.Вставить("8",8);
	СоответствиеЧисел.Вставить("9",9);
	СоответствиеЧисел.Вставить("0",0);
	
	НомерДок = СокрЛП(НомерДок);
	ДлинаСтроки = СтрДлина(НомерДок);
	НомерЧисло = НомерДок;
	
	Для н=1 По ДлинаСтроки Цикл
	
		Если СоответствиеЧисел.Получить(Сред(НомерДок,ДлинаСтроки-н+1,1)) = Неопределено Тогда
			НомерЧисло = Прав(НомерДок, н-1); 
			Прервать;
		КонецЕсли;
	
	КонецЦикла;
	
	Если СтрДлина(НомерЧисло)>0 Тогда
		Возврат Формат(Число(НомерЧисло), "ЧГ=0");
	Иначе
		Возврат НомерДок;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьИмяФормыСтрокой(Знач ИмяФормы) Экспорт
	
	ИмяФормы = СтрЗаменить(ИмяФормы, ".ФормаСписка", "");
	ИмяФормы = СтрЗаменить(ИмяФормы, ".ФормаДокумента", "");
	ИмяФормы = СтрЗаменить(ИмяФормы, ".ФормаВыбора", "");
	ИмяФормы = СтрЗаменить(ИмяФормы, ".ФормаЭлемента", "");
	ИмяФормы = СтрЗаменить(ИмяФормы, ".Форма", "");
	
	ИмяФормы = СтрЗаменить(ИмяФормы, ".", "");
	
	Возврат ИмяФормы;
	
КонецФункции

Функция ВариантОтчета(ИмяОтчета, КлючВарианта) Экспорт
	
	Возврат РаботаСФормойДокумента.СсылкаВариантаОтчета(ИмяОтчета, КлючВарианта);
	
КонецФункции

// Возвращает структуру имен элементов подбора предоплаты о умолчанию на форме документа
// 
// Возвращаемое значение:
// 	Структура - Структура имен элементов
Функция ИменаЭлементовПредоплатыПоУмолчанию() Экспорт
	
	ИменаЭлементов = Новый Структура;
	ИменаЭлементов.Вставить("ВариантЗаполненияРасшифровки", "ВариантЗаполненияРасшифровки");
	ИменаЭлементов.Вставить("СтраницыРасчетовСКонтрагентом", "СтраницыРасчетовСКонтрагентом");
	ИменаЭлементов.Вставить("СтраницаПросмотр", "СтраницаПросмотр");
	ИменаЭлементов.Вставить("СтраницаРедактирование", "СтраницаРедактирование");
	ИменаЭлементов.Вставить("СтраницаРучноеЗаполнение", "СтраницаРучноеЗаполнение");
	ИменаЭлементов.Вставить("ТаблицаДляПросмотра", "ТаблицаДляПросмотра");
	ИменаЭлементов.Вставить("ГруппаКомандыТаблицыДляПросмотра", "ГруппаКомандыТаблицыДляПросмотра");
	ИменаЭлементов.Вставить("СпособЗачетаПредоплаты", "СпособЗачетаПредоплаты");
	ИменаЭлементов.Вставить("ГруппаПредоплата", "ГруппаПредоплата");
	ИменаЭлементов.Вставить("ОткрытьПомощникЗачетаПредоплаты", "ОткрытьПомощникЗачетаПредоплаты");
	Возврат ИменаЭлементов;
	
КонецФункции

// Возвращает строку с описанием настроек налогового учета в строке табличной части
// 
// Параметры:
//  ПараметрСтрока - ДанныеФормыЭлементКоллекции
//  ВидимостьУСН - Булево
//  ВидимостьПатент - Булево
//  ВидимостьНДС - Булево
// 
// Возвращаемое значение:
//  Строка - представление налогового учета в переданной строке
Функция ПредставлениеНалоговогоУчетаСтроки(ПараметрСтрока, ВидимостьУСН, ВидимостьПатент = Ложь, ВидимостьНДС = Истина) Экспорт
	
	КомпонентыСтроки = Новый Массив;
	
	Если ВидимостьУСН Тогда
		Если ПараметрСтрока.УчитыватьВНУ Тогда
			КомпонентыСтроки.Добавить(НСтр("ru='УСН (Да)'"));
		Иначе
			КомпонентыСтроки.Добавить(НСтр("ru='УСН (Нет)'"));
		КонецЕсли;
	КонецЕсли; 
	
	Если ВидимостьНДС Тогда
		НалогообложениеСтрокой = "";
		
		Если ПараметрСтрока.Свойство("НалогообложениеНДС") Тогда
			НалогообложениеСтрокой = КраткоеПредставлениеТипаНалогообложенияНДС(ПараметрСтрока.НалогообложениеНДС);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НалогообложениеСтрокой) Тогда
			КомпонентыСтроки.Добавить(НалогообложениеСтрокой);
		Иначе
			КомпонентыСтроки.Добавить(НСтр("ru='<Не выбрано>'"));
		КонецЕсли;
	КонецЕсли;
	
	Если ВидимостьПатент Тогда
		Если ЗначениеЗаполнено(ПараметрСтрока.Патент) Тогда
			КомпонентыСтроки.Добавить(ПараметрСтрока.Патент);
		КонецЕсли;
	КонецЕсли;
	
	Результат = СтрСоединить(КомпонентыСтроки, ", ");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти