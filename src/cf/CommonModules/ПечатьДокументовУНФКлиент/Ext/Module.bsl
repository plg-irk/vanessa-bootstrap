// Обрабатывает навигационную ссылку, полученную из общей формы ПечатьДокументов
// Параметры:
//  Форма                - ФормаКлиентскогоПриложения
//  Элемент              - ВсеЭлементыФормы - элемент, вызвавший событие
//  НавигационнаяСсылкаФорматированнойСтроки - Строка - Текст навигационной ссылки
//  СтандартнаяОбработка - Булево - признак выполнения стандартной обработки события
Процедура ПечатьДокументовОбработкаНавигационнойСсылки(Форма, Элемент, НавигационнаяСсылкаФорматированнойСтроки,
	СтандартнаяОбработка) Экспорт
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "ФаксимилеОрганизации" Тогда
		СтандартнаяОбработка = Ложь;
		НастроитьФаксимилеОткрытьОрганизацию(Форма.Организация);
	КонецЕсли;
	
КонецПроцедуры

// Печать реестра документов.
// 
// Параметры:
//	ПараметрыПечати - структура - содержит ключ, соответствующие таблице значений
//						создаваемой функций БСП УправлениеПечатью.СоздатьКоллекциюКомандПечати(),
//						и ключ Форма - управляемая форма, из которой вызвана команда печати.
// Возвращаемое значение:
//  Неопределено
//
Функция ПечатьРеестраДокументов(ПараметрыПечати) Экспорт
	
	ФормаСписка = ПараметрыПечати.Форма;
	
	Если ПараметрыПечати.ДополнительныеПараметры.Свойство("АдресХранилищаНастроекСпискаДляРеестра") Тогда
		ПараметрыФормы = ПолучитьИзВременногоХранилища(
			ПараметрыПечати.ДополнительныеПараметры.АдресХранилищаНастроекСпискаДляРеестра);
		ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	ОткрытьФорму("Отчет.РеестрДокументов.Форма", ПараметрыФормы, ФормаСписка);
	
	Возврат Неопределено;
	
КонецФункции

// Обработчик события ПриНачалеРедактирования таблицы Товары
// Параметры:
//  Элемент - ТаблицаФормы - Элемент, где произошло событие.
//  НоваяСтрока - Булево - Признак редактирования новой строки. Имеет значение Истина, если строка была добавлена или скопирована.
//  Копирование -  Булево - Определяет режим копирования. Если установлено Истина, то происходит копирование строки.
//  Форма - ФормаКлиентскогоПриложения - форма, где произошло событие.
//
Процедура ТоварыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование, Форма) Экспорт
	
	Если Элемент.ТекущийЭлемент.Имя = "КолонкаСерия" Тогда
		СтандартнаяОбработка = Ложь;
		ТекущиеДанные = Форма.Элементы.Товары.ТекущиеДанные;
		СтруктураТовары = Новый Структура;
		СтруктураТовары.Вставить("КлючСвязи", ТекущиеДанные.НомерСтроки);
		СтруктураТовары.Вставить("Номенклатура", ТекущиеДанные.НоменклатураБПО);
		СтруктураТовары.Вставить("Характеристика", ТекущиеДанные.ХарактеристикаБПО);
		СтруктураТовары.Вставить("Количество", ТекущиеДанные.Количество);
		Если ТекущиеДанные.Свойство("Партия") Тогда
			СтруктураТовары.Вставить("Партия", ТекущиеДанные.Партия);
		КонецЕсли;
		
		Организация = ПредопределенноеЗначение("Справочник.Организации.ПустаяСсылка");
		ПолеОрганизация = НайтиОтборВКомпоновщике("Организация", Форма.КомпоновщикНастроек);
		Если Не ПолеОрганизация = Неопределено Тогда
			Если ПолеОрганизация.Использование Тогда
				Организация = ПолеОрганизация.ПравоеЗначение;
			КонецЕсли;
		КонецЕсли;
		ПараметрыПодбораСерийНоменклатуры = Новый Структура;
		ПараметрыПодбораСерийНоменклатуры.Вставить("Организация", Организация);
		Если ЗначениеЗаполнено(Форма.Объект.ТорговыйОбъектБПО) Тогда
			ПараметрыПодбораСерийНоменклатуры.Вставить("СтруктурнаяЕдиница", Форма.Объект.ТорговыйОбъектБПО);
		КонецЕсли;
		ПараметрыПодбораСерийНоменклатуры.Вставить("ИгнорироватьКонтрольОстатков", Истина);
		ПараметрыПодбораСерийНоменклатуры.Вставить("Запасы", СтруктураТовары);
		ПараметрыПодбораСерийНоменклатуры.Вставить("УникальныйИдентификаторФормыВладельца", Форма.УникальныйИдентификатор);
		ПараметрыПодбораСерийНоменклатуры.Вставить("РежимПодбора", Истина);
		ПараметрыПодбораСерийНоменклатуры.Вставить("АдресВоВременномХранилище", "");
		ПараметрыПодбораСерийНоменклатуры.Вставить("ДокСсылка", ПредопределенноеЗначение("Документ.РасходнаяНакладная.ПустаяСсылка"));
		ОткрытьФорму("Обработка.ПодборСерийНоменклатуры.Форма", ПараметрыПодбораСерийНоменклатуры, Форма);
	КонецЕсли;
	
КонецПроцедуры

