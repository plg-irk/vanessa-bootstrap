	// Склад
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
		СтрокаРеквизитов = "Дата,Организация,Склад_GUID,СкладПолучатель_GUID";
		СтрокаТабличныхЧастей = "";
		СтрокаСпециальныхРеквизитов = "Проведен";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ИнвентаризацияЗапасов") Тогда
		СтрокаРеквизитов = "Дата,Организация,Склад_GUID";
		СтрокаТабличныхЧастей = "";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОприходованиеЗапасов") Тогда
		СтрокаРеквизитов = "Дата,Организация,Склад_GUID";
