		СтрокаРеквизитов = "Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение";
		СтрокаТабличныхЧастей = "";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПереоценкаТоваровНаКомиссии") Тогда
		СтрокаРеквизитов = "Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение";
		СтрокаТабличныхЧастей = "";
		
 	//	Закупки
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.СчетНаОплатуПоставщика") Тогда
		СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение,НомерВходящегоДокумента,ДатаВходящегоДокумента,СуммаНДС";
