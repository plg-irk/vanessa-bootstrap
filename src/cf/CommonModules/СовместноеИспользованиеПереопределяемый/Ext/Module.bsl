			ИЛИ ВидОперацииДокумента = Перечисления.ВидыОперацийРасходСоСчета.СнятиеНаличных
			ИЛИ ВидОперацииДокумента = Перечисления.ВидыОперацийРасходСоСчета.Зарплата
			ИЛИ ВидОперацииДокумента = Перечисления.ВидыОперацийРасходСоСчета.ПрочиеРасчеты
			ИЛИ ВидОперацииДокумента = Перечисления.ВидыОперацийРасходСоСчета.НаРасходы
			ИЛИ ВидОперацииДокумента = Перечисления.ВидыОперацийРасходСоСчета.Прочее Тогда
			СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение,НомерВходящегоДокумента,ДатаВходящегоДокумента";
		Иначе
			СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение,НомерВходящегоДокумента,ДатаВходящегоДокумента,СуммаНДС";
		КонецЕсли;
		СтрокаТабличныхЧастей = "РасшифровкаПлатежа";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПлатежноеПоручение") Тогда
		СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение";
		СтрокаТабличныхЧастей = "";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда
		СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение,СуммаНДС";
