	// Раздел Прочее
	ДобавитьСоответствиеВидаДокументаИРазделаУчета(ТаблицаСоответствие, "Прочее", Метаданные.Документы.ЗаказПокупателя, , НСтр("ru = 'Заказ-наряд'"));
	ДобавитьСоответствиеВидаДокументаИРазделаУчета(ТаблицаСоответствие, "Прочее", Метаданные.Документы.Взаимозачет);
	ДобавитьСоответствиеВидаДокументаИРазделаУчета(ТаблицаСоответствие, "Прочее", Метаданные.Документы.ДоговорКредитаИЗайма);
	ДобавитьСоответствиеВидаДокументаИРазделаУчета(ТаблицаСоответствие, "Прочее", Метаданные.Документы.НачисленияПоКредитамИЗаймам);
	ДобавитьСоответствиеВидаДокументаИРазделаУчета(ТаблицаСоответствие, "Прочее", Метаданные.Документы.ПрочиеРасходы);
	ДобавитьСоответствиеВидаДокументаИРазделаУчета(ТаблицаСоответствие, "Прочее", Метаданные.Документы.ПередачаТоваровМеждуОрганизациями);
	
КонецПроцедуры

Процедура ЗаполнитьДоступныеРазделыУчета(ТаблицаРазделы) Экспорт
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуПродажи") Тогда
		НовыйРаздел = ТаблицаРазделы.Добавить();
		НовыйРаздел.Идентификатор = "Продажи";
		НовыйРаздел.Представление = НСтр("ru = 'Продажи'");
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуЗакупки") Тогда
		НовыйРаздел = ТаблицаРазделы.Добавить();
		НовыйРаздел.Идентификатор = "Закупки";
		НовыйРаздел.Представление = НСтр("ru = 'Закупки'");
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуДеньги") Тогда
		НовыйРаздел = ТаблицаРазделы.Добавить();
		НовыйРаздел.Идентификатор = "Деньги";
		НовыйРаздел.Представление = НСтр("ru = 'Деньги'");
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуСклад") Тогда
		НовыйРаздел = ТаблицаРазделы.Добавить();
		НовыйРаздел.Идентификатор = "Склад";
		НовыйРаздел.Представление = НСтр("ru = 'Склад'");
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуПроизводство") Тогда
		НовыйРаздел = ТаблицаРазделы.Добавить();
		НовыйРаздел.Идентификатор = "Производство";
		НовыйРаздел.Представление = НСтр("ru = 'Производство'");
	КонецЕсли;
	
	НовыйРаздел = ТаблицаРазделы.Добавить();
	НовыйРаздел.Идентификатор = "Прочее";
	НовыйРаздел.Представление = НСтр("ru = 'Прочее'");
	
КонецПроцедуры

Функция ОписаниеОбъектаБухгалтерии(Идентификатор, ИдентификаторМетаданных, ДополнятьДаннымиОбъекта = Ложь) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения КАК ЕстьОшибкиОтражения,
	|	ИдентификаторыБухгалтерии.ПроблемыПриПроверке КАК ПроблемыПриПроверке,
	|	ИдентификаторыБухгалтерии.НавигационнаяСсылка КАК НавигационнаяСсылка,
	|	ИдентификаторыБухгалтерии.Представление КАК Представление,
	|	ИдентификаторыБухгалтерии.Проведен КАК Проведен,
	|	ИдентификаторыБухгалтерии.ПометкаУдаления КАК ПометкаУдаления,
	|	ИдентификаторыБухгалтерии.ДанныеОбъекта КАК ДанныеОбъекта,
	|	ИдентификаторыБухгалтерии.Номер КАК Номер,
	|	ИдентификаторыБухгалтерии.Дата КАК Дата,
	|	ИдентификаторыБухгалтерии.ВидОперации КАК ВидОперации,
	|	ИдентификаторыБухгалтерии.СуммаДокумента КАК СуммаДокумента
	|ИЗ
	|	РегистрСведений.ПубличныеИдентификаторыБухгалтерии КАК ИдентификаторыБухгалтерии
	|ГДЕ
	|	ИдентификаторыБухгалтерии.Идентификатор = &Идентификатор
	|	И ИдентификаторыБухгалтерии.ИдентификаторМетаданных = &ИдентификаторМетаданных");
	Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
	Запрос.УстановитьПараметр("ИдентификаторМетаданных", ИдентификаторМетаданных);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Новый Структура("ЕстьОшибкиОтражения,НавигационнаяСсылка,Представление,Проведен,ПометкаУдаления");
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		
		Если ПустаяСтрока(Выборка.ПроблемыПриПроверке) Тогда
			Результат.Вставить("ПроблемыПриПроверке", Новый Массив);
		Иначе
			Результат.Вставить("ПроблемыПриПроверке", ОбщегоНазначения.JSONВЗначение(Выборка.ПроблемыПриПроверке));
		КонецЕсли;  
		
		Если ДополнятьДаннымиОбъекта Тогда
			Если Не ПустаяСтрока(Выборка.ДанныеОбъекта) Тогда
				ДанныеОбъекта = ОбщегоНазначения.JSONВЗначение(Выборка.ДанныеОбъекта, , Ложь);
			Иначе
				ДанныеОбъекта = Новый Структура;
			КонецЕсли;                                                                            
			ДанныеОбъекта.Вставить("Номер", Выборка.Номер);
			ДанныеОбъекта.Вставить("Дата", Выборка.Дата);
			ДанныеОбъекта.Вставить("ВидОперации", Выборка.ВидОперации);
			ДанныеОбъекта.Вставить("СуммаДокумента", Выборка.СуммаДокумента); 
			
			Результат.Вставить("ДанныеОбъекта", ДанныеОбъекта);
		КонецЕсли;
		
		Возврат Результат;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция СведенияОПарныхДокументахПоДокументуБизнеса(Ссылка, УзелОбмена) Экспорт 
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ИдентификаторыБухгалтерии.Идентификатор КАК Идентификатор,
	|	ИдентификаторыБухгалтерии.ИдентификаторМетаданных КАК ИдентификаторМетаданных,
	|	ИдентификаторыБухгалтерии.ПометкаУдаления КАК ПометкаУдаления,
	|	ИдентификаторыБухгалтерии.Проведен КАК Проведен,
	|	ИдентификаторыБухгалтерии.Номер КАК Номер,
	|	ИдентификаторыБухгалтерии.Дата КАК Дата,
	|	ЕСТЬNULL(ПубличныеИдентификаторыОрганизации.Ссылка, НЕОПРЕДЕЛЕНО) КАК Организация,
	|	ИдентификаторыБухгалтерии.ВидОперации КАК ВидОперации,
	|	ИдентификаторыБухгалтерии.СуммаДокумента КАК СуммаДокумента,
	|	ИдентификаторыБухгалтерии.ВерсияФорматаДанных КАК ВерсияФорматаДанных,
	|	ИдентификаторыБухгалтерии.ДанныеОбъекта КАК ДанныеОбъекта,
	|	ИдентификаторыБухгалтерии.ВерсияПравилаПроверки КАК ВерсияПравилаПроверки,
	|	ИдентификаторыБухгалтерии.ПроблемыПриПроверке КАК ПроблемыПриПроверке,
	|	ИдентификаторыБухгалтерии.ТипДанных КАК ТипДанных,
	|	ИдентификаторыБухгалтерии.НавигационнаяСсылка КАК НавигационнаяСсылка,
	|	ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения КАК ЕстьОшибкиОтражения,
	|	ИдентификаторыБухгалтерии.Представление КАК Представление
	|ИЗ
	|	РегистрСведений.ПубличныеИдентификаторыБухгалтерии КАК ИдентификаторыБухгалтерии
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторы
	|		ПО (ПубличныеИдентификаторы.Идентификатор = ИдентификаторыБухгалтерии.ПубличныйИдентификатор)
	|			И (ПубличныеИдентификаторы.УзелИнформационнойБазы = &УзелОбмена)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторыОрганизации
	|		ПО (ПубличныеИдентификаторыОрганизации.Идентификатор = ИдентификаторыБухгалтерии.Организация)
	|			И (ПубличныеИдентификаторыОрганизации.УзелИнформационнойБазы = &УзелОбмена)
	|			И (ПубличныеИдентификаторыОрганизации.Ссылка ССЫЛКА Справочник.Организации)
	|ГДЕ
	|	ПубличныеИдентификаторы.Ссылка = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("УзелОбмена", УзелОбмена);
	
	МассивДокументовБухгалтерии = Новый Массив;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		
		ОписаниеОбъекта = Новый Структура("Идентификатор,ИдентификаторМетаданных,Представление,Проведен,ПометкаУдаления,НавигационнаяСсылка,ЕстьОшибкиОтражения");
		ЗаполнитьЗначенияСвойств(ОписаниеОбъекта, Выборка);
		
		Если ПустаяСтрока(Выборка.ПроблемыПриПроверке) Тогда
			ОписаниеОбъекта.Вставить("ПроблемыПриПроверке", Новый Массив);
		Иначе
			ОписаниеОбъекта.Вставить("ПроблемыПриПроверке", ОбщегоНазначения.JSONВЗначение(Выборка.ПроблемыПриПроверке));
		КонецЕсли;  
		
		Если Не ПустаяСтрока(Выборка.ДанныеОбъекта) Тогда
			ДанныеОбъекта = ОбщегоНазначения.JSONВЗначение(Выборка.ДанныеОбъекта, , Ложь);
		Иначе
			ДанныеОбъекта = Новый Структура;
		КонецЕсли;                                                                            
		ДанныеОбъекта.Вставить("Номер", Выборка.Номер);
		ДанныеОбъекта.Вставить("Дата", Выборка.Дата);
		ДанныеОбъекта.Вставить("ВидОперации", Выборка.ВидОперации);
		ДанныеОбъекта.Вставить("СуммаДокумента", Выборка.СуммаДокумента); 
		ДанныеОбъекта.Вставить("Организация", Выборка.Организация); 
		
		ОписаниеОбъекта.Вставить("ДанныеОбъекта", ДанныеОбъекта);
		
		МассивДокументовБухгалтерии.Добавить(ОписаниеОбъекта);
	КонецЦикла;

	Возврат МассивДокументовБухгалтерии;
	
КонецФункции     

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура ПроизвестиОбщуюСверкуЗначенийРеквизитов(Ссылка, СтрокаРеквизитов, СтрокаТабличныхЧастей, ОписаниеОбъекта, РезультатПроверки, ЗначенияНастроек)
	
	МассивРеквизитов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаРеквизитов, ",");     
	
   	ИмяРеквизитаДебитор = "Контрагент";
   	ИмяРеквизитаКредитор = "Контрагент";
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.Взаимозачет") Тогда
		ВидОперацииДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ВидОперации");
		Если ВидОперацииДокумента = Перечисления.ВидыОперацийВзаимозачет.КорректировкаДолгаПоставщику Тогда
			СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "КонтрагентДебитор_GUID", "Контрагент");  
		Иначе
			СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "КонтрагентДебитор_GUID", "КонтрагентИсточник");  
   			ИмяРеквизитаДебитор = "КонтрагентИсточник";
		КонецЕсли;  
		
		Если Не (ВидОперацииДокумента = Перечисления.ВидыОперацийВзаимозачет.КорректировкаДолгаПокупателя 
			ИЛИ ВидОперацииДокумента = Перечисления.ВидыОперацийВзаимозачет.КорректировкаДолгаПоставщику) Тогда
				СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "КонтрагентКредитор_GUID", "Контрагент");  
		Иначе
			СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "КонтрагентКредитор_GUID", "");  
		КонецЕсли;
	Иначе
		СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "Контрагент_GUID", "Контрагент");  
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.АвансовыйОтчет") Тогда
		СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "Склад_GUID", "");
	Иначе
		СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "Склад_GUID", "СтруктурнаяЕдиница");
	КонецЕсли;

	СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "ФизЛицо_GUID", "Сотрудник");
	СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "СкладПолучатель_GUID", "СтруктурнаяЕдиницаПолучатель");
	СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "Контрагент_ОбособленноеПодразделение", "");
	СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "ДеятельностьНаПатенте", "Патент");
	Если ТипЗнч(Ссылка) <> Тип("ДокументСсылка.СчетФактура")  
		И ТипЗнч(Ссылка) <> Тип("ДокументСсылка.СчетФактураПолученный") Тогда  
		СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов, "СуммаНДС", "");        
 	КонецЕсли;
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПлатежноеПоручение")  
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПоступлениеВКассу")  
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПоступлениеНаСчет")  
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.РасходИзКассы") 
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.РасходСоСчета") Тогда
  		СтрокаРеквизитов = СтрокаРеквизитов+",Подотчетник";        
	КонецЕсли;

	СвойстваДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, СтрокаРеквизитов);
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.СчетФактура")  
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.СчетФактураПолученный") Тогда  
		СвойстваДокумента.СуммаДокумента = СвойстваДокумента.СуммаДокумента + СвойстваДокумента.СуммаНДСДокумента;
 	КонецЕсли;

	Для Каждого ИмяРеквизита Из МассивРеквизитов Цикл
		
		Если ИмяРеквизита = "СуммаДокумента"			
			 И СвойстваДокумента.СуммаДокумента <> ОписаниеОбъекта.ДанныеОбъекта.СуммаДокумента Тогда
			ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Общие суммы документа отличаются: рекомендуется проверить суммы Всего и суммы НДС. Сумма в бухгалтерии: %1'"),
				Формат(ОписаниеОбъекта.ДанныеОбъекта.СуммаДокумента, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
			РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
		КонецЕсли;
		Если ИмяРеквизита = "СуммаНДСДокумента" 
			И (ОписаниеОбъекта.ДанныеОбъекта.Свойство("СуммаНДСДокумента") ИЛИ ОписаниеОбъекта.ДанныеОбъекта.Свойство("СуммаНДС")) Тогда
			Если ОписаниеОбъекта.ДанныеОбъекта.Свойство("СуммаНДСДокумента") Тогда  
				ДанныеОбъектаСуммаНДС = ОписаниеОбъекта.ДанныеОбъекта.СуммаНДСДокумента;
			Иначе
				ДанныеОбъектаСуммаНДС = ОписаниеОбъекта.ДанныеОбъекта.СуммаНДС;
			КонецЕсли;
			
			Если СвойстваДокумента.СуммаНДСДокумента <> ДанныеОбъектаСуммаНДС Тогда
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Суммы НДС различаются: рекомендуется проверить примененные ставки НДС. Сумма НДС в бухгалтерии: %1'"),
					Формат(ДанныеОбъектаСуммаНДС, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли;
		Если ИмяРеквизита = "СуммаНДС" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("СуммаНДС") Тогда
			СуммаНДС = 0;
			МассивТабличныхЧастей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаТабличныхЧастей, ",");  
			Для Каждого ИмяТЧ Из МассивТабличныхЧастей Цикл         
				СуммаНДС = СуммаНДС + Ссылка[ИмяТЧ].Итог("СуммаНДС")
			КонецЦикла;
			Если СуммаНДС <> ОписаниеОбъекта.ДанныеОбъекта.СуммаНДС Тогда
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Суммы НДС различаются: рекомендуется проверить примененные ставки НДС. Сумма НДС в бухгалтерии: %1'"),
					Формат(ОписаниеОбъекта.ДанныеОбъекта.СуммаНДС, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли;
		Если ИмяРеквизита = "Дата"
			И НачалоДня(СвойстваДокумента.Дата) <> НачалоДня(ОписаниеОбъекта.ДанныеОбъекта.Дата) Тогда
			ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Дата отражения отличается: возможно, она была изменена вручную. Дата в бухгалтерии: %1'"),
				Формат(ОписаниеОбъекта.ДанныеОбъекта.Дата, "ДЛФ=D"));
			РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
		КонецЕсли;
		Если ИмяРеквизита = "НомерВходящегоДокумента"
			И ЗначениеЗаполнено(СвойстваДокумента.НомерВходящегоДокумента)
			И СвойстваДокумента.НомерВходящегоДокумента <> ОписаниеОбъекта.ДанныеОбъекта.НомерВходящегоДокумента Тогда
			ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не совпадают входящие номера документов. Входящий номер в бухгалтерии: %1'"),
				ОписаниеОбъекта.ДанныеОбъекта.НомерВходящегоДокумента);
			РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
		КонецЕсли;
		Если ИмяРеквизита = "ДатаВходящегоДокумента"
			И ЗначениеЗаполнено(СвойстваДокумента.ДатаВходящегоДокумента) Тогда
				Если ТипЗнч(ОписаниеОбъекта.ДанныеОбъекта.ДатаВходящегоДокумента) = Тип("Строка") Тогда
					ДанныеОбъектаДатаВходящегоДокумента = ПрочитатьДатуJSON(ОписаниеОбъекта.ДанныеОбъекта.ДатаВходящегоДокумента, ФорматДатыJSON.ISO);
				Иначе
					ДанныеОбъектаДатаВходящегоДокумента = ОписаниеОбъекта.ДанныеОбъекта.ДатаВходящегоДокумента;
				КонецЕсли;
				Если СвойстваДокумента.ДатаВходящегоДокумента <> ДанныеОбъектаДатаВходящегоДокумента Тогда
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Входящая дата отличается: возможно, она изменена вручную. Входящая дата в бухгалтерии: %1'"),
					Формат(ДанныеОбъектаДатаВходящегоДокумента, "ДЛФ=D"));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли;
		Если ИмяРеквизита = "Организация" И ЗначениеЗаполнено(ОписаниеОбъекта.ДанныеОбъекта.Организация) Тогда
			ОрганизацияПоИдентификатору = ОписаниеОбъекта.ДанныеОбъекта.Организация;  
			Если СвойстваДокумента.Организация <> ОрганизацияПоИдентификатору И Не ОрганизацияПоИдентификатору.Пустая() Тогда  
				Если ОрганизацияПоИдентификатору.ПолучитьОбъект() <> Неопределено Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Различаются организации в документах. Организация в бухгалтерии: %1'"),
						ОрганизацияПоИдентификатору.Наименование);
				Иначе
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Различаются организации в документах. В бухгалтерии установлена неизвестная организация'"),);
				КонецЕсли;
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли;  
		
		Если ИмяРеквизита = "Контрагент_GUID" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("Контрагент_GUID") 
			И ЗначениеЗаполнено(ОписаниеОбъекта.ДанныеОбъекта.Контрагент_GUID) Тогда
			Если СвойстваДокумента.Свойство("Подотчетник") И ЗначениеЗаполнено(СвойстваДокумента.Подотчетник) Тогда
				КонтрагентПоИдентификатору = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.Контрагент_GUID));  
				КонтрагентДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СвойстваДокумента.Подотчетник, "ФизическоеЛицо");
			Иначе
				КонтрагентПоИдентификатору = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.Контрагент_GUID));  
				КонтрагентДокумента = СвойстваДокумента.Контрагент;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(КонтрагентДокумента) 
				И КонтрагентДокумента <> КонтрагентПоИдентификатору И Не КонтрагентПоИдентификатору.Пустая() Тогда	  
				Если ОбщегоНазначения.СсылкаСуществует(КонтрагентПоИдентификатору) Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Различаются контрагенты в документе. Контрагент в бухгалтерии: %1'"),
						КонтрагентПоИдентификатору);
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Если ИмяРеквизита = "КонтрагентДебитор_GUID" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("КонтрагентДебитор_GUID") 
			И ЗначениеЗаполнено(ОписаниеОбъекта.ДанныеОбъекта.КонтрагентДебитор_GUID) Тогда
			КонтрагентПоИдентификатору = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.КонтрагентДебитор_GUID));  
			Если СвойстваДокумента.Свойство("ИмяРеквизитаДебитор") И СвойстваДокумента[ИмяРеквизитаДебитор] <> КонтрагентПоИдентификатору И Не КонтрагентПоИдентификатору.Пустая() Тогда  
				Если ОбщегоНазначения.СсылкаСуществует(КонтрагентПоИдентификатору) Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Контрагенты-дебиторы в документе отличаются. Дебитор в бухгалтерии: %1'"),
						КонтрагентПоИдентификатору);
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;     
		Если ИмяРеквизита = "КонтрагентКредитор_GUID" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("КонтрагентКредитор_GUID") 
			И ЗначениеЗаполнено(ОписаниеОбъекта.ДанныеОбъекта.КонтрагентКредитор_GUID) Тогда
			КонтрагентПоИдентификатору = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.КонтрагентКредитор_GUID));  
			Если СвойстваДокумента.Свойство("ИмяРеквизитаКредитор") И СвойстваДокумента[ИмяРеквизитаКредитор] <> КонтрагентПоИдентификатору И Не КонтрагентПоИдентификатору.Пустая() Тогда  
				Если ОбщегоНазначения.СсылкаСуществует(КонтрагентПоИдентификатору) Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Контрагенты-кредиторы в документе отличаются. Кредитор в бухгалтерии: %1'"),
						КонтрагентПоИдентификатору);
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;     
		
		Если ИмяРеквизита = "ДеятельностьНаПатенте" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("ДеятельностьНаПатенте") Тогда
			ПатентЗаполнен = ЗначениеЗаполнено(СвойстваДокумента.Патент);
			Если ПатентЗаполнен <> ОписаниеОбъекта.ДанныеОбъекта.ДеятельностьНаПатенте Тогда
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Не совпадают признаки деятельности на патенте. Использование патента в бухгалтерии: %1'"),
					Формат(ОписаниеОбъекта.ДанныеОбъекта.ДеятельностьНаПатенте, "БЛ=отключено; БИ=включено"));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли;

		Если ИмяРеквизита = "ФизЛицо_GUID" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("ФизЛицо_GUID") 
			И ЗначениеЗаполнено(ОписаниеОбъекта.ДанныеОбъекта.ФизЛицо_GUID) Тогда
			ФизЛицоПоИдентификатору = Справочники.ФизическиеЛица.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.ФизЛицо_GUID));  
			Если СвойстваДокумента.Сотрудник.Физлицо <> ФизЛицоПоИдентификатору И Не ФизЛицоПоИдентификатору.Пустая() Тогда
				Если ОбщегоНазначения.СсылкаСуществует(ФизЛицоПоИдентификатору) Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Различаются сотрудники в документе. Сотрудник в бухгалтерии: %1'"),
						ФизЛицоПоИдентификатору);
				Иначе
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Различаются сотрудники в документе. В бухгалтерии установлен неизвестный сотрудник'"),);
				КонецЕсли;
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли;     
		
		Если ИмяРеквизита = "Склад_GUID" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("Склад_GUID") 
			И ЗначениеЗаполнено(ОписаниеОбъекта.ДанныеОбъекта.Склад_GUID) Тогда     
			
			Если ЗначенияНастроек.РазрешитьСкладыВТабличныхЧастях Тогда
				РазрешатьОбобщенныйСклад = Истина;
			ИначеЕсли ЗначенияНастроек.ВыгружатьНаОбобщенныйСклад Тогда
				РазрешатьОбобщенныйСклад = Истина;     
			Иначе
				РазрешатьОбобщенныйСклад = Ложь;
			КонецЕсли;
				
			Если НЕ РазрешатьОбобщенныйСклад Тогда
				СкладПоИдентификатору = Справочники.СтруктурныеЕдиницы.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.Склад_GUID));  
				Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.АвансовыйОтчет") Тогда    
					Если Не СкладПоИдентификатору.Пустая() Тогда   
						СкладыОтличаются = Ложь;                           
						Для Каждого СтрокаЗапасы Из Ссылка.Запасы Цикл
							Если СтрокаЗапасы.СтруктурнаяЕдиница <> СкладПоИдентификатору Тогда     
								СкладыОтличаются = Истина;
							КонецЕсли;
						КонецЦикла;
						Если СкладыОтличаются Тогда
							Если ОбщегоНазначения.СсылкаСуществует(СкладПоИдентификатору) Тогда 
								ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
									НСтр("ru = 'Различаются склады в документе. Склад в бухгалтерии: %1'"),
									СкладПоИдентификатору);
							Иначе
								ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
									НСтр("ru = 'Различаются склады в документе. В бухгалтерии установлен неизвестный склад'"),);
							КонецЕсли;
							РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
						КонецЕсли;
					КонецЕсли;
				ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеЗапасов")
				 	И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ВидОперации") = Перечисления.ВидыОперацийПеремещениеЗапасов.ВозвратИзЭксплуатации Тогда   
					Если СвойстваДокумента.СтруктурнаяЕдиницаПолучатель <> СкладПоИдентификатору И Не СкладПоИдентификатору.Пустая() Тогда  
						Если ОбщегоНазначения.СсылкаСуществует(СкладПоИдентификатору) Тогда 
							ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
								НСтр("ru = 'Различаются склады в документе. Склад в бухгалтерии: %1'"),
								СкладПоИдентификатору);
						Иначе
							ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
								НСтр("ru = 'Различаются склады в документе. В бухгалтерии установлен неизвестный склад'"),);
						КонецЕсли;
						РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
					КонецЕсли;
				Иначе
					Если СвойстваДокумента.СтруктурнаяЕдиница <> СкладПоИдентификатору И Не СкладПоИдентификатору.Пустая() Тогда  
						Если ОбщегоНазначения.СсылкаСуществует(СкладПоИдентификатору) Тогда 
							ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
								НСтр("ru = 'Различаются склады в документе. Склад в бухгалтерии: %1'"),
								СкладПоИдентификатору);
						Иначе
							ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
								НСтр("ru = 'Различаются склады в документе. В бухгалтерии установлен неизвестный склад'"),);
						КонецЕсли;
						РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Если ИмяРеквизита = "СкладПолучатель_GUID" И ОписаниеОбъекта.ДанныеОбъекта.Свойство("СкладПолучатель_GUID") 
			И ЗначениеЗаполнено(ОписаниеОбъекта.ДанныеОбъекта.СкладПолучатель_GUID) Тогда
			
			Если ЗначенияНастроек.РазрешитьСкладыВТабличныхЧастях Тогда
				РазрешатьОбобщенныйСклад = Истина;
			ИначеЕсли ЗначенияНастроек.ВыгружатьНаОбобщенныйСклад Тогда
				РазрешатьОбобщенныйСклад = Истина;     
			Иначе
				РазрешатьОбобщенныйСклад = Ложь;
			КонецЕсли;
				
			Если НЕ РазрешатьОбобщенныйСклад Тогда
				СкладПоИдентификатору = Справочники.СтруктурныеЕдиницы.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.СкладПолучатель_GUID));  
				Если СвойстваДокумента.СтруктурнаяЕдиницаПолучатель <> СкладПоИдентификатору И Не СкладПоИдентификатору.Пустая() Тогда  
					Если ОбщегоНазначения.СсылкаСуществует(СкладПоИдентификатору) Тогда 
						ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
							НСтр("ru = 'Склады-получатели в документе отличаются. Склад в бухгалтерии: %1'"),
							СкладПоИдентификатору);
					Иначе
						ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
							НСтр("ru = 'Склады-получатели в документе отличаются. В бухгалтерии установлен неизвестный склад'"),);
					КонецЕсли;
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;  
		
	КонецЦикла;
	
	РезультатПроверки.ЕстьОшибкиОтражения = (РезультатПроверки.ПроблемыПриПроверке.Количество() > 0);       

КонецПроцедуры	

Процедура ПроизвестиМножественнуюСверкуЗначенийРеквизитов(Ссылка, СтрокаРеквизитов,  МассивОписаний, РезультатПроверки)
	
	Если СтрНайти(СтрокаРеквизитов, "ИТОГИ") > 0 Тогда     
		СравниватьИтоги = Истина;  
		СтрокаРеквизитов = СтрЗаменить(СтрокаРеквизитов,"ИТОГИ","");
	Иначе
		СравниватьИтоги = Ложь;
	КонецЕсли;
	МассивРеквизитов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаРеквизитов, ",");     
	СвойстваДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, СтрокаРеквизитов);
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.СчетФактура")  
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.СчетФактураПолученный") Тогда  
		СвойстваДокумента.СуммаДокумента = СвойстваДокумента.СуммаДокумента + СвойстваДокумента.СуммаНДСДокумента;
 	КонецЕсли;

	Для Каждого ИмяРеквизита Из МассивРеквизитов Цикл
		
		Если ИмяРеквизита = "Дата" Тогда
			ЗначенияСовпадают = Истина;       
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				ЗначениеВБухгалтерии = ОписаниеОбъекта.ДанныеОбъекта.Дата;  

				МассивЗначений.Добавить(Формат(ЗначениеВБухгалтерии, "ДЛФ=D"));
				Если НачалоДня(СвойстваДокумента.Дата) <> НачалоДня(ЗначениеВБухгалтерии) Тогда 
					ЗначенияСовпадают = Ложь; 
				КонецЕсли;
			КонецЦикла; 
			Если Не ЗначенияСовпадают Тогда               
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Даты отражения документов отличаются: Даты в бухгалтерии: %1'"),
					МассивВСтрокуСРазделителями(МассивЗначений, "; "));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли;   
		
		Если ИмяРеквизита = "СуммаДокумента" Тогда  
			ЗначенияСовпадают = Истина;       
			Итоги = 0;
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				Если СтрНайти(ОписаниеОбъекта.Представление, "Списание товаров") > 0 Тогда
					Продолжить;
				ИначеЕсли СтрНайти(ОписаниеОбъекта.Представление, "Расход материалов") > 0 Тогда
					Продолжить;
				КонецЕсли;
				ЗначениеВБухгалтерии = ОписаниеОбъекта.ДанныеОбъекта.СуммаДокумента;          
				Итоги = Итоги + ЗначениеВБухгалтерии;
				МассивЗначений.Добавить(Формат(ЗначениеВБухгалтерии, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
				Если СвойстваДокумента.СуммаДокумента <> ЗначениеВБухгалтерии Тогда 
					ЗначенияСовпадают = Ложь; 
				КонецЕсли;
			КонецЦикла; 
			Если СравниватьИтоги Тогда
				Если СвойстваДокумента.СуммаДокумента <> Итоги Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Объединенная сумма документов отличается: Общая сумма в бухгалтерии: %1'"),
						Формат(Итоги, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			Иначе
				Если Не ЗначенияСовпадают Тогда               
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Суммы документов отличаются: Суммы в бухгалтерии: %1'"),
						МассивВСтрокуСРазделителями(МассивЗначений, "; "));
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;  
		
		Если ИмяРеквизита = "СтруктурнаяЕдиница" Тогда  
			ЗначенияСовпадают = Истина;       
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				ЗначениеВБухгалтерии = Справочники.СтруктурныеЕдиницы.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.Склад_GUID));  

				МассивЗначений.Добавить(ЗначениеВБухгалтерии);
				Если СвойстваДокумента.СтруктурнаяЕдиница <> ЗначениеВБухгалтерии Тогда 
					ЗначенияСовпадают = Ложь; 
				КонецЕсли;
			КонецЦикла; 
			Если Не ЗначенияСовпадают Тогда               
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Склады документов отличаются: Склады в бухгалтерии: %1'"),
					МассивВСтрокуСРазделителями(МассивЗначений, "; "));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли; 
		
		Если ИмяРеквизита = "Организация" Тогда  
			ЗначенияСовпадают = Истина;       
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				ЗначениеВБухгалтерии = ОписаниеОбъекта.ДанныеОбъекта.Организация;  

				МассивЗначений.Добавить(ЗначениеВБухгалтерии);
				Если СвойстваДокумента.Организация <> ЗначениеВБухгалтерии Тогда 
					ЗначенияСовпадают = Ложь; 
				КонецЕсли;
			КонецЦикла; 
			Если Не ЗначенияСовпадают Тогда               
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Различаются организации в документах: Организации в бухгалтерии: %1'"),
					МассивВСтрокуСРазделителями(МассивЗначений, "; "));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли; 
		
		Если ИмяРеквизита = "Контрагент" Тогда  
			ЗначенияСовпадают = Истина;       
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				ЗначениеВБухгалтерии = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.Контрагент_GUID));  

				МассивЗначений.Добавить(ЗначениеВБухгалтерии);
				Если СвойстваДокумента.Контрагент <> ЗначениеВБухгалтерии Тогда 
					ЗначенияСовпадают = Ложь; 
				КонецЕсли;
			КонецЦикла; 
			Если Не ЗначенияСовпадают Тогда               
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Различаются контрагенты в документах: Контрагенты в бухгалтерии: %1'"),
					МассивВСтрокуСРазделителями(МассивЗначений, "; "));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;
		КонецЕсли; 

		Если ИмяРеквизита = "КонтрагентВладелец" Тогда  
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				ЭтоПоступление = СтрНайти(ОписаниеОбъекта.Представление, "Поступление") > 0;
				ЗначениеВБухгалтерии = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.Контрагент_GUID));  
				Если ЭтоПоступление И СвойстваДокумента.КонтрагентВладелец <> ЗначениеВБухгалтерии Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Некорректный контрагент-владелец товаров: Контрагент в бухгалтерии: %1'"),
						ЗначениеВБухгалтерии);
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			КонецЦикла; 
		КонецЕсли; 
		
		Если ИмяРеквизита = "КонтрагентПолучатель" Тогда  
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				ЭтоРеализация = СтрНайти(ОписаниеОбъекта.Представление, "Реализация") > 0;
				ЗначениеВБухгалтерии = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ОписаниеОбъекта.ДанныеОбъекта.Контрагент_GUID));  
				Если ЭтоРеализация И СвойстваДокумента.КонтрагентПолучатель <> ЗначениеВБухгалтерии Тогда 
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Некорректный контрагент-получатель товаров: Контрагент в бухгалтерии: %1'"),
						ЗначениеВБухгалтерии);
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
				КонецЕсли;
			КонецЦикла; 
		КонецЕсли; 
		
	КонецЦикла; 
	
	РезультатПроверки.ЕстьОшибкиОтражения = (РезультатПроверки.ПроблемыПриПроверке.Количество() > 0);       
	РезультатПроверки.Множественный = Истина;  
	СвязанныеИдентификаторы = Новый Массив;
	Для Каждого Описание Из МассивОписаний Цикл
		СтруктураИдентификатора = Новый Структура("Идентификатор, ИдентификаторМетаданных");
		ЗаполнитьЗначенияСвойств(СтруктураИдентификатора,Описание); 
		СвязанныеИдентификаторы.Добавить(СтруктураИдентификатора);
	КонецЦикла;

	РезультатПроверки.СвязанныеИдентификаторы = СвязанныеИдентификаторы;
	
КонецПроцедуры	

Процедура ПроизвестиСпециальнуюСверкуЗначенийРеквизитов(Ссылка, СтрокаРеквизитов, СтрокаТабличныхЧастей, ОписаниеОбъекта, РезультатПроверки, ЗначенияНастроек)
 	
	СвойстваДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, СтрокаРеквизитов);
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОтчетКомиссионера") 
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОтчетКомитенту") Тогда
		СуммаНДС = 0;
		МассивТабличныхЧастей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СтрокаТабличныхЧастей, ",");  
		Для Каждого ИмяТЧ Из МассивТабличныхЧастей Цикл         
			СуммаНДС = СуммаНДС + Ссылка[ИмяТЧ].Итог("СуммаНДС")
		КонецЦикла;

		Если СвойстваДокумента.СуммаДокумента + СвойстваДокумента.СуммаВознаграждения  <> ОписаниеОбъекта.ДанныеОбъекта.СуммаДокумента +  ОписаниеОбъекта.ДанныеОбъекта.СуммаВознаграждения
			ИЛИ СуммаНДС <> ОписаниеОбъекта.ДанныеОбъекта.СуммаНДС Тогда     
			
			Если СвойстваДокумента.СуммаВознаграждения <> ОписаниеОбъекта.ДанныеОбъекта.СуммаВознаграждения Тогда
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Отличаются суммы комиссионного вознаграждения. Сумма в бухгалтерии: %1'"),
					Формат(ОписаниеОбъекта.ДанныеОбъекта.СуммаВознаграждения, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);  
				
				Если СвойстваДокумента.СпособРасчетаКомиссионногоВознаграждения <> ОписаниеОбъекта.ДанныеОбъекта.СпособРасчетаКомиссионногоВознаграждения Тогда  
					СпособРасчетаПредставление = Перечисления.СпособыРасчетаКомиссионногоВознаграждения[ОписаниеОбъекта.ДанныеОбъекта.СпособРасчетаКомиссионногоВознаграждения];
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Отличаются способы расчета комиссионного вознаграждения. Способ в бухгалтерии: %1'"),
						СпособРасчетаПредставление);
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);    
					
					РасчетПроцентом =  (СвойстваДокумента.СпособРасчетаКомиссионногоВознаграждения = Перечисления.СпособыРасчетаКомиссионногоВознаграждения.ПроцентОтСуммыПродажи
							ИЛИ  СвойстваДокумента.СпособРасчетаКомиссионногоВознаграждения = Перечисления.СпособыРасчетаКомиссионногоВознаграждения.ПроцентОтРазностиСуммПродажиИПоступления);
					Если РасчетПроцентом 
						И СвойстваДокумента.ПроцентКомиссионногоВознаграждения <> ОписаниеОбъекта.ДанныеОбъекта.ПроцентКомиссионногоВознаграждения Тогда
						ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
							НСтр("ru = 'Отличаются проценты комиссионного вознаграждения. Процент в бухгалтерии: %1%'"),
							Формат(ОписаниеОбъекта.ДанныеОбъекта.ПроцентКомиссионногоВознаграждения, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
						РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
					КонецЕсли;
					
				КонецЕсли;  
				СтавкаПредставление = СтавкаНДСПоСтроке(ОписаниеОбъекта.ДанныеОбъекта.СтавкаНДСВознаграждения);
				Если СвойстваДокумента.СтавкаНДСВознаграждения <> СтавкаПредставление Тогда
					ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = 'Отличаются ставки НДС комиссионного вознаграждения. Ставка в бухгалтерии: %1'"),
						СтавкаПредставление);
					РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);    
				КонецЕсли;
				
				
			КонецЕсли;
			
		КонецЕсли;  
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.СчетНаОплату") Тогда    
		Если ОписаниеОбъекта.ДанныеОбъекта = Неопределено Тогда
			Если ЗначенияНастроек.ПереноситьЗаказыКакСчетаНаОплату Тогда
				ОписаниеПроблемы = НСтр("ru = 'В синхронизации установлен флаг ""Переносить заказы покупателей как счета на оплату"". Он запрещает выгружать счета на оплату.'");
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);    
			КонецЕсли;       
		КонецЕсли;       

	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		ВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ВидОперации");
		Если ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу Тогда
			Если ОписаниеОбъекта.ДанныеОбъекта = Неопределено
				И ЗначенияНастроек.ПереноситьЗаказыКакСчетаНаОплату Тогда
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'В синхронизации установлен флаг ""Переносить заказы покупателей как счета на оплату"". Он запрещает выгружать заказы покупателя.'"),
					СтавкаПредставление);
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);    
			КонецЕсли;
		ИначеЕсли РаботаСЗаявкамиКлиентСервер.ЭтоЗаявка(ВидОперации) Тогда
			ОписаниеПроблемы = НСтр("ru = 'Выгрузка заявок запрещена'");
			РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
		КонецЕсли;       

	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда    
		Если ОписаниеОбъекта.ДанныеОбъекта = Неопределено Тогда
			Если ЗначенияНастроек.НеВыгружатьПеремещенияЗапасов Тогда
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'В синхронизации установлен флаг ""Исключить перемещения из обмена"". Он запрещает выгружать перемещения.'"),
					СтавкаПредставление);
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);    
			КонецЕсли;       
		КонецЕсли;    
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда    
		
		МассивОписаний = ЗначенияНастроек.ДополнительныеСведения;
		Если ТипЗнч(МассивОписаний) = Тип("Массив") Тогда
			ЗначенияСовпадают = Истина;       
			Итоги = 0;
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				ЗначениеВБухгалтерии = ОписаниеОбъекта.ДанныеОбъекта.СуммаДокумента;          
				Итоги = Итоги + ЗначениеВБухгалтерии;
				МассивЗначений.Добавить(Формат(ЗначениеВБухгалтерии, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
				Если СвойстваДокумента.СуммаДокумента <> ЗначениеВБухгалтерии Тогда 
					ЗначенияСовпадают = Ложь; 
				КонецЕсли;
			КонецЦикла; 
			Если СвойстваДокумента.СуммаДокумента <> Итоги Тогда 
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Объединенная сумма документов отличается: Общая сумма в бухгалтерии: %1'"),
					Формат(Итоги, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;  
			
			РезультатПроверки.Множественный = Истина;  
			СвязанныеИдентификаторы = Новый Массив;
			Для Каждого Описание Из МассивОписаний Цикл
				СтруктураИдентификатора = Новый Структура("Идентификатор, ИдентификаторМетаданных");
				ЗаполнитьЗначенияСвойств(СтруктураИдентификатора,Описание); 
				СвязанныеИдентификаторы.Добавить(СтруктураИдентификатора);
			КонецЦикла;

			РезультатПроверки.СвязанныеИдентификаторы = СвязанныеИдентификаторы;  
			
		КонецЕсли;

	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда    
		
		МассивОписаний = ЗначенияНастроек.ДополнительныеСведения;
		Если ТипЗнч(МассивОписаний) = Тип("Массив") Тогда
			ЗначенияСовпадают = Истина;       
			Итоги = 0;
			МассивЗначений = Новый Массив;   
			Для Каждого ОписаниеОбъекта Из МассивОписаний Цикл    
				Если ТипЗнч(ОписаниеОбъекта.Ссылка) = Тип ("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда  
					ЗаменяющаяСсылка = Новый Структура("Идентификатор, ИдентификаторМетаданных, ПубличныйИдентификатор, Проведен, ПометкаУдаления, НавигационнаяСсылка, Представление");    
					ЗаполнитьЗначенияСвойств(ЗаменяющаяСсылка, ОписаниеОбъекта);
					РезультатПроверки.ЗаменяющаяСсылка = ЗаменяющаяСсылка;     
				ИначеЕсли ТипЗнч(РезультатПроверки.ЗаменяющаяСсылка) = Тип("Структура") Тогда   
					ЗаполнитьЗначенияСвойств(РезультатПроверки.ЗаменяющаяСсылка, ОписаниеОбъекта, "Проведен, ПометкаУдаления, НавигационнаяСсылка, Представление"); 
				КонецЕсли;
				ЗначениеВБухгалтерии = ОписаниеОбъекта.ДанныеОбъекта.СуммаДокумента;  
				Если ЗначениеЗаполнено(ЗначениеВБухгалтерии) Тогда
					Итоги = Итоги + ЗначениеВБухгалтерии;
					МассивЗначений.Добавить(Формат(ЗначениеВБухгалтерии, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
					Если СвойстваДокумента.СуммаДокумента <> ЗначениеВБухгалтерии Тогда 
						ЗначенияСовпадают = Ложь; 
					КонецЕсли;
				КонецЕсли;
			КонецЦикла; 
			Если СвойстваДокумента.СуммаДокумента <> Итоги Тогда 
				ОписаниеПроблемы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Объединенная сумма документов отличается: Общая сумма в бухгалтерии: %1'"),
					Формат(Итоги, "ЧДЦ=2; ЧН=; ЧГ=3,0"));
				РезультатПроверки.ПроблемыПриПроверке.Добавить(ОписаниеПроблемы);
			КонецЕсли;  
		КонецЕсли;
		
	КонецЕсли;
	
	РезультатПроверки.ЕстьОшибкиОтражения = (РезультатПроверки.ПроблемыПриПроверке.Количество() > 0);     

КонецПроцедуры	

Процедура ДобавитьСоответствиеВидаДокументаИРазделаУчета(Приемник, РазделУчета, ОбъектМетаданных, ИмяОбъектаМетаданных = "", Представление = "")
	
	Если Не ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = Приемник.Добавить();
	НоваяСтрока.РазделУчета = РазделУчета;
	Если ПустаяСтрока(ИмяОбъектаМетаданных) Тогда
		НоваяСтрока.ИмяОбъектаМетаданных = ОбъектМетаданных.Имя;
	Иначе
		НоваяСтрока.ИмяОбъектаМетаданных = ИмяОбъектаМетаданных;
	КонецЕсли;
	НоваяСтрока.ПолноеИмяМетаданных = ОбъектМетаданных.ПолноеИмя();
	НоваяСтрока.РазрешеноПроведение = ОбъектМетаданных.Проведение = Метаданные.СвойстваОбъектов.Проведение.Разрешить;
	
	НоваяСтрока.Представление = Представление;
	Если ПустаяСтрока(НоваяСтрока.Представление) Тогда
		НоваяСтрока.Представление = ОбъектМетаданных.ПредставлениеСписка;
		Если ПустаяСтрока(НоваяСтрока.Представление) Тогда
			НоваяСтрока.Представление = ОбъектМетаданных.Синоним;
		КонецЕсли;
	КонецЕсли;
	НоваяСтрока.ЕстьОрганизация = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ОбъектМетаданных.Реквизиты, "Организация");
	
КонецПроцедуры

Функция МассивВСтрокуСРазделителями(ИсходныйМассив, Разделитель = ",")
	
	СтрокаСРазделителями = "";
	Для Каждого ЭлементМассива Из ИсходныйМассив Цикл
		СтрокаСРазделителями = СтрокаСРазделителями + ?(ПустаяСтрока(СтрокаСРазделителями), "", Разделитель) + ЭлементМассива;
	КонецЦикла;
	
	Возврат СокрЛП(СтрокаСРазделителями);
	
КонецФункции  

Функция СтавкаНДСПоСтроке(СтавкаСтрокой)
	Если СтавкаСтрокой = "НДС18" Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Ставка = 18
		|	И НЕ СтавкиНДС.НеОблагается
		|	И НЕ СтавкиНДС.Расчетная";
	ИначеЕсли СтавкаСтрокой = "НДС18_118" Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Ставка = 18
		|	И НЕ СтавкиНДС.НеОблагается
		|	И СтавкиНДС.Расчетная";
	ИначеЕсли СтавкаСтрокой = "НДС10" Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Ставка = 10
		|	И НЕ СтавкиНДС.НеОблагается
		|	И НЕ СтавкиНДС.Расчетная";
	ИначеЕсли СтавкаСтрокой = "НДС10_110" Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Ставка = 10
		|	И НЕ СтавкиНДС.НеОблагается
		|	И СтавкиНДС.Расчетная";
	ИначеЕсли СтавкаСтрокой = "НДС0" Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Ставка = 0
		|	И НЕ СтавкиНДС.НеОблагается";
	ИначеЕсли СтавкаСтрокой = "НДС20" Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Ставка = 20
		|	И НЕ СтавкиНДС.НеОблагается
		|	И НЕ СтавкиНДС.Расчетная";
	ИначеЕсли СтавкаСтрокой = "НДС20_120" Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Ставка = 20
		|	И НЕ СтавкиНДС.НеОблагается
		|	И СтавкиНДС.Расчетная";	
	Иначе
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК СтавкаНДС
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.НеОблагается";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СтавкаНДС;
	Иначе
		Возврат Справочники.СтавкиНДС.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция МассивДокументовБухгалтерииПредоплаты(Ссылка, УзелОбмена)

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ЧекККМПредоплата.Ссылка КАК Ссылка,
	|	ПубличныеИдентификаторыСинхронизируемыхОбъектов.Идентификатор КАК ПубличныйИдентификатор,
	|	ИдентификаторыБухгалтерии.Идентификатор КАК Идентификатор,
	|	ИдентификаторыБухгалтерии.ИдентификаторМетаданных КАК ИдентификаторМетаданных,
	|	ИдентификаторыБухгалтерии.ПометкаУдаления КАК ПометкаУдаления,
	|	ИдентификаторыБухгалтерии.Проведен КАК Проведен,
	|	ИдентификаторыБухгалтерии.Номер КАК Номер,
	|	ИдентификаторыБухгалтерии.Дата КАК Дата,
	|	ЕСТЬNULL(ПубличныеИдентификаторыОрганизации.Ссылка, НЕОПРЕДЕЛЕНО) КАК Организация,
	|	ИдентификаторыБухгалтерии.ВидОперации КАК ВидОперации,
	|	ИдентификаторыБухгалтерии.СуммаДокумента КАК СуммаДокумента,
	|	ИдентификаторыБухгалтерии.ВерсияФорматаДанных КАК ВерсияФорматаДанных,
	|	ИдентификаторыБухгалтерии.ДанныеОбъекта КАК ДанныеОбъекта,
	|	ИдентификаторыБухгалтерии.ВерсияПравилаПроверки КАК ВерсияПравилаПроверки,
	|	ИдентификаторыБухгалтерии.ПроблемыПриПроверке КАК ПроблемыПриПроверке,
	|	ИдентификаторыБухгалтерии.ТипДанных КАК ТипДанных,
	|	ИдентификаторыБухгалтерии.НавигационнаяСсылка КАК НавигационнаяСсылка,
	|	ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения КАК ЕстьОшибкиОтражения,
	|	ИдентификаторыБухгалтерии.Представление КАК Представление
	|ИЗ
	|	РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторыСинхронизируемыхОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Предоплата КАК ЧекККМПредоплата
	|		ПО (ЧекККМПредоплата.Ссылка = ПубличныеИдентификаторыСинхронизируемыхОбъектов.Ссылка)
	|			И (ПубличныеИдентификаторыСинхронизируемыхОбъектов.УзелИнформационнойБазы = &УзелОбмена)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыБухгалтерии КАК ИдентификаторыБухгалтерии
	|		ПО (ИдентификаторыБухгалтерии.ПубличныйИдентификатор = ПубличныеИдентификаторыСинхронизируемыхОбъектов.Идентификатор)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторыОрганизации
	|		ПО (ПубличныеИдентификаторыОрганизации.Идентификатор = ИдентификаторыБухгалтерии.Организация)
	|			И (ПубличныеИдентификаторыОрганизации.УзелИнформационнойБазы = &УзелОбмена)
	|			И (ПубличныеИдентификаторыОрганизации.Ссылка ССЫЛКА Справочник.Организации)
	|ГДЕ
	|	ЧекККМПредоплата.Ссылка.Проведен
	|	И ЧекККМПредоплата.Ссылка.КассоваяСмена = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Ссылка,
	|	ПубличныеИдентификаторыСинхронизируемыхОбъектов.Идентификатор,
	|	ИдентификаторыБухгалтерии.Идентификатор,
	|	ИдентификаторыБухгалтерии.ИдентификаторМетаданных,
	|	ИдентификаторыБухгалтерии.ПометкаУдаления,
	|	ИдентификаторыБухгалтерии.Проведен,
	|	ИдентификаторыБухгалтерии.Номер,
	|	ИдентификаторыБухгалтерии.Дата,
	|	ЕСТЬNULL(ПубличныеИдентификаторыОрганизации.Ссылка, НЕОПРЕДЕЛЕНО),
	|	ИдентификаторыБухгалтерии.ВидОперации,
	|	ИдентификаторыБухгалтерии.СуммаДокумента,
	|	ИдентификаторыБухгалтерии.ВерсияФорматаДанных,
	|	ИдентификаторыБухгалтерии.ДанныеОбъекта,
	|	ИдентификаторыБухгалтерии.ВерсияПравилаПроверки,
	|	ИдентификаторыБухгалтерии.ПроблемыПриПроверке,
	|	ИдентификаторыБухгалтерии.ТипДанных,
	|	ИдентификаторыБухгалтерии.НавигационнаяСсылка,
	|	ИдентификаторыБухгалтерии.ЕстьОшибкиОтражения,
	|	ИдентификаторыБухгалтерии.Представление
	|ИЗ
	|	РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторыСинхронизируемыхОбъектов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыБухгалтерии КАК ИдентификаторыБухгалтерии
	|		ПО (ИдентификаторыБухгалтерии.ПубличныйИдентификатор = ПубличныеИдентификаторыСинхронизируемыхОбъектов.Идентификатор)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПубличныеИдентификаторыСинхронизируемыхОбъектов КАК ПубличныеИдентификаторыОрганизации
	|		ПО (ПубличныеИдентификаторыОрганизации.Идентификатор = ИдентификаторыБухгалтерии.Организация)
	|			И (ПубличныеИдентификаторыОрганизации.УзелИнформационнойБазы = &УзелОбмена)
	|			И (ПубличныеИдентификаторыОрганизации.Ссылка ССЫЛКА Справочник.Организации)
