		СтрокаРеквизитов = "Дата,Организация,Склад_GUID";
		СтрокаТабличныхЧастей = "";
		
	// Производство
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОтчетОПереработке") Тогда
