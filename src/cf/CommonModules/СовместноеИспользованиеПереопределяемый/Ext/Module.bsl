		Если ВидОперацииДокумента = Перечисления.ВидыОперацийПриходнаяНакладная.ВыкупленныеКомиссионеромТовары Тогда         
			СтрокаРеквизитовМножественнойПроверки = "Дата,СуммаДокумента,СтруктурнаяЕдиница,Организация,Контрагент";  
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.СчетФактураПолученный") Тогда
		СтрокаРеквизитов = "СуммаДокумента,СуммаНДСДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение,НомерВходящегоДокумента,ДатаВходящегоДокумента";
		СтрокаТабличныхЧастей = "";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.КорректировкаПоступления") Тогда
		СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Склад_GUID,Контрагент_ОбособленноеПодразделение,НомерВходящегоДокумента,ДатаВходящегоДокумента,СуммаНДС";
		СтрокаТабличныхЧастей = "Запасы,Расходы";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
		СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение,НомерВходящегоДокумента,ДатаВходящегоДокумента,СуммаНДС";
		СтрокаТабличныхЧастей = "Запасы,Расходы";
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОтчетКомитенту") Тогда
		СтрокаРеквизитов = "СуммаДокумента,Дата,Организация,Контрагент_GUID,Контрагент_ОбособленноеПодразделение,СуммаНДС";
