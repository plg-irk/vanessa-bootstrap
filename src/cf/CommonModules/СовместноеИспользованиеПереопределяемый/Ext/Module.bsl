	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.СборкаЗапасов") Тогда
		СтрокаРеквизитов = "Дата,Организация,Склад_GUID";
		СтрокаТабличныхЧастей = "";
		
