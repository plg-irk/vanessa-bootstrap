		КонецЕсли;                                                                            
		ДанныеОбъекта.Вставить("Номер", Выборка.Номер);
		ДанныеОбъекта.Вставить("Дата", Выборка.Дата);
		ДанныеОбъекта.Вставить("ВидОперации", Выборка.ВидОперации);
		ДанныеОбъекта.Вставить("СуммаДокумента", Выборка.СуммаДокумента); 
		ДанныеОбъекта.Вставить("Организация", Выборка.Организация); 
		
		ОписаниеОбъекта.Вставить("ДанныеОбъекта", ДанныеОбъекта);
		
		МассивДокументовБухгалтерии.Добавить(ОписаниеОбъекта);
	КонецЦикла;

	Возврат МассивДокументовБухгалтерии;
	
КонецФункции

