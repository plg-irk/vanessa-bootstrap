//
Функция ПриВыводеПодробнойИнформации(Ссылка, СтрокиИнформации) Экспорт
КонецФункции
 
// Параметры:
//  ЗначенияНастроек - Структура - набор значений опций, необходимых для последующей проверки объектов. Ключ - имя настройки, Значение - значение.
//
Функция ПередПроверкойДанных(ЗначенияНастроек) Экспорт

	ЗначенияНастроек = Справочники.НастройкиОтраженияДокументовВБухгалтерии.НастройкиУзлаОбмена();  

	МассивКонстант = Новый Массив;
	МассивКонстант.Добавить(Метаданные.Константы.ФункциональнаяОпцияРазрешитьСкладыВТабличныхЧастях);

	НаборКонстант = Константы.СоздатьНабор(МассивКонстант);
	НаборКонстант.Прочитать();  
	
	ЗначенияНастроек.Вставить("РазрешитьСкладыВТабличныхЧастях", НаборКонстант.ФункциональнаяОпцияРазрешитьСкладыВТабличныхЧастях);
	ЗначенияНастроек.Вставить("ДополнительныеСведения");

КонецФункции

