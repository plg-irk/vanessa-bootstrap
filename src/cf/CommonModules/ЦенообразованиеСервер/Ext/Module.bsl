Функция ПолучитьВидЦенПоИдентификаторуФормул(ИдентификаторФормул) 
	
	ВидЦен = Справочники.ВидыЦен.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыЦен.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	ВидыЦен.ИдентификаторФормул = &ИдентификаторФормул
	|	И НЕ ВидыЦен.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ИдентификаторФормул", ИдентификаторФормул);
	
	РезультатЗапроса = Запрос.Выполнить();	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();	
		ВыборкаДетальныеЗаписи.Следующий(); 	
		ВидЦен = ВыборкаДетальныеЗаписи.Ссылка; 
	КонецЕсли;
	
	Возврат ВидЦен;
	
КонецФункции

Функция ДокументУстановкиПроведен(ДокументУстановки)
	
	Результат = Ложь;
	Если ЗначениеЗаполнено(ДокументУстановки) Тогда
		
		Если ТипЗнч(ДокументУстановки) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
			ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументУстановки, "Проведен,ВидОперации");
			Результат = РаботаСЗаявкамиКлиентСервер.ЗаказПроведен(ЗначенияРеквизитов);
		Иначе
			Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументУстановки, "Проведен");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти