#Область СлужебныеПроцедурыИФункции

Функция СпособАвторизацииOAUTH() Экспорт
	Возврат 0;
КонецФункции

Функция СпособАвторизацииVKID() Экспорт
	Возврат 1;
КонецФункции

Функция ПараметрыURLПолучить( Знач URL ) Экспорт

	Результат = Новый Соответствие;
    
    ТекущаяСтрока = СокрЛП( URL );
    Позиция = СтрНайти( ТекущаяСтрока, "?" );
    Если Позиция = 0 Тогда
    	// нет параметров
    	Возврат Результат;
    КонецЕсли;

	ТекущаяСтрока = Сред( ТекущаяСтрока, Позиция + 1 );
	
    Позиция = СтрНайти( ТекущаяСтрока, "=" );
    Если Позиция = 0 Тогда
    	// нет параметров
    	Возврат Результат;
    КонецЕсли;
	
	Строки = СтрРазделить( ТекущаяСтрока, "&", Ложь );
	Если Строки.Количество() = 0 Тогда
		// есть только 1 параметр
		Строки.Добавить( ТекущаяСтрока );
	КонецЕсли;
	
	Для Каждого ТекущаяСтрока Из Строки Цикл
    	
    	Позиция = СтрНайти( ТекущаяСтрока, "=" );
    	Если Позиция = 0 Тогда
    		Продолжить;
    	КонецЕсли;
    	
    	ПараметрИмя = Лев( ТекущаяСтрока, Позиция - 1);
    	ПараметрЗначение = Сред( ТекущаяСтрока, Позиция + 1 );
		
		Результат.Вставить( ПараметрИмя, ПараметрЗначение );
		
	КонецЦикла;

	Возврат Результат;
КонецФункции

Функция АвторизацияВКонтактеБезопасноеХранилищеКлючиПолучить( СпособАвторизации ) Экспорт

	Если СпособАвторизации = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииVKID() Тогда
		Результат = "access_token, ОкончанияДействияТокенаДоступа, refresh_token, client_id, device_id, state, "
		+ "access_token_community, ОкончанияДействияТокенДоступаСообщества";
	Иначе
	    Результат = 
	    "access_token, ОкончанияДействияТокенаДоступа, access_token_community, ОкончанияДействияТокенДоступаСообщества";
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ДанныеАвторизацииСообществаЗаполнены( АвторизацияВКонтактеПараметры ) Экспорт
	Возврат ЗначениеЗаполнено( АвторизацияВКонтактеПараметры.access_token_community );
КонецФункции

Функция АвторизацияВКонтактеПараметрыНовый( СпособАвторизации ) Экспорт

	Результат = Новый Структура;
	Результат.Вставить( "СпособАвторизации", СпособАвторизации );
	
	Если СпособАвторизации = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииVKID() Тогда
		
		Результат.Вставить( "client_id", "" ); // идентификатор приложения
		Результат.Вставить( "redirect_uri", "" ); // адрес перенаправления, должен совпадать с настройками приложения
		Результат.Вставить( "state", "" ); // произвольная строка состояния
		Результат.Вставить( "scope", "" ); // список доступов

		Результат.Вставить( "code", "" ); // код, который можно обменять на токен
		Результат.Вставить( "code_verifier", "" ); // параметр для защиты передаваемых данных
		Результат.Вставить( "code_challenge", "" ); // преобразованный code_verifier
		Результат.Вставить( "code_challenge_method", "" ); // метод преобразования code_verifier

		Результат.Вставить( "device_id", "" ); // идентификатор устройства

		Результат.Вставить( "access_token", "" ); // Access token пользователя
		Результат.Вставить( "ОкончанияДействияТокенаДоступа", Дата( 1, 1, 1) );
		
		Результат.Вставить( "refresh_token", "" ); // Токен, который используется для обмена на новую пару Access token + Refresh token

		Результат.Вставить( "АвторизацияСтрокаURL", "" );

		Результат.Вставить( "access_token_community", "" );
		Результат.Вставить( "ОкончанияДействияТокенДоступаСообщества", Дата( 1, 1, 1) );
		
		Результат.Вставить( "УчетнаяЗапись", ПредопределенноеЗначение( "ПланОбмена.ИнтеграцияСМагазинамиСоцСетей.ПустаяСсылка" ) );
		
	Иначе

		Результат.Вставить( "access_token", "" );
		Результат.Вставить( "ОкончанияДействияТокенаДоступа", Дата( 1, 1, 1) );

		Результат.Вставить( "access_token_community", "" );
		Результат.Вставить( "ОкончанияДействияТокенДоступаСообщества", Дата( 1, 1, 1) );
		
		Результат.Вставить( "УчетнаяЗапись", ПредопределенноеЗначение( "ПланОбмена.ИнтеграцияСМагазинамиСоцСетей.ПустаяСсылка" ) );
		
	КонецЕсли;

	Возврат Результат;
КонецФункции

#КонецОбласти