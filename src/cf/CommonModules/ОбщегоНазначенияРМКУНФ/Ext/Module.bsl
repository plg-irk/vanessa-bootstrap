// Заполняет признак использования КМ по номенклатуре
//
// Параметры:
//  Номенклатура - Ссылка - номенклатура
//  НоменклатураИспользующаяКМ - Булево - Ложь, если номенклатура маркируется средством идентификации, не имеющий кода маркировки, иначе Истина
//
Процедура ЗаполнитьПризнакИспользованияКМПоНоменклатуре(Номенклатура, НоменклатураИспользующаяКМ) Экспорт
	
	НоменклатураИспользующаяКМ = Ложь;
	
	МассивПредметовРасчетаБезКМ = Новый Массив;
	МассивПредметовРасчетаБезКМ.Добавить(Перечисления.ПризнакиПредметаРасчета.ПодакцизныйТоварМаркируемыйСИИмеющийКМ);
	МассивПредметовРасчетаБезКМ.Добавить(Перечисления.ПризнакиПредметаРасчета.ТоварМаркируемыйСИИмеющийКМ);
	
	ПризнакПредметаРасчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "ПризнакПредметаРасчета");
	
	Если МассивПредметовРасчетаБезКМ.Найти(ПризнакПредметаРасчета) <> Неопределено Тогда
		НоменклатураИспользующаяКМ = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Процедура заполняет данные на форме РМК на освновании расходной накладной.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - данные формы РМК.
//  ЧекККМ - ДокументСсылка.ЧекККМ - выбранная накладная.
//  ДополнительныеПараметры - Структура - структура дополнительных параметров для заполнения чека
//     *ПереноситьКодыМаркировки - Булево - признак необходимости заполнить коды маркировки из чека
//
Процедура ЗаполнитьНаОснованииРасходнойНакладной(Форма, РасходнаяНакладная, ДополнительныеПараметры = Неопределено) Экспорт
	
	ПереноситьКодыМаркировки = Ложь;
	Если (Не ДополнительныеПараметры = Неопределено) И ДополнительныеПараметры.Свойство("ПереноситьКодыМаркировки") Тогда
		ПереноситьКодыМаркировки = ДополнительныеПараметры.ПереноситьКодыМаркировки;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "Объект") Тогда
		Объект = Форма.Объект;
	Иначе
		Возврат;
	КонецЕсли;
	
	ТребуютсяДанныеКонтроля = Ложь;
	Если Не ДополнительныеПараметры = Неопределено
			И ДополнительныеПараметры.Свойство("ДанныеКонтроляПродаж")
			И ТипЗнч(ДополнительныеПараметры.ДанныеКонтроляПродаж) = Тип("Структура") Тогда
		ТребуютсяДанныеКонтроля = Истина;
	КонецЕсли;
	
	Объект.Товары.Очистить();
	Объект.Оплата.Очистить();
	
	Форма.ЧекККМПродажа = РасходнаяНакладная;
	Объект.ЗаказПокупателя = РасходнаяНакладная.Заказ;
	
	Форма.ОтправкаЧекаПочта = РасходнаяНакладная.АдресЭП;
	Форма.ОтправкаЧекаТелефон = РасходнаяНакладная.Телефон;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасходнаяНакладнаяЗапасы.НомерСтроки КАК НомерСтроки,
	|	РасходнаяНакладнаяЗапасы.Количество КАК Количество,
	|	РасходнаяНакладнаяЗапасы.Количество КАК КоличествоУпаковок,
	|	РасходнаяНакладнаяЗапасы.Номенклатура КАК Номенклатура,
	|	РасходнаяНакладнаяЗапасы.ПроцентАвтоматическойСкидки КАК ПроцентАвтоматическойСкидки,
	|	РасходнаяНакладнаяЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
	|	РасходнаяНакладнаяЗапасы.СтавкаНДС КАК СтавкаНДС,
	|	РасходнаяНакладнаяЗапасы.Сумма КАК Сумма,
	|	РасходнаяНакладнаяЗапасы.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки,
	|	РасходнаяНакладнаяЗапасы.Цена * РасходнаяНакладнаяЗапасы.Количество КАК СуммаБезСкидки,
	|	РасходнаяНакладнаяЗапасы.СуммаНДС КАК СуммаНДС,
	|	РасходнаяНакладнаяЗапасы.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	РасходнаяНакладнаяЗапасы.СуммаСкидкиОплатыБонусом КАК СуммаСкидкиОплатыБонусом,
	|	РасходнаяНакладнаяЗапасы.СтруктурнаяЕдиница КАК ТорговыйОбъект,
	|	РасходнаяНакладнаяЗапасы.ЕдиницаИзмерения КАК Упаковка,
	|	РасходнаяНакладнаяЗапасы.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияНоменклатуры,
	|	ВЫБОР
	|		КОГДА СправочникЕдиницыИзмерения.Ссылка ЕСТЬ NULL
	|				ИЛИ СправочникЕдиницыИзмерения.Коэффициент = 0
	|			ТОГДА 1
	|		ИНАЧЕ СправочникЕдиницыИзмерения.Коэффициент
	|	КОНЕЦ КАК КоэффициентУпаковки,
	|	РасходнаяНакладнаяЗапасы.Характеристика КАК Характеристика,
	|	РасходнаяНакладнаяЗапасы.Цена КАК Цена,
	|	ЕСТЬNULL(СпрНоменклатура.ИспользоватьСерииНоменклатуры, ЛОЖЬ) КАК НеобходимостьВводаСерии,
	|	РасходнаяНакладнаяЗапасы.Партия КАК Партия,
	|	ЕСТЬNULL(РасходнаяНакладнаяШтрихкодыУпаковок.ЧастичноеВыбытиеКоличество, 0) КАК ЧастичноеВыбытиеКоличество,
	|	ЕСТЬNULL(РасходнаяНакладнаяШтрихкодыУпаковок.ЧастичноеВыбытиеВариантУчета, ЗНАЧЕНИЕ(Перечисление.ВариантыУчетаЧастичногоВыбытияИС.ПустаяСсылка)) КАК ЧастичноеВыбытиеВариантУчета,
	|	ЕСТЬNULL(РасходнаяНакладнаяШтрихкодыУпаковок.ЧастичноеВыбытиеНоменклатура, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК ЧастичноеВыбытиеНоменклатура,
	|	ЕСТЬNULL(РасходнаяНакладнаяШтрихкодыУпаковок.ЧастичноеВыбытиеХарактеристика, ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК ЧастичноеВыбытиеХарактеристика,
	|	ЕСТЬNULL(СпрНоменклатура.Весовой, ЛОЖЬ) КАК Весовой,
	|	СпрНоменклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|	СпрНоменклатура.КатегорияНоменклатуры КАК ВидНоменклатуры,
	|	РасходнаяНакладнаяЗапасы.СуммаСкидкиНаценки + РасходнаяНакладнаяЗапасы.СуммаАвтоматическойСкидки + РасходнаяНакладнаяЗапасы.СуммаСкидкиОплатыБонусом КАК СуммаСкидокОбщая,
	|	ЕСТЬNULL(СпрНоменклатура.КодТРУ, """") КАК КодТРУ,
	|	ЕСТЬNULL(СпрНоменклатура.ИспользоватьПартии, ЛОЖЬ) КАК ИспользоватьПартии,
	|	ЕСТЬNULL(СпрНоменклатура.ПроверятьЗаполнениеПартий, ЛОЖЬ) КАК ПроверятьЗаполнениеПартий,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СпрПолитикаУчетаСерий.ТипПолитики, ЗНАЧЕНИЕ(Перечисление.ТипыПолитикУказанияСерий.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.ТипыПолитикУказанияСерий.УправлениеОстаткамиСерий)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПроверятьЗаполнениеСерий,
	|	СпрНоменклатура.ИспользоватьУникальныеСерии КАК УникальностьСерии,
	|	ВЫБОР
	|		КОГДА РасходнаяНакладнаяЗапасы.НоменклатураНабора = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЭтоНабор,
	|	РасходнаяНакладнаяЗапасы.НоменклатураНабора КАК НоменклатураНабора,
	|	РасходнаяНакладнаяЗапасы.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|	ВЫБОР
