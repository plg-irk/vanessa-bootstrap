Функция ПолучитьТекстЗапросаТоваровЧека()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЧекККМЗапасы.Номенклатура КАК Номенклатура,
	|	ЧекККМЗапасы.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втТоварыКонтроля
	|ИЗ
	|	Документ.ЧекККМ.Запасы КАК ЧекККМЗапасы
	|ГДЕ
	|	ЧекККМЗапасы.Ссылка = &ЧекККМ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПолучитьТекстЗапросаТоваровНабора()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаСостава.Номенклатура КАК Номенклатура,
	|	ТаблицаСостава.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втТоварыКонтроля
	|ИЗ
	|	ТаблицаСоставНабора КАК ТаблицаСостава
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПолучитьТекстЗапросаКонтроляПродаж(ТекстФормированияТаблицыТоваров = "")
	
	Если ТекстФормированияТаблицыТоваров = "" Тогда
		ТекстФормированияТаблицыТоваров =
		"ВЫБРАТЬ
		|	ТаблицаТовары.Номенклатура КАК Номенклатура,
		|	ТаблицаТовары.Характеристика КАК Характеристика
		|ПОМЕСТИТЬ втТоварыКонтроля
		|ИЗ
		|	&ТаблицаТовары КАК ТаблицаТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|";
	КонецЕсли;
	
	ТекстОбщегоЗапроса =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТолькоТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ втТолькоТовары
	|ИЗ
	|	втТоварыКонтроля КАК ТолькоТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СпрКонтрольПродаж.Ссылка КАК КонтрольПродаж,
	|	СпрКонтрольПродаж.ДляВсейНоменклатуры КАК ДляВсейНоменклатуры,
	|	СпрКонтрольПродаж.ДляВсехТорговыхОбъектов КАК ДляВсехТорговыхОбъектов
	|ПОМЕСТИТЬ втЭлементыКонтроля
	|ИЗ
	|	Справочник.КонтрольПродаж КАК СпрКонтрольПродаж
	|ГДЕ
	|	СпрКонтрольПродаж.Использование
	|	И (СпрКонтрольПродаж.ВключенВРМК
	|			ИЛИ СпрКонтрольПродаж.Локальный)
	|	И НЕ СпрКонтрольПродаж.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭлементыКонтроля.КонтрольПродаж КАК КонтрольПродаж,
	|	ЭлементыКонтроля.ДляВсейНоменклатуры КАК ДляВсейНоменклатуры
	|ПОМЕСТИТЬ втЭлементыКонтроляТорговогоОбъекта
	|ИЗ
	|	втЭлементыКонтроля КАК ЭлементыКонтроля
	|ГДЕ
	|	ЭлементыКонтроля.ДляВсехТорговыхОбъектов
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭлементыКонтроля.КонтрольПродаж,
	|	ЭлементыКонтроля.ДляВсейНоменклатуры
	|ИЗ
	|	втЭлементыКонтроля КАК ЭлементыКонтроля
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтрольПродаж.ТорговыеОбъекты КАК КонтрольПродажТорговыеОбъекты
	|		ПО ЭлементыКонтроля.КонтрольПродаж = КонтрольПродажТорговыеОбъекты.Ссылка
	|			И (КонтрольПродажТорговыеОбъекты.ТорговыйОбъект = &ТорговыйОбъект)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭлементыКонтроля.КонтрольПродаж КАК КонтрольПродаж,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
	|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика
	|ПОМЕСТИТЬ втОтобранныйКонтроль
	|ИЗ
	|	втЭлементыКонтроляТорговогоОбъекта КАК ЭлементыКонтроля
	|ГДЕ
	|	ЭлементыКонтроля.ДляВсейНоменклатуры
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЭлементыКонтроля.КонтрольПродаж,
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка),
	|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|ИЗ
	|	втЭлементыКонтроляТорговогоОбъекта КАК ЭлементыКонтроля
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтрольПродаж.КонтрольПродаж КАК ТабличнаяЧастьКонтрольПродаж
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыКонтроля КАК СпрВидыКонтроля
	|			ПО ТабличнаяЧастьКонтрольПродаж.ВидКонтроля = СпрВидыКонтроля.Ссылка
	|		ПО ЭлементыКонтроля.КонтрольПродаж = ТабличнаяЧастьКонтрольПродаж.Ссылка
	|ГДЕ
	|	СпрВидыКонтроля.ТипКонтроля В (ЗНАЧЕНИЕ(Перечисление.ТипыКонтроля.ЛимитКоличестваСтрокВЧеке), ЗНАЧЕНИЕ(Перечисление.ТипыКонтроля.ЛимитСуммыВЧеке))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭлементыКонтроля.КонтрольПродаж,
	|	ТолькоТовары.Номенклатура,
	|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|ИЗ
	|	втЭлементыКонтроляТорговогоОбъекта КАК ЭлементыКонтроля
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтрольПродаж.Номенклатура КАК КонтрольПродажНоменклатура
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втТолькоТовары КАК ТолькоТовары
	|			ПО КонтрольПродажНоменклатура.Номенклатура = ТолькоТовары.Номенклатура
	|		ПО ЭлементыКонтроля.КонтрольПродаж = КонтрольПродажНоменклатура.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЭлементыКонтроля.КонтрольПродаж,
	|	ТоварыКонтроля.Номенклатура,
	|	ТоварыКонтроля.Характеристика
	|ИЗ
	|	втЭлементыКонтроляТорговогоОбъекта КАК ЭлементыКонтроля
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтрольПродаж.ПалитрыКонтроляПродаж КАК КонтрольПродажПалитрыКонтроляПродаж
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПалитраТоваровРМК.Состав КАК ПалитраТоваровРМКСостав
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ втТоварыКонтроля КАК ТоварыКонтроля
	|				ПО ПалитраТоваровРМКСостав.Номенклатура = ТоварыКонтроля.Номенклатура
	|					И ПалитраТоваровРМКСостав.Характеристика = ТоварыКонтроля.Характеристика
	|			ПО КонтрольПродажПалитрыКонтроляПродаж.Палитра = ПалитраТоваровРМКСостав.Ссылка
	|				И (НЕ ПалитраТоваровРМКСостав.Ссылка.ПометкаУдаления)
	|		ПО ЭлементыКонтроля.КонтрольПродаж = КонтрольПродажПалитрыКонтроляПродаж.Ссылка
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ЭлементыКонтроля.КонтрольПродаж,
	|	ТолькоТовары.Номенклатура,
	|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|ИЗ
	|	втЭлементыКонтроляТорговогоОбъекта КАК ЭлементыКонтроля
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтрольПродаж.ПалитрыКонтроляПродаж КАК КонтрольПродажПалитрыКонтроляПродаж
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПалитраТоваровРМК.Состав КАК ПалитраТоваровРМКСостав
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ втТолькоТовары КАК ТолькоТовары
	|				ПО ПалитраТоваровРМКСостав.Номенклатура = ТолькоТовары.Номенклатура
	|					И (ПалитраТоваровРМКСостав.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка))
	|			ПО КонтрольПродажПалитрыКонтроляПродаж.Палитра = ПалитраТоваровРМКСостав.Ссылка
	|				И (НЕ ПалитраТоваровРМКСостав.Ссылка.ПометкаУдаления)
	|		ПО ЭлементыКонтроля.КонтрольПродаж = КонтрольПродажПалитрыКонтроляПродаж.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтобранныйКонтроль.КонтрольПродаж КАК КонтрольПродаж,
	|	СтрокиКонтроляПродаж.ВидКонтроля КАК ВидКонтроля,
	|	СтрокиКонтроляПродаж.НачалоПериода КАК НачалоПериода,
	|	СтрокиКонтроляПродаж.КонецПериода КАК КонецПериода,
	|	СтрокиКонтроляПродаж.ДеньНедели КАК ДеньНедели,
	|	СтрокиКонтроляПродаж.ВремяНачала КАК ВремяНачала,
	|	СтрокиКонтроляПродаж.ВремяОкончания КАК ВремяОкончания
	|ПОМЕСТИТЬ втСтрокиКонтроля
	|ИЗ
	|	втОтобранныйКонтроль КАК ОтобранныйКонтроль
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтрольПродаж.КонтрольПродаж КАК СтрокиКонтроляПродаж
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыКонтроля КАК СпрВидыКонтроля
	|			ПО СтрокиКонтроляПродаж.ВидКонтроля = СпрВидыКонтроля.Ссылка
	|		ПО ОтобранныйКонтроль.КонтрольПродаж = СтрокиКонтроляПродаж.Ссылка
	|ГДЕ
	|	СтрокиКонтроляПродаж.НачалоПериода <= &НачалоСледующегоДня
	|	И СтрокиКонтроляПродаж.ДеньНедели В(&ДниСегодняЗавтра)
	|	И (СтрокиКонтроляПродаж.КонецПериода >= &НачалоТекущегоДня
	|			ИЛИ СтрокиКонтроляПродаж.КонецПериода = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0))
	|	И (&РежимКассыСамообслуживания
	|			ИЛИ НЕ СпрВидыКонтроля.ТипКонтроля = ЗНАЧЕНИЕ(Перечисление.ТипыКонтроля.КонтрольСотрудникомНаКСО))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтрокиКонтроля.ВидКонтроля КАК ВидКонтроля
	|ПОМЕСТИТЬ втВидыКонтроля
	|ИЗ
	|	втСтрокиКонтроля КАК СтрокиКонтроля
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СтрокиКонтроля.КонтрольПродаж КАК КонтрольПродаж
	|ПОМЕСТИТЬ втКонтрольПродаж
	|ИЗ
	|	втСтрокиКонтроля КАК СтрокиКонтроля
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СпрКонтрольПродаж.Ссылка КАК КонтрольПродаж,
	|	СпрКонтрольПродаж.НаименованиеГруппыТоваров КАК НаименованиеГруппыТоваров
	|ИЗ
	|	втКонтрольПродаж КАК втКонтрольПродаж
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтрольПродаж КАК СпрКонтрольПродаж
	|		ПО втКонтрольПродаж.КонтрольПродаж = СпрКонтрольПродаж.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СпрВидыКонтроля.Ссылка КАК ВидКонтроля,
	|	СпрВидыКонтроля.ТипКонтроля КАК ТипКонтроля,
	|	СпрВидыКонтроля.ТекстШаблонаПредупреждения КАК ТекстШаблонаПредупреждения,
	|	СпрВидыКонтроля.ПараметрыКонтроля.(
	|		Ссылка КАК Ссылка,
	|		НомерСтроки КАК НомерСтроки,
	|		Параметр КАК Параметр,
	|		Значение КАК Значение
	|	) КАК ПараметрыКонтроля
	|ИЗ
	|	втВидыКонтроля КАК ВидыКонтроля
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыКонтроля КАК СпрВидыКонтроля
	|		ПО ВидыКонтроля.ВидКонтроля = СпрВидыКонтроля.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОтобранныйКонтроль.КонтрольПродаж КАК КонтрольПродаж,
	|	ОтобранныйКонтроль.Номенклатура КАК Номенклатура,
	|	ОтобранныйКонтроль.Характеристика КАК Характеристика
	|ИЗ
	|	втОтобранныйКонтроль КАК ОтобранныйКонтроль
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втКонтрольПродаж КАК втКонтрольПродаж
	|		ПО (втКонтрольПродаж.КонтрольПродаж = ОтобранныйКонтроль.КонтрольПродаж)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтрокиКонтроля.КонтрольПродаж КАК КонтрольПродаж,
	|	СтрокиКонтроля.ВидКонтроля КАК ВидКонтроля,
	|	СтрокиКонтроля.НачалоПериода КАК НачалоПериода,
	|	СтрокиКонтроля.КонецПериода КАК КонецПериода,
	|	СтрокиКонтроля.ДеньНедели КАК ДеньНедели,
	|	СтрокиКонтроля.ВремяНачала КАК ВремяНачала,
	|	СтрокиКонтроля.ВремяОкончания КАК ВремяОкончания
	|ИЗ
	|	втСтрокиКонтроля КАК СтрокиКонтроля";
	
	ТекстЗапроса = СтрШаблон("%1%2", ТекстФормированияТаблицыТоваров, ТекстОбщегоЗапроса);
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПодготовитьДанныеКонтроляПродаж(РезультатыЗапроса, НачальныйНомерЗапроса)
	
	ТаблицаКонтроляИСвойств = РезультатыЗапроса[НачальныйНомерЗапроса].Выгрузить();
	ТаблицаВидовКонтроляСПараметрами = РезультатыЗапроса[НачальныйНомерЗапроса + 1].Выгрузить();
	ТаблицаКонтроляИНоменклатуры = РезультатыЗапроса[НачальныйНомерЗапроса + 2].Выгрузить();
	ТаблицаСтрокКонтроля = РезультатыЗапроса[НачальныйНомерЗапроса + 3].Выгрузить();
	
	НаборТаблиц = Новый Структура();
	НаборТаблиц.Вставить("ТаблицаКонтроляИСвойств", ТаблицаКонтроляИСвойств);
	НаборТаблиц.Вставить("ТаблицаВидовКонтроляСПараметрами", ТаблицаВидовКонтроляСПараметрами);
	НаборТаблиц.Вставить("ТаблицаКонтроляИНоменклатуры", ТаблицаКонтроляИНоменклатуры);
	НаборТаблиц.Вставить("ТаблицаСтрокКонтроля", ТаблицаСтрокКонтроля);
	
	ДанныеКонтроляПродаж = ИнтерфейсРМКСлужебный.ПодготовитьДанныеКонтроляПродаж(НаборТаблиц);
	
	Возврат ДанныеКонтроляПродаж;
	
КонецФункции

Функция ПодготовитьТаблицуТоваровДляЗапроса(МассивТоваров, Характеристика)
	
	ПараметрТаблицаТоваров = Новый ТаблицаЗначений;
	ПараметрТаблицаТоваров.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ПараметрТаблицаТоваров.Колонки.Добавить("Характеристика",
		Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
		
	Для Каждого Товар Из МассивТоваров Цикл
		НоваяСтрока = ПараметрТаблицаТоваров.Добавить();
		НоваяСтрока.Номенклатура = Товар;
		НоваяСтрока.Характеристика = Характеристика;
	КонецЦикла;
	
	Возврат ПараметрТаблицаТоваров;
	
КонецФункции

Процедура УстановитьПараметрыЗапросаКонтроляПродаж(ЗапросКонтроляПродаж, ТаблицаТоваров, ДополнительныеДанные)
	
	Сутки = 86400;
	НачалоТекущегоДня = НачалоДня(ТекущаяДатаСеанса());
	НачалоСледующегоДня = НачалоТекущегоДня + Сутки;
	ДниНеделиСегодняЗавтра = Новый Массив;
	ДеньНеделиСегодня = Неопределено;
	ДеньНеделиЗавтра = Неопределено;
	ДеньНеделиПустаяСсылка = Неопределено;
	ОбщегоНазначенияРМКУНФКлиентСервер.ЗаполнитьДеньНеделиПеречислением(ДеньНеделиСегодня, НачалоТекущегоДня);
	ОбщегоНазначенияРМКУНФКлиентСервер.ЗаполнитьДеньНеделиПеречислением(ДеньНеделиЗавтра, НачалоСледующегоДня);
	ОбщегоНазначенияРМКУНФКлиентСервер.ЗаполнитьДеньНеделиПеречислением(ДеньНеделиПустаяСсылка, Неопределено);
	ДниНеделиСегодняЗавтра.Добавить(ДеньНеделиСегодня);
	ДниНеделиСегодняЗавтра.Добавить(ДеньНеделиЗавтра);
	ДниНеделиСегодняЗавтра.Добавить(ДеньНеделиПустаяСсылка);
	
	ЗапросКонтроляПродаж.УстановитьПараметр("ТаблицаТовары", ТаблицаТоваров);
	ЗапросКонтроляПродаж.УстановитьПараметр("НачалоСледующегоДня", НачалоСледующегоДня);
	ЗапросКонтроляПродаж.УстановитьПараметр("НачалоТекущегоДня", НачалоТекущегоДня);
	ЗапросКонтроляПродаж.УстановитьПараметр("ДниСегодняЗавтра", ДниНеделиСегодняЗавтра);
	ЗапросКонтроляПродаж.УстановитьПараметр("РежимКассыСамообслуживания",
		ДополнительныеДанные.РежимКассыСамообслуживания);
	ЗапросКонтроляПродаж.УстановитьПараметр("ТорговыйОбъект", ДополнительныеДанные.ТорговыйОбъект);
	
КонецПроцедуры

Функция ПолучитьСтатусЧекаВОблаке(ПараметрыПроцедуры, АдресРезультата) Экспорт
	
	СтатусПробитияЧека = ОборудованиеЧекопечатающиеОблачныеККТ.СтатусПробитияЧека(ПараметрыПроцедуры.ДокументОснование);
	ПоместитьВоВременноеХранилище(СтатусПробитияЧека, АдресРезультата);
	
КонецФункции

Функция ПолучитьМассивКолонокКоллекции(КоллекцияКолонок)
	
	РезультатФункции = Новый Массив;
	Для Каждого КолонкаКоллекции Из КоллекцияКолонок Цикл
		ОписаниеКолонки = Новый Структура("Имя,Тип", КолонкаКоллекции.Имя, КолонкаКоллекции.Тип);
		РезультатФункции.Добавить(ОписаниеКолонки);
	КонецЦикла;
	Возврат РезультатФункции;
	
КонецФункции

Процедура ДобавитьОписаниеКолонкиВКоллекцию(КоллекцияКолонок, ИмяКолонки, ТипКолонки)
	
	ОписаниеКолонки = Новый Структура("Имя,Тип", ИмяКолонки, ТипКолонки);
	КоллекцияКолонок.Добавить(ОписаниеКолонки);
	
КонецПроцедуры

Функция СтрокаКоллекцииИмеетСвойство(СтрокаКоллекции, ИмяСвойства)
	
	РезультатФункции = Ложь;
	
	Если ТипЗнч(СтрокаКоллекции) = Тип("СтрокаТаблицыЗначений") Тогда
		ТаблицаРодитель = СтрокаКоллекции.Владелец();
		Если Не ТаблицаРодитель.Колонки.Найти(ИмяСвойства) = Неопределено Тогда
			РезультатФункции = Истина;
		КонецЕсли;
	ИначеЕсли СтрокаКоллекции.Свойство(ИмяСвойства) Тогда
		РезультатФункции = Истина;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

#Область УчетНаличных
// Заполняет признак контроля остатка наличных в кассе если используется переопределение настроек.
//
// Параметры:
//  КонтролироватьОстатокНаличных - Булево - заполняемый признак учета
//
Процедура ЗаполнитьПризнакКонтролироватьОстатокНаличных(КонтролироватьОстатокНаличных) Экспорт
	
	КонтролироватьОстатокНаличных = Константы.КонтролироватьОстаткиПриПробитииЧековККМ.Получить()
		И Константы.КонтролироватьОстаткиДенегВКассах.Получить();
	
КонецПроцедуры

// Заполняет количество наличных денежных средств в кассе ккм.
//
// Параметры:
//  Организация - ОпределяемыйТип.ОрганизацияРМК - Организация
//  КассаККМ - ОпределяемыйТип.КассаККМРМК - КассаККМ
//  Результат - Число - Наличные денежные средства в кассе ККМ.
//
Процедура ЗаполнитьНаличныеДенежныеСредстваВКассеККМ(Организация, КассаККМ, Результат) Экспорт
	
	ОрганизацияОстатков = Организация;
	Если Константы.УчетПоКомпании.Получить() Тогда
		ОрганизацияОстатков = Константы.Компания.Получить();
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДенежныеСредстваВКассахККМОстатки.СуммаОстаток КАК СуммаОстаток
	|ИЗ
	|	РегистрНакопления.ДенежныеСредстваВКассахККМ.Остатки(
	|			,
	|			Организация = &Организация
	|				И КассаККМ = &КассаККМ) КАК ДенежныеСредстваВКассахККМОстатки";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Организация", ОрганизацияОстатков);
	Запрос.УстановитьПараметр("КассаККМ", КассаККМ);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.СуммаОстаток;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет параметры автоматической выемки денежных средств в кассе ккм
// при закрытии смены.
// 
// Параметры:
//  Организация - ОпределяемыйТип.ОрганизацияРМК - Организация
//  КассаККМ - ОпределяемыйТип.КассаККМРМК - КассаККМ
//  Результат - Структура - Структура параметров выемки
//   *ТребуетсяВыемкаПриЗакрытииСмены - Булево - Признак необходимости делать автовыемку при закрытии смены.
//   *МинимальныйОстатокНаличныхВКассе - Число - Минимальный остаток наличных при автовыемки.
//
Процедура ЗаполнитьПараметрыВыемкиПриЗакрытииСмены(Организация, КассаККМ, Результат) Экспорт
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КассыККМ.СоздаватьВыемку КАК ТребуетсяВыемкаПриЗакрытииСмены,
	|	КассыККМ.МинимальныйОстатокВКассеККМ КАК МинимальныйОстатокНаличныхВКассе
	|ИЗ
	|	Справочник.КассыККМ КАК КассыККМ
	|ГДЕ
	|	КассыККМ.Ссылка = &КассаККМ";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("КассаККМ", КассаККМ);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ЗаполнениеХарактеристик

// Заполняет данные о характеристиках товаров
//
// Параметры:
//  СтруктураПараметров			 - Структура		 - настройки заполнения данных.
//  		* Номенклатура - ОпределяемыйТип.НоменклатураРМК - номенклатура текущей строки.
//  		* Характеристика - ОпределяемыйТип.ХарактеристикаРМК - характеристика текущей строки.
//  		* ВидЦены - ОпределяемыйТип.ВидЦеныРМК - вид цены рабочего места кассира.
//  		* ТорговыйОбъект - ОпределяемыйТип.ТорговыйОбъектРМК - торговый объект рабочего места кассира.
//  ДанныеПлиткиПодбораЗначений	 - ТаблицаЗначений	 - таблица для заполнения плитки значениями подбора.
//
Процедура ЗаполнитьДанныеПлиткиВыбораЗначений(СтруктураПараметров, ДанныеПлиткиПодбораЗначений) Экспорт
	
	ДанныеПлиткиПодбораЗначений.Очистить();
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Номенклатура,
	|	ВидыНоменклатуры.Ссылка КАК ВидНоменклатуры
	|ПОМЕСТИТЬ втДанныеНоменклатуры
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КатегорииНоменклатуры КАК ВидыНоменклатуры
	|		ПО Номенклатура.КатегорияНоменклатуры = ВидыНоменклатуры.Ссылка
	|ГДЕ
	|	Номенклатура.Ссылка = &ТекущаяНоменклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СписокХарактеристик.Характеристика КАК ЗначениеВыбора,
	|	СписокХарактеристик.НаименованиеДляПечати КАК НаименованиеДляПечати,
	|	ЦеныНоменклатурыСрезПоследних.Цена / ЕСТЬNULL(ЕдиницыИзмерения.Коэффициент, 1) * ЕСТЬNULL(ЕдиницыИзмеренияСтроки.Коэффициент, 1) КАК Цена,
	|	ЕСТЬNULL(ИнформативныеОстаткиТоваров.Количество, 0) - ЕСТЬNULL(ИнформативныеОстаткиТоваров.Резерв, 0) КАК Доступно,
	|	ВЫБОР
	|		КОГДА СписокХарактеристик.Характеристика = &Характеристика
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ТекущаяХарактеристика,
	|	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ИЗ
	|	(ВЫБРАТЬ
	|		ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
	|		ВЫРАЗИТЬ(ХарактеристикиНоменклатуры.НаименованиеДляПечати КАК СТРОКА(150)) КАК НаименованиеДляПечати,
	|		втДанныеНоменклатуры.Номенклатура КАК Номенклатура
	|	ИЗ
	|		втДанныеНоменклатуры КАК втДанныеНоменклатуры
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|			ПО втДанныеНоменклатуры.Номенклатура = ХарактеристикиНоменклатуры.Владелец
	|	ГДЕ
	|		НЕ ХарактеристикиНоменклатуры.ПометкаУдаления
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ХарактеристикиНоменклатуры.Ссылка,
	|		ВЫРАЗИТЬ(ХарактеристикиНоменклатуры.НаименованиеДляПечати КАК СТРОКА(150)),
	|		втДанныеНоменклатуры.Номенклатура
	|	ИЗ
	|		втДанныеНоменклатуры КАК втДанныеНоменклатуры
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|			ПО втДанныеНоменклатуры.ВидНоменклатуры = ХарактеристикиНоменклатуры.Владелец
	|	ГДЕ
	|		НЕ ХарактеристикиНоменклатуры.ПометкаУдаления) КАК СписокХарактеристик
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаСеанса, ВидЦен = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	|			ПО ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения = ЕдиницыИзмерения.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмеренияСтроки
	|			ПО (ЕдиницыИзмеренияСтроки.Ссылка = &УпаковкаСтроки)
	|		ПО СписокХарактеристик.Характеристика = ЦеныНоменклатурыСрезПоследних.Характеристика
	|			И СписокХарактеристик.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОстаткиТоваров КАК ИнформативныеОстаткиТоваров
	|		ПО СписокХарактеристик.Номенклатура = ИнформативныеОстаткиТоваров.Номенклатура
	|			И СписокХарактеристик.Характеристика = ИнформативныеОстаткиТоваров.Характеристика
	|			И (ИнформативныеОстаткиТоваров.СтруктурнаяЕдиница = &ТорговыйОбъект)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТекущаяХарактеристика УБЫВ";
	Запрос.УстановитьПараметр("ТекущаяНоменклатура", СтруктураПараметров.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", СтруктураПараметров.Характеристика);
	Запрос.УстановитьПараметр("ДатаСеанса", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВидЦены", СтруктураПараметров.ВидЦены);
	Запрос.УстановитьПараметр("ТорговыйОбъект", СтруктураПараметров.ТорговыйОбъект);
	Запрос.УстановитьПараметр("УпаковкаСтроки", СтруктураПараметров.Упаковка);
	РезультатЗапроса = Запрос.Выполнить();
	КоличествоДобавленныхКнопок = 0;
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		КоличествоЭлементов = Выборка.Количество();
		Если КоличествоЭлементов > 12 Тогда
			КоличествоНаСтранице = 11;
		Иначе
			КоличествоНаСтранице = 12;
		КонецЕсли;
		
		ОстатокНаСтранице = КоличествоНаСтранице;
		Пока Выборка.Следующий() Цикл
			
			НоваяСтрока = ДанныеПлиткиПодбораЗначений.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.Шрифт = ШрифтыСтиля.ШрифтОбычныйПолужирный12РМК;
			НоваяСтрока.ЦветШрифта = ЦветаСтиля.ЦветНеАктивизированногоПунктаРМК;
			НоваяСтрока.ЦветФона = ?(Выборка.ТекущаяХарактеристика, ЦветаСтиля.ЦветЗеленойКнопкиРМК, ЦветаСтиля.ЦветХарактеристикиРМК);
			НоваяСтрока.ИмяЭлемента = Выборка.ЗначениеВыбора;
			НоваяСтрока.ИмяДействия = "ЗаполнитьДанныеВыборХарактеристики";
			
			// Уменьшение оставшихся элементов
			ОстатокНаСтранице = ОстатокНаСтранице - 1;
			Если ОстатокНаСтранице = 0
				И КоличествоЭлементов > 12 Тогда
				// Добавление команды управления списком
				НоваяСтрока = ДанныеПлиткиПодбораЗначений.Добавить();
				НоваяСтрока.Шрифт = ШрифтыСтиля.ШрифтОбычныйПолужирный12РМК;
				НоваяСтрока.ЦветШрифта = ЦветаСтиля.ЦветНеАктивизированногоПунктаРМК;
				НоваяСтрока.ЦветФона = ЦветаСтиля.ЦветАктивнойКнопкиРМК;
				НоваяСтрока.ИмяЭлемента = "Все";
				НоваяСтрока.ИмяДействия = "ПоказатьВсеХарактеристики";
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти

Процедура НастроитьДинамическиеСпискиОтборовПоГруппе(Форма)
	
	ТекстЗапросаОтбораПоГруппе =
	"ВЫБРАТЬ
	|	Номенклатура.Наименование КАК Наименование,
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа";
	
	Форма.ОтборГруппа.ТекстЗапроса = ТекстЗапросаОтбораПоГруппе;
	Форма.ОтборГруппа.ОсновнаяТаблица = "Справочник.Номенклатура";
	
	ТекстЗапросаОтбораПоКатегории =
	"ВЫБРАТЬ
	|	Категории.Наименование КАК Наименование,
	|	Категории.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.КатегорииНоменклатуры КАК Категории";
	
	Форма.ОтборКатегория.ТекстЗапроса = ТекстЗапросаОтбораПоКатегории;
	Форма.ОтборКатегория.ОсновнаяТаблица = "Справочник.КатегорииНоменклатуры";
	
КонецПроцедуры

Процедура РассчитатьСуммуСкидокВСтроках(ТабличнаяЧастьТовары, ЧекВозвратаБезОснования = Ложь, ЭтоЧекККМ = Истина)
	
	Для Каждого Строка Из ТабличнаяЧастьТовары Цикл
		ИтоговаяСумма = Строка.Сумма + Строка.СуммаСкидкиОплатыБонусом + Строка.СуммаАвтоматическойСкидки + Строка.СуммаСкидкиНаценки;
		ИтоговаяЦенаПродажи = Окр(ИтоговаяСумма / Строка.Количество, 2, РежимОкругления.Окр15как10);

		Строка.Сумма = ИтоговаяСумма - Строка.СуммаСкидкиОплатыБонусом - Строка.СуммаАвтоматическойСкидки - Строка.СуммаСкидкиНаценки;
		Строка.СуммаБезСкидки = ИтоговаяСумма;
		Если ЭтоЧекККМ Тогда
			Строка.СуммаАвтоматическойСкидкиЧекаПродажи = Строка.СуммаАвтоматическойСкидки;
			Строка.СуммаСкидкиНаценкиЧекаПродажи = Строка.СуммаСкидкиНаценки;
			Строка.СуммаСкидкиОплатыБонусомЧекаПродажи = Строка.СуммаСкидкиОплатыБонусом;
			Строка.СуммаБезСкидкиЧекаПродажи = Строка.СуммаБезСкидки;
		ИначеЕсли НЕ ЧекВозвратаБезОснования Тогда
			Строка.СуммаАвтоматическойСкидкиЧекаПродажи = Строка.СуммаАвтоматическойСкидкиЧекаПродажи;
			Строка.СуммаСкидкиНаценкиЧекаПродажи = Строка.СуммаСкидкиНаценкиЧекаПродажи;
			Строка.СуммаСкидкиОплатыБонусомЧекаПродажи = Строка.СуммаСкидкиОплатыБонусомЧекаПродажи;
			Строка.СуммаБезСкидкиЧекаПродажи = Строка.СуммаБезСкидки;
		КонецЕсли;
		Строка.СуммаСкидокОбщая = Строка.СуммаСкидкиОплатыБонусом + Строка.СуммаАвтоматическойСкидки + Строка.СуммаСкидкиНаценки;
		Строка.Цена = ИтоговаяЦенаПродажи;
	КонецЦикла;
	
КонецПроцедуры

#Область НастройкиРасчетаСкидокИДисконтныхКарт
// Заполняет признак использования автоматических скидок в форме "Настройки рабочего места кассира"
//
// Параметры:
//  ИспользоватьСерверЛояльностиПолучательДанных - Булево	 - признак использования сервера лояльности
//  ИспользоватьАвтоматическиеСкидки			 - Булево	 - признак использования автоматических скидок.
//  ЕстьАвтоматическиеСкидки					 - Булево	 - признак использования локальных автоматических скидок.
//
Процедура ЗаполнитьИспользованиеАвтоматическихСкидок(ИспользоватьСерверЛояльностиПолучательДанных, ИспользоватьАвтоматическиеСкидки, ЕстьАвтоматическиеСкидки) Экспорт
	
	ЕстьАвтоматическиеСкидки = ПолучитьФункциональнуюОпцию("ИспользоватьАвтоматическиеСкидкиНаценки");
	ИспользоватьАвтоматическиеСкидки = ЕстьАвтоматическиеСкидки
											Или ИспользоватьСерверЛояльностиПолучательДанных;
	
КонецПроцедуры

// Заполняет признак использования дисконтных карт
//
// Параметры:
//  ИспользоватьДисконтныеКарты	 - Булево	 - признак использования дисконтных карт
//
Процедура ЗаполнитьПризнакИспользованияДисконтныхКарт(ИспользоватьДисконтныеКарты) Экспорт
	
	ИспользоватьДисконтныеКарты = ПолучитьФункциональнуюОпцию("ИспользоватьДисконтныеКарты");
	
КонецПроцедуры
#КонецОбласти

#Область СписаниеБалловПоВладельцу
	
// Процедура дополняет данные о карте в форме списания баллов по владельцу
//
// Параметры:
//  СтрокаПриемник - СтрокаТаблицыЗначений - строка таблицы значений таблицы данных дисконтной карты.
//  СтрокаИсточник - СтрокаТаблицыЗначений - строка таблицы значений источника.
Процедура ДополнитьДанныеОКарте(СтрокаПриемник, СтрокаИсточник) Экспорт
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаИсточник, "ДополнительныеДанные") Тогда
		ДополнитьДанныеОКартеСерверЛояльности(СтрокаПриемник, СтрокаИсточник);
	Иначе
		ДополнитьДанныеОКартеЛокально(СтрокаПриемник, СтрокаИсточник);
	КонецЕсли;
	
КонецПроцедуры

// Процедура объединяет бонусные баллы дисконтных карт
//
// Параметры:
//  БонуснаяПрограмма	 - Строка						 - идентификатор бонусной программы.
//  БонуснаяКарта		 - ОпределяемыйТип.ДисконтнаяКартаРМК	 - Дисконтная карта начисления.
//  ТаблицаВыбранныхКарт - ТаблицаЗначений						 - таблица бонусных карт для объединения.
//  СтруктураОтвета		 - Структура							 - структура ответа по бонусным картам.
//
Процедура ОбъединитьБонусныеБаллы(БонуснаяПрограмма, БонуснаяКарта, ТаблицаВыбранныхКарт, СтруктураОтвета) Экспорт
	Если Не ЗначениеЗаполнено(БонуснаяПрограмма) Тогда
		РеквизитыБонуснойПрограммы = РаботаСБонусами.РеквизитыБонуснойПрограммы(БонуснаяКарта);
		БонуснаяПрограммаСсылка = РеквизитыБонуснойПрограммы.БонуснаяПрограмма;
	Иначе
		БонуснаяПрограммаСсылка = Справочники.БонусныеПрограммы.ПолучитьСсылку(Новый УникальныйИдентификатор(БонуснаяПрограмма));
	КонецЕсли;
	
	ПараметрыМетода = Новый Структура;
	ПараметрыМетода.Вставить("БонуснаяПрограмма", БонуснаяПрограммаСсылка);
	ПараметрыМетода.Вставить("БонуснаяКарта", БонуснаяКарта);
	
	ТаблицаБонусныхКарт = Новый ТаблицаЗначений;
	ТаблицаБонусныхКарт.Колонки.Добавить("БонуснаяКарта", Новый ОписаниеТипов("СправочникСсылка.ДисконтныеКарты"));
	ТаблицаБонусныхКарт.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));

	Для Каждого СтрокаТаблицы Из ТаблицаВыбранныхКарт Цикл
		Если СтрокаТаблицы.КартаНачисления Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ТаблицаБонусныхКарт.Добавить();
		НоваяСтрока.БонуснаяКарта = СтрокаТаблицы.ДисконтнаяКарта;
		НоваяСтрока.Количество = СтрокаТаблицы.ОстатокБонусныхБаллов;
	КонецЦикла;
	
	ПараметрыМетода.Вставить("ТаблицаБонусныхКарт", ТаблицаБонусныхКарт);
	ДисконтныеКартыУНФСервер.ОбъединитьБонусныеКарты(ПараметрыМетода, СтруктураОтвета);
КонецПроцедуры

Процедура ДополнитьДанныеОКартеСерверЛояльности(СтрокаПриемник, СтрокаИсточник)
	СтрокаПриемник.ДатаРождения = СтрокаИсточник.ДополнительныеДанные.DateOfBirth;
	СтрокаПриемник.КартаНедействительна = НЕ СтрокаИсточник.ДополнительныеДанные.Valid;
	СтрокаПриемник.КодКарты = СтрокаИсточник.ДополнительныеДанные.Barcode;
	СтрокаПриемник.КурсБонусов = СтрокаИсточник.ДополнительныеДанные.BonusData.BonusRate;
	СтрокаПриемник.НомерТелефона = СтрокаИсточник.ДополнительныеДанные.Phone;
	СтрокаПриемник.ИдентификаторКарты = СтрокаИсточник.ДополнительныеДанные.CardGUID;
	СтрокаПриемник.ВидДисконтнойКарты = СтрокаИсточник.ДополнительныеДанные.TypeCard;
	СтрокаПриемник.БонуснаяПрограммаНаименование = СтрокаИсточник.ДополнительныеДанные.BonusData.BonusName;
	СтрокаПриемник.БонуснаяПрограмма = СтрокаИсточник.ДополнительныеДанные.BonusData.BonusGUID;
	СтрокаПриемник.МаксимальныйПроцентОплаты = СтрокаИсточник.ДополнительныеДанные.BonusData.PaymentPercent;
КонецПроцедуры

Процедура ДополнитьДанныеОКартеЛокально(СтрокаПриемник, СтрокаИсточник)
	РеквизитыДисконтнойКарты = ОбщегоНазначенияРМКВызовСервера.ЗначенияРеквизитовОбъекта(СтрокаИсточник.ДисконтнаяКарта, "Владелец, ВладелецКарты, КодКартыШтрихкод, КодКартыМагнитный, КартаНедействительна");
	ДанныеВладельцаКарты = ОбщегоНазначенияРМКВызовСервера.ЗначенияРеквизитовОбъекта(РеквизитыДисконтнойКарты.ВладелецКарты, "НомерТелефонаДляПоиска, ДатаРождения");
	ВидДисконтнойКарты = РеквизитыДисконтнойКарты.Владелец;
	СтрокаПриемник.ВидДисконтнойКарты = ВидДисконтнойКарты;
	ТипКарты = ОбщегоНазначенияРМКВызовСервера.ЗначениеРеквизитаОбъекта(ВидДисконтнойКарты, "ТипКарты");
	Если ТипКарты = ПредопределенноеЗначение("Перечисление.ТипыКарт.Магнитная") Тогда
		СтрокаПриемник.КодКарты = РеквизитыДисконтнойКарты.КодКартыМагнитный;
	Иначе
		СтрокаПриемник.КодКарты = РеквизитыДисконтнойКарты.КодКартыШтрихкод;
	КонецЕсли;
	СтрокаПриемник.НомерТелефона = ДанныеВладельцаКарты.НомерТелефонаДляПоиска;
	СтрокаПриемник.ДатаРождения = ДанныеВладельцаКарты.ДатаРождения;
	СтрокаПриемник.КартаНедействительна = РеквизитыДисконтнойКарты.КартаНедействительна;
	РеквизитыБонуснойПрограммыКарта = РаботаСБонусами.РеквизитыБонуснойПрограммы(СтрокаПриемник.ДисконтнаяКарта);
	Если ЗначениеЗаполнено(РеквизитыБонуснойПрограммыКарта.БонуснаяПрограмма) Тогда
		СтрокаПриемник.КурсБонусов = РеквизитыБонуснойПрограммыКарта.КурсБонусов;
		СтрокаПриемник.ИдентификаторКарты = Строка(СтрокаИсточник.ДисконтнаяКарта.УникальныйИдентификатор());
		СтрокаПриемник.БонуснаяПрограмма = Строка(РеквизитыБонуснойПрограммыКарта.БонуснаяПрограмма.УникальныйИдентификатор());
		СтрокаПриемник.БонуснаяПрограммаНаименование = РеквизитыБонуснойПрограммыКарта.БонуснаяПрограмма;
		СтрокаПриемник.МаксимальныйПроцентОплаты = РеквизитыБонуснойПрограммыКарта.МаксимальныйПроцентОплаты;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

// Возвращает режим записи документа ЧекККМКоррекции.
//
// Возвращаемое значение:
//  РежимЗаписиДокумента - режим, который необходим при записи документа ЧекККМ.
//
Функция РежимЗаписиКоррекции()
	
	Возврат РежимЗаписиДокумента.Запись;
	
КонецФункции

// Заполняет соответствие применяемых в СНО ставок НДС для чека коррекции
//
// Параметры:
//  СтавкиНДСПоСНО - Соответствие - Список значения ставок НДС по ключу Системы налогообложения.
//
// Пример:
//	Ключ: УСН
//	Значение: СписокЗначений ставок НДС (22, 10, 0, БезНДС, 5, 7)
//
Процедура ЗаполнитьСоответствиеСтавокНДСДляЧекаКоррекции(СтавкиНДСПоСНО) Экспорт
	
	СтавкаОбщая = Справочники.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Общая);
	НаименованиеОбщая = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтавкаОбщая, "Наименование");
	
	СтавкаПониженная = Справочники.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Пониженная);
	НаименованиеПониженная = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтавкаПониженная, "Наименование");
	
	СтавкаНулевая = Справочники.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Нулевая);
	НаименованиеНулевая = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтавкаНулевая, "Наименование");
	
	СтавкаОбщаяУСН = Справочники.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.ОбщаяУСН);
	НаименованиеОбщаяУСН = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтавкаОбщаяУСН, "Наименование");
	
	СтавкаПониженнаяУСН = Справочники.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.ПониженнаяУСН);
	НаименованиеПониженнаяУСН = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтавкаПониженнаяУСН, "Наименование");
	
	СтавкаБезНДС = Справочники.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.БезНДС);
	НаименованиеБезНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтавкаБезНДС, "Наименование");
	
	Ключ = Перечисления.ТипыСистемНалогообложенияККТ.ОСН;
	Значение = Новый СписокЗначений;
	Значение.Добавить(СтавкаОбщая,      НаименованиеОбщая);
	Значение.Добавить(СтавкаПониженная, НаименованиеПониженная);
	Значение.Добавить(СтавкаНулевая,    НаименованиеНулевая);
	
	СтавкиНДСПоСНО.Вставить(Ключ, Значение);
	
	Ключ = Перечисления.ТипыСистемНалогообложенияККТ.ЕСН;
	Значение = Новый СписокЗначений;
	Значение.Добавить(СтавкаОбщая,      НаименованиеОбщая);
	Значение.Добавить(СтавкаПониженная, НаименованиеПониженная);
	Значение.Добавить(СтавкаНулевая,    НаименованиеНулевая);
	
	СтавкиНДСПоСНО.Вставить(Ключ, Значение);
	
	Ключ = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоход;
	Значение = Новый СписокЗначений;
	Значение.Добавить(СтавкаОбщая,         НаименованиеОбщая);
	Значение.Добавить(СтавкаПониженная,    НаименованиеПониженная);
	Значение.Добавить(СтавкаНулевая,       НаименованиеНулевая);
	Значение.Добавить(СтавкаОбщаяУСН,      НаименованиеОбщаяУСН);
	Значение.Добавить(СтавкаПониженнаяУСН, НаименованиеПониженнаяУСН);
	Значение.Добавить(СтавкаБезНДС,        НаименованиеБезНДС);
	
	СтавкиНДСПоСНО.Вставить(Ключ, Значение);
	
	Ключ = Перечисления.ТипыСистемНалогообложенияККТ.УСНДоходРасход;
	Значение = Новый СписокЗначений;
	Значение.Добавить(СтавкаОбщая,         НаименованиеОбщая);
	Значение.Добавить(СтавкаПониженная,    НаименованиеПониженная);
	Значение.Добавить(СтавкаНулевая,       НаименованиеНулевая);
	Значение.Добавить(СтавкаОбщаяУСН,      НаименованиеОбщаяУСН);
	Значение.Добавить(СтавкаПониженнаяУСН, НаименованиеПониженнаяУСН);
	Значение.Добавить(СтавкаБезНДС,        НаименованиеБезНДС);
	
	СтавкиНДСПоСНО.Вставить(Ключ, Значение);
	
КонецПроцедуры

#Область ВыборСкладаИЯчейкиПриПродаже

Процедура НастроитьФормуВыбораСкладЯчейка(Форма)
	
	ВыборЯчейки = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Параметры, "ВыборЯчейки") Тогда
		ВыборЯчейки = Истина;
	КонецЕсли;
	
	// Добавим реквизиты на форму
	ДобавляемыеРеквизиты = Новый Массив;
	
	НовыйРеквизит = Новый РеквизитФормы("ВыборЯчейки", Новый ОписаниеТипов("Булево"), , НСтр("ru = 'Выбор ячейки'"));
	ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
	
	НовыйРеквизит = Новый РеквизитФормы("Организация",
	Новый ОписаниеТипов("СправочникСсылка.Организации"), , НСтр("ru = 'Организация'"));
	ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
	
	НовыйРеквизит = Новый РеквизитФормы("Номенклатура",
	Новый ОписаниеТипов("СправочникСсылка.Номенклатура"), , НСтр("ru = 'Номенклатура'"));
	ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
	
	НовыйРеквизит = Новый РеквизитФормы("Характеристика",
	Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"), , НСтр("ru = 'Характеристика'"));
	ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
	
	Если ВыборЯчейки Тогда
		
		НовыйРеквизит = Новый РеквизитФормы("ЯчейкаПоУмолчанию",
			Новый ОписаниеТипов("СправочникСсылка.Ячейки"), , НСтр("ru = 'Ячейка по умолчанию'"));
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
		
		НовыйРеквизит = Новый РеквизитФормы("НеЗадаватьВопросПриВыбореЯчейки",
			Новый ОписаниеТипов("Булево"), , НСтр("ru = 'Не задавать вопрос при выборе ячейки'"));
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
		
	КонецЕсли;
	
	Форма.ИспользоватьНастройкиКаталога = Истина;
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Параметры, "Организация") Тогда
		Форма.Организация = Форма.Параметры.Организация;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Параметры, "Номенклатура") Тогда
		Форма.Номенклатура = Форма.Параметры.Номенклатура;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Параметры, "Характеристика") Тогда
		Форма.Характеристика = Форма.Параметры.Характеристика;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Параметры, "ОтображатьОстаток") Тогда
		Форма.ОтображатьОстаток = Форма.Параметры.ОтображатьОстаток;
	КонецЕсли;
	
	// Заполним значения реквизитов
	Форма.ВыборЯчейки = ВыборЯчейки;
	ВосстановитьНастройкиФормыВыбораСкладЯчейка(Форма);
	
	Если НЕ ВыборЯчейки Тогда
		Форма.Элементы.НастройкаКаталогаДанныеСтрокиПоУмолчанию.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если НЕ Форма.Номенклатура.Пустая() Тогда
		РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Форма.Номенклатура, "Ячейка, Склад");
		Если РеквизитыНоменклатуры.Склад = Форма.Параметры.Склад Тогда
			Форма.ЯчейкаПоУмолчанию = РеквизитыНоменклатуры.Ячейка;
		КонецЕсли;
	КонецЕсли;
	
	ОтборЯчейкаПоУмолчанию = Форма.Элементы.НастройкаКаталогаДанныеСтрокиПоУмолчанию;
	ОтборЯчейкаПоУмолчанию.Заголовок = СтрЗаменить(ОтборЯчейкаПоУмолчанию.Заголовок,
		НСтр("ru = 'Данные строки'"), НСтр("ru = 'Ячейка'"));
	
КонецПроцедуры

Процедура СохранитьНастройкиФормыВыбораСкладЯчейка(Форма)
	
	ВыборЯчейки = Форма.ВыборЯчейки;
	
	СписокНастроек = Новый Соответствие;
	СписокНастроек.Вставить("НастройкиСписка", Форма.Список.КомпоновщикНастроек.Настройки);
	СписокНастроек.Вставить("НастройкаКаталогаНастройкиПолей", Форма.НастройкаКаталогаНастройкиПолей.Выгрузить());
	СписокНастроек.Вставить("ПользовательскиеНастройкиСписка",
		Форма.Список.КомпоновщикНастроек.ПользовательскиеНастройки);
	
	Если ВыборЯчейки Тогда
		ИмяКлючаОбъекта = "Обработка.РабочееМестоКассира.Форма.ФормаВыбораСкладЯчейка/НастройкиДополнительныеВыборЯчейки";
		СписокНастроек.Вставить("НеЗадаватьВопросПриВыбореЯчейки", Форма.НеЗадаватьВопросПриВыбореЯчейки);
	Иначе
		ИмяКлючаОбъекта = "Обработка.РабочееМестоКассира.Форма.ФормаВыбораСкладЯчейка/НастройкиДополнительныеВыборСклада";
	КонецЕсли;
	
	ХранилищеСистемныхНастроек.Сохранить(ИмяКлючаОбъекта, "НастройкиДополнительные", СписокНастроек);
	
КонецПроцедуры

Процедура ВосстановитьНастройкиФормыВыбораСкладЯчейка(Форма)
	
	ВыборЯчейки = Форма.ВыборЯчейки;
	
	Форма.Список.АвтоматическоеСохранениеПользовательскихНастроек = Ложь;
	
	Если ВыборЯчейки Тогда
		ИмяКлючаОбъекта = "Обработка.РабочееМестоКассира.Форма.ФормаВыбораСкладЯчейка/НастройкиДополнительныеВыборЯчейки";
	Иначе
		ИмяКлючаОбъекта = "Обработка.РабочееМестоКассира.Форма.ФормаВыбораСкладЯчейка/НастройкиДополнительныеВыборСклада";
	КонецЕсли;

	СписокНастроекДляЗагрузки = ХранилищеСистемныхНастроек.Загрузить(ИмяКлючаОбъекта, "НастройкиДополнительные");
	
	Если СписокНастроекДляЗагрузки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Настройка Из СписокНастроекДляЗагрузки Цикл
		Если Настройка.Ключ = "НастройкиСписка" Тогда
			Форма.Список.КомпоновщикНастроек.ЗагрузитьНастройки(Настройка.Значение);
		ИначеЕсли Настройка.Ключ = "НастройкаКаталогаНастройкиПолей" Тогда
			Форма.НастройкаКаталогаНастройкиПолей.Загрузить(Настройка.Значение);
		ИначеЕсли Настройка.Ключ = "ПользовательскиеНастройкиСписка" Тогда
			Форма.Список.КомпоновщикНастроек.ЗагрузитьПользовательскиеНастройки(Настройка.Значение);
		ИначеЕсли Настройка.Ключ = "НеЗадаватьВопросПриВыбореЯчейки" Тогда
			Форма.НеЗадаватьВопросПриВыбореЯчейки = Настройка.Значение
		Иначе
			// Настройку загружать не нужно
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

Процедура НастроитьФормуВыбораПокупателя(Форма)
	
	ТекстЗапроса = "ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Покупатель
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	НЕ Контрагенты.ПометкаУдаления
	|	И НЕ Контрагенты.ЭтоГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	Покупатель";
	Форма.СписокПокупателей.ТекстЗапроса = ТекстЗапроса;
	
КонецПроцедуры

// Получает настройки ТСПИоТ для переданного фискального накопителя
// Параметры:
//  НастройкиТСПИоТ - Структура
//                  * НастроенТСПИоТ - Булево - признак наличия настроек
//                  * ПодключаемоеОборудование - СправочникСсылка.ПодключаемоеОборудование - ККМ
//  СтрокаКассыККМ - СтрокаТаблицыЗначений - Параметры кассы и организации
//  Форма - ФормаКлиентскогоПриложения - данные формы РМК.
//
Процедура НастройкиТСПИоТ(НастройкиТСПИоТ, СтрокаКассыККМ, Форма) Экспорт
	
	НомерФискальногоНакопителя = СтрокаКассыККМ.НомерФискальногоНакопителя;
	ПодключаемоеОборудование = СтрокаКассыККМ.ИдентификаторУстройства;
	НастройкиТСПИоТ.ПодключаемоеОборудование = СтрокаКассыККМ.ИдентификаторУстройства;
	НастроенТСПИоТ = Ложь;
	ВнешнийТСПИоТ = Ложь;
	
	Если ЗначениеЗаполнено(НомерФискальногоНакопителя) Тогда
		
		НастроенТСПИоТ = ИнтеграцияТСПИоТ.ПоПодключаемомуОборудованиюНастроеноПодключениеТСПИоТ(ПодключаемоеОборудование, НомерФискальногоНакопителя);
		
		Если НастроенТСПИоТ Тогда
			
			МодульМенеджера = ОбщегоНазначения.ОбщийМодуль("МенеджерОборудованияТСПИоТ");
			НастроенныйТСПИоТ = МодульМенеджера.ПолучитьТСПИоТ(ПодключаемоеОборудование);
			
			Если ЗначениеЗаполнено(НастроенныйТСПИоТ) Тогда
				
				Если НастроенныйТСПИоТ.Тип = Перечисления.ТипыТСПИоТ.Внешний Тогда
					
					ВнешнийТСПИоТ = Истина;
					
				КонецЕсли;
				
			КонецЕсли;
				
		КонецЕсли;
		
	КонецЕсли;
	
	НастройкиТСПИоТ.НастроенТСПИоТ = НастроенТСПИоТ;
	НастройкиТСПИоТ.ВнешнийТСПИоТ = ВнешнийТСПИоТ;
	
КонецПроцедуры

Процедура НастроитьЭлементОтображатьНаименованиеДляПечати(Форма)
	
	Форма.Элементы.НастройкаРМКОтображатьНаименованиеДляПечати.Видимость = Истина;
	
КонецПроцедуры

Процедура НастроитьГруппуУдалятьАрхивныеЧеки(Форма)
	
	Форма.Элементы.ГруппаОчисткаАрхивныхЧеков.Видимость = Ложь;
	
КонецПроцедуры

Процедура УстановитьОтображениеНаименованияДляПечатиВПалитреТоваров(Форма)
	
	УстановитьПривилегированныйРежим(Истина);
	РабочееМесто = МенеджерОборудованияВызовСервера.РабочееМестоКлиента();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиРабочегоМестаКассира.ОтображатьНаименованиеДляПечати КАК ОтображатьНаименованиеДляПечати
		|ИЗ
		|	Справочник.НастройкиРабочегоМестаКассира КАК НастройкиРабочегоМестаКассира
		|ГДЕ
		|	НЕ НастройкиРабочегоМестаКассира.ПометкаУдаления
		|	И НастройкиРабочегоМестаКассира.РабочееМесто = &РабочееМесто";
	
	Запрос.УстановитьПараметр("РабочееМесто", РабочееМесто);
	ВыборкаНастроек = Запрос.Выполнить().Выбрать();
	Если ВыборкаНастроек.Количество() = 1 И ВыборкаНастроек.Следующий() Тогда
		Форма.ОтображатьНаименованиеДляПечати = ВыборкаНастроек.ОтображатьНаименованиеДляПечати;
	КонецЕсли;
	
КонецПроцедуры

Процедура НастроитьФормуНастройкиMAX(Форма, Отказ, СтандартнаяОбработка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Организации.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	НЕ Организации.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Организации = РезультатЗапроса.ВыгрузитьКолонку("Ссылка");
	
	Если Организации.Количество() = 0 Тогда
		Форма.ТекстОшибкиОткрытияФормы = НСтр("ru = 'Не найдена организация.'");
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	КлючБезопасногоХранилища = КлючБезопасногоХранилищаСТокеномMAX();
	Если Организации.Количество() = 1 Тогда
		Форма.Элементы.ВариантыИнтерфейса.ТекущаяСтраница = Форма.Элементы.ОднаОрганизация;
		Форма.Элементы.НесколькоОрганизаций.Видимость = Ложь;
		
		Организация = Организации[0];
		ТокенОрганизацииMAX = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(Организация,
			КлючБезопасногоХранилища);
		НовыйПараметрПодключенияMAX = Форма.ПараметрыПодключенияMAX.Добавить();
		НовыйПараметрПодключенияMAX.Организация = Организация;
		Если ЗначениеЗаполнено(ТокенОрганизацииMAX) Тогда
			НовыйПараметрПодключенияMAX.Токен = ТокенОрганизацииMAX;
			Форма.ОрганизацииСохраненныхЗаписей.Добавить(Организация);
		КонецЕсли;
	Иначе
		Форма.Элементы.ВариантыИнтерфейса.ТекущаяСтраница = Форма.Элементы.НесколькоОрганизаций;
		Форма.Элементы.ОднаОрганизация.Видимость = Ложь;
		ПараметрыВыбора = Новый Массив;
		ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.ПометкаУдаления", Ложь));
		Форма.Элементы.ПараметрыПодключенияMAXОрганизация.ПараметрыВыбора = Новый ФиксированныйМассив(
			ПараметрыВыбора);
		
		ТокеныОрганизацийMAX = ОбщегоНазначения.ПрочитатьДанныеВладельцевИзБезопасногоХранилища(Организации,
			КлючБезопасногоХранилища);
		Для каждого ТокенОрганизацииMAX Из ТокеныОрганизацийMAX Цикл
			Если ЗначениеЗаполнено(ТокенОрганизацииMAX.Значение) Тогда
				НовыйПараметрПодключенияMAX = Форма.ПараметрыПодключенияMAX.Добавить();
				НовыйПараметрПодключенияMAX.Организация = ТокенОрганизацииMAX.Ключ;
				НовыйПараметрПодключенияMAX.Токен = ТокенОрганизацииMAX.Значение;
				
				Форма.ОрганизацииСохраненныхЗаписей.Добавить(ТокенОрганизацииMAX.Ключ);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Функция КлючБезопасногоХранилищаСТокеномMAX()
	Возврат "ТокенОрганизацииMAX";
КонецФункции

#КонецОбласти
