	|			И (ИтоговаяТаблицаТовары.СтруктурнаяЕдиница = ТаблицаОстатокСерий.СтруктурнаяЕдиница)
	|			И (ИтоговаяТаблицаТовары.Организация = ТаблицаОстатокСерий.Организация)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаИтоговоеКоличество.Номенклатура КАК Номенклатура,
	|	ТаблицаИтоговоеКоличество.Характеристика КАК Характеристика,
	|	ТаблицаИтоговоеКоличество.Серия КАК Серия,
	|	ТаблицаИтоговоеКоличество.Количество КАК Количество,
	|	ТаблицаИтоговоеКоличество.Партия КАК Партия,
	|	ТаблицаИтоговоеКоличество.НомерСтроки КАК НомерСтроки,
	|	ТаблицаИтоговоеКоличество.Организация КАК Организация,
	|	ТаблицаИтоговоеКоличество.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ТаблицаИтоговоеКоличество.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаИтоговоеКоличество.КоличествоОстаток КАК КоличествоОстаток,
	|	ТаблицаИтоговоеКоличество.КоличествоОстатокСерий КАК КоличествоОстатокСерий,
	|	ТаблицаИтоговоеКоличество.КоличествоОбщийОстатокСерий КАК КоличествоОбщийОстатокСерий,
	|	ТаблицаИтоговоеКоличество.КоличествоРезерв КАК КоличествоРезерв,
	|	ВЫБОР
	|		КОГДА ТаблицаИтоговоеКоличество.ЕдиницаИзмерения ССЫЛКА Справочник.ЕдиницыИзмерения
	|			ТОГДА ЕСТЬNULL(СпрЕдиницыИзмерения.Коэффициент, 1)
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Коэффициент,
	|	ТаблицаИтоговоеКоличество.ЕдиницаИзмеренияПредставление КАК ЕдиницаИзмеренияПредставление
	|ПОМЕСТИТЬ ТаблицаИтог
	|ИЗ
	|	ТаблицаИтоговоеКоличество КАК ТаблицаИтоговоеКоличество
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК СпрЕдиницыИзмерения
	|		ПО ТаблицаИтоговоеКоличество.ЕдиницаИзмерения = СпрЕдиницыИзмерения.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаИтог.Номенклатура КАК Номенклатура,
	|	ТаблицаИтог.Характеристика КАК Характеристика,
	|	ТаблицаИтог.Партия КАК Партия,
	|	ТаблицаИтог.Серия КАК Серия,
	|	МАКСИМУМ(ЕСТЬNULL(СпрСерииНоменклатуры.Наименование, """")) КАК СерияНаименование,
	|	ТаблицаИтог.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СУММА(ТаблицаИтог.Количество) КАК Количество,
	|	МАКСИМУМ(ТаблицаИтог.КоличествоОстаток) КАК КоличествоОстаток,
	|	МАКСИМУМ(ТаблицаИтог.КоличествоОстатокСерий) КАК КоличествоОстатокСерий,
	|	МАКСИМУМ(ТаблицаИтог.КоличествоОбщийОстатокСерий) КАК КоличествоОбщийОстатокСерий,
	|	МАКСИМУМ(ТаблицаИтог.КоличествоРезерв) КАК КоличествоРезерв,
	|	МАКСИМУМ(ЕСТЬNULL(СпрСтруктурныеЕдиницы.ТипСтруктурнойЕдиницы, ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.ПустаяСсылка))) КАК ТипСтруктурнойЕдиницы,
	|	МАКСИМУМ(ТаблицаИтог.ЕдиницаИзмеренияПредставление) КАК ЕдиницаИзмеренияПредставление,
	|	МАКСИМУМ(ТаблицаИтог.НомерСтроки) КАК НомерСтроки,
	|	МАКСИМУМ(ТаблицаИтог.Коэффициент) КАК Коэффициент
	|ИЗ
	|	ТаблицаИтог КАК ТаблицаИтог
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СпрСтруктурныеЕдиницы
	|		ПО ТаблицаИтог.СтруктурнаяЕдиница = СпрСтруктурныеЕдиницы.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СерииНоменклатуры КАК СпрСерииНоменклатуры
	|		ПО ТаблицаИтог.Серия = СпрСерииНоменклатуры.Ссылка
	|ГДЕ
	|	ИСТИНА";
	
	ДополнитьЗапросДляУчетаИсключенийКонтроляОстатков(Запрос);
	
	ТекстИтогов = " 
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаИтог.Номенклатура,
	|	ТаблицаИтог.Характеристика,
	|	ТаблицаИтог.Партия,
	|	ТаблицаИтог.СтруктурнаяЕдиница,
	|	ТаблицаИтог.Серия
	|ИТОГИ
	|	СУММА(Количество),
	|	МАКСИМУМ(КоличествоОстаток),
	|	МАКСИМУМ(КоличествоОстатокСерий),
	|	МАКСИМУМ(КоличествоОбщийОстатокСерий),
	|	МАКСИМУМ(КоличествоРезерв),
	|	МАКСИМУМ(ТипСтруктурнойЕдиницы),
	|	МАКСИМУМ(ЕдиницаИзмеренияПредставление),
	|	МАКСИМУМ(НомерСтроки),
	|	МАКСИМУМ(Коэффициент)
	|ПО
	|	СтруктурнаяЕдиница,
	|	Номенклатура,
	|	Характеристика,
	|	Партия";
	
	Запрос.Текст = СтрШаблон("%1%2", Запрос.Текст, ТекстИтогов);
	
КонецПроцедуры

Процедура ДополнитьЗапросДляУчетаИсключенийКонтроляОстатков(ОсновнойЗапрос)
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТаблицаТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ТаблицаТовары
	|ИЗ
	|	&ТаблицаТовары КАК ТаблицаТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТовары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасы
	|ИЗ
	|	ТаблицаТовары КАК ТаблицаТовары
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТаблицаТовары");
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаТовары", ОсновнойЗапрос.Параметры.ТаблицаТовары);
	Запрос.Выполнить();
	
	ПроведениеДокументовУНФ.ПодготовитьВременныеТаблицыИсключенийКонтроляОстатков(МенеджерВременныхТаблиц);
	
	ОсновнойЗапрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	ТекстУсловия = "
	|	И НЕ (ТаблицаИтог.Номенклатура, ТаблицаИтог.СтруктурнаяЕдиница) В
	|				(ВЫБРАТЬ
	|					НоменклатураСкладыБезКонтроля.Номенклатура КАК Номенклатура,
	|					НоменклатураСкладыБезКонтроля.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|				ИЗ
	|					НоменклатураСкладыБезКонтроля КАК НоменклатураСкладыБезКонтроля)
	|	И НЕ ТаблицаИтог.СтруктурнаяЕдиница В
	|				(ВЫБРАТЬ
	|					СкладыБезКонтроля.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
	|				ИЗ
	|					СкладыБезКонтроля КАК СкладыБезКонтроля)";
	ОсновнойЗапрос.Текст = ОсновнойЗапрос.Текст + ТекстУсловия;
	
КонецПроцедуры

Процедура ДополнитьТекстОшибкиПроверкиНаличияТовара(Форма, ПараметрыПроверки, Выборка, ДоступныйОстаток, ТекстОшибки)
	
	Коэффициент = ?(Выборка.Коэффициент = 0, 1, Выборка.Коэффициент);
	НедостающееКоличество = Выборка.Количество - ДоступныйОстаток;
	
	Форма.Элементы.Товары.ТекущаяСтрока = Форма.Объект.Товары[Выборка.НомерСтроки - 1].ПолучитьИдентификатор();
		
	Если (НЕ ПараметрыПроверки.УчетПоНесколькимСкладам
			И Выборка.ТипСтруктурнойЕдиницы = Перечисления.ТипыСтруктурныхЕдиниц.Склад)
			ИЛИ (НЕ ПараметрыПроверки.УчетПоНесколькимПодразделениям
			И Выборка.ТипСтруктурнойЕдиницы = Перечисления.ТипыСтруктурныхЕдиниц.Подразделение) Тогда
			
			ПредставлениеСтруктурнойЕдиницы = "";
	Иначе
		ПредставлениеСтруктурнойЕдиницы = Справочники.СтруктурныеЕдиницы.Представление(
			Выборка.СтруктурнаяЕдиница);
	КонецЕсли;
	
	ПредставлениеНоменклатуры = Справочники.Номенклатура.Представление(Выборка.Номенклатура, Выборка.Характеристика,
		Выборка.Партия);
	Если ЗначениеЗаполнено(Выборка.Серия) Тогда
		ПредставлениеНоменклатуры = СтрШаблон("%1, %2", ПредставлениеНоменклатуры, Выборка.СерияНаименование);
	КонецЕсли;
	
	ТекстСообщения = СтрЗаменить(ПараметрыПроверки.ШаблонСообщения,
		"%НоменклатураХарактеристикаПартия%", ПредставлениеНоменклатуры);
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ТипСтруктурнойЕдиницы%",
		Перечисления.ТипыСтруктурныхЕдиниц.Представление(Выборка.ТипСтруктурнойЕдиницы));
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%СтруктурнаяЕдиницаПредставление%", ПредставлениеСтруктурнойЕдиницы);
	
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%КоличествоОстаток%", ДоступныйОстаток / Коэффициент);
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Количество%", НедостающееКоличество / Коэффициент);
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ЕдиницаИзмерения%",
		СокрЛП(Выборка.ЕдиницаИзмеренияПредставление));
		
	СимволРазделитель = ?(ПараметрыПроверки.КонтрольОстатковПройден, "", Символы.ПС);
	ТекстОшибки = СтрШаблон("%1%2%3%4", ТекстОшибки, СимволРазделитель, ТекстСообщения, Символы.ПС);
	
	ПараметрыПроверки.КонтрольОстатковПройден = Ложь;
	
КонецПроцедуры

Процедура ОбойтиВыборкуОстаткаТовара(Форма, ПараметрыПроверки, ВыборкаУровня, Знач НомерУровня, ТекстОшибки)
	
	УровеньПартии = 4;
	
	Если НомерУровня < УровеньПартии Тогда
		ВыборкаПодУровня = ВыборкаУровня.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПодУровня.Следующий() Цикл
			ОбойтиВыборкуОстаткаТовара(Форма, ПараметрыПроверки, ВыборкаПодУровня, НомерУровня + 1, ТекстОшибки);
		КонецЦикла;
	Иначе
		ДоступныйОстаток = ВыборкаУровня.КоличествоОстаток + ВыборкаУровня.КоличествоОбщийОстатокСерий
			- ВыборкаУровня.КоличествоРезерв;
		Если ВыборкаУровня.Количество > ДоступныйОстаток Тогда
			ДополнитьТекстОшибкиПроверкиНаличияТовара(Форма, ПараметрыПроверки, ВыборкаУровня, ДоступныйОстаток, ТекстОшибки);
		Иначе
			ВыборкаСерии = ВыборкаУровня.Выбрать();
			Пока ВыборкаСерии.Следующий() Цикл
				ДоступныйОстаток = ВыборкаСерии.КоличествоОстаток + ВыборкаСерии.КоличествоОстатокСерий;
				Если ВыборкаСерии.Количество > ДоступныйОстаток Тогда
					ДополнитьТекстОшибкиПроверкиНаличияТовара(Форма, ПараметрыПроверки, ВыборкаСерии, ДоступныйОстаток, ТекстОшибки);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьЗаполнениеПалитрыПоСегментуНоменклатуры(Форма)
	
	ОсновнойВид = Ложь;
	Если ТипЗнч(Форма.Объект.ИсточникЗаполнения) = Тип("СправочникСсылка.СегментыНоменклатуры") Тогда
		ОсновнойВид = Истина;
	КонецЕсли;
	
	ИмяСпособа = "ПоСегментуНоменклатуры";
	СинонимСпособа = НСтр("ru = 'По сегменту номенклатуры'");
	ДобавитьЗаполнениеПалитрыПоСпособу(Форма, ИмяСпособа, СинонимСпособа, ОсновнойВид);
	
КонецПроцедуры

Процедура ДобавитьЗаполнениеПалитрыПоКатегорииНоменклатуры(Форма)
	
	ОсновнойВид = Ложь;
	Если ТипЗнч(Форма.Объект.ИсточникЗаполнения) = Тип("СправочникСсылка.КатегорииНоменклатуры") Тогда
		ОсновнойВид = Истина;
	КонецЕсли;
	
	ИмяСпособа = "ПоКатегории";
	СинонимСпособа = НСтр("ru = 'По категории'");
	ДобавитьЗаполнениеПалитрыПоСпособу(Форма, ИмяСпособа, СинонимСпособа, ОсновнойВид);
	
КонецПроцедуры

Процедура ДобавитьЗаполнениеПалитрыПоСпособу(Форма, ИмяСпособа, СинонимСпособа, ОсновнойВид)
	
	Элементы = Форма.Элементы;
	ГруппаЗаполнить = Элементы.ИерархияТоваровГруппаЗаполнить;
	
	НачалоИмениКоманды = "ИерархияТоваровЗаполнить";
	ИмяДействия = "Подключаемый_ЗаполнитьНоменклатуру";
	
	ИмяКнопкиКоманды = СтрШаблон("%1%2", НачалоИмениКоманды, ИмяСпособа);
	НоваяКоманда = Форма.Команды.Добавить(ИмяКнопкиКоманды);
	НоваяКоманда.Действие = ИмяДействия;
	
	КнопкаОсновногоМеню = Элементы.Добавить(ИмяКнопкиКоманды, Тип("КнопкаФормы"), ГруппаЗаполнить);
	КнопкаОсновногоМеню.Заголовок = СинонимСпособа;
	КнопкаОсновногоМеню.ИмяКоманды = ИмяКнопкиКоманды;
	КнопкаОсновногоМеню.Отображение = ОтображениеКнопки.Текст;
	КнопкаОсновногоМеню.Пометка = ОсновнойВид;
	
КонецПроцедуры

Процедура НастроитьФормуСпискаКонтроляПродаж(Форма)

	Форма.Элементы.ИспользованиеАвтономно.Видимость = Ложь;
	Форма.Элементы.Использование.Видимость = Истина;
	
КонецПроцедуры

Процедура НастроитьФормуЭлементаКонтроляПродаж(Форма)
	
	Форма.АвтономнаяЛогикаИспользования = Ложь;
	
КонецПроцедуры

Процедура НастроитьФормуОтчетаСоставПалитры(Форма)
	
	ДобавитьПараметрыЗапросаЦенНаФорму(Форма);
	Форма.КолонкиОтбораЦен.Добавить("Характеристика");
	Форма.ТекстЗапросаЦен = СформироватьТекстЗапросаЦенНоменклатурыПалитры();
	Форма.СмещениеДляТаблицыЦен = 1;
	
КонецПроцедуры

Процедура НастроитьФормуАвторизации(Форма)
	
	УстановитьПривилегированныйРежим(Истина);
	Форма.ИспользуетсяТорговыйОбъект = Истина;
	Форма.Элементы.ГруппаВыборМагазинаДляВхода.Видимость = Истина;
	ТекстПодсказки = НСтр("ru = 'От выбора магазина зависит, какие кассы ККМ будут подключены к РМК.
		|Кассы ККМ определяются складами, которые входят в группу выбранного магазина.'");
	Форма.Элементы.ТорговыйОбъектДляВхода.Подсказка = ТекстПодсказки;
	Форма.Элементы.ТорговыйОбъектДляВхода.ОтображениеПодсказки = ОтображениеПодсказки.Кнопка;
	
	СтруктурныеЕдиницы = Новый Массив;
	СтруктурныеЕдиницы.Добавить(Перечисления.ТипыСтруктурныхЕдиниц.Склад);
	СтруктурныеЕдиницы.Добавить(Перечисления.ТипыСтруктурныхЕдиниц.Розница);
	СтруктурныеЕдиницы.Добавить(Перечисления.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов);
	СтруктурныеЕдиницы.Добавить(Перечисления.ТипыСтруктурныхЕдиниц.Подразделение);
	
	ЗначенияВыбора = Новый ФиксированныйМассив(СтруктурныеЕдиницы);
	ПараметрВыбора = Новый ПараметрВыбора("Отбор.ТипСтруктурнойЕдиницы", ЗначенияВыбора);
	
	Параметры = Новый Массив();
	Параметры.Добавить(ПараметрВыбора);
	
	Форма.Элементы.ТорговыйОбъектДляВхода.ПараметрыВыбора = Новый ФиксированныйМассив(Параметры);
	Если Не ЗначениеЗаполнено(Форма.ТорговыйОбъектДляВхода) Тогда
		ОпределитьТекущийТорговыйОбъект(Форма.ТорговыйОбъектДляВхода);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПараметрыЗапросаЦенНаФорму(Форма)

	ИмяРеквизитаВидЦены = "ВидЦены";
	СинонимВидЦены = НСтр("ru = 'Вид цены'");
	Форма.ПараметрыЗапросаЦен.Добавить(ИмяРеквизитаВидЦены, СинонимВидЦены);
	
	ТипРеквизитаВидЦены = Новый ОписаниеТипов(Метаданные.ОпределяемыеТипы.ВидЦеныРМК.Тип);
	РеквизитВидЦены = Новый РеквизитФормы(ИмяРеквизитаВидЦены, ТипРеквизитаВидЦены, , СинонимВидЦены);
	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(РеквизитВидЦены);
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	ПолеВидЦены = Форма.Элементы.Добавить(ИмяРеквизитаВидЦены, Тип("ПолеФормы"), Форма.Элементы.ГруппаВариантСЦеной);
	ПолеВидЦены.ПутьКДанным = ИмяРеквизитаВидЦены;
	ПолеВидЦены.Вид = ВидПоляФормы.ПолеВвода;
	ПолеВидЦены.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	ПолеВидЦены.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	ПолеВидЦены.КнопкаВыбора = Истина;
	ПолеВидЦены.РастягиватьПоГоризонтали = Истина;
	
КонецПроцедуры

Функция СформироватьТекстЗапросаЦенНоменклатурыПалитры()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	0 КАК ПорядокХарактеристики,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаОтчета,
	|			ВидЦен = &ВидЦены
	|				И (Номенклатура, Характеристика) В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						СтрокиПалитры.Номенклатура КАК Номенклатура,
	|						СтрокиПалитры.Характеристика КАК Характеристика
	|					ИЗ
	|						втСтрокиПалитры КАК СтрокиПалитры)) КАК ЦеныНоменклатурыСрезПоследних
	|ГДЕ
	|	НЕ ЦеныНоменклатурыСрезПоследних.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	|	1,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика,
	|	ЦеныНоменклатурыСрезПоследних.Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаОтчета,
	|			ВидЦен = &ВидЦены
	|				И Номенклатура В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						СтрокиПалитры.Номенклатура КАК Номенклатура
	|					ИЗ
	|						втСтрокиПалитры КАК СтрокиПалитры)
	|				И Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК ЦеныНоменклатурыСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура,
	|	ПорядокХарактеристики,
	|	Характеристика";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция СформироватьТаблицуНоменклатурыДляПалитрыПоВидуПродукции(ОсобенностьУчета)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Номенклатура.Наименование КАК Наименование,
	|	Номенклатура.Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ВидПродукцииИС = &ОсобенностьУчета";
	Запрос.УстановитьПараметр("ОсобенностьУчета", ОсобенностьУчета);
	ТаблицаНоменклатуры = Запрос.Выполнить().Выгрузить();
	
	Возврат ТаблицаНоменклатуры;
	
КонецФункции

Функция СформироватьТаблицуНоменклатурыДляПалитрыПоОтбору(ВидНоменклатуры, ОсобенностьУчета)
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Номенклатура.Наименование КАК Наименование,
	|	Номенклатура.Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.КатегорияНоменклатуры = &ВидНоменклатуры
	|	И Номенклатура.ВидПродукцииИС = &ОсобенностьУчета";
	
	Если ВидНоменклатуры = Неопределено Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Номенклатура.КатегорияНоменклатуры = &ВидНоменклатуры
			|	И", "");
	КонецЕсли;
	Если ОсобенностьУчета = Неопределено Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И Номенклатура.ВидПродукцииИС = &ОсобенностьУчета", "");
	КонецЕсли;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	Запрос.УстановитьПараметр("ОсобенностьУчета", ОсобенностьУчета);
	
	ТаблицаНоменклатуры = Запрос.Выполнить().Выгрузить();
	Возврат ТаблицаНоменклатуры;
	
КонецФункции

Функция ПолучитьПалитруПоСлужебномуОтбору(ВидНоменклатуры, ОсобенностьУчета)
	
	РезультатФункции = Неопределено;
	
	НаименованиеПалитры = "";
	ОтборВидНоменклатуры = Неопределено;
	ОтборОсобенностьУчета = Неопределено;
	Если ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ОтборВидНоменклатуры = ВидНоменклатуры;
		НаименованиеПалитры = ПолучитьНаименованиеЭлемента(ВидНоменклатуры);
	КонецЕсли;
	Если ЗначениеЗаполнено(ОсобенностьУчета) Тогда
		ОтборОсобенностьУчета = ОсобенностьУчета;
		Если НаименованиеПалитры = "" Тогда
			НаименованиеПалитры = ПолучитьНаименованиеЭлемента(ОсобенностьУчета);
		Иначе
			НаименованиеПалитры = СтрШаблон("%1, %2", НаименованиеПалитры, ПолучитьНаименованиеЭлемента(ОсобенностьУчета));
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ПалитраТоваровРМК.Ссылка КАК Палитра,
	|	ПалитраТоваровРМК.СлужебныйВидНоменклатуры КАК СлужебныйВидНоменклатуры,
	|	ПалитраТоваровРМК.СлужебнаяОсобенностьУчета КАК СлужебнаяОсобенностьУчета
	|ИЗ
	|	Справочник.ПалитраТоваровРМК КАК ПалитраТоваровРМК
	|ГДЕ
	|	НЕ ПалитраТоваровРМК.ПометкаУдаления
	|	И ПалитраТоваровРМК.СлужебныйВидНоменклатуры = &ОтборВидНоменклатуры
	|	И ПалитраТоваровРМК.СлужебнаяОсобенностьУчета = &ОтборОсобенностьУчета";
	
	Если ОтборВидНоменклатуры = Неопределено Тогда
		ТекстЗапроса
			= СтрЗаменить(ТекстЗапроса, "	И ПалитраТоваровРМК.СлужебныйВидНоменклатуры = &ОтборВидНоменклатуры", "");
	Иначе
		Запрос.УстановитьПараметр("ОтборВидНоменклатуры", ОтборВидНоменклатуры);
	КонецЕсли;
	Если ОтборОсобенностьУчета = Неопределено Тогда
		ТекстЗапроса
			= СтрЗаменить(ТекстЗапроса, "	И ПалитраТоваровРМК.СлужебнаяОсобенностьУчета = &ОтборОсобенностьУчета", "");
	Иначе
		Запрос.УстановитьПараметр("ОтборОсобенностьУчета", ОтборОсобенностьУчета);
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	ВыборкаПалитр = Запрос.Выполнить().Выбрать();
	Пока ВыборкаПалитр.Следующий() И РезультатФункции = Неопределено Цикл
		Если ОтборВидНоменклатуры = Неопределено Тогда
			Если Не ЗначениеЗаполнено(ВыборкаПалитр.СлужебныйВидНоменклатуры) Тогда
				РезультатФункции = ВыборкаПалитр.Палитра;
			КонецЕсли;
		ИначеЕсли ОтборОсобенностьУчета = Неопределено Тогда
			Если Не ЗначениеЗаполнено(ВыборкаПалитр.СлужебнаяОсобенностьУчета) Тогда
				РезультатФункции = ВыборкаПалитр.Палитра;
			КонецЕсли;
		Иначе
			РезультатФункции = ВыборкаПалитр.Палитра;
		КонецЕсли;
	КонецЦикла;
	
	Если РезультатФункции = Неопределено Тогда
		ПалитраОбъект = ОбщегоНазначенияРМК.ПолучитьШаблонСлужебнойПалитры(Неопределено, НаименованиеПалитры);
		ТаблицаНоменклатуры = СформироватьТаблицуНоменклатурыДляПалитрыПоОтбору(ОтборВидНоменклатуры, ОтборОсобенностьУчета);
		ЗаполнитьСоставПалитры(ПалитраОбъект, ТаблицаНоменклатуры);
		ПалитраОбъект.СлужебныйВидНоменклатуры = ВидНоменклатуры;
		ПалитраОбъект.СлужебнаяОсобенностьУчета = ОсобенностьУчета;
		Если ПалитраОбъект.Состав.Количество() > 0 Тогда
			ПалитраОбъект.Записать();
			РезультатФункции = ПалитраОбъект.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Процедура ЗаполнитьСоставПалитры(ПалитраОбъект, ТаблицаНоменклатуры)

	ЦветПоУмолчанию = Новый Цвет();
	ЦветСтрокой = ОбщегоНазначения.ЗначениеВСтрокуXML(ЦветПоУмолчанию);
	
	НомерСтроки = 1;
	Для Каждого СтрокаТовара Из ТаблицаНоменклатуры Цикл
		НоваяСтрока = ПалитраОбъект.Состав.Добавить();
		НоваяСтрока.ИндексПозиции = НомерСтроки;
		НоваяСтрока.ИмяЭлемента = СтрокаТовара.Наименование;
		НоваяСтрока.Номенклатура = СтрокаТовара.Номенклатура;
		НоваяСтрока.Шрифт = ПалитраОбъект.ШрифтЭлементовПодбора;
		НоваяСтрока.ЦветШрифта = ЦветСтрокой;
		НоваяСтрока.ЦветФона = ЦветСтрокой;
			
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьОтборНоменклатурыВОписанииКонтроля(ОписаниеКонтроля, ВыборкаОсобенности, СписокТоваровПуст)
	
	Если ЗначениеЗаполнено(ВыборкаОсобенности.ВидНоменклатуры)
			Или ЗначениеЗаполнено(ВыборкаОсобенности.ОсобенностьУчета) Тогда
		НоваяСтрокаОтбора = ОписаниеКонтроля.ОписаниеОтбораНоменклатуры.Добавить();
		НоваяСтрокаОтбора.ВидНоменклатуры = ВыборкаОсобенности.ВидНоменклатуры;
		НоваяСтрокаОтбора.ОсобенностьУчета = ВыборкаОсобенности.ОсобенностьУчета;
		
		СлужебнаяПалитра
			= ПолучитьПалитруПоСлужебномуОтбору(ВыборкаОсобенности.ВидНоменклатуры, ВыборкаОсобенности.ОсобенностьУчета);
		
		Если СлужебнаяПалитра = Неопределено Тогда
			СписокТоваровПуст = Истина;
		Иначе
			НоваяСтрокаОтбора.СлужебнаяПалитра = СлужебнаяПалитра;
		КонецЕсли;
	Иначе
		ОписаниеКонтроля.ВсяНоменклатура = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьОтборТорговыхОбъектовВОписанииКонтроля(ОписаниеКонтроля, Организация, ТаблицаТорговыхОбъектов)
	
	Если ЗначениеЗаполнено(Организация) Тогда
		
		ОтборПоОрганизации = Новый Структура("Организация", Организация);
		СтрокиТорговыхОбъектов = ТаблицаТорговыхОбъектов.НайтиСтроки(ОтборПоОрганизации);
		Для Каждого СтрокаТорговогоОбъекта Из СтрокиТорговыхОбъектов Цикл
			Если ОписаниеКонтроля.ТорговыеОбъекты.Найти(СтрокаТорговогоОбъекта.ТорговыйОбъект) = Неопределено Тогда
				ОписаниеКонтроля.ТорговыеОбъекты.Добавить(СтрокаТорговогоОбъекта.ТорговыйОбъект);
			КонецЕсли;
		КонецЦикла;
		
	Иначе
		ОписаниеКонтроля.ВсеТорговыеОбъекты = Истина;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьНаименованиеЭлемента(ЛюбойЭлемент)
	
	РезультатФункции = "";
	
	ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗнч(ЛюбойЭлемент));
	Если Метаданные.Справочники.Содержит(ОбъектМетаданных) Тогда
		РезультатФункции = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЛюбойЭлемент, "Наименование");
	ИначеЕсли Метаданные.Перечисления.Содержит(ОбъектМетаданных) Тогда
		ИмяВидаПеречисления = ЛюбойЭлемент.Метаданные().Имя;
		ИндексЗначения = Перечисления[ИмяВидаПеречисления].Индекс(ЛюбойЭлемент);
		РезультатФункции = Метаданные.Перечисления[ИмяВидаПеречисления].ЗначенияПеречисления[ИндексЗначения].Синоним;
	Иначе
		РезультатФункции = Строка(ЛюбойЭлемент);
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Процедура ЗарегистрироватьДобавленнуюСтрокуПодбораНаФорме(Форма, СтрокаДобавляемогоТовара, ДобавленнаяСтрока)
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "СписокДобавленныхСтрокТоваров") Тогда
		Если Не СтрокаДобавляемогоТовара.ЭтоНабор Тогда
			Форма.СписокДобавленныхСтрокТоваров.Добавить(ДобавленнаяСтрока.ИдентификаторСтроки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

