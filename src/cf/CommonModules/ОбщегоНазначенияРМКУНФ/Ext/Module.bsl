	|ГДЕ
	|	РасходнаяНакладнаяВыбранныеУправляемыеСкидки.Ссылка = &РасходнаяНакладная";
	
	Если ТребуютсяДанныеКонтроля Тогда
		ТекстЗапросаТоваров = ПолучитьТекстЗапросаТоваровРасходнойНакладной();
		
		РазделительЗапросов = "
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|";
		ТекстЗапросаКонтроляПродаж = ПолучитьТекстЗапросаКонтроляПродаж(ТекстЗапросаТоваров);
		Запрос.Текст = СтрШаблон("%1%2%3", Запрос.Текст, РазделительЗапросов, ТекстЗапросаКонтроляПродаж);
		ПараметрТаблицаТоваров = Неопределено;
		
		УстановитьПараметрыЗапросаКонтроляПродаж(Запрос, ПараметрТаблицаТоваров, ДополнительныеПараметры);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("РасходнаяНакладная", РасходнаяНакладная);
	Запрос.УстановитьПараметр("ТорговыйОбъект", Объект.ТорговыйОбъект);
	Запрос.УстановитьПараметр("ПереноситьКодыМаркировки", ПереноситьКодыМаркировки);
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	ТаблицаТовары = МассивРезультатов[0].Выгрузить();
	ТаблицаСерийНоменклатуры = МассивРезультатов[2].Выгрузить();
	ТаблицаСкидокНаценок = МассивРезультатов[3].Выгрузить();
	ТаблицаБонусов = МассивРезультатов[4].Выгрузить();
	ТаблицаПримененныхПромокодов = МассивРезультатов[5].Выгрузить();
	ТаблицаВыбранныхУправляемыхСкидок = МассивРезультатов[6].Выгрузить();
	
	КлючСвязиМаксимум = 0;
	ВыборкаМаксимальногоКлючаСвязи = МассивРезультатов[1].Выбрать();
	Если ВыборкаМаксимальногоКлючаСвязи.Следующий() Тогда
		КлючСвязиМаксимум = ВыборкаМаксимальногоКлючаСвязи.КлючСвязиМаксимум;
	КонецЕсли;
	ДанныеДляРаспределения = Новый Структура;
	ДанныеДляРаспределения.Вставить("КлючСвязиМаксимум", КлючСвязиМаксимум);
	ДанныеДляРаспределения.Вставить("ТаблицаСерийНоменклатуры", ТаблицаСерийНоменклатуры);
	ДанныеДляРаспределения.Вставить("ТаблицаСкидокНаценок", ТаблицаСкидокНаценок);
	ДанныеДляРаспределения.Вставить("ТаблицаБонусов", ТаблицаБонусов);
	
	Если Форма.ЭтоОплатаРассрочки Тогда
		ТаблицаТовары.ЗаполнитьЗначения(Ложь, "НеобходимостьВводаСерии, ПроверятьЗаполнениеСерий");
	КонецЕсли;
	
	Если РасходнаяНакладная.ПоложениеЗаказаПокупателя = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке
		И ЗначениеЗаполнено(Объект.ЗаказПокупателя) Тогда
			ТаблицаТовары.ЗаполнитьЗначения(Объект.ЗаказПокупателя, "ЗаказПокупателя");
	КонецЕсли;
	
	ПеренестиТаблицуТоваровЧекаВТаблицуФормы(Форма, ТаблицаТовары, ДанныеДляРаспределения);
	
	Для Каждого СтрокаУправляемойСкидки Из ТаблицаВыбранныхУправляемыхСкидок Цикл
		Если Не ЗначениеЗаполнено(СтрокаУправляемойСкидки.КлючСвязи) Тогда
			СтрокаУправляемойСкидки.ИдентификаторСтроки = "";
			Продолжить;
		КонецЕсли;
		СтруктураОтбора = Новый Структура("КлючСвязиЧекаПродажи", СтрокаУправляемойСкидки.КлючСвязи);
		СтрокиТоваров = Объект.Товары.НайтиСтроки(СтруктураОтбора);
		Если СтрокиТоваров.Количество() > 0 Тогда 
			СтрокаУправляемойСкидки.ИдентификаторСтроки = СтрокиТоваров[0].ИдентификаторСтроки; 
		Иначе
			СтрокаУправляемойСкидки.ИдентификаторСтроки = "";
		КонецЕсли;
	КонецЦикла;

	Если (Не ОбщегоНазначенияРМК.ЭтоВидОперацииПродажа(Объект.ВидОперации)) 
		Или ЗначениеЗаполнено(Объект.ЗаказПокупателя)
		Или ЗначениеЗаполнено(Объект.ДокументРасчета) Тогда
		
		РассчитатьСуммуСкидокВСтроках(Объект.Товары, Ложь, Истина);
		
	КонецЕсли;
	
	МаксимальныйНомерНабора = 0;
	Для Каждого ДобавленныйНабор Из РасходнаяНакладная.ДобавленныеНаборы Цикл
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("НоменклатураНабора", ДобавленныйНабор.НоменклатураНабора);
		СтруктураПоиска.Вставить("ХарактеристикаНабора", ДобавленныйНабор.ХарактеристикаНабора);
		МассивТоваров = Объект.Товары.НайтиСтроки(СтруктураПоиска);
		Если МассивТоваров.Количество() > 0 Тогда
			МаксимальныйНомерНабора = МаксимальныйНомерНабора + 1;
			ВНабореЕстьПострочныйТовар = Ложь;
			Для Каждого СтрокаТовара Из МассивТоваров Цикл
				Если СтрокаТовара.НеобходимостьВводаКодаМаркировки Или СтрокаТовара.НеобходимостьВводаСерии Тогда
					ВНабореЕстьПострочныйТовар = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Для Каждого СтрокаТовара Из МассивТоваров Цикл
				СтрокаТовара.НомерНабора = МаксимальныйНомерНабора;
				СтрокаТовара.КоличествоНаборов = ?(ВНабореЕстьПострочныйТовар, 1, ДобавленныйНабор.Количество);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	ЗагрузитьТаблицуСкидокНаценок(ДанныеДляРаспределения.ТаблицаСкидокНаценок, Форма.ТаблицаСкидкиНаценки, Объект.Товары);
	ОбщегоНазначенияРМК.ЗагрузитьВТаблицуЗначений(ДанныеДляРаспределения.ТаблицаБонусов, Форма.ТаблицаБонусныеБаллы, Истина);
	ОбщегоНазначенияРМК.ЗагрузитьВТаблицуЗначений(ДанныеДляРаспределения.ТаблицаБонусов, Форма.ТаблицаБонусныеБаллыЧекаПродажи, Истина);
	ОбщегоНазначенияРМК.ЗагрузитьВТаблицуЗначений(ТаблицаПримененныхПромокодов, Форма.ТаблицаПримененныхПромокодов, Истина);
	ОбщегоНазначенияРМК.ЗагрузитьВТаблицуЗначений(ТаблицаВыбранныхУправляемыхСкидок, Форма.ТаблицаВыбранныхУправляемыхСкидок, Истина);
	
	Если ТребуютсяДанныеКонтроля Тогда
		НачальныйНомерЗапроса = 15;
		ДополнительныеПараметры.ДанныеКонтроляПродаж
			= ПодготовитьДанныеКонтроляПродаж(МассивРезультатов, НачальныйНомерЗапроса);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОпределитьИспользованиеРазрешительногоРежимаГосИС(Форма, Результат) Экспорт
	
	Результат = ПолучитьФункциональнуюОпцию("ВестиУчетМаркируемойПродукцииИСМП");
	
КонецПроцедуры

// Получает список организаций для обновления розничного токена авторизации.
//
// Параметры:
//  ОрганизацииДляПроверкиРозничногоТокена - Массив - Организации для обновления
//  Форма - ФормаКлиентскогоПриложения - данные формы РМК.
//
Процедура ОрганизацииДляПроверкиРозничногоТокена(ОрганизацииДляПроверкиРозничногоТокена, Форма) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("НастройкаРМК", Форма.ТекущаяНастройкаРМК);
	Запрос.УстановитьПараметр("ИспользоватьРазрешительныйРежимГосИС", Форма.ИспользоватьРазрешительныйРежимГосИС);
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПулКодовМаркировкиСУЗ.Организация КАК Организация
		|ИЗ
		|	РегистрСведений.ПулКодовМаркировкиСУЗ КАК ПулКодовМаркировкиСУЗ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КассыККМ.Владелец
		|ИЗ
		|	Справочник.НастройкиРабочегоМестаКассира КАК НастройкиРабочегоМестаКассира
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КассыККМ КАК КассыККМ
		|		ПО НастройкиРабочегоМестаКассира.ОсновнаяКассаККМ = КассыККМ.Ссылка
		|ГДЕ
		|	НастройкиРабочегоМестаКассира.Ссылка = &НастройкаРМК
		|	И &ИспользоватьРазрешительныйРежимГосИС";
	
	ОрганизацииДляПроверкиРозничногоТокена = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Организация");
	
КонецПроцедуры

// Заполняет параметры необходимые для проверки марки при сканировании
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма РМК
//  СтрокаКассыККМ - СтрокаТаблицыЗначений - Параметры кассы и организации
//
Процедура ЗаполнитьПараметрыКассыМаркируемойПродукции(Форма, СтрокаКассыККМ) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Склад = Общегоназначения.ЗначениеРеквизитаОбъекта(СтрокаКассыККМ.КассаККМ, "СтруктурнаяЕдиница");
	Организация = СтрокаКассыККМ.Организация;
	ИдентификаторУстройства = СтрокаКассыККМ.ИдентификаторУстройства;
	
	ОрганизацияЕГАИС =
		Справочники.КлассификаторОрганизацийЕГАИС.ОрганизацияЕГАИСПоОрганизацииИТорговомуОбъекту(Организация, Склад);
	СтрокаКассыККМ.ОрганизацияЕГАИС = ОрганизацияЕГАИС;
	
	ЗаводскойНомерФН = "";
	Если ОбщегоНазначенияБПО.ИспользуетсяЧекопечатающиеУстройства() Тогда
		МодульОборудованиеЧекопечатающиеУстройства = ОбщегоНазначенияБПО.ОбщийМодуль("ОборудованиеЧекопечатающиеУстройства");
		ПараметрыРегистрации = МодульОборудованиеЧекопечатающиеУстройства.ПараметрыРегистрацииУстройства(ИдентификаторУстройства);
		Если ПараметрыРегистрации.Свойство("ЗаводскойНомерФН") И ЗначениеЗаполнено(ПараметрыРегистрации.ЗаводскойНомерФН) Тогда
			ЗаводскойНомерФН = ПараметрыРегистрации.ЗаводскойНомерФН;
		КонецЕсли;
	КонецЕсли;
	
	СтрокаКассыККМ.НомерФискальногоНакопителя = ЗаводскойНомерФН;
	
КонецПроцедуры

// Заполняет признак ведения учета маркируемой продукци переданного вида.
// 
// Параметры:
//  ВидМаркируемойПродукции - ПеречислениеСсылка.ВидыПродукцииИС - вид маркируемой продукции
//  Результат - Булево - признак ведения учета маркируемой продукции переданного вида.
//
Процедура ЗаполнитьПризнакВедениеУчетМаркируемойПродукции(ВидМаркируемойПродукции, Результат) Экспорт
	
	Результат = ОбщегоНазначенияИСМПВызовСервера.ВестиУчетМаркируемойПродукции(ВидМаркируемойПродукции);
	
КонецПроцедуры

// Заполняет заказ покупателя по чеку.
// 
// Параметры:
//  ЧекККМ - ОпределяемыйТип.ЧекККМРМК - чек ккм.
//  ЗаказПокупателя - ОпределяемыйТип.ЗаказПокупателяРМК - заказ покупателя.
//
Процедура ЗаполнитьЗаказПокупателяПоЧеку(ЧекККМ, ЗаказПокупателя) Экспорт
	
	Если ТипЗнч(ЧекККМ) = Тип("ДокументСсылка.ЧекККМ") ИЛИ ТипЗнч(ЧекККМ) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
		ЗаказПокупателя = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЧекККМ, "Заказ");
	КонецЕсли;
	
КонецПроцедуры

// Проверяет соответствие чека по заказу покупателя
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложение - форма настройки рабочего места кассира.
//  ТекстОшибки - Строка - текст возможной ошибки.
//
Процедура ПроверитьСоответствиеЗаказу(Форма, ТекстОшибки) Экспорт
	
	Объект = Форма.Объект;
	ЭтоОплатаРассрочки = Форма.ЭтоОплатаРассрочки;
	ЗапретитьЧастичнуюОтгрузкуЗаказа = Форма.ЗапретитьЧастичнуюОтгрузкуЗаказа;
	РазрешитьПродажуСверхЗаказа = Форма.РазрешитьПродажуСверхЗаказа;
	
	Если Форма.ЭтоВнесениеПредоплатыПоЗаказу Тогда
		ЗапретитьЧастичнуюОтгрузкуЗаказа = Ложь;
	КонецЕсли;
	
	ЕстьОплатаВРассрочку = Форма.СуммаОплаченоВРассрочку > 0;
	Если Объект.ОперацияСДенежнымиСредствами Или ЕстьОплатаВРассрочку Тогда
		РазрешитьПродажуСверхЗаказа = Ложь;
	КонецЕсли;
	
	ТоварыЧека = Объект.Товары.Выгрузить();
	ТоварыЧека.Свернуть("Номенклатура, Характеристика, ЗаказПокупателя, Оплачена, Подарок", "Количество, КоличествоУпаковок");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТоварыЧека.Номенклатура КАК Номенклатура,
	|	ТоварыЧека.Характеристика КАК Характеристика,
	|	ТоварыЧека.ЗаказПокупателя КАК ЗаказПокупателя,
	|	ВЫБОР
	|		КОГДА ТоварыЧека.ЗаказПокупателя = &ЗаказПокупателя
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПоЗаказу,
	|	ТоварыЧека.Количество КАК Количество,
	|	ТоварыЧека.КоличествоУпаковок КАК КоличествоУпаковок
	|ПОМЕСТИТЬ ТоварыЧека
	|ИЗ
	|	&ТоварыЧека КАК ТоварыЧека
	|ГДЕ
	|	НЕ ТоварыЧека.Оплачена
	|	И НЕ ТоварыЧека.Подарок
	|	И ВЫБОР
	|			КОГДА &РазрешитьПродажуСверхЗаказа
	|				ТОГДА ТоварыЧека.ЗаказПокупателя = &ЗаказПокупателя
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказПокупателяЗапасы.Номенклатура КАК Номенклатура,
	|	ЗаказПокупателяЗапасы.Характеристика КАК Характеристика,
	|	ЗаказПокупателяЗапасы.Ссылка КАК ЗаказПокупателя,
	|	СУММА(ЗаказПокупателяЗапасы.Количество) КАК Количество
	|ПОМЕСТИТЬ ТоварыЗаказа
	|ИЗ
	|	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
	|ГДЕ
	|	ЗаказПокупателяЗапасы.Ссылка = &ЗаказПокупателя
	|	И &ЭтоОплатаРассрочки
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказПокупателяЗапасы.Номенклатура,
	|	ЗаказПокупателяЗапасы.Характеристика,
	|	ЗаказПокупателяЗапасы.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказПокупателя.НоменклатураДоставки,
	|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),
	|	ЗаказПокупателя.Ссылка,
	|	1
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|ГДЕ
	|	ЗаказПокупателя.Ссылка = &ЗаказПокупателя
	|	И &ЭтоОплатаРассрочки
	|	И НЕ ЗаказПокупателя.НоменклатураДоставки = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|	И ЗаказПокупателя.СтоимостьДоставки > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиПоЗаказамПокупателей.Номенклатура КАК Номенклатура,
	|	ОстаткиПоЗаказамПокупателей.Характеристика КАК Характеристика,
	|	ОстаткиПоЗаказамПокупателей.ЗаказПокупателя КАК ЗаказПокупателя,
	|	ОстаткиПоЗаказамПокупателей.КоличествоОстаток КАК Количество
	|ПОМЕСТИТЬ ОстаткиЗаказа
	|ИЗ
	|	РегистрНакопления.ЗаказыПокупателей.Остатки(
	|			&ДатаОстатков,
	|			ЗаказПокупателя = &ЗаказПокупателя
	|				И НЕ &ЭтоОплатаРассрочки) КАК ОстаткиПоЗаказамПокупателей
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДвиженияЧека.Номенклатура,
	|	ДвиженияЧека.Характеристика,
	|	ДвиженияЧека.ЗаказПокупателя,
	|	ДвиженияЧека.Количество
	|ИЗ
	|	РегистрНакопления.ЗаказыПокупателей КАК ДвиженияЧека
	|ГДЕ
	|	ДвиженияЧека.Регистратор = &ЧекККМ
	|	И ДвиженияЧека.ЗаказПокупателя = &ЗаказПокупателя
	|	И НЕ &ЭтоОплатаРассрочки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТоварыЗаказа.Номенклатура,
	|	ТоварыЗаказа.Характеристика,
	|	ТоварыЗаказа.ЗаказПокупателя,
	|	ТоварыЗаказа.Количество - ЕСТЬNULL(ОстаткиПоЗаказамПокупателей.КоличествоОстаток, 0)
	|ИЗ
	|	ТоварыЗаказа КАК ТоварыЗаказа
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗаказыПокупателей.Остатки(&ДатаОстатков, ЗаказПокупателя = &ЗаказПокупателя) КАК ОстаткиПоЗаказамПокупателей
	|		ПО ТоварыЗаказа.Номенклатура = ОстаткиПоЗаказамПокупателей.Номенклатура
	|			И ТоварыЗаказа.Характеристика = ОстаткиПоЗаказамПокупателей.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТоварыЧека.Номенклатура, ОстаткиЗаказа.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(ТоварыЧека.Характеристика, ОстаткиЗаказа.Характеристика) КАК Характеристика,
	|	ЕСТЬNULL(ТоварыЧека.ПоЗаказу, ИСТИНА) КАК ПоЗаказу,
	|	ЕСТЬNULL(ТоварыЧека.Количество, 0) КАК КоличествоВЧеке,
	|	ЕСТЬNULL(ОстаткиЗаказа.Количество, 0) КАК КоличествоОстатокПоЗаказу
	|ИЗ
	|	ТоварыЧека КАК ТоварыЧека
	|		ПОЛНОЕ СОЕДИНЕНИЕ ОстаткиЗаказа КАК ОстаткиЗаказа
	|		ПО ТоварыЧека.Номенклатура = ОстаткиЗаказа.Номенклатура
	|			И ТоварыЧека.Характеристика = ОстаткиЗаказа.Характеристика
	|			И ТоварыЧека.ЗаказПокупателя = ОстаткиЗаказа.ЗаказПокупателя
	|ГДЕ
	|	&УсловиеПоКоличествуВЗаказе");
	
	Запрос.УстановитьПараметр("ЗаказПокупателя", Объект.ЗаказПокупателя);
	Запрос.УстановитьПараметр("ТоварыЧека", ТоварыЧека);
	Запрос.УстановитьПараметр("ЭтоОплатаРассрочки", ЭтоОплатаРассрочки);
	Запрос.УстановитьПараметр("РазрешитьПродажуСверхЗаказа", РазрешитьПродажуСверхЗаказа);
	Запрос.УстановитьПараметр("ДатаОстатков", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ЧекККМ", Форма.ЧекККМВОбработке);
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоКоличествуВЗаказе",
		?(ЗапретитьЧастичнуюОтгрузкуЗаказа, "ЕСТЬNULL(ТоварыЧека.Количество, 0) <> ЕСТЬNULL(ОстаткиЗаказа.Количество, 0)",
			"ЕСТЬNULL(ТоварыЧека.Количество, 0) > ЕСТЬNULL(ОстаткиЗаказа.Количество, 0)"));
	
	ТаблицаОтрицательныхОстатковПоЗаказу = Запрос.Выполнить().Выгрузить();
	
	СписокТоваровСверхЗаказа = "";
	СписокТоваровЧастичнаяОтгрузка = "";
	СписокТоваровНетВЗаказе = "";
	СписокТоваровБольшеЗаказа = "";
	СписокТоваровОтсутствуетВОтгрузке = "";
	
	Для Каждого СтрокаОстатка Из ТаблицаОтрицательныхОстатковПоЗаказу Цикл
		
		НаименованиеТовара = СтрШаблон(НСтр("ru = '%1 %2'"), СтрокаОстатка.Номенклатура, СтрокаОстатка.Характеристика);
		
		Если Не СтрокаОстатка.ПоЗаказу Тогда
			СписокТоваровСверхЗаказа = СтрШаблон("%1%2%3", СписокТоваровСверхЗаказа, Символы.ПС, НаименованиеТовара);
		ИначеЕсли СтрокаОстатка.КоличествоВЧеке > СтрокаОстатка.КоличествоОстатокПоЗаказу Тогда
			СписокТоваровБольшеЗаказа = СтрШаблон("%1%2%3", СписокТоваровБольшеЗаказа, Символы.ПС, НаименованиеТовара);
		ИначеЕсли ЗапретитьЧастичнуюОтгрузкуЗаказа И СтрокаОстатка.КоличествоВЧеке > 0 Тогда
			СписокТоваровЧастичнаяОтгрузка = СтрШаблон("%1%2%3", СписокТоваровЧастичнаяОтгрузка, Символы.ПС, НаименованиеТовара);
		ИначеЕсли ЗапретитьЧастичнуюОтгрузкуЗаказа И СтрокаОстатка.КоличествоВЧеке = 0 Тогда
			СписокТоваровОтсутствуетВОтгрузке = СтрШаблон("%1%2%3", СписокТоваровОтсутствуетВОтгрузке, Символы.ПС, НаименованиеТовара);
		Иначе
			СписокТоваровНетВЗаказе = СтрШаблон("%1%2%3", СписокТоваровНетВЗаказе, Символы.ПС, НаименованиеТовара);
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СписокТоваровСверхЗаказа) Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Сверх заказа: %1'"), СписокТоваровСверхЗаказа);
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СписокТоваровЧастичнаяОтгрузка) Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Неполная отгрузка: %1'"), СписокТоваровЧастичнаяОтгрузка);
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СписокТоваровОтсутствуетВОтгрузке) Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Отсутствует отгрузка: %1'"), СписокТоваровОтсутствуетВОтгрузке);
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СписокТоваровБольшеЗаказа) Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Больше чем в заказе: %1'"), СписокТоваровБольшеЗаказа);
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СписокТоваровНетВЗаказе) Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Уже отгружены или не требуются: %1'"), СписокТоваровНетВЗаказе);
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

// Обработчик подписки на событие "НастроитьДоступностьФОИспользоватьСтаруюОбработкуПечатиЦенников".
//
Процедура НастроитьВозможностьИзмененияНастройкиИспользованияСтаройОбработкиПечатиЦенников(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьТолькоНовуюОбработкуПечатиЦенников")
		И Источник.Значение = Истина Тогда
		
		Отказ = Истина;
		ТекстСообщения = НСтр("ru = 'Разрешено использование только новой обработки печати этикеток и ценников.'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

