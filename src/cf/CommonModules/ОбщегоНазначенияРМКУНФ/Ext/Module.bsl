//  Результат - Булево - признак использования оплат сертификатами НСПК.
//
Процедура ЗаполнитьПризнакВеденияУчетаПивнойПродукцииВРозлив(Результат) Экспорт
	
	Результат = ИнтеграцияИСМПКлиентСерверПовтИсп.ВестиУчетМаркируемойПродукции(Перечисления.ВидыПродукцииИС.Пиво)
		Или ИнтеграцияИСМПКлиентСерверПовтИсп.ВестиУчетМаркируемойПродукции(Перечисления.ВидыПродукцииИС.БезалкогольноеПиво);
	
КонецПроцедуры

// Заполняет признак ведения учета продукции ИСМП кроме пива.
//
// Возвращаемое значение:
//  Результат - Булево - Истина, если ведется учет
//
Процедура ВедетсяУчетЧастичногоВыбытияИСМПКромеПива(Результат) Экспорт
	
	УчитываемыеВидыМаркируемойПродукции = ОбщегоНазначенияИСМПКлиентСерверПовтИсп.УчитываемыеВидыМаркируемойПродукции();
	
	Для Каждого ВидПродукции Из УчитываемыеВидыМаркируемойПродукции Цикл
		Если ОбщегоНазначенияИСКлиентСерверПовтИсп.ПоддерживаетсяЧастичноеВыбытие(ВидПродукции)
				И ВидПродукции <> Перечисления.ВидыПродукцииИС.Пиво Тогда
			Результат = Истина;
			
			Прервать;
		КонецЕсли;		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает признак ведения учета продукции с частичным выбытием ЕГАИС.
//
// Возвращаемое значение:
//  Результат - Булево - Истина, если ведется учет
//
Функция ВедетсяУчетЧастичногоВыбытияЕГАИС(Результат) Экспорт
	
	Результат = ПолучитьФункциональнуюОпцию("ВестиСведенияДляДекларацийПоАлкогольнойПродукции");
	
КонецФункции

// Заполняет признак доступности пивной палитры.
//
// Параметры:
//  Результат - Булево - признак использования пивной палитры.
//  Форма - ФормаКлиентскогоПриложения - Форма настроек РМК
//
Процедура ЗаполнитьДоступностьПивнойПалитры(Результат, Форма) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Палитра", Форма.СтруктураПлиточногоИнтерфейсаПодбора);
	Запрос.УстановитьПараметр("ВидПродукцииИС", Перечисления.ВидыПродукцииИС.Пиво);
	
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПалитраТоваровРМКСостав.Номенклатура КАК Номенклатура,
		|	ДанныеНоменклатуры.ВидПродукцииИС КАК ОсобенВидПродукцииИСностьУчета
		|ПОМЕСТИТЬ ПивныеПозицииПалитры
		|ИЗ
		|	Справочник.ПалитраТоваровРМК.Состав КАК ПалитраТоваровРМКСостав
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ДанныеНоменклатуры
		|		ПО ПалитраТоваровРМКСостав.Номенклатура = ДанныеНоменклатуры.Ссылка
		|ГДЕ
		|	ПалитраТоваровРМКСостав.Ссылка = &Палитра
		|	И ДанныеНоменклатуры.ВидПродукцииИС = &ВидПродукцииИС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НастройкиЧастичногоВыбытияПродукцииИС.НоменклатураЧастичногоВыбытия КАК НоменклатураЧастичногоВыбытия
		|ИЗ
		|	РегистрСведений.НастройкиЧастичногоВыбытияПродукцииИС КАК НастройкиЧастичногоВыбытияПродукцииИС
		|ГДЕ
		|	НастройкиЧастичногоВыбытияПродукцииИС.НоменклатураЧастичногоВыбытия В
		|			(ВЫБРАТЬ
		|				ПивныеПозицииПалитры.Номенклатура КАК Номенклатура
		|			ИЗ
		|				ПивныеПозицииПалитры КАК ПивныеПозицииПалитры)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Результат = Ложь;
	Иначе
		Результат = Истина;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет признак использования характеристик в конфигурации.
//
// Параметры:
//  ИспользоватьХарактеристики - Булево - признак использования характеристик.
