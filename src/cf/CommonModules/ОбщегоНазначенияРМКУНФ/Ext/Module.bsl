// Проверяет, были ли необходимые подарка добавлены в состав чека ранее. 
// Убирает из исходной таблицы те подарки что уже были выбраны ранее, и корректирует идентификатор строк в таблице скидок.
//
// Параметры:
//  ФормаРМК - ФормаКлиентскогоПриложения - форма рабочего места кассира
//  ТаблицаТоваров - ТаблицаЗначений - Таблица товаров формы РМК
//  ТаблицаПодарков - ТаблицаЗначений - Таблица подарков, которые необходимо выдать по результату расчета
//  ТаблицаСкидкиНаценки - ТаблицаЗначений - Таблица скидок. Связывает сработавшие скидки-подарки со строками самих подарков в товарах, если они были выбраны в чек ранее
//
Процедура ОбработатьПолученнуюТаблицуПодарков(ФормаРМК, ТаблицаТоваров, ТаблицаПодарков, ТаблицаСкидкиНаценки) Экспорт
	ОписаниеРанееВыданныхПодарков = СкидкиНаценкиСервер.УчестьРанееВыданныеПодарки(ТаблицаТоваров, ТаблицаПодарков,,Истина);
	СоответствиеСтрокПодарковТоварам = ОписаниеРанееВыданныхПодарков["СоответствиеСтрокПодарковТоварам"];
	ТоварыУдалить  = ОписаниеРанееВыданныхПодарков["ТоварыУдалить"];
	Если ТоварыУдалить.Количество() > 0 Тогда
		Для Каждого СтрокаУдалить Из ТоварыУдалить Цикл
			ОбщегоНазначенияРМККлиентСервер.УдалитьСтрокуТовара(ФормаРМК, СтрокаУдалить, ФормаРМК.Объект.Товары);
		КонецЦикла;
	КонецЕсли;
	Для Каждого ОписаниеВыданногоПодарка Из СоответствиеСтрокПодарковТоварам Цикл
		СтрокаВыданногоПодарка = ОписаниеВыданногоПодарка.Ключ;
		КлючСтроки = ОписаниеВыданногоПодарка.Значение.ИдентификаторСтроки;
		ОтборСкидки = Новый Структура("ИдентификаторСтроки, СкидкаНаценка", "", СтрокаВыданногоПодарка.ВладелецПодарка);
		СтрокиСкидкиПодарка = ТаблицаСкидкиНаценки.НайтиСтроки(ОтборСкидки);
		Для Каждого СтрокаСкидкиПодарка  Из СтрокиСкидкиПодарка Цикл
			СтрокаСкидкиПодарка.ИдентификаторСтроки = КлючСтроки;
		КонецЦикла;
	КонецЦикла;
	СтрокиПодаркаУжеВЧеке = ТаблицаПодарков.НайтиСтроки(Новый Структура("УжеВыдан", Истина));
	Для Каждого СтрокаПодаркаУжеВЧеке Из СтрокиПодаркаУжеВЧеке Цикл
		ТаблицаПодарков.Удалить(СтрокаПодаркаУжеВЧеке );
	КонецЦикла;
КонецПроцедуры

Функция ВыделитьОтсортированныеПоНДССтрокиПоОтбору(ТаблицаТоваров, ОтборСтрок)
	
	МассивСтрок = Новый Массив;
	Для Каждого Строкатовара Из ТаблицаТоваров Цикл
		Если СтрокаУдовлетворяетУсловиямОтбора(Строкатовара, ОтборСтрок) Тогда
			
			ПозицияВставки = -1;
			ИндексЭлемента = 0;
			КоличествоЭлементов = МассивСтрок.Количество();
			Пока ИндексЭлемента < КоличествоЭлементов И ПозицияВставки < 0 Цикл
				СтрокаМассива = МассивСтрок[ИндексЭлемента];
				Если СтрокаМассива.СуммаНДС < СтрокаТовара.СуммаНДС Тогда
					ПозицияВставки = ИндексЭлемента;
				КонецЕсли;
				ИндексЭлемента = ИндексЭлемента + 1;
			КонецЦикла;
			Если ПозицияВставки < 0 Тогда
				МассивСтрок.Добавить(Строкатовара);
			Иначе
				МассивСтрок.Вставить(ПозицияВставки, Строкатовара);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	Возврат МассивСтрок;
	
КонецФункции

Процедура ЗаполнитьНастройкиРазрешительногоРежима(Форма)

	РазрешительныйРежимГосИС = ПолучитьФункциональнуюОпцию("ЗапрашиватьДанныеСервисаИСМП")
								И ОбщегоНазначенияИСМПВызовСервера.ВестиУчетМаркируемойПродукции();
								
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиРабочегоМестаКассира.Ссылка КАК Ссылка,
		|	НастройкиРабочегоМестаКассира.ОжидатьРезультатПроверкиМарок КАК ОжидатьРезультатПроверкиМарок
		|ИЗ
		|	Справочник.НастройкиРабочегоМестаКассира КАК НастройкиРабочегоМестаКассира
		|ГДЕ
		|	НЕ НастройкиРабочегоМестаКассира.ПометкаУдаления
		|	И НастройкиРабочегоМестаКассира.РабочееМесто = &РабочееМесто";
	Запрос.УстановитьПараметр("РабочееМесто", Форма.РабочееМесто);
	
	ВыборкаНастроек = Запрос.Выполнить().Выбрать();
	КоличествоНастроек = ВыборкаНастроек.Количество();
	
	Если КоличествоНастроек = 1 И ВыборкаНастроек.Следующий() Тогда
		ТекущаяНастройкаРМК = ВыборкаНастроек.Ссылка;
		РазрешительныйРежимРМК = ВыборкаНастроек.ОжидатьРезультатПроверкиМарок;
	Иначе
		Возврат;
	КонецЕсли;
	
	Если РазрешительныйРежимГосИС <> РазрешительныйРежимРМК Тогда
	
		НастройкиРМК = ТекущаяНастройкаРМК.ПолучитьОбъект();
		НастройкиРМК.ОжидатьРезультатПроверкиМарок = РазрешительныйРежимГосИС;
		
		Попытка
			НастройкиРМК.Записать();
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Установка разрешительного режима РМК по настройкам ГосИС.'",
					ОбщегоНазначения.КодОсновногоЯзыка()),
				УровеньЖурналаРегистрации.Ошибка,,,
				ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	
	КонецЕсли;
	

КонецПроцедуры

// Возвращает ширину ленты для формирования чека покупателя,
// макет существует только для ленты шириной: 24 32 36 40 48 64.
//
// Параметры:
//   ШиринаЛенты - Число
//
// Возвращаемое значение:
//  Число
Функция ДопустимаяШиринаЛентыДляМакетаЧекПокупателя(Знач ШиринаЛенты)
	
	Если ШиринаЛенты = Неопределено Или ШиринаЛенты = 0 Тогда
		Возврат 32;
	ИначеЕсли ШиринаЛенты <= 24 Тогда
		Возврат 24;
	ИначеЕсли ШиринаЛенты <= 32 Тогда
		Возврат 32;
	ИначеЕсли ШиринаЛенты <= 36 Тогда
		Возврат 36;
	ИначеЕсли ШиринаЛенты <= 40 Тогда
		Возврат 40;
	ИначеЕсли ШиринаЛенты <= 48 Тогда
		Возврат 48;
	Иначе
		Возврат 64;
	КонецЕсли;
	
КонецФункции

Процедура ОбработатьДанныеПоАкцизнымМаркамПередЗаписьюЧека(ТекущийЧек)
	
	АкцизныеМаркиЧека = ТекущийЧек.АкцизныеМарки.Выгрузить();
	ПоследниеЗначенияПоМаркам = АкцизныеМаркиЧека.СкопироватьКолонки(
		"АкцизнаяМарка, РазрешительныйРежимДатаЗапросаГИСМТ, РазрешительныйРежимИдентификаторЗапросаГИСМТ, РазрешительныйРежимИдентификаторЭкземпляраПО, РазрешительныйРежимВерсияБазы");
	ЕстьОдинаковыеМарки = Ложь;
	Для Каждого СтрокаМарки Из АкцизныеМаркиЧека Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаМарки.АкцизнаяМарка) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаМарки.РазрешительныйРежимИдентификаторЗапросаГИСМТ)
			И Не ЗначениеЗаполнено(СтрокаМарки.РазрешительныйРежимДатаЗапросаГИСМТ) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаЗначенийПоМарке = ПоследниеЗначенияПоМаркам.Найти(СтрокаМарки.АкцизнаяМарка, "АкцизнаяМарка");
		Если СтрокаЗначенийПоМарке = Неопределено Тогда
			СтрокаЗначенийПоМарке = ПоследниеЗначенияПоМаркам.Добавить();
		Иначе
			ЕстьОдинаковыеМарки = Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаЗначенийПоМарке.РазрешительныйРежимИдентификаторЗапросаГИСМТ)
			И Не ЗначениеЗаполнено(СтрокаМарки.РазрешительныйРежимИдентификаторЗапросаГИСМТ) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрокаЗначенийПоМарке, СтрокаМарки);
		
	КонецЦикла;
	
	Если ЕстьОдинаковыеМарки Тогда
		Для Каждого СтрокаМарки Из ТекущийЧек.АкцизныеМарки Цикл
			СтрокаЗначенийПоМарке = ПоследниеЗначенияПоМаркам.Найти(СтрокаМарки.АкцизнаяМарка, "АкцизнаяМарка");
			Если Не СтрокаЗначенийПоМарке = Неопределено Тогда
				ЗаполнитьЗначенияСвойств(СтрокаМарки, СтрокаЗначенийПоМарке,
					"РазрешительныйРежимДатаЗапросаГИСМТ, РазрешительныйРежимИдентификаторЗапросаГИСМТ, РазрешительныйРежимИдентификаторЭкземпляраПО, РазрешительныйРежимВерсияБазы");
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
Конецпроцедуры

Процедура ПодготовитьТекстЗапросаПроверкиНаличияТоваров(Запрос)
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаКассККМ.Организация КАК Организация,
	|	ТаблицаКассККМ.КассаККМ КАК КассаККМ
	|ПОМЕСТИТЬ ТаблицаКассККМ
	|ИЗ
	|	&ТаблицаКассККМ КАК ТаблицаКассККМ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ТаблицаТовары.Характеристика КАК Характеристика,
	|	ТаблицаТовары.Серия КАК Серия,
	|	ТаблицаТовары.Количество КАК Количество,
	|	ТаблицаТовары.Партия КАК Партия,
	|	ТаблицаТовары.НомерСтроки КАК НомерСтроки,
	|	ТаблицаТовары.Организация КАК Организация,
	|	ВЫРАЗИТЬ(ТаблицаТовары.Упаковка КАК Справочник.ЕдиницыИзмерения) КАК ЕдиницаИзмерения,
	|	ВЫРАЗИТЬ(ТаблицаТовары.ПредставлениеЕдиницыИзмерения КАК СТРОКА(50)) КАК ЕдиницаИзмеренияПредставление,
	|	ТаблицаТовары.ТорговыйОбъект КАК ТорговыйОбъект
