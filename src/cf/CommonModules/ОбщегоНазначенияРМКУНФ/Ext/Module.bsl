Процедура ДополнитьСтрокуТоваровДаннымиПартииПоУмолчанию(СтрокаТовары)

	СтатусПартииНаКомиссии = ПредопределенноеЗначение("Перечисление.СтатусыПартий.ТоварыНаКомиссии");
	СтатусПартии = Новый СписокЗначений;
	СтатусПартии.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыПартий.СобственныеЗапасы"));
	СтатусПартии.Добавить(СтатусПартииНаКомиссии);
	
	ПартияПоУмолчанию = НоменклатураВДокументахСервер.ЗначенияПартийНоменклатурыПоУмолчанию(
		СтрокаТовары.Номенклатура,
		СтатусПартии);

	Если ЗначениеЗаполнено(ПартияПоУмолчанию) Тогда
		СтрокаТовары.Партия = ПартияПоУмолчанию;
		РеквизитыПартии = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПартияПоУмолчанию, "Статус,ВладелецПартии");
		Если РеквизитыПартии.Статус = СтатусПартииНаКомиссии Тогда
			СтрокаТовары.Поставщик = РеквизитыПартии.ВладелецПартии;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура НастроитьГруппуАвтоподбораПартий(Форма)
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Форма.Элементы, "ГруппаАвтоподбораПартий", "Видимость", Истина);
	
	ИспользуютсяПартии = ПолучитьФункциональнуюОпцию("ИспользоватьПартии");
	ПриемНаКомиссию = ПолучитьФункциональнуюОпцию("ПриемТоваровНаКомиссию");
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Форма.Элементы, "ГруппаАвтоподбораПартий", "Доступность", ИспользуютсяПартии);
	
	ТекстПроОстаток = НСтр("ru = 'Подбор партий в зависимости от остатка товара'");
	ТекстПроПриоритет = НСтр("ru = ' и приоритета списания'");
	ТекстПроНастройки = Новый ФорматированнаяСтрока(
		НСтр("ru = 'Партионный учет можно включить в '"),
		Новый ФорматированнаяСтрока(НСтр("ru = 'настройках программы'"),,,, "e1cib/command/Обработка.НастройкаПрограммы.Команда.ЕщеБольшеВозможностей"));
	
	Если Не ИспользуютсяПартии Тогда
		ТекстПодсказки = Новый ФорматированнаяСтрока(ТекстПроОстаток + Символы.ПС, ТекстПроНастройки);
	ИначеЕсли Не ПриемНаКомиссию Тогда
		ТекстПодсказки = ТекстПроОстаток;
	Иначе
		ТекстПодсказки = ТекстПроОстаток + ТекстПроПриоритет;
	КонецЕсли;
	Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	
	Если ПриемНаКомиссию Тогда
		Если Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.Вид <> ВидПоляФормы.ПолеПереключателя Тогда
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.Вид = ВидПоляФормы.ПолеПереключателя;
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.ВидПереключателя = ВидПереключателя.Тумблер;
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Верх;
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.СписокВыбора.Добавить(0, НСтр("ru = 'Не подбирать'"));
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.СписокВыбора.Добавить(1, НСтр("ru = 'Сначала свои'"));
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.СписокВыбора.Добавить(2, НСтр("ru = 'Сначала чужие'"));
		КонецЕсли;
	Иначе
		Если Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.Вид <> ВидПоляФормы.ПолеФлажка Тогда
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.Вид = ВидПоляФормы.ПолеФлажка;
			Форма.Элементы.НастройкаРМКПодбиратьПартииАвтоматически.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура НастроитьГруппуРаботыСОтложеннымиЧеками(Форма)
	
	Форма.НастройкаРМК.УдалятьНепробитыеЧеки = Константы.УдалятьНепробитыеЧекиПриЗакрытииКассовойСмены.Получить();
	Форма.Элементы.ГруппаНастройкиУдаленияНепробитыхЧеков.Видимость = Ложь;
	Форма.Элементы.ГруппаКоличествоДнейХранения.Видимость = Ложь;
	
КонецПроцедуры

Функция ПодготовитьСтруктуруПоискаДляПодбораПартий(СтрокаТаблицы, ТорговыйОбъект, СкладВТЧ, ПоискПоСерии)
	
	СтруктураПоиска = Новый Структура;
	
	СтруктураПоиска.Вставить("Номенклатура", СтрокаТаблицы.Номенклатура);
	СтруктураПоиска.Вставить("Характеристика", СтрокаТаблицы.Характеристика);
	СтруктураПоиска.Вставить("Партия", СтрокаТаблицы.Партия);
	СтруктураПоиска.Вставить("Ячейка", СтрокаТаблицы.Ячейка);
	СтруктураПоиска.Вставить("Организация", СтрокаТаблицы.Организация);
	Если СкладВТЧ Тогда
		СтруктураПоиска.Вставить("СтруктурнаяЕдиница", СтрокаТаблицы.ТорговыйОбъект);
	Иначе
		СтруктураПоиска.Вставить("СтруктурнаяЕдиница", ТорговыйОбъект);
	КонецЕсли;
	Если ПоискПоСерии Тогда
		СтруктураПоиска.Вставить("Серия", СтрокаТаблицы.Серия);
	КонецЕсли;
	
	Возврат СтруктураПоиска
	
КонецФункции

Процедура РаспределитьСтроку(СтрокаТЧ, НайденныеСтроки, ТаблицаСРаспределением)
	
	Если ЗначениеЗаполнено(СтрокаТЧ.Упаковка) Тогда
		Коэффициент = СтрокаТЧ.Упаковка.Коэффициент;
	Иначе
		Коэффициент = 1;
	КонецЕсли;
	
	Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
		ОстатокУпаковок = Цел(НайденнаяСтрока.Остаток/Коэффициент);
		Если ОстатокУпаковок <= 0 Тогда
			Продолжить;
		Иначе
			НоваяСтрока = ТаблицаСРаспределением.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			НоваяСтрока.Партия = НайденнаяСтрока.Партия;
			Если ОстатокУпаковок < СтрокаТЧ.Количество Тогда
				НоваяСтрока.Количество = ОстатокУпаковок;
				НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
				НоваяСтрока.СуммаСкидкиНаценки = СтрокаТЧ.СуммаСкидкиНаценки/СтрокаТЧ.Количество*НоваяСтрока.Количество;
			КонецЕсли;
			НайденнаяСтрока.Остаток = НайденнаяСтрока.Остаток - НоваяСтрока.Количество*Коэффициент;
			СтрокаТЧ.Количество = СтрокаТЧ.Количество - НоваяСтрока.Количество;
			СтрокаТЧ.КоличествоУпаковок = СтрокаТЧ.КоличествоУпаковок - НоваяСтрока.КоличествоУпаковок;
			СтрокаТЧ.СуммаСкидкиНаценки = СтрокаТЧ.СуммаСкидкиНаценки - НоваяСтрока.СуммаСкидкиНаценки;
			Если СтрокаТЧ.Количество <= 0 Тогда
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Формирует печатную форму согласия на обработку персональных данных, при выдаче новой дисконтной карты
//
// Параметры:
//  Данные - Структура - Данные покупателя, для которого формируется печатная форма согласия на обработку персональных данных
//
Функция ДанныеДляПечатиСогласия(ДанныеСогласия)
	
	Данные = Новый Структура();
	ТекущаяДата = ТекущаяДатаСеанса();	
	ОтветственныйФИО = "";
	ДанныеОрганизации = ЗащитаПерсональныхДанных.ОписаниеДанныхОрганизации();
	ЗащитаПерсональныхДанныхПереопределяемый.ДополнитьДанныеОрганизацииОператораПерсональныхДанных(ДанныеСогласия.Организация, ДанныеОрганизации, ТекущаяДата);

	Данные.Вставить("ДокументОснование", Документы.ЧекККМ.ПустаяСсылка());
	Данные.Вставить("Номер", "");
	Данные.Вставить("Организация", ДанныеСогласия.Организация);
	Данные.Вставить("НаименованиеОрганизации", ДанныеОрганизации.НаименованиеОрганизации);
	Данные.Вставить("ЮридическийАдресОрганизации", ДанныеОрганизации.АдресОрганизации);
	Данные.Вставить("ОтветственныйЗаОбработкуПерсональныхДанных", ДанныеОрганизации.ОтветственныйЗаОбработкуПерсональныхДанных);
	Данные.Вставить("ОтветственныйЗаОбработкуПерсональныхДанныхВРодительномПадеже", ОтветственныйФИО);
	Данные.Вставить("Субъект", Справочники.ФизическиеЛица.ПустаяСсылка());
	Данные.Вставить("ФИО", ДанныеСогласия.ФИО);
	Данные.Вставить("Адрес", "");
	Данные.Вставить("ПаспортныеДанные", "");
	Данные.Вставить("ДатаПолучения", ТекущаяДата);
	Данные.Вставить("СрокДействия", Дата(1,1,1));
	Данные.Вставить("Ответственный", ДанныеСогласия.Ответственный);
	Данные.Вставить("Комментарий", "");
	
	Возврат Данные;
	
КонецФункции

Процедура СформироватьТабличныйДокументСогласияНаОбработкуПерсональныхДанных(ТабличныйДокумент, ДанныеПокупателя) Экспорт	
	
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_СогласиеНаОбработкуПерсональныхДанных";
	
	ОбластиМакета = Новый Структура;
	ОбластиМакета.Вставить("Заголовок");
	ОбластиМакета.Вставить("НомерДата");
	ОбластиМакета.Вставить("Преамбула");
	ОбластиМакета.Вставить("П1_ЦелиОбработкиПДн");
	ОбластиМакета.Вставить("П2_СоставПДн");
	ОбластиМакета.Вставить("П3_ДействияСПДн");
	ОбластиМакета.Вставить("П4_ПравоПолученияИнформации");
	ОбластиМакета.Вставить("П5_СрокДействия");
	ОбластиМакета.Вставить("П6_ПравоОтзыва");
	ОбластиМакета.Вставить("РеквизитыОператора");
	ОбластиМакета.Вставить("РеквизитыСубъекта");
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.СогласиеНаОбработкуПерсональныхДанных.ПФ_MXL_СогласиеНаОбработкуПерсональныхДанных");
	
	ДанныеДляПечати = ДанныеДляПечатиСогласия(ДанныеПокупателя);

	НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
	// Формируем печатную форму согласия.
	СогласиеФорма = Новый ТабличныйДокумент;
	Для Каждого КлючИЗначение Из ОбластиМакета Цикл
		ИмяОбласти = КлючИЗначение.Ключ;
		ОбластьМакета = Макет.ПолучитьОбласть(ИмяОбласти);
		ОбластьМакета.Параметры.Заполнить(ДанныеДляПечати);
		СогласиеФорма.Вывести(ОбластьМакета);
	КонецЦикла;
	ТабличныйДокумент.Вывести(СогласиеФорма);	
КонецПроцедуры 

Процедура УдалитьСтрокуТовара(Форма, ТекущаяСтрока, ТаблицаТовары)
	ИндексПредыдущейСтроки = -1;
	ОбъектТовары = Форма.Объект.Товары;
	
	Если ТекущаяСтрока.ЭтоНабор Тогда
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("НомерНабора", ТекущаяСтрока.НомерНабора);
		МассивСтрокНабора = ТаблицаТовары.НайтиСтроки(СтруктураПоиска);
		Для Каждого СтрокаМассива Из МассивСтрокНабора Цикл
			ТекущийИндекс = ТаблицаТовары.Индекс(СтрокаМассива);
			Если ТекущийИндекс < ИндексПредыдущейСтроки Или ИндексПредыдущейСтроки = -1 Тогда
				ИндексПредыдущейСтроки = ТекущийИндекс;
			КонецЕсли;
			ТаблицаТовары.Удалить(СтрокаМассива);
		КонецЦикла;
	Иначе
		ИндексПредыдущейСтроки = ТаблицаТовары.Индекс(ТекущаяСтрока);
		ТаблицаТовары.Удалить(ТекущаяСтрока);
	КонецЕсли;
	Если ИндексПредыдущейСтроки > 0 Тогда
		ИндексПредыдущейСтроки = ИндексПредыдущейСтроки - 1;
	КонецЕсли;
	Если ОбъектТовары.Количество() > 0 Тогда
		Форма.Элементы.Товары.ТекущаяСтрока = ОбъектТовары[ИндексПредыдущейСтроки].ПолучитьИдентификатор();
	КонецЕсли;
КонецПроцедуры

Функция ЭтоВозвратнаяНоменклатураСМодификаторами(Строка)
	
	Возврат (Строка.ИмеетсяВложенность И Строка.НомерКатегории = 0 И Не Строка.ЭтоКатегория);
	
КонецФункции

Функция ЭтоПозицияМодификатора(Строка, ОпорныеДанные, ПапкиПлитки)
	
	РезультатФункции = Ложь;
	
	Если Строка.НомерКатегорииРазмещенияЭлемента > 0 Тогда
		
		ЗначениеКатегорииРодителя = ПапкиПлитки.Получить(Строка.НомерКатегорииРазмещенияЭлемента);
		Если ЗначениеКатегорииРодителя = Неопределено Тогда
			ЗначениеКатегорииРодителя
				= ПолучитьЗначениеКатегорииПоНомеру(ОпорныеДанные, Строка.НомерКатегорииРазмещенияЭлемента);
			Если Не ЗначениеКатегорииРодителя = Неопределено Тогда
				ПапкиПлитки.Вставить(Строка.НомерКатегорииРазмещенияЭлемента, ЗначениеКатегорииРодителя);
			Иначе
				ЗначениеКатегорииРодителя = Ложь;
			КонецЕсли;
		КонецЕсли;
		Если Не ЗначениеКатегорииРодителя Тогда
			РезультатФункции = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Процедура СнятьПризнакВесовогоТовараУСлужебныхЭлементов(Строка, ОпорныеДанные, ПапкиПлитки)
	
	Если Строка.Весовой И (ЭтоВозвратнаяНоменклатураСМодификаторами(Строка)
			Или ЭтоПозицияМодификатора(Строка, ОпорныеДанные, ПапкиПлитки)) Тогда
		
		Строка.Весовой = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьЗначениеКатегорииПоНомеру(ОпорныеДанные, НомерКатегорииРодителя)
	
	РезультатФункции = Неопределено;
	СтрокиРодителя = ОпорныеДанные.НайтиСтроки(Новый Структура("НомерКатегории", НомерКатегорииРодителя));
	Если СтрокиРодителя.Количество() > 0 Тогда
		РезультатФункции = СтрокиРодителя[0].ЭтоКатегория;
	КонецЕсли;
	Возврат РезультатФункции;
	
КонецФункции

Функция НаФормеПодключеныЭлектронныеВесы(Форма)
	
	РезультатФункции = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ТаблицаЭлектронныхВесов") Тогда
		РезультатФункции = (Форма.ТаблицаЭлектронныхВесов.Количество() > 0);
	КонецЕсли;
	Возврат РезультатФункции;
	
КонецФункции

Процедура ЗаполнитьТорговыйОбъектИВидЦеныПоДаннымФормы(Форма, ТорговыйОбъект, ВидЦены)
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ТекущийТорговыйОбъект") Тогда
		ТорговыйОбъект = Форма.ТекущийТорговыйОбъект;
	Иначе
		ТорговыйОбъект = Форма.Объект.ТорговыйОбъект;
	КонецЕсли;
	
	ВидЦены = ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка");
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "РозничныйВидЦены") Тогда
		ВидЦены = Форма.РозничныйВидЦены;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТорговыйОбъект) И Не ЗначениеЗаполнено(ВидЦены) Тогда
		ВидЦены = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТорговыйОбъект, "РозничныйВидЦен");
	КонецЕсли;
	
КонецПроцедуры

Процедура ОчиститьИсточникВесовойТоварВОпорныхДанных(Форма)
	
	ИсточникиПлитки = ИнтерфейсРМКСлужебныйКлиентСервер.ИсточникиДанныхДляПлитки();
	КоличествоСтрок = Форма.ОпорныеДанные.Количество();
	ИндексСтроки = 0;
	Пока ИндексСтроки < КоличествоСтрок Цикл
		ИндексПозиции = КоличествоСтрок - ИндексСтроки - 1;
		СтрокаОпорныхДанных = Форма.ОпорныеДанные.Получить(ИндексПозиции);
		Если СтрокаОпорныхДанных.ИсточникПлитки = ИсточникиПлитки.ВесовойТовар Тогда
			Форма.ОпорныеДанные.Удалить(ИндексПозиции);
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДополнитьОпорныеДанныеПлиточногоИнтерфейсаВесовымТоваром(Форма, ВидЦены, ТорговыйОбъект)

	ИсточникиПлитки = ИнтерфейсРМКСлужебныйКлиентСервер.ИсточникиДанныхДляПлитки();
	ОчиститьИсточникВесовойТоварВОпорныхДанных(Форма);
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ПОМЕСТИТЬ втСрезЦенНоменклатуры
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&Дата,
	|			Номенклатура.Весовой
	|				И ВидЦен = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ЕдиницыИзмерения.Коэффициент, 0) = 0
	|			ТОГДА 1
	|		ИНАЧЕ ЕдиницыИзмерения.Коэффициент
	|	КОНЕЦ КАК КоэффициентУпаковки,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ЕСТЬNULL(КодыТоваровSKU.SKU, 0) КАК SKU
	|ПОМЕСТИТЬ втЦеныНоменклатуры
	|ИЗ
	|	втСрезЦенНоменклатуры КАК ЦеныНоменклатурыСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КодыТоваровSKU КАК КодыТоваровSKU
	|		ПО ЦеныНоменклатурыСрезПоследних.Номенклатура = КодыТоваровSKU.Номенклатура
	|			И ЦеныНоменклатурыСрезПоследних.Характеристика = КодыТоваровSKU.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	|		ПО ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения = ЕдиницыИзмерения.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка КАК Склад,
	|	СтруктурныеЕдиницы.ТипСтруктурнойЕдиницы КАК ТипСтруктурнойЕдиницы
	|ПОМЕСТИТЬ ДанныеТорговогоОбъекта
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И СтруктурныеЕдиницы.Ссылка = &ТорговыйОбъект
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка КАК Склад
	|ПОМЕСТИТЬ ТаблицаСклады
	|ИЗ
	|	ДанныеТорговогоОбъекта КАК ДанныеТорговогоОбъекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ПО ДанныеТорговогоОбъекта.Склад = СтруктурныеЕдиницы.Родитель
	|ГДЕ
	|	ДанныеТорговогоОбъекта.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка
	|ИЗ
	|	ДанныеТорговогоОбъекта КАК ДанныеТорговогоОбъекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ПО ДанныеТорговогоОбъекта.Склад = СтруктурныеЕдиницы.Ссылка
	|ГДЕ
	|	(ДанныеТорговогоОбъекта.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)
	|			ИЛИ ДанныеТорговогоОбъекта.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиТоваров.Номенклатура КАК Номенклатура,
	|	ОстаткиТоваров.Характеристика КАК Характеристика,
	|	СУММА(ОстаткиТоваров.Количество) КАК Количество
	|ПОМЕСТИТЬ втОстаткиТоваров
	|ИЗ
	|	РегистрСведений.ОстаткиТоваров КАК ОстаткиТоваров
	|ГДЕ
	|	ОстаткиТоваров.СтруктурнаяЕдиница В
	|			(ВЫБРАТЬ
	|				ТаблицаСклады.Склад КАК Склад
	|			ИЗ
	|				ТаблицаСклады КАК ТаблицаСклады)
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиТоваров.Номенклатура,
	|	ОстаткиТоваров.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПалитраТоваровРМКСостав.Номенклатура КАК Номенклатура,
	|	ПалитраТоваровРМКСостав.Характеристика КАК Характеристика,
	|	МАКСИМУМ(ПалитраТоваровРМКСостав.ИзображениеЭлемента) КАК ИзображениеЭлемента
	|ПОМЕСТИТЬ втИзображенияТовара
	|ИЗ
	|	Справочник.ПалитраТоваровРМК.Состав КАК ПалитраТоваровРМКСостав
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втЦеныНоменклатуры КАК втЦеныНоменклатуры
	|		ПО ПалитраТоваровРМКСостав.Номенклатура = втЦеныНоменклатуры.Номенклатура
	|			И ПалитраТоваровРМКСостав.Характеристика = втЦеныНоменклатуры.Характеристика
	|ГДЕ
	|	НЕ ПалитраТоваровРМКСостав.Ссылка.ПометкаУдаления
	|	И НЕ ПалитраТоваровРМКСостав.ИзображениеЭлемента = ЗНАЧЕНИЕ(Справочник.ПалитраТоваровРМКПрисоединенныеФайлы.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПалитраТоваровРМКСостав.Номенклатура,
	|	ПалитраТоваровРМКСостав.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СпрНоменклатура.КатегорияНоменклатуры КАК ВидНоменклатуры,
	|	ВЫБОР
	|		КОГДА НЕ СпрНоменклатура.ВидАлкогольнойПродукции = ЗНАЧЕНИЕ(Справочник.ВидыАлкогольнойПродукции.ПустаяСсылка)
	|				И СпрНоменклатура.ВидПродукцииИС = ЗНАЧЕНИЕ(Перечисление.ВидыПродукцииИС.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыПродукцииИС.Алкогольная)
	|		ИНАЧЕ СпрНоменклатура.ВидПродукцииИС
	|	КОНЕЦ КАК ОсобенностьУчета,
	|	СпрНоменклатура.КодТРУ КАК КодТРУ,
	|	СпрНоменклатура.Ссылка КАК Номенклатура,
	|	СпрНоменклатура.Наименование КАК ИмяЭлемента,
	|	втЦеныНоменклатуры.Характеристика КАК Характеристика,
	|	втЦеныНоменклатуры.Цена / втЦеныНоменклатуры.КоэффициентУпаковки КАК Цена,
	|	втЦеныНоменклатуры.SKU КАК SKU,
	|	ЕСТЬNULL(ОстаткиТоваров.Количество, 0) КАК Доступно,
	|	ЕСТЬNULL(втИзображенияТовара.ИзображениеЭлемента, ЗНАЧЕНИЕ(Справочник.ПалитраТоваровРМКПрисоединенныеФайлы.ПустаяСсылка)) КАК Изображение,
	|	ПРЕДСТАВЛЕНИЕ(СпрНоменклатура.ЕдиницаИзмерения) КАК ПредставлениеЕдиницыИзмерения,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СпрЕдиницыИзмерения.Код, """") = ""163""
	|			ТОГДА 1000
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК КоэффициентПереводаВКилограммы
	|ИЗ
	|	Справочник.Номенклатура КАК СпрНоменклатура
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втЦеныНоменклатуры КАК втЦеныНоменклатуры
	|			ЛЕВОЕ СОЕДИНЕНИЕ втИзображенияТовара КАК втИзображенияТовара
	|			ПО втЦеныНоменклатуры.Номенклатура = втИзображенияТовара.Номенклатура
	|				И втЦеныНоменклатуры.Характеристика = втИзображенияТовара.Характеристика
	|			ЛЕВОЕ СОЕДИНЕНИЕ втОстаткиТоваров КАК ОстаткиТоваров
	|			ПО втЦеныНоменклатуры.Номенклатура = ОстаткиТоваров.Номенклатура
	|				И втЦеныНоменклатуры.Характеристика = ОстаткиТоваров.Характеристика
	|		ПО СпрНоменклатура.Ссылка = втЦеныНоменклатуры.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторЕдиницИзмерения КАК СпрЕдиницыИзмерения
	|			ПО СпрНоменклатура.ЕдиницаИзмерения = СпрЕдиницыИзмерения.Ссылка";
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	Запрос.УстановитьПараметр("ТорговыйОбъект", ТорговыйОбъект);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ИдентификаторФормы = Форма.УникальныйИдентификатор;
		ИндексТовара = 0;
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ИндексТовара = ИндексТовара + 1;
			СтрокаОпорныхДанных = Форма.ОпорныеДанные.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаОпорныхДанных, Выборка);
			СтрокаОпорныхДанных.ИндексПозицииВКатегории = ИндексТовара;
			СтрокаОпорныхДанных.ДоступностьКоманды = Истина;
			СтрокаОпорныхДанных.ПервыйИндексПлитки = Форма.ОпорныеДанные.Индекс(СтрокаОпорныхДанных);
			СтрокаОпорныхДанных.ИсточникПлитки = ИсточникиПлитки.ВесовойТовар;
			СтрокаОпорныхДанных.Весовой = Истина;
			Если ЗначениеЗаполнено(Выборка.Изображение) Тогда
				АдресКартинки = РаботаСФайлами.ДанныеФайла(Выборка.Изображение, ИдентификаторФормы).СсылкаНаДвоичныеДанныеФайла;
				СтрокаОпорныхДанных.АдресИзображения = АдресКартинки;
			КонецЕсли;
			СтрокаОпорныхДанных.ЦветФона = Форма.ЦветаФормы.АктивнаяКнопка;
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура НастроитьДинамическийСписокВесовыхТоваровСоSKU(Форма)
	
	Форма.СписокТоваров.ТекстЗапроса = ПолучитьТекстЗапросаТоваровДляРаботыСУстройствами();
	ВидЦены = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Форма.ТорговыйОбъект, "РозничныйВидЦен");
	Если Не ЗначениеЗаполнено(ВидЦены) Тогда
		ВидЦены = Справочники.ВидыЦен.Оптовая;
	КонецЕсли;
	Форма.СписокТоваров.Параметры.УстановитьЗначениеПараметра("ВидЦены", ВидЦены);
	
КонецПроцедуры

Функция ПолучитьТекстЗапросаТоваровПоДаннымРаспознавания(ОграничениеКоличества)
	
	ОграничениеКоличестваСтрокой = Формат(ОграничениеКоличества, "ЧГ=");
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВесовыеТовары.Номенклатура КАК Номенклатура,
	|	ВесовыеТовары.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втВесовыеТовары
	|ИЗ
	|	&ТаблицаВесовыхТоваров КАК ВесовыеТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КодыSKU.Код КАК КодSKU,
	|	КодыSKU.Вероятность КАК Вероятность
	|ПОМЕСТИТЬ втКодыSKU
	|ИЗ
	|	&ТаблицаКодовSKU КАК КодыSKU
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втСрезЦенНоменклатуры
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&Дата,
	|			(Номенклатура, Характеристика) В
	|					(ВЫБРАТЬ
	|						ВесовыеТовары.Номенклатура КАК Номенклатура,
	|						ВесовыеТовары.Характеристика КАК Характеристика
	|					ИЗ
	|						втВесовыеТовары КАК ВесовыеТовары)
	|				И ВидЦен = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 999
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	КодыSKU.Вероятность КАК Вероятность
	|ИЗ
	|	втКодыSKU КАК КодыSKU
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КодыТоваровSKU КАК РегистрКодыТоваровSKU
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСрезЦенНоменклатуры КАК ЦеныНоменклатурыСрезПоследних
	|			ПО (ЦеныНоменклатурыСрезПоследних.Номенклатура = РегистрКодыТоваровSKU.Номенклатура)
	|				И (ЦеныНоменклатурыСрезПоследних.Характеристика = РегистрКодыТоваровSKU.Характеристика)
	|		ПО КодыSKU.КодSKU = РегистрКодыТоваровSKU.SKU
	|
	|УПОРЯДОЧИТЬ ПО
	|	Вероятность УБЫВ";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "999", ОграничениеКоличестваСтрокой);
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПолучитьТекстЗапросаТоваровДляРаботыСУстройствами()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Весовой КАК Весовой,
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Артикул КАК Артикул
	|ПОМЕСТИТЬ втНоменклатураВПРодаже
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			,
	|			Номенклатура В
	|					(ВЫБРАТЬ
	|						РегистрКодыТоваровSKU.Номенклатура
	|					ИЗ
	|						РегистрСведений.КодыТоваровSKU КАК РегистрКодыТоваровSKU
	|					ГДЕ
	|						РегистрКодыТоваровSKU.Номенклатура.Весовой)
	|				И ВидЦен = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втНоменклатураВПРодаже.Номенклатура КАК Номенклатура,
	|	втНоменклатураВПРодаже.Характеристика КАК Характеристика,
	|	втНоменклатураВПРодаже.Весовой КАК Весовой,
	|	КодыТоваровSKU.SKU КАК SKU,
	|	втНоменклатураВПРодаже.Артикул КАК Артикул
	|ИЗ
	|	втНоменклатураВПРодаже КАК втНоменклатураВПРодаже
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КодыТоваровSKU КАК КодыТоваровSKU
	|		ПО втНоменклатураВПРодаже.Номенклатура = КодыТоваровSKU.Номенклатура
	|			И втНоменклатураВПРодаже.Характеристика = КодыТоваровSKU.Характеристика";
	
	Возврат ТекстЗапроса;
	
КонецФункции

