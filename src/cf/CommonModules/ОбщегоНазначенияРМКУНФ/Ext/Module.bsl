	КолонкиТаблицФормы.Вставить("ТаблицаСкидкиНаценки", КолонкиСкидок);
	КолонкиТаблицФормы.Вставить("ТаблицаВыбранныхКарт", КолонкиВыбранныхКарт);
	КолонкиТаблицФормы.Вставить("ТаблицаПредоплаты", КолонкиПредоплаты);
	КолонкиТаблицФормы.Вставить("ТаблицаВыбранныхУправляемыхСкидок", КолонкиВыбранныхУправляемыхСкидок);
	КолонкиТаблицФормы.Вставить("ПробитыеЧеки", КолонкиПробитыхЧеков);
	
КонецПроцедуры

