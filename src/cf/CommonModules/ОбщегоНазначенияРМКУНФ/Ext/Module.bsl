	ДобавитьОписаниеКолонкиВКоллекцию(КолонкиТоваров, "ЭтоНабор", ТипБулево);
	ДобавитьОписаниеКолонкиВКоллекцию(КолонкиТоваров, "НоменклатураНабора", ТипНоменклатура);
