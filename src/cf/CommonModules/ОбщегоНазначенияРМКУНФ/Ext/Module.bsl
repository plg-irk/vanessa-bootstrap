// Определеяет значение налогообложения НДС для текущей организации.
//
// Параметры:
//  НалогообложениеНДС - ОпределяемыйТип.НалогообложениеНДСРМК - налогообложение НДС для организации.
//  Форма - ФормаКлиентскогоПриложения - форма рабочего места кассира.
//
Процедура ЗаполнитьСНОНДСДляОрганизации(НалогообложениеНДС, Форма) Экспорт
	
	НалогообложениеНДС = НалогиУНФ.НалогообложениеНДС(Форма.Объект.Организация);
	
КонецПроцедуры

// Определеяет значение налогообложения ККТ для организации.
//
// Параметры:
//  НалогообложениеККТ - ОпределяемыйТип.ТипыСистемНалогообложенияККТРМК - налогообложение ККТ для организации.
//  Форма - ФормаКлиентскогоПриложения - форма рабочего места кассира.
//  ТекущаяСтрока - СтрокаТабличнойЧасти - текущая строка.
//  Дата - ДатаВремя - (необязательный).
//
Процедура ЗаполнитьСНОККТДляОрганизации(НалогообложениеККТ, Форма, ТекущаяСтрока, Дата) Экспорт
	
	ТекущаяДата = ОбщегоНазначения.ТекущаяДатаПользователя();
	Дата = ?(Дата = '00010101', ТекущаяДата, Дата);
	Организация = ?(ТекущаяСтрока = Неопределено, Форма.Объект.Организация, ТекущаяСтрока.Организация);
	ТорговыйОбъект = Форма.Объект.ТорговыйОбъект;
	
	СкладСпецРежима = ТорговыйОбъект;
	
	СНО = РегистрыСведений.СистемыНалогообложенияОрганизаций.ОпределитьСистемуНалогообложенияОрганизации(Организация, Дата);
	
	Если ТорговыйОбъект.ТипСтруктурнойЕдиницы = Перечисления.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов 
		И СНО.ПрименяетсяПатент Тогда
		
		ТипыСтруктурнойЕдиницы = Новый Массив;
		ТипыСтруктурнойЕдиницы.Добавить(Перечисления.ТипыСтруктурныхЕдиниц.Розница);
		ТипыСтруктурнойЕдиницы.Добавить(Перечисления.ТипыСтруктурныхЕдиниц.РозницаСуммовойУчет);
		ТипыСтруктурнойЕдиницы.Добавить(Перечисления.ТипыСтруктурныхЕдиниц.Склад);
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СтруктурныеЕдиницы.Ссылка КАК СкладСпецРежима
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|ГДЕ
		|	СтруктурныеЕдиницы.Родитель = &ТорговыйОбъект
		|	И НЕ СтруктурныеЕдиницы.ПометкаУдаления
		|	И СтруктурныеЕдиницы.ТипСтруктурнойЕдиницы В(&ТипыСтруктурнойЕдиницы)";
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("ТорговыйОбъект", ТорговыйОбъект);
		Запрос.УстановитьПараметр("ТипыСтруктурнойЕдиницы", ТипыСтруктурнойЕдиницы);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Количество() = 1 Тогда
			Пока Выборка.Следующий() Цикл
				СкладСпецРежима = Выборка.СкладСпецРежима;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	СпециальныйНалоговыйРежим = Перечисления.СпециальныеНалоговыеРежимы.НеПрименяется;
	Если СНО.ПрименяетсяПатент Тогда
		СпециальныйНалоговыйРежим = НалогиУНФ.СпециальныйНалоговыйРежим(Организация, СкладСпецРежима, Дата);
	КонецЕсли;
	Если НЕ СпециальныйНалоговыйРежим = Перечисления.СпециальныеНалоговыеРежимы.НеПрименяется Тогда
		ТорговыйОбъект = СкладСпецРежима;
		Форма.Объект.ТорговыйОбъект = СкладСпецРежима;
	КонецЕсли;
	
	НалогообложениеККТ = РозничныеПродажиСервер.ПолучитьТипСистемыНалогообложенияККТ(
		Организация,
		ТорговыйОбъект,
		Дата,
		СпециальныйНалоговыйРежим);
	
КонецПроцедуры

