#Область ПрограммныйИнтерфейс

// См. ПерсональныеНастройкиРУНФ.Установить
Процедура Установить(Знач ЗначениеНастройки, Знач ИмяНастройки, Знач Пользователь = Неопределено) Экспорт
	ПерсональныеНастройкиРУНФ.Установить(ЗначениеНастройки, ИмяНастройки, Пользователь);
КонецПроцедуры

// См. ПерсональныеНастройкиРУНФ.Прочитать
Функция Прочитать(Знач ИмяНастройки, Знач Организация = Неопределено, Знач Пользователь = Неопределено,
	Знач ЗначениеПоУмолчанию = Неопределено) Экспорт
	Результат = ПерсональныеНастройкиРУНФ.Прочитать(ИмяНастройки, Организация, Пользователь, ЗначениеПоУмолчанию);
	Возврат Результат;
КонецФункции

// См. ПерсональныеНастройкиРУНФ.ЗначенияНастроек
Функция ЗначенияНастроек(Знач Пользователь) Экспорт
	Результат = ПерсональныеНастройкиРУНФ.ЗначенияНастроек(Пользователь);
	Возврат Результат;
КонецФункции

#КонецОбласти