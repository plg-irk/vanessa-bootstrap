	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Товары.КлючСвязи КАК КлючСвязи,
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	Товары.Характеристика КАК Характеристика,
	|	Товары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	Товары.Количество КАК Количество,
	|	Товары.КоличествоВБазовыхЕдиницах КАК КоличествоВБазовыхЕдиницах,
	|	Товары.Цена КАК ЦенаЗаУпаковку,
	|	Товары.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	Товары.СуммаСкидкиОплатыБонусом КАК СуммаСкидкиОплатыБонусом,
	|	Товары.СтавкаНДС КАК СтавкаНДС,
	|	Товары.Количество * Товары.Цена КАК Сумма
	|ПОМЕСТИТЬ ВременнаяТаблицаТовары
	|ИЗ
	|	&Товары КАК Товары
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СоставСегментаНоменклатуры.Сегмент КАК Сегмент,
	|	СоставСегментаНоменклатуры.Номенклатура КАК Номенклатура,
	|	СоставСегментаНоменклатуры.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ ВременнаяСоставСегментаНоменклатуры
	|ИЗ
	|	ВременнаяТаблицаТовары КАК ВременнаяТаблицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СоставСегментаНоменклатуры КАК СоставСегментаНоменклатуры
	|		ПО (СоставСегментаНоменклатуры.Номенклатура = ВременнаяТаблицаТовары.Номенклатура)
	|			И (СоставСегментаНоменклатуры.Характеристика = ВременнаяТаблицаТовары.Характеристика)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаТовары.КлючСвязи КАК КлючСвязи,
	|	ВременнаяТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ВременнаяТаблицаТовары.Характеристика КАК Характеристика,
	|	ВременнаяТаблицаТовары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВременнаяТаблицаТовары.Количество КАК Количество,
	|	ВременнаяТаблицаТовары.ЦенаЗаУпаковку КАК ЦенаЗаУпаковку,
	|	ВременнаяТаблицаТовары.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	ВременнаяТаблицаТовары.СуммаСкидкиОплатыБонусом КАК СуммаСкидкиОплатыБонусом,
	|	ВременнаяТаблицаТовары.Сумма КАК Сумма,
	|	ВременнаяТаблицаТовары.СтавкаНДС КАК СтавкаНДС,
	|	ВременнаяТаблицаТовары.Номенклатура.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	ВременнаяТаблицаТовары.Номенклатура.КатегорияНоменклатуры КАК КатегорияНоменклатуры
	|ИЗ
	|	ВременнаяТаблицаТовары КАК ВременнаяТаблицаТовары";
	
	
	ТекстЗапроса = ТекстЗапроса + "
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
	
	Возврат ДанныеЗапроса(ТекстЗапроса, 3, 3, "Товары");
	
КонецФункции // ТекстЗапросаТаблицаТовары()

