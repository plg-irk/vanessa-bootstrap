КонецФункции

// Функция формирует текст запроса для таблицы произвольных условий скидок (наценок).
//
// Возвращаемое значение:
//	Структура - см. ДанныеЗапроса
//
Функция ТекстЗапросаТаблицаПроизвольныхУсловий()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ПараметрыУсловий.Ссылка КАК Ссылка,
	|	ПараметрыУсловий.ИмяСхемыКомпоновкиДанных КАК ИмяСхемыКомпоновкиДанных,
	|	ПараметрыУсловий.ХранилищеСхемыКомпоновкиДанных КАК ХранилищеСхемыКомпоновкиДанных,
	|	ПараметрыУсловий.ХранилищеНастроекКомпоновкиДанных КАК ХранилищеНастроекКомпоновкиДанных,
	|	ПараметрыУсловий.ХранилищеСкомпонованногоМакета КАК ХранилищеСкомпонованногоМакета
	|ИЗ
	|	УсловияПредоставления КАК УсловияПредоставления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УсловияПредоставленияСкидокНаценок КАК ПараметрыУсловий
	|		ПО УсловияПредоставления.Ссылка = ПараметрыУсловий.Ссылка
	|ГДЕ
	|	УсловияПредоставления.УсловиеПредоставления В (ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ПроизвольныйЗапрос),
	|		ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.Расширение))";
	
	ТекстЗапроса = ТекстЗапроса + "
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
	
	Возврат ДанныеЗапроса(ТекстЗапроса, 1, 1, "ПроизвольныеУсловия");
	
КонецФункции

Процедура РассчитатьТаблицуИерархииКатегорийИНоменклатуры(ПараметрыРасчета, МенеджерВременныхТаблиц)
	
	ЗапросИерархии = Новый Запрос;
    ЗапросИерархии.УстановитьПараметр("СкидкиНаценки", ПараметрыРасчета.СкидкиНаценки);
    ЗапросИерархии.УстановитьПараметр("Товары", ПараметрыРасчета.Товары);
	
	ЗапросИерархии.Текст = 
	
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(СкидкиНаценки.СкидкаНаценка КАК Справочник.АвтоматическиеСкидки) КАК СкидкаНаценка
	|ПОМЕСТИТЬ СкидкиНаценки
	|ИЗ
	|	&СкидкиНаценки КАК СкидкиНаценки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СкидкаНаценка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	Товары.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.Номенклатура КАК ЗначениеУточнения
	|ИЗ
	|	Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СкидкиНаценки КАК СкидкиНаценки
	|		ПО (СкидкиНаценки.СкидкаНаценка.ВариантОграниченияПоНоменклатуре = ЗНАЧЕНИЕ(Перечисление.ВариантыОграниченийСкидокПоНоменклатуре.ПоНоменклатуре)) И СкидкиНаценки.СкидкаНаценка.ЕстьУточненияПоНоменклатуре
	|ИТОГИ ПО
	|	ЗначениеУточнения ТОЛЬКО ИЕРАРХИЯ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.Номенклатура.КатегорияНоменклатуры КАК ЗначениеУточнения
	|ИЗ
	|	Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СкидкиНаценки КАК СкидкиНаценки
	|		ПО (СкидкиНаценки.СкидкаНаценка.ВариантОграниченияПоНоменклатуре = ЗНАЧЕНИЕ(Перечисление.ВариантыОграниченийСкидокПоНоменклатуре.ПоКатегориям)) И СкидкиНаценки.СкидкаНаценка.ЕстьУточненияПоКатегориям
	|ИТОГИ ПО
	|	ЗначениеУточнения ТОЛЬКО ИЕРАРХИЯ";
	
	ПакетЗапросов 			 = ЗапросИерархии.ВыполнитьПакет();
	ПоГруппировкамСИерархией = ОбходРезультатаЗапроса.ПоГруппировкамСИерархией;
	ИерархияНоменклатуры 	 = ПакетЗапросов[ПакетЗапросов.ВГраница()-1].Выгрузить(ПоГруппировкамСИерархией);
	ИерархияКатегорий    	 = ПакетЗапросов[ПакетЗапросов.ВГраница()].Выгрузить(ПоГруппировкамСИерархией);
	
	СоставНоменклатуры 		 = Новый ТаблицаЗначений;

	ОписаниеТипаЗначений     = Новый ОписаниеТипов("СправочникСсылка.Номенклатура, СправочникСсылка.КатегорииНоменклатуры");
	
	СоставНоменклатуры.Колонки.Добавить("ЗначениеУточненияГруппа", ОписаниеТипаЗначений);
	СоставНоменклатуры.Колонки.Добавить("ЗначениеУточненияСсылка", ОписаниеТипаЗначений);
	
	Для Каждого СтрокаИерархии Из ИерархияКатегорий.Строки Цикл
		
		МассивГрупп = Новый Массив;
		ЗаполнитьСоставИерархии(СтрокаИерархии, СоставНоменклатуры, МассивГрупп);

	КонецЦикла;
	
	Для Каждого СтрокаИерархии Из ИерархияНоменклатуры.Строки Цикл
		
		МассивГрупп = Новый Массив;
		ЗаполнитьСоставИерархии(СтрокаИерархии, СоставНоменклатуры, МассивГрупп);

	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("СоставНоменклатуры", СоставНоменклатуры);
	
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	Состав.ЗначениеУточненияГруппа КАК ЗначениеУточненияГруппа,
	|	Состав.ЗначениеУточненияСсылка КАК ЗначениеУточненияСсылка
	|ПОМЕСТИТЬ НоменклатураГруппыЦеновыеГруппыРасшифровка
	|ИЗ
	|	&СоставНоменклатуры КАК Состав";
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ЗаполнитьСоставИерархии(СтрокаДерева, СоставНоменклатуры, Знач МассивГрупп = Неопределено)
	
	Если СтрокаДерева.Строки.Количество() = 0 Тогда

		Для Каждого ЗначениеУточнения Из МассивГрупп Цикл
				
			НовыйСостав = СоставНоменклатуры.Добавить();
			НовыйСостав.ЗначениеУточненияГруппа = ЗначениеУточнения;
			НовыйСостав.ЗначениеУточненияСсылка = СтрокаДерева.ЗначениеУточнения;
				
		КонецЦикла;

	Иначе

		МассивГрупп.Добавить(СтрокаДерева.ЗначениеУточнения);

		Для Каждого ПодстрокаДерева Из СтрокаДерева.Строки Цикл
			ЗаполнитьСоставИерархии(ПодстрокаДерева, СоставНоменклатуры, МассивГрупп);
		КонецЦикла;
		
		МассивГрупп.Удалить(МассивГрупп.ВГраница());
		
	КонецЕсли;
	
КонецПроцедуры

