	ТаблицаБонусов = Новый ТаблицаЗначений;
	ТаблицаБонусов.Колонки.Добавить("СкидкаНаценка",	Новый ОписаниеТипов("СправочникСсылка.АвтоматическиеСкидки"));
	ТаблицаБонусов.Колонки.Добавить("КлючСвязи",		Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(36)));
	Возврат ТаблицаБонусов;
КонецФункции

// Возвращает структуру параметров для расчета значения скидки.
// Вызывается из расширения, подключенного для реализации произвольного алгоритма расчета скидки
// 
// Параметры:
//  СтрокаДерева - СтрокаДереваЗначений
//  ПараметрыРасчета - Структура - Параметры расчета
// 
// Возвращаемое значение:
//  Структура: - Содержит необходимые для рассчета значения скидки данные, а так же значения дополнительных реквизитов текушей скидки:
// * Товары - ТаблицаЗначений - 
// * ЭтоУмножение - Булево - 
// * ТаблицаСообщений - См. ПустаяТаблицаСообщений
// * ТаблицаПодарков - См. ПустаяТаблицаПодарков
// * СтрокиСНевыполненнымиУсловиями - Массив из Число - 
// * ЗначениеСкидкиНаценки - Число - 
// * ОбластьПредоставления - ПеречислениеСсылка.ВариантыОбластейОграниченияСкидокНаценок - 
Функция ПолучитьПараметрырасчетаПроизвольнойСкидки(СтрокаДерева, ПараметрыРасчета) Экспорт 
	
	// Получение дополнительных реквизитов скидки, которые могут потребоваться при расчете
	Результат = Новый Структура;
	ПараметрыСкидки = ПараметрыРасчета.СкидкиНаценки.Найти(СтрокаДерева.СкидкаНаценка, "СкидкаНаценка");
	Если УправлениеСвойствами.ИспользоватьДопРеквизиты(СтрокаДерева.СкидкаНаценка) Тогда
		ДополнительныеРеквизиты = УправлениеСвойствами.СвойстваОбъекта(СтрокаДерева.СкидкаНаценка, Истина, Ложь);
		ТаблицаЗначенийРеквизитов = УправлениеСвойствами.ЗначенияСвойств(СтрокаДерева.СкидкаНаценка, Истина, Ложь, ДополнительныеРеквизиты);
		Для Каждого Реквизит Из ДополнительныеРеквизиты Цикл
			НайденныеЗначения = ТаблицаЗначенийРеквизитов.НайтиСтроки(Новый Структура("Свойство", Реквизит));
			Если НайденныеЗначения.Количество() Тогда
				Результат.Вставить(НайденныеЗначения[0].ИмяСвойства, НайденныеЗначения[0].Значение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	// Исходные данные для расчета
	Товары = СтрокаДерева.ТаблицаТоваров;
	Если СтрокаДерева.Родитель = Неопределено Тогда
		ЭтоУмножение = Константы.ВариантыСовместногоПримененияСкидокНаценок.Получить() = ПредопределенноеЗначение("Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Умножение");
	Иначе
		ЭтоУмножение = СтрокаДерева.Родитель.ВариантСовместногоПрименения = ПредопределенноеЗначение("Перечисление.ВариантыСовместногоПримененияСкидокНаценок.Умножение");
	КонецЕсли;
	ТаблицаСообщений 	= ПустаяТаблицаСообщений();
	ТаблицаПодарков 	= ПустаяТаблицаПодарков();

	ДействуетБезусловно = СтрокаДерева.ПараметрыУсловий.УсловияВыполнены И СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.Количество() = 0;
	СтрокиСНевыполненнымиУсловиями = Новый Массив;
	Для Каждого Товар Из Товары Цикл
		Если НЕ ДействуетБезусловно Тогда
			ОтборУсловийВСтроке = Новый Структура("ОбластьОграничения", ПредопределенноеЗначение("Перечисление.ВариантыОбластейОграниченияСкидокНаценок.ВСтроке"));
			Если СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.НайтиСтроки(ОтборУсловийВСтроке).Количество() > 0 Тогда
				Если СтрокаДерева.ПараметрыУсловий.КодыСтрок.Найти(Товар.КлючСвязи) = Неопределено Тогда
					СтрокиСНевыполненнымиУсловиями.Добавить(Товар.КлючСвязи);;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
    Результат.Вставить("Товары", Товары);
	Результат.Вставить("ЭтоУмножение", ЭтоУмножение);
	Результат.Вставить("ТаблицаСообщений", ТаблицаСообщений);
	Результат.Вставить("ТаблицаПодарков", ТаблицаПодарков);	
	Результат.Вставить("СтрокиСНевыполненнымиУсловиями", СтрокиСНевыполненнымиУсловиями);
	Результат.Вставить("ЗначениеСкидкиНаценки", ПараметрыСкидки.ЗначениеСкидкиНаценки);
	Результат.Вставить("ОбластьПредоставления", ПараметрыСкидки.ОбластьПредоставления);

	Возврат Результат;
	
Конецфункции

// Процедура расчета округления бонусов для скидок и наценок.
//
// Параметры:
//  СтрокаДерева - Структура - строка дерева скидок и наценок, для которой необходимо рассчитать округление бонусов.
//  Параметры - Структура - параметры расчета скидок и наценок.
//  ТаблицаДанныхОбщая - ТаблицаЗначений - таблица данных для расчета скидок и наценок.
//
Процедура РассчитатьОкруглениеБонусов(СтрокаДерева, Параметры, ТаблицаДанныхОбщая)

	Если НЕ СтрокаДерева.ПараметрыУсловий.УсловияВыполнены Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыСкидки = Параметры.СкидкиНаценки.Найти(СтрокаДерева.СкидкаНаценка, "СкидкаНаценка");
	
	ТаблицаДанных 		= ПолучитьПустуюТаблицуСкидокСРасшифровкой(Параметры);
	
	ДействуетБезусловно = СтрокаДерева.ПараметрыУсловий.УсловияВыполнены И СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.Количество() = 0;
	
	РеквизитыБП = РаботаСБонусами.РеквизитыБонуснойПрограммы(Параметры.ДисконтнаяКарта);
	БонуснаяПрограмма = РеквизитыБП.БонуснаяПрограмма;
	Курс = РеквизитыБП.КурсБонусов;

	Если Не ЗначениеЗаполнено(БонуснаяПрограмма) Тогда
		Возврат;
	КонецЕсли;
	
	СуммаДокумента = 0;
	СуммаСкидкиКРаспределению = 0;
	Для Каждого ОбщаяСтрокаСкидок Из ТаблицаДанныхОбщая Цикл
		Для Каждого Начисление Из ОбщаяСтрокаСкидок.ТаблицаБонусов Цикл
			СуммаДокумента = СуммаДокумента + Начисление.КоличествоБонусныхБаллов;
		КонецЦикла;
	КонецЦикла;
	
	
	ДолжноБытьПослеОкругления = ОкруглитьЧисло(СуммаДокумента, ПараметрыСкидки.ПорядокОкругления, ПараметрыСкидки.ВариантОкругления, Истина);
	СуммаСкидкиКРаспределению = ДолжноБытьПослеОкругления - СуммаДокумента;
	ОбщаяСуммаОкругленияДокумента = СуммаСкидкиКРаспределению;
	ВКаждойСтроке = ПараметрыСкидки.ОбластьПредоставления = Перечисления.ВариантыОбластейОграниченияСкидокНаценок.ВСтроке;	
	ЕстьУсловияПоСтроке = СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.НайтиСтроки(Новый Структура("ОбластьОграничения", Перечисления.ВариантыОбластейОграниченияСкидокНаценок.ВСтроке)).Количество() > 0;
	
	СтрокаСкидкиДляРаспределения = Неопределено;
	МаксимальнаяСуммаВРаспределении = 0;
	ПроцентСкидкиНаценкиОкругления = ?(СуммаДокумента = 0, 0, СуммаСкидкиКРаспределению / СуммаДокумента);
	Для Каждого ОбщаяСтрокаСкидок Из ТаблицаДанныхОбщая Цикл
		
		Если ВКаждойСтроке Тогда
			СтрокаСкидкиДляРаспределения = Неопределено;
			МаксимальнаяСуммаВРаспределении = 0;
			
			СуммаСтроки = 0;
			Для Каждого Начисление Из ОбщаяСтрокаСкидок.ТаблицаБонусов Цикл
				СуммаСтроки = СуммаСтроки + Начисление.КоличествоБонусныхБаллов;
			КонецЦикла;
			ДолжноБытьПослеОкругления = ОкруглитьЧисло(СуммаСтроки, ПараметрыСкидки.ПорядокОкругления, ПараметрыСкидки.ВариантОкругления, Истина);
			СуммаСкидкиКРаспределению = ДолжноБытьПослеОкругления - СуммаСтроки;
			ПроцентСкидкиНаценкиОкругления = ?(СуммаСтроки = 0 , 0, СуммаСкидкиКРаспределению / СуммаСтроки);
			ОбщаяСуммаОкругленияСтроки = СуммаСкидкиКРаспределению;
		КонецЕсли;
		
		НачисленияБонусов = ОбщаяСтрокаСкидок.ТаблицаБонусов.Скопировать();
		НачисленияБонусов.Свернуть("КлючСвязи, ДатаНачисления, ДатаСписания, РеквизитДопУпорядочивания", "КоличествоБонусныхБаллов");
		Для Каждого Начисление Из НачисленияБонусов Цикл
			
			Действует = Ложь;
			Если ВКаждойСтроке Тогда
				Если НЕ ЕстьУсловияПоСтроке 
					ИЛИ ДействуетБезусловно 
					ИЛИ СтрокаДерева.ПараметрыУсловий.КодыСтрок.Найти(Начисление.КлючСвязи) <> Неопределено Тогда
					Действует = Истина;
				КонецЕсли;
			Иначе
				Действует = Истина;
			КонецЕсли;
			СуммаБонусов = Окр(ПроцентСкидкиНаценкиОкругления * Начисление.КоличествоБонусныхБаллов, 2);
			Если Не Действует 
				ИЛИ СуммаСкидкиКРаспределению = 0 Тогда
					Продолжить;
			КонецЕсли;
			НоваяСтрокаСкидки           = ТаблицаДанных.Добавить();
			НоваяСтрокаСкидки.КлючСвязи = Начисление.КлючСвязи;
			НоваяСтрокаСкидки.Действует = Действует;
			НоваяСтрокаСкидки.ТаблицаБонусов = ПустаяТаблицаБонусов();

			СтрокаОкругления = НоваяСтрокаСкидки.ТаблицаБонусов.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаОкругления, Начисление);
			СтрокаОкругления.СкидкаНаценка = СтрокаДерева.СкидкаНаценка;
			СтрокаОкругления.КоличествоБонусныхБаллов = СуммаБонусов;
			// Запоминаем строку с максимальной суммой для разнесения остатка корректировки
			Если Начисление.КоличествоБонусныхБаллов > МаксимальнаяСуммаВРаспределении Тогда
				МаксимальнаяСуммаВРаспределении = СтрокаОкругления.КоличествоБонусныхБаллов;
				СтрокаСкидкиДляРаспределения = НоваяСтрокаСкидки;
			КонецЕсли;

			СуммаСкидкиКРаспределению = СуммаСкидкиКРаспределению - СуммаБонусов;
			Комментарий = СтрШаблон(НСтр("ru = 'Округляем %1 до %2 %3 (%4 из %5)'"), 
				СуммаДокумента, 
				ПараметрыСкидки.ПорядокОкругления, 
				ПараметрыСкидки.ВариантОкругления, 
				СуммаБонусов, 
				?(ВКаждойСтроке, ОбщаяСуммаОкругленияСтроки, ОбщаяСуммаОкругленияДокумента)) ;
			Расшифровка = ПолучитьРасшифровкуСкидки(СтрокаДерева, СтрокаОкругления.КоличествоБонусныхБаллов, Параметры, Комментарий, Истина);
			СтрокаОкругления.Комментарий = Комментарий;
			НоваяСтрокаСкидки.Расшифровка = Расшифровка;
			ОбщаяСтрокаСкидок.ОценкаСкидки = ОбщаяСтрокаСкидок.ОценкаСкидки + СуммаБонусов * Курс;
				
		КонецЦикла;
		Если ВКаждойСтроке
			И СуммаСкидкиКРаспределению <> 0
			И СтрокаСкидкиДляРаспределения <> Неопределено Тогда
			ИсходноеНачислениеБонусов = СтрокаСкидкиДляРаспределения.ТаблицаБонусов[0];
			КорректировкаНачисленияБонусов = СтрокаСкидкиДляРаспределения.ТаблицаБонусов.Добавить();
			ЗаполнитьЗначенияСвойств(КорректировкаНачисленияБонусов, ИсходноеНачислениеБонусов);
			КорректировкаНачисленияБонусов.КоличествоБонусныхБаллов = СуммаСкидкиКРаспределению;
			СтрокаСкидкиДляРаспределения.ОценкаСкидки = СтрокаСкидкиДляРаспределения.ОценкаСкидки + СуммаСкидкиКРаспределению * Курс;
			Комментарий = НСтр("ru = 'Остаток дробной части после распределения в строке'");
			Расшифровка = ПолучитьРасшифровкуСкидки(СтрокаДерева, КорректировкаНачисленияБонусов.КоличествоБонусныхБаллов, Параметры, Комментарий);
			Для Каждого СтрокаНовойРасшифровки Из Расшифровка Цикл
				НоваяСтрокаРасшифровки = СтрокаСкидкиДляРаспределения.Расшифровка.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаРасшифровки, СтрокаНовойРасшифровки);
			КонецЦикла;
			КорректировкаНачисленияБонусов.Комментарий = Комментарий;
		КонецЕсли;
	КонецЦикла;
	
	Если СуммаСкидкиКРаспределению <> 0 И СтрокаСкидкиДляРаспределения <> Неопределено Тогда
		ИсходноеНачислениеБонусов = СтрокаСкидкиДляРаспределения.ТаблицаБонусов[0];
		КорректировкаНачисленияБонусов = СтрокаСкидкиДляРаспределения.ТаблицаБонусов.Добавить();
		ЗаполнитьЗначенияСвойств(КорректировкаНачисленияБонусов, ИсходноеНачислениеБонусов);
		КорректировкаНачисленияБонусов.КоличествоБонусныхБаллов = СуммаСкидкиКРаспределению;
		СтрокаСкидкиДляРаспределения.ОценкаСкидки = СтрокаСкидкиДляРаспределения.ОценкаСкидки + СуммаСкидкиКРаспределению * Курс;
		Комментарий = НСтр("ru = 'Остаток дробной части после распределения в документе'");
		Расшифровка = ПолучитьРасшифровкуСкидки(СтрокаДерева, КорректировкаНачисленияБонусов.КоличествоБонусныхБаллов, Параметры, Комментарий);
		Для Каждого СтрокаНовойРасшифровки Из Расшифровка Цикл
			НоваяСтрокаРасшифровки = СтрокаСкидкиДляРаспределения.Расшифровка.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаРасшифровки, СтрокаНовойРасшифровки);
		КонецЦикла;
		КорректировкаНачисленияБонусов.Комментарий = Комментарий;
	КонецЕсли;
	СтрокаДерева.ТаблицаДанных = ТаблицаДанных;
			
КонецПроцедуры

Функция ПолучитьВиртуальныйОбъектДляРасчетаСкидок(СтруктураСкидок, Параметры, ИмяТЧЗапасы = "Запасы")
	
	ВиртуальныйОбъект = Новый Структура();
	ВиртуальныйОбъект.Вставить("Подарки", ПустаяТаблицаПодарков());
	ВиртуальныйОбъект.Вставить("СкидкиНаценки", СтруктураСкидок.ТаблицаСкидкиНаценки.Скопировать()); 
	ВиртуальныйОбъект.Вставить("Ссылка", Параметры.Регистратор);
	ВиртуальныйОбъект.Вставить("СкидкиРассчитаны", Ложь);
	ВиртуальныйОбъект.Вставить("СуммаВключаетНДС" , Параметры.СуммаВключаетНДС);
	ВиртуальныйОбъект.Вставить("ДисконтнаяКарта", Параметры.ДисконтнаяКарта);
	ВиртуальныйОбъект.Вставить("ПроцентСкидкиПоДисконтнойКарте" , ДисконтныеКартыУНФВызовСервера.ВычислитьПроцентСкидкиПоДисконтнойКарте(Параметры.ТекущаяДата, Параметры.ДисконтнаяКарта));
	ВиртуальныйОбъект.Вставить("ПримененныеПромокоды", Параметры.ПримененныеПромокоды);
	
	// Сумма бонуса считается до переноса подарка в продажи. 
	// Даже если скидка, соответствующая стоимости подарка будет распределена на все товары чека
	// Таким образом, при пробитии двух идентичных чеков, когда в одном чеке мы выдаем подарок с распределением суммы
	// скидки по строкам чека А в другом чеке подарка не выдается, сумма бонусов должна быть идентичной, не зависимо от
	// выдачи или не выдачи подарков
	ВиртуальныйОбъект.Вставить("ОтменаПереносаПодарковВПродажи", Истина);
	
	// Для заказ-наряда таблица содержит строки и с товарами и с работами, отдельную ТЧ вставлять не требуется
	ВиртуальныйОбъект.Вставить(ИмяТЧЗапасы, Параметры.Товары.Скопировать());
	// Добавим стандартные поля ТЧ, необходимые для применения скидки к объекту
	Если ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("ПродажаПодарка") = Неопределено Тогда
		ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Добавить("ПродажаПодарка", Новый ОписаниеТипов("Булево"));		
	КонецЕсли;
	Если ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("ПроцентСкидкиНаценки") = Неопределено Тогда
		ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Добавить("ПроцентСкидкиНаценки", Новый ОписаниеТипов("Число"));
	КонецЕсли;
	Если ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("СуммаАвтоматическойСкидки") = Неопределено Тогда
		ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Добавить("СуммаАвтоматическойСкидки", Новый ОписаниеТипов("Число"));
	КонецЕсли;
	Если ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("ПроцентАвтоматическойСкидки") = Неопределено Тогда
		ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Добавить("ПроцентАвтоматическойСкидки", Новый ОписаниеТипов("Число"));
	КонецЕсли;
	Если ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("Цена") = Неопределено Тогда
		ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Добавить("Цена", Новый ОписаниеТипов("Число"));
		Если НЕ ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("ЦенаЗаУпаковку") = Неопределено Тогда
			ВиртуальныйОбъект[ИмяТЧЗапасы].ЗагрузитьКолонку(ВиртуальныйОбъект[ИмяТЧЗапасы].ВыгрузитьКолонку("ЦенаЗаУпаковку"), "Цена");
		КонецЕсли;
	КонецЕсли;
	Если ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("СуммаНДС") = Неопределено Тогда
		ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Добавить("СуммаНДС", Новый ОписаниеТипов("Число"));
	КонецЕсли;
	Если ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Найти("Всего") = Неопределено Тогда
		ВиртуальныйОбъект[ИмяТЧЗапасы].Колонки.Добавить("Всего", Новый ОписаниеТипов("Число"));
	КонецЕсли;

	Возврат ВиртуальныйОбъект;
КонецФункции

Процедура ПрименитьСкидкиКВиртуальномуОбъекту(ВиртуальныйОбъект, СтруктураСкидок, ИмяТЧЗапасы = "Запасы")
	Для Каждого СтрокаЗапаса Из ВиртуальныйОбъект[ИмяТЧЗапасы] Цикл
		// В таблице сумма - до применения всех скидок, включая ручные и оплату бонусами.
		НоваяСумма = СтрокаЗапаса.Цена * СтрокаЗапаса.Количество - СтрокаЗапаса.СуммаСкидкиНаценки;
		// При расчете начисления бонусных баллов, когда учитываются суммы скидки, оплата бонусными баллами тоже считается скидкой 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаЗапаса,"СуммаСкидкиОплатыБонусом") Тогда
			НоваяСумма = НоваяСумма - СтрокаЗапаса.СуммаСкидкиОплатыБонусом;
		КонецЕсли;
		СтрокаЗапаса.Сумма = НоваяСумма;
	КонецЦикла;
	// При виртуальном расчете скидок, с целью начисления бонусов после скидок, не будем выдавать подарки и выводить сообщения
	ПрименитьРассчитанныеСкидкиКОбъекту(ВиртуальныйОбъект, СтруктураСкидок, ИмяТЧЗапасы);
КонецПроцедуры	

#КонецОбласти  

#Область ПроцедурыРаботыСЗаголовкамиРучныхСкидок

// Функция выполняет изменение заголовков группы колонок "ЗапасыРучнаяСкидка" на форме.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  ИмяТабличнойЧасти - Строка - Имя табличной части
Процедура УстановитьЗаголовокГруппаКолонокРучнаяСкидка(Форма, ИмяТабличнойЧасти) Экспорт  
	
	Элементы = Форма.Элементы;
	
	// Строку поиска необходимо локализировать в соответствие с заголовками элементов формы.
	СтрокаПоиска = НСтр("ru = 'руч.'");  
	
	ИмяГруппыКолонокРучнаяСкидка = "ЗапасыРучнаяСкидка";	
	ЗаголовокКолонкиРучнаяСкидка = Элементы[ИмяТабличнойЧасти].ПодчиненныеЭлементы[ИмяГруппыКолонокРучнаяСкидка].Заголовок;
		
	Если СтрНайти(ЗаголовокКолонкиРучнаяСкидка, СтрокаПоиска) > 0 Тогда  
		
		НовыйЗаголовокКолонкиРучнаяСкидка = НСтр("ru = 'Скидка'"); 
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяГруппыКолонокРучнаяСкидка, 
			"Заголовок", НовыйЗаголовокКолонкиРучнаяСкидка);  
		
	КонецЕсли;
		
КонецПроцедуры 

// Процедура выполняет изменение заголовков группы полей "скидка" в итогах на форме.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
Процедура УстановитьЗаголовокИтогиРучнаяСкидка(Форма) Экспорт 
	
	Элементы 		= Форма.Элементы;
	ИмяСвойства 	= "Заголовок";  
	
	// Строку поиска необходимо локализировать в соответствие с заголовками элементов формы.
	СтрокаПоиска 	= НСтр("ru = 'руч.'");	 
	
	ИмяФормы = Форма.ИмяФормы;	
	Если ИмяФормы = "Документ.ОтчетОРозничныхПродажах.Форма.ФормаДокумента" Тогда
		
		// Итог сумма ручной скидки
		ИмяЭлемента = "ИтогСуммаРучнойСкидки";
		Если Элементы.Найти(ИмяЭлемента) <> Неопределено Тогда 
			
			ЗаголовокКолонкиСкидкаСумма = Элементы[ИмяЭлемента].Заголовок;
			Если СтрНайти(ЗаголовокКолонкиСкидкаСумма, СтрокаПоиска) > 0 Тогда  
				
				НовыйЗаголовокКолонкиИтогСуммаРучнойСкидки = НСтр("ru = 'Скидка'");
				
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяЭлемента, 
					ИмяСвойства, НовыйЗаголовокКолонкиИтогСуммаРучнойСкидки); 
				
			КонецЕсли;
			
		КонецЕсли;  
		
	КонецЕсли;
	
	// Скидка процент
	ИмяЭлемента = "СкидкаПроцент";
	Если Элементы.Найти(ИмяЭлемента) <> Неопределено Тогда 
		
		ЗаголовокКолонкиСкидкаПроцент = Элементы[ИмяЭлемента].Заголовок;	
		Если СтрНайти(ЗаголовокКолонкиСкидкаПроцент, СтрокаПоиска) > 0 Тогда  
			
			НовыйЗаголовокЗаголовокКолонкиСкидкаПроцент = НСтр("ru = 'Скидка, %'"); 
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяЭлемента, 
				ИмяСвойства, НовыйЗаголовокЗаголовокКолонкиСкидкаПроцент); 
			
		КонецЕсли; 
		
	КонецЕсли;
	
	// Скидка сумма
	ИмяЭлемента = "СкидкаСумма";
	Если Элементы.Найти(ИмяЭлемента) <> Неопределено Тогда 
		
		ЗаголовокКолонкиСкидкаСумма = Элементы[ИмяЭлемента].Заголовок;
		Если СтрНайти(ЗаголовокКолонкиСкидкаСумма, СтрокаПоиска) > 0 Тогда  
			
			НовыйЗаголовокЗаголовокКолонкиСкидкаСумма = НСтр("ru = 'Скидка, Σ'");
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяЭлемента, 
				ИмяСвойства, НовыйЗаголовокЗаголовокКолонкиСкидкаСумма); 
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры 

#КонецОбласти 

#Область ПроцедурыПроверкиУсловийСкидокНаценок

// Функция выполняет проверку выполнения условий скидок.
//
Процедура ПроверитьУсловия(СтрокаДерева, ВыполненныеУсловия, ПараметрыРасчета)
	
	СтрокаДерева.ПараметрыУсловий.Вставить("УсловияВыполнены", Истина);
	СтрокаДерева.ПараметрыУсловий.Вставить("КодыСтрок",        Новый Массив);
	СтрокаДерева.ПараметрыУсловий.Вставить("УсловияПоСтроке",  Новый Структура);
	СтрокаДерева.ПараметрыУсловий.Вставить("ТаблицаУсловий",   Новый ТаблицаЗначений);
	
	// Служебная таблица для временного хранения результатов проверки условий предоставления
	СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.Колонки.Добавить("УсловиеПредоставления", Новый ОписаниеТипов("СправочникСсылка.УсловияПредоставленияСкидокНаценок"));
	СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.Колонки.Добавить("ОбластьОграничения",    Новый ОписаниеТипов("ПеречислениеСсылка.ВариантыОбластейОграниченияСкидокНаценок"));
	СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.Колонки.Добавить("Выполнено");
	СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.Колонки.Добавить("КратностьВыполнения", Новый ОписаниеТипов("Число"));
	
	// Таблица применяется для проверки выполнения условий по строке.
	// Если у скидки существуют условия по строке то для этих условий в таблице будет создана колонка
	СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.Вставить("ТаблицаПроверкиУсловий", Новый ТаблицаЗначений);
	СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.Колонки.Добавить("КлючСвязи");
	СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.Индексы.Добавить("КлючСвязи");
	
	СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.Вставить("СоответствиеУсловийКолонкамТаблицыПроверкиУсловий", Новый Соответствие);
	
	// Служебные параметры
	//ЭтоПервоеУсловиеТаблицыПроверкиУсловий  = Истина;
	КоличествоКолонокТаблицыПроверкиУсловий = 0;
	КоличествоВыполненийУсловияВсего = неопределено;
	
	// Обходим все условия одной скидки.
	Для Каждого Условие Из СтрокаДерева.УсловияПредоставления Цикл
		
		КоличествоВыполненийУсловия = неопределено;
		
		СтрокаТаблицаУсловий = СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.Добавить();
		СтрокаТаблицаУсловий.УсловиеПредоставления = Условие.УсловиеПредоставления;
		СтрокаТаблицаУсловий.ОбластьОграничения    = Условие.ОбластьОграничения;
		
		НайденныеСтроки = Новый Массив;
		ТаблицаВыбранныхУправляемыхСкидок = Неопределено;
		Если Условие.ЗаАктивациюВручную
			И ПараметрыРасчета.Свойство("ВыбранныеУправляемыеСкидки", ТаблицаВыбранныхУправляемыхСкидок) Тогда
			// Возможно, несколько управляемых скидок используют одно и то же условие "за активацию вручную".
			// В этом  случае, сработают все скидки, связанные с этим условием.
			// Однако, пользователь выбрал конкретную скидку - проверим, ее ли активировали вручную на самом деле.
			УсловияВсехСтрок = ВыполненныеУсловия.НайтиСтроки(Новый Структура("Ссылка", Условие.УсловиеПредоставления));
			ОтборСкидки = Новый Структура("СкидкаНаценка", СтрокаДерева.СкидкаНаценка);
			Для Каждого УсловиеСтроки Из УсловияВсехСтрок Цикл
				ОтборСкидки.Вставить("КлючСвязи", УсловиеСтроки.КлючСвязи);
				АктивированныеУсловияСкидки = ТаблицаВыбранныхУправляемыхСкидок.НайтиСтроки(ОтборСкидки);
				Если АктивированныеУсловияСкидки.Количество() Тогда
					НайденныеСтроки.Добавить(УсловиеСтроки);
				КонецЕсли;
			КонецЦикла;
		Иначе
			ОтборСтрокСкидок = Новый Структура("Ссылка", Условие.УсловиеПредоставления);
			НайденныеСтроки = ВыполненныеУсловия.НайтиСтроки(ОтборСтрокСкидок);
		КонецЕсли;
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			// Условие не выполнено.
			СтрокаТаблицаУсловий.Выполнено = Ложь;
			
			СтрокаДерева.ПараметрыУсловий.УсловияВыполнены = Ложь;
			
		ИначеЕсли НайденныеСтроки.Количество() = 1 
			И (НайденныеСтроки[0].КлючСвязи = "0" 
				ИЛИ НайденныеСтроки[0].КлючСвязи = "-1") Тогда
			
			СтрокаТаблицаУсловий.Выполнено = Истина;
			// Условие выполнено. Условие не зависит от конкретных строк.
			Если Не НайденныеСтроки[0].КоличествоКомплектов = 0 Тогда
				Если КоличествоВыполненийУсловия = Неопределено Тогда
					КоличествоВыполненийУсловия = НайденныеСтроки[0].КоличествоКомплектов;
				Иначе
					КоличествоВыполненийУсловия = Мин(КоличествоВыполненийУсловия, НайденныеСтроки[0].КоличествоКомплектов);
				КонецЕсли;
			КонецЕсли;
			
		Иначе
			
			СтрокаТаблицаУсловий.Выполнено = Истина;
			// Условие выполнено. Найдено несколько строк, прошедших проверку условий.
			
			КоличествоКолонокТаблицыПроверкиУсловий = КоличествоКолонокТаблицыПроверкиУсловий + 1;
			ЗаголовокКолонки = "Условие" + Формат(КоличествоКолонокТаблицыПроверкиУсловий,"ЧГ=");
			ЗаголовокКолонкиКратность = ЗаголовокКолонки + "Кратность";
			
			СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.СоответствиеУсловийКолонкамТаблицыПроверкиУсловий.Вставить(Условие.УсловиеПредоставления, ЗаголовокКолонки);
			СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.Колонки.Добавить(ЗаголовокКолонки, Новый ОписаниеТипов("Булево"));
			СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.Колонки.Добавить(ЗаголовокКолонкиКратность, Новый ОписаниеТипов("Число"));
			
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				
				НайденныеСтрокиТаблицыПроверкиУсловий = СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.Найти(НайденнаяСтрока.КлючСвязи, "КлючСвязи");
				Если НайденныеСтрокиТаблицыПроверкиУсловий <> Неопределено Тогда
					НайденныеСтрокиТаблицыПроверкиУсловий[ЗаголовокКолонки] = Истина;
					НайденныеСтрокиТаблицыПроверкиУсловий[ЗаголовокКолонкиКратность] = НайденнаяСтрока.КоличествоКомплектов;					
				Иначе
					НоваяСтрока1 = СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.Добавить();
					НоваяСтрока1.КлючСвязи = НайденнаяСтрока.КлючСвязи;
					НоваяСтрока1[ЗаголовокКолонки] = Истина;
					НоваяСтрока1[ЗаголовокКолонкиКратность] = НайденнаяСтрока.КоличествоКомплектов;
				КонецЕсли;
				
				Если НЕ НайденнаяСтрока.КоличествоКомплектов = 0 Тогда
					Если КоличествоВыполненийУсловия = Неопределено Тогда
						КоличествоВыполненийУсловия = НайденнаяСтрока.КоличествоКомплектов;
					Иначе
						КоличествоВыполненийУсловия = Мин(КоличествоВыполненийУсловия, НайденнаяСтрока.КоличествоКомплектов);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		СтрокаТаблицаУсловий.КратностьВыполнения = КоличествоВыполненийУсловия;
		Если КоличествоВыполненийУсловияВсего = Неопределено И НЕ КоличествоВыполненийУсловия = Неопределено Тогда
			КоличествоВыполненийУсловияВсего = КоличествоВыполненийУсловия;
		ИначеЕсли НЕ КоличествоВыполненийУсловия = Неопределено Тогда
			КоличествоВыполненийУсловияВсего = Мин(КоличествоВыполненийУсловияВсего, КоличествоВыполненийУсловия);
		КонецЕсли;
		
		
	КонецЦикла;
	
	// Заполним коды строк...
	Если СтрокаДерева.ПараметрыУсловий.УсловияВыполнены Тогда
		
		Если СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.СоответствиеУсловийКолонкамТаблицыПроверкиУсловий.Количество() > 0 Тогда
			
			Отбор = Новый Структура;
			Для Каждого КлючИЗначение Из СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.СоответствиеУсловийКолонкамТаблицыПроверкиУсловий Цикл
				Отбор.Вставить(КлючИЗначение.Значение, Истина);
			КонецЦикла;
			
			НайденныеСтроки = СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.НайтиСтроки(Отбор);
			Для Каждого СтрокаТЗ Из НайденныеСтроки Цикл
				СтрокаДерева.ПараметрыУсловий.КодыСтрок.Добавить(СтрокаТЗ.КлючСвязи);
			КонецЦикла;
			
		КонецЕсли;
		
		СтрокаДерева.КоличествоВыполненийУсловия = КоличествоВыполненийУсловияВсего;
		
	КонецЕсли;

КонецПроцедуры// ПроверитьУсловия()

// Функция выполняет заполнение служебных реквизитов у строк дерева скидок.
//
Процедура ПроверитьУсловияРекурсивно(ДеревоСкидок, ВыполненныеУсловия, ПараметрыРасчета)
	
	Для Каждого СтрокаДерева Из ДеревоСкидок.Строки Цикл
		
		Если СтрокаДерева.ЭтоГруппа Тогда
			
			ПроверитьУсловияРекурсивно(СтрокаДерева, ВыполненныеУсловия, ПараметрыРасчета);
			
		Иначе
			
			ПроверитьУсловия(СтрокаДерева, ВыполненныеУсловия, ПараметрыРасчета);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры // ПроверитьУсловияРекурсивно()

#КонецОбласти

#Область ПроцедурыРасчетаСкидокНаценокПоДокументам

// Функция выполняет расчет скидок (наценок) по переданным параметрам.
//	Параметры:
// 		ПараметрыРасчета - Структура - Структура, представляющая данные документа для расчета
//		ВходныеПараметры - Структура - Параметры, как именно следует выполнить расчет
// 
//	Возвращаемое значение: 
//		Структура - см. СтруктураРассчитанныхСкидок
Функция РассчитатьДеревоСкидокНаценок(ПараметрыРасчета, ВходныеПараметры) Экспорт
	
	ПервыйПакетЗапросов = ПакетЗапросовСоздать();
	
	// Инициализация необходимых параметров, которые могут быть не переданы вызывающей процедурой
	ПервыйПакетЗапросов.Запрос.УстановитьПараметр("ГраницаДокумента", ПараметрыРасчета.ТекущаяДата);
	ПервыйПакетЗапросов.Запрос.УстановитьПараметр("ПромокодыСкидок", ПустаяТаблицаПромокодов());
	ПервыйПакетЗапросов.Запрос.УстановитьПараметр("ВыбранныеУправляемыеСкидки", ПустаяТаблицаУправляемыхСкидок());
	ПервыйПакетЗапросов.Запрос.УстановитьПараметр("ИспользуемыеВидыОплат", ПолучитьПустуюТаблицуИспользуемыхОплат());
	ПервыйПакетЗапросов.Запрос.УстановитьПараметр("ПолучатьПотенциальныеСкидкиЗаВидОплаты", Ложь);
	ПервыйПакетЗапросов.Запрос.УстановитьПараметр("ПолучатьПотенциальныеБонусыКНачислению", Ложь);
	
	Для Каждого ПараметрПакета Из ПараметрыРасчета Цикл
		ПервыйПакетЗапросов.Запрос.УстановитьПараметр(ПараметрПакета.Ключ, ПараметрПакета.Значение);
	КонецЦикла;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ПервыйПакетЗапросов.Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	КоличествоУровнейИерархииНоменклатуры = КоличествоУровнейПодготовленнойТаблицыИЕрархии(МенеджерВременныхТаблиц, "вт_ГруппыСИерархией");

	РассчитатьТаблицуИерархииКатегорийИНоменклатуры(ПараметрыРасчета, МенеджерВременныхТаблиц);
	
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаТовары(),														ПервыйПакетЗапросов, Истина);

	// Подготовка и выполнение первого пакета.
	ПакетЗапросовВставитьЗапросВПакет(СкидкиНаценкиСерверПереопределяемый.ТекстЗапросаТаблицаКурсыВалют(),				ПервыйПакетЗапросов);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаСкидкиНаценки(ВходныеПараметры.ТолькоПредварительныйРасчет), 	ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаУсловияПредоставления(),         								ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаПроизвольныхУсловий(),        									ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаСкидкиНаценкиПоЦеновымГруппам(), 								ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаСкидкиНаценкиПоКатегориямНоменклатуры(), 						ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаСкидкиНаценкиПоНоменклатуре(), 								ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаСкидкиНаценкиПоСегментамНоменклатуры(),						ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаПримененныхПромокодов(),										ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаУсловияВыбранныхУправляемыхСкидок(),							ПервыйПакетЗапросов, Истина);
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаВыбранныхВидовОплат(),											ПервыйПакетЗапросов, Истина);
	                              
	// Скидки после расчета нужно применить к таблице товаров, после чего запустить расчет бонусов
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаТаблицаСкидкиНаценкиПоВидуЦен(),		 								ПервыйПакетЗапросов, Истина);
	
	ПакетЗапросовВставитьЗапросВПакет(ТекстЗапросаВыполненныхУсловий(КоличествоУровнейИерархииНоменклатуры),			ПервыйПакетЗапросов, Истина);
	
	ПакетЗапросовВыполнить(ПервыйПакетЗапросов);
	
	ТаблицаВыполненныеУсловия = ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("ВыполненныеУсловияСкидокНаценок", ПервыйПакетЗапросов).Выгрузить();
	ТаблицаПроизвольныхУсловий = ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("ПроизвольныеУсловия", ПервыйПакетЗапросов).Выгрузить();
	ДобавитьВыполненныеПроизвольныеУсловияВТаблицу(ТаблицаПроизвольныхУсловий, ТаблицаВыполненныеУсловия, ПараметрыРасчета);
	ТаблицаИспользуемыеВидыОплат = ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("ИспользуемыеВидыОплат", ПервыйПакетЗапросов).Выгрузить();
		
	ОбъединенныеПараметры = ПодготовитьПараметрыРасчетаСкидок(ПервыйПакетЗапросов, ПараметрыРасчета, ВходныеПараметры);

	ДеревоСкидок = ПолучитьДеревоСкидок(ОбъединенныеПараметры.СкидкиНаценки.ВыгрузитьКолонку("СкидкаНаценка"));
	
	ИмяТЧЗапасы = "Запасы";
	Если ТипЗнч(ПараметрыРасчета.Регистратор) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
		ИмяТЧЗапасы = "РаботыИУслуги";
	ИначеЕсли ТипЗнч(ПараметрыРасчета.Регистратор) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		Если Ложь Тогда
			ИмяТЧЗапасы = "Работы";
		КонецЕсли;
	КонецЕсли;
	
	ПотенциальныеБонусыКНачислению = Неопределено;
	Если ПервыйПакетЗапросов.Запрос.Параметры.ПолучатьПотенциальныеБонусыКНачислению Тогда
		ПотенциальныеБонусыКНачислению = РассчитатьПотенциальныеБонусыКНачислению(ДеревоСкидок,
			ТаблицаВыполненныеУсловия, ПараметрыРасчета, ОбъединенныеПараметры);
		АктуализироватьДанныеПослеРасчетаПотенциальныхБонусовКНачислению(ДеревоСкидок,
			ТаблицаВыполненныеУсловия, ПараметрыРасчета, ОбъединенныеПараметры);
	КонецЕсли;
	
	ПотенциальныеСкидкиЗаВидОплаты = Новый Соответствие;
	
	ИмяПараметраЗапроса = "ПолучатьПотенциальныеСкидкиЗаВидОплаты";
	Если ПервыйПакетЗапросов.Запрос.Параметры[ИмяПараметраЗапроса] = Истина Тогда
		
		ПотенциальныеСкидкиЗаВидОплаты = ПотенциальныеСкидкиПоВидамОплаты(ДеревоСкидок,
			ТаблицаВыполненныеУсловия, ПараметрыРасчета, ОбъединенныеПараметры, ИмяТЧЗапасы);
			 
		// Все условия за виды оплат считались выполненными, для возможности альтернативного расчета за разные виды оплаты
		// Теперь оставим только те, что действительно сработали
		ПримененныеОплаты = ТаблицаИспользуемыеВидыОплат.НайтиСтроки(Новый Структура("Используется", Истина));
		СписокВидовОплатыПрименен = Новый Массив;
		Для Каждого СтрокаВидаОплат Из ПримененныеОплаты Цикл
			СписокВидовОплатыПрименен.Добавить(СтрокаВидаОплат.ВидОплаты);
		КонецЦикла;
		СписокВидовОплатыПрименен = ОбщегоНазначенияКлиентСервер.СвернутьМассив(СписокВидовОплатыПрименен);
		УдалитьУсловияЗаВидОплаты(ТаблицаВыполненныеУсловия, СписокВидовОплатыПрименен);
	КонецЕсли;
	
	ПроверитьУсловияРекурсивно(ДеревоСкидок, ТаблицаВыполненныеУсловия, ПараметрыРасчета);
	ДеревоСкидок.Колонки.Удалить(ДеревоСкидок.Колонки.УсловияПредоставления);
		
	Если ВходныеПараметры.ТолькоПредварительныйРасчет Тогда
		
		ТаблицаСкидокНаценок = Новый ТаблицаЗначений;
		ТаблицаСкидокНаценок.Колонки.Добавить("КлючСвязи",
			Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(36)));
		ТаблицаСкидокНаценок.Колонки.Добавить("СкидкаНаценка",
			Новый ОписаниеТипов("СправочникСсылка.АвтоматическиеСкидки"));
		ТаблицаСкидокНаценок.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));
		
		ВозвращаемыеДанные = Новый Структура;
		ВозвращаемыеДанные.Вставить("ДеревоСкидок", ДеревоСкидок);
		ВозвращаемыеДанные.Вставить("ТаблицаСкидкиНаценки", ТаблицаСкидокНаценок);
		ВозвращаемыеДанные.Вставить("ТаблицаСообщений", ПустаяТаблицаСообщений());
		ВозвращаемыеДанные.Вставить("ТаблицаПодарков", ПустаяТаблицаПодарков());
		ВозвращаемыеДанные.Вставить("ТаблицаБонусыКНачислению", ПустаяТаблицаБонусов());
		
		Возврат ВозвращаемыеДанные;
		
	КонецЕсли;
	СтруктураСкидок = СтруктураРассчитанныхСкидок(ДеревоСкидок, ОбъединенныеПараметры);
	
	// Посчитаем потенциальную скидку за виды оплаты, для чего нужно понять, как выбранные скидки применятся к документу
	Если ПотенциальныеСкидкиЗаВидОплаты.Количество() > 0 Тогда	
		// Создадим виртуальный объект, и попробуем применить скидки. 
		// На этом этапе срабатывают контроли минимальных цен, и правила совместного применения скидок
		КопияРезультатаРасчета = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураСкидок);
		ВиртуальныйОбъект = ПолучитьВиртуальныйОбъектДляРасчетаСкидок(КопияРезультатаРасчета, ОбъединенныеПараметры, ИмяТЧЗапасы);
		ПрименитьСкидкиКВиртуальномуОбъекту(ВиртуальныйОбъект, КопияРезультатаРасчета, ИмяТЧЗапасы);
		СуммаСкидки = ВиртуальныйОбъект[ИмяТЧЗапасы].Итог("СуммаАвтоматическойСкидки");
		Для Каждого СкидкаЗаВидОплаты Из ПотенциальныеСкидкиЗаВидОплаты Цикл
			// Возвращаем изменение при выборе вида оплаты, т.е. разницу в общей скидке двух вариантов 
			ПотенциальныеСкидкиЗаВидОплаты[СкидкаЗаВидОплаты.Ключ] = СкидкаЗаВидОплаты.Значение - СуммаСкидки;
		КонецЦикла;
		СтруктураСкидок.Вставить("ВозможныеСкидкиЗаВидОплаты", ПотенциальныеСкидкиЗаВидОплаты);
	КонецЕсли;

	Если ОбъединенныеПараметры.Свойство("СообщениеПользователю") Тогда
		ВходныеПараметры.Вставить("СообщениеПользователю", ОбъединенныеПараметры.СообщениеПользователю);
	КонецЕсли;
	
	Если ПервыйПакетЗапросов.Запрос.Параметры.ПолучатьПотенциальныеБонусыКНачислению
		И ПотенциальныеБонусыКНачислению <> Неопределено Тогда
		СтруктураСкидок.Вставить("ПотенциальныеБонусыКНачислению", ПотенциальныеБонусыКНачислению);
	КонецЕсли;
	
	Возврат СтруктураСкидок;
	
КонецФункции

// Подготавливает структуру параметров, необходимых для выполнения расчета скидок.
// 
// Параметры:
//  ПакетЗапросов		- см. СкидкиНаценкиСервер.ПолучитьДеревоСкидок
//  ПараметрыРасчета	- Структура - Данные документа, исходя из которых следует выполнить расчет скидок
//  ВходныеПараметры	- Структура - Уточняющие параметры, описывающие, как именно следует выполнить расчет скидок:
//		* БонуснаяПрограмма - СправочникСсылка.БонусныеПрограммы - Бонусная программа предъявленной дисконтной карты.
// 		* РассчитыватьБонусы - Булево - Следует ли выполнять расчет начисления бонусных баллов
//
// Возвращаемое значение:
// 	Структура - Параметры, необходимые для расчета скидок и бонусов:
//		* СкидкиНаценкиПоЦеновымГруппам - ТаблицаЗначений - Таблица уточнения размера скидки по ценовым группам. Одновременно может действовать только одна таблица уточнений.
//		* СкидкиНаценкиПоКатегориямНоменклатуры - ТаблицаЗначений - Таблица уточнения размера скидки по категориям номенклатуры. Одновременно может действовать только одна таблица уточнений.
//		* СкидкиНаценкиПоНоменклатуре - ТаблицаЗначений - Таблица уточнения размера скидки по номенклатуре, с учетом иерархии. Одновременно может действовать только одна таблица уточнений.
//		* СкидкиНаценкиПоВидуЦен - ТаблицаЗначений - Таблица уточнения размера скидки по виду цен. Одновременно может действовать только одна таблица уточнений.
//		* СкидкиНаценкиПоСегментамНоменклатуры - ТаблицаЗначений - Таблица уточнения размера скидки по сегментам номенклатуры. Одновременно может действовать только одна таблица уточнений.
//		* Товары - ТаблицаЗначений - Представление табличной части документа, содержащей продаваемые товары. Предварительно очищена от скидок и подарков.
//		* СкидкиНаценки - ТаблицаЗначений - Таблица скидок/наценок, которые могут быть применены к текущему документу (до проерки условий скидок, но после фильтров по поставщикам/складам и канала продаж)
//		* ПустаяТаблицаСкидокСРасшифровкой - ТаблицаЗначений - Таблица, в которой будет размещена расшифровка расчета скидок.
//		* ПустаяТаблицаРасшифровка - ТаблицаЗначений - см. ПолучитьПустуюТаблицуРасшифровки. Таблица,
//			в которой будет размещена расшифровка расчета скидок.
//		* Регистратор - ДокументСсылка - Ссылка на документ, для которого выполняется расчет скидок. Может быть пустой ссылкой. Служит для определения типа документа и момента времени уже  существующих движений в БД (чтобы их не учитывать).
//		* ВалютаДокумента - СправочникСсылка.Валюты - Валюта документа для пересчета курсов.
//		* СуммаВключаетНДС - Булево - Вариант учета НДС, выбранный в документе.
//		* ТекущаяДата - Дата - Дата документа.
//		* ТекущийВидЦен - СправочникСсылка.ВидыЦен - Вид цен, выбранный в документе.
//		* ТекущаяСтруктурнаяЕдиница - СправочникСсылка.СтруктурныеЕдиницы - Магазин, склад, или иное подразделение, осуществляющее продажу товара. В некоторых документах магазин может быть указан в табличной части.
//		* ПримененныеПромокоды - ТаблицаЗначений - см. ПустаяТаблицаПромокодов.
//			Список промокодов, которые были предъявлены покупателем.
//		* ВыбранныеУправляемыеСкидки - ТаблицаЗначений - см. ПустаяТаблицаУправляемыхСкидок.
//			Список условий управляемых скидок, активированных кассиром вручную.
//		* ДисконтнаяКарта - СправочникСсылка.ДисконтныеКарты - Предъявленная покупателем дисконтная карта
//		* РассчитыватьБонусы - Булево - Следует ли выполнять расчет начисленных бонусов при расчете скидок
//		* НачислятьБонусыДоСкидок - Булево - Если установлен, то сумма документа для расчета начисления бонусов будет определяться до применения ручных и автоматических скидок.
Функция ПодготовитьПараметрыРасчетаСкидок(ПакетЗапросов, ПараметрыРасчета, ВходныеПараметры)	

	// Подготовка параметров для расчета скидок.
	Параметры = Новый Структура;
	// Уточнения размера скидки по ценовой группе, номенклатурной группе или номенклатуре. По номенклатуре - с учетом иерархии.
	Параметры.Вставить("СкидкиНаценкиПоЦеновымГруппам", ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("СкидкиНаценкиПоЦеновымГруппам", ПакетЗапросов).Выгрузить());
	Параметры.Вставить("СкидкиНаценкиПоКатегориямНоменклатуры", ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("СкидкиНаценкиПоКатегориямНоменклатуры", ПакетЗапросов).Выгрузить());
	Параметры.Вставить("СкидкиНаценкиПоНоменклатуре", ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("СкидкиНаценкиПоНоменклатуре", ПакетЗапросов).Выгрузить());	
	Параметры.Вставить("СкидкиНаценкиПоВидуЦен", ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("СкидкиНаценкиПоВидуЦен", ПакетЗапросов).Выгрузить());	
	Параметры.Вставить("СкидкиНаценкиПоСегментамНоменклатуры", ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("СкидкиНаценкиПоСегментамНоменклатуры", ПакетЗапросов).Выгрузить());
	
	ТаблицаСкидкиНаценки      = ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("СкидкиНаценки", ПакетЗапросов).Выгрузить();

	ТЗТовары = ПакетЗапросовПолучитьРезультатЗапросаПоИмениТаблицы("Товары"            , ПакетЗапросов).Выгрузить();
	ТЗТовары.Колонки.Добавить("СуммаТочность2", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Неотрицательный)));
	ТЗТовары.Колонки.Добавить("АвтоСкидкаТочность2", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Любой)));
	ТЗТовары.Колонки.Добавить("ВсегоТочность2", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2, ДопустимыйЗнак.Неотрицательный)));
	
	ТаблицаМРЦ = Новый ТаблицаЗначений;
	ТаблицаМРЦ.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаМРЦ.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТаблицаМРЦ.Колонки.Добавить("ЕдиницаИзмерения", Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения, СправочникСсылка.КлассификаторЕдиницИзмерения"));
	ОписаниеТиповЧисло = Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15,2));
	ОписаниеТиповБулево = Новый ОписаниеТипов("Булево");
	ОписаниеТиповСтрокаУИД = Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(36));
	ТаблицаМРЦ.Колонки.Добавить("ЦенаМРЦ", ОписаниеТиповЧисло);
	ТаблицаМРЦ.Колонки.Добавить("КлючСвязи", ОписаниеТиповСтрокаУИД);
	ТаблицаМРЦ.Колонки.Добавить("ЭтоЦенаМРЦ", ОписаниеТиповБулево);
	
	МинимальныеЦеныИспользуются = ЦенообразованиеСерверПовтИсп.МинимальныеЦеныИспользуются();
	
	ЕстьДанныеМРЦ = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПараметрыРасчета, "ТаблицаМРЦ") Тогда
		ЕстьДанныеМРЦ = Истина;
		Для Каждого СтрокаТаблицы Из ПараметрыРасчета.ТаблицаМРЦ Цикл
			НоваяСтрока = ТаблицаМРЦ.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		КонецЦикла;
	КонецЕсли;
	
	Если (МинимальныеЦеныИспользуются Или ЕстьДанныеМРЦ)
		И ПараметрыРасчета.Товары.Колонки.Найти("ВидМинимальныхЦен") <> Неопределено Тогда
		
		МинимальныеЦеныИспользуются = Ложь;
		
		ТЗТовары.Колонки.Добавить("ВидМинимальныхЦен", Новый ОписаниеТипов("СправочникСсылка.ВидыЦен"));
		Для Каждого СтрокаТовары Из ТЗТовары Цикл 			
			НайденаСтрока = ПараметрыРасчета.Товары.Найти(СтрокаТовары.КлючСвязи, "КлючСвязи");
			Если НайденаСтрока <> Неопределено Тогда
				
				СтрокаТовары.ВидМинимальныхЦен = НайденаСтрока.ВидМинимальныхЦен;
				
				МинимальныеЦеныИспользуются = МАКС(
					МинимальныеЦеныИспользуются, 
					ЗначениеЗаполнено(НайденаСтрока.ВидМинимальныхЦен),
					ЕстьДанныеМРЦ);
				
				КонецЕсли;
				
		КонецЦикла;
		Если ТЗТовары.Колонки.Найти("МинимальнаяЦена") = Неопределено Тогда
			ИмяКолонкиПоиска = "КлючСвязиМинимальныеЦены";
			ТЗТовары.Колонки.Добавить("МинимальнаяЦена", Новый ОписаниеТипов("Число"));
			ТЗТовары.Колонки.Добавить(ИмяКолонкиПоиска, Новый ОписаниеТипов("Число"));   
			
			Если МинимальныеЦеныИспользуются Тогда
			
				ИндексКлючСвязи = 0;
				Для Каждого Товар Из ТЗТовары Цикл			
					ТабличныеЧастиУНФКлиентСервер.ЗаполнитьКлючСвязи(ТЗТовары, Товар, "КлючСвязиМинимальныеЦены", ИндексКлючСвязи);				
					ИндексКлючСвязи = ИндексКлючСвязи + 1;				
				КонецЦикла;
			
				ТаблицаЦен = ТаблицаЦенТоваров(ТЗТовары, Параметры.СкидкиНаценкиПоВидуЦен,
					ТаблицаМРЦ, 
					ПараметрыРасчета.ТекущаяДата, 
					ПараметрыРасчета.ВалютаДокумента, 
					ПараметрыРасчета.СуммаВключаетНДС);

				Для Каждого СтрокаЦен Из ТаблицаЦен Цикл
					Если СтрокаЦен.ЭтоМРЦ Тогда
						Отбор = Новый Структура("Номенклатура, Характеристика");
					Иначе
						Отбор = Новый Структура("Номенклатура, Характеристика, ВидМинимальныхЦен");
						Отбор.ВидМинимальныхЦен = СтрокаЦен.ВидЦен;
					КонецЕсли;
					ЗаполнитьЗначенияСвойств(Отбор, СтрокаЦен);
					СтрокиТоваров = ТЗТовары.НайтиСтроки(Отбор);
					Для Каждого ЗаписьМинимальныхЦен Из СтрокиТоваров Цикл
						ЗаписьМинимальныхЦен.МинимальнаяЦена = СтрокаЦен.ЦенаВВалютеДокумента;
					КонецЦикла;
				КонецЦикла;
				
				Параметры.Вставить("ТаблицаЦен", 				ТаблицаЦен);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;	
	
	Параметры.Вставить("Товары", ТЗТовары);
	Параметры.Вставить("СкидкиНаценки"                , ТаблицаСкидкиНаценки);
	Параметры.Вставить("ТаблицаМРЦ", ТаблицаМРЦ);
	
	// Пустые таблицы.
	Параметры.Вставить("ПустаяТаблицаСкидокСРасшифровкой", Неопределено);
	Параметры.Вставить("ПустаяТаблицаРасшифровка",	ПолучитьПустуюТаблицуРасшифровки());
	Параметры.Вставить("ТекущаяДата", 				ПараметрыРасчета.ТекущаяДата);
	Параметры.Вставить("Регистратор", 				ПараметрыРасчета.Регистратор);
	Параметры.Вставить("ВалютаДокумента", 			ПараметрыРасчета.ВалютаДокумента);
	Параметры.Вставить("ТекущийВидЦен", 			ПараметрыРасчета.ВидЦен);
	Параметры.Вставить("ДисконтнаяКарта", 			ПараметрыРасчета.ДисконтнаяКарта);
	Параметры.Вставить("ТекущаяСтруктурнаяЕдиница", Неопределено);
	Параметры.Вставить("ПримененныеПромокоды", 		?(ПараметрыРасчета.Свойство("ПромокодыСкидок"), ПараметрыРасчета.ПромокодыСкидок, ПустаяТаблицаПромокодов()));
	Параметры.Вставить("ВыбранныеУправляемыеСкидки",  ?(ПараметрыРасчета.Свойство("ВыбранныеУправляемыеСкидки"), ПараметрыРасчета.ВыбранныеУправляемыеСкидки, ПустаяТаблицаУправляемыхСкидок()));
	
	Если ЗначениеЗаполнено(ПараметрыРасчета.Магазин) Тогда
		Параметры.ТекущаяСтруктурнаяЕдиница = ПараметрыРасчета.Магазин;
	Иначе
		СкладОптовойПродажи = Неопределено;
		Если ПараметрыРасчета.Свойство("СкладПродажи", СкладОптовойПродажи) Тогда
			Параметры.ТекущаяСтруктурнаяЕдиница = СкладОптовойПродажи;
		КонецЕсли;
	КонецЕсли;
	Параметры.Вставить("СуммаВключаетНДС", 			ПараметрыРасчета.СуммаВключаетНДС);
	
	Параметры.Вставить("НачислятьБонусыДоСкидок", 	Ложь);
	Если ВходныеПараметры.Свойство("БонуснаяПрограмма") 
		И НЕ (ВходныеПараметры.Свойство("РассчитыватьБонусы") И ВходныеПараметры.РассчитыватьБонусы = Ложь) Тогда
		Параметры.Вставить("РассчитыватьБонусы", Истина);
		Параметры.Вставить("НачислятьБонусыДоСкидок", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВходныеПараметры.БонуснаяПрограмма, "УдалитьНачислятьБонусыДоСкидок"));
	Иначе
		Параметры.Вставить("РассчитыватьБонусы", Ложь);
	КонецЕсли;

	ВариантСовместногоПрименения = ?(ПараметрыРасчета.Свойство("ВариантСовместногоПрименения"),
		ПараметрыРасчета.ВариантСовместногоПрименения,
		Константы.ВариантыСовместногоПримененияСкидокНаценок.Получить());
	
	Параметры.Вставить("ВариантСовместногоПрименения", ВариантСовместногоПрименения);
	
	РучнаяСкидкаДействует = Ложь;
	СтруктураНастройкиСкидки = Справочники.АвтоматическиеСкидки.ВернутьНастройкиРучнойСкидки();
	Если СтруктураНастройкиСкидки <> Неопределено Тогда
		РучнаяСкидкаДействует = СтруктураНастройкиСкидки.РучнаяСкидкаДействует;
	КонецЕсли;
	Параметры.Вставить("РучнаяСкидкаДействует", РучнаяСкидкаДействует);
	
	// Индексирование таблиц
	Параметры.СкидкиНаценки.Индексы.Добавить("СкидкаНаценка");
	Возврат Параметры;

КонецФункции

// Пустая таблица расшифровки.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Получить пустую таблицу расшифровки:
// * СкидкаНаценка - СправочникСсылка.АвтоматическиеСкидки - 
// * Сумма - Число - 
// * КоличествоБонусныхБаллов - Число - 
// * СуммаРучнойСкидки - Число - 
// * ОграниченаМинимальнойЦеной - Булево - 
// * ИзменитьРучнуюСкидку - Булево - 
// * ЗначениеСкидкиНаценки - Число - 
// * Комментарий - Строка - 
Функция ПолучитьПустуюТаблицуРасшифровки() Экспорт
	Расшифровка = Новый ТаблицаЗначений;
	Расшифровка.Колонки.Добавить("СкидкаНаценка",				Новый ОписаниеТипов("СправочникСсылка.АвтоматическиеСкидки"));
	Расшифровка.Колонки.Добавить("Сумма",				        Новый ОписаниеТипов("Число"));
	Расшифровка.Колонки.Добавить("КоличествоБонусныхБаллов",	Новый ОписаниеТипов("Число"));
	Расшифровка.Колонки.Добавить("СуммаРучнойСкидки",			Новый ОписаниеТипов("Число"));
	Расшифровка.Колонки.Добавить("ОграниченаМинимальнойЦеной",	Новый ОписаниеТипов("Булево"));
	Расшифровка.Колонки.Добавить("ИзменитьРучнуюСкидку",		Новый ОписаниеТипов("Булево"));
	Расшифровка.Колонки.Добавить("ЗначениеСкидкиНаценки",		Новый ОписаниеТипов("Число"));
	Расшифровка.Колонки.Добавить("Комментарий",					Новый ОписаниеТипов("Строка"));
	Возврат Расшифровка
КонецФункции

// Процедура применяет результат расчета скидок (наценок) к объекту.
// Вызывается из форм документов.
// 
// Параметры:
//  Объект - ДокументОбъект
//  ИмяТЧ - Строка - Имя ТЧ
//  РезультатРасчетаСкидокНаценок - ТаблицаЗначений - Результат расчета скидок наценок
//  РеализацияСверхЗаказа - Булево - Реализация сверх заказа
//  ТоварыСверхЗаказа - Неопределено - Товары сверх заказа
//  ИмяТЧ2 - Неопределено - Имя т ч2
//  ДеревоСкидок - Неопределено - Дерево скидок
//  ДополнительныеПараметры - Неопределено, Структура - Дополнительные параметры:
//@skip-check method-too-many-params
Процедура ПрименитьРезультатРасчетаСкидокКОбъекту(Объект, ИмяТЧ, РезультатРасчетаСкидокНаценок, РеализацияСверхЗаказа = Ложь,
		ТоварыСверхЗаказа = Неопределено, ИмяТЧ2 = Неопределено, ДеревоСкидок = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СкидкиНаценки") Тогда
		Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
			МассивСтрокКУдалению = Новый Массив;
			Для Каждого СтрокаТаблицы Из Объект.СкидкиНаценки Цикл
				Если СтрокаТаблицы.ПриВозврате Тогда
					МассивСтрокКУдалению.Добавить(СтрокаТаблицы);
				КонецЕсли;
			КонецЦикла;
			Для Каждого СтрокаКУдалению Из МассивСтрокКУдалению Цикл
				Объект.СкидкиНаценки.Удалить(СтрокаКУдалению);
			КонецЦикла;
		Иначе
			Объект.СкидкиНаценки.Очистить();
			Если ТипЗнч(Объект.СкидкиНаценки) = Тип("ТаблицаЗначений") Тогда
				//@skip-check bsl-legacy-check-expression-type
				Объект.СкидкиНаценки = РезультатРасчетаСкидокНаценок.Скопировать();
			Иначе
				Для Каждого СтрокаСкидкиНаценки Из РезультатРасчетаСкидокНаценок Цикл
					ЭтоРучнаяСкидка = Ложь;
					Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаСкидкиНаценки, "ЭтоРучнаяСкидка") Тогда
						ЭтоРучнаяСкидка = СтрокаСкидкиНаценки.ЭтоРучнаяСкидка;
					КонецЕсли;
					Если Не ЭтоРучнаяСкидка Тогда
						НоваяСтрока = Объект.СкидкиНаценки.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСкидкиНаценки);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	АвтоматическиеСкидкиНаценки = РезультатРасчетаСкидокНаценок.Скопировать();
	Если АвтоматическиеСкидкиНаценки.Колонки.Найти("ЭтоРучнаяСкидка") = Неопределено Тогда
		АвтоматическиеСкидкиНаценки.Колонки.Добавить("ЭтоРучнаяСкидка", Новый ОписаниеТипов("Булево"));
	КонецЕсли;
	
	// Заполнение скидок в табличной части "Товары"
	АвтоматическиеСкидкиНаценки.Свернуть("КлючСвязи, ЭтоРучнаяСкидка", "Сумма");
	АвтоматическиеСкидкиНаценки.Индексы.Добавить("КлючСвязи");
	
	РучныеСкидкиСкорректированы = Ложь;
	Если НЕ ДополнительныеПараметры = Неопределено Тогда
		РучныеСкидкиСкорректированы = ДополнительныеПараметры.РучныеСкидкиСкорректированы;
	КонецЕсли;
	
	ЗаполнятьСуммуСкидки = Истина;
	РеквизитКлючСвязи = "КлючСвязи";
	ЭтоВозврат = Ложь;
	СуммаВключаетНДС = Истина;
	КлючСвязиЧисло = Истина;
	Если ТипЗнч(Объект) = Тип("ДанныеФормыСтруктура") 
		И НЕ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "Ссылка") Тогда
		// Это РМК
		РеквизитКлючСвязи = "ИдентификаторСтроки";
		ЭтоВозврат = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств");
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СуммаВключаетНДС") Тогда
			СуммаВключаетНДС = Объект.СуммаВключаетНДС;
		КонецЕсли;
		КлючСвязиЧисло = Ложь;
	ИначеЕсли ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		СуммаВключаетНДС = Объект.СуммаВключаетНДС;
	ИначеЕсли ТипЗнч(Объект.Ссылка) <> Тип("ДокументСсылка.ЧекККМВозврат") Тогда
		ЭтоВозврат = Истина;
		СуммаВключаетНДС = Объект.СуммаВключаетНДС;
	КонецЕсли;
	
	//ТЧТовары = Объект[ИмяТЧ];
	СоответствиеТЧ = Новый Соответствие;
	СоответствиеТЧ.Вставить(ИмяТЧ, РеквизитКлючСвязи);
	Если НЕ ИмяТЧ2 = Неопределено Тогда // Для заказ-наряда, в котором есть 2 ТЧ: "Работы" и "Запасы".
		СоответствиеТЧ.Вставить(ИмяТЧ2, "КлючСвязиДляСкидокНаценок");
	КонецЕсли;

	ПроцентСкидкиПоДисконтнойКарте = 0;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "ПроцентСкидкиПоДисконтнойКарте") Тогда
		ПроцентСкидкиПоДисконтнойКарте = Объект.ПроцентСкидкиПоДисконтнойКарте;
	КонецЕсли;	
	Для Каждого ТекЭлементСоответствия Из СоответствиеТЧ Цикл
		РеквизитКлючСвязи = ТекЭлементСоответствия.Значение;
		Для Каждого СтрокаТЧ Из Объект[ТекЭлементСоответствия.Ключ] Цикл
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "ТоварКЗамене")
				И СтрокаТЧ.ТоварКЗамене Тогда
				Продолжить;
			КонецЕсли;
			СуммаСкидкиОплатыБонусом = 0;
			СуммаАвтоматическойСкидки = 0;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "СуммаСкидкиОплатыБонусом") Тогда
				СуммаСкидкиОплатыБонусом = СтрокаТЧ.СуммаСкидкиОплатыБонусом;
			КонецЕсли;
			КлючСвязи = СтрокаТЧ[РеквизитКлючСвязи];
			Если КлючСвязиЧисло Тогда
				// В расчете скидок ключ связи представляется в виде строки, для совместимости с РМК
				КлючСвязи = XMLСтрока(КлючСвязи);
			КонецЕсли;
			ОтборСтрок = Новый Структура("КлючСвязи", КлючСвязи);
			СтрокиТаблицыСкидок = АвтоматическиеСкидкиНаценки.НайтиСтроки(ОтборСтрок);
			Если СтрокиТаблицыСкидок = Неопределено Тогда
				Если СтрокаТЧ.СуммаАвтоматическойСкидки = 0 И СтрокаТЧ.ПроцентАвтоматическойСкидки = 0 И СуммаСкидкиОплатыБонусом = 0 Тогда
					// Не будем пересчитывать строки, в которых значение автоматической скидки не поменялось.
					// Это нужно в тех случаях, когда сумму документа изменили вручную, а цена при этом не поменялась.
					// Это возможно, когда количество очень большое, а цена маленькая.
					// В этом случае при изменении суммы цена будет рассчитана как сумма / количество с округлением до 2-х знаков.
					Продолжить;
				КонецЕсли;
				СтрокаТЧ.СуммаАвтоматическойСкидки = 0;
			Иначе
				СуммаВключаетНДС = Истина;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СуммаВключаетНДС") Тогда
					СуммаВключаетНДС = Объект.СуммаВключаетНДС;
				КонецЕсли;
				СтруктураРасчета = Новый Структура;
				СтруктураРасчета.Вставить("СуммаСкидки", 0);
				СтруктураРасчета.Вставить("СуммаВключаетНДС", СуммаВключаетНДС);
				СтруктураРасчета.Вставить("РучныеСкидкиСкорректированы", РучныеСкидкиСкорректированы);
				ОбработатьСуммыСкидокИзТаблицы(СтрокиТаблицыСкидок, СтрокаТЧ, СтруктураРасчета);
				СуммаСкидки = СтруктураРасчета.СуммаСкидки;
				РучныеСкидкиСкорректированы = СтруктураРасчета.РучныеСкидкиСкорректированы;
				
				Если СуммаСкидки = 0 И СтрокаТЧ.СуммаАвтоматическойСкидки = 0 И СтрокаТЧ.ПроцентАвтоматическойСкидки = 0
					И СуммаСкидкиОплатыБонусом = 0 Тогда
					// Не будем пересчитывать строки, в которых значение автоматической скидки не поменялось.
					// Это нужно в тех случаях, когда сумму документа изменили вручную, а цена при этом не поменялась.
					// Это возможно, когда количество очень большое, а цена маленькая.
					// В этом случае при изменении суммы цена будет рассчитана как сумма / количество с округлением до 2-х знаков.
					Продолжить;
				КонецЕсли;
				СтрокаТЧ.СуммаАвтоматическойСкидки = СуммаСкидки;
				СуммаАвтоматическойСкидки = СтрокаТЧ.СуммаАвтоматическойСкидки; // Для точного расчета процента автоматической скидки
			КонецЕсли;

			Если НЕ ЭтоВозврат Тогда
				ЦенообразованиеСервер.УстановитьЗначенияРучнойСкидкиПоМинимальнойЦене(СтрокаТЧ, ДеревоСкидок, СуммаВключаетНДС, РеквизитКлючСвязи);
			КонецЕсли;
			ПересчитатьСуммыВСтрокеДокумента(СтрокаТЧ, 
				СуммаАвтоматическойСкидки, 
				ПроцентСкидкиПоДисконтнойКарте, 
				СуммаВключаетНДС, 
				ТекЭлементСоответствия.Ключ = "Работы", 
				ЗаполнятьСуммуСкидки);

		КонецЦикла;
	КонецЦикла;
	
	Если НЕ ДополнительныеПараметры = Неопределено Тогда
		ДополнительныеПараметры.РучныеСкидкиСкорректированы = РучныеСкидкиСкорректированы;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СкидкиРассчитаны") Тогда
		Объект.СкидкиРассчитаны = Истина;
	КонецЕсли;	
КонецПроцедуры // РассчитатьПоОбъекту()

Процедура ПрименитьРезультатРасчетаСкидокПодарковКОбъекту(Объект, ТаблицаПодарков, ТаблицаПодарковНаВыбор) Экспорт
	
	// Очистить ТЧ от уже перенесенных ранее подарков
	ОчиститьЗапасыОтПодарков(Объект);
	Для Каждого СтрокаПодарка Из ТаблицаПодарков Цикл
		Если СтрокаПодарка.ПодарокИзСписка Тогда
		    НоваяСтрока = ТаблицаПодарковНаВыбор.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПодарка);
		Иначе
		    НоваяСтрока = Объект.Подарки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПодарка);
			ТабличныеЧастиУНФКлиентСервер.ЗаполнитьКлючСвязи(Объект.Подарки, НоваяСтрока, "КлючСвязи");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры 

// Выполняет удаление строк из табличной части объекта "Запасы",
// в которых значение поля ПродажаПодарка установлено равным Истина.
//
// Параметры:
//  Объект - ДокументОбъект - документ из строк которого требуется исключить подарки.
//  ИмяТЧЗапасы - Строка - Не обязательный. Имя табличной части, содержащей строки с признаком "ПродажаПодарка", которые
//                         требуется удалить.
//  ТолькоУказанныеСтроки - Неопределено, Булево - Не обязательный. Перечень строк, которые требуется удалить.
//  						Если не указан, используется отбор по признаку "ПродажаПодарка", если передан перечень строк, признак игнорируется.
Процедура ОчиститьЗапасыОтПодарков(Объект, Знач ИмяТЧЗапасы = Неопределено, ТолькоУказанныеСтроки = Неопределено)
	
	Если ИмяТЧЗапасы = Неопределено Тогда
		Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
			ИмяТЧЗапасы = "РаботыИУслуги";
		Иначе
			ИмяТЧЗапасы = "Запасы";
		КонецЕсли;
	КонецЕсли;
	СтруктураПоиска = Новый Структура("ПродажаПодарка", Истина);
	СтрокиЗапасов = Новый Массив;
	Если ТолькоУказанныеСтроки = Неопределено Тогда
		СтрокиЗапасов = Объект[ИмяТЧЗапасы].НайтиСтроки(СтруктураПоиска);
	Иначе
		СтрокиЗапасов = ТолькоУказанныеСтроки;
	КонецЕсли;
	
	УдалятьАкцизныеМарки = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "АкцизныеМарки") Тогда
		УдалятьАкцизныеМарки = Истина;
	КонецЕсли;
	ИспользоватьСерииНоменклатурыОстатки = Ложь;
	УдалятьСерииНоменклатуры = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СерииНоменклатуры") Тогда
		УдалятьСерииНоменклатуры  = Истина;
		ИспользоватьСерииНоменклатурыОстатки = СерииНоменклатурыУНФ.ИспользоватьСерииНоменклатурыОстатки();
	КонецЕсли;
	УдалятьСерииПодарков = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СерииПодарков") Тогда
		УдалятьСерииПодарков  = Истина;
	КонецЕсли;
	УдалятьБонусныеБаллыКНачислению = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "БонусныеБаллыКНачислению") Тогда
		УдалятьБонусныеБаллыКНачислению = Истина;
	КонецЕсли;
	
	Для Каждого СтрокаЗапасов Из СтрокиЗапасов Цикл
		Если УдалятьАкцизныеМарки Тогда
			ТабличныеЧастиУНФКлиентСервер.УдалитьСтрокиПоКлючуСвязи(Объект.АкцизныеМарки, СтрокаЗапасов);
		КонецЕсли;
		Если УдалятьБонусныеБаллыКНачислению Тогда
			ТабличныеЧастиУНФКлиентСервер.УдалитьСтрокиПоКлючуСвязи(Объект.БонусныеБаллыКНачислению, СтрокаЗапасов);
		КонецЕсли;
		Если УдалятьСерииНоменклатуры Тогда
			СерииНоменклатурыУНФКлиентСервер.УдалитьСерииНоменклатурыПоКлючуСвязи(Объект.СерииНоменклатуры, СтрокаЗапасов,
				ИспользоватьСерииНоменклатурыОстатки);
		КонецЕсли;
		ТабличныеЧастиУНФКлиентСервер.УдалитьСтрокиПоКлючуСвязи(Объект.СкидкиНаценки, СтрокаЗапасов);
		Объект[ИмяТЧЗапасы].Удалить(СтрокаЗапасов);
	КонецЦикла;
	
	Если УдалятьСерииПодарков Тогда
		Объект.СерииПодарков.Очистить();
	КонецЕсли;
	Объект.Подарки.Очистить();		
	
КонецПроцедуры

// Процедура проверяет табличную часть Подарки документа на наличие таких подарков,
// которые должны быть оформлены как продажа.
// Такие подарки исключаются из табличной части Подарки, и переносятся в состав документа. На стоимость подарка
// предоставляется скидка. Вызывается из форм документов.

Функция ПеренестиПодаркиВЗапасы(Объект, ПримененныеСкидкиНаценки = Неопределено, АдресПримененныхСкидокВоВременномХранилище = "", ИмяТЧ = "Запасы") Экспорт
	
	Запасы = Объект[ИмяТЧ];
	
	Результат = Новый Структура();
	Результат.Вставить("Успех", Истина);
	Результат.Вставить("ПримененныеСкидкиНаценки", ПримененныеСкидкиНаценки);
	Если ПримененныеСкидкиНаценки = Неопределено Тогда
		Результат.Вставить("ПримененныеСкидкиНаценки", Новый Структура());
	КонецЕсли;
	Результат.Вставить("ДобавленныеСтрокиЗапасов", Новый Соответствие());
	Результат.Вставить("АдресПримененныхСкидокВоВременномХранилище", АдресПримененныхСкидокВоВременномХранилище);
	Если Запасы.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Объект.Подарки.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаСтрокПереносимыхПодарков = Неопределено;
	Если ТипЗнч(Объект.Подарки) = Тип("ТаблицаЗначений") Тогда
		ТаблицаСтрокПереносимыхПодарков = Объект.Подарки.Скопировать();
	Иначе
		ТаблицаСтрокПереносимыхПодарков = Объект.Подарки.Выгрузить();
	КонецЕсли;
	
	МассивУдаляемыхСтрок = Новый Массив;
	КоличествоПеренесенных = 0;
	ОбновитьПримененныеСкидкиВХранилище = Ложь;
	Если ПримененныеСкидкиНаценки = Неопределено 
		И ЗначениеЗаполнено(АдресПримененныхСкидокВоВременномХранилище) Тогда
		ПримененныеСкидкиНаценки = ПолучитьИзВременногоХранилища(АдресПримененныхСкидокВоВременномХранилище);
		ОбновитьПримененныеСкидкиВХранилище = Истина;
		Результат.Вставить("ПримененныеСкидкиНаценки", ПримененныеСкидкиНаценки);
	КонецЕсли;
	РазрешитьТолькоРаботы = ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.АктВыполненныхРабот");
	ТипыНоменклатурыРаботы = Новый Массив();
	ТипыНоменклатурыРаботы.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Работа"));
	ТипыНоменклатурыРаботы.Добавить(ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга"));
	
	Для Каждого СтрокаПодарка Из ТаблицаСтрокПереносимыхПодарков Цикл
		ПараметрыПодарка = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаПодарка.СкидкаНаценка, "УчитыватьПодарокКакПродажу, ПодарокИзКорзиныПокупателя");
		Учитывать = ПараметрыПодарка.УчитыватьПодарокКакПродажу ИЛИ ПараметрыПодарка.ПодарокИзКорзиныПокупателя;
		УдалятьСтроку = Истина;
		СтрокаСообщения = "";
		ВидПродукции = ОбщегоНазначенияИС.ВидПродукцииПоНоменклатуре(СтрокаПодарка.Номенклатура);
		Если Учитывать = Истина Тогда
			Если НЕ ЗначениеЗаполнено(СтрокаПодарка.СкидкаНаценка) Тогда
				СтрокаСообщения = НСтр("ru = 'Подарок в строке %1 нельзя учесть как продажу: не заполнена скидка'");
				СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, СтрокаПодарка.НомерСтроки);
			ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаПодарка.Номенклатура) Тогда
				СтрокаСообщения = НСтр("ru = 'Подарок ""%1"" нельзя учесть как продажу: не заполнена номенклатура'");
				СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, СтрокаПодарка.СкидкаНаценка);
			ИначеЕсли СтрокаПодарка.Количество <= 0 Тогда
				СтрокаСообщения = НСтр("ru = 'Подарок ""%1"" нельзя учесть как продажу: не корректно заполнено количество'");
				СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, СтрокаПодарка.Номенклатура);
			ИначеЕсли СтрокаПодарка.Сумма <= 0 Тогда
				СтрокаСообщения = НСтр("ru = 'Подарок ""%1"" нельзя учесть как продажу: не корректно заполнена сумма'");
				СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, СтрокаПодарка.Номенклатура);
			ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "ОтменаПереносаПодарковВПродажи")
				И Объект.ОтменаПереносаПодарковВПродажи Тогда
				СтрокаСообщения = НСтр("ru = 'Подарок ""%1"" нельзя учесть как продажу: в документе отменен учет подарков как продажи'");
				СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, СтрокаПодарка.Номенклатура);
			ИначеЕсли РазрешитьТолькоРаботы 
				И ТипыНоменклатурыРаботы.Найти(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаПодарка.Номенклатура, "ТипНоменклатуры")) = Неопределено Тогда
				СтрокаСообщения = НСтр("ru = 'Подарок ""%1"" нельзя учесть как продажу: в документе можно отразить только работы или услуги'");
				СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, СтрокаПодарка.Номенклатура);
			Иначе
				УдалятьСтроку = Ложь;
			КонецЕсли; 
		Иначе
			Если ВидПродукции = Перечисления.ВидыПродукцииИС.Табак Тогда
				Объект.Подарки.Очистить();
				СтрокаСообщения = НСтр("ru = 'Табачную продукцию ""%1"" можно дарить, учитывая только как продажу.'");
				СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаСообщения, СтрокаПодарка.Номенклатура);
			КонецЕсли;
		КонецЕсли;
		Если УдалятьСтроку Тогда
			МассивУдаляемыхСтрок.Добавить(СтрокаПодарка);
			Если ЗначениеЗаполнено(СтрокаСообщения) 
				// Расчет суммы виртуального объекта для корректного расчета бонусов, сообщения выводить не требуется
				И НЕ ТипЗнч(Объект) = Тип("Структура") Тогда 
				ОбщегоНазначения.СообщитьПользователю(СтрокаСообщения);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементМассива Из МассивУдаляемыхСтрок Цикл
		ТаблицаСтрокПереносимыхПодарков.Удалить(ЭлементМассива);
	КонецЦикла;
	
	Если ТаблицаСтрокПереносимыхПодарков.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
		
	// ГосИС
	
	СоответствиеПереносимыхСтрокПодарков = Новый Соответствие;
	Для Каждого СтрокаПодарка Из ТаблицаСтрокПереносимыхПодарков Цикл
							
		СтрокаПеренесенногоПодарка = Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПеренесенногоПодарка, СтрокаПодарка, , "КлючСвязи");
		ТабличныеЧастиУНФКлиентСервер.ЗаполнитьКлючСвязи(Запасы, СтрокаПеренесенногоПодарка, "КлючСвязи");
		СтрокаПеренесенногоПодарка.ПродажаПодарка = Истина;
		
		КодАкцизнойМарки = Неопределено;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаПодарка, "ШтрихкодУпаковки")
			И ЗначениеЗаполнено(СтрокаПодарка.ШтрихкодУпаковки) Тогда
			
			КодАкцизнойМарки = СтрокаПодарка.ШтрихкодУпаковки;

		КонецЕсли;
		КоличествоПеренесенных = КоличествоПеренесенных + 1;
		Результат.ДобавленныеСтрокиЗапасов.Вставить(СтрокаПеренесенногоПодарка, КодАкцизнойМарки); 
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "ПоложениеОтветственный") Тогда 
			ЗаполнениеОбъектовУНФ.ЗаполнитьСтрокуПоШапке(СтрокаПеренесенногоПодарка, Объект, "Ответственный", "ПоложениеОтветственный");
		КонецЕсли;
		СоответствиеПереносимыхСтрокПодарков[Объект.Подарки[СтрокаПодарка.НомерСтроки - 1]] = СтрокаПеренесенногоПодарка;
		
	КонецЦикла;
	
	ОбновитьСкидкиПослеПереносаПодарков(СоответствиеПереносимыхСтрокПодарков, Объект, ИмяТЧ, ПримененныеСкидкиНаценки);
	
	ЕстьСерииПодарков = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СерииПодарков")
		И Объект.СерииПодарков.Количество() > 0;
	Для Каждого СоответствиеСтрок Из СоответствиеПереносимыхСтрокПодарков Цикл
		
		СтрокаПодарка = СоответствиеСтрок.Ключ;
		СтрокаЗапаса = СоответствиеСтрок.Значение;
		Если ЕстьСерииПодарков Тогда 
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("КлючСвязи", СтрокаПодарка.КлючСвязи);
			СтрокиСерий = Объект.СерииПодарков.НайтиСтроки(СтруктураПоиска);
			МассивУдаляемыхСерий = Новый Массив;
			Если СтрокиСерий.Количество() = 0 Тогда
				СтруктураПоиска = Новый Структура;
				СтруктураПоиска.Вставить("Номенклатура", СтрокаПодарка.Номенклатура);
				СтруктураПоиска.Вставить("Характеристика", СтрокаПодарка.Характеристика);
				СтрокиСерий = Объект.СерииПодарков.НайтиСтроки(СтруктураПоиска);
			КонецЕсли;
			Для Каждого СтрокаСерии Из СтрокиСерий Цикл
				МассивУдаляемыхСерий.Добавить(СтрокаСерии);
				НоваяСтрока = Объект.Серии.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСерии);
				НоваяСтрока.КлючСвязи = СтрокаЗапаса.КлючСвязи;
			КонецЦикла;
			Для Каждого УдаляемаяСерия Из МассивУдаляемыхСерий Цикл
				Объект.СерииПодарков.Удалить(УдаляемаяСерия);
			КонецЦикла;
		КонецЕсли;
		Объект.Подарки.Удалить(СтрокаПодарка);
		
	КонецЦикла;
	
	СтруктураПересчетаВсего = Новый Структура;
	СуммаВключаетНДС = Истина;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СуммаВключаетНДС") Тогда
		СуммаВключаетНДС = Объект.СуммаВключаетНДС;
	КонецЕсли;
	СтруктураПересчетаВсего.Вставить("СуммаВключаетНДС", СуммаВключаетНДС);
	Для Каждого СтрокаЗапаса Из Запасы Цикл
		ТабличныеЧастиУНФКлиентСервер.РассчитатьСуммуНДСИВсего(СтрокаЗапаса, СтруктураПересчетаВсего);
	КонецЦикла;
	
	ДеревоСкидок = Неопределено;
	Если НЕ ПримененныеСкидкиНаценки = Неопределено Тогда
		ПримененныеСкидкиНаценки.Свойство("ДеревоСкидок", ДеревоСкидок);
	КонецЕсли;
	СкидкиНаценки = Объект.СкидкиНаценки.Выгрузить();
	СкидкиНаценкиСерверПереопределяемый.ПреобразоватьКлючСвязиВСтроку(СкидкиНаценки);
	Если СкидкиНаценки.Колонки.Найти("ЭтоРучнаяСкидка") = Неопределено Тогда
		СкидкиНаценки.Колонки.Добавить("ЭтоРучнаяСкидка", Новый ОписаниеТипов("Булево"));
	КонецЕсли;
	ПрименитьРезультатРасчетаСкидокКОбъекту(Объект, ИмяТЧ, СкидкиНаценки, , , , ДеревоСкидок);

	Если ОбновитьПримененныеСкидкиВХранилище Тогда
		АдресПримененныхСкидокВоВременномХранилище = ПоместитьВоВременноеХранилище(ПримененныеСкидкиНаценки, АдресПримененныхСкидокВоВременномХранилище);
		Результат.АдресПримененныхСкидокВоВременномХранилище = АдресПримененныхСкидокВоВременномХранилище;
	КонецЕсли;
		
	Возврат Результат;
КонецФункции

Функция РаспределитьСкидкуПодарок(СтрокаПодарка, СтрокаЗапаса, ТЧЗапасы, Параметры = Неопределено) Экспорт
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("КлючСвязи",Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(36)));
	Результат.Колонки.Добавить("Сумма",Новый ОписаниеТипов("Число"));
	Результат.Колонки.Добавить("ПроцентСкидки",Новый ОписаниеТипов("Число"));
	
	ТоварыИтогСумма = ТЧЗапасы.Итог("Сумма");
	СуммаТоваровНеУчаствующихВРаспределении = 0;
	ОбластьПредоставления_ВДокументе = ПредопределенноеЗначение("Перечисление.ВариантыОбластейОграниченияСкидокНаценок.ВДокументе");
	
	ЭтоРМК = Ложь;
	Если НЕ Параметры = Неопределено
	И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Параметры, "ЭтоРМК") Тогда
		ЭтоРМК = Параметры["ЭтоРМК"];
	КонецЕсли;
	ИмяПризнакаПодарка = "ПродажаПодарка";
	ИмяКолонкиКлючСвязи = "КлючСвязи";
	Если ЭтоРМК Тогда
		ИмяПризнакаПодарка = "Подарок";
		ИмяКолонкиКлючСвязи = "ИдентификаторСтроки";
	КонецЕсли;

	Для Каждого СтрокаТоваров Из ТЧЗапасы Цикл
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТоваров, ИмяПризнакаПодарка)
			И СтрокаТоваров[ИмяПризнакаПодарка] Тогда
			СуммаТоваровНеУчаствующихВРаспределении = СуммаТоваровНеУчаствующихВРаспределении + СтрокаТоваров.Сумма;
		ИначеЕсли СтрокаТоваров.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
			СуммаТоваровНеУчаствующихВРаспределении = СуммаТоваровНеУчаствующихВРаспределении + СтрокаТоваров.Сумма;
		ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТоваров, "ДоговорПлатежногоАгента")
			И ЗначениеЗаполнено(СтрокаТоваров.ДоговорПлатежногоАгента) Тогда
			СуммаТоваровНеУчаствующихВРаспределении = СуммаТоваровНеУчаствующихВРаспределении + СтрокаТоваров.Сумма;
		КонецЕсли;
		
	КонецЦикла;
	
	ОбщаяСумма = ТоварыИтогСумма - СуммаТоваровНеУчаствующихВРаспределении; 
	
	СуммаСкидкиКРаспределению = СтрокаПодарка.Сумма;
	ОбщаяСумма = ТоварыИтогСумма - СуммаТоваровНеУчаствующихВРаспределении;
	
	ПараметрыСкидки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаПодарка.СкидкаНаценка,
		"ОбластьПредоставления, ПодарокИзКорзиныПокупателя, УчитыватьПодарокКакПродажу");
	Если ПараметрыСкидки.ОбластьПредоставления = ОбластьПредоставления_ВДокументе
		И ПараметрыСкидки.УчитыватьПодарокКакПродажу Тогда
		// Скидка распределяется равномерно, в том числе на саму строку подарка, но не на строки других подарков.
		Если НЕ ПараметрыСкидки.ПодарокИзКорзиныПокупателя Тогда
			// Если ключ связи заполнен, то это подарок уже находящийся в табличной части, т.е. из корзины покупателя
			// Такой подарок не добавляется в ТЧ, потому его стоимость уже входит в общую сумму документа 
			ОбщаяСумма = ОбщаяСумма + СуммаСкидкиКРаспределению;
		КонецЕсли;
		Для Каждого СтрокаТоваров Из ТЧЗапасы Цикл
			
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТоваров, ИмяПризнакаПодарка)
				И СтрокаТоваров[ИмяПризнакаПодарка] Тогда
				Продолжить;
			ИначеЕсли СтрокаТоваров.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
				Продолжить;
			ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТоваров, "ДоговорПлатежногоАгента")
				И ЗначениеЗаполнено(СтрокаТоваров.ДоговорПлатежногоАгента) Тогда
				Продолжить;
			КонецЕсли;
			
			Если ОбщаяСумма <> 0 Тогда
				СуммаСкидки = Окр(СтрокаТоваров.Сумма * (СуммаСкидкиКРаспределению / ОбщаяСумма), 2); 
			Иначе
				СуммаСкидки = 0;
			КонецЕсли;
		
			Если ЦенообразованиеСерверПовтИсп.МинимальныеЦеныИспользуются() Тогда 
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТоваров, "МинимальнаяЦена") Тогда				
					МинимальнаяСумма = СтрокаТоваров.Количество * СтрокаТоваров.МинимальнаяЦена;
				ИначеЕсли Не Параметры = Неопределено
					И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Параметры, "ВидЦен")
					И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Параметры, "ДатаОбработки") 
					И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Параметры, "ВалютаДокумента")
					И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Параметры, "СуммаВключаетНДС") Тогда
					ПараметрыЦены = Новый Структура;
					ПараметрыЦены.Вставить("ВидЦен", Параметры.ВидЦен);
					ПараметрыЦены.Вставить("ДатаОбработки", Параметры.ДатаОбработки);
					ПараметрыЦены.Вставить("Номенклатура", СтрокаТоваров.Номенклатура);
					ПараметрыЦены.Вставить("Характеристика", СтрокаТоваров.Характеристика);
					ПараметрыЦены.Вставить("ВалютаДокумента", Параметры.ВалютаДокумента);
					ПараметрыЦены.Вставить("СуммаВключаетНДС", Параметры.СуммаВключаетНДС);  
					Если ТипЗнч(СтрокаТоваров.ЕдиницаИзмерения) = Тип("СправочникСсылка.ЕдиницыИзмерения") Тогда
						ПараметрыЦены.Вставить("Коэффициент", СтрокаТоваров.ЕдиницаИзмерения.Коэффициент);
					Иначе
						ПараметрыЦены.Вставить("Коэффициент", 1);
					КонецЕсли; 
					
					МинимальнаяЦена = ЦенообразованиеСервер.ПолучитьЦенуНоменклатурыПоВидуЦен(ПараметрыЦены);
					МинимальнаяСумма = СтрокаТоваров.Количество * МинимальнаяЦена;
				Иначе
					// Не удалось определить минимальную цену в строке. Скидка будет предоставлена только на сам подарок, без
					// распределения по документу.
					МинимальнаяСумма = СтрокаТоваров.Сумма;
				КонецЕсли;
				
				МаксимальнаяСкидка = СтрокаТоваров.Сумма - МинимальнаяСумма; 
				СуммаСкидки = Мин(МаксимальнаяСкидка, СуммаСкидки);
				СуммаСкидки = Макс(0, СуммаСкидки);
			КонецЕсли;
					
			СтрокаСкидки = Результат.Добавить();
			СтрокаСкидки.КлючСвязи = СтрокаТоваров[ИмяКолонкиКлючСвязи];
			СтрокаСкидки.Сумма = СуммаСкидки;
			СтрокаСкидки.ПроцентСкидки = ПолучитьПроцентСкидкиПоСтроке(СуммаСкидки, СтрокаТоваров);
			
			СуммаСкидкиКРаспределению = СуммаСкидкиКРаспределению - СуммаСкидки;
			ОбщаяСумма = ОбщаяСумма - СтрокаТоваров.Сумма;
			
		КонецЦикла;
	КонецЕсли;		
	
	Если СуммаСкидкиКРаспределению <> 0 Тогда
		СтрокаСкидки = Результат.Добавить();
		СтрокаСкидки.КлючСвязи = СтрокаЗапаса[ИмяКолонкиКлючСвязи];
		СтрокаСкидки.Сумма = СуммаСкидкиКРаспределению;
		СтрокаСкидки.ПроцентСкидки = ПолучитьПроцентСкидкиПоСтроке(СуммаСкидкиКРаспределению, СтрокаЗапаса);
	КонецЕсли;
	
	Возврат Результат;
				
КонецФункции 

Функция ПолучитьПроцентСкидкиПоСтроке(СуммаСкидки, СтрокаЗапаса)
	ПроцентСкидки = 0;
	СуммаБезСкидки = СтрокаЗапаса.Сумма;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаЗапаса, "Цена") Тогда  
		СуммаБезСкидки =  СтрокаЗапаса.Цена * СтрокаЗапаса.Количество;
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаЗапаса, "ЦенаЗаУпаковку") Тогда
		СуммаБезСкидки =  СтрокаЗапаса.ЦенаЗаУпаковку * СтрокаЗапаса.Количество;  
	КонецЕсли;
	Если НЕ СуммаБезСкидки = 0 Тогда
		ПроцентСкидки = Окр( 100 * СуммаСкидки / СуммаБезСкидки, 2);
	КонецЕсли;
    Возврат ПроцентСкидки;
КонецФункции

Процедура ДобавитьВыполненныеПроизвольныеУсловияВТаблицу(ТаблицаПроизвольныхУсловий, ТаблицаВыполненныеУсловия, ПараметрыРасчета)
	СобытиеЖурналаРегистрации = "СкидкиНаценкиСервер.ДобавитьВыполненныеПроизвольныеУсловияВТаблицу";
	ПредставлениеУровняОшибка = УровеньЖурналаРегистрации.Ошибка;
	ОбъектМетаданных = Метаданные.Справочники.УсловияПредоставленияСкидокНаценок;
	Для Каждого ОписаниеУсловия Из ТаблицаПроизвольныхУсловий Цикл
		// Получение скомпанованного макета СКД из хранилища
		
		// Все таблицы значений из параметров произвольных условий, размещенных в ПараметрыРасчета будут помещены во временные таблицы 
		МВТ = Новый МенеджерВременныхТаблиц;

		МакетКомпоновки = ОписаниеУсловия.ХранилищеСкомпонованногоМакета.Получить();
		Справочники.УсловияПредоставленияСкидокНаценок.ЗаполнитьПараметровУсловия(ОписаниеУсловия.ИмяСхемыКомпоновкиДанных, МакетКомпоновки.ЗначенияПараметров, ПараметрыРасчета, МВТ);
		
		// Выполнение СКД.
		ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки,,,Ложь,Ложь,МВТ);

		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		ТЗ = Новый ТаблицаЗначений;	
		ПроцессорВывода.УстановитьОбъект(ТЗ);
		ПривилегированныйРежимБылВключен = ПривилегированныйРежим();
		Попытка
			Если НЕ ПривилегированныйРежимБылВключен Тогда
				УстановитьПривилегированныйРежим(Истина);
			КонецЕсли;
			ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
			Если НЕ ПривилегированныйРежимБылВключен Тогда
				УстановитьПривилегированныйРежим(Ложь);
			КонецЕсли;
			// Если на выходе из СКД есть строки, прошедшие все фильтры - то условие выполнено.
			Для Каждого СтрокаВыполненногоПроизвольногоУсловия Из ТЗ Цикл
				ЗаполнитьЗначенияСвойств(ТаблицаВыполненныеУсловия.Добавить(), СтрокаВыполненногоПроизвольногоУсловия);			
			КонецЦикла;
		Исключение
			ОписаниеОшибки = ИнформацияОбОшибке();
			ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ОписаниеОшибки);
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(СобытиеЖурналаРегистрации, 
				ПредставлениеУровняОшибка, ОбъектМетаданных, ОписаниеУсловия.Ссылка, ТекстОшибки);			
		КонецПопытки;
        МВТ.Закрыть();
	КонецЦикла;
КонецПроцедуры

Процедура ПересчитатьСуммыВСтрокеДокумента(СтрокаТЧ, СуммаАвтоматическойСкидки, ПроцентСкидкиПоДисконтнойКарте, СуммаВключаетНДС, ЭтоРаботы = Ложь, ЗаполнятьСуммуСкидки = Ложь)
    СуммаБезСкидки = 0;
	
	СуммаСкидкиОплатыБонусом = 0;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "СуммаСкидкиОплатыБонусом") Тогда
		СуммаСкидкиОплатыБонусом = СтрокаТЧ.СуммаСкидкиОплатыБонусом;
	КонецЕсли;

	// Применение автоматической скидки.
	
	Если ЭтоРаботы Тогда
		СуммаБезСкидки = СтрокаТЧ.Количество * СтрокаТЧ.Кратность * СтрокаТЧ.Коэффициент * СтрокаТЧ.Цена;
	Иначе
		СуммаБезСкидки = СтрокаТЧ.Количество * СтрокаТЧ.Цена;
	КонецЕсли;
	
	// Скидки.
	СуммаПослеПримененияСкидокНаценок = Макс(СуммаБезСкидки - СуммаАвтоматическойСкидки - СуммаСкидкиОплатыБонусом, 0);
	Если СуммаБезСкидки <> 0 Тогда
		Если СтрокаТЧ.ПроцентСкидкиНаценки = 100 Тогда
			СуммаПослеПримененияСкидокНаценок = 0;
		ИначеЕсли (СтрокаТЧ.ПроцентСкидкиНаценки <> 0 ИЛИ СтрокаТЧ.СуммаСкидкиНаценки <> 0) 
			ИЛИ (ПроцентСкидкиПоДисконтнойКарте <> 0)
			И СтрокаТЧ.Количество <> 0 Тогда
			
			СуммаПослеПримененияСкидокНаценок = Макс(СуммаПослеПримененияСкидокНаценок - СтрокаТЧ.СуммаСкидкиНаценки, 0); //считаем скидку из СуммаСкидкиНаценки 
		КонецЕсли;
	КонецЕсли;
	
	СуммаРучнойСкидки = СуммаБезСкидки - (СуммаПослеПримененияСкидокНаценок + СуммаАвтоматическойСкидки + СуммаСкидкиОплатыБонусом);
	
	СтрокаТЧ.СуммаСкидкиНаценки = СуммаРучнойСкидки;
	СтрокаТЧ.ПроцентСкидкиНаценки = ?(СуммаБезСкидки = 0, 0 , 100 * СуммаРучнойСкидки / СуммаБезСкидки);
	СтрокаТЧ.ПроцентАвтоматическойСкидки = ?(СуммаБезСкидки = 0, 0 , 100 * СуммаАвтоматическойСкидки / СуммаБезСкидки);
	
	Сумма = СуммаБезСкидки - СуммаАвтоматическойСкидки - СуммаРучнойСкидки - СуммаСкидкиОплатыБонусом;
	
	СтрокаТЧ.Сумма = Макс(Сумма, 0);
	
	// Сумма НДС.
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТЧ.СтавкаНДС);

	СтрокаТЧ.СуммаНДС = ?(СуммаВключаетНДС, 
									  СтрокаТЧ.Сумма - (СтрокаТЧ.Сумма) / ((СтавкаНДС + 100) / 100),
									  СтрокаТЧ.Сумма * СтавкаНДС / 100);

	// Всего.
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "Всего") Тогда
		СтрокаТЧ.Всего = СтрокаТЧ.Сумма + ?(СуммаВключаетНДС, 0, СтрокаТЧ.СуммаНДС);
	КонецЕсли;
	
КонецПроцедуры

Функция УчестьРанееВыданныеПодарки(ТабличнаяЧасть, ТаблицаПодарковКВыдаче, ВыданныеПодаркиНеВТоварах = Неопределено, ЭтоРМК = Ложь) Экспорт

	Результат = Новый Структура();
	СоответствиеСтрокПодарковТоварам = Новый Соответствие;
	Товары = Новый ТаблицаЗначений();
	ТипЕдиницИзмерения = Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения");	
	
	Если ТипЗнч(ТабличнаяЧасть) = Тип("ТаблицаЗначений") Тогда
		Товары = ТабличнаяЧасть.Скопировать();
	Иначе
		Товары = ТабличнаяЧасть.Выгрузить();
	КонецЕсли;
	// Названия колонок отличаются, скопируем их для унификации логики
	СтруктураСоответствияПолей = Новый Структура;
	Если Не ЭтоРМК Тогда
		СтруктураСоответствияПолей.Вставить("Подарок", "ПродажаПодарка");
		СтруктураСоответствияПолей.Вставить("Упаковка", "ЕдиницаИзмерения");
		СтруктураСоответствияПолей.Вставить("КоличествоУпаковок", "Количество");
	Иначе
		СтруктураСоответствияПолей.Вставить("КлючСвязи", "ИдентификаторСтроки");
	КонецЕсли;
	Для Каждого ДобавляемоеПоле Из СтруктураСоответствияПолей Цикл
		Товары.Колонки.Добавить(ДобавляемоеПоле.Ключ, Товары.Колонки[ДобавляемоеПоле.Значение].ТипЗначения);	
		Товары.ЗагрузитьКолонку(Товары.ВыгрузитьКолонку(ДобавляемоеПоле.Значение), ДобавляемоеПоле.Ключ); 
	КонецЦикла;
	Товары.Индексы.Добавить("КлючСвязи");
	ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка";
	Если НЕ ТаблицаПодарковКВыдаче.Колонки.Найти("ЕдиницаИзмерения") = Неопределено Тогда
		ИмяКолонкиУпаковкаВТаблицеПодарков = "ЕдиницаИзмерения"; 
	КонецЕсли;
	Если ЭтоРМК
		И ТаблицаПодарковКВыдаче.Колонки.Найти("НаименованиеДляПечатиНоменклатуры") = Неопределено Тогда
		ТаблицаПодарковКВыдаче.Колонки.Добавить("НаименованиеДляПечатиНоменклатуры", Новый ОписаниеТипов("Строка"));
	КонецЕсли;
	Если ЭтоРМК
		И ТаблицаПодарковКВыдаче.Колонки.Найти("НаименованиеДляПечатиХарактеристики") = Неопределено Тогда
		ТаблицаПодарковКВыдаче.Колонки.Добавить("НаименованиеДляПечатиХарактеристики", Новый ОписаниеТипов("Строка"));
	КонецЕсли;
	
	// Поиск подарков может идти как в таблице товаров (когда подарок учитывается как продажа и фигурирует в Чеке)
	// Так и в отдельной табличной части Подарки, по которой впоследствии, формируются документы Списания
	// В какую именно табличную часть попадает подарок, регулируется настройками скидки с выдачей подарка.
	ИскатьВТЧПодарков = Не ВыданныеПодаркиНеВТоварах = Неопределено;
	ПодаркиВТаблицеВыданныхПодарков = Новый ТаблицаЗначений;
	Если ИскатьВТЧПодарков И ТипЗнч(ВыданныеПодаркиНеВТоварах) = Тип("ТаблицаЗначений") Тогда 
		ПодаркиВТаблицеВыданныхПодарков = ВыданныеПодаркиНеВТоварах.Скопировать();
	ИначеЕсли ИскатьВТЧПодарков Тогда 
		ПодаркиВТаблицеВыданныхПодарков = ВыданныеПодаркиНеВТоварах.Выгрузить();
	КонецЕсли;
	ПодаркиВТаблицеВыданныхПодарков.Колонки.Добавить("Подарок", Новый ОписаниеТипов("Булево"));
	ПодаркиВТаблицеВыданныхПодарков.ЗаполнитьЗначения(Истина, "Подарок");
	Если НЕ ПодаркиВТаблицеВыданныхПодарков.Колонки.Найти("ЕдиницаИзмерения") = Неопределено Тогда
		ПодаркиВТаблицеВыданныхПодарков.Колонки.Добавить("Упаковка", ТипЕдиницИзмерения);
		ПодаркиВТаблицеВыданныхПодарков.ЗагрузитьКолонку(ПодаркиВТаблицеВыданныхПодарков.ВыгрузитьКолонку("ЕдиницаИзмерения"), "Упаковка"); 
	КонецЕсли;
	
	ПодаркиУжеВыданы = ТаблицаПодарковКВыдаче.СкопироватьКолонки();
	ПодаркиУжеВыданы.Колонки.Добавить("СтрокаТоваров");
	СписокКолонок = "Номенклатура, Характеристика, Упаковка, Подарок, Количество, КоличествоУпаковок, Сумма, КлючСвязи";
	Если Не Товары.Колонки.Найти("НомерВариантаКП") = Неопределено Тогда
		СписокКолонок = СписокКолонок + ", НомерВариантаКП";
	КонецЕсли;
	СтрокиПодарковВТоварах = Товары.НайтиСтроки(Новый Структура("Подарок", Истина));
	ПодаркиВТоварахКЗачету = Товары.Скопировать(СтрокиПодарковВТоварах, СписокКолонок);
	ПодаркиВТоварахКЗачету.Индексы.Добавить("Номенклатура, Характеристика, Упаковка, Подарок");
	ПодаркиВТоварахКЗачету.Индексы.Добавить("КлючСвязи");
	Если ТаблицаПодарковКВыдаче.Количество() > 0 Тогда
		ВариантыПодарковУдалить = Новый Массив();
		Для Каждого ПодарокКВыдаче Из ТаблицаПодарковКВыдаче Цикл
			
			Если ПодарокКВыдаче.Количество <= 0 Тогда
				Продолжить;
			КонецЕсли;
			ЗафиксированныйРанееПодарок = Неопределено;
			
			Если ЭтоРМК Тогда
				ИмяРеквизита = "НаименованиеПолное";
				ПодарокКВыдаче.НаименованиеДляПечатиНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
					ПодарокКВыдаче.Номенклатура, ИмяРеквизита);
				Если ЗначениеЗаполнено(ПодарокКВыдаче.Характеристика) Тогда
					ИмяРеквизита = "НаименованиеДляПечати";
					ПодарокКВыдаче.НаименованиеДляПечатиХарактеристики = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
						ПодарокКВыдаче.Характеристика, ИмяРеквизита);
				КонецЕсли;
			КонецЕсли;
			
			КоличествоПодарковВыдать = ПодарокКВыдаче.Количество; 			
			КоэффициентУпаковки = 1;
			Если ТипЗнч(ПодарокКВыдаче[ИмяКолонкиУпаковкаВТаблицеПодарков]) = Тип("СправочникСсылка.ЕдиницыИзмерения") Тогда
				КоэффициентУпаковки = ПодарокКВыдаче[ИмяКолонкиУпаковкаВТаблицеПодарков].Коэффициент;
				Если КоэффициентУпаковки = 0 Тогда
					КоэффициентУпаковки = 1;
				КонецЕсли;
			КонецЕсли;
			ОтборРанееВыданныхПодарков = Новый Структура("Номенклатура, Характеристика, Подарок, " + ИмяКолонкиУпаковкаВТаблицеПодарков, 
				ПодарокКВыдаче.Номенклатура, 
				ПодарокКВыдаче.Характеристика,
				Истина,
				ПодарокКВыдаче[ИмяКолонкиУпаковкаВТаблицеПодарков]);
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПодарокКВыдаче, "НомерВариантаКП") Тогда
				ОтборРанееВыданныхПодарков.Вставить("НомерВариантаКП", ПодарокКВыдаче.НомерВариантаКП);
			КонецЕсли;
				
			ОтборРанееВыданныхПодарков[ИмяКолонкиУпаковкаВТаблицеПодарков] = ТипЕдиницИзмерения.ПривестиЗначение(ОтборРанееВыданныхПодарков[ИмяКолонкиУпаковкаВТаблицеПодарков]);
			Если ЭтоРМК ИЛИ Не ЗначениеЗаполнено(ОтборРанееВыданныхПодарков[ИмяКолонкиУпаковкаВТаблицеПодарков]) Тогда
				ОтборРанееВыданныхПодарков.Удалить(ИмяКолонкиУпаковкаВТаблицеПодарков);
 			КонецЕсли;
			УжеВыданныеПодаркиКЗачету = ПодаркиВТоварахКЗачету.НайтиСтроки(ОтборРанееВыданныхПодарков);
			Для Каждого ВыданныйПодарокКЗачету Из УжеВыданныеПодаркиКЗачету Цикл				
				Если КоличествоПодарковВыдать <= 0 Тогда
					Прервать;
				КонецЕсли;
				ЗафиксированныйРанееПодарок = ПодаркиУжеВыданы.Добавить();
				СписокКолонокИсключение = "Количество, Сумма";
				Если ЭтоРМК и ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка" Тогда
					СписокКолонокИсключение = СписокКолонокИсключение + ", КоличествоУпаковок";
				Иначе
					СписокКолонокИсключение = СписокКолонокИсключение + ", ПодарокИзСписка";
				КонецЕсли;
				ЗаполнитьЗначенияСвойств(ЗафиксированныйРанееПодарок, ПодарокКВыдаче,,СписокКолонокИсключение);
				ЗафиксированныйРанееПодарок.СтрокаТоваров = ВыданныйПодарокКЗачету;
				
				ЗачитываемоеКоличествоУпаковок = Мин(ВыданныйПодарокКЗачету.КоличествоУпаковок, КоличествоПодарковВыдать);
				ЗачитываемоеКоличество = ЗачитываемоеКоличествоУпаковок * КоэффициентУпаковки;
				ЗачитываемаяСумма = 0;
				Если НЕ ПодарокКВыдаче.Количество = 0 Тогда
					ЗачитываемаяСумма = Окр(ПодарокКВыдаче.Сумма * (ЗачитываемоеКоличествоУпаковок / ПодарокКВыдаче.Количество), 2);
				КонецЕсли;
				// Зачтем ранее выданный подарок (уменьшим количество к зачету)
				ВыданныйПодарокКЗачету.КоличествоУпаковок = ВыданныйПодарокКЗачету.КоличествоУпаковок - ЗачитываемоеКоличествоУпаковок;
				ВыданныйПодарокКЗачету.Количество = ВыданныйПодарокКЗачету.Количество - ЗачитываемоеКоличество;
				ВыданныйПодарокКЗачету.Сумма = ВыданныйПодарокКЗачету.Сумма - ЗачитываемаяСумма;
								
				ЗафиксированныйРанееПодарок.Количество = ЗачитываемоеКоличествоУпаковок;
				ЗафиксированныйРанееПодарок.Сумма = ЗачитываемаяСумма; 
				Если ЭтоРМК и ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка" Тогда
					ЗафиксированныйРанееПодарок.Количество = ЗачитываемоеКоличество;
					ЗафиксированныйРанееПодарок.КоличествоУпаковок = ЗачитываемоеКоличествоУпаковок;
				КонецЕсли;
				
				КоличествоПодарковВыдать = КоличествоПодарковВыдать - ЗачитываемоеКоличествоУпаковок;
			КонецЦикла;
			Если ИскатьВТЧПодарков И КоличествоПодарковВыдать > 0 Тогда
				// Если надо уменьшить ранее выданное количество
				ЗачитываемыеПодарки = ПодаркиВТаблицеВыданныхПодарков.НайтиСтроки(ОтборРанееВыданныхПодарков);
				Для Каждого СтрокаЗачитываемогоПодарка Из ЗачитываемыеПодарки Цикл				
					Если КоличествоПодарковВыдать <= 0 Тогда
						Прервать;
					КонецЕсли;
					ЗачитываемоеКоличествоУпаковок = Мин(СтрокаЗачитываемогоПодарка.Количество, КоличествоПодарковВыдать);
					ЗачитываемаяСумма = 0;
					Если НЕ ЗачитываемоеКоличествоУпаковок = 0 Тогда
						ЗачитываемаяСумма = Окр(ПодарокКВыдаче.Сумма * (СтрокаЗачитываемогоПодарка.Количество / ЗачитываемоеКоличествоУпаковок), 2);
					КонецЕсли;					
					// Зачитываем, уменьшаем количество к зачету 
					СтрокаЗачитываемогоПодарка.Количество = СтрокаЗачитываемогоПодарка.Количество - ЗачитываемоеКоличествоУпаковок;				
					СтрокаЗачитываемогоПодарка.Сумма = СтрокаЗачитываемогоПодарка.Сумма - ЗачитываемаяСумма;				
					
					КоличествоПодарковВыдать = КоличествоПодарковВыдать - ЗачитываемоеКоличествоУпаковок;
				КонецЦикла;
			КонецЕсли;
			КоличествоПодарковВыдано = ПодарокКВыдаче.Количество - КоличествоПодарковВыдать;				
			Если КоличествоПодарковВыдано > 0 Тогда				
				// Если это подарок на выбор, то один выданный подарок должен уменьшить количество любых других вариантов подарка
				// А вот если это выдача комплекта подарка, то зачитывается только конкретные единицы выданного товара
				ЭтоПодарокИзСписка = Ложь;
				// Те подарки, что уже выданы ранее, уберем из таблице подарков к выдаче
				Если ЭтоРМК и ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка" Тогда
					ОтборВариантовПодаркаПоСкидке = Новый Структура("ВладелецПодарка, ВыборИзСписка", ПодарокКВыдаче.ВладелецПодарка, ПодарокКВыдаче.ВыборИзСписка);
					ЭтоПодарокИзСписка = ПодарокКВыдаче.ВыборИзСписка;
				Иначе
					ОтборВариантовПодаркаПоСкидке = Новый Структура("СкидкаНаценка, ПодарокИзСписка", ПодарокКВыдаче.СкидкаНаценка, ПодарокКВыдаче.ПодарокИзСписка);
					ЭтоПодарокИзСписка = ПодарокКВыдаче.ПодарокИзСписка;
				КонецЕсли;
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПодарокКВыдаче, "НомерВариантаКП") Тогда
					ОтборВариантовПодаркаПоСкидке.Вставить("НомерВариантаКП", ПодарокКВыдаче.НомерВариантаКП);
				КонецЕсли;
				Если Не ЭтоПодарокИзСписка Тогда
					ОтборВариантовПодаркаПоСкидке.Вставить("Номенклатура", ПодарокКВыдаче.Номенклатура);
					ОтборВариантовПодаркаПоСкидке.Вставить("Характеристика", ПодарокКВыдаче.Характеристика);
				КонецЕсли;
				
				ВариантыПодарка = ТаблицаПодарковКВыдаче.НайтиСтроки(ОтборВариантовПодаркаПоСкидке);
				Для Каждого ДругойВариант Из ВариантыПодарка Цикл
					Если ДругойВариант.Количество = 0 Тогда
						Продолжить;
					КонецЕсли;
					КоэффициентУпаковкиВарианта = 1;
					Если ТипЗнч(ДругойВариант[ИмяКолонкиУпаковкаВТаблицеПодарков]) = Тип("СправочникСсылка.ЕдиницыИзмерения") Тогда
						КоэффициентУпаковкиВарианта = ДругойВариант[ИмяКолонкиУпаковкаВТаблицеПодарков].Коэффициент;
						Если КоэффициентУпаковкиВарианта = 0 Тогда
							КоэффициентУпаковкиВарианта = 1;
						КонецЕсли;
					КонецЕсли;
					КоличествоДругойВариант = ДругойВариант.Количество * КоэффициентУпаковкиВарианта;
					Если ЭтоРМК и ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка" Тогда
						КоличествоДругойВариант = ДругойВариант.КоличествоУпаковок * КоэффициентУпаковкиВарианта;
					КонецЕсли;
					КоличествоУпаковокДругойВариант = КоличествоДругойВариант / КоэффициентУпаковкиВарианта;
					КоличествоЗачесть = Цел(Мин(КоличествоДругойВариант, КоличествоПодарковВыдано * КоэффициентУпаковки) / КоэффициентУпаковкиВарианта);
					НовоеКоличество = ДругойВариант.Количество - КоличествоЗачесть;
					НовоеКоличествоУпаковок = НовоеКоличество / КоэффициентУпаковкиВарианта;
					НоваяСумма = Окр(ДругойВариант.Сумма * (НовоеКоличествоУпаковок / КоличествоУпаковокДругойВариант), 2);
					Если ЭтоРМК и ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка" Тогда
						ДругойВариант.КоличествоУпаковок = НовоеКоличествоУпаковок;
					КонецЕсли;
					ДругойВариант.Количество = НовоеКоличество;
					ДругойВариант.Сумма = НоваяСумма;
					Если ДругойВариант.Количество <= 0 Тогда
						ВариантыПодарковУдалить.Добавить(ДругойВариант);
					КонецЕсли;
					
					Если НЕ ЭтоПодарокИзСписка Тогда
						КоличествоПодарковВыдано = КоличествоПодарковВыдано - (КоличествоЗачесть * КоэффициентУпаковкиВарианта / КоэффициентУпаковки);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		Для Каждого ВариантПодаркаУдалить Из ВариантыПодарковУдалить Цикл
			ТаблицаПодарковКВыдаче.Удалить(ВариантПодаркаУдалить);
		КонецЦикла; 
	КонецЕсли;
	
	Если ТаблицаПодарковКВыдаче.Колонки.Найти("УжеВыдан") = Неопределено Тогда
		ТаблицаПодарковКВыдаче.Колонки.Добавить("УжеВыдан", Новый ОписаниеТипов("Булево"));
	КонецЕсли;
	Для Каждого РанееВыданныйПодарок Из ПодаркиУжеВыданы Цикл
		НоваяСтрока = ТаблицаПодарковКВыдаче.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, РанееВыданныйПодарок);
		НоваяСтрока.УжеВыдан = Истина;
		Отбор = Новый Структура();
		Если ЭтоРМК Тогда
			Отбор.Вставить("ИдентификаторСтроки", РанееВыданныйПодарок.СтрокаТоваров.КлючСвязи);
		Иначе
			Отбор.Вставить("КлючСвязи", РанееВыданныйПодарок.СтрокаТоваров.КлючСвязи);
		КонецЕсли;
		СтрокиИсходнойТЧТоваров = ТабличнаяЧасть.НайтиСтроки(Отбор);
		Для Каждого СтрокаИсходнойТЧ Из СтрокиИсходнойТЧТоваров Цикл
			СоответствиеСтрокПодарковТоварам[НоваяСтрока] = СтрокаИсходнойТЧ;
		КонецЦикла;
	КонецЦикла;
	Результат.Вставить("СоответствиеСтрокПодарковТоварам", СоответствиеСтрокПодарковТоварам);

	// В таблице ПодаркиВТоварах находятся подарки, которые были выданы ранее 
	// Но теперь, после нового расчета, оказывается, их не требовалось выдавать. Уберем их из оригинальной ТЧ Товаров.
	ТоварыУдалить = Новый Массив;
	ТоварыКоличествоИзменилось = Новый Массив;
	Для Каждого СтрокаИзлишнеВыданногоРанееПодарка Из ПодаркиВТоварахКЗачету Цикл
		Отбор = Новый Структура();
		Если ЭтоРМК Тогда
			Отбор.Вставить("ИдентификаторСтроки", СтрокаИзлишнеВыданногоРанееПодарка.КлючСвязи);	
		Иначе
			Отбор.Вставить("КлючСвязи", СтрокаИзлишнеВыданногоРанееПодарка.КлючСвязи);	
		КонецЕсли;
		СтрокиПодарков = ТабличнаяЧасть.НайтиСтроки(Отбор);
		Для Каждого СтрокаПодаркаДокумента Из СтрокиПодарков Цикл
			НовоеКоличество = 0;
			НовоеКоличествоУпаковок = 0;
			КоличествоИзменилось = Ложь;
			//Если ЭтоРМК и ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка" Тогда
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаПодаркаДокумента,"КоличествоУпаковок") Тогда
				НовоеКоличество = СтрокаПодаркаДокумента.Количество - СтрокаИзлишнеВыданногоРанееПодарка.Количество;	
				НовоеКоличествоУпаковок = СтрокаПодаркаДокумента.КоличествоУпаковок - СтрокаИзлишнеВыданногоРанееПодарка.КоличествоУпаковок;	
				КоличествоИзменилось = НЕ СтрокаПодаркаДокумента.Количество = НовоеКоличество;
				СтрокаПодаркаДокумента.Количество = НовоеКоличество;	
				СтрокаПодаркаДокумента.КоличествоУпаковок = НовоеКоличествоУпаковок;	
			Иначе
				НовоеКоличествоУпаковок = СтрокаПодаркаДокумента.Количество - СтрокаИзлишнеВыданногоРанееПодарка.КоличествоУпаковок;	
				КоличествоИзменилось = НЕ СтрокаПодаркаДокумента.Количество = НовоеКоличествоУпаковок;
				СтрокаПодаркаДокумента.Количество = НовоеКоличествоУпаковок;	
			КонецЕсли;
			НоваяСумма = СтрокаПодаркаДокумента.Сумма - СтрокаИзлишнеВыданногоРанееПодарка.Сумма;	
			СтрокаПодаркаДокумента.Сумма = НоваяСумма;
			Если НовоеКоличествоУпаковок <= 0 Тогда 
				ТоварыУдалить.Добавить(СтрокаПодаркаДокумента);
			ИначеЕсли КоличествоИзменилось Тогда
				ТоварыКоличествоИзменилось.Добавить(СтрокаПодаркаДокумента);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;                
	Результат.Вставить("ТоварыУдалить", ТоварыУдалить);
	Результат.Вставить("ТоварыКоличествоИзменилось", ТоварыКоличествоИзменилось);
	
	ПодаркиУдалить = Новый Массив;
	Для Каждого СтрокаВыданногоРанееПодарка Из ПодаркиВТаблицеВыданныхПодарков Цикл
		Отбор = Новый Структура();
		Если ЭтоРМК и ИмяКолонкиУпаковкаВТаблицеПодарков = "Упаковка" Тогда
			Отбор.Вставить("ИдентификаторСтроки", СтрокаВыданногоРанееПодарка.КлючСвязи);
		Иначе
			Отбор.Вставить("КлючСвязи", СтрокаВыданногоРанееПодарка.КлючСвязи);	
		КонецЕсли;
		СтрокиПодарков = ВыданныеПодаркиНеВТоварах.НайтиСтроки(Отбор);
		Для Каждого СтрокаПодаркаДокумента Из СтрокиПодарков Цикл
			СтрокаПодаркаДокумента.Количество = СтрокаПодаркаДокумента.Количество - СтрокаВыданногоРанееПодарка.Количество;	
			СтрокаПодаркаДокумента.Сумма = СтрокаПодаркаДокумента.Сумма - СтрокаВыданногоРанееПодарка.Сумма;	
			Если СтрокаПодаркаДокумента.Количество <= 0 Тогда 
				ПодаркиУдалить.Добавить(СтрокаПодаркаДокумента);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;  
	Результат.Вставить("ПодаркиУдалить", ПодаркиУдалить);
	
	Возврат Результат;

КонецФункции 


Процедура ОбновитьСкидкиПослеПереносаПодарков(СоответствиеПодарковЗапасам, Объект, ИмяТЧ, ПримененныеСкидкиНаценки = Неопределено)
	ЕстьКолонкаЗначениеСкидкиНаценки = Неопределено;
	Товары = Новый ТаблицаЗначений();
	Если ТипЗнч(Объект[ИмяТЧ]) = Тип("ТаблицаЗначений") Тогда
		Товары = Объект[ИмяТЧ].Скопировать();
	Иначе
		Товары = Объект[ИмяТЧ].Выгрузить();
	КонецЕсли;
	
	// Очистим товары от предыдущих скидок, чтобы корректно посчитать сумму распределения, после этого скидки заново применим к документу.
	СуммаВключаетНДС = Истина;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Объект, "СуммаВключаетНДС") Тогда
		СуммаВключаетНДС = Объект.СуммаВключаетНДС;
	КонецЕсли;
	Для Каждого СтрокаТЧ Из Товары Цикл
		СтрокаТЧ.СуммаАвтоматическойСкидки = 0;
		СтрокаТЧ.ПроцентАвтоматическойСкидки = 0;
		ПересчитатьСуммыВСтрокеДокумента(СтрокаТЧ, 
			0,
			0,
			СуммаВключаетНДС, 
			ИмяТЧ = "Работы", 
			ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ"));
	КонецЦикла;
	ТоварыДляРаспределенияСкидки = Товары;
	Для Каждого КиЗПодарков Из СоответствиеПодарковЗапасам Цикл		
		СтрокаПодарка = КиЗПодарков.Ключ;
		СтрокаПеренесенногоПодарка = КиЗПодарков.Значение; 
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаПеренесенногоПодарка, "НомерВариантаКП") Тогда
			ОтборСтрокКП = Новый Структура("НомерВариантаКП", СтрокаПеренесенногоПодарка.НомерВариантаКП);
			СтрокиТоваровДляРаспределенияСкидки = Товары.НайтиСтроки(ОтборСтрокКП);
			ТоварыДляРаспределенияСкидки = Товары.Скопировать(СтрокиТоваровДляРаспределенияСкидки);
		КонецЕсли;
		Параметры = Новый Структура;
		СтруктурнаяЕдиница = Неопределено;
		СкладВШапке = ЦенообразованиеКлиентСервер.ОпределитьПоложениеСкладаВОбъекте(Объект);
		ИмяРеквизитаСЕ = ЦенообразованиеКлиентСервер.ОпределитьИмяРеквизитаСкладаВОбъекте(Объект);
		Если СкладВШапке И ЗначениеЗаполнено(ИмяРеквизитаСЕ) Тогда
			СтруктурнаяЕдиница = Объект[ИмяРеквизитаСЕ];
		ИначеЕсли ЗначениеЗаполнено(ИмяРеквизитаСЕ) Тогда
			СтруктурнаяЕдиница = СтрокаПеренесенногоПодарка[ИмяРеквизитаСЕ];
		Иначе
			СтруктурнаяЕдиница = Неопределено;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) Тогда
			ВидМинимальныхЦен = ЦенообразованиеСерверПовтИсп.ПолучитьВидМинимальныхЦен(СтруктурнаяЕдиница);		
			Параметры.Вставить("ВидЦен", ВидМинимальныхЦен);
			Параметры.Вставить("ДатаОбработки", Объект.Дата);
			Параметры.Вставить("ВалютаДокумента", Объект.ВалютаДокумента);
			Параметры.Вставить("СуммаВключаетНДС", СуммаВключаетНДС);
//		Иначе
//			Параметры = Неопределено;
		КонецЕсли;
		СкидкиПрименить = РаспределитьСкидкуПодарок(СтрокаПодарка, СтрокаПеренесенногоПодарка, ТоварыДляРаспределенияСкидки, Параметры); 
		// Отразим скидки в документе, согласно правилам распределения
		Для Каждого СкидкаПрименить Из СкидкиПрименить Цикл 
			НоваяСкидка = Объект.СкидкиНаценки.Добавить();
			НоваяСкидка.КлючСвязи 				= СкидкаПрименить.КлючСвязи;
			НоваяСкидка.СкидкаНаценка 			= СтрокаПодарка.СкидкаНаценка;
			НоваяСкидка.Сумма 					= СкидкаПрименить.Сумма;
			Если ЕстьКолонкаЗначениеСкидкиНаценки = Неопределено Тогда
				ЕстьКолонкаЗначениеСкидкиНаценки = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НоваяСкидка, "ЗначениеСкидкиНаценки");
			КонецЕсли;
			Если ЕстьКолонкаЗначениеСкидкиНаценки Тогда
				НоваяСкидка.ЗначениеСкидкиНаценки	= СкидкаПрименить.ПроцентСкидки;
			КонецЕсли;
			
			ОтборСтрокЗапасов = Новый Структура;
			ОтборСтрокЗапасов.Вставить("КлючСвязи", НоваяСкидка.КлючСвязи); 
			СтрокиТоваров = Объект[ИмяТЧ].НайтиСтроки(ОтборСтрокЗапасов);
			
			Для Каждого СтрокаТоваров Из СтрокиТоваров Цикл 
				
				СуммаБезСкидки = СтрокаТоваров.Количество * СтрокаТоваров.Цена;
				ПроцентТекущейСкидки = ?(СуммаБезСкидки = 0, 0, Окр(100 * СкидкаПрименить.Сумма / СуммаБезСкидки, 2));
				Если ЕстьКолонкаЗначениеСкидкиНаценки Тогда
					НоваяСкидка.ЗначениеСкидкиНаценки	= ПроцентТекущейСкидки;
				КонецЕсли;
				
			КонецЦикла;
			Если Не ПримененныеСкидкиНаценки = Неопределено Тогда
				ЗаполнитьЗначенияСвойств(ПримененныеСкидкиНаценки.ТаблицаСкидкиНаценки.Добавить(), НоваяСкидка);
			КонецЕсли;

		КонецЦикла;
		
		// Исключим скидки, фиксировавшие подарки, не отнесенные в состав документа
		ОтборСкидки = Новый Структура;
		ОтборСкидки.Вставить("СкидкаНаценка", СтрокаПодарка.СкидкаНаценка);
		ОтборСкидки.Вставить("КлючСвязи", 0);
		СтрокиСкидкиПереносимогоПодарка = Объект.СкидкиНаценки.НайтиСтроки(ОтборСкидки);
		СтрокиСкидкиУдалить = Новый Массив;
		СуммаСкидкиРаспределить = СтрокаПодарка.Сумма;
		Для Каждого СтрокаСкидкиПодарка Из СтрокиСкидкиПереносимогоПодарка Цикл
			СуммаЗасчитать = Мин(СтрокаСкидкиПодарка.Сумма, СуммаСкидкиРаспределить);
			СтрокаСкидкиПодарка.Сумма = СтрокаСкидкиПодарка.Сумма - СуммаЗасчитать;
			СуммаСкидкиРаспределить = СуммаСкидкиРаспределить - СуммаЗасчитать;
			Если СтрокаСкидкиПодарка.Сумма <= 0 Тогда
				СтрокиСкидкиУдалить.Добавить(СтрокаСкидкиПодарка);
			КонецЕсли;
			Если СуммаСкидкиРаспределить <= 0 Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрокаСкидкиПодарка Из СтрокиСкидкиУдалить Цикл
			Объект.СкидкиНаценки.Удалить(СтрокаСкидкиПодарка);
		КонецЦикла;
		// Повторим для структуры с расшифровкой рассчитанных скидок
		Если Не ПримененныеСкидкиНаценки = Неопределено Тогда
			СтрокиСкидкиУдалить = Новый Массив();
			СтрокиСкидкиПереносимогоПодарка = ПримененныеСкидкиНаценки.ТаблицаСкидкиНаценки.НайтиСтроки(ОтборСкидки);
			СуммаСкидкиРаспределить = СтрокаПодарка.Сумма;
			Для Каждого СтрокаСкидкиПодарка Из СтрокиСкидкиПереносимогоПодарка Цикл
				СуммаЗасчитать = Мин(СтрокаСкидкиПодарка.Сумма, СуммаСкидкиРаспределить);
				Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаСкидкиПодарка.СкидкаНаценка,"ЛюбойПодарокИзСписка") Тогда
					// На момент расчета скидок, мы не знали, какой именно подарок выбран покупателем, и сумма скидки была не корректной
					СтрокаСкидкиПодарка.Сумма = СуммаСкидкиРаспределить;
				КонецЕсли;
				СтрокаСкидкиПодарка.Сумма = СтрокаСкидкиПодарка.Сумма - СуммаЗасчитать;
				СуммаСкидкиРаспределить = СуммаСкидкиРаспределить - СуммаЗасчитать;
				Если СтрокаСкидкиПодарка.Сумма <= 0 Тогда
					СтрокиСкидкиУдалить.Добавить(СтрокаСкидкиПодарка);
				КонецЕсли;
				Если СуммаСкидкиРаспределить <= 0 Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Для Каждого СтрокаСкидкиПодарка Из СтрокиСкидкиУдалить Цикл
				ПримененныеСкидкиНаценки.ТаблицаСкидкиНаценки.Удалить(СтрокаСкидкиПодарка);
			КонецЦикла;
		КонецЕсли;
		
		Если НЕ ПримененныеСкидкиНаценки = Неопределено Тогда
			
			СтрокиСкидкиПереносимогоПодарка = ПримененныеСкидкиНаценки.ТаблицаСкидкиНаценки.НайтиСтроки(ОтборСкидки);
			Если СтрокиСкидкиПереносимогоПодарка.Количество() > 0 Тогда
				// Скидка распределена по строкам документа
				Для Каждого СтрокаСкидкиПодарка Из СтрокиСкидкиПереносимогоПодарка Цикл
					ПримененныеСкидкиНаценки.ТаблицаСкидкиНаценки.Удалить(СтрокаСкидкиПодарка);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

//
Функция ПотенциальныеСкидкиПоВидамОплаты(ДеревоСкидок, ТаблицаВыполненныеУсловия, ПараметрыРасчета, ОбъединенныеПараметры, ИмяТЧЗапасы = "Запасы")
	Результат = Новый Соответствие;
	
	ТаблицаИспользуемыеВидыОплат = Неопределено;
	Если НЕ ПараметрыРасчета.Свойство("ИспользуемыеВидыОплат", ТаблицаИспользуемыеВидыОплат) Тогда
		Возврат Результат;
	КонецЕсли;
	//СтрокиВыбраны = ТаблицаИспользуемыеВидыОплат.НайтиСтроки(Новый Структура("Используется", Истина));
	ВидыОплатУжеВыбраны = Новый Массив();
	НевыбранныеВидыОплат = Новый Массив();
	Для Каждого СтрокаВидаОплаты Из ТаблицаИспользуемыеВидыОплат Цикл
		Если СтрокаВидаОплаты.Используется Тогда
			ВидыОплатУжеВыбраны.Добавить(СтрокаВидаОплаты.ВидОплаты);
		Иначе
			НевыбранныеВидыОплат.Добавить(СтрокаВидаОплаты.ВидОплаты);
		КонецЕсли;
	КонецЦикла;
	ВидыОплатУжеВыбраны = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ВидыОплатУжеВыбраны);
	НевыбранныеВидыОплат = ОбщегоНазначенияКлиентСервер.СвернутьМассив(НевыбранныеВидыОплат);

	Для Каждого ВидОплаты Из НевыбранныеВидыОплат Цикл
		ВидыОплатыСтанутВыбраны = Новый Массив();
		ВидыОплатыСтанутВыбраны.Добавить(ВидОплаты);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВидыОплатыСтанутВыбраны, ВидыОплатУжеВыбраны, Истина);
		//@skip-check query-in-loop
		РезультатЕсли = СтруктураРассчитанныхСкидокПриИспользованииВидаОплаты(ДеревоСкидок, ТаблицаВыполненныеУсловия, ПараметрыРасчета, ОбъединенныеПараметры, ВидыОплатыСтанутВыбраны);
		ВиртуальныйОбъект = ПолучитьВиртуальныйОбъектДляРасчетаСкидок(РезультатЕсли, ОбъединенныеПараметры, ИмяТЧЗапасы);
		ПрименитьСкидкиКВиртуальномуОбъекту(ВиртуальныйОбъект, РезультатЕсли, ИмяТЧЗапасы);
		СуммаСкидки = ВиртуальныйОбъект[ИмяТЧЗапасы].Итог("СуммаАвтоматическойСкидки");
		
		Результат.Вставить(ВидОплаты, СуммаСкидки);
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция СтруктураРассчитанныхСкидокПриИспользованииВидаОплаты(ДеревоСкидок, ТаблицаВыполненныеУсловия, ПараметрыРасчета, ОбъединенныеПараметры, ВидОплаты = Неопределено)
	// Сделаем копии исходных данных, чтобы их не модифицировать во время расчета потенциальных скидок
	КопияДереваСкидок = ОбщегоНазначения.СкопироватьРекурсивно(ДеревоСкидок);
	КопияПараметрыРасчета = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыРасчета);
	КопияОбъединенныеПараметры = ОбщегоНазначения.СкопироватьРекурсивно(ОбъединенныеПараметры);
	//@skip-check bsl-legacy-check-expression-type
	КопияОбъединенныеПараметры.Вставить("РассчитыватьБонусы", Ложь);
	КопияТаблицыВыполненныхУсловий = ТаблицаВыполненныеУсловия.Скопировать();
	Если Не ВидОплаты = Неопределено Тогда // Иначе предварительно рассчитываем скидки "как есть"
		УдалитьУсловияЗаВидОплаты(КопияТаблицыВыполненныхУсловий, ВидОплаты);
	КонецЕсли;
	// Выполним рассчет скидок с выполенным условием на копии данных	
		
	ПроверитьУсловияРекурсивно(КопияДереваСкидок, КопияТаблицыВыполненныхУсловий, КопияПараметрыРасчета);
	КопияДереваСкидок.Колонки.Удалить(КопияДереваСкидок.Колонки.УсловияПредоставления);
	СтруктураСкидок = СтруктураРассчитанныхСкидок(КопияДереваСкидок, КопияОбъединенныеПараметры);
	Возврат СтруктураСкидок;
	
КонецФункции

//
Процедура УдалитьУсловияЗаВидОплаты(ТаблицаУсловий, ВыбранныеВидыОплаты = Неопределено)
	// Пометим условия, связанные с переданным видом оплаты как выполненные
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВариантыОплаты.Ссылка КАК ВидОплаты
	|ПОМЕСТИТЬ вт_ВариантыОплаты
	|ИЗ
	|	Перечисление.ВидыОплатСерверЛояльности КАК ВариантыОплаты
	|ГДЕ
	|	ВариантыОплаты.Ссылка В(&ВыбранныйВидыОплаты)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ПустаяСсылка)
	|ГДЕ
	|	ЗНАЧЕНИЕ(Перечисление.ВидыОплатСерверЛояльности.ПустаяСсылка) В (&ВыбранныйВидыОплаты)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КоличествоСпособовОплаты.Условие КАК Ссылка,
	|	1 КАК КоличествоКомплектов,
	|	""-1"" КАК КлючСвязи
	|ИЗ
	|	(ВЫБРАТЬ
	|		УсловияПредоставленияСкидокНаценок.Ссылка КАК Условие,
	|		СУММА(ВЫБОР
	|				КОГДА ВариантыОплаты.ВидОплаты = УсловияПредоставленияСкидокНаценок.ВидОплаты
	|					ТОГДА 1
	|				ИНАЧЕ 0
	|			КОНЕЦ) КАК ПравильныхОплат,
	|		СУММА(ВЫБОР
	|				КОГДА ВариантыОплаты.ВидОплаты = ЗНАЧЕНИЕ(Перечисление.ВидыОплатСерверЛояльности.Бонусами)
	|						И НЕ УсловияПредоставленияСкидокНаценок.ДоплатаБонусамиОтменяетСкидку
	|					ТОГДА 0
	|				КОГДА ВариантыОплаты.ВидОплаты = УсловияПредоставленияСкидокНаценок.ВидОплаты
	|					ТОГДА 0
	|				ИНАЧЕ 1
	|			КОНЕЦ) КАК ЛишнихОплат
	|	ИЗ
	|		Справочник.УсловияПредоставленияСкидокНаценок КАК УсловияПредоставленияСкидокНаценок
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ вт_ВариантыОплаты КАК ВариантыОплаты
	|			ПО (УсловияПредоставленияСкидокНаценок.УсловиеПредоставления = ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ЗаВидОплаты))
	|	
	|	СГРУППИРОВАТЬ ПО
	|		УсловияПредоставленияСкидокНаценок.Ссылка) КАК КоличествоСпособовОплаты
	|ГДЕ
	|	КоличествоСпособовОплаты.ПравильныхОплат > 0
	|	И КоличествоСпособовОплаты.ЛишнихОплат = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УсловияПредоставленияСкидокНаценок.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.УсловияПредоставленияСкидокНаценок КАК УсловияПредоставленияСкидокНаценок
	|ГДЕ
	|	УсловияПредоставленияСкидокНаценок.Ссылка В(&Условия)
	|	И УсловияПредоставленияСкидокНаценок.УсловиеПредоставления = ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ЗаВидОплаты)";
	Запрос.УстановитьПараметр("ВыбранныйВидыОплаты", ВыбранныеВидыОплаты);
	Запрос.УстановитьПараметр("Условия", ТаблицаУсловий.ВыгрузитьКолонку("Ссылка"));
	Результаты = Запрос.ВыполнитьПакет();
	ТаблицаДействующихУсловий = Результаты[1].Выгрузить();
	СписокОчиститьУсловия = Результаты[2].Выгрузить().ВыгрузитьКолонку("Ссылка");
	Для Каждого УсловиеУдалить Из СписокОчиститьУсловия Цикл
		СтрокиУдалить = ТаблицаУсловий.НайтиСтроки(Новый Структура("Ссылка", УсловиеУдалить));
		Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
			ТаблицаУсловий.Удалить(СтрокаУдалить);
		КонецЦикла;
	КонецЦикла;
	Для Каждого СтрокаДобавить Из ТаблицаДействующихУсловий Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаУсловий.Добавить(), СтрокаДобавить);
	КонецЦикла;
КонецПроцедуры 

Функция ПолучитьПустуюТаблицуИспользуемыхОплат() Экспорт
	ТаблицаВидовОплаты = Новый ТаблицаЗначений();
	ТипЗначенияВидОплтаы = Новый ОписаниеТипов("ПеречислениеСсылка.ВидыОплатСерверЛояльности");
	ТаблицаВидовОплаты.Колонки.Добавить("ВидОплаты", ТипЗначенияВидОплтаы);
	ТаблицаВидовОплаты.Колонки.Добавить("Используется", Новый ОписаниеТипов("Булево"));
	ТаблицаВидовОплаты.Колонки.Добавить("ИмяРеквизитаФормыАльтернативыСкидки", Новый ОписаниеТипов("Строка"));
	Возврат ТаблицаВидовОплаты;
КонецФункции

Функция ТаблицаЦенТоваров(ТаблицаТоваров, ТаблицаСкидокПоВидуЦен, ТаблицаЦенМРЦ, ДатаДокумента, ВалютаДокумента, СуммаВключаетНДС)
	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	втТовары.Номенклатура КАК Номенклатура,
	|	втТовары.Характеристика КАК Характеристика,
	|	втТовары.ЦенаЗаУпаковку КАК ЦенаВДокументе,
	|	втТовары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВЫРАЗИТЬ(втТовары.СтавкаНДС КАК Справочник.СтавкиНДС) КАК СтавкаНДС,
	|	втТовары.Количество КАК Количество,
	|	втТовары.КлючСвязи КАК КлючСвязи
	|ПОМЕСТИТЬ втТовары
	|ИЗ
	|	&Товары КАК втТовары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаМРЦ.Номенклатура КАК Номенклатура,
	|	ТаблицаМРЦ.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ТаблицаМРЦ.ЦенаМРЦ КАК ЦенаМРЦ,
	|	ТаблицаМРЦ.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втДанныеМРЦ
	|ИЗ
	|	&ТаблицаМРЦ КАК ТаблицаМРЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КурсыВалютСкидки.Курс КАК Курс,
	|	КурсыВалютСкидки.Кратность КАК Кратность,
	|	КурсыВалютСкидки.Валюта КАК Валюта
	|ПОМЕСТИТЬ КурсыВалютСкидки
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&ДатаДокумента, ) КАК КурсыВалютСкидки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Валюта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСкидок.ВидЦен КАК ВидЦен
	|ПОМЕСТИТЬ ВтСкидкиПоВидуЦены
	|ИЗ
	|	&ТаблицаСкидокПоВидуЦен КАК ТаблицаСкидок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.Номинал КАК Номинал,
	|	Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ПОМЕСТИТЬ вт_ПодарочныеСертификаты
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	|	И НЕ Номенклатура.ПроизвольныйНоминал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыМинимальныхЦенСтруктурныхЕдиниц.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВидыМинимальныхЦенСтруктурныхЕдиниц.ВидМинимальныхЦен КАК ВидМинимальныхЦен,
	|	1 КАК Приоритет
	|ПОМЕСТИТЬ ВидыМинимальныхЦен
	|ИЗ
	|	РегистрСведений.ВидыМинимальныхЦенСтруктурныхЕдиниц КАК ВидыМинимальныхЦенСтруктурныхЕдиниц
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка),
	|	ВидыМинимальныхЦенСтруктурныхЕдиниц.ВидМинимальныхЦен,
	|	2
	|ИЗ
	|	РегистрСведений.ВидыМинимальныхЦенСтруктурныхЕдиниц КАК ВидыМинимальныхЦенСтруктурныхЕдиниц
	|ГДЕ
	|	ВидыМинимальныхЦенСтруктурныхЕдиниц.СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыМинимальныхЦен.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВидыМинимальныхЦен.ВидМинимальныхЦен КАК ВидМинимальныхЦен
	|ПОМЕСТИТЬ вт_ЦеныСтруктурныхЕдиниц
	|ИЗ
	|	ВидыМинимальныхЦен КАК ВидыМинимальныхЦен,
	|	Константа.ФункциональнаяОпцияИспользоватьМинимальныеЦены КАК ИспользоватьМинимальныеЦены
	|ГДЕ
	|	ИспользоватьМинимальныеЦены.Значение = ИСТИНА
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВидыМинимальныхЦен.Приоритет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Скидка.ВидЦен КАК ВидЦен,
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втФильтрЦен
	|ИЗ
	|	ВтСкидкиПоВидуЦены КАК Скидка,
	|	втТовары КАК Товары
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	МинимальныеЦены.ВидМинимальныхЦен,
	|	Товары.Номенклатура,
	|	Товары.Характеристика
	|ИЗ
	|	вт_ЦеныСтруктурныхЕдиниц КАК МинимальныеЦены,
	|	втТовары КАК Товары
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидЦен,
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
	|	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ЦеныНоменклатурыСрезПоследних.ВалютаЦены <> ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)
	|			ТОГДА ЦеныНоменклатурыСрезПоследних.ВалютаЦены
	|		ИНАЧЕ ЦеныНоменклатурыСрезПоследних.ВидЦен.ВалютаЦены
	|	КОНЕЦ КАК ВалютаЦены
	|ПОМЕСТИТЬ вт_СрезЦен
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			&ДатаДокумента,
	|			(ВидЦен, Номенклатура, Характеристика) В
	|				(ВЫБРАТЬ
	|					ФильтрЦен.ВидЦен КАК ВидЦен,
	|					ФильтрЦен.Номенклатура КАК Номенклатура,
	|					ФильтрЦен.Характеристика КАК Характеристика
	|				ИЗ
	|					втФильтрЦен КАК ФильтрЦен)) КАК ЦеныНоменклатурыСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
	|	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЕСТЬNULL(ЕдиницаИзмеренияЦены.Коэффициент, 1) КАК КоэффициентЕдиницыИзмерения,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ЦеныНоменклатурыСрезПоследних.ВалютаЦены <> ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)
	|			ТОГДА ЦеныНоменклатурыСрезПоследних.ВалютаЦены
	|		ИНАЧЕ ЦеныНоменклатурыСрезПоследних.ВидЦен.ВалютаЦены
	|	КОНЕЦ КАК ВалютаЦены,
	|	ПараметрыВидаЦен.ЦенаВключаетНДС КАК МинимальнаяЦенаВключаетНДС
	|ПОМЕСТИТЬ ВтЦеныНоменклатурыСрезПоследних
	|ИЗ
	|	вт_СрезЦен КАК ЦеныНоменклатурыСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ПараметрыВидаЦен
	|		ПО ЦеныНоменклатурыСрезПоследних.ВидЦен = ПараметрыВидаЦен.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницаИзмеренияЦены
	|		ПО ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения = ЕдиницаИзмеренияЦены.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	ВалютаЦены
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втТовары.КлючСвязи КАК КлючСвязи,
	|	ВЫБОР
	|		КОГДА ПараметрыСертификата.Номинал ЕСТЬ NULL
	|			ТОГДА ЦеныНоменклатурыСрезПоследних.ВидЦен
	|		ИНАЧЕ NULL
	|	КОНЕЦ КАК ВидЦен,
	|	втТовары.Номенклатура КАК Номенклатура,
	|	втТовары.Характеристика КАК Характеристика,
	|	втТовары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЕСТЬNULL(ПараметрыСертификата.ЕдиницаИзмерения, ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения) КАК ЕдиницаИзмеренияСкидки,
	|	ВЫБОР
	|		КОГДА ЦеныНоменклатурыСрезПоследних.МинимальнаяЦенаВключаетНДС ЕСТЬ НЕ NULL 
	|				И втТовары.СтавкаНДС.Ставка ЕСТЬ НЕ NULL 
	|				И &ЦенаВключаетНДС = ИСТИНА
	|				И ЦеныНоменклатурыСрезПоследних.МинимальнаяЦенаВключаетНДС = ЛОЖЬ
	|			ТОГДА ЦеныНоменклатурыСрезПоследних.Цена * (100 + втТовары.СтавкаНДС.Ставка) / 100
	|		КОГДА ЦеныНоменклатурыСрезПоследних.МинимальнаяЦенаВключаетНДС ЕСТЬ НЕ NULL 
	|				И втТовары.СтавкаНДС.Ставка ЕСТЬ НЕ NULL 
	|				И &ЦенаВключаетНДС = ЛОЖЬ
	|				И ЦеныНоменклатурыСрезПоследних.МинимальнаяЦенаВключаетНДС = ИСТИНА
	|			ТОГДА ЦеныНоменклатурыСрезПоследних.Цена * 100 / (100 + втТовары.СтавкаНДС.Ставка)
	|		ИНАЧЕ ЕСТЬNULL(ПараметрыСертификата.Номинал, ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0))
	|	КОНЕЦ КАК ЦенаСкидки,
	|	ЕСТЬNULL(ЕдиницаИзмеренияТовара.Коэффициент, 1) / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.КоэффициентЕдиницыИзмерения, 1) КАК КоэффициентПриведенияКЕдиницеЦеныСкидки,
	|	втТовары.ЦенаВДокументе КАК Цена,
	|	втТовары.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА ЦеныНоменклатурыСрезПоследних.Цена ЕСТЬ NULL
	|				И ПараметрыСертификата.Номинал ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЦенаСкидкиУказана,
	|	ЦеныНоменклатурыСрезПоследних.ВалютаЦены КАК ВалютаЦеныСкидки,
	|	ЛОЖЬ КАК ЭтоМРЦ
	|ПОМЕСТИТЬ втЦеныДляДокумента
	|ИЗ
	|	втТовары КАК втТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницаИзмеренияТовара
	|		ПО втТовары.ЕдиницаИзмерения = ЕдиницаИзмеренияТовара.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтЦеныНоменклатурыСрезПоследних КАК ЦеныНоменклатурыСрезПоследних
	|		ПО втТовары.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И втТовары.Характеристика = ЦеныНоменклатурыСрезПоследних.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_ПодарочныеСертификаты КАК ПараметрыСертификата
	|		ПО втТовары.Номенклатура = ПараметрыСертификата.Ссылка
	|ГДЕ
	|	НЕ (втТовары.Номенклатура, втТовары.Характеристика) В
	|				(ВЫБРАТЬ
	|					ФильтрЦен.Номенклатура КАК Номенклатура,
	|					ФильтрЦен.Характеристика КАК Характеристика
	|				ИЗ
	|					втДанныеМРЦ КАК ФильтрЦен)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втТовары.КлючСвязи,
	|	NULL,
	|	втДанныеМРЦ.Номенклатура,
	|	втДанныеМРЦ.Характеристика,
	|	втТовары.ЕдиницаИзмерения,
	|	втДанныеМРЦ.ЕдиницаИзмерения,
	|	втДанныеМРЦ.ЦенаМРЦ,
	|	1,
	|	втТовары.ЦенаВДокументе,
	|	втТовары.Количество,
	|	ИСТИНА,
	|	&ВалютаДокумента,
	|	ИСТИНА
	|ИЗ
	|	втТовары КАК втТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втДанныеМРЦ КАК втДанныеМРЦ
	|		ПО втТовары.Номенклатура = втДанныеМРЦ.Номенклатура
	|			И втТовары.Характеристика = втДанныеМРЦ.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеДокумента.КлючСвязи КАК КлючСвязи,
	|	ДанныеДокумента.ВидЦен КАК ВидЦен,
	|	ДанныеДокумента.Номенклатура КАК Номенклатура,
	|	ДанныеДокумента.Характеристика КАК Характеристика,
	|	ДанныеДокумента.ЕдиницаИзмеренияСкидки КАК ЕдиницаИзмерения,
	|	ДанныеДокумента.Цена КАК ЦенаВДокументе,
	|	ДанныеДокумента.ЦенаСкидки КАК Цена,
	|	ДанныеДокумента.ЦенаСкидкиУказана КАК ЦенаСкидкиУказана,
	|	ДанныеДокумента.КоэффициентПриведенияКЕдиницеЦеныСкидки КАК КоэффициентПриведенияКЕдиницеЦеныСкидки,
	|	ДанныеДокумента.Количество * ДанныеДокумента.КоэффициентПриведенияКЕдиницеЦеныСкидки * (ДанныеДокумента.Цена / ДанныеДокумента.КоэффициентПриведенияКЕдиницеЦеныСкидки - ЕСТЬNULL(ДанныеДокумента.ЦенаСкидки, 0) / ЕСТЬNULL(КурсыВалютДокумента.Курс, 0) / ЕСТЬNULL(КурсыВалютДокумента.Кратность, 0) * ЕСТЬNULL(КурсыВалютСкидки.Курс, 0) * ЕСТЬNULL(КурсыВалютСкидки.Кратность, 0)) КАК РазмерСкидки,
	|	ЕСТЬNULL(ДанныеДокумента.ЦенаСкидки, 0) * ДанныеДокумента.КоэффициентПриведенияКЕдиницеЦеныСкидки / ЕСТЬNULL(КурсыВалютДокумента.Курс, 0) / ЕСТЬNULL(КурсыВалютДокумента.Кратность, 0) * ЕСТЬNULL(КурсыВалютСкидки.Курс, 0) * ЕСТЬNULL(КурсыВалютСкидки.Кратность, 0) КАК ЦенаВВалютеДокумента,
	|	ДанныеДокумента.ЭтоМРЦ КАК ЭтоМРЦ
	|ИЗ
	|	втЦеныДляДокумента КАК ДанныеДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютСкидки КАК КурсыВалютСкидки
	|		ПО ДанныеДокумента.ВалютаЦеныСкидки = КурсыВалютСкидки.Валюта,
	|	РегистрСведений.КурсыВалют.СрезПоследних(&ДатаДокумента, Валюта = &ВалютаДокумента) КАК КурсыВалютДокумента";

	Запрос.УстановитьПараметр("Товары", ТаблицаТоваров);
	Запрос.УстановитьПараметр("ТаблицаМРЦ", ТаблицаЦенМРЦ);
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
	Запрос.УстановитьПараметр("ВалютаДокумента", ВалютаДокумента);
	Запрос.УстановитьПараметр("ТаблицаСкидокПоВидуЦен", ТаблицаСкидокПоВидуЦен);
	Запрос.УстановитьПараметр("ЦенаВключаетНДС", СуммаВключаетНДС);
	
	Результат = Запрос.Выполнить().Выгрузить();
	Результат.Индексы.Добавить("КлючСвязи, ВидЦен");
	Результат.Индексы.Добавить("Номенклатура, Характеристика, ВидЦен");
	
	Для Каждого СтрокаЦены Из Результат Цикл
		Если СтрокаЦены.ЭтоМРЦ Тогда
			Продолжить;
		КонецЕсли;
		СтрокаЦены.Цена = ЦенообразованиеСервер.ОкруглитьЦенуПоВидуЦен(СтрокаЦены.Цена, СтрокаЦены.ВидЦен);
		СтрокаЦены.ЦенаВВалютеДокумента = Окр(СтрокаЦены.Цена * СтрокаЦены.КоэффициентПриведенияКЕдиницеЦеныСкидки, 2);
	КонецЦикла;
	
	Возврат Результат;	
	
КонецФункции

