Функция ОписаниеКратностиУсловия(УсловиеПредоставления, ПолучатьПредставление = Ложь) Экспорт
	
	УсловиеРазовыйОбъем = ПредопределенноеЗначение("Перечисление.УсловияПредоставленияСкидокНаценок.ЗаРазовыйОбъемПродаж");
	УсловиеКомплект = ПредопределенноеЗначение("Перечисление.УсловияПредоставленияСкидокНаценок.ЗаКомплектПокупки");
	ТипСравненияБольшеИлиРавно = ПредопределенноеЗначение("Перечисление.ТипыСравненияЗначенийСкидокНаценок.БольшеИлиРавно");

	ДанныеУсловий = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(УсловиеПредоставления, 
		"ТипСравнения, УсловиеПредоставления, КритерийОграниченияПримененияЗаОбъемПродаж, ОбластьОграничения, ЗначениеУсловияОграничения, ВалютаОграничения");
	Результат = Неопределено;
	Если ДанныеУсловий.УсловиеПредоставления = УсловиеКомплект Тогда
		Если ПолучатьПредставление Тогда
			КоличествоТоваровВКомплекте = 1;
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ
			|	ЕстьNull(Количество(УсловияПредоставленияСкидокНаценокКомплектПокупки.Номенклатура), 0) КАК ТоваровВКомплекте
			|ИЗ
			|	Справочник.УсловияПредоставленияСкидокНаценок.КомплектПокупки КАК УсловияПредоставленияСкидокНаценокКомплектПокупки
			|ГДЕ 
			|	УсловияПредоставленияСкидокНаценокКомплектПокупки.Ссылка = &Условие";
			Запрос.УстановитьПараметр("Условие", УсловиеПредоставления);
			ВыбОписаниеКомплекта = Запрос.Выполнить().Выбрать();
			Если ВыбОписаниеКомплекта.Следующий() Тогда
				КоличествоТоваровВКомплекте = ВыбОписаниеКомплекта.ТоваровВКомплекте;
			КонецЕсли;
			Описания = ПолучитьСклоненияСтрокиПоЧислу("товар",  КоличествоТоваровВКомплекте, "", "ЧС=Количественное", "ПД=Родительный; ПЧ=Число");
			Результат = СтрШаблон(НСтр("ru = 'комплект из %1'"), Описания[0]);
		Иначе
			Результат = Строка(УсловиеПредоставления);	
		КонецЕсли;
	ИначеЕсли  ДанныеУсловий.УсловиеПредоставления = УсловиеРазовыйОбъем
		И ДанныеУсловий.ТипСравнения = ТипСравненияБольшеИлиРавно Тогда
		Если ПолучатьПредставление Тогда
			ОписаниеКритерия = "";
			Если ДанныеУсловий.КритерийОграниченияПримененияЗаОбъемПродаж = 
				ПредопределенноеЗначение("Перечисление.КритерииОграниченияПримененияСкидкиНаценкиЗаОбъемПродаж.Количество") Тогда
				КоличествоТоваров = ДанныеУсловий.ЗначениеУсловияОграничения;
				ОписанияКритерия = ПолучитьСклоненияСтрокиПоЧислу("товара",  КоличествоТоваров, "ед.", "ЧС=Количественное", "ПД=Родительный; ПЧ=Число");
				Для Каждого Описание Из ОписанияКритерия Цикл
					ОписаниеКритерия = Описание;
					Прервать;
				КонецЦикла;
			Иначе
				СуммаРублей = ДанныеУсловий.ЗначениеУсловияОграничения;
				Валюта = ДанныеУсловий.ВалютаОграничения;
				//@skip-check bsl-legacy-check-string-literal
				ОписаниеВалюты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Валюта, "ПараметрыПрописи");
				ПараметрыПрописи = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ОписаниеВалюты, ",");
				ОписаниеЕдиницИзмерения = Новый Массив;
				Если ПараметрыПрописи.Количество() > 0 Тогда
					ОписаниеЕдиницИзмерения.Добавить(ПараметрыПрописи[0]);
				КонецЕсли;
				Если ПараметрыПрописи.Количество() > 4 Тогда
					ОписаниеЕдиницИзмерения.Добавить(ПараметрыПрописи[4]);
				КонецЕсли;
				Если ПараметрыПрописи.Количество() > 8 Тогда
					ОписаниеЕдиницИзмерения.Добавить(ПараметрыПрописи[8]);
				КонецЕсли;
				ОписаниеСуммы = СтрСоединить(ОписаниеЕдиницИзмерения, ", ");
				ОписанияКритерия = ПолучитьСклоненияСтрокиПоЧислу("",  СуммаРублей, ОписаниеСуммы, "ЧС=Количественное", "ПД=Родительный; ПЧ=Число");
				Для Каждого Описание Из ОписанияКритерия Цикл
					ОписаниеКритерия = Описание;
					Прервать;
				КонецЦикла;
			КонецЕсли;
			ОписаниеОбластиОграничения = "";
			Если ДанныеУсловий.ОбластьОграничения = 
				ПредопределенноеЗначение("Перечисление.ВариантыОбластейОграниченияСкидокНаценок.ВДокументе") Тогда
				ОписаниеОбластиОграничения = НРег("в документе, по возрастанию цены");
			Иначе
				ОписаниеОбластиОграничения = НРег("в строке");
			КонецЕсли;
			Результат = СтрШаблон(НРег("%1 %2"), ОписаниеКритерия, ОписаниеОбластиОграничения);
		Иначе
			Результат = Строка(УсловиеПредоставления);	
		КонецЕсли;			
	КонецЕсли;
	Возврат Результат;
КонецФункции

Процедура ДобавитьСкидкуВТаблицу(Знач СтрокаДерева, Знач ПараметрыРасчета, ТаблицаСкидок) Экспорт
		
	ПараметрыСкидки = ПараметрыРасчета.СкидкиНаценки.Найти(СтрокаДерева.СкидкаНаценка, "СкидкаНаценка");
	Если ПараметрыСкидки = Неопределено Тогда 
		Возврат;
	Конецесли;
		
	СкидкиНаценкиПоЦеновымГруппам = ПараметрыРасчета.СкидкиНаценкиПоЦеновымГруппам.НайтиСтроки(Новый Структура("СкидкаНаценка", СтрокаДерева.СкидкаНаценка));
	СкидкиНаценкиПоКатегориямНоменклатуры = ПараметрыРасчета.СкидкиНаценкиПоКатегориямНоменклатуры.НайтиСтроки(Новый Структура("СкидкаНаценка", СтрокаДерева.СкидкаНаценка));
	СкидкиНаценкиПоНоменклатуре = ПараметрыРасчета.СкидкиНаценкиПоНоменклатуре.НайтиСтроки(Новый Структура("СкидкаНаценка", СтрокаДерева.СкидкаНаценка));
	СкидкиНаценкиПоСегментамНоменклатуры = ПараметрыРасчета.СкидкиНаценкиПоСегментамНоменклатуры.НайтиСтроки(Новый Структура("СкидкаНаценка", СтрокаДерева.СкидкаНаценка));

	ПараметрыРасчетаСкидки = ПолучитьПараметрыРасчетаПроизвольнойСкидки(СтрокаДерева, ПараметрыРасчета);
	// Таблица сообщений, которые будут показаны кассиру в момент расчета скидки, или пробития чека (только в розничном канале продаж)
	ТаблицаСообщений 	= ПараметрыРасчетаСкидки.ТаблицаСообщений;
	// Таблица подарков, которые следует предоставить покупателю. В данной таблице присутствуют только подарки, которые следует выдать на кассе.
	// Подарки, которые покупатель берет самостоятельно (например "Три по цене двух") предоставляются в виде скидок, добавлять их в таблицу не нужно.
	ТаблицаПодарков 	= ПараметрыРасчетаСкидки.ТаблицаПодарков;
    ИспользоватьКратность = Истина;
	
	// Кратность
	// Проверяем кратность, сколько раз должна быть предоставлена скидка
	КратностьДокумента = Неопределено;
	ДополнительныеПараметрыСкидки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыСкидки.СкидкаНаценка,"ИспользоватьРежимКратности, КртаностьСкидкиПоУсловию, КратноКоличествуУсловий");
	Повторять = ДополнительныеПараметрыСкидки.КратноКоличествуУсловий;
	ОтборСтрок = Новый Структура("КлючСвязи", "-1");
	УсловияПоДокументу = СтрокаДерева.ПараметрыУсловий.Условия.НайтиСтроки(ОтборСтрок);
	Для Каждого ОписаниеУсловия Из УсловияПоДокументу Цикл
		//@skip-check query-in-loop
		Если НЕ УсловиеПоддерживаетКратность(ОписаниеУсловия.УсловиеПредоставления) 
			ИЛИ НЕ ИспользоватьКратность Тогда
			Продолжить;
		КонецЕсли;
		КратностьУсловия = ОписаниеУсловия.КоличествоКомплектов;
		Если КратностьДокумента = Неопределено Тогда 
			КратностьДокумента = КратностьУсловия;
		Иначе
			КратностьДокумента = Мин(КратностьУсловия, КратностьДокумента);
		КонецЕсли;
	КонецЦикла;
	//Конец Кратность
	
	СуммаДокументаПоУсловиям = 0;
	Для Каждого Товар Из ПараметрыРасчетаСкидки.Товары Цикл
		
		Комментарий = "";
		// Каждая примененная скидка добаляется в специальную таблицу, связанную с табличной частью товаров 
		НоваяСтрока           = ТаблицаСкидок.Добавить();
		НоваяСтрока.КлючСвязи = Товар.КлючСвязи;
		Если ПараметрыРасчетаСкидки.СтрокиСНевыполненнымиУсловиями.Найти(Товар.КлючСвязи) = Неопределено Тогда
			НоваяСтрока.Действует = Истина;
		Иначе
			// Скидка не применится, но она сохраняется в таблице для отображения в расшифровке расчета
			// Тогда можно будет увидеть, какие конкретно условия не выполнились
			НоваяСтрока.Действует = Ложь;
		КонецЕсли;
				
		СуммаТовара = Товар.Сумма - ?(ПараметрыСкидки.УменьшатьНаСуммуОплатыБаллами, Товар.СуммаСкидкиОплатыБонусом, 0);

		// Кратность
		Кратность = КратностьДокумента;
		ОтборСтрок = Новый Структура("КлючСвязи", Товар.КлючСвязи);
		УсловияПоСтроке = СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.ТаблицаПроверкиУсловий.НайтиСтроки(ОтборСтрок);
		Если ИспользоватьКратность И НоваяСтрока.Действует И УсловияПоСтроке.Количество() > 0 Тогда
			СтрокаУсловий = УсловияПоСтроке[0];
			Для Каждого ОписаниеУсловия Из СтрокаДерева.ПараметрыУсловий.УсловияПоСтроке.СоответствиеУсловийКолонкамТаблицыПроверкиУсловий Цикл			
				ИмяКолонкиКратность = ОписаниеУсловия.Значение + "Кратность";
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаУсловий, ИмяКолонкиКратность) Тогда 
					КратностьУсловия = СтрокаУсловий[ИмяКолонкиКратность];
				Иначе
					ОтборУсловия = Новый Структура("УсловиеПредоставления", ОписаниеУсловия.Ключ);
					РезультатПроверки = СтрокаДерева.ПараметрыУсловий.ТаблицаУсловий.НайтиСтроки(ОтборУсловия);
					Если РезультатПроверки.Количество() > 0 Тогда
						КратностьУсловия = РезультатПроверки[0].КратностьВыполнения;
					КонецЕсли;
				КонецЕсли;
				КратностьУсловия = ?(Повторять ИЛИ КратностьУсловия < 0, КратностьУсловия, 1);
				Если Кратность = Неопределено Тогда 
					Кратность = КратностьУсловия;
				Иначе
					Кратность = Мин(КратностьУсловия, Кратность);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если Кратность = 0 Тогда 
			НоваяСтрока.Действует = Ложь;
		КонецЕсли;
		// Конец Кратность
		
		Если НоваяСтрока.Действует Тогда
			СуммаДокументаПоУсловиям = СуммаДокументаПоУсловиям + СуммаТовара;
		КонецЕсли;
		ЗначениеСкидкиНаценки = ПараметрыСкидки.ЗначениеСкидкиНаценки;
		
		// Уточнения
		// Поиск значения скидки (наценки) для ценовой группы
		СкидкаПодразумеваетУточненияПоНоменклатуре = Истина;
		Если НЕ СкидкаПодразумеваетУточненияПоНоменклатуре Тогда
			// УточненийНеТребуется	
		ИначеЕсли СтрокаДерева.ЕстьУточненияПоЦеновымГруппам Тогда
			Для Каждого СтрокаТЧ Из СкидкиНаценкиПоЦеновымГруппам Цикл
				Если СтрокаТЧ.ЗначениеУточнения = Товар.ЦеноваяГруппа Тогда
					ЗначениеСкидкиНаценки = СтрокаТЧ.ЗначениеСкидкиНаценки;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		// Поиск значения скидки (наценки) для номенклатурной группы
		ИначеЕсли СтрокаДерева.ЕстьУточненияПоКатегориям Тогда
			Для Каждого СтрокаТЧ Из СкидкиНаценкиПоКатегориямНоменклатуры Цикл
				Если СтрокаТЧ.ЗначениеУточнения = Товар.КатегорияНоменклатуры Тогда
					ЗначениеСкидкиНаценки = СтрокаТЧ.ЗначениеСкидкиНаценки;
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли СтрокаДерева.ЕстьУточненияПоСегментамНоменклатуры Тогда
			Для Каждого СтрокаТЧ Из СкидкиНаценкиПоСегментамНоменклатуры Цикл
				Если СтрокаТЧ.ЗначениеУточнения = Товар.Номенклатура И СтрокаТЧ.Характеристика = Товар.Характеристика Тогда
					ЗначениеСкидкиНаценки = СтрокаТЧ.ЗначениеСкидкиНаценки;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		// Поиск значения скидки (наценки) для номенклатуры
		ИначеЕсли СтрокаДерева.ЕстьУточненияПоНоменклатуре Тогда
			Если Не СтрокаДерева.ЕстьГруппыВУточненииПоНоменклатуре Тогда
				Если Товар.Характеристика.Пустая() Тогда
					Для Каждого СтрокаТЧ Из СкидкиНаценкиПоНоменклатуре Цикл
						Если СтрокаТЧ.ЗначениеУточнения = Товар.Номенклатура И СтрокаТЧ.Характеристика.Пустая() Тогда
							ЗначениеСкидкиНаценки = СтрокаТЧ.ЗначениеСкидкиНаценки;
							Прервать;
						КонецЕсли;
					КонецЦикла;
				Иначе
					ЕстьЗначениеДляХарактеристики = Ложь;
					ЗначениеДляХарактеристики = 0;
					Для Каждого СтрокаТЧ Из СкидкиНаценкиПоНоменклатуре Цикл
						Если СтрокаТЧ.ЗначениеУточнения = Товар.Номенклатура И СтрокаТЧ.Характеристика = Товар.Характеристика Тогда
							ЗначениеСкидкиНаценки = СтрокаТЧ.ЗначениеСкидкиНаценки;
							ЕстьЗначениеДляХарактеристики = Истина;
							ЗначениеДляХарактеристики = ЗначениеСкидкиНаценки;
							Прервать;
						ИначеЕсли СтрокаТЧ.ЗначениеУточнения = Товар.Номенклатура И СтрокаТЧ.Характеристика.Пустая() Тогда
							ЗначениеСкидкиНаценки = СтрокаТЧ.ЗначениеСкидкиНаценки;
						КонецЕсли;
					КонецЦикла;
					
					Если ЕстьЗначениеДляХарактеристики Тогда
						ЗначениеСкидкиНаценки = ЗначениеДляХарактеристики;
					КонецЕсли;
				КонецЕсли;
			Иначе
				// Поиск с учетом иерархии.
				//@skip-check query-in-loop
				ТекЗначениеУточнения = ПолучитьЗначениеУточненияСУчетомИерархии(СтрокаДерева.СкидкаНаценка, ПараметрыРасчета.СкидкиНаценкиПоНоменклатуре, Товар.Номенклатура, Товар.Характеристика);
				Если ТекЗначениеУточнения <> Неопределено Тогда
					ЗначениеСкидкиНаценки = ТекЗначениеУточнения;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// Конец Уточнения
		
		Комментарий = "";
#Область ПереопределяемыйАлгоритмРасчетаСуммыСкидки
        СуммаСкидки = 0;
#КонецОбласти		

		НоваяСтрока.Сумма = СуммаСкидки;
		НоваяСтрока.ЗначениеСкидкиНаценки = ЗначениеСкидкиНаценки;
		НоваяСтрока.ТаблицаСообщений = ТаблицаСообщений;
		НоваяСтрока.ТаблицаПодарков = ТаблицаПодарков;
		НоваяСтрока.Расшифровка = ТаблицаРасшифровкиСкидки(СтрокаДерева.СкидкаНаценка, НоваяСтрока.Сумма,
			НоваяСтрока.ЗначениеСкидкиНаценки, Комментарий);
		
	КонецЦикла;		
КонецПроцедуры

// Функция создает таблицу значений с расшифровками скидок и добавляет в нее переданные значения.
// 
// Параметры:
//  СкидкаНаценка - СправочникСсылка.АвтоматическиеСкидки - Скидка, наценка
//  Сумма - Число - Сумма
//  ЗначениеСкидкиНаценки - Число - Значение скидки, наценки
//  Комментарий - Строка - Комментарий
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Расшифровка скидок.
Функция ТаблицаРасшифровкиСкидки(СкидкаНаценка, Сумма, ЗначениеСкидкиНаценки, Комментарий = "") Экспорт
	
	Расшифровка = ПолучитьПустуюТаблицуРасшифровки();
	
	СтрокаРасшифровки = Расшифровка.Добавить();
	СтрокаРасшифровки.СкидкаНаценка = СкидкаНаценка;
	СтрокаРасшифровки.Сумма         = Сумма;
	СтрокаРасшифровки.ЗначениеСкидкиНаценки = ЗначениеСкидкиНаценки;
	СтрокаРасшифровки.Комментарий	= Комментарий;
	
	Возврат Расшифровка;
	
КонецФункции // ПолучитьРасшифровкуСкидки()

Процедура ПеренестиАвтоматическиеСкидкиИзДокументаОснования(ДокументОбъект, ТаблицаВыбранныеУправляемыеСкидки = Неопределено, 
	ТаблицаПримененныеПромокоды = Неопределено, ТаблицаОплатыБонусами = Неопределено) Экспорт
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьАвтоматическиеСкидкиНаценки") Тогда
		// Управляемые скидки
		Если НЕ ТаблицаВыбранныеУправляемыеСкидки = Неопределено Тогда
			КлючиСвязиДокумента = ДокументОбъект.Запасы.ВыгрузитьКолонку("КлючСвязи");
			КлючиСвязиДокумента.Добавить(0); // Скидки, действующие на документ целиком
			СтрокиПеренести = Новый Массив;
			Для Каждого СтрокаУправляемойСкидки Из ТаблицаВыбранныеУправляемыеСкидки Цикл
				Если Не КлючиСвязиДокумента.Найти(СтрокаУправляемойСкидки.КлючСвязи) = Неопределено Тогда
					СтрокиПеренести.Добавить(СтрокаУправляемойСкидки);
				КонецЕсли;
			КонецЦикла;
			ДокументОбъект.ВыбранныеУправляемыеСкидки.Загрузить(ТаблицаВыбранныеУправляемыеСкидки.Скопировать(СтрокиПеренести));
		КонецЕсли;
		
		Если НЕ ТаблицаПримененныеПромокоды = Неопределено Тогда
			// Промокоды
			// Если в заказе выдается промокод, но заказ еще не отгружен полностью,
			// Скидка с выдачей промокода не применится (она применяется только для последней отгрузки по заказу)
			// В таком случае, промокод при расчете скидок будет удален из ТЧ.
			ДокументОбъект.ПримененныеПромокоды.Загрузить(ТаблицаПримененныеПромокоды);
		КонецЕсли;
		//РасчетныеСкидки = СкидкиНаценкиСерверПереопределяемый.ПолучитьСкидкиНаценкиПоЗаказу(ДокументОбъект);
		СтруктураПараметры = Новый Структура;
		РасчетныеСкидки = СкидкиНаценкиСерверПереопределяемый.ВыполнитьРасчетСкидокНаСервере(ДокументОбъект, СтруктураПараметры);
		СуммаОплатыБонусами = Неопределено;
		ИмяТабличнойЧасти = "Предоплата";
		ИмяКолонкиСумма = "СуммаРасчетов";
		ОтборОплатБаллами = Новый Структура("ОплатаБонусами", Истина);
		Если ТипЗнч(ДокументОбъект.Ссылка) = Тип("ДокументСсылка.ЧекККМ") 
			ИЛИ ТипЗнч(ДокументОбъект.Ссылка) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
			ИмяТабличнойЧасти = "БезналичнаяОплата";
			ИмяКолонкиСумма = "СуммаБонусов";
			ОтборОплатБаллами = Новый Структура("ВидОплаты", ПредопределенноеЗначение("Перечисление.ВидыБезналичныхОплат.Бонусы"));
		КонецЕсли;
		Если Не ТаблицаОплатыБонусами = Неопределено Тогда
			ОплатыБаллами = ДокументОбъект[ИмяТабличнойЧасти].НайтиСтроки(ОтборОплатБаллами);
			Для Каждого СтрокаОплатыБаллами Из ОплатыБаллами Цикл
				ДокументОбъект[ИмяТабличнойЧасти].Удалить(СтрокаОплатыБаллами);
			КонецЦикла;
			
			ПараметрыБП = РаботаСБонусами.РеквизитыБонуснойПрограммы(ДокументОбъект.ДисконтнаяКарта);

			// Оплата в рублях, а сколько списывается бонусов с карты - нужно считать по курсу
			КурсБонусов = 1;
			Если ПараметрыБП.Свойство("КурсБонусов") И ЗначениеЗаполнено(ПараметрыБП.КурсБонусов) Тогда
				КурсБонусов = ПараметрыБП.КурсБонусов;
			КонецЕсли;
			Если НЕ ПараметрыБП.Свойство("БонуснаяПрограмма")
				ИЛИ Не ЗначениеЗаполнено(ПараметрыБП.БонуснаяПрограмма) Тогда
				СуммаОплатыБонусами = 0;
			ИначеЕсли НЕ РасчетныеСкидки.Свойство("СуммаОплатыБонусами", СуммаОплатыБонусами) Тогда
				СуммаОплатыБонусами = ТаблицаОплатыБонусами.Итог("СуммаБонусов") * КурсБонусов;
			КонецЕсли;
				
			//ТаблицаОплатыБонусами
			СуммаОплатыБонусамиОсталосьУчесть = СуммаОплатыБонусами;
			Для Каждого ОплатаБонусами ИЗ ТаблицаОплатыБонусами Цикл
				Если СуммаОплатыБонусамиОсталосьУчесть <= 0 Тогда
					Прервать;
				КонецЕсли;
				ОплатаБонусамиСтроки = Мин(СуммаОплатыБонусамиОсталосьУчесть, ОплатаБонусами.СуммаБонусов * КурсБонусов);
				Если ОплатаБонусамиСтроки <= 0 Тогда
					Продолжить;
				КонецЕсли;
				СтрокаОплатыБонусами = ДокументОбъект[ИмяТабличнойЧасти].Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаОплатыБонусами, ОплатаБонусами);
				// Курс - это сколько рублей зачтется за 1 потраченный бонус
				СтрокаОплатыБонусами[ИмяКолонкиСумма] = ОплатаБонусамиСтроки / КурсБонусов;
				СуммаОплатыБонусамиОсталосьУчесть = СуммаОплатыБонусамиОсталосьУчесть - ОплатаБонусамиСтроки;
			КонецЦикла;
			РасчетныеСкидки.СуммаОплатыБонусами = СуммаОплатыБонусами;
		КонецЕсли;
		РезультатПрименения = ПрименитьРассчитанныеСкидкиКОбъекту(ДокументОбъект, РасчетныеСкидки);
		ВыданныеПодарки = Новый Массив;
		ДатаОбработки = ЦенообразованиеСервер.ПолучитьДатуОбработкиЦен(Истина, ДокументОбъект.Дата);
		НалогообложениеНДСОрганизации = НалогиУНФ.НалогообложениеНДС(ДокументОбъект.Организация,, ДатаОбработки);
		ВидСтавкиОрганизации = Неопределено;
		Если РезультатПрименения.Свойство("ДобавленныеСтрокиЗапасов", ВыданныеПодарки) Тогда
			СуммаВключаетНДС = Истина;
			Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументОбъект, "СуммаВключаетНДС") Тогда
				СуммаВключаетНДС = ДокументОбъект.СуммаВключаетНДС;
			КонецЕсли;
			Для Каждого ОписаниеПодарка Из ВыданныеПодарки Цикл		
				СтрокаЗапаса = ОписаниеПодарка.Ключ;

				РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтрокаЗапаса.Номенклатура, "ВидСтавкиНДС, Вес, Объем");
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаЗапаса, "Вес") Тогда
					СтрокаЗапаса.Вес = СтрокаЗапаса.Количество * РеквизитыНоменклатуры.Вес;
				КонецЕсли; 
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаЗапаса, "Объем") Тогда
					СтрокаЗапаса.Объем = СтрокаЗапаса.Количество * РеквизитыНоменклатуры.Объем;
				КонецЕсли; 
				ВидСтавкиНоменклатуры = РеквизитыНоменклатуры.ВидСтавкиНДС;
				Если НалогообложениеНДСОрганизации = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НаЭкспорт") Тогда
					СтрокаЗапаса.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
				ИначеЕсли НалогообложениеНДСОрганизации = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НеОблагаетсяНДС") Тогда
					СтрокаЗапаса.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();									
				ИначеЕсли ЗначениеЗаполнено(ВидСтавкиНоменклатуры) Тогда					
					СтрокаЗапаса.СтавкаНДС = Справочники.СтавкиНДС.СтавкаНДС(ВидСтавкиНоменклатуры);
				Иначе
					Если ВидСтавкиОрганизации = Неопределено Тогда
						//@skip-check bsl-legacy-check-string-literal
						ВидСтавкиОрганизации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОбъект.Организация, "ВидСтавкиНДСПоУмолчанию");
					КонецЕсли;
					СтрокаЗапаса.СтавкаНДС = Справочники.СтавкиНДС.СтавкаНДС(ВидСтавкиОрганизации);
				КонецЕсли;
				ПараметрыРасчета = Новый Структура("СуммаВключаетНДС", СуммаВключаетНДС);
				ТабличныеЧастиУНФКлиентСервер.РассчитатьСуммуНДСИВсего(СтрокаЗапаса, ПараметрыРасчета);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция РассчитатьПотенциальныеБонусыКНачислению(ДеревоСкидок, ТаблицаВыполненныеУсловия,
	ПараметрыРасчета, ОбъединенныеПараметры)
	
	// Сделаем копии исходных данных, чтобы их не модифицировать во время расчета потенциальных скидок
	КопияДереваСкидок = ОбщегоНазначения.СкопироватьРекурсивно(ДеревоСкидок);
	КопияПараметрыРасчета = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыРасчета);
	КопияОбъединенныеПараметры = ОбщегоНазначения.СкопироватьРекурсивно(ОбъединенныеПараметры);
	//@skip-check bsl-legacy-check-expression-type
	КопияОбъединенныеПараметры.Вставить("РассчитыватьБонусы", Истина);
	КопияТаблицыВыполненныхУсловий = ТаблицаВыполненныеУсловия.Скопировать();
	
	БонусыКНачислению = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АвтоматическиеСкидкиУсловияПредоставления.УсловиеПредоставления КАК Ссылка,
		|	""-1"" КАК КлючСвязи,
		|	1 КАК КоличествоКомплектов
		|ИЗ
		|	Справочник.АвтоматическиеСкидки.УсловияПредоставления КАК АвтоматическиеСкидкиУсловияПредоставления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АвтоматическиеСкидки КАК АвтоматическиеСкидки
		|		ПО АвтоматическиеСкидкиУсловияПредоставления.Ссылка = АвтоматическиеСкидки.Ссылка
		|			И (АвтоматическиеСкидки.Ссылка В (&Скидки))
		|			И (АвтоматическиеСкидки.ЭтоПравилоНачисленияБонусов)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УсловияПредоставленияСкидокНаценок КАК УсловияПредоставленияСкидокНаценок
		|		ПО АвтоматическиеСкидкиУсловияПредоставления.УсловиеПредоставления = УсловияПредоставленияСкидокНаценок.Ссылка
		|			И (УсловияПредоставленияСкидокНаценок.УсловиеПредоставления = ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ЗаДисконтнуюКарту))
		|			И (УсловияПредоставленияСкидокНаценок.ВидДисконтнойКарты В (ЗНАЧЕНИЕ(Справочник.ВидыДисконтныхКарт.ПустаяСсылка), &ВидДисконтнойКарты))
		|
		|СГРУППИРОВАТЬ ПО
		|	АвтоматическиеСкидкиУсловияПредоставления.УсловиеПредоставления";
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(КопияПараметрыРасчета,
		"ВидДисконтнойКартыПоУмолчанию") Тогда
		
		ВидДисконтнойКарты = КопияПараметрыРасчета.ВидДисконтнойКартыПоУмолчанию;
	Иначе
		ВидДисконтнойКарты = Справочники.ВидыДисконтныхКарт.ПустаяСсылка();
	КонецЕсли;
	Запрос.УстановитьПараметр("ВидДисконтнойКарты", ВидДисконтнойКарты);
	Запрос.УстановитьПараметр("Скидки", КопияОбъединенныеПараметры.СкидкиНаценки.ВыгрузитьКолонку("СкидкаНаценка"));
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаУсловийЗаДисконтнуюКарту = РезультатЗапроса.Выбрать();
	Пока ВыборкаУсловийЗаДисконтнуюКарту.Следующий() Цикл
		НоваяСтрокаВыполненныхУсловий = КопияТаблицыВыполненныхУсловий.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаВыполненныхУсловий, ВыборкаУсловийЗаДисконтнуюКарту);
	КонецЦикла;

	// Выполним рассчет скидок с выполенным условием на копии данных
	ПроверитьУсловияРекурсивно(КопияДереваСкидок, КопияТаблицыВыполненныхУсловий, КопияПараметрыРасчета);
	КопияДереваСкидок.Колонки.Удалить(КопияДереваСкидок.Колонки.УсловияПредоставления);
	СтруктураСкидок = СтруктураРассчитанныхСкидок(КопияДереваСкидок, КопияОбъединенныеПараметры);
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтруктураСкидок,
		"ТаблицаБонусыКНачислению") Тогда
		
		БонусыКНачислению = СтруктураСкидок.ТаблицаБонусыКНачислению.Итог("КоличествоБонусныхБаллов");
	КонецЕсли;
	
	Возврат БонусыКНачислению;
	
КонецФункции

Процедура АктуализироватьДанныеПослеРасчетаПотенциальныхБонусовКНачислению(ДеревоСкидок, ТаблицаВыполненныеУсловия,
	ПараметрыРасчета, ОбъединенныеПараметры)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АвтоматическиеСкидки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.АвтоматическиеСкидки КАК АвтоматическиеСкидки
		|ГДЕ
		|	АвтоматическиеСкидки.Ссылка В(&Скидки)
		|	И АвтоматическиеСкидки.ЭтоПравилоНачисленияБонусов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УсловияПредоставления.Ссылка КАК Ссылка
		|ИЗ
		|	(ВЫБРАТЬ
		|		АвтоматическиеСкидкиУсловияПредоставления.УсловиеПредоставления КАК Ссылка,
		|		СУММА(ВЫБОР
		|				КОГДА АвтоматическиеСкидки.ЭтоПравилоНачисленияБонусов
		|					ТОГДА 1
		|				ИНАЧЕ 0
		|			КОНЕЦ) КАК ВНачисленияхБонусов,
		|		СУММА(ВЫБОР
		|				КОГДА НЕ АвтоматическиеСкидки.ЭтоПравилоНачисленияБонусов
		|					ТОГДА 1
		|				ИНАЧЕ 0
		|			КОНЕЦ) КАК НеВНачисленияхБонусов
		|	ИЗ
		|		Справочник.АвтоматическиеСкидки.УсловияПредоставления КАК АвтоматическиеСкидкиУсловияПредоставления
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АвтоматическиеСкидки КАК АвтоматическиеСкидки
		|			ПО АвтоматическиеСкидкиУсловияПредоставления.Ссылка = АвтоматическиеСкидки.Ссылка
		|				И (АвтоматическиеСкидкиУсловияПредоставления.УсловиеПредоставления В (&Условия))
		|				И (АвтоматическиеСкидки.Ссылка В (&Скидки))
		|	
		|	СГРУППИРОВАТЬ ПО
		|		АвтоматическиеСкидкиУсловияПредоставления.УсловиеПредоставления) КАК УсловияПредоставления
		|ГДЕ
		|	УсловияПредоставления.ВНачисленияхБонусов > 0
		|	И УсловияПредоставления.НеВНачисленияхБонусов = 0";
	
	Запрос.УстановитьПараметр("Скидки", ОбъединенныеПараметры.СкидкиНаценки.ВыгрузитьКолонку("СкидкаНаценка"));
	Запрос.УстановитьПараметр("Условия", ТаблицаВыполненныеУсловия.ВыгрузитьКолонку("Ссылка"));
	
	Результаты = Запрос.ВыполнитьПакет();
	СкидкиКУдалению = Результаты[0].Выгрузить().ВыгрузитьКолонку("Ссылка");
	УсловияКУдалению = Результаты[1].Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Для Каждого СкидкаКУдалению Из СкидкиКУдалению Цикл
		СтрокиКУдалению = ОбъединенныеПараметры.СкидкиНаценки.НайтиСтроки(
			Новый Структура("СкидкаНаценка", СкидкаКУдалению));
		Для Каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
			ОбъединенныеПараметры.СкидкиНаценки.Удалить(СтрокаКУдалению);
		КонецЦикла;
		
		СтрокиКУдалению = ПараметрыРасчета.СкидкиНаценки.НайтиСтроки(
			Новый Структура("СкидкаНаценка", СкидкаКУдалению));
		Для Каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
			ПараметрыРасчета.СкидкиНаценки.Удалить(СтрокаКУдалению);
		КонецЦикла;
	КонецЦикла;
	
	Для Каждого УсловиеКУдалению Из УсловияКУдалению Цикл
		СтрокиКУдалению = ТаблицаВыполненныеУсловия.НайтиСтроки(Новый Структура("Ссылка", УсловиеКУдалению));
		Для Каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
			ТаблицаВыполненныеУсловия.Удалить(СтрокаКУдалению);
		КонецЦикла;
	КонецЦикла;
	
	ДеревоСкидок = ПолучитьДеревоСкидок(ОбъединенныеПараметры.СкидкиНаценки.ВыгрузитьКолонку("СкидкаНаценка"));
	
КонецПроцедуры

#КонецОбласти

#Область ЭлементыСкидокЗаполнение

// Процедура заполняет дерево скидок по таблице скидок наценок документа
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения	 - форма, где будут созданы элементы.
//
Процедура ЗаполнитьДеревоСкидок(Форма) Экспорт
	ЭлементыФормы = Форма.Элементы;
	ОбъектФормы = Форма.Объект;
	Если ЭлементыФормы.Найти("ДеревоСкидок") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДеревоСкидок = Форма.ДеревоСкидок;
	ЭлементыДерева = ДеревоСкидок.ПолучитьЭлементы();
	ЭлементыДерева.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаСкидок.КлючСвязи КАК КлючСвязи,
	|	ТаблицаСкидок.СкидкаНаценка КАК СкидкаНаценка,
	|	ТаблицаСкидок.Сумма КАК Сумма,
	|	ТаблицаСкидок.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки
	|ПОМЕСТИТЬ втТаблицаСкидок
	|ИЗ
	|	&ТаблицаСкидок КАК ТаблицаСкидок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасы.КлючСвязи КАК КлючСвязи,
	|	ТаблицаЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ТаблицаЗапасы.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	ТаблицаЗапасы.ПродажаПодарка КАК ПродажаПодарка
	|ПОМЕСТИТЬ втЗапасы
	|ИЗ
	|	&ТаблицаЗапасы КАК ТаблицаЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаУправляемыеСкидки.КлючСвязи КАК КлючСвязи,
	|	ТаблицаУправляемыеСкидки.СкидкаНаценка КАК СкидкаНаценка
	|ПОМЕСТИТЬ втУправляемыеСкидки
	|ИЗ
	|	&ТаблицаУправляемыеСкидки КАК ТаблицаУправляемыеСкидки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втЗапасы.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(втТаблицаСкидок.СкидкаНаценка, ЗНАЧЕНИЕ(справочник.АвтоматическиеСкидки.пустаяссылка)) КАК СкидкаНаценка,
	|	ЕСТЬNULL(втТаблицаСкидок.Сумма, 0) КАК Сумма,
	|	ЕСТЬNULL(втТаблицаСкидок.ЗначениеСкидкиНаценки, 0) КАК ЗначениеСкидкиНаценки,
	|	ВЫБОР
	|		КОГДА НЕ втУправляемыеСкидки.СкидкаНаценка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК УправляемаяСкидка,
	|	втЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	втЗапасы.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	втЗапасы.ПродажаПодарка КАК ПродажаПодарка,
	|	втЗапасы.КлючСвязи КАК КлючСвязи
	|ПОМЕСТИТЬ втДанныеДерева
	|ИЗ
	|	втЗапасы КАК втЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ втТаблицаСкидок КАК втТаблицаСкидок
	|			ЛЕВОЕ СОЕДИНЕНИЕ втУправляемыеСкидки КАК втУправляемыеСкидки
	|			ПО втТаблицаСкидок.СкидкаНаценка = втУправляемыеСкидки.СкидкаНаценка
	|		ПО втЗапасы.КлючСвязи = втТаблицаСкидок.КлючСвязи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанныеДерева.Номенклатура КАК Номенклатура,
	|	втДанныеДерева.СкидкаНаценка КАК СкидкаНаценка,
	|	втДанныеДерева.Сумма КАК Сумма,
	|	втДанныеДерева.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки,
	|	втДанныеДерева.УправляемаяСкидка КАК УправляемаяСкидка,
	|	втДанныеДерева.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	втДанныеДерева.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	втДанныеДерева.ПродажаПодарка КАК ПродажаПодарка,
	|	втДанныеДерева.КлючСвязи КАК КлючСвязи
	|ИЗ
	|	втДанныеДерева КАК втДанныеДерева
	|ИТОГИ
	|	МАКСИМУМ(Номенклатура),
	|	МАКСИМУМ(ПроцентСкидкиНаценки),
	|	МАКСИМУМ(СуммаСкидкиНаценки)
	|ПО
	|	КлючСвязи";
	Запрос.УстановитьПараметр("ТаблицаСкидок", ОбъектФормы.СкидкиНаценки.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаЗапасы", ОбъектФормы.Запасы.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаУправляемыеСкидки", ОбъектФормы.ВыбранныеУправляемыеСкидки.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаНоменклатураКлюч = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		СтруктураНастроекОбозначения = Новый Структура;
		СтруктураНастроекОбозначения.Вставить("РучнаяСкидка", Ложь);
		СтруктураНастроекОбозначения.Вставить("УправляемаяСкидка", Ложь);
		СтруктураНастроекОбозначения.Вставить("Подарок", Ложь);
		ДеревоСкидокОбъект = Форма.РеквизитФормыВЗначение("ДеревоСкидок");
		Пока ВыборкаНоменклатураКлюч.Следующий() Цикл
			СтрокаНоменклатура = ДеревоСкидокОбъект.Строки.Добавить();
			СтрокаНоменклатура.Представление = ВыборкаНоменклатураКлюч.Номенклатура;
			ОбщаяСуммаСкидок = 0;
			Выборка = ВыборкаНоменклатураКлюч.Выбрать();
			Пока Выборка.Следующий() Цикл
				Если Выборка.СкидкаНаценка.Пустая() Тогда
					Продолжить;
				КонецЕсли;
				СтрокаСкидки = СтрокаНоменклатура.Строки.Добавить();
				Если Выборка.ПродажаПодарка Тогда
					СтрокаСкидки.Представление = НСтр("ru = 'Подарок'");
				Иначе
					СтрокаСкидки.Представление = Строка(Выборка.СкидкаНаценка);
				КонецЕсли;
				СтрокаСкидки.ЗначениеСкидкиНаценки = Выборка.ЗначениеСкидкиНаценки;
				СтрокаСкидки.Сумма = Выборка.Сумма;
				СтрокаСкидки.Уровень = 1;
				СтруктураНастроекОбозначения.РучнаяСкидка = Ложь;
				СтруктураНастроекОбозначения.УправляемаяСкидка = Выборка.УправляемаяСкидка;
				СтруктураНастроекОбозначения.Подарок = Выборка.ПродажаПодарка;
				УстановитьОбозначение(СтруктураНастроекОбозначения, СтрокаСкидки);
				ОбщаяСуммаСкидок = ОбщаяСуммаСкидок + Выборка.Сумма;
			КонецЦикла;
			
			Если НЕ ВыборкаНоменклатураКлюч.СуммаСкидкиНаценки = 0 Тогда
				СтрокаСкидки = СтрокаНоменклатура.Строки.Добавить();
				Представление = НСтр("ru = 'Ручная %1'");
				ЗначениеПредставления = ?(ВыборкаНоменклатураКлюч.СуммаСкидкиНаценки > 0, НСтр("ru = 'скидка'"), НСтр("ru = 'наценка'"));
				Представление = СтрШаблон(Представление, ЗначениеПредставления);
				СтрокаСкидки.Представление = Представление;
				СтрокаСкидки.ЗначениеСкидкиНаценки = ВыборкаНоменклатураКлюч.ПроцентСкидкиНаценки;
				СтрокаСкидки.Сумма = ВыборкаНоменклатураКлюч.СуммаСкидкиНаценки;
				СтрокаСкидки.Уровень = 1;
				СтруктураНастроекОбозначения.РучнаяСкидка = Истина;
				СтруктураНастроекОбозначения.УправляемаяСкидка = Ложь;
				СтруктураНастроекОбозначения.Подарок = Ложь;
				УстановитьОбозначение(СтруктураНастроекОбозначения, СтрокаСкидки);
				ОбщаяСуммаСкидок = ОбщаяСуммаСкидок + ВыборкаНоменклатураКлюч.СуммаСкидкиНаценки;
			КонецЕсли;
			СтрокаНоменклатура.Сумма = ОбщаяСуммаСкидок;
		КонецЦикла;
		Форма.ЗначениеВРеквизитФормы(ДеревоСкидокОбъект, "ДеревоСкидок");
	КонецЕсли;
КонецПроцедуры

// Процедура заполняет таблицу управляемых скидок
//
// Параметры:
//  Форма		 - ФормаКлиентскогоПриложения	 - форма, где будут созданы элементы.
//  ЭтоВозврат	 - Булево						 - признак операции возврата.
//
Процедура ЗаполнитьТаблицуУправляемыхСкидок(Форма, ЭтоВозврат) Экспорт
	
	ЭлементыФормы = Форма.Элементы;
	Если ЭлементыФормы.Найти("УправляемыеСкидки") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ОбъектФормы = Форма.Объект;
	СтруктурнаяЕдиница = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ОбъектФормы, "СтруктурнаяЕдиницаРезерв") Тогда
		СтруктурнаяЕдиница = ОбъектФормы.СтруктурнаяЕдиницаРезерв;
	Иначе
		СтруктурнаяЕдиница = ОбъектФормы.СтруктурнаяЕдиница;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	|	ТаблицаУправляемыхСкидок.СкидкаНаценка КАК СкидкаНаценка
	|ПОМЕСТИТЬ втВыбранныеУС
	|ИЗ
	|	&ТаблицаУправляемыхСкидок КАК ТаблицаУправляемыхСкидок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СкидкаНаценка.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА СкидкаНаценка.СпособПредоставления В (ЗНАЧЕНИЕ(Перечисление.СпособыПредоставленияСкидокНаценок.Процент), ЗНАЧЕНИЕ(Перечисление.СпособыПредоставленияСкидокНаценок.Сумма), ЗНАЧЕНИЕ(Перечисление.СпособыПредоставленияСкидокНаценок.КоличествоБонусныхБаллов), ЗНАЧЕНИЕ(Перечисление.СпособыПредоставленияСкидокНаценок.ПроцентОтСуммыВВидеБонусныхБаллов))
	|			ТОГДА СкидкаНаценка.ЗначениеСкидкиНаценки
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(СкидкаНаценка.СпособПредоставления)
	|	КОНЕЦ КАК ЗначениеСкидки,
	|	СкидкаНаценка.Представление КАК Представление,
	|	&ТекстАвтоматическая КАК ТипСкидки,
	|	ВЫБОР
	|		КОГДА ПараметрыУсловий.ОбластьОграничения = ЗНАЧЕНИЕ(Перечисление.ВариантыОбластейОграниченияСкидокНаценок.ВДокументе)
	|			ТОГДА &ТекстНаДокумент
	|		ИНАЧЕ &ТекстНаСтроку
	|	КОНЕЦ КАК ОбластьДействия,
	|	СкидкаНаценка.ИспользоватьПриВозврате КАК ИспользоватьПриВозврате,
	|	СкидкаНаценка.ЭтоПравилоНачисленияБонусов КАК ЭтоПравилоНачисленияБонусов,
	|	СкидкаНаценка.ЕстьОграниченияПоПолучателямКонтрагентам КАК ЕстьОграниченияПоПолучателямКонтрагентам,
	|	СкидкаНаценка.ЕстьОграниченияПоПолучателямСкладам КАК ЕстьОграниченияПоПолучателямСкладам,
	|	СкидкаНаценка.ЕстьОграниченияПоПолучателямСегментам КАК ЕстьОграниченияПоПолучателямСегментам
	|ПОМЕСТИТЬ ВТ_Скидки
	|ИЗ
	|	Справочник.АвтоматическиеСкидки КАК СкидкаНаценка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АвтоматическиеСкидки.УсловияПредоставления КАК УсловияСкидок
	|		ПО СкидкаНаценка.Ссылка = УсловияСкидок.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УсловияПредоставленияСкидокНаценок КАК ПараметрыУсловий
	|		ПО (УсловияСкидок.УсловиеПредоставления = ПараметрыУсловий.Ссылка)
	|ГДЕ
	|	СкидкаНаценка.Действует
	|	И НЕ СкидкаНаценка.ПометкаУдаления
	|	И СкидкаНаценка.ЕстьУсловияАктивацииВручную
	|	И ПараметрыУсловий.УсловиеПредоставления = ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ЗаАктивациюВручную)
	|	И (СкидкаНаценка.ДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ &ДатаСеанса >= НАЧАЛОПЕРИОДА(СкидкаНаценка.ДатаНачала, ДЕНЬ))
	|	И (СкидкаНаценка.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|			ИЛИ &ДатаСеанса <= КОНЕЦПЕРИОДА(СкидкаНаценка.ДатаОкончания, ДЕНЬ))
	|	И ПараметрыУсловий.ОбластьОграничения = ЗНАЧЕНИЕ(Перечисление.ВариантыОбластейОграниченияСкидокНаценок.ВДокументе)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка КАК Склад,
	|	СтруктурныеЕдиницы.ТипСтруктурнойЕдиницы КАК ТипСтруктурнойЕдиницы
	|ПОМЕСТИТЬ ДанныеТорговогоОбъекта
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И СтруктурныеЕдиницы.Ссылка = &Склад
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка КАК Склад
	|ПОМЕСТИТЬ ТаблицаСклады
	|ИЗ
	|	ДанныеТорговогоОбъекта КАК ДанныеТорговогоОбъекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ПО ДанныеТорговогоОбъекта.Склад = СтруктурныеЕдиницы.Родитель
	|ГДЕ
	|	ДанныеТорговогоОбъекта.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов)
	|	И СтруктурныеЕдиницы.ТипСтруктурнойЕдиницы В (ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница), ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка
	|ИЗ
	|	ДанныеТорговогоОбъекта КАК ДанныеТорговогоОбъекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ПО ДанныеТорговогоОбъекта.Склад = СтруктурныеЕдиницы.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Скидки.Ссылка КАК СкидкаНаценка,
	|	ВТ_Скидки.ЗначениеСкидки КАК ЗначениеСкидки,
	|	ВТ_Скидки.Представление КАК Представление,
	|	ВТ_Скидки.ТипСкидки КАК ТипСкидки,
	|	ВТ_Скидки.ОбластьДействия КАК ОбластьДействия,
	|	ВТ_Скидки.ИспользоватьПриВозврате КАК ИспользоватьПриВозврате,
	|	ВТ_Скидки.ЭтоПравилоНачисленияБонусов КАК ЭтоПравилоНачисленияБонусов,
	|	ВТ_Скидки.ЕстьОграниченияПоПолучателямКонтрагентам КАК ЕстьОграниченияПоПолучателямКонтрагентам,
	|	ВТ_Скидки.ЕстьОграниченияПоПолучателямСегментам КАК ЕстьОграниченияПоПолучателямСегментам
	|ПОМЕСТИТЬ ВТ_Скидки_ОтборПоСкладу
	|ИЗ
	|	Справочник.АвтоматическиеСкидки.ПолучателиСкидкиСклады КАК АвтоматическиеСкидкиПолучателиСкидкиСклады
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Скидки КАК ВТ_Скидки
	|		ПО АвтоматическиеСкидкиПолучателиСкидкиСклады.Ссылка = ВТ_Скидки.Ссылка,
	|	ТаблицаСклады КАК ТаблицаСклады
	|ГДЕ
	|	ВТ_Скидки.ЕстьОграниченияПоПолучателямСкладам
	|	И АвтоматическиеСкидкиПолучателиСкидкиСклады.Получатель В
	|			(ВЫБРАТЬ
	|				ТаблицаСклады.Склад
	|			ИЗ
	|				ТаблицаСклады)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Скидки.Ссылка,
	|	ВТ_Скидки.ЗначениеСкидки,
	|	ВТ_Скидки.Представление,
	|	ВТ_Скидки.ТипСкидки,
	|	ВТ_Скидки.ОбластьДействия,
	|	ВТ_Скидки.ИспользоватьПриВозврате,
	|	ВТ_Скидки.ЭтоПравилоНачисленияБонусов,
	|	ВТ_Скидки.ЕстьОграниченияПоПолучателямКонтрагентам,
	|	ВТ_Скидки.ЕстьОграниченияПоПолучателямСегментам
	|ИЗ
	|	ВТ_Скидки КАК ВТ_Скидки
	|ГДЕ
	|	НЕ ВТ_Скидки.ЕстьОграниченияПоПолучателямСкладам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Скидки_ОтборПоСкладу.СкидкаНаценка КАК СкидкаНаценка,
	|	ВТ_Скидки_ОтборПоСкладу.ЗначениеСкидки КАК ЗначениеСкидки,
	|	ВТ_Скидки_ОтборПоСкладу.Представление КАК Представление,
	|	ВТ_Скидки_ОтборПоСкладу.ТипСкидки КАК ТипСкидки,
	|	ВТ_Скидки_ОтборПоСкладу.ОбластьДействия КАК ОбластьДействия,
	|	ВТ_Скидки_ОтборПоСкладу.ИспользоватьПриВозврате КАК ИспользоватьПриВозврате,
	|	ВТ_Скидки_ОтборПоСкладу.ЭтоПравилоНачисленияБонусов КАК ЭтоПравилоНачисленияБонусов
	|ПОМЕСТИТЬ ВТ_УправляемыеСкидки
	|ИЗ
	|	Справочник.АвтоматическиеСкидки.ПолучателиСкидкиКонтрагенты КАК АвтоматическиеСкидкиПолучателиСкидкиКонтрагенты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Скидки_ОтборПоСкладу КАК ВТ_Скидки_ОтборПоСкладу
	|		ПО (АвтоматическиеСкидкиПолучателиСкидкиКонтрагенты.Получатель = &Контрагент)
	|			И АвтоматическиеСкидкиПолучателиСкидкиКонтрагенты.Ссылка = ВТ_Скидки_ОтборПоСкладу.СкидкаНаценка
	|ГДЕ
	|	ВТ_Скидки_ОтборПоСкладу.ЕстьОграниченияПоПолучателямКонтрагентам
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Скидки_ОтборПоСкладу.СкидкаНаценка,
	|	ВТ_Скидки_ОтборПоСкладу.ЗначениеСкидки,
	|	ВТ_Скидки_ОтборПоСкладу.Представление,
	|	ВТ_Скидки_ОтборПоСкладу.ТипСкидки,
	|	ВТ_Скидки_ОтборПоСкладу.ОбластьДействия,
	|	ВТ_Скидки_ОтборПоСкладу.ИспользоватьПриВозврате,
	|	ВТ_Скидки_ОтборПоСкладу.ЭтоПравилоНачисленияБонусов
	|ИЗ
	|	Справочник.АвтоматическиеСкидки.ПолучателиСкидкиСегменты КАК АвтоматическиеСкидкиПолучателиСкидкиСегменты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Скидки_ОтборПоСкладу КАК ВТ_Скидки_ОтборПоСкладу
	|		ПО АвтоматическиеСкидкиПолучателиСкидкиСегменты.Ссылка = ВТ_Скидки_ОтборПоСкладу.СкидкаНаценка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СоставСегментаКонтрагентов КАК СоставСегментаКонтрагентов
	|		ПО АвтоматическиеСкидкиПолучателиСкидкиСегменты.Получатель = СоставСегментаКонтрагентов.Сегмент
	|			И (СоставСегментаКонтрагентов.Контрагент = &Контрагент)
	|ГДЕ
	|	ВТ_Скидки_ОтборПоСкладу.ЕстьОграниченияПоПолучателямСегментам
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Скидки_ОтборПоСкладу.СкидкаНаценка,
	|	ВТ_Скидки_ОтборПоСкладу.ЗначениеСкидки,
	|	ВТ_Скидки_ОтборПоСкладу.Представление,
	|	ВТ_Скидки_ОтборПоСкладу.ТипСкидки,
	|	ВТ_Скидки_ОтборПоСкладу.ОбластьДействия,
	|	ВТ_Скидки_ОтборПоСкладу.ИспользоватьПриВозврате,
	|	ВТ_Скидки_ОтборПоСкладу.ЭтоПравилоНачисленияБонусов
	|ИЗ
	|	ВТ_Скидки_ОтборПоСкладу КАК ВТ_Скидки_ОтборПоСкладу
	|ГДЕ
	|	НЕ ВТ_Скидки_ОтборПоСкладу.ЕстьОграниченияПоПолучателямКонтрагентам
	|	И НЕ ВТ_Скидки_ОтборПоСкладу.ЕстьОграниченияПоПолучателямСегментам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_УправляемыеСкидки.СкидкаНаценка КАК СкидкаНаценка,
	|	ВТ_УправляемыеСкидки.ЗначениеСкидки КАК ЗначениеСкидки,
	|	ВТ_УправляемыеСкидки.ИспользоватьПриВозврате КАК ИспользоватьПриВозврате,
	|	ВТ_УправляемыеСкидки.ЭтоПравилоНачисленияБонусов КАК ЭтоПравилоНачисленияБонусов,
	|	ВЫБОР
	|		КОГДА втВыбранныеУС.СкидкаНаценка ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК Отметка
	|ИЗ
	|	ВТ_УправляемыеСкидки КАК ВТ_УправляемыеСкидки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втВыбранныеУС КАК втВыбранныеУС
	|		ПО ВТ_УправляемыеСкидки.СкидкаНаценка = втВыбранныеУС.СкидкаНаценка";
	Запрос.УстановитьПараметр("ДатаСеанса", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Контрагент", ОбъектФормы.Контрагент);
	Запрос.УстановитьПараметр("Склад", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТаблицаУправляемыхСкидок", ОбъектФормы.ВыбранныеУправляемыеСкидки.Выгрузить());
	Запрос.УстановитьПараметр("ТекстАвтоматическая", НСтр("ru = 'Автоматическая'"));
	Запрос.УстановитьПараметр("ТекстНаДокумент", НСтр("ru = 'На документ'"));
	Запрос.УстановитьПараметр("ТекстНаСтроку", НСтр("ru = 'На строку'"));
	Форма.УправляемыеСкидки.Очистить();
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ЭлементыФормы.ГруппаУправляемыеСкидки.Видимость = Истина;
		РезультатУправляемыеСкидки = РезультатЗапроса.Выгрузить();
		СтрокиОтбор = РезультатУправляемыеСкидки.НайтиСтроки(Новый Структура("ИспользоватьПриВозврате", ЭтоВозврат));
		Для Каждого СтрокаСкидки Из СтрокиОтбор Цикл
			НоваяСтрока = Форма.УправляемыеСкидки.Добавить();
			НоваяСтрока.Отметка = СтрокаСкидки.Отметка;
			Если СтрокаСкидки.Отметка Тогда
				НоваяСтрока.ОтметкаКартинка = БиблиотекаКартинок.РМКАктивныйВыбор;
			Иначе
				НоваяСтрока.ОтметкаКартинка = БиблиотекаКартинок.РМКНеактивныйВыбор;
			КонецЕсли;
			НоваяСтрока.СкидкаНаценка = СтрокаСкидки.СкидкаНаценка;
			НоваяСтрока.ЗначениеСкидкиНаценки = СтрокаСкидки.ЗначениеСкидки;
			НоваяСтрока.ОтметкаКартинка = БиблиотекаКартинок.РМКНеактивныйВыбор;
		КонецЦикла;
	Иначе
		ЭлементыФормы.ГруппаУправляемыеСкидки.Видимость  = Ложь;
	КонецЕсли;
КонецПроцедуры

// Процедура заполняет дерево подарков
//
// Параметры:
//  Форма		 - ФормаКлиентскогоПриложения	 - форма, где будут созданы элементы.
//
Процедура ЗаполнитьДеревоПодарков(Форма) Экспорт
	ЭлементыФормы = Форма.Элементы;
	Если ЭлементыФормы.Найти("ДеревоПодарков") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДеревоПодарков = Форма.ДеревоПодарков;
	ЭлементыДерева = ДеревоПодарков.ПолучитьЭлементы();
	ЭлементыДерева.Очистить();
	
	Если ПустаяСтрока(Форма.АдресПодарковНаВыбор) Тогда
		ЭлементыФормы.ГруппаДеревоПодарки.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	ТаблицаПодарковНаВыбор = ПолучитьИзВременногоХранилища(Форма.АдресПодарковНаВыбор);
	Для Каждого СтрокаПодарка Из ТаблицаПодарковНаВыбор Цикл
		Если СтрокаПодарка.КлючСвязи = 0 Тогда
			ТабличныеЧастиУНФКлиентСервер.ЗаполнитьКлючСвязи(ТаблицаПодарковНаВыбор, СтрокаПодарка, "КлючСвязи");
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаПодаркиНаВыбор.СкидкаНаценка КАК СкидкаНаценка,
	|	ТаблицаПодаркиНаВыбор.Номенклатура КАК Номенклатура,
	|	ТаблицаПодаркиНаВыбор.Характеристика КАК Характеристика,
	|	ТаблицаПодаркиНаВыбор.Количество КАК Количество,
	|	ТаблицаПодаркиНаВыбор.Цена КАК Цена,
	|	ТаблицаПодаркиНаВыбор.Сумма КАК Сумма,
	|	ТаблицаПодаркиНаВыбор.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаПодаркиНаВыбор.КлючСвязи КАК КлючСвязи,
	|	ТаблицаПодаркиНаВыбор.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ПОМЕСТИТЬ втПодарки
	|ИЗ
	|	&ТаблицаПодаркиНаВыбор КАК ТаблицаПодаркиНаВыбор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втПодарки.СкидкаНаценка КАК СкидкаНаценка,
	|	втПодарки.Номенклатура КАК Номенклатура,
	|	втПодарки.Характеристика КАК Характеристика,
	|	втПодарки.Количество КАК Количество,
	|	втПодарки.Цена КАК Цена,
	|	втПодарки.Сумма КАК Сумма,
	|	втПодарки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	втПодарки.КлючСвязи КАК КлючСвязи,
	|	втПодарки.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ИЗ
	|	втПодарки КАК втПодарки
	|ИТОГИ ПО
	|	СкидкаНаценка";
	Запрос.УстановитьПараметр("ТаблицаПодаркиНаВыбор", ТаблицаПодарковНаВыбор);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ЭлементыФормы.ГруппаДеревоПодарки.Видимость = Истина;
		ДеревоПодарковОбъект = Форма.РеквизитФормыВЗначение("ДеревоПодарков");
		ВыборкаСкидка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСкидка.Следующий() Цикл
			СтрокаСкидка = ДеревоПодарковОбъект.Строки.Добавить();
			СтрокаСкидка.Представление = Строка(ВыборкаСкидка.СкидкаНаценка);
			Выборка = ВыборкаСкидка.Выбрать();
			Пока Выборка.Следующий() Цикл
				СтрокаДерева = СтрокаСкидка.Строки.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаДерева, Выборка);
				ПредставлениеХарактеристики = "";
				Если ЗначениеЗаполнено(Выборка.Характеристика) Тогда
					ПредставлениеХарактеристики = " (" + Строка(Выборка.Характеристика) + ")";
				КонецЕсли;
				ПредставлениеТовара = СтрШаблон("%1%2", Выборка.Номенклатура, ПредставлениеХарактеристики);
				СтрокаДерева.Представление = ПредставлениеТовара;
				СтрокаДерева.Уровень = 1;
			КонецЦикла;
		КонецЦикла;
		Форма.ЗначениеВРеквизитФормы(ДеревоПодарковОбъект, "ДеревоПодарков");
	Иначе
		ЭлементыФормы.ГруппаДеревоПодарки.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

// Процедура заполняет дерево скидок по таблице скидок наценок документа
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения	 - форма, где будут созданы элементы.
//
Процедура ЗаполнитьДеревоСкидокБезУправляемыхСкидок(Форма) Экспорт
	ЭлементыФормы = Форма.Элементы;
	ОбъектФормы = Форма.Объект;
	Если ЭлементыФормы.Найти("ДеревоСкидок") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДеревоСкидок = Форма.ДеревоСкидок;
	ЭлементыДерева = ДеревоСкидок.ПолучитьЭлементы();
	ЭлементыДерева.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаСкидок.КлючСвязи КАК КлючСвязи,
	|	ТаблицаСкидок.СкидкаНаценка КАК СкидкаНаценка,
	|	ТаблицаСкидок.Сумма КАК Сумма,
	|	ТаблицаСкидок.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки
	|ПОМЕСТИТЬ втТаблицаСкидок
	|ИЗ
	|	&ТаблицаСкидок КАК ТаблицаСкидок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасы.КлючСвязи КАК КлючСвязи,
	|	ТаблицаЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ТаблицаЗапасы.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	ТаблицаЗапасы.ПродажаПодарка КАК ПродажаПодарка
	|ПОМЕСТИТЬ втЗапасы
	|ИЗ
	|	&ТаблицаЗапасы КАК ТаблицаЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втЗапасы.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(втТаблицаСкидок.СкидкаНаценка, ЗНАЧЕНИЕ(справочник.АвтоматическиеСкидки.пустаяссылка)) КАК СкидкаНаценка,
	|	ЕСТЬNULL(втТаблицаСкидок.Сумма, 0) КАК Сумма,
	|	ЕСТЬNULL(втТаблицаСкидок.ЗначениеСкидкиНаценки, 0) КАК ЗначениеСкидкиНаценки,
	|	втЗапасы.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	втЗапасы.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	втЗапасы.ПродажаПодарка КАК ПродажаПодарка
	|ПОМЕСТИТЬ втДанныеДерева
	|ИЗ
	|	втЗапасы КАК втЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ втТаблицаСкидок КАК втТаблицаСкидок
	|		ПО втЗапасы.КлючСвязи = втТаблицаСкидок.КлючСвязи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втДанныеДерева.Номенклатура КАК Номенклатура,
	|	втДанныеДерева.СкидкаНаценка КАК СкидкаНаценка,
	|	втДанныеДерева.Сумма КАК Сумма,
	|	втДанныеДерева.ЗначениеСкидкиНаценки КАК ЗначениеСкидкиНаценки,
	|	втДанныеДерева.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	втДанныеДерева.СуммаСкидкиНаценки КАК СуммаСкидкиНаценки,
	|	втДанныеДерева.ПродажаПодарка КАК ПродажаПодарка
	|ИЗ
	|	втДанныеДерева КАК втДанныеДерева
	|ИТОГИ
	|	МАКСИМУМ(ПроцентСкидкиНаценки),
	|	МАКСИМУМ(СуммаСкидкиНаценки)
	|ПО
	|	Номенклатура";
	Запрос.УстановитьПараметр("ТаблицаСкидок", ОбъектФормы.СкидкиНаценки.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаЗапасы", ОбъектФормы.Запасы.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаНоменклатура = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		СтруктураНастроекОбозначения = Новый Структура;
		СтруктураНастроекОбозначения.Вставить("РучнаяСкидка", Ложь);
		СтруктураНастроекОбозначения.Вставить("УправляемаяСкидка", Ложь);
		СтруктураНастроекОбозначения.Вставить("Подарок", Ложь);
		ДеревоСкидокОбъект = Форма.РеквизитФормыВЗначение("ДеревоСкидок");
		Пока ВыборкаНоменклатура.Следующий() Цикл
			СтрокаНоменклатура = ДеревоСкидокОбъект.Строки.Добавить();
			СтрокаНоменклатура.Представление = ВыборкаНоменклатура.Номенклатура;
			ОбщаяСуммаСкидок = 0;
			Выборка = ВыборкаНоменклатура.Выбрать();
			Пока Выборка.Следующий() Цикл
				Если Выборка.СкидкаНаценка.Пустая() Тогда
					Продолжить;
				КонецЕсли;
				СтрокаСкидки = СтрокаНоменклатура.Строки.Добавить();
				Если Выборка.ПродажаПодарка Тогда
					СтрокаСкидки.Представление = НСтр("ru = 'Подарок'");
				Иначе
					СтрокаСкидки.Представление = Строка(Выборка.СкидкаНаценка);
				КонецЕсли;
				СтрокаСкидки.ЗначениеСкидкиНаценки = Выборка.ЗначениеСкидкиНаценки;
				СтрокаСкидки.Сумма = Выборка.Сумма;
				СтрокаСкидки.Уровень = 1;
				СтруктураНастроекОбозначения.РучнаяСкидка = Ложь;
				СтруктураНастроекОбозначения.УправляемаяСкидка = Ложь;
				СтруктураНастроекОбозначения.Подарок = Выборка.ПродажаПодарка;
				УстановитьОбозначение(СтруктураНастроекОбозначения, СтрокаСкидки);
				ОбщаяСуммаСкидок = ОбщаяСуммаСкидок + Выборка.Сумма;
			КонецЦикла;
			
			Если НЕ ВыборкаНоменклатура.СуммаСкидкиНаценки = 0 Тогда
				СтрокаСкидки = СтрокаНоменклатура.Строки.Добавить();
				Представление = НСтр("ru = 'Ручная %1'");
				ЗначениеПредставления = ?(ВыборкаНоменклатура.СуммаСкидкиНаценки > 0, НСтр("ru = 'скидка'"), НСтр("ru = 'наценка'"));
				Представление = СтрШаблон(Представление, ЗначениеПредставления);
				СтрокаСкидки.Представление = Представление;
				СтрокаСкидки.ЗначениеСкидкиНаценки = ВыборкаНоменклатура.ПроцентСкидкиНаценки;
				СтрокаСкидки.Сумма = ВыборкаНоменклатура.СуммаСкидкиНаценки;
				СтрокаСкидки.Уровень = 1;
				СтруктураНастроекОбозначения.РучнаяСкидка = Истина;
				СтруктураНастроекОбозначения.УправляемаяСкидка = Ложь;
				СтруктураНастроекОбозначения.Подарок = Ложь;
				УстановитьОбозначение(СтруктураНастроекОбозначения, СтрокаСкидки);
				ОбщаяСуммаСкидок = ОбщаяСуммаСкидок + ВыборкаНоменклатура.СуммаСкидкиНаценки;
			КонецЕсли;
			СтрокаНоменклатура.Сумма = ОбщаяСуммаСкидок;
		КонецЦикла;
		Форма.ЗначениеВРеквизитФормы(ДеревоСкидокОбъект, "ДеревоСкидок");
	КонецЕсли;
КонецПроцедуры


// Процедура создает элементы работы со скидками на любой форме, где есть группа скидок
//
// Параметры:
//  Форма						 - ФормаКлиентскогоПриложения	 - форма, где будут созданы элементы.
//  СоздаватьУправляемыеСкидки	 - Булево						 - признак необходимости создавать таблицу управляемый скидок.
//  СоздаватьПодарки			 - Булево						 - признак необходимости создавать дерево подарков.
//
Процедура СоздатьЭлементыСкидок(Форма, СоздаватьУправляемыеСкидки = Истина, СоздаватьПодарки = Истина) Экспорт
	ЭлементыФормы = Форма.Элементы;
	ГруппаСкидки = ЭлементыФормы.Найти("ГруппаСкидок");
	Если ГруппаСкидки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СоздаватьУправляемыеСкидки Тогда
		СоздатьТаблицуУправляемыеСкидки(Форма, ГруппаСкидки);
	КонецЕсли;
	Если СоздаватьПодарки Тогда
		СоздатьДеревоПодарков(Форма, ГруппаСкидки);
	КонецЕсли;
	СоздатьЭлементДеревоСкидок(Форма, ГруппаСкидки);
КонецПроцедуры
#КонецОбласти

#Область ЭлементыСкидокСоздание

Процедура СоздатьТаблицуУправляемыеСкидки(Форма, ГруппаСкидки)
	
	ЭлементыФормы = Форма.Элементы;
	НоваяГруппа = ЭлементыФормы.Добавить("ГруппаСкидкиПодарки", Тип("ГруппаФормы"), ГруппаСкидки);
	НоваяГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НоваяГруппа.ОтображатьЗаголовок = Ложь;
	НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	НовыйЭлементФормы = ЭлементыФормы.Добавить("ГруппаУправляемыеСкидки", Тип("ГруппаФормы"), НоваяГруппа);
	НовыйЭлементФормы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НовыйЭлементФормы.ОтображатьЗаголовок = Ложь;
	НовыйЭлементФормы.Видимость = Ложь;
	
	ДобавляемыеРеквизиты 				= Новый Массив;
	ОписаниеТиповЧисло 					= Новый ОписаниеТипов("Число",,, Новый КвалификаторыЧисла(15,2));
	РеквизитТаблицаУправляемыеСкидки	= Новый РеквизитФормы("УправляемыеСкидки", Новый ОписаниеТипов("ТаблицаЗначений"),, НСтр("ru = 'Управляемые скидки'"));
	//@skip-check bsl-nstr-string-literal-format
	РеквизитОтметка						= Новый РеквизитФормы("Отметка", Новый ОписаниеТипов("Булево"), "УправляемыеСкидки", НСтр("ru = ''"));
	//@skip-check bsl-nstr-string-literal-format
	РеквизитОтметкаКартинка				= Новый РеквизитФормы("ОтметкаКартинка", Новый ОписаниеТипов("Картинка"), "УправляемыеСкидки", НСтр("ru = ''"));
	РеквизитСкидкаНаценка				= Новый РеквизитФормы("СкидкаНаценка", Новый ОписаниеТипов("СправочникСсылка.АвтоматическиеСкидки"), "УправляемыеСкидки", НСтр("ru = 'Управляемая скидка'"));
	РеквизитЗначениеСкидкиНаценки 		= Новый РеквизитФормы("ЗначениеСкидкиНаценки", ОписаниеТиповЧисло, "УправляемыеСкидки", НСтр("ru = 'Значение'"));
	ДобавляемыеРеквизиты.Добавить(РеквизитТаблицаУправляемыеСкидки);
	ДобавляемыеРеквизиты.Добавить(РеквизитОтметка);
	ДобавляемыеРеквизиты.Добавить(РеквизитОтметкаКартинка);
	ДобавляемыеРеквизиты.Добавить(РеквизитСкидкаНаценка);
	ДобавляемыеРеквизиты.Добавить(РеквизитЗначениеСкидкиНаценки);
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	ТаблицаУправляемыеСкидки = ЭлементыФормы.Добавить("УправляемыеСкидки", Тип("ТаблицаФормы"), ЭлементыФормы.ГруппаУправляемыеСкидки);
	ТаблицаУправляемыеСкидки.Отображение = ОтображениеТаблицы.Список;
	ТаблицаУправляемыеСкидки.ПутьКДанным = "УправляемыеСкидки";
	ТаблицаУправляемыеСкидки.КоманднаяПанель.Видимость = Ложь;
	ТаблицаУправляемыеСкидки.ГоризонтальныеЛинии = Ложь;
	ТаблицаУправляемыеСкидки.ВертикальныеЛинии = Ложь;
	ТаблицаУправляемыеСкидки.Шапка = Ложь;
	ТаблицаУправляемыеСкидки.УстановитьДействие("Выбор", "Подключаемый_УправляемыеСкидкиОтметка");

	НовыйЭлементТаблицы = ЭлементыФормы.Добавить("УправляемыеСкидкиОтметка", Тип("ПолеФормы"), ТаблицаУправляемыеСкидки);
	НовыйЭлементТаблицы.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементТаблицы.ПутьКДанным = "УправляемыеСкидки.Отметка";
	НовыйЭлементТаблицы.Видимость = Ложь;
	
	НовыйЭлементТаблицы = ЭлементыФормы.Добавить("УправляемыеСкидкиОтметкаКартинка", Тип("ПолеФормы"), ТаблицаУправляемыеСкидки);
	НовыйЭлементТаблицы.Вид = ВидПоляФормы.ПолеКартинки;
	НовыйЭлементТаблицы.Ширина = 2;
	НовыйЭлементТаблицы.ПутьКДанным = "УправляемыеСкидки.ОтметкаКартинка";
	//@skip-check bsl-nstr-string-literal-format
	НовыйЭлементТаблицы.Заголовок = НСтр("ru = ''");
	
	НовыйЭлементТаблицы = ЭлементыФормы.Добавить("УправляемыеСкидкиЗначениеСкидкиНаценки", Тип("ПолеФормы"), ТаблицаУправляемыеСкидки);
	НовыйЭлементТаблицы.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементТаблицы.ПутьКДанным = "УправляемыеСкидки.ЗначениеСкидкиНаценки";
	НовыйЭлементТаблицы.Ширина = 6;
	НовыйЭлементТаблицы.ТолькоПросмотр = Истина;
	
	НовыйЭлементТаблицы = ЭлементыФормы.Добавить("УправляемыеСкидкиСкидкаНаценка", Тип("ПолеФормы"), ТаблицаУправляемыеСкидки);
	НовыйЭлементТаблицы.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементТаблицы.ПутьКДанным = "УправляемыеСкидки.СкидкаНаценка";
	НовыйЭлементТаблицы.ТолькоПросмотр = Истина;
	
	Элемент = Форма.УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементыФормы.УправляемыеСкидки.Имя);
	ЭлементОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ЭлементыФормы.УправляемыеСкидкиОтметка.ПутьКДанным);
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Истина;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветЗеленойКнопкиРМК);
	
КонецПроцедуры

Процедура СоздатьЭлементДеревоСкидок(Форма, ГруппаСкидки)
	
	ЭлементыФормы = Форма.Элементы;
	
	НовыйЭлементФормы = ЭлементыФормы.Добавить("ГруппаДеревоСкидок", Тип("ГруппаФормы"), ГруппаСкидки);
	НовыйЭлементФормы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НовыйЭлементФормы.ОтображатьЗаголовок = Ложь;
	НовыйЭлементФормы.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	ДобавляемыеРеквизиты 			= Новый Массив;
	ОписаниеТиповСтрока 			= Новый ОписаниеТипов("Строка");
	ОписаниеТиповЧисло 				= Новый ОписаниеТипов("Число",,, Новый КвалификаторыЧисла(15,2));
	ОписаниеТиповКартинка			= Новый ОписаниеТипов("Картинка");
	РеквизитДеревоСкидок 			= Новый РеквизитФормы("ДеревоСкидок", Новый ОписаниеТипов("ДеревоЗначений"),,НСтр("ru = 'Дерево скидок'"));
	РеквизитПредставление 			= Новый РеквизитФормы("Представление", ОписаниеТиповСтрока, "ДеревоСкидок", НСтр("ru = 'Номенклатура/Скидка'"));
	РеквизитЗначениеСкидкиНаценки 	= Новый РеквизитФормы("ЗначениеСкидкиНаценки", ОписаниеТиповЧисло, "ДеревоСкидок", НСтр("ru = 'Значение'"));
	РеквизитСуммаСкидки 			= Новый РеквизитФормы("Сумма", ОписаниеТиповЧисло, "ДеревоСкидок", НСтр("ru = 'Сумма'"));
	РеквизитУровень 				= Новый РеквизитФормы("Уровень", ОписаниеТиповЧисло, "ДеревоСкидок", НСтр("ru = 'Уровень'"));
	//@skip-check bsl-nstr-string-literal-format
	РеквизитОбозначение 			= Новый РеквизитФормы("Обозначение", ОписаниеТиповКартинка, "ДеревоСкидок",
		НСтр("ru = ''"));
	
	ДобавляемыеРеквизиты.Добавить(РеквизитДеревоСкидок);
	ДобавляемыеРеквизиты.Добавить(РеквизитПредставление);
	ДобавляемыеРеквизиты.Добавить(РеквизитЗначениеСкидкиНаценки);
	ДобавляемыеРеквизиты.Добавить(РеквизитСуммаСкидки);
	ДобавляемыеРеквизиты.Добавить(РеквизитУровень);
	ДобавляемыеРеквизиты.Добавить(РеквизитОбозначение);
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	ДеревоСкидок = ЭлементыФормы.Добавить("ДеревоСкидок", Тип("ТаблицаФормы"), ЭлементыФормы.ГруппаДеревоСкидок);
	ДеревоСкидок.Отображение = ОтображениеТаблицы.Дерево;
	ДеревоСкидок.ПутьКДанным = "ДеревоСкидок";
	ДеревоСкидок.КоманднаяПанель.Видимость = Ложь;
	ДеревоСкидок.ГоризонтальныеЛинии = Ложь;
	ДеревоСкидок.ВертикальныеЛинии = Ложь;
	ДеревоСкидок.Шапка = Ложь;
	ДеревоСкидок.НачальноеОтображениеДерева = НачальноеОтображениеДерева.РаскрыватьВсеУровни;
	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоСкидокПредставление", Тип("ПолеФормы"), ДеревоСкидок);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоСкидок.Представление";
	НовыйЭлементДерева.ТолькоПросмотр = Истина;
	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоСкидокЗначениеСкидкиНаценки", Тип("ПолеФормы"), ДеревоСкидок);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоСкидок.ЗначениеСкидкиНаценки";
	НовыйЭлементДерева.ТолькоПросмотр = Истина;
	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоСкидокСумма", Тип("ПолеФормы"), ДеревоСкидок);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоСкидок.Сумма";
	НовыйЭлементДерева.ТолькоПросмотр = Истина;
	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоСкидокУровень", Тип("ПолеФормы"), ДеревоСкидок);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеКартинки;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоСкидок.Уровень";
	НовыйЭлементДерева.Видимость = Ложь;
	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоСкидокОбозначение", Тип("ПолеФормы"), ДеревоСкидок);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеКартинки;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоСкидок.Обозначение";
	НовыйЭлементДерева.ТолькоПросмотр = Истина;
	//@skip-check bsl-nstr-string-literal-format
	НовыйЭлементДерева.Заголовок = НСтр("ru = ''");
	
	Элемент = Форма.УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементыФормы.ДеревоСкидок.Имя);
	ЭлементОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ЭлементыФормы.ДеревоСкидокУровень.ПутьКДанным);
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = 0;
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.ШрифтОбычныйПолужирныйРМК);
	
	КомандаПрименениеСкидок = Форма.Команды.Добавить("ПрименениеАвтоматическихСкидок");
	КомандаПрименениеСкидок.Заголовок = НСтр("ru = 'Применение автоматических скидок'");
	КомандаПрименениеСкидок.Действие = "Подключаемый_ПрименениеАвтоматическихСкидок";
	
	НовыйЭлемент = Форма.Элементы.Добавить("Подключаемый_ПрименениеАвтоматическихСкидок", Тип("КнопкаФормы"), ЭлементыФормы.ГруппаДеревоСкидок);
	НовыйЭлемент.Заголовок = НСтр("ru = 'Применение автоматических скидок'");
	НовыйЭлемент.ИмяКоманды = "ПрименениеАвтоматическихСкидок";
	НовыйЭлемент.Вид = ВидКнопкиФормы.Гиперссылка;
КонецПроцедуры

Процедура СоздатьДеревоПодарков(Форма, ГруппаСкидки)
	ЭлементыФормы = Форма.Элементы;
	ГруппаСкидкиПодарки = ЭлементыФормы.Найти("ГруппаСкидкиПодарки");
	Если ГруппаСкидкиПодарки = Неопределено Тогда
		ЭлементыФормы = Форма.Элементы;
		НоваяГруппа = ЭлементыФормы.Добавить("ГруппаСкидкиПодарки", Тип("ГруппаФормы"), ГруппаСкидки);
		НоваяГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НоваяГруппа.ОтображатьЗаголовок = Ложь;
		НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ГруппаСкидкиПодарки = НоваяГруппа;
	КонецЕсли;
	НовыйЭлементФормы = ЭлементыФормы.Добавить("ГруппаДеревоПодарки", Тип("ГруппаФормы"), ГруппаСкидкиПодарки);
	НовыйЭлементФормы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	НовыйЭлементФормы.ОтображатьЗаголовок = Ложь;
	НовыйЭлементФормы.Видимость = Ложь;
	
	ДобавляемыеРеквизиты 			= Новый Массив;
	ОписаниеТиповСтрока 			= Новый ОписаниеТипов("Строка");
	ОписаниеТиповЧисло 				= Новый ОписаниеТипов("Число",,, Новый КвалификаторыЧисла(15,2));
	ОписаниеТиповНоменклатура		= Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	ОписаниеТиповХарактеристика		= Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры");
	ОписаниеСкидкаНаценка			= Новый ОписаниеТипов("СправочникСсылка.АвтоматическиеСкидки");
	ОписаниеСтруктурнаяЕдиница		= Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы");
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.КлассификаторЕдиницИзмерения"));
	МассивТипов.Добавить(Тип("СправочникСсылка.ЕдиницыИзмерения"));
	ОписаниеЕдиницаИзмерения		= Новый ОписаниеТипов(МассивТипов);
	
	РеквизитДеревоПодарков 			= Новый РеквизитФормы("ДеревоПодарков", Новый ОписаниеТипов("ДеревоЗначений"),
		,НСтр("ru = 'Дерево подарков'"));
	РеквизитПредставление			= Новый РеквизитФормы("Представление", ОписаниеТиповСтрока, "ДеревоПодарков",
		 НСтр("ru = 'Представление'"));
	РеквизитНоменклатура			= Новый РеквизитФормы("Номенклатура", ОписаниеТиповНоменклатура,
		"ДеревоПодарков", НСтр("ru = 'Номенклатура'"));
	РеквизитХарактеристика			= Новый РеквизитФормы("Характеристика", ОписаниеТиповХарактеристика,
		"ДеревоПодарков", НСтр("ru = 'Характеристика'"));
	РеквизитСкидкаНаценка			= Новый РеквизитФормы("СкидкаНаценка", ОписаниеСкидкаНаценка, "ДеревоПодарков",
		НСтр("ru = 'Скидка/наценка'"));
	РеквизитСкидкаКоличество		= Новый РеквизитФормы("Количество", ОписаниеТиповЧисло, "ДеревоПодарков",
		НСтр("ru = 'Количество'"));
	РеквизитСкидкаЦена				= Новый РеквизитФормы("Цена", ОписаниеТиповЧисло, "ДеревоПодарков",
		НСтр("ru = 'Цена'"));
	РеквизитСкидкаСумма				= Новый РеквизитФормы("Сумма", ОписаниеТиповЧисло, "ДеревоПодарков",
		НСтр("ru = 'Сумма'"));
	РеквизитСтруктурнаяЕдиница		= Новый РеквизитФормы("СтруктурнаяЕдиница", ОписаниеСтруктурнаяЕдиница,
		"ДеревоПодарков", НСтр("ru = 'Склад'"));
	РеквизитКлючСвязи				= Новый РеквизитФормы("КлючСвязи", ОписаниеТиповЧисло, "ДеревоПодарков",
		НСтр("ru = 'КлючСвязи'"));
	РеквизитЕдиницаИзмерения		= Новый РеквизитФормы("ЕдиницаИзмерения", ОписаниеЕдиницаИзмерения,
		"ДеревоПодарков", НСтр("ru = 'КлючСвязи'"));
	РеквизитУровень 				= Новый РеквизитФормы("Уровень", ОписаниеТиповЧисло, "ДеревоПодарков",
		НСтр("ru = 'Уровень'"));
	
	ДобавляемыеРеквизиты.Добавить(РеквизитДеревоПодарков);
	ДобавляемыеРеквизиты.Добавить(РеквизитПредставление);
	ДобавляемыеРеквизиты.Добавить(РеквизитНоменклатура);
	ДобавляемыеРеквизиты.Добавить(РеквизитХарактеристика);
	ДобавляемыеРеквизиты.Добавить(РеквизитСкидкаНаценка);
	ДобавляемыеРеквизиты.Добавить(РеквизитСкидкаКоличество);
	ДобавляемыеРеквизиты.Добавить(РеквизитСкидкаЦена);
	ДобавляемыеРеквизиты.Добавить(РеквизитСкидкаСумма);
	ДобавляемыеРеквизиты.Добавить(РеквизитСтруктурнаяЕдиница);
	ДобавляемыеРеквизиты.Добавить(РеквизитКлючСвязи);
	ДобавляемыеРеквизиты.Добавить(РеквизитЕдиницаИзмерения);
	ДобавляемыеРеквизиты.Добавить(РеквизитУровень);
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	ДеревоПодарков = ЭлементыФормы.Добавить("ДеревоПодарков", Тип("ТаблицаФормы"), ЭлементыФормы.ГруппаДеревоПодарки);
	ДеревоПодарков.Отображение = ОтображениеТаблицы.Дерево;
	ДеревоПодарков.ПутьКДанным = "ДеревоПодарков";
	ДеревоПодарков.КоманднаяПанель.Видимость = Ложь;
	ДеревоПодарков.ГоризонтальныеЛинии = Ложь;
	ДеревоПодарков.ВертикальныеЛинии = Ложь;
	ДеревоПодарков.Шапка = Ложь;
	ДеревоПодарков.НачальноеОтображениеДерева = НачальноеОтображениеДерева.РаскрыватьВсеУровни;
	ДеревоПодарков.УстановитьДействие("Выбор", "Подключаемый_ВыборПодарка");

	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоПодарковПредставление", Тип("ПолеФормы"), ДеревоПодарков);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоПодарков.Представление";
	НовыйЭлементДерева.ТолькоПросмотр = Истина;
	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоПодарковКоличество", Тип("ПолеФормы"), ДеревоПодарков);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоПодарков.Количество";
	НовыйЭлементДерева.ТолькоПросмотр = Истина;
	
	НовыйЭлементДерева = ЭлементыФормы.Добавить("ДеревоПодарковУровень", Тип("ПолеФормы"), ДеревоПодарков);
	НовыйЭлементДерева.Вид = ВидПоляФормы.ПолеКартинки;
	НовыйЭлементДерева.ПутьКДанным = "ДеревоПодарков.Уровень";
	НовыйЭлементДерева.Видимость = Ложь;
	
	
	Элемент = Форма.УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементыФормы.ДеревоПодарков.Имя);
	ЭлементОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ЭлементыФормы.ДеревоПодарковУровень.ПутьКДанным);
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = 0;
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.ШрифтОбычныйПолужирныйРМК);
	
КонецПроцедуры

Процедура УстановитьОбозначение(СтруктураНастроек, СтрокаСкидки)
	ИмяОбозначения = "РМКОбозначение";
	Если СтруктураНастроек.РучнаяСкидка Тогда
		ИмяОбозначения = ИмяОбозначения + "Ручные";
	ИначеЕсли СтруктураНастроек.УправляемаяСкидка
		И СтруктураНастроек.Подарок Тогда
		ИмяОбозначения = ИмяОбозначения + "УправляемыеСкидки";
	ИначеЕсли СтруктураНастроек.УправляемаяСкидка Тогда
		ИмяОбозначения = ИмяОбозначения + "Управляемые";
	ИначеЕсли СтруктураНастроек.Подарок Тогда
		ИмяОбозначения = ИмяОбозначения + "Подарок";
	Иначе
		ИмяОбозначения = ИмяОбозначения + "Автоматические";
	КонецЕсли;
	
	Если НЕ СтруктураНастроек.Подарок Тогда
		ИмяОбозначенияСкидки = "Скидки";
		Если СтрокаСкидки.Сумма < 0 Тогда
			ИмяОбозначенияСкидки = "Наценки";
		КонецЕсли;
	КонецЕсли;
	ИмяОбозначения = ИмяОбозначения + ИмяОбозначенияСкидки;
	СтрокаСкидки.Обозначение = БиблиотекаКартинок[ИмяОбозначения];
КонецПроцедуры

Процедура ПреобразоватьКлючСвязиВСтроку(ТаблицаТоваров) Экспорт
	Если Не ТипЗнч(ТаблицаТоваров) = Тип("ТаблицаЗначений") Тогда
		Возврат;
	КонецЕсли;
	
	КолонкаКлючСвязи = ТаблицаТоваров.Колонки.Найти("КлючСвязи");
	Если КолонкаКлючСвязи <> Неопределено И НЕ КолонкаКлючСвязи.ТипЗначения.СодержитТип(Тип("Строка")) Тогда
		КлючиСвязи = ТаблицаТоваров.ВыгрузитьКолонку("КлючСвязи");
		ТаблицаТоваров.Колонки.Удалить("КлючСвязи");
		ТаблицаТоваров.Колонки.Добавить("КлючСвязи", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(36)));
		Для инд = 0 по ТаблицаТоваров.Количество()-1 Цикл
			ТаблицаТоваров[инд].КлючСвязи = XMLСтрока(КлючиСвязи[инд]);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

