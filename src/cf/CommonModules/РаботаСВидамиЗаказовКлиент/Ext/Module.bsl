
#Область СлужебныйПрограммныйИнтерфейс

Процедура ПометитьНаУдалениеСостояние(Форма) Экспорт 
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	
	ВыделенныеСтроки = Элементы.ПорядокСостояний.ВыделенныеСтроки;
	
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьСостояниеПомеченноеНаУдаление = Ложь;
	ИдентификаторыУдаляемыхСтрок = Новый Массив;
	
	Для Каждого ИдентификаторСтроки Из ВыделенныеСтроки Цикл
		
		ТекущиеДанные = Объект.ПорядокСостояний.НайтиПоИдентификатору(ИдентификаторСтроки);
		
		Если ТекущиеДанные = Неопределено Или Не ЗначениеЗаполнено(ТекущиеДанные.Состояние) Тогда
			Продолжить;
		КонецЕсли;
		
		ИдентификаторыУдаляемыхСтрок.Добавить(ИдентификаторСтроки);
		
		Если ТекущиеДанные.ПометкаУдаления Тогда
			ЕстьСостояниеПомеченноеНаУдаление = Истина;
			Прервать;
		КонецЕсли; 
		
	КонецЦикла;
	
	СтруктураСостояний = Новый Структура();
	СтруктураСостояний.Вставить("ВыделенныеСтроки", ИдентификаторыУдаляемыхСтрок);
	СтруктураСостояний.Вставить("ТаблицаСостояний", Объект.ПорядокСостояний);
	СтруктураСостояний.Вставить("ПометкаУдаления", НЕ ЕстьСостояниеПомеченноеНаУдаление);
	
	Если ИдентификаторыУдаляемыхСтрок.Количество() = 1 Тогда
		ТекущиеДанные = Объект.ПорядокСостояний.НайтиПоИдентификатору(ИдентификаторыУдаляемыхСтрок[0]);
		ТекстВопроса = ?(ЕстьСостояниеПомеченноеНаУдаление, СтрШаблон(НСтр("ru='Снять с ""%1"" пометку удаления?'"), ТекущиеДанные.Состояние), 
		СтрШаблон(НСтр("ru='Пометить ""%1"" на удаление?'"), ТекущиеДанные.Состояние));
	Иначе
		ТекстВопроса = ?(ЕстьСостояниеПомеченноеНаУдаление, НСтр("ru='Снять с выделенных элементов пометку удаления?'"), 
		НСтр("ru='Пометить выделенные элементы на удаление?'"));
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УстановитьПометкуНаУдалениеКлиент", РаботаСВидамиЗаказовКлиент, СтруктураСостояний);
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры 

Процедура УстановитьПометкуНаУдалениеКлиент(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДополнительныеПараметры) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	УдаляемыеСостояния = Новый Массив;
	ИдентификаторыУдаляемыхСтрок = ДополнительныеПараметры.ВыделенныеСтроки;
	ПометкаУдаления = ДополнительныеПараметры.ПометкаУдаления;
	
	Для Каждого Идентификатор ИЗ ИдентификаторыУдаляемыхСтрок Цикл 
		ТекущиеДанные = ДополнительныеПараметры.ТаблицаСостояний.НайтиПоИдентификатору(Идентификатор);
		УдаляемоеСостояние = Новый Структура();
		УдаляемоеСостояние.Вставить("Состояние", ТекущиеДанные.Состояние);
		УдаляемоеСостояние.Вставить("ПометкаУдаления", ТекущиеДанные.ПометкаУдаления);
		УдаляемыеСостояния.Добавить(УдаляемоеСостояние);
	КонецЦикла;
	
	РаботаСВидамиЗаказовВызовСервера.ПометитьНаУдалениеСостоянияНаСервере(УдаляемыеСостояния, 
		ПометкаУдаления);
		
	Для Каждого УдаляемоеСостояние Из УдаляемыеСостояния Цикл
		НайденноеСостояние = ДополнительныеПараметры.ТаблицаСостояний.НайтиСтроки(Новый Структура("Состояние", УдаляемоеСостояние.Состояние));
		Для Каждого Состояние Из НайденноеСостояние Цикл
			Состояние.ПометкаУдаления = УдаляемоеСостояние.ПометкаУдаления;
			Состояние.Изменено = Истина;
		КонецЦикла;
	КонецЦикла;
	
	ТекстОповещения = ?(ПометкаУдаления, НСтр("ru = 'Пометка удаления'"), НСтр("ru = 'Пометка удаления снята'"));
	Если УдаляемыеСостояния.Количество() = 1 Тогда
		ПоказатьОповещениеПользователя(
		ТекстОповещения,
		,
		УдаляемыеСостояния[0].Состояние,
		БиблиотекаКартинок.Информация32);
	Иначе
		ПоказатьОповещениеПользователя(
		СтрШаблон("%1 (%2)", ТекстОповещения, УдаляемоеСостояние.Количество()),
		,
		НСтр("ru = 'Состояния заказов'"),
		БиблиотекаКартинок.Информация32);
	КонецЕсли;
	
КонецПроцедуры

#Область СозданиеНовыхОбъектовПриВводе

Процедура СостояниеАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь; 
	
	Если НЕ ПараметрыПолученияДанных.Свойство("Автоподбор") Тогда 
		ПараметрыПолученияДанных.Вставить("Автоподбор", Истина); 
	КонецЕсли; 
	
	Если НЕ ПараметрыПолученияДанных.Свойство("ВыборИзВидаЗаказа") Тогда 
		ПараметрыПолученияДанных.Вставить("ВыборИзВидаЗаказа", Истина); 
	КонецЕсли;
	
	ПараметрыПолученияДанных.Вставить("ОтображатьСостоянияЗаявок");
	
	ДанныеВыбора = РаботаСВидамиЗаказовВызовСервера.ДанныеВыбораСостояния(ПараметрыПолученияДанных, Ложь); 
	
КонецПроцедуры 

Процедура НачалоВыбораЦветаИзПорядкаСостояний(Форма, Свойство, СтандартнаяОбработка = Ложь) Экспорт 
	
	ОписаниеОповещения = Новый ОписаниеОповещения(
		"НачалоВыбораЦветаИзПорядкаСостоянийФрагмент", Форма.ЭтотОбъект, Свойство);
	
	ПараметрыОткрытияФормы = Новый Структура; 
	
	ДанныеТекущейСтроки = Форма.Элементы.ПорядокСостояний.ТекущиеДанные; 
	Если ДанныеТекущейСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ВыбранноеСостояние = ДанныеТекущейСтроки.Состояние;
	СтандартнаяОбработка = Ложь;
	
	Если ВыбранноеСостояние <> ПредопределенноеЗначение("Справочник.СостоянияЗаказовПокупателей.ПустаяСсылка") И 
		ВыбранноеСостояние <> ПредопределенноеЗначение("Справочник.СостоянияЗаказНарядов.ПустаяСсылка") Тогда
		ПараметрыОткрытияФормы.Вставить("Цвет", ДанныеТекущейСтроки[Свойство]);
	КонецЕсли;
		
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораЦветаУНФ", ПараметрыОткрытияФормы, ЭтотОбъект, , , , ОписаниеОповещения);
	
КонецПроцедуры 

