#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// См. СтандартныеПодсистемыКлиент.ПриПолученииСерверногоОповещения.
//
Процедура ПриПолученииСерверногоОповещения(ИмяОповещения, Результат) Экспорт
	
	Если ИмяОповещения <> ТарификацияБизнесКлиентСервер.ИмяСерверногоОповещения() Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеПриложения = Результат.ОписаниеПриложения;
	Если Результат.ПриложениеБылоПодключено Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ОписаниеПриложения", ОписаниеПриложения);
		ОткрытьФорму("Обработка.БизнесПриложения.Форма.ОповещениеОНовомПриложении", ПараметрыФормы);
		Возврат;
		
	КонецЕсли;
	
	ДополнительныеДанные = ТарификацияБизнесКлиентСервер.ДополнительныеДанныеПриложения(ОписаниеПриложения.Имя);
	Если ДополнительныеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПоказатьОповещениеПользователя(
	СтрШаблон(НСтр("ru = 'Отключено приложение ""%1""'"), ОписаниеПриложения.Синоним), ,
	НСтр("ru = 'Функции этого приложения станут недоступны'"),
	ДополнительныеДанные.Картинка,
	СтатусОповещенияПользователя.Важное);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти