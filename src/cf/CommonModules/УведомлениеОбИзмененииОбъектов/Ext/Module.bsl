
////////////////////////////////////////////////////////////////////////////////
// Серверные процедуры работы с уведомлениями об изменении объектов (используется СистемаВзаимодействия)
//
// Для новых объектов и при изменении из списка, изменения в СистемаВзаимодействия записываются 
// регламентным заданием (отложенно)
// Для изменений в форме объектов, изменения отправляются фоновым заданием (сразу)
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Записывает данные об изменениях объекта по подписке на событие.
// См. ПодпискаНаСобытие.УведомленияОбИзмененииОбъектовПередЗаписью
// 
// Параметры:
//  Источник - ДокументОбъект - Объект, для которого будут записаны данные уведомления
//  Отказ - Булево - Отказ записи
//  РежимЗаписи - РежимЗаписиДокумента - Режим записи объекта
//  РежимПроведения - РежимПроведенияДокумента - Режим проведения объекта
Процедура УведомленияОбИзмененииОбъектовПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт

	Если Отказ Или Не ОтправкаУведомленийРазрешена(Источник) Тогда
		Возврат;
	КонецЕсли;	
	
	ОтправлятьУведомления = Истина;
	
	УведомлениеОбИзмененииОбъектовПереопределяемый.ОбсужденияПередЗаписью(Источник, РежимЗаписи, РежимПроведения, 
		ОтправлятьУведомления);
	
	Если ОтправлятьУведомления <> Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЗадачаСотрудника") Тогда
		ПередЗаписьюЗадачиСотрудника(Источник, Отказ, РежимЗаписи, РежимПроведения);	
	КонецЕсли;
	
КонецПроцедуры

// Записывает данные об изменениях объекта по подписке на событие.
// См. ПодпискаНаСобытие.УведомленияОбИзмененииОбъектовПриЗаписи
// 
// Параметры:
//  Источник			   - ДокументОбъект- Объект, для которого будут записаны данные уведомления
//  Отказ				   - Булево - Отказ записи
Процедура УведомленияОбИзмененииОбъектовПриЗаписи(Источник, Отказ) Экспорт

	Если Отказ Или Не ОтправкаУведомленийРазрешена(Источник) Тогда
		Возврат;
	КонецЕсли;	
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЗадачаСотрудника") Тогда
		ПриЗаписиЗадачиСотрудника(Источник);	
	КонецЕсли;

КонецПроцедуры

// Вызывается после записи на сервере из формы документа
// 
// Параметры:
//  ТекущийОбъект - ДокументОбъект - Текущий объект
Процедура ПослеЗаписиНаСервере(ТекущийОбъект) Экспорт
	
	Если Не ОтправкаУведомленийРазрешена(ТекущийОбъект) Тогда
		Возврат;
	КонецЕсли;

	НайденыНеотправленныеСообщения = 
		Справочники.НеотправленныеСообщенияСистемыВзаимодействия.ЕстьНеотправленныеСообщенияПоОбъекту(
		ТекущийОбъект.Ссылка);
		
	Если Не НайденыНеотправленныеСообщения Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, 
		"ОбсужденияУНФ.ЗаписатьОтложенныеСообщенияВСистемуВзаимодействия", ТекущийОбъект.Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОтправкаУведомленийРазрешена(Объект)
	
	Если Объект.ПометкаУдаления Или Объект.ОбменДанными.Загрузка 
		Или Не ПолучитьФункциональнуюОпцию("ИспользоватьЗадачиСотрудников") Тогда
		
		Возврат Ложь;
		
	КонецЕсли;
		
	ИнформационнаяБазаЗарегистрирована = СистемаВзаимодействия.ИнформационнаяБазаЗарегистрирована();
	
	ЭтоГрупповаяЗагрузкаДанных = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Объект.ДополнительныеСвойства,
		"ГрупповаяЗагрузкаДанных", Ложь);
	
	ЭтоЗаписьАссистентом = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Объект.ДополнительныеСвойства,
		"ЭтоЗаписьАссистентом", Ложь);
	
	Результат = ИнформационнаяБазаЗарегистрирована И Не ЭтоГрупповаяЗагрузкаДанных И Не ЭтоЗаписьАссистентом; 

	Возврат Результат;
	
КонецФункции

Функция ПараметрыУведомления(Источник, Автор)
	
	ПараметрыУведомления = Новый Структура;
	ПараметрыУведомления.Вставить("Автор", 		Автор); 
	ПараметрыУведомления.Вставить("Получатели", Новый Массив); 
	ПараметрыУведомления.Вставить("Объект", 	Источник.Ссылка); 
	ПараметрыУведомления.Вставить("Текст", 		"");
	ПараметрыУведомления.Вставить("Дата",		ТекущаяДатаСеанса());
	
	Возврат ПараметрыУведомления;
	
КонецФункции

Процедура СоздатьСообщенияСистемыВзаимодействия(ПараметрыСообщений, ИспользоватьФорматированныйТекст = Ложь)

	Для Каждого ПараметрыНовогоСообщения Из ПараметрыСообщений Цикл
		
		Если Не ДанныеСообщенияЗаполнены(ПараметрыНовогоСообщения) Тогда
			Продолжить;
		КонецЕсли;
	
		ДанныеСообщения = ОбсужденияУНФ.НовыйДанныеСообщения();
		ЗаполнитьЗначенияСвойств(ДанныеСообщения, ПараметрыНовогоСообщения);
		
		ОбсужденияУНФ.СоздатьСообщениеОтложенно(ДанныеСообщения);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДанныеСообщенияЗаполнены(ПараметрыНовогоСообщения)

	Для Каждого КлючИЗначение Из ПараметрыНовогоСообщения Цикл
		Если Не ЗначениеЗаполнено(КлючИЗначение.Значение) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

#Область ЗадачаСотрудника

Процедура ПередЗаписьюЗадачиСотрудника(Источник, Отказ, РежимЗаписи, РежимПроведения)
	
	ДанныеПредыдущегоСостояния = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Источник.Ссылка, 
		"Выполнена, Ответственный, ПометкаУдаления");
	
	УдаленоДоЗаписи = ДанныеПредыдущегоСостояния.ПометкаУдаления;
	Если УдаленоДоЗаписи = Неопределено Тогда
		УдаленоДоЗаписи = Ложь;
	КонецЕсли;
	
	ВыполненоДоЗаписи = ДанныеПредыдущегоСостояния.Выполнена;
	Если ВыполненоДоЗаписи = Неопределено Тогда
		ВыполненоДоЗаписи = Ложь;
	КонецЕсли;

	ПредыдущийОтветственный = ДанныеПредыдущегоСостояния.Ответственный;

	Источник.ДополнительныеСвойства.Вставить("УведомленияОбИзменении", Новый Структура);
	Источник.ДополнительныеСвойства.УведомленияОбИзменении.Вставить("ЭтоНовый", 				Источник.ЭтоНовый());
	Источник.ДополнительныеСвойства.УведомленияОбИзменении.Вставить("ВыполненоДоЗаписи", 		ВыполненоДоЗаписи);
	Источник.ДополнительныеСвойства.УведомленияОбИзменении.Вставить("УдаленоДоЗаписи", 			УдаленоДоЗаписи);
	Источник.ДополнительныеСвойства.УведомленияОбИзменении.Вставить("ПредыдущийОтветственный", 	ПредыдущийОтветственный);
		
КонецПроцедуры

Процедура ПриЗаписиЗадачиСотрудника(Источник)
		
	ПараметрыУведомлений = ПараметрыУведомленийЗадачиСотрудника(Источник);
	СоздатьСообщенияСистемыВзаимодействия(ПараметрыУведомлений, Истина);
	
КонецПроцедуры

Функция ПараметрыУведомленийЗадачиСотрудника(Источник)

	ПараметрыСообщений = Новый Массив;

	УведомленияОбИзменении = Источник.ДополнительныеСвойства.УведомленияОбИзменении;
	 	 
	ЭтоНоваяЗадача 				= УведомленияОбИзменении.ЭтоНовый;
	ЗадачаВыполненаРанее 		= УведомленияОбИзменении.ВыполненоДоЗаписи;
	ПредыдущийОтветственный		= УведомленияОбИзменении.ПредыдущийОтветственный; 
	УдаленоДоЗаписи				= УведомленияОбИзменении.УдаленоДоЗаписи;
	
	ЗадачаВыполнена 			= Источник.Выполнена И Не ЗадачаВыполненаРанее;
	ИзмененОтветственный 		= Источник.Ответственный <> ПредыдущийОтветственный;
	СозданаВыполненнаяЗадача 	= ЭтоНоваяЗадача И Источник.Выполнена; 
	ИзмененаПометкаУдаления 	= УдаленоДоЗаписи <> Источник.ПометкаУдаления;
	
	ОтправкаУведомленияЗапрещена = Источник.ПометкаУдаления Или ИзмененаПометкаУдаления Или СозданаВыполненнаяЗадача 
		Или ЗадачаВыполненаРанее;
		
	Если ОтправкаУведомленияЗапрещена Тогда
		Возврат ПараметрыСообщений;
	КонецЕсли;
	
	АвторизованныйПользователь = Пользователи.АвторизованныйПользователь();
	
	ШаблоныУведомлений = ШаблоныУведомленийЗадачиСотрудника(Источник, ЭтоНоваяЗадача);
	
	Если ЭтоНоваяЗадача Или ИзмененОтветственный Тогда
		
		ПараметрыСообщения = ПараметрыУведомления(Источник, АвторизованныйПользователь);
		ПараметрыСообщения.Получатели 	= СформироватьПолучателейОтветственногоЗадачиСотрудника(Источник.Ответственный);
		ПараметрыСообщения.Текст 		= ШаблоныУведомлений.НоваяЗадача;

		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ПараметрыСообщения.Получатели,
				АвторизованныйПользователь);			

		Если ПараметрыСообщения.Получатели.Количество() Тогда
			ПараметрыСообщений.Добавить(ПараметрыСообщения);
		КонецЕсли;
						
	ИначеЕсли ЗадачаВыполнена Тогда
		
		Если Не ТребуетсяУведомлениеОВыполненииЗадачиСотрудника(Источник) Тогда
			Возврат ПараметрыСообщений;
		КонецЕсли;
		
		ПараметрыСообщения = ПараметрыУведомления(Источник, АвторизованныйПользователь);
		ПараметрыСообщения.Получатели 	= ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Источник.Автор);
		ПараметрыСообщения.Текст 		= ШаблоныУведомлений.ЗадачаВыполнена;
				
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ПараметрыСообщения.Получатели,
				АвторизованныйПользователь);	
		
		ПараметрыСообщений.Добавить(ПараметрыСообщения);
		
	Иначе
		
		Возврат ПараметрыСообщений;
		
	КонецЕсли;
	
	Возврат ПараметрыСообщений;
	
КонецФункции

Функция ШаблоныУведомленийЗадачиСотрудника(Объект, ЭтоНоваяЗадача)
	
	// Шаблон "НоваяЗадача"
	
	ПредставлениеДаты = Формат(Объект.ДатаНачала, "ДФ=dd.MM.yyyy; ДП=-;"); 
	ПредставлениеВремени = Формат(Объект.ДатаНачала, "ДФ=HH:mm; ДП=-;");
		
	Если НачалоДня(ТекущаяДатаСеанса()) = НачалоДня(Объект.ДатаНачала) Тогда
		
		ШаблонСтроки = НСтр("ru = 'Вам назначена задача.
			|Срок: <span style=""color: ИнформационныйЦентрКрасныйЦвет""><b>сегодня</b></span>'");   
		
		НоваяЗадача = СтроковыеФункции.ФорматированнаяСтрока(ШаблонСтроки);
				
	ИначеЕсли Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		
		ШаблонСтроки = НСтр("ru = 'Вам назначена задача.
			|Срок: <b>не установлен</b>'"); 
		
		НоваяЗадача = СтроковыеФункции.ФорматированнаяСтрока(ШаблонСтроки); 
		
	ИначеЕсли ЗначениеЗаполнено(Объект.ДатаНачала) И Объект.ВесьДень Тогда
		
		ШаблонСтроки = НСтр("ru = 'Вам назначена задача.
			|Срок: <b>%1</b> (весь день)'");		
		НоваяЗадача = СтроковыеФункции.ФорматированнаяСтрока(ШаблонСтроки, ПредставлениеДаты); 		
		
	Иначе
		
		ШаблонСтроки = НСтр("ru = 'Вам назначена задача.
			|Срок: <b>%1</b> в %2'"); 
		
		НоваяЗадача = СтроковыеФункции.ФорматированнаяСтрока(ШаблонСтроки, ПредставлениеДаты, ПредставлениеВремени); 
		
	КонецЕсли;

		
	// Шаблон "ЗадачаВыполнена"
		
	Если Не ПустаяСтрока(Объект.Результат) Тогда
		
		ШаблонСтроки = НСтр("ru = 'Задача выполнена.
				|Результат: <b>%1</b></span>'");
		
		ЗадачаВыполнена = СтроковыеФункции.ФорматированнаяСтрока(ШаблонСтроки, СокрЛП(Объект.Результат));
		
	Иначе
		
		ШаблонСтроки = НСтр("ru = 'Задача выполнена.'");
		ЗадачаВыполнена = СтроковыеФункции.ФорматированнаяСтрока(ШаблонСтроки);
		
	КонецЕсли;
		
	ШаблоныУведомлений = Новый Структура;
	ШаблоныУведомлений.Вставить("НоваяЗадача", 			НоваяЗадача);
	ШаблоныУведомлений.Вставить("ЗадачаВыполнена", 		ЗадачаВыполнена);
	
	Возврат ШаблоныУведомлений;	
		
КонецФункции

Функция СформироватьПолучателейОтветственногоЗадачиСотрудника(Ответственный)
	
	Получатели = Новый Массив;
	
	Если Не ЗначениеЗаполнено(Ответственный) Тогда
		Возврат Получатели;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиПользователя.Пользователь КАК Пользователь,
		|	СотрудникиПользователя.Пользователь.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ
		|ИЗ
		|	РегистрСведений.СотрудникиПользователя КАК СотрудникиПользователя
		|ГДЕ
		|	СотрудникиПользователя.Сотрудник = &Ответственный
		|	И НЕ СотрудникиПользователя.Пользователь.Недействителен
		|	И НЕ СотрудникиПользователя.Пользователь.ПометкаУдаления";

	Запрос.УстановитьПараметр("Ответственный", Ответственный);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Получатели;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если ТипЗнч(Выборка.ИдентификаторПользователяИБ) <> Тип("УникальныйИдентификатор") Тогда
			Продолжить;
		КонецЕсли;
		
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(
			Выборка.ИдентификаторПользователяИБ);
			
		Если ПользовательИБ = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ОтправлятьУведомление = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("ПараметрыУведомленийЗадачиСотрудника", 
			"УведомлятьОНовыхЗадачахСотрудника", Истина, , ПользовательИБ.Имя);
			
		Если ОтправлятьУведомление Тогда
			Получатели.Добавить(Выборка.Пользователь);
		КонецЕсли;
		
	КонецЦикла; 
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Получатели;
	
КонецФункции

Функция ТребуетсяУведомлениеОВыполненииЗадачиСотрудника(Объект)
	
	УстановитьПривилегированныйРежим(Истина);
			
	ПользовательИБ = Пользователи.НайтиПоСсылке(Объект.Автор);		
	ОтправитьУведомление = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("ПараметрыУведомленийЗадачиСотрудника", 
		"УведомлятьОВыполненииЗадачиСотрудника", Истина, , ПользовательИБ.Имя);

	УстановитьПривилегированныйРежим(Ложь);
			
	Возврат ОтправитьУведомление;
	
КонецФункции

#КонецОбласти

#КонецОбласти
