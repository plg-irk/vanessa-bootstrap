
#Область ПрограммныйИнтерфейс

// Обработчик создания нового сообщения WhatsApp в панели контактной информации.
// Выполняет открытие формы создания нового сообщения.
//
// Параметры:
//  КонтактнаяИнформация - Структура - информация о контактном телефоне контрагнета.
//  ДополнительныеПараметры - Структура
//
Процедура ОбработчикДействияНаписатьВМессенджерWhatsApp(КонтактнаяИнформация, ДополнительныеПараметры) Экспорт
	
	НомерТелефона = УправлениеКонтактнойИнформациейУНФКлиентСервер.НомерТелефонаВМеждународномФормате(
		КонтактнаяИнформация.Представление);
		
	Если ПустаяСтрока(НомерТелефона) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru='Не указан номер телефона'"));
		Возврат;
	КонецЕсли;
	
	ДопустимаяДлинаНомераТелефона = 12;
	Если СтрДлина(НомерТелефона) <> ДопустимаяДлинаНомераТелефона Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru='Неверный формат номера телефона.'"));
		Возврат;
	КонецЕсли;
	
	НомерТелефона = СтрЗаменить(НомерТелефона, "+", "");
	
	ВНомереТолькоЦифры = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(НомерТелефона);
	Если Не ВНомереТолькоЦифры Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru='Неверный формат номера телефона.'"));
		Возврат;		
	КонецЕсли;
	
	ОткрытьФормуСообщенияWhatsAppИзПанелиКИ(НомерТелефона);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ОбработкаВыбораШаблонаСообщенияСистемыВзаимодействия(Обсуждение, СтандартнаяОбработка) Экспорт
	
	СтандартнаяОбработка = Ложь;
	ОткрытьФормуОтправкиСообщенияИзОбсуждения(Обсуждение);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОткрытьФормуОтправкиСообщенияИзОбсуждения(Обсуждение)
	
	ПараметрыФормы = Новый Структура("ИдентификаторОбсуждения, ФормаОткрытаИзОбсуждения", Обсуждение, Истина);
	ОткрытьФорму("Обработка.Мессенджеры.Форма.ФормаяНовогоСообщенияWhatsApp", ПараметрыФормы);
	
КонецПроцедуры

Процедура ОткрытьФормуСообщенияWhatsAppИзПанелиКИ(НомерТелефона)
		
	ПараметрыОткрытияФормы = ПараметрыОткрытияФормыНовогоСообщения();	
	ПараметрыОткрытияФормы.ВнешнийИдентификатор = НомерТелефона;

	ДанныеИнтеграцииСАбонентом = МессенджерыWhatsAppВызовСервера.ДанныеИнтеграцииWhatsAppСАбонентом(НомерТелефона);
	Если ДанныеИнтеграцииСАбонентом.ОбнаруженаОшибка Тогда
		
		Если Не ДанныеИнтеграцииСАбонентом.ОбсужденияДоступны Тогда
			ТекстОшибки = ТекстОшибкиОбсужденияНеПодключены();
		ИначеЕсли Не ДанныеИнтеграцииСАбонентом.ИнтеграцияWhatsAppДоступна Тогда 
			ТекстОшибки = ТекстОшибкиТипаИнтеграции();
		ИначеЕсли Не ДанныеИнтеграцииСАбонентом.ИнтеграцияWhatsAppНастроена Тогда
			ТекстОшибки = ТекстОшибкиИнтеграцииWhatsApp();
		ИначеЕсли Не ДанныеИнтеграцииСАбонентом.ДоступныИнтеграцииСПользователем Тогда
			ТекстОшибки = ТекстОшибкиДоступа();
		Иначе
			ТекстОшибки = ТекстНеизвестнойОшибки();
		КонецЕсли;

		ПараметрыОткрытияФормы.ОбнаруженаОшибка = Истина;
		ПараметрыОткрытияФормы.ТекстОшибки = ТекстОшибки;
			
		ОткрытьФормуНовогоСообщенияWhatsApp(ПараметрыОткрытияФормы, ДанныеИнтеграцииСАбонентом);
		Возврат;

	КонецЕсли;
	
	Если ДанныеИнтеграцииСАбонентом.Интеграции.Количество() = 1 Тогда
		
		ПараметрыОткрытияФормы.ИдентификаторИнтеграции = ДанныеИнтеграцииСАбонентом.Интеграции[0].Значение;
		ПараметрыОткрытияФормы.ИдентификаторОбсуждения = ДанныеИнтеграцииСАбонентом.Обсуждение;
		
		ОткрытьФормуНовогоСообщенияWhatsApp(ПараметрыОткрытияФормы, ДанныеИнтеграцииСАбонентом);
		
	ИначеЕсли ДанныеИнтеграцииСАбонентом.Интеграции.Количество() > 1 Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораИнтеграции", ЭтотОбъект,
			ДанныеИнтеграцииСАбонентом);
		
		ДанныеИнтеграцииСАбонентом.Интеграции.ПоказатьВыборЭлемента(ОписаниеОповещения, 
			НСтр("ru='Выберите интеграцию:'"));

	Иначе
		
		Возврат;
		
	КонецЕсли;	
		
КонецПроцедуры

Процедура ПослеВыбораИнтеграции(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторИнтеграции = Результат.Значение;
	
	Если ДополнительныеПараметры.Обсуждение <> Неопределено Тогда
		ИдентификаторОбсуждения = ДополнительныеПараметры.Обсуждение;
	Иначе
		ИдентификаторОбсуждения = МессенджерыВызовСервера.ОбсуждениеСАбонентомИнтеграцииПоЗаголовку(
			ИдентификаторИнтеграции, ДополнительныеПараметры.ВнешнийИдентификатор);
	КонецЕсли;
		
	ПараметрыОткрытияФормы = ПараметрыОткрытияФормыНовогоСообщения();	
	ПараметрыОткрытияФормы.ВнешнийИдентификатор = ДополнительныеПараметры.ВнешнийИдентификатор;
	ПараметрыОткрытияФормы.ИдентификаторИнтеграции = ИдентификаторИнтеграции;
	ПараметрыОткрытияФормы.ИдентификаторОбсуждения = ИдентификаторОбсуждения;
	
	ОткрытьФормуНовогоСообщенияWhatsApp(ПараметрыОткрытияФормы, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ОткрытьФормуНовогоСообщенияWhatsApp(ПараметрыОткрытия, ДанныеИнтеграцииСАбонентом)

	ИнтеграцииСПользователем = ДанныеИнтеграцииСАбонентом.ИнтеграцииСПользователем;
	ПользовательОтсутствуетВИнтеграции =
		ИнтеграцииСПользователем.Найти(ПараметрыОткрытия.ИдентификаторИнтеграции) = Неопределено;
	
	Если Не ДанныеИнтеграцииСАбонентом.ОбнаруженаОшибка И ПользовательОтсутствуетВИнтеграции Тогда
		ПараметрыОткрытия.ОбнаруженаОшибка = Истина;
		ПараметрыОткрытия.ТекстОшибки = ТекстОшибкиДоступа();
	КонецЕсли;
	
	ОткрытьФорму("Обработка.Мессенджеры.Форма.ФормаяНовогоСообщенияWhatsApp", ПараметрыОткрытия);
	
КонецПроцедуры

Функция ПараметрыОткрытияФормыНовогоСообщения()
	
	ТекстОшибки = СтроковыеФункцииКлиент.ФорматированнаяСтрока("");
	ТипВнешнейСистемы = МессенджерыКлиентСервер.ТипВнешнийСистемыWhatsApp();
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ИдентификаторОбсуждения", Неопределено);
	ПараметрыОткрытия.Вставить("ВнешнийИдентификатор",    Неопределено);
	ПараметрыОткрытия.Вставить("ИдентификаторИнтеграции", Неопределено);	
	ПараметрыОткрытия.Вставить("ОбнаруженаОшибка",        Ложь);
	ПараметрыОткрытия.Вставить("ТекстОшибки",             ТекстОшибки);		
	ПараметрыОткрытия.Вставить("ТипВнешнейСистемы",       ТипВнешнейСистемы);		
	
	Возврат ПараметрыОткрытия;
	
КонецФункции

// Текст ошибки доступа для отображения в форме создания нового сообщения.
// 
// Возвращаемое значение:
//  ФорматированнаяСтрока
Функция ТекстОшибкиДоступа()
	
	ТекстОшибки = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		НСтр("ru='Пользователь отсутствует в списке для отправки и получения сообщений'"));
		
	Возврат ТекстОшибки;
	
КонецФункции

// Текст стандартной ошибки для отображения в форме создания нового сообщения.
// 
// Возвращаемое значение:
//  ФорматированнаяСтрока
Функция ТекстНеизвестнойОшибки()
	
	ТекстОшибки = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		НСтр("ru='Обнаружена ошибка'"));
		
	Возврат ТекстОшибки;
	
КонецФункции

// Текст ошибки подключения обсуждений для отображения в форме создания нового сообщения
// 
// Возвращаемое значение:
//  ФорматированнаяСтрока
Функция ТекстОшибкиОбсужденияНеПодключены()
	
	ТекстОшибки = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		 НСтр("ru='Обсуждения не подключены. <a href=""ПодключитьОбсуждения"">Подключить</a>'"));
		 
	Возврат ТекстОшибки;
	
КонецФункции

// Текст ошибки поддержки интеграции WhatsApp сервером, для отображения в форме создания нового сообщения
// 
// Возвращаемое значение:
//  ФорматированнаяСтрока
Функция ТекстОшибкиТипаИнтеграции()
	
	ТекстОшибки = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		 НСтр("ru='Сервер взаимодействия не поддерживает тип интеграции WhatsApp'"));
		 
	Возврат ТекстОшибки;
	
КонецФункции
// Текст ошибки наличия настроенных интеграций WhatsApp для отображения в форме создания нового сообщения
// 
// Возвращаемое значение:
//  ФорматированнаяСтрока
Функция ТекстОшибкиИнтеграцииWhatsApp()
	
	ТекстОшибки = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		 НСтр("ru='Интеграция с WhatsApp не настроена. <a href=""НастроитьИнтеграцию"">Настроить</a>'"));
		 
	Возврат ТекстОшибки;
		
КонецФункции

#КонецОбласти
