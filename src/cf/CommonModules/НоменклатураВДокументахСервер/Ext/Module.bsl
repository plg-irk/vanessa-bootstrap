	|		ПО ВТНоменклатура.Номенклатура = УправлениеЗапасами.Номенклатура
	|			И ВТНоменклатура.Характеристика = УправлениеЗапасами.Характеристика
	|ГДЕ
	|	УправлениеЗапасами.Организация = &Организация
	|	И УправлениеЗапасами.Склад = &Получатель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ОстаткиНаСкладеОтправительИПолучательИтог.ОстатокОтправитель, 0) КАК СвободноОтправитель,
	|	ЕСТЬNULL(ОстаткиНаСкладеОтправительИПолучательИтог.ОстатокПолучатель, 0) КАК СвободноПолучатель,
	|	ВТНоменклатура.Номенклатура КАК Номенклатура,
	|	ВТНоменклатура.Характеристика КАК Характеристика,
	|	ВТНоменклатура.Партия КАК Партия,
	|	ЕСТЬNULL(ОстаткиНаСкладеВсего.КоличествоОстаток, 0) КАК ОстатокВсего,
	|	ЗаказаноИтог.ДатаПоступления КАК ДатаПоступления,
	|	ЕСТЬNULL(ЗаказаноИтог.КоличествоДокументов, 0) КАК КоличествоДокументов,
	|	ВТНоменклатура.ЗаказПокупателя КАК ЗаказПокупателя,
	|	ЕСТЬNULL(УправлениеЗапасами.МаксимальныйУровеньЗапаса, 0) КАК МаксимальныйОстаток,
	|	ЕСТЬNULL(УправлениеЗапасами.МинимальныйУровеньЗапаса, 0) КАК МинимальныйОстаток,
	|	ЕСТЬNULL(ЗаказаноИтог.КПоступлению, 0) КАК КПоступлению,
	|	ЕСТЬNULL(НеОтгруженоПоПеремещению.НеОтгружено, 0) КАК НеОтгружено,
	|	ЕСТЬNULL(ОстатокПоЗаказамПолучатель.КоличествоДвижение, 0) КАК Заказано
	|ИЗ
	|	ВТНоменклатура КАК ВТНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиНаСкладеОтправительИПолучательИтог КАК ОстаткиНаСкладеОтправительИПолучательИтог
	|		ПО ВТНоменклатура.Номенклатура = ОстаткиНаСкладеОтправительИПолучательИтог.Номенклатура
	|			И ВТНоменклатура.Характеристика = ОстаткиНаСкладеОтправительИПолучательИтог.Характеристика
	|			И ВТНоменклатура.Партия = ОстаткиНаСкладеОтправительИПолучательИтог.Партия
	|			И ВТНоменклатура.Номенклатура = ОстаткиНаСкладеОтправительИПолучательИтог.Номенклатура
	|			И ВТНоменклатура.Характеристика = ОстаткиНаСкладеОтправительИПолучательИтог.Характеристика
	|			И ВТНоменклатура.Партия = ОстаткиНаСкладеОтправительИПолучательИтог.Партия
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗаказаноИтог КАК ЗаказаноИтог
	|		ПО ВТНоменклатура.Номенклатура = ЗаказаноИтог.Номенклатура
	|			И ВТНоменклатура.Характеристика = ЗаказаноИтог.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстатокПоЗаказамОтправитель КАК ОстатокПоЗаказамОтправитель
	|		ПО ВТНоменклатура.Номенклатура = ОстатокПоЗаказамОтправитель.Номенклатура
	|			И ВТНоменклатура.Характеристика = ОстатокПоЗаказамОтправитель.Характеристика
	|			И ВТНоменклатура.Партия = ОстатокПоЗаказамОтправитель.Партия
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстатокПоЗаказамПолучатель КАК ОстатокПоЗаказамПолучатель
	|		ПО ВТНоменклатура.Номенклатура = ОстатокПоЗаказамПолучатель.Номенклатура
	|			И ВТНоменклатура.Характеристика = ОстатокПоЗаказамПолучатель.Характеристика
	|			И ВТНоменклатура.Партия = ОстатокПоЗаказамПолучатель.Партия
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиНаСкладеВсего КАК ОстаткиНаСкладеВсего
	|		ПО ВТНоменклатура.Номенклатура = ОстаткиНаСкладеВсего.Номенклатура
	|			И ВТНоменклатура.Характеристика = ОстаткиНаСкладеВсего.Характеристика
	|			И ВТНоменклатура.Партия = ОстаткиНаСкладеВсего.Партия
	|		ЛЕВОЕ СОЕДИНЕНИЕ НеОтгруженоПоПеремещению КАК НеОтгруженоПоПеремещению
	|		ПО ВТНоменклатура.Номенклатура = НеОтгруженоПоПеремещению.Номенклатура
	|			И ВТНоменклатура.Характеристика = НеОтгруженоПоПеремещению.Характеристика
	|			И ВТНоменклатура.Партия = НеОтгруженоПоПеремещению.Партия
	|		ЛЕВОЕ СОЕДИНЕНИЕ УправлениеЗапасами КАК УправлениеЗапасами
	|		ПО ВТНоменклатура.Номенклатура = УправлениеЗапасами.Номенклатура
	|			И ВТНоменклатура.Характеристика = УправлениеЗапасами.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДвижениеДокумента КАК ДвижениеДокумента
	|		ПО ВТНоменклатура.Номенклатура = ДвижениеДокумента.Номенклатура
	|			И ВТНоменклатура.Характеристика = ДвижениеДокумента.Характеристика";
	
	
	Возврат ТекстЗапроса;
