	|	ЕСТЬNULL(ДвижениеДокументаПоРезерву.ОтгруженоРезерва, 0) + ЕСТЬNULL(ОстаткиРезервов.КоличествоОстаток, 0) КАК ВсегоРезерва,
	|	ЕСТЬNULL(ОстаткиНаСкладе.КоличествоОстаток, 0) КАК СвободныйОстаток,
