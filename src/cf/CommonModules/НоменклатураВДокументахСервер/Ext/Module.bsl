Функция МассивТиповДокументовПоИмениТабличнойЧасти(ИмяТабличнойЧасти)
	
	МассивТипов = Новый Массив;
	
	Если ИмяТабличнойЧасти = "Расходы" Тогда
		МассивТипов.Добавить(Тип("ДокументСсылка.АвансовыйОтчет"));
		МассивТипов.Добавить(Тип("ДокументСсылка.АктОРасхождениях"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ДополнительныеРасходы"));
		МассивТипов.Добавить(Тип("ДокументСсылка.КорректировкаПоступления"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ПриходнаяНакладная"));
	КонецЕсли;
	
	Если ИмяТабличнойЧасти = "Продукция" Тогда
		МассивТипов.Добавить(Тип("ДокументСсылка.ЗаказНаПроизводство"));
		МассивТипов.Добавить(Тип("ДокументСсылка.СборкаЗапасов"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ОтчетОПереработке"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ОтчетПереработчика"));
		МассивТипов.Добавить(Тип("ДокументСсылка.РаспределениеЗатрат"));
	КонецЕсли;
	
	Если ИмяТабличнойЧасти = "Отходы" Тогда
		МассивТипов.Добавить(Тип("ДокументСсылка.СборкаЗапасов"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ОтчетОПереработке"));
		МассивТипов.Добавить(Тип("ДокументСсылка.ОтчетПереработчика"));
	КонецЕсли;
	
	Если ИмяТабличнойЧасти = "РаспределениеЗапасов" Тогда
		МассивТипов.Добавить(Тип("ДокументСсылка.СборкаЗапасов"));
		МассивТипов.Добавить(Тип("ДокументСсылка.РаспределениеЗатрат"));
	КонецЕсли;
	
	Возврат МассивТипов;
	
КонецФункции

// Заполняет колонку "ОстатокОбщий" в документе Установка цен значениями по остаткам
//   
// Параметры:
//  СтрокиОбхода 	- ТаблицаЗначений, ДанныеФормыКоллекция - Строки для обхода
//  ТаблицаОстатков - ТаблицаЗначений 
Процедура ЗаполнитьКолонкуОстатокОбщийУстановкаЦен(СтрокиОбхода, ТаблицаОстатков)
	
	ОбходСУчетомХарактеристик = ПолучитьПризнакОбходаСтрокПоХарактеристикамУстановкаЦен(СтрокиОбхода);
	
	Если НЕ ОбходСУчетомХарактеристик Тогда
		ПараметрыОтбора = Новый Структура("Номенклатура");  
	Иначе
		ПараметрыОтбора = Новый Структура("Номенклатура, Характеристика"); 
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из СтрокиОбхода Цикл  
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.ЕдиницаИзмеренияШаблон) 
			Или ТипЗнч(СтрокаТаблицы.ЕдиницаИзмеренияШаблон) = Тип("СправочникСсылка.КлассификаторЕдиницИзмерения") Тогда
			КоэффициентЕдиницыИзмерения = 1;
		Иначе
			КоэффициентЕдиницыИзмерения = СтрокаТаблицы.ЕдиницаИзмеренияШаблон.Коэффициент;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.Номенклатура) 
			Или ТипЗнч(СтрокаТаблицы.Номенклатура) = Тип("Строка") Тогда 
			Продолжить; 
		КонецЕсли;
		
		ПараметрыОтбора.Номенклатура = СтрокаТаблицы.Номенклатура;
		
		Если ОбходСУчетомХарактеристик Тогда
			ПараметрыОтбора.Характеристика = СтрокаТаблицы.Характеристика;
		КонецЕсли;
		
		НайденныеСтрокиОстатки = ТаблицаОстатков.НайтиСтроки(ПараметрыОтбора); 	
		Если НайденныеСтрокиОстатки.Количество() > 0 Тогда
			СтрокаОстатка = НайденныеСтрокиОстатки[0]; 
		Иначе
			СтрокаОстатка = Неопределено;
		КонецЕсли; 
		
		Если СтрокаОстатка = Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
		ОстатокОбщийСКоэффициентом = Окр(СтрокаОстатка.ОстатокОбщий / КоэффициентЕдиницыИзмерения, 3); 
		
		СтрокаТаблицы.ОстатокОбщий = ОстатокОбщийСКоэффициентом; 
	КонецЦикла;    

КонецПроцедуры

// Возвращает признак необходимости обхода строк по характеристикам.
//
// Параметры:
//  СтрокиОбхода - ТаблицаЗначений, ДанныеФормыКоллекция - Строки для обхода
Функция ПолучитьПризнакОбходаСтрокПоХарактеристикамУстановкаЦен(СтрокиОбхода) 
	
	ИмяКолонкиПоиска = "Характеристика"; 
	
	Если ТипЗнч(СтрокиОбхода) = Тип("ДанныеФормыКоллекция") Тогда			
		ПризнакОбходаСтрок = СтрокиОбхода.Выгрузить().Колонки.Найти(ИмяКолонкиПоиска) <> Неопределено;		
	Иначе  	
	    ПризнакОбходаСтрок = СтрокиОбхода.Колонки.Найти(ИмяКолонкиПоиска) <> Неопределено; 		
	КонецЕсли;
	
	Возврат ПризнакОбходаСтрок;	
КонецФункции

// Возвращает массив строк для копирования
//
// Параметры:
//  ТаблицаПоискаСтрок 	- ТаблицаЗначений.
//  НоменклатураОтбора 	- Массив из СправочникСсылка.Номенклатура 
//
// Возвращаемое значение:
// 	Массив из СтрокаТаблицыЗначений
Функция СформироватьМассивСтрокДляКопированияУстановкаЦен(ТаблицаПоискаСтрок, НоменклатураОтбора) 
	
	МассивСтрокКопировать = Новый Массив; 
	
	Для Каждого ЭлементМассива Из НоменклатураОтбора Цикл 
		
		МассивНайденныхСтрок = ТаблицаПоискаСтрок.НайтиСтроки(Новый Структура("Номенклатура", ЭлементМассива));
		Если МассивНайденныхСтрок.Количество() > 0 Тогда 
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивСтрокКопировать, МассивНайденныхСтрок);
		КонецЕсли;  
		
	КонецЦикла;   
		
	Возврат МассивСтрокКопировать;
КонецФункции

Функция МассивСкладовСДоступнымиЯчейками()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницы.Ссылка КАК Ссылка,
	|	СтруктурныеЕдиницы.ОрдерныйСклад КАК ОрдерныйСклад,
	|	СтруктурныеЕдиницы.ТипСтруктурнойЕдиницы КАК ТипСтруктурнойЕдиницы
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ОрдерныйСклад
	|	И СтруктурныеЕдиницы.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)";

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ТекстЗапросаОстаткиУстановкаЦенНоменклатуры(ТекстЗапросаСХарактеристиками)
	
	Если ТекстЗапросаСХарактеристиками Тогда 
		
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыНаСкладахОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыНаСкладахОстатки.Характеристика КАК Характеристика,
		|	ЗапасыНаСкладахОстатки.КоличествоОстаток КАК ОстатокОбщий
		|ИЗ
		|	РегистрНакопления.ЗапасыНаСкладах.Остатки(
		|			,
		|			Номенклатура = &НоменклатураОтбора
		|				И Характеристика В (&МассивХарактеристик)
		|				И СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы В (ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад), ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница))) КАК ЗапасыНаСкладахОстатки"; 
		
	Иначе 
		
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВнешняяТаблица.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВтНоменклатура
		|ИЗ
		|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблица
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыНаСкладахОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыНаСкладахОстатки.КоличествоОстаток КАК ОстатокОбщий
		|ИЗ
		|	РегистрНакопления.ЗапасыНаСкладах.Остатки(, СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы В (ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад), ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница))) КАК ЗапасыНаСкладахОстатки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтНоменклатура КАК ВтНоменклатура
		|		ПО ЗапасыНаСкладахОстатки.Номенклатура = ВтНоменклатура.Номенклатура";
		
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции   

Функция ТекстЗапросаСписокСкладовОстаткиУстановкаЦенНоменклатуры(ИмяТаблицыДанныхФормы) 
		
	Если ИмяТаблицыДанныхФормы = "ТЧНоменклатура" Тогда 
		
		Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница КАК Склад,
		|	СУММА(ЗапасыНаСкладахОстатки.КоличествоОстаток) КАК КоличествоОстаток
		|ИЗ
		|	РегистрНакопления.ЗапасыНаСкладах.Остатки(
		|			,
		|			Номенклатура = &Номенклатура
		|				И СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы В (ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад), ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница))) КАК ЗапасыНаСкладахОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница";    
		
	Иначе 
		
		Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница КАК Склад,
		|	СУММА(ЗапасыНаСкладахОстатки.КоличествоОстаток) КАК КоличествоОстаток
		|ИЗ
		|	РегистрНакопления.ЗапасыНаСкладах.Остатки(
		|			,
		|			Номенклатура = &Номенклатура
		|				И Характеристика = &Характеристика
		|				И СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы В (ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад), ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница))) КАК ЗапасыНаСкладахОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница"; 
			
	КонецЕсли;
		
	Возврат Текст;
КонецФункции

Функция ТекстЗапросаОстаткиИРезервыЗаказНаПеремещение()
	
	ТекстЗапроса =
	
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасы.Характеристика КАК Характеристика,
	|	ТаблицаЗапасы.Партия КАК Партия,
	|	ТаблицаЗапасы.ЗаказПокупателя КАК ЗаказПокупателя
	|ПОМЕСТИТЬ ВТНоменклатура
	|ИЗ
	|	&ТаблицаНоменклатура КАК ТаблицаЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТНоменклатура.Номенклатура КАК Номенклатура,
	|	ВТНоменклатура.Характеристика КАК Характеристика,
	|	ВТНоменклатура.Партия КАК Партия,
	|	СУММА(ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0)) КАК КоличествоОстаток
	|ПОМЕСТИТЬ ОстаткиНаСкладеВсего
	|ИЗ
	|	ВТНоменклатура КАК ВТНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(
	|				,
	|				Организация = &Организация
	|					И ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
	|					И ТИПЗНАЧЕНИЯ(СтруктурнаяЕдиница) = ТИП(Справочник.СтруктурныеЕдиницы)) КАК ЗапасыОстатки
	|		ПО ВТНоменклатура.Номенклатура = ЗапасыОстатки.Номенклатура
	|			И ВТНоменклатура.Характеристика = ЗапасыОстатки.Характеристика
	|			И ВТНоменклатура.Партия = ЗапасыОстатки.Партия
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТНоменклатура.Номенклатура,
	|	ВТНоменклатура.Партия,
	|	ВТНоменклатура.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказыПоставщикамОстатки.Номенклатура КАК Номенклатура,
	|	ЗаказыПоставщикамОстатки.Характеристика КАК Характеристика,
	|	СУММА(ЕСТЬNULL(ЗаказыПоставщикамОстатки.КоличествоОстаток, 0)) КАК КПоступлению,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказыПоставщикамОстатки.ЗаказПоставщику) КАК КоличествоДокументов
	|ПОМЕСТИТЬ ЗаказаноОстатки
	|ИЗ
	|	РегистрНакопления.ЗаказыПоставщикам.Остатки(
	|			,
	|			Организация = &Организация
	|				И Склад = &Отправитель
	|				И Номенклатура В (&Номенклатура)
	|				И Характеристика В (&Характеристика)) КАК ЗаказыПоставщикамОстатки
	|ГДЕ
	|	&УчетПотребностиПоСкладам
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказыПоставщикамОстатки.Характеристика,
	|	ЗаказыПоставщикамОстатки.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказыНаПроизводствоОстатки.Номенклатура,
	|	ЗаказыНаПроизводствоОстатки.Характеристика,
	|	СУММА(ЕСТЬNULL(ЗаказыНаПроизводствоОстатки.КоличествоОстаток, 0)),
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказыНаПроизводствоОстатки.ЗаказНаПроизводство)
	|ИЗ
	|	РегистрНакопления.ЗаказыНаПроизводство.Остатки(
	|			,
	|			Организация = &Организация
	|				И Склад = &Отправитель
	|				И Номенклатура В (&Номенклатура)
	|				И Характеристика В (&Характеристика)) КАК ЗаказыНаПроизводствоОстатки
	|ГДЕ
	|	&УчетПотребностиПоСкладам
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказыНаПроизводствоОстатки.Номенклатура,
	|	ЗаказыНаПроизводствоОстатки.Характеристика
	|
	|ОБЪЕДИНИТЬ ВСЕ
