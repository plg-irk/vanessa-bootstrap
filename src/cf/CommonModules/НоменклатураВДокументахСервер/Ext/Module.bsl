			|	И Запасы.Номенклатура = &Номенклатура
			|	И Запасы.Характеристика = &Характеристика
			|	И Запасы.Партия = &Партия
			|	И Запасы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
			|
