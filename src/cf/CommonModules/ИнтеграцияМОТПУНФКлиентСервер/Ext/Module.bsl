	ИменаФорм.Добавить("Документ.СборкаЗапасов.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.РезервированиеЗапасов.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.РасходныйОрдер.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.РаспределениеЗатрат.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ПриходныйОрдер.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ПриемИПередачаВРемонт.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ПересортицаЗапасов.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ПереоценкаТоваровНаКомиссии.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ПереоценкаВРозницеСуммовойУчет.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ПеремещениеПоЯчейкам.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ПеремещениеЗапасов.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ОтчетОРозничныхПродажах.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ОтчетКомитенту.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ОтчетКомиссионераОСписании.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ОтчетКомиссионера.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ОприходованиеЗапасов.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.КомплектацияЗапасов.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ИнвентаризацияЗапасов.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ЗаказНаПроизводство.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ЗаказНаПеремещение.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ВводНачальныхОстатков.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.АвансовыйОтчет.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.ЗаказПокупателя.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Документ.УстановкаЦенНоменклатуры.Форма.ФормаДокумента");
	ИменаФорм.Добавить("Справочник.Номенклатура.Форма.ФормаСписка");
	
	Возврат ИменаФорм.НайтиПоЗначению(ИмяФормы) <> Неопределено;
	
КонецФункции

Процедура ЗаполнитьБазовыеПараметрыСканирования(Контекст, ПараметрыСканирования, ВидПродукции)
	
	#Область Метаданные
	
	ПараметрыСканирования.ИмяТабличнойЧастиШтрихкодыУпаковок = Неопределено;
	ПараметрыСканирования.ИмяКолонкиШтрихкодУпаковки = Неопределено;
	
	#КонецОбласти
	
	#Область ПоддержкаПродукцииИСМП
	
	ШтрихкодированиеОбщегоНазначенияМОТПКлиентСервер.ВключитьПоддержкуТабачнойПродукции(ПараметрыСканирования,
		ВидПродукции);
	ШтрихкодированиеИСМПКлиентСервер.ВключитьПоддержкуПродукцииИСМП(ПараметрыСканирования, ВидПродукции);
	
	НастройкиИСМП = Новый Структура;
	НастройкиИСМП.Вставить("КонтролироватьОкончаниеСрокаГодности", Ложь);
	НастройкиИСМП.Вставить("ЗапрашиватьДанныеСервисаИСМП",         Ложь);
	НастройкиИСМП.Вставить("ДопустимыПроверкиСеройЗоныМОТП",       Ложь);
	
	НастройкиИСМП.Вставить("РазрешеноЗапрашиватьКодМаркировки",    Ложь);
	НастройкиИСМП.Вставить("КонтрольУникальностиКодовМаркировки",  Ложь);
	НастройкиИСМП.Вставить("СоздаватьШтрихкодУпаковки",            Ложь);
	
	ЗаполнитьЗначенияСвойств(ПараметрыСканирования, НастройкиИСМП);
	
	#КонецОбласти
	
	#Область ПоддержкаАлкогольнойПродукции
	
	ШтрихкодированиеОбщегоНазначенияЕГАИСКлиентСервер.ВключитьПоддержкуАлкогольнойПродукции(ПараметрыСканирования,
		ВидПродукции);
		
	#КонецОбласти
	
КонецПроцедуры

#КонецОбласти