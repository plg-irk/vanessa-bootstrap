Функция ОбластиПримененияНастроекПанели()
	
	ОбластиПрименения = Новый Структура();
	ОбластиПрименения.Вставить("ОбычныйИнтерфейс", 0);
	ОбластиПрименения.Вставить("ПлиточныйИнтерфейс", 1);
	ОбластиПрименения.Вставить("Везде", 2);
	
	Возврат ОбластиПрименения;
	
