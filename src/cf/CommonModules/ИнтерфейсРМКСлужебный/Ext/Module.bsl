Функция ПолучитьТиповыеАвтоЗначенияСвойствНастроекЭлементов()
	
	ЦветАвто = Новый Цвет();
	ЦветАвтоСтрокой = ОбщегоНазначения.ЗначениеВСтрокуXML(ЦветАвто);
	ШрифтАвто = Новый Шрифт();
	ШрифтАвтоСтрокой = ОбщегоНазначения.ЗначениеВСтрокуXML(ШрифтАвто);
	
	ТиповыеАвтоЗначения = Новый Структура();
	ТиповыеАвтоЗначения.Вставить("ЦветАвто", ЦветАвтоСтрокой);
	ТиповыеАвтоЗначения.Вставить("ШрифтАвто", ШрифтАвтоСтрокой);
	ТиповыеАвтоЗначения.Вставить("ФигураАвто", НСтр("ru = 'Авто'"));
	ТиповыеАвтоЗначения.Вставить("ВыравниваниеАвто", НСтр("ru = 'Авто'"));
	ТиповыеАвтоЗначения.Вставить("ПоложениеЧасовНет", НСтр("ru = 'Нет'"));
	
	Возврат ТиповыеАвтоЗначения;
	
КонецФункции

Процедура ДобавитьСтандартныеНастройкиОбластей(ТаблицаНастроек, ИмяОбласти, ТиповыеАвтоЗначения,
		МаксимальнаяВысотаКнопки, МаксимальнаяШиринаКнопки, МаксимальныйРазмерШрифта)

	СвойствоВысотаКнопок = Перечисления.СвойстваЭлементовРМК.ВысотаКнопок;
	СвойстваШиринаКнопок = Перечисления.СвойстваЭлементовРМК.ШиринаКнопок;
	СвойствоЦветКнопок = Перечисления.СвойстваЭлементовРМК.ЦветКнопок;
	СвойствоШрифтКнопок = Перечисления.СвойстваЭлементовРМК.ШрифтКнопок;
	СвойствоЦветШрифта = Перечисления.СвойстваЭлементовРМК.ЦветШрифта;
	СвойствоФигураКнопок = Перечисления.СвойстваЭлементовРМК.ФигураКнопок;
	
	ЗначенияВысотыКнопок = Новый Структура();
	ЗначенияВысотыКнопок.Вставить("ЗначениеПоУмолчанию", 0);
	ЗначенияВысотыКнопок.Вставить("МаксимальноеЗначение", МаксимальнаяВысотаКнопки);
	
	ЗначенияШириныКнопок = Новый Структура();
	ЗначенияШириныКнопок.Вставить("ЗначениеПоУмолчанию", 0);
	ЗначенияШириныКнопок.Вставить("МаксимальноеЗначение", МаксимальнаяШиринаКнопки);
	
	ЗначенияРазмераШрифта = Новый Структура();
	ЗначенияРазмераШрифта.Вставить("ЗначениеПоУмолчанию", 0);
	ЗначенияРазмераШрифта.Вставить("МаксимальноеЗначение", МаксимальныйРазмерШрифта);
	
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ИмяОбласти, СвойствоВысотаКнопок, ЗначенияВысотыКнопок);
	Если МаксимальнаяШиринаКнопки > 0 Тогда
		ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ИмяОбласти, СвойстваШиринаКнопок, ЗначенияШириныКнопок);
		ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ИмяОбласти, СвойствоШрифтКнопок, ТиповыеАвтоЗначения.ШрифтАвто);
		ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ИмяОбласти, СвойствоЦветШрифта, ТиповыеАвтоЗначения.ЦветАвто);
	КонецЕсли;
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ИмяОбласти, СвойствоЦветКнопок, ТиповыеАвтоЗначения.ЦветАвто);
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ИмяОбласти, СвойствоФигураКнопок, ТиповыеАвтоЗначения.ФигураАвто);
	
КонецПроцедуры

Функция ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоЭлементов, ЗначениеПоУмолчанию)
	
	НоваяСтрока = ТаблицаНастроек.Добавить();
	НоваяСтрока.СвойствоЭлементов = СвойствоЭлементов;
	НоваяСтрока.ЗначениеСвойства = ЗначениеПоУмолчанию;
	
	Возврат НоваяСтрока;
	
КонецФункции

Процедура ДобавитьМаксимальноеЗначениеНастройкиЭлемента(ТаблицаНастроек,
		ИмяЭлемента, СвойствоЭлементов, МаксимальноеЗначение)
	
	НоваяСтрока = ТаблицаНастроек.Добавить();
	НоваяСтрока.ИмяЭлемента = ИмяЭлемента;
	НоваяСтрока.СвойствоЭлементов = СвойствоЭлементов;
	НоваяСтрока.МаксимальноеЗначение = МаксимальноеЗначение;
	
КонецПроцедуры

Процедура ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ИмяОбласти, СвойствоОбласти, ЗначениеСвойства)
	
	НоваяСтрока = ТаблицаНастроек.Добавить();
	НоваяСтрока.ЗаголовокОбласти = ИмяОбласти;
	НоваяСтрока.СвойствоЭлементовОбласти = СвойствоОбласти;
	Если ТипЗнч(ЗначениеСвойства) = Тип("Структура") Тогда
		НоваяСтрока.ЗначениеСвойства = ЗначениеСвойства.ЗначениеПоУмолчанию;
		НоваяСтрока.МаксимальноеЗначение = ЗначениеСвойства.МаксимальноеЗначение;
	Иначе
		НоваяСтрока.ЗначениеСвойства = ЗначениеСвойства;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСтраницуЭлементаПлитки(ЭлементыФормы, Страницы,
		ИндексКнопки, ЦветФонаКнопки, ИмяКомандыНажатия, БазовыйШрифт, НомераЭлементов)
	
	ИмяЭлемента = СтрШаблон("Плитка_Элемент%1_%2", НомераЭлементов.НомерСтраницы, ИндексКнопки);
	ЭлементФормы = ЭлементыФормы.Добавить(ИмяЭлемента, Тип("ГруппаФормы"), Страницы);
