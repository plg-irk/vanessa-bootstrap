Функция ПолучитьУстройстваРаспознаванияЭлектронныхВесовДляПодключения(РабочееМесто) Экспорт
	
	УстройстваРаспознавания = Новый Массив;
	
	ЭлектронныеВесыРабочегоМеста
		= ОбщегоНазначенияРМК.ПолучитьПодключенноеОборудованиеПоТипу("ЭлектронныеВесы", РабочееМесто);
	УстройстваРаспознаванияРабочегоМеста
		= ОбщегоНазначенияРМК.ПолучитьПодключенноеОборудованиеПоТипу("УстройствоРаспознавания", РабочееМесто);
		
	ЗапросУстройств = Новый Запрос;
	ЗапросУстройств.Текст =
	"ВЫБРАТЬ
	|	КомплектацияПодключаемогоОборудования.ОсновноеОборудование КАК ЭлектронныеВесыСсылка,
	|	КомплектацияПодключаемогоОборудования.ДополнительноеОборудование КАК УстройствоРаспознаванияСсылка
	|ИЗ
	|	РегистрСведений.КомплектацияПодключаемогоОборудования КАК КомплектацияПодключаемогоОборудования
	|ГДЕ
	|	КомплектацияПодключаемогоОборудования.ОсновноеОборудование В(&ЭлектронныеВесы)
	|	И КомплектацияПодключаемогоОборудования.ДополнительноеОборудование В(&УстройстваРаспознавания)";
	ЗапросУстройств.УстановитьПараметр("ЭлектронныеВесы", ЭлектронныеВесыРабочегоМеста);
	ЗапросУстройств.УстановитьПараметр("УстройстваРаспознавания", УстройстваРаспознаванияРабочегоМеста);
	РезультатЗапроса = ЗапросУстройств.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаУстройств = РезультатЗапроса.Выбрать();
		Пока ВыборкаУстройств.Следующий() Цикл
			
			СтрокаКомплекта = Новый Структура();
			СтрокаКомплекта.Вставить("ЭлектронныеВесы", ВыборкаУстройств.ЭлектронныеВесыСсылка);
			СтрокаКомплекта.Вставить("УстройствоРаспознавания", ВыборкаУстройств.УстройствоРаспознаванияСсылка);
			СтрокаКомплекта.Вставить("ВесыОбработаны", Ложь);
			СтрокаКомплекта.Вставить("УстройствоРаспознаванияОбработано", Ложь);
			УстройстваРаспознавания.Добавить(СтрокаКомплекта);
			
		КонецЦикла;
	КонецЕсли;
	
	Возврат УстройстваРаспознавания;
	
КонецФункции

Процедура НастроитьЭлементыВесовогоТовараВПлитке(Форма) Экспорт
	
	ПараметрыИнтерфейсаПлитки = ИнтерфейсРМКСлужебныйКлиентСервер.ПараметрыПлиточногоИнтерфейса();
	Форма.ЕстьВесовойТоварВПлитке = ЕстьВесовойТоварВОпорныхДанных(Форма.ОпорныеДанные);
	Элементы = Форма.Элементы;
	СтандартнаяПлитка = ЗначениеЗаполнено(Форма.СтруктураПлиточногоИнтерфейсаПодбора);
	НастройкиЭлементов = ОбщегоНазначенияРМК.ПолучитьНастройкиЭлементовРабочегоМестаКассира(Форма.ТекущаяНастройкаРМК);
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	НаборСвойствПлитки = НастройкиЭлементов.Получить(ЗаголовкиОбластей.ПлиточныйИнтерфейс);
	СвойствоВысота = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ВысотаКнопок");
	СвойствоШирина = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ШиринаКнопок");
	
	ЗначениеВысоты = Неопределено;
	ЗначениеШирины = Неопределено;
	Если Не НаборСвойствПлитки = Неопределено Тогда
		ЗначениеВысоты = НаборСвойствПлитки.Получить(СвойствоВысота);
		ЗначениеШирины = НаборСвойствПлитки.Получить(СвойствоШирина);
	КонецЕсли;
	Элементы.ОтборВесовогоТовара.Ширина
		= ?(ЗначениеЗаполнено(ЗначениеШирины), ЗначениеШирины, ПараметрыИнтерфейсаПлитки.ШиринаКоманды);
	Элементы.ОтборВесовогоТовара.Высота
		= ?(ЗначениеЗаполнено(ЗначениеВысоты), ЗначениеВысоты, ПараметрыИнтерфейсаПлитки.ВысотаКоманды);

	Если Форма.РежимКассыСамообслуживания Тогда
		Элементы.ОтборВесовогоТовараКСО.Видимость = СтандартнаяПлитка И Форма.ЕстьВесовойТоварВПлитке;;
	Иначе
		Элементы.ОтборВесовогоТовара.Видимость = СтандартнаяПлитка И Форма.ЕстьВесовойТоварВПлитке;
	КонецЕсли;
	Элементы.Декорация1.Видимость = (Форма.РежимПлитки И СтандартнаяПлитка И Форма.ЕстьВесовойТоварВПлитке);
	
	Если Форма.ЕстьВесовойТоварВПлитке Тогда
		ДобавитьСлужебныеГруппыВесовогоТовараВОпорныеДанные(Форма);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьАнализИРегистрациюАварийногоЗавершенияЧеков(ПараметрыРМК) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	СтартовыеОперации = РегистрыСведений.ЖурналДействийКассира.ПолучитьОперацииДействийОткрытияЧека();
	ТекущийНомерСеанса = НомерСеансаИнформационнойБазы();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаНеЗавершенныхДействийСЧеком();
	Запрос.УстановитьПараметр("НачальныеОперацииСЧеком", СтартовыеОперации);
	
	НачатьТранзакцию();
	Попытка
		
		БлокировкаЖурналаДействий = Новый БлокировкаДанных;
		ЭлементБлокировки = БлокировкаЖурналаДействий.Добавить("РегистрСведений.ЖурналДействийКассира");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		БлокировкаЖурналаДействий.Заблокировать();
		
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			
			АктивныеСеансы = ПолучитьСеансыИнформационнойБазы();
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				РегистрироватьАварийноеЗавершение = Ложь;
				Если Выборка.НомерСеанса = ТекущийНомерСеанса Тогда
					РегистрироватьАварийноеЗавершение = ПараметрыРМК.ЗапускПриСтарте;
				Иначе
					Активныйсеанс = НайтиАктивныйСеансПоНомеру(АктивныеСеансы, Выборка.НомерСеанса);
					Если Активныйсеанс = Неопределено Тогда
						РегистрироватьАварийноеЗавершение = Истина;
					КонецЕсли;
				КонецЕсли;
				Если РегистрироватьАварийноеЗавершение Тогда
					ЗарегистрироватьАварийноеЗавершениеЧека(Выборка);
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Не удалось зарегистрировать аварийные завершения чеков.'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.РегистрыСведений.ЖурналДействийКассира, ,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецПроцедуры

Процедура УстановитьУсловноеОформлениеЖурналаДействийКассира(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	УсловноеОформление = Форма.УсловноеОформление;
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеСписок = Элемент.Поля.Элементы.Добавить();
	ПолеСписок.Поле = Новый ПолеКомпоновкиДанных(Элементы.Список.Имя);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Список.ОперацияСЧеком");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Перечисления.ОперацииРабочегоМестаКассира.АварийноеЗавершениеЧека;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветОсобогоТекста);
	
КонецПроцедуры

Функция ПолучитьПервоначальноеРасположениеОбластейФормыРМК(ГруппаФормыРМК, ПараметрыЗаполнения) Экспорт
	
	МассивТиповЦвет = Новый Массив;
	МассивТиповЦвет.Добавить(Тип("Цвет"));
	ТипЧислоРазмер = ОбщегоНазначения.ОписаниеТипаЧисло(3, 0, ДопустимыйЗнак.Неотрицательный);
	
	МассивТиповГруппировка = Новый Массив;
	МассивТиповГруппировка.Добавить(Тип("ГруппировкаПодчиненныхЭлементовФормы"));
	
	ДеревоПорядкаОбластей = Новый ДеревоЗначений;
	ДеревоПорядкаОбластей.Колонки.Добавить("ИмяОбласти", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ДеревоПорядкаОбластей.Колонки.Добавить("ЗаголовокОбласти", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	ДеревоПорядкаОбластей.Колонки.Добавить("Группировка", ОбщегоНазначения.ОписаниеТипаСтрока(15));
	ДеревоПорядкаОбластей.Колонки.Добавить("Ширина", ТипЧислоРазмер);
	ДеревоПорядкаОбластей.Колонки.Добавить("Высота", ТипЧислоРазмер);
	ДеревоПорядкаОбластей.Колонки.Добавить("ЦветОбласти", Новый ОписаниеТипов(МассивТиповЦвет));
	ДеревоПорядкаОбластей.Колонки.Добавить("ДоступностьГруппы", Новый ОписаниеТипов("Булево"));
	
	ЗаполнитьПервоначальныйПорядокОбластейФормыРМК(ГруппаФормыРМК, ДеревоПорядкаОбластей, ПараметрыЗаполнения);
	
	Возврат ДеревоПорядкаОбластей;
	
КонецФункции

Процедура ПрименитьНастройкуПорядкаОбластей(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	
	ЗапросПорядка = Новый Запрос;
	ЗапросПорядка.Текст =
	"ВЫБРАТЬ
	|	НастройкиРабочегоМестаКассираПорядокОбластей.ОбластьРодитель КАК ОбластьРодитель,
	|	НастройкиРабочегоМестаКассираПорядокОбластей.Область КАК Область,
	|	НастройкиРабочегоМестаКассираПорядокОбластей.Порядок КАК Порядок
	|ИЗ
	|	Справочник.НастройкиРабочегоМестаКассира.ПорядокОбластей КАК НастройкиРабочегоМестаКассираПорядокОбластей
	|ГДЕ
	|	НастройкиРабочегоМестаКассираПорядокОбластей.ВертикальнаяОриентация = &ВертикальнаяОриентация
	|	И НастройкиРабочегоМестаКассираПорядокОбластей.Ссылка = &ТекущаяНастройка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОбластьРодитель,
	|	Порядок";
	ЗапросПорядка.УстановитьПараметр("ВертикальнаяОриентация", Форма.ВертикальнаяОриентация);
	ЗапросПорядка.УстановитьПараметр("ТекущаяНастройка", Форма.ТекущаяНастройкаРМК);
	
	СуффиксВертикальная = "_Вертикальная";
	СуффиксГоризонтальная = "_Горизонтальная";
	ТекущийСуффикс = ?(Форма.ВертикальнаяОриентация, СуффиксВертикальная, СуффиксГоризонтальная);

	ТаблицаПорядка = ЗапросПорядка.Выполнить().Выгрузить();
	Для Каждого СтрокаПорядка Из ТаблицаПорядка Цикл
		
		ПозицияСуффикса = СтрНайти(СтрокаПорядка.Область, ТекущийСуффикс);
		Если ПозицияСуффикса > 0 Тогда
			ИмяГруппы = Лев(СтрокаПорядка.Область, ПозицияСуффикса - 1);
			ГруппаЭлемент = Элементы.Найти(ИмяГруппы);
			КоллекцияЭлементов = ГруппаЭлемент.Родитель.ПодчиненныеЭлементы;
			ИндексЭлемента = КоллекцияЭлементов.Индекс(ГруппаЭлемент);
			Если СтрокаПорядка.Порядок <> ИндексЭлемента + 1 Тогда
				ЭлементДляСмещения = КоллекцияЭлементов.Получить(СтрокаПорядка.Порядок - 1);
				Элементы.Переместить(ГруппаЭлемент, ГруппаЭлемент.Родитель, ЭлементДляСмещения);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	ПрименитьИсключенияОбработкиПорядкаОбластей(Форма, ТаблицаПорядка);
	
КонецПроцедуры

// Получает массив вложенных палитр в переданных палитрах по всей глубине иерархии
//
// Параметры:
//  КорневыеПалитры - Массив из СправочникСсылка.ПалитраТоваровРМК
//
// Возвращаемое значение - Массив из СправочникСсылка.ПалитраТоваровРМК
//
Функция ПолучитьВложенныеПалитры(КорневыеПалитры) Экспорт
	
	РезультатФункции = Новый Массив;
	
	СхемаВложенныхПалитр = Справочники.ПалитраТоваровРМК.ПолучитьМакет("МакетВложенныхПалитр");
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.ЗагрузитьНастройки(СхемаВложенныхПалитр.НастройкиПоУмолчанию);

	ПараметрМассивПалитр = Новый ПараметрКомпоновкиДанных("МассивПалитр");
	МассивПалитр = Новый СписокЗначений;
	МассивПалитр.ЗагрузитьЗначения(КорневыеПалитры);
	КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(ПараметрМассивПалитр, МассивПалитр);
	ТекущиеНастройки = КомпоновщикНастроек.ПолучитьНастройки();
	ТипГенератораДляКоллекции = Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений");
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаВложенныхПалитр, ТекущиеНастройки, , , ТипГенератораДляКоллекции);
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ТаблицаВложенныхПалитр = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаВложенныхПалитр);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	Для каждого СтрокаТаблицы Из ТаблицаВложенныхПалитр Цикл
		
		Если КорневыеПалитры.Найти(СтрокаТаблицы.ВложеннаяПалитра) = Неопределено
				И РезультатФункции.Найти(СтрокаТаблицы.ВложеннаяПалитра) = Неопределено Тогда
				
			РезультатФункции.Добавить(СтрокаТаблицы.ВложеннаяПалитра);
				
		КонецЕсли;
		
	КонецЦикла;
	Возврат РезультатФункции;
	
КонецФункции

// Получает массив палитр, начиная с текущей и всех палитр - владельцев
//
// Параметры:
//  ИсходнаяПалитра - СправочникСсылка.ПалитраТоваровРМК,
//  ИсключитьИсходнуюПалитру - Булево - в возвращаемом массиве будет исключена исходная палитра
//
// Возвращаемое значение - Массив из СправочникСсылка.ПалитраТоваровРМК
//
Функция ПолучитьИерархиюРодителейПалитры(ИсходнаяПалитра, ИсключитьИсходнуюПалитру = Ложь) Экспорт
	
	РезультатФункции = Новый Массив;
	
	СхемаРодительскихПалитр = Справочники.ПалитраТоваровРМК.ПолучитьМакет("МакетРодительскихПалитр");
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.ЗагрузитьНастройки(СхемаРодительскихПалитр.НастройкиПоУмолчанию);

	ПараметрИсходнаяПалитра = Новый ПараметрКомпоновкиДанных("ИсходнаяПалитра");
	КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(ПараметрИсходнаяПалитра, ИсходнаяПалитра);
	ТекущиеНастройки = КомпоновщикНастроек.ПолучитьНастройки();
	ТипГенератораДляКоллекции = Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений");
	МакетКомпоновки
		= КомпоновщикМакета.Выполнить(СхемаРодительскихПалитр, ТекущиеНастройки, , , ТипГенератораДляКоллекции);
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ТаблицаРодительскихПалитр = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаРодительскихПалитр);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	РезультатФункции = ТаблицаРодительскихПалитр.ВыгрузитьКолонку("ПалитраВладелец");
	Если Не ИсключитьИсходнуюПалитру Тогда
		РезультатФункции.Вставить(0, ИсходнаяПалитра);
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Процедура НастроитьКоличествоЭлементовПлитки(Форма) Экспорт
	
	ВертикальнаяОриентация = Ложь;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ВертикальнаяОриентация") тогда
		ВертикальнаяОриентация = Форма.ВертикальнаяОриентация;
	КонецЕсли;
	РазмерыПлиткиПоУмолчанию = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьРазмерыПлиткиПоУмолчанию(ВертикальнаяОриентация);
	
	СтруктураРеквизитовФормы = Новый Структура;
	СтруктураРеквизитовФормы.Вставить("КоличествоЭлементовВРяду", РазмерыПлиткиПоУмолчанию.КоличествоЭлементовВРяду);
	СтруктураРеквизитовФормы.Вставить("КоличествоРядовНаСтранице", РазмерыПлиткиПоУмолчанию.КоличествоРядовНаСтранице);
	ЗаполнитьЗначенияСвойств(Форма, СтруктураРеквизитовФормы);
	
КонецПроцедуры

Функция ПодготовитьДанныеКонтроляПродаж(НаборТаблиц) Экспорт
	
	ДанныеКонтроляПродаж = ИнтерфейсРМКСлужебныйКлиентСервер.ШаблонКэшаКонтроляПродаж();
	ТаблицаКонтроляИСвойств = НаборТаблиц.ТаблицаКонтроляИСвойств;
	ТаблицаВидовКонтроляСПараметрами = НаборТаблиц.ТаблицаВидовКонтроляСПараметрами;
	ТаблицаКонтроляИНоменклатуры = НаборТаблиц.ТаблицаКонтроляИНоменклатуры;
	ТаблицаСтрокКонтроля = НаборТаблиц.ТаблицаСтрокКонтроля;
	
	Для Каждого СтрокаКонтроляНоменклатуры Из ТаблицаКонтроляИНоменклатуры Цикл
		ТекущийКонтроль = СтрокаКонтроляНоменклатуры.КонтрольПродаж;
		КонтрольДобавлен = Ложь;
		Если ЗначениеЗаполнено(СтрокаКонтроляНоменклатуры.Номенклатура) Тогда
			КонтрольДобавлен = ДобавитьКонтрольНоменклатурыПриНеобходимости(ДанныеКонтроляПродаж.НоменклатураКонтроляПродаж, 
				СтрокаКонтроляНоменклатуры);
		Иначе
			Если ДанныеКонтроляПродаж.ОбщийКонтрольПродаж.Найти(ТекущийКонтроль) = Неопределено Тогда
				ДанныеКонтроляПродаж.ОбщийКонтрольПродаж.Добавить(ТекущийКонтроль);
				КонтрольДобавлен = Истина;
			КонецЕсли;
		КонецЕсли;
		Если КонтрольДобавлен Тогда
			СтрокаЭлементаКонтроля
				= ПолучитьСтрокуЭлементаКонтроляПродаж(ДанныеКонтроляПродаж.ЭлементыКонтроляПродаж, ТекущийКонтроль);
				
			Если СтрокаЭлементаКонтроля = Неопределено Тогда
				ДобавитьЭлементКонтроляПродажВДанныеКонтроля(НаборТаблиц, ДанныеКонтроляПродаж, ТекущийКонтроль);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат ДанныеКонтроляПродаж;
	
КонецФункции

Функция ПолучитьРеквизитыОбработкиРабочееМестоКассира() Экспорт
	
	РезультатФункции = Новый Массив;
	КоллекцияРеквизитов = Метаданные.Обработки.РабочееМестоКассира.Реквизиты;
	Для Каждого РеквизитОбработки Из КоллекцияРеквизитов Цикл
		РезультатФункции.Добавить(РеквизитОбработки.Имя);
	КонецЦикла;
	Возврат РезультатФункции;
	
КонецФункции

Процедура ПреобразоватьМассивыСтруктурДанныхЧекаВТаблицы(РеквизитыФормы) Экспорт
	
	ИмяТаблицыОплата = "Оплата";
	ИмяТаблицыТовары = "Товары";
	
	СтруктураИсточник = Неопределено;
	Для Каждого ОписаниеТаблицы Из РеквизитыФормы.КолонкиТаблицФормы Цикл
		ТаблицаПриемник = Новый ТаблицаЗначений;
		Для Каждого КолонкаТаблицы Из ОписаниеТаблицы.Значение Цикл
			ТаблицаПриемник.Колонки.Добавить(КолонкаТаблицы.Имя, КолонкаТаблицы.Тип);
		КонецЦикла;
		Если ОписаниеТаблицы.Ключ = ИмяТаблицыОплата Или ОписаниеТаблицы.Ключ = ИмяТаблицыТовары Тогда
			СтруктураИсточник = РеквизитыФормы.Объект[ОписаниеТаблицы.Ключ];
		Иначе
			СтруктураИсточник = РеквизитыФормы[ОписаниеТаблицы.Ключ];
		КонецЕсли;
		Для Каждого ДанныеСтроки Из СтруктураИсточник Цикл
			НоваяСтрока = ТаблицаПриемник.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеСтроки);
		КонецЦикла;
		Если ОписаниеТаблицы.Ключ = ИмяТаблицыОплата Или ОписаниеТаблицы.Ключ = ИмяТаблицыТовары Тогда
			РеквизитыФормы.Объект.Вставить(ОписаниеТаблицы.Ключ, ТаблицаПриемник);
		Иначе
			РеквизитыФормы.Вставить(ОписаниеТаблицы.Ключ, ТаблицаПриемник);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ПреобразоватьТаблицыЧекаВСтруктурыДанных(РеквизитыФормы) Экспорт
	
	ИмяТаблицыОплата = "Оплата";
	ИмяТаблицыТовары = "Товары";
	
	ТаблицаИсточник = Неопределено;
	Для Каждого ОписаниеТаблицы Из РеквизитыФормы.КолонкиТаблицФормы Цикл
		Если ОписаниеТаблицы.Ключ = ИмяТаблицыОплата Или ОписаниеТаблицы.Ключ = ИмяТаблицыТовары Тогда
			ТаблицаИсточник = РеквизитыФормы.Объект[ОписаниеТаблицы.Ключ];
		Иначе
			ТаблицаИсточник = РеквизитыФормы[ОписаниеТаблицы.Ключ];
		КонецЕсли;
		СтруктураПриемник = Новый Массив;
		Для Каждого СтрокаТаблицыИсточника Из ТаблицаИсточник Цикл
			ДанныеСтроки = Новый Структура();
			Для Каждого КолонкаТаблицы Из ОписаниеТаблицы.Значение Цикл
				ДанныеСтроки.Вставить(КолонкаТаблицы.Имя, СтрокаТаблицыИсточника[КолонкаТаблицы.Имя]);
			КонецЦикла;
			СтруктураПриемник.Добавить(ДанныеСтроки);
		КонецЦикла;
		Если ОписаниеТаблицы.Ключ = ИмяТаблицыОплата Или ОписаниеТаблицы.Ключ = ИмяТаблицыТовары Тогда
			РеквизитыФормы.Объект.Вставить(ОписаниеТаблицы.Ключ, СтруктураПриемник);
		Иначе
			РеквизитыФормы.Вставить(ОписаниеТаблицы.Ключ, СтруктураПриемник);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ВключитьКнопочныйВариантКомандРежимЕще(Форма, НастройкиЭлементов) Экспорт
	
	Элементы = Форма.Элементы;
	Элементы.ОперацииСтраницаКнопок.Видимость = Истина;
	Элементы.ОперацииСтраницы.ТекущаяСтраница = Элементы.ОперацииСтраницаКнопок;
	НастроитьКомандыРежимИЕще(Форма);
	
	СвойствоВысота = Перечисления.СвойстваЭлементовРМК.ВысотаКнопок;
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	НаборСвойств = НастройкиЭлементов.Получить(ЗаголовкиОбластей.ОбластьПанельОпераций);
	Если Не НаборСвойств = Неопределено Тогда
		ЗначениеВысоты = НаборСвойств.Получить(СвойствоВысота);
		Если ЗначениеЗаполнено(ЗначениеВысоты) И ЗначениеВысоты > 1 Тогда
			ПараметрыУвеличенногоИнтерфейса = ПараметрыУвеличенногоИнтерфейса(Форма.ВидОтображения);
			Элементы.ВводТовараПоСтроке.Шрифт = ПараметрыУвеличенногоИнтерфейса.Шрифт;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьПервоначальныеНастройкиОбластейРМК() Экспорт
	
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	
	ТиповыеАвтоЗначения = ПолучитьТиповыеАвтоЗначенияСвойствНастроекЭлементов();
	ОбластиПрименения = ОбластиПримененияНастроекПанели();
	
	ТипЦелоеЧисло = ОбщегоНазначения.ОписаниеТипаЧисло(2, 0, ДопустимыйЗнак.Неотрицательный);
	ТаблицаНастроек = Справочники.НастройкиРабочегоМестаКассира.ПустаяСсылка().НастройкиОбластей.ВыгрузитьКолонки();
	ТаблицаНастроек.Колонки.Добавить("МаксимальноеЗначение", ТипЦелоеЧисло);
	
	ДобавитьСтандартныеНастройкиОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьПробитьЧек, ТиповыеАвтоЗначения, 5, 36, 24);
	ДобавитьСтандартныеНастройкиОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьВернутьсяКПодбору, ТиповыеАвтоЗначения, 3, 36, 20);
	ДобавитьСтандартныеНастройкиОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьВидыОплат, ТиповыеАвтоЗначения, 4, 30, 22);
	ДобавитьСтандартныеНастройкиОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьДанныеТекущегоТовара, ТиповыеАвтоЗначения, 4, 12, 22);
	ДобавитьСтандартныеНастройкиОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьПанельОпераций, ТиповыеАвтоЗначения, 5, 25, 22);
	
	СвойствоВыравниваниеЭлементов = Перечисления.СвойстваЭлементовРМК.ВыравниваниеЭлементов;
	СвойствоПоложениеЧасов = Перечисления.СвойстваЭлементовРМК.ПоложениеЧасов;
	СвойствоОбластьПрименения = Перечисления.СвойстваЭлементовРМК.ОбластьПрименения;
	СвойствоПоказыватьСтатусСмены = Перечисления.СвойстваЭлементовРМК.ПоказыватьСтатусСмены;
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьПанельОпераций,
		СвойствоВыравниваниеЭлементов, ТиповыеАвтоЗначения.ВыравниваниеАвто);
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьПанельОпераций, СвойствоПоложениеЧасов,
		ТиповыеАвтоЗначения.ПоложениеЧасовНет);
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьПанельОпераций, СвойствоОбластьПрименения,
		ОбластиПрименения.ОбычныйИнтерфейс);
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьПанельОпераций,
		СвойствоПоказыватьСтатусСмены, Ложь);
		
	ЗначенияШириныКолонки = Новый Структура();
	ЗначенияШириныКолонки.Вставить("ЗначениеПоУмолчанию", 0);
	ЗначенияШириныКолонки.Вставить("МаксимальноеЗначение", 30);
	
	ЗначенияШириныСуммы = Новый Структура();
	ЗначенияШириныСуммы.Вставить("ЗначениеПоУмолчанию", 0);
	ЗначенияШириныСуммы.Вставить("МаксимальноеЗначение", 30);
	
	СвойствоШрифт = Перечисления.СвойстваЭлементовРМК.ШрифтКнопок;
	СвойстваШирина = Перечисления.СвойстваЭлементовРМК.ШиринаКнопок;
	СвойствоВысота = Перечисления.СвойстваЭлементовРМК.ВысотаКнопок;
	СвойствоПереноситьТекст = Перечисления.СвойстваЭлементовРМК.ПереноситьТекст;
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьСписокТоваров, СвойствоШрифт,
		ТиповыеАвтоЗначения.ШрифтАвто);
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьСписокТоваров, СвойстваШирина,
		ЗначенияШириныКолонки);
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьСписокТоваров, СвойствоВысота,
		ЗначенияШириныСуммы);
	ДобавитьСтрокуНастроекОбластей(ТаблицаНастроек, ЗаголовкиОбластей.ОбластьСписокТоваров,
		СвойствоПереноситьТекст, Ложь);
	
	Возврат ТаблицаНастроек;
	
КонецФункции

Функция ПолучитьПервоначальныеНастройкиЭлементовРМК(КвадратныеКнопки = Ложь) Экспорт
	
	СвойствоВысотаКнопок = Перечисления.СвойстваЭлементовРМК.ВысотаКнопок;
	СвойствоШиринаКнопок = Перечисления.СвойстваЭлементовРМК.ШиринаКнопок;
	
	СвойствоЦветКнопок = Перечисления.СвойстваЭлементовРМК.ЦветКнопок;
	СвойствоШрифтКнопок = Перечисления.СвойстваЭлементовРМК.ШрифтКнопок;
	СвойствоЦветШрифта = Перечисления.СвойстваЭлементовРМК.ЦветШрифта;
	СвойствоФигураКнопок = Перечисления.СвойстваЭлементовРМК.ФигураКнопок;
	
	ТиповыеАвтоЗначения = ПолучитьТиповыеАвтоЗначенияСвойствНастроекЭлементов();
	
	ТаблицаНастроек = Справочники.НастройкиРабочегоМестаКассира.ПустаяСсылка().НастройкиЭлементов.ВыгрузитьКолонки();
	ТаблицаНастроек.Колонки.Удалить("ИмяЭлемента");
	ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоВысотаКнопок, 0);
	ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоШиринаКнопок, 0);
	Если Не КвадратныеКнопки Тогда
		ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоШрифтКнопок, ТиповыеАвтоЗначения.ШрифтАвто);
		ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоЦветШрифта, ТиповыеАвтоЗначения.ЦветАвто);
	КонецЕсли;
	ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоЦветКнопок, ТиповыеАвтоЗначения.ЦветАвто);
	ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоФигураКнопок, ТиповыеАвтоЗначения.ФигураАвто);
	
	Возврат ТаблицаНастроек;
	
КонецФункции

Функция ПолучитьИндивидуальныеПервоначальныеНастройки(ИмяЭлемента = "") Экспорт
	
	ТаблицаНастроек = Справочники.НастройкиРабочегоМестаКассира.ПустаяСсылка().НастройкиЭлементов.ВыгрузитьКолонки();
	ЭлементДробноеКоличество = "ТекущийТоварУстановитьДробноеКоличество";
	
	Если ИмяЭлемента = ЭлементДробноеКоличество Или ИмяЭлемента = "" Тогда
		
		СвойствоЗаголовокКнопки = Перечисления.СвойстваЭлементовРМК.ЗаголовокКнопки;
		СвойствоВеличинаДробная = Перечисления.СвойстваЭлементовРМК.ВеличинаДробногоКоличества;
		СвойствоШагДробный = Перечисления.СвойстваЭлементовРМК.ШагДробногоКоличества;
		СвойствоПодтверждениеДробного = Перечисления.СвойстваЭлементовРМК.ПодтверждениеДробногоТовара;
		
		СтрокаНастройки = ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоЗаголовокКнопки, "");
		СтрокаНастройки.ИмяЭлемента = ЭлементДробноеКоличество;
		СтрокаНастройки = ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоВеличинаДробная, 0);
		СтрокаНастройки.ИмяЭлемента = ЭлементДробноеКоличество;
		СтрокаНастройки = ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоШагДробный, 0);
		СтрокаНастройки.ИмяЭлемента = ЭлементДробноеКоличество;
		СтрокаНастройки = ДобавитьСтрокуНастроекЭлементов(ТаблицаНастроек, СвойствоПодтверждениеДробного, Ложь);
		СтрокаНастройки.ИмяЭлемента = ЭлементДробноеКоличество;
		
	КонецЕсли;
	
	Возврат ТаблицаНастроек;
	
КонецФункции

Функция ПодготовитьНастройкиЭлементовДляКлиента(ПараметрыРМК) Экспорт
	
	НастройкаРМК = ПараметрыРМК.НастройкаРМК;
	
	РезультатФункции = Новый Соответствие();
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	
	ЭлементыДляКлиента = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиПанельОпераций();
	ЭлементыТекущегоТовара = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиДанныхТекущегоТовара();
	Для Каждого ИмяЭлемента Из ЭлементыТекущегоТовара Цикл
		ЭлементыДляКлиента.Добавить(ИмяЭлемента);
	КонецЦикла;
	
	ТаблицаПервоначальныхНастроек = ПолучитьПервоначальныеНастройкиОбластейРМК();
	НаборСвойствПанельОпераций = Новый Соответствие();
	ОтборСтрокПанелиОпераций = Новый Структура("ЗаголовокОбласти", ЗаголовкиОбластей.ОбластьПанельОпераций);
	СтрокиНастроекПанелиОпераций = ТаблицаПервоначальныхНастроек.найтиСтроки(ОтборСтрокПанелиОпераций);
	Для Каждого СтрокаНастройки Из СтрокиНастроекПанелиОпераций Цикл
		Если Не СтрокаНастройки.СвойствоЭлементовОбласти = Перечисления.СвойстваЭлементовРМК.ОбластьПрименения Тогда
			ЗначениеСвойства
				= ПривестиТипЗначенияСвойства(СтрокаНастройки.СвойствоЭлементовОбласти, СтрокаНастройки.ЗначениеСвойства);
			НаборСвойствПанельОпераций.Вставить(СтрокаНастройки.СвойствоЭлементовОбласти, ЗначениеСвойства);
		КонецЕсли;
	КонецЦикла;
	НаборСвойствПлиточныйИнтерфейс = СкопироватьСоответствие(НаборСвойствПанельОпераций);
	
	НастройкиЭлементов = ОбщегоНазначенияРМК.ПолучитьНастройкиЭлементовРабочегоМестаКассира(НастройкаРМК);
	КнопкаКаталог = "Каталог";
	КнопкаКаталогКСО = "ОткрытьПлиточныйИнтерфейсКаталога";
	
	Для Каждого ТекущаяНастройка Из НастройкиЭлементов Цикл
		Если Не ЭлементыДляКлиента.Найти(ТекущаяНастройка.Ключ) = Неопределено Тогда
			РезультатФункции.Вставить(ТекущаяНастройка.Ключ, ТекущаяНастройка.Значение);
			Если ТекущаяНастройка.Ключ = КнопкаКаталог И ПараметрыРМК.РежимКассыСамообслуживания Тогда
				РезультатФункции.Вставить(КнопкаКаталогКСО, ТекущаяНастройка.Значение);
			КонецЕсли;
		ИначеЕсли ТекущаяНастройка.Ключ = ЗаголовкиОбластей.ОбластьПанельОпераций Тогда
			ПеренестиЗначенияСвойствВНабор(НаборСвойствПанельОпераций, ТекущаяНастройка.Значение);
		ИначеЕсли ТекущаяНастройка.Ключ = ЗаголовкиОбластей.ПлиточныйИнтерфейс Тогда
			ПеренестиЗначенияСвойствВНабор(НаборСвойствПлиточныйИнтерфейс, ТекущаяНастройка.Значение);
		КонецЕсли;
	КонецЦикла;
	РезультатФункции.Вставить(ЗаголовкиОбластей.ОбластьПанельОпераций, НаборСвойствПанельОпераций);
	РезультатФункции.Вставить(ЗаголовкиОбластей.ПлиточныйИнтерфейс, НаборСвойствПлиточныйИнтерфейс);
	
	Возврат РезультатФункции;
	
КонецФункции

Функция ПолучитьМассивИменКвадратныхКнопок() Экспорт
	
	КнопкиИсключения = Новый Массив;
	КнопкиИсключения.Добавить("ПоказатьРассчитанныеСкидки");
	КнопкиИсключения.Добавить("ТекущийТоварУстановитьДробноеКоличество");
	
	МассивИмен = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиДанныхТекущегоТовара();
	Для Каждого КнопкаИсключение Из КнопкиИсключения Цикл
		ИндексИсключения = МассивИмен.Найти(КнопкаИсключение);
		Если Не ИндексИсключения = Неопределено Тогда
			МассивИмен.Удалить(ИндексИсключения);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивИмен;
	
КонецФункции

Функция ПолучитьМаксимальноеЗначениеНастройкиЭлемента(ИмяЭлемента, СвойствоЭлементов) Экспорт
	
	РезультатФункции = 1;
	
	ТаблицаМаксимальныхЗначений = ПолучитьТаблицуМаксимальныхЗначенийНастроекЭлементов();
	ОтборСтрок = Новый Структура();
	ОтборСтрок.Вставить("ИмяЭлемента", ИмяЭлемента);
	ОтборСтрок.Вставить("СвойствоЭлементов", СвойствоЭлементов);
	СтрокиМаксимальногоЗначения = ТаблицаМаксимальныхЗначений.НайтиСтроки(ОтборСтрок);
	Если СтрокиМаксимальногоЗначения.Количество() > 0 Тогда
		РезультатФункции = СтрокиМаксимальногоЗначения[0].МаксимальноеЗначение;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Функция ПолучитьНастройкиЭлементовРабочегоМестаКассира(НастройкаРМК) Экспорт
	
	РезультатФункции = Новый Соответствие();
	
	ЗапросНастроек = Новый Запрос;
	ЗапросНастроек.Текст =
	"ВЫБРАТЬ
	|	НастройкиРабочегоМестаКассираНастройкиЭлементов.ИмяЭлемента КАК ИмяЭлемента,
	|	НастройкиРабочегоМестаКассираНастройкиЭлементов.СвойствоЭлементов КАК СвойствоЭлементов,
	|	НастройкиРабочегоМестаКассираНастройкиЭлементов.ЗначениеСвойства КАК ЗначениеСвойства
	|ИЗ
	|	Справочник.НастройкиРабочегоМестаКассира.НастройкиЭлементов КАК НастройкиРабочегоМестаКассираНастройкиЭлементов
	|ГДЕ
	|	НастройкиРабочегоМестаКассираНастройкиЭлементов.Ссылка = &ТекущаяНастройкаРМК
	|ИТОГИ ПО
	|	ИмяЭлемента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкиРабочегоМестаКассираНастройкиОбластей.ЗаголовокОбласти КАК ЗаголовокОбласти,
	|	НастройкиРабочегоМестаКассираНастройкиОбластей.СвойствоЭлементовОбласти КАК СвойствоЭлементов,
	|	НастройкиРабочегоМестаКассираНастройкиОбластей.ЗначениеСвойства КАК ЗначениеСвойства
	|ИЗ
	|	Справочник.НастройкиРабочегоМестаКассира.НастройкиОбластей КАК НастройкиРабочегоМестаКассираНастройкиОбластей
	|ГДЕ
	|	НастройкиРабочегоМестаКассираНастройкиОбластей.Ссылка = &ТекущаяНастройкаРМК
	|ИТОГИ ПО
	|	ЗаголовокОбласти";
	ЗапросНастроек.УстановитьПараметр("ТекущаяНастройкаРМК", НастройкаРМК);
	
	КнопкаПробитьЧек = "ПробитьЧек";
	ПакетРезультатов = ЗапросНастроек.ВыполнитьПакет();
	ВыборкаНастроекЭлементов = ПакетРезультатов[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаНастроекЭлементов.Следующий() Цикл
		
		СоответствиеНастроек = Новый Соответствие();
		ВыборкаСвойств = ВыборкаНастроекЭлементов.Выбрать();
		Пока ВыборкаСвойств.Следующий() Цикл
			
			ЗначениеСвойства = ПривестиТипЗначенияСвойства(ВыборкаСвойств.СвойствоЭлементов, ВыборкаСвойств.ЗначениеСвойства);
			СоответствиеНастроек.Вставить(ВыборкаСвойств.СвойствоЭлементов, ЗначениеСвойства);
			
		КонецЦикла;
		РезультатФункции.Вставить(ВыборкаНастроекЭлементов.ИмяЭлемента, СоответствиеНастроек);
		
		Если ВыборкаНастроекЭлементов.ИмяЭлемента = КнопкаПробитьЧек Тогда
			РодственныеЭлементы = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиПробитьЧек(Ложь);
			Для Каждого ИмяЭлемента Из РодственныеЭлементы Цикл
				РезультатФункции.Вставить(ИмяЭлемента, СоответствиеНастроек);
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	ВыборкаНастроекОбластей = ПакетРезультатов[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ОбработатьВыборкуНастроекОбластей(РезультатФункции, ВыборкаНастроекОбластей);
	
	Возврат РезультатФункции;
	
КонецФункции

Процедура НастроитьЭлементыРабочегоМестаКассира(Форма, НастройкиЭлементов) Экспорт
	
	ПоложениеЧасов = "";
	СвойствоШирина = Перечисления.СвойстваЭлементовРМК.ШиринаКнопок;
	СвойствоВыравнивание = Перечисления.СвойстваЭлементовРМК.ВыравниваниеЭлементов;
	СвойствоВысота = Перечисления.СвойстваЭлементовРМК.ВысотаКнопок;
	ШиринаСтатусаСмены = 0;
	ЭлементыПанелиОпераций = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиПанельОпераций();
	
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	Для Каждого СтрокаНастройки Из НастройкиЭлементов Цикл
		
		Если СтрокаНастройки.Ключ = ЗаголовкиОбластей.ОбластьПанельОпераций Тогда
			
			ОпределитьПрименитьПоложениеЧасов(Форма, ПоложениеЧасов, СтрокаНастройки.Значение);
			ИнтерфейсРМКСлужебныйКлиентСервер.ОпределитьПрименитьВыравниваниеГруппыОперации(Форма, СтрокаНастройки.Значение);
			НастроитьОтображениеСтатусаКассовойСмены(Форма, ПоложениеЧасов, СтрокаНастройки.Значение);
			ЗначениеВысоты = СтрокаНастройки.Значение.Получить(СвойствоВысота);
			Если Не ЗначениеВысоты = Неопределено И ЗначениеВысоты > 1 Тогда
				ШиринаСтатусаСмены = 4;
			КонецЕсли;
			
		ИначеЕсли СтрокаНастройки.Ключ = ЗаголовкиОбластей.ПлиточныйИнтерфейс Тогда
			
			КнопкаОтборВеса = Форма.Элементы.ОтборВесовогоТовара;
			КнопкаНазад = Форма.Элементы.ПерейтиНазад;
			КнопкаВперед = Форма.Элементы.ПерейтиДалее;
			КнопкаДомой = Форма.Элементы.ПерейтиНаНачальнуюСтраницу;
			
			КнопкаОтборВесаКСО = Форма.Элементы.ОтборВесовогоТовараКСО;
			ИнтерфейсРМКСлужебныйКлиентСервер.НастроитьОтображениеКнопкиФормы(КнопкаОтборВеса, СтрокаНастройки.Значение);
			ИнтерфейсРМКСлужебныйКлиентСервер.НастроитьОтображениеКнопкиФормы(КнопкаНазад, СтрокаНастройки.Значение);
			ИнтерфейсРМКСлужебныйКлиентСервер.НастроитьОтображениеКнопкиФормы(КнопкаВперед, СтрокаНастройки.Значение);
			ИнтерфейсРМКСлужебныйКлиентСервер.НастроитьОтображениеКнопкиФормы(КнопкаДомой, СтрокаНастройки.Значение);
			
			НаборСвойствКнопкаКСО = СкопироватьСоответствие(СтрокаНастройки.Значение);
			Если Не НаборСвойствКнопкаКСО.Получить(СвойствоШирина) = Неопределено Тогда
				НаборСвойствКнопкаКСО.Удалить(СвойствоШирина);
			КонецЕсли;
			ИнтерфейсРМКСлужебныйКлиентСервер.НастроитьОтображениеКнопкиФормы(КнопкаОтборВесаКСО, НаборСвойствКнопкаКСО);
			
			ОпределитьПрименитьПоложениеЧасов(Форма, ПоложениеЧасов, СтрокаНастройки.Значение);
			
		ИначеЕсли СтрокаНастройки.Ключ = ЗаголовкиОбластей.ОбластьСписокТоваров Тогда
			
			НастроитьОтображениеСпискаТоваров(Форма, СтрокаНастройки.Значение);
			
		Иначе
			
			ЭлементФормы = Форма.Элементы.Найти(СтрокаНастройки.Ключ);
			Если Не ЭлементФормы = Неопределено И ТипЗнч(ЭлементФормы) = Тип("КнопкаФормы") Тогда
				ИнтерфейсРМКСлужебныйКлиентСервер.НастроитьОтображениеКнопкиФормы(ЭлементФормы, СтрокаНастройки.Значение);
				Если ШиринаСтатусаСмены = 0 И Не ЭлементыПанелиОпераций.Найти(СтрокаНастройки.Ключ) = Неопределено Тогда
					ЗначениеВысоты = СтрокаНастройки.Значение.Получить(СвойствоВысота);
					Если Не ЗначениеВысоты = Неопределено И ЗначениеВысоты > 1 Тогда
						ШиринаСтатусаСмены = 4;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ШиринаСтатусаСмены > 0 Тогда
		Форма.Элементы.ДекорацияСтатусСмены.Ширина = ШиринаСтатусаСмены;
	КонецЕсли;
	КлючПараметрыПолей = "ПараметрыПолей";
	ПараметрыПолей = СформироватьНастройкиСвязанныхПолей(Форма, НастройкиЭлементов);
	НастройкиЭлементов.Вставить(КлючПараметрыПолей, ПараметрыПолей);
	
КонецПроцедуры

Функция ВидыЦифровойКлавиатуры() Экспорт
	
	РезультатФункции = Новый Структура();
	
	РезультатФункции.Вставить("Стандартный", 0);
	РезультатФункции.Вставить("Авторизация", 1);
	
	Возврат РезультатФункции;
	
КонецФункции

Функция ПостроитьПанельЦифровойКлавиатуры(Форма, ЭлементКонтейнер, ПараметрыПостроения) Экспорт
	
	ТекстОшибки = "";
	
	ИмяРеквизитаВвода = "";
	КнопкаЗакрытия = Ложь;
	Если ПараметрыПостроения.Свойство("ИмяРеквизитаВвода") Тогда
		ИмяРеквизитаВвода = ПараметрыПостроения.ИмяРеквизитаВвода;
	КонецЕсли;
	Если ПараметрыПостроения.Свойство("КнопкаЗакрытия") Тогда
		КнопкаЗакрытия = ПараметрыПостроения.КнопкаЗакрытия;
	КонецЕсли;
	ВидыКлавиатуры = ВидыЦифровойКлавиатуры();
	ВидКлавиатуры = ВидыКлавиатуры.Стандартный;
	Если ПараметрыПостроения.Свойство("ВидКлавиатуры") Тогда
		ВидКлавиатуры = ПараметрыПостроения.ВидКлавиатуры;
	КонецЕсли;
	
	ДобавитьКомандыКлавиатуры(Форма, ВидКлавиатуры);
	
	ОбщаяГруппа = ДобавитьГруппуКлавиатуры(Форма, ЭлементКонтейнер, "ОбщийКонтейнер", ПараметрыПостроения, ТекстОшибки);
	ОбщаяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

	Если ВидКлавиатуры = ВидыКлавиатуры.Стандартный Тогда
		ГруппаТабло = ДобавитьГруппуКлавиатуры(Форма, ОбщаяГруппа, "ГруппаТабло", ПараметрыПостроения, ТекстОшибки);
		ГруппаТабло.Ширина = ЭлементКонтейнер.Ширина;
		ДобавитьЭлементыГруппыТабло(Форма, ГруппаТабло, ИмяРеквизитаВвода, КнопкаЗакрытия, ТекстОшибки);
	КонецЕсли;
	ГруппаПанель = ДобавитьГруппуКлавиатурыЦифроваяПанель(Форма, ОбщаяГруппа, ПараметрыПостроения, ТекстОшибки);
	
	ГруппаЦифры789 = ДобавитьГруппуКлавиатуры(Форма, ГруппаПанель, "ГруппаЦифры789", ПараметрыПостроения, ТекстОшибки);
	МассивЦифр = Новый Массив;
	МассивЦифр.Добавить(7);
	МассивЦифр.Добавить(8);
	МассивЦифр.Добавить(9);
	ДобавитьКнопкиЦифрыРяда(Форма, ГруппаЦифры789, МассивЦифр, ПараметрыПостроения, ТекстОшибки);
	
	ГруппаЦифры456 = ДобавитьГруппуКлавиатуры(Форма, ГруппаПанель, "ГруппаЦифры456", ПараметрыПостроения, ТекстОшибки);
	МассивЦифр.Очистить();
	МассивЦифр.Добавить(4);
	МассивЦифр.Добавить(5);
	МассивЦифр.Добавить(6);
	ДобавитьКнопкиЦифрыРяда(Форма, ГруппаЦифры456, МассивЦифр, ПараметрыПостроения, ТекстОшибки);
	
	ГруппаЦифры123 = ДобавитьГруппуКлавиатуры(Форма, ГруппаПанель, "ГруппаЦифры123", ПараметрыПостроения, ТекстОшибки);
	МассивЦифр.Очистить();
	МассивЦифр.Добавить(1);
	МассивЦифр.Добавить(2);
	МассивЦифр.Добавить(3);
	ДобавитьКнопкиЦифрыРяда(Форма, ГруппаЦифры123, МассивЦифр, ПараметрыПостроения, ТекстОшибки);
	
	ГруппаЦифры0 = ДобавитьГруппуКлавиатуры(Форма, ГруппаПанель, "ГруппаЦифры0", ПараметрыПостроения, ТекстОшибки);
	Если ВидКлавиатуры = ВидыКлавиатуры.Стандартный Тогда
		ДобавитьКнопкиНулевогоРяда(Форма, ГруппаЦифры0, ПараметрыПостроения, ТекстОшибки);
	
		ГруппаОчищениеПоиск = ДобавитьГруппуКлавиатуры(Форма, ГруппаПанель, "ГруппаОчищениеПоиск", ПараметрыПостроения, ТекстОшибки);
		ГруппаОчищениеПоиск.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Лево;
		ГруппаОчищениеПоиск.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Лево;
		ДобавитьКнопкиРядаОчищениеПоиск(Форма, ГруппаОчищениеПоиск, ПараметрыПостроения, ТекстОшибки);
	ИначеЕсли ВидКлавиатуры = ВидыКлавиатуры.Авторизация Тогда
		ДобавитьКнопкиНулевогоРядаАвторизации(Форма, ГруппаЦифры0, ПараметрыПостроения, ТекстОшибки);
	КонецЕсли;
	
	Возврат ТекстОшибки;
	
КонецФункции

Процедура ОбновитьКнопкуСтатусаКассовыхСмен(Форма) Экспорт
	
	КартинкаСтатуса = ПолучитьКартинкуСтатусаКассовыхСмен(Форма.ГрупповойСтатусСмен);
	Если Не КартинкаСтатуса = Неопределено Тогда
		Форма.Элементы.ДекорацияСтатусСмены.картинка = КартинкаСтатуса;
	КонецЕсли;
	
КонецПроцедуры

Функция КодДоступаПользователяУказан(ДанныеПоискаКассира) Экспорт
	
	Результат = Ложь;
	Запрос = Новый Запрос;
	ОбщегоНазначенияРМКПереопределяемый.СформироватьЗапросПолученияКодовДоступаПользователя(Запрос, ДанныеПоискаКассира);
	
	Если ЗначениеЗаполнено(Запрос.Текст) Тогда
		Выборка = Запрос.Выполнить().Выбрать();
		КоличествоПаролейПользователя = Выборка.Количество();
		Результат = (КоличествоПаролейПользователя > 0);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура УдалитьСтрокиСоставаПалитрыСРазорваннымиСвязями(ПалитраОбъект) Экспорт
	
	СтрокиБезСвязи = ПолучитьСтрокиСоставаПалитрыБезСвязи(ПалитраОбъект.Состав);
	Пока СтрокиБезСвязи.Количество() > 0 Цикл
		
		ПроверяемыеКатегории = Новый Массив;
		Для Каждого СтрокаУдаления Из СтрокиБезСвязи Цикл
			Если СтрокаУдаления.ЭтоКатегория И СтрокаУдаления.НомерКатегорииРазмещения > 0 Тогда
				ПроверяемыеКатегории.Добавить(СтрокаУдаления.НомерКатегорииРазмещения);
			КонецЕсли;
			ПалитраОбъект.Состав.Удалить(СтрокаУдаления);
		КонецЦикла;
		СтрокиБезСвязи = ПолучитьСтрокиСоставаПалитрыБезСвязи(ПалитраОбъект.Состав, ПроверяемыеКатегории);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСУниверсальнойЦифровойКлавиатурой

Процедура ДобавитьКомандыКлавиатуры(Форма, ВидКлавиатуры)

	ДобавитьКомандыЦифрКлавиатуры(Форма);
	ДобавитьКомандуКлавиатуры(Форма, "ОчиститьУниверсальнаяКлавиатура");
	ДобавитьКомандуКлавиатуры(Форма, "УдалитьПоследнееУниверсальнаяКлавиатура");
	
	ВидыКлавиатуры = ВидыЦифровойКлавиатуры();
	Если ВидКлавиатуры = ВидыКлавиатуры.Стандартный Тогда
		ДобавитьКомандуКлавиатуры(Форма, "ЗапятаяУниверсальнаяКлавиатура");
		ДобавитьКомандуКлавиатуры(Форма, "ПоискУниверсальнаяКлавиатура");
		ДобавитьКомандуКлавиатуры(Форма, "ЗакрытьУниверсальнаяКлавиатура");
		ДобавитьКомандуКлавиатуры(Форма, "ДваНуляУниверсальнаяКлавиатура");
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКомандуКлавиатуры(Форма, ИмяКоманды)
	
	НоваяКоманда = Форма.Команды.Найти(ИмяКоманды);
	Если НоваяКоманда = Неопределено Тогда
		НоваяКоманда = Форма.Команды.Добавить(ИмяКоманды);
		НоваяКоманда.Действие = СтрШаблон("Подключаемый_%1", ИмяКоманды);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКомандыЦифрКлавиатуры(Форма)
	
	Для Счетчик = 0 По 9 Цикл
		ИмяКоманды = СтрШаблон("Цифра%1УниверсальнаяКлавиатура", Счетчик);
		
		НоваяКоманда = Форма.Команды.Найти(ИмяКоманды);
		Если НоваяКоманда = Неопределено Тогда
			НоваяКоманда = Форма.Команды.Добавить(ИмяКоманды);
			НоваяКоманда.Действие = "Подключаемый_ЦифраУниверсальнаяКлавиатура";
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьКнопкиНулевогоРяда(Форма, ГруппаЦифры0, ПараметрыПостроения, ТекстОшибки)
	
	ДанныеКнопки = Новый Структура();
	ДанныеКнопки.Вставить("ИмяКнопки", "Цифра00УниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("ИмяКоманды", "ДваНуляУниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("Заголовок", "00");
	ДобавитьКнопкуКлавиатуры(Форма, ГруппаЦифры0, ДанныеКнопки, ПараметрыПостроения, ТекстОшибки);
	
	ДанныеКнопки = Новый Структура();
	ДанныеКнопки.Вставить("ИмяКнопки", "Цифра0УниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("ИмяКоманды", "Цифра0УниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("Заголовок", "0");
	ДобавитьКнопкуКлавиатуры(Форма, ГруппаЦифры0, ДанныеКнопки, ПараметрыПостроения, ТекстОшибки);
	
	ДанныеКнопки = Новый Структура();
	ДанныеКнопки.Вставить("ИмяКнопки", "ЗапятаяУниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("ИмяКоманды", "ЗапятаяУниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("Заголовок", ",");
	ДобавитьКнопкуКлавиатуры(Форма, ГруппаЦифры0, ДанныеКнопки, ПараметрыПостроения, ТекстОшибки);
	
КонецПроцедуры

Процедура ДобавитьКнопкиНулевогоРядаАвторизации(Форма, ГруппаЦифры0, ПараметрыПостроения, ТекстОшибки)
	
	ДанныеКнопки = Новый Структура();
	ДанныеКнопки.Вставить("ИмяКнопки", "ОчиститьУниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("ИмяКоманды", "ОчиститьУниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("Заголовок", "X");
	КнопкаОчистить = ДобавитьКнопкуКлавиатуры(Форма, ГруппаЦифры0, ДанныеКнопки, ПараметрыПостроения, ТекстОшибки);
	КнопкаОчистить.ЦветТекста = ЦветаСтиля.ЦветОсобогоТекста;
	
	ДанныеКнопки = Новый Структура();
	ДанныеКнопки.Вставить("ИмяКнопки", "Цифра0УниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("ИмяКоманды", "Цифра0УниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("Заголовок", "0");
	ДобавитьКнопкуКлавиатуры(Форма, ГруппаЦифры0, ДанныеКнопки, ПараметрыПостроения, ТекстОшибки);
	
	ДанныеКнопки = Новый Структура();
	ДанныеКнопки.Вставить("ИмяКнопки", "УдалитьПоследнееУниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("ИмяКоманды", "УдалитьПоследнееУниверсальнаяКлавиатура");
	ДанныеКнопки.Вставить("Заголовок", "<<");
	КнопкаУдалить = ДобавитьКнопкуКлавиатуры(Форма, ГруппаЦифры0, ДанныеКнопки, ПараметрыПостроения, ТекстОшибки);
	КнопкаУдалить.Отображение = ОтображениеКнопки.Картинка;
	КнопкаУдалить.Картинка = БиблиотекаКартинок.СтрелкаВлевоРМК;
	
КонецПроцедуры

Процедура ДобавитьКнопкиРядаОчищениеПоиск(Форма, ГруппаОчищениеПоиск, ПараметрыПостроения, ТекстОшибки)
	
	ДанныеКнопки = Новый Структура();
