Функция ПолучитьМинимальнуюВысотуКнопок(НастройкиЭлементов, Кнопки)
	
	ВысотаКнопок = Неопределено;
	СвойствоВысота = Перечисления.СвойстваЭлементовРМК.ВысотаКнопок;
	
	Для Каждого ИмяКнопки Из Кнопки Цикл
		НаборСвойств = НастройкиЭлементов.Получить(ИмяКнопки);
		Если Не НаборСвойств = Неопределено Тогда
			ЗначениеВысоты = НаборСвойств.Получить(СвойствоВысота);
			Если ЗначениеЗаполнено(ЗначениеВысоты) И (ВысотаКнопок = Неопределено Или ВысотаКнопок > ЗначениеВысоты) Тогда
				ВысотаКнопок = ЗначениеВысоты;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ВысотаКнопок = Неопределено Тогда
		ВысотаКнопок = 0;
	КонецЕсли;
	Возврат ВысотаКнопок;
	
КонецФункции

Функция ПривестиТипЗначенияСвойства(СвойствоЭлементов, ИсходноеЗначениеСвойства)
	Перем ЗначениеСвойства;
	
	Если СвойствоЭлементов = Перечисления.СвойстваЭлементовРМК.ЦветКнопок
			Или СвойствоЭлементов = Перечисления.СвойстваЭлементовРМК.ЦветШрифта
			Или СвойствоЭлементов = Перечисления.СвойстваЭлементовРМК.ШрифтКнопок Тогда
			
		ЗначениеСвойства = ОбщегоНазначения.ЗначениеИзСтрокиXML(ИсходноеЗначениеСвойства);
		
	Иначе
		
		ЗначениеСвойства = ИсходноеЗначениеСвойства;
		
	КонецЕсли;
	Возврат ЗначениеСвойства;
	
КонецФункции

Процедура ОбработатьВыборкуНастроекОбластей(НастройкиЭлементов, ВыборкаНастроекОбластей)
	
	СвойствоСтатусСмены = Перечисления.СвойстваЭлементовРМК.ПоказыватьСтатусСмены;
	СвойстваПанели = Новый Массив;
	СвойстваПанели.Добавить(Перечисления.СвойстваЭлементовРМК.ВыравниваниеЭлементов);
	СвойстваПанели.Добавить(Перечисления.СвойстваЭлементовРМК.ПоложениеЧасов);
	СвойстваПанели.Добавить(СвойствоСтатусСмены);
	ОбластиПримененияНастроек = ОбластиПримененияНастроекПанели();
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	
	Пока ВыборкаНастроекОбластей.Следующий() Цикл
		
		НаборНастроекЭлементов = Новый Соответствие();
		НаборНастроекПанелиОпераций = Новый Соответствие();
		ОбластьПрименения = ОбластиПримененияНастроек.ОбычныйИнтерфейс;
		ВыборкаСвойств = ВыборкаНастроекОбластей.Выбрать();
		Пока ВыборкаСвойств.Следующий() Цикл
			
			Если ВыборкаСвойств.СвойствоЭлементов = Перечисления.СвойстваЭлементовРМК.ОбластьПрименения Тогда
				ОбластьПрименения = ВыборкаСвойств.ЗначениеСвойства;
			ИначеЕсли Не СвойстваПанели.Найти(ВыборкаСвойств.СвойствоЭлементов) = Неопределено Тогда
				НаборНастроекПанелиОпераций.Вставить(ВыборкаСвойств.СвойствоЭлементов, ВыборкаСвойств.ЗначениеСвойства);
			Иначе
				ЗначениеСвойства = ПривестиТипЗначенияСвойства(ВыборкаСвойств.СвойствоЭлементов, ВыборкаСвойств.ЗначениеСвойства);
				НаборНастроекЭлементов.Вставить(ВыборкаСвойств.СвойствоЭлементов, ЗначениеСвойства);
			КонецЕсли;
			
		КонецЦикла;
		
		Если ОбластьПрименения = ОбластиПримененияНастроек.ОбычныйИнтерфейс
				Или ОбластьПрименения = ОбластиПримененияНастроек.Везде Тогда
				
			ДобавитьНастройкиВсемЭлементамОбласти(НастройкиЭлементов, ВыборкаНастроекОбластей.ЗаголовокОбласти,
				НаборНастроекЭлементов);
				
			Если ВыборкаНастроекОбластей.ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьПанельОпераций Тогда
				
				ДобавитьСтрокиИзСоответствия(НаборНастроекПанелиОпераций, НаборНастроекЭлементов);
				НастройкиЭлементов.Вставить(ВыборкаНастроекОбластей.ЗаголовокОбласти, НаборНастроекПанелиОпераций);
				
			КонецЕсли;
				
		КонецЕсли;
		Если ВыборкаНастроекОбластей.ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьПанельОпераций
				И (ОбластьПрименения = ОбластиПримененияНастроек.ПлиточныйИнтерфейс
				Или ОбластьПрименения = ОбластиПримененияНастроек.Везде) Тогда
			
			НаборНастроекПлиточныйИнтерфейс = СкопироватьСоответствие(НаборНастроекЭлементов);
			ДобавитьСтрокиИзСоответствия(НаборНастроекПлиточныйИнтерфейс, НаборНастроекПанелиОпераций);
			НастройкиЭлементов.Вставить(ЗаголовкиОбластей.ПлиточныйИнтерфейс, НаборНастроекПлиточныйИнтерфейс);
			Если ОбластьПрименения = ОбластиПримененияНастроек.ПлиточныйИнтерфейс
					И НаборНастроекПанелиОпераций.Получить(СвойствоСтатусСмены) = Истина Тогда
				
				НаборНастроекПанелиОпераций.Очистить();
				НаборНастроекПанелиОпераций.Вставить(СвойствоСтатусСмены, Истина);
				НастройкиЭлементов.Вставить(ВыборкаНастроекОбластей.ЗаголовокОбласти, НаборНастроекПанелиОпераций);
				
			КонецЕсли;
		КонецЕсли;
		Если ВыборкаНастроекОбластей.ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьСписокТоваров Тогда
			НастройкиЭлементов.Вставить(ЗаголовкиОбластей.ОбластьСписокТоваров, НаборНастроекЭлементов);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьНастройкиВсемЭлементамОбласти(НастройкиЭлементов, ЗаголовокОбласти, НаборНастроекЭлементов)
	
	МассивКомандРежимЕще = Новый Массив;
	МассивКомандРежимЕще.Добавить("КомандаРежим");
	МассивКомандРежимЕще.Добавить("КомандаЕще");
	
	ЭлементыОбласти = ПолучитьЭлементыОбласти(ЗаголовокОбласти);
	Для Каждого ИмяЭлемента Из ЭлементыОбласти Цикл
		ТекущаяНастройка = НастройкиЭлементов.Получить(ИмяЭлемента);
		Если ТекущаяНастройка = Неопределено Тогда
			Если МассивКомандРежимЕще.Найти(ИмяЭлемента) = Неопределено Тогда
				НастройкиЭлементов.Вставить(ИмяЭлемента, НаборНастроекЭлементов);
			Иначе
				ТекущаяНастройка = Новый Соответствие();
				НастройкиЭлементов.Вставить(ИмяЭлемента, ТекущаяНастройка);
			КонецЕсли;
		КонецЕсли;
		Если Не ТекущаяНастройка = Неопределено Тогда
			Для Каждого СтрокаНабора Из НаборНастроекЭлементов Цикл
				ТекущееСвойство = ТекущаяНастройка.Получить(СтрокаНабора.Ключ);
				Если ТекущееСвойство = Неопределено И (МассивКомандРежимЕще.Найти(ИмяЭлемента) = Неопределено
						Или Не СтрокаНабора.Ключ = Перечисления.СвойстваЭлементовРМК.ШиринаКнопок) Тогда
					ТекущаяНастройка.Вставить(СтрокаНабора.Ключ, СтрокаНабора.Значение);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьЭлементыОбласти(ЗаголовокОбласти)
	
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	
	РезультатФункции = Новый Массив;
	
	Если ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьПанельОпераций Тогда
		РезультатФункции = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиПанельОпераций();
	ИначеЕсли ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьПробитьЧек Тогда
		РезультатФункции = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиПробитьЧек();
	ИначеЕсли ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьВернутьсяКПодбору Тогда
		РезультатФункции = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиВернутьсяКПодбору();
	ИначеЕсли ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьВидыОплат Тогда
		РезультатФункции = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиВидыОплат();
	ИначеЕсли ЗаголовокОбласти = ЗаголовкиОбластей.ОбластьДанныеТекущегоТовара Тогда
		РезультатФункции = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЭлементыОбластиДанныхТекущеготовара();
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Функция СкопироватьСоответствие(ИсходноеСоответствие)
	
	РезультатФункции = Новый Соответствие();
	Для Каждого СтрокаСоответствия Из ИсходноеСоответствие Цикл
		
		РезультатФункции.Вставить(СтрокаСоответствия.Ключ, СтрокаСоответствия.Значение);
		
	КонецЦикла;
	Возврат РезультатФункции;
	
КонецФункции

Процедура ДобавитьСтрокиИзСоответствия(СоответствиеПриемник, СоответствиеИсточник)
	
	Для Каждого СтрокаСоответствия Из СоответствиеИсточник Цикл
		
		СоответствиеПриемник.Вставить(СтрокаСоответствия.Ключ, СтрокаСоответствия.Значение);
		
	КонецЦикла;
	
КонецПроцедуры

