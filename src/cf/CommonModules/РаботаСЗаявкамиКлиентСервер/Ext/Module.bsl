
#Область ПрограммныйИнтерфейс

#Область ПроверкаНаТипЗаказа

// Проверяет заказ на тип заказа на продажу (заказ на продажу или заявка на продажу)
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоТипЗаказаНаПродажу(ВидОперации) Экспорт
	
	Возврат ЭтоЗаказНаПродажу(ВидОперации) Или ЭтоЗаявкаНаПродажу(ВидОперации);
	
КонецФункции

// Проверяет вид операции на тип заказ наряда (заказ-наряд или заявка заказ-наряд)
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоТипЗаказНаряда(ВидОперации) Экспорт
	
	Возврат ЭтоЗаказНаряд(ВидОперации) Или ЭтоЗаявкаЗаказНаряд(ВидОперации);
	
КонецФункции

// Проверяет вид операции на тип заказ на переработку (заказ на переработку)
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоТипЗаказаНаПереработку(ВидОперации) Экспорт
	
	Возврат ЭтоЗаказНаПереработку(ВидОперации);
	
КонецФункции

// Проверяет вид операции на тип заказа на продажу или заказа на переработку
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоТипЗаказаНаПродажуИлиПереработку(ВидОперации) Экспорт
	
	Возврат ЭтоТипЗаказаНаПродажу(ВидОперации) Или ЭтоТипЗаказаНаПереработку(ВидОперации);
	
КонецФункции

// Проверяет вид операции на тип заказа, у которого поддерживаются заявки
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоТипЗаказаСЗаявками(ВидОперации) Экспорт
	
	Возврат ЭтоЗаказНаПродажу(ВидОперации) Или ЭтоЗаказНаряд(ВидОперации);
	
КонецФункции

// Проверяет вид операции на заявку
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоЗаявка(ВидОперации) Экспорт
	
	Возврат ЭтоЗаявкаНаПродажу(ВидОперации) Или ЭтоЗаявкаЗаказНаряд(ВидОперации);
	
КонецФункции

// Проверяет, является ли вид операции полноценным заказом, а не заявкой
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоЗаказ(ВидОперации) Экспорт
	
	Возврат ЭтоЗаказНаПродажу(ВидОперации) Или ЭтоЗаказНаПереработку(ВидОперации) Или ЭтоЗаказНаряд(ВидОперации);
	
КонецФункции

// Является ли вид операции заявкой на продажу
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоЗаявкаНаПродажу(ВидОперации) Экспорт
	
	Возврат ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу");
	
КонецФункции

// Является ли вид операции заказом на продажу
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоЗаказНаПродажу(ВидОперации) Экспорт
	
	Возврат ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу");
	
КонецФункции

// Является ли вид операции заказом на переработку
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоЗаказНаПереработку(ВидОперации) Экспорт
	
	Возврат ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаПереработку");
	
КонецФункции

// Является ли вид операции заявкой заказ-нарядом
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоЗаявкаЗаказНаряд(ВидОперации) Экспорт
	
	Возврат ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд");
	
КонецФункции

// Является ли вид операции заказ-нарядом
// 
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЭтоЗаказНаряд(ВидОперации) Экспорт
	
	Возврат ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд");
	
КонецФункции

#КонецОбласти

// Сообщение, когда для выполнении действия необходимо сначала перевести заявку в заказ
// 
// Параметры:
//  ЗаказИлиПредставление - ДокументСсылка.ЗаказПокупателя, Строка - Заказ или его представление
// 
// Возвращаемое значение:
//  Булево
Функция СообщениеОНеобходимостиПереводаЗаявкиВЗаказ(ЗаказИлиПредставление) Экспорт
	
	Возврат СтрШаблон(
	НСтр("ru = 'Документ ""%1"" находится в состоянии заявки. Для выполнения действия переведите его в заказ'"),
	ЗаказИлиПредставление);
	
КонецФункции

// Проверяет проведенность заказа с учетом того, что он может быть заявкой
// 
// Параметры:
//  Данные - Структура:
//   * Проведен - Булево - Проведенность заказа
//   * ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - Вид операции заказа
// 
// Возвращаемое значение:
//  Булево
Функция ЗаказПроведен(Данные) Экспорт
	
	Возврат Данные.Проведен И ЭтоЗаказ(Данные.ВидОперации);
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ОбработатьРезультатПроверкиВозможностиИзмененияИспользованияЗаявокДляСостояния(Параметры) Экспорт
	
	РезультатОбработки = НовыйРезультатОбработкиРезультатаПроверкиИспользованияСостояний();
	
	РезультатПроверки = Параметры.РезультатПроверки;
	
	#Если Клиент Тогда
		СтроковыеФункцииМодуль = СтроковыеФункцииКлиент;
	#Иначе
		СтроковыеФункцииМодуль = СтроковыеФункции;
	#КонецЕсли
	Параметры.Вставить("СтроковыеФункцииМодуль", СтроковыеФункцииМодуль);
	
	Если РезультатПроверки.ИспользованиеСостоянийВЗаказах <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВЗаказах(
		РезультатПроверки.ИспользованиеСостоянийВЗаказах, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеСостоянийВЗаявках <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВЗаявках(
		РезультатПроверки.ИспользованиеСостоянийВЗаявках, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеСостоянийВДругихНастройкахКартыПроцессов <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВДругихНастройкахКартыПроцессов(
		РезультатПроверки.ИспользованиеСостоянийВДругихНастройкахКартыПроцессов, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеСостоянийВИнтернетМагазине <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВИнтернетМагазине(
		РезультатПроверки.ИспользованиеСостоянийВИнтернетМагазине, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеСостоянийВМагазинахСоцсетей <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВМагазинеСоцсетей(
		РезультатПроверки.ИспользованиеСостоянийВМагазинахСоцсетей, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеСостоянийВМаркетплейсах <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВМаркетплейсах(
		РезультатПроверки.ИспользованиеСостоянийВМаркетплейсах, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеСостоянийВКабинетеКлиента <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВКабинетеКлиента(
		РезультатПроверки.ИспользованиеСостоянийВКабинетеКлиента, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеЗаявокВАссистентеУправления <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВАссистентеУправления(
		РезультатПроверки.ИспользованиеЗаявокВАссистентеУправления, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеЗаявокВМаг1С <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВМаг1С(
		РезультатПроверки.ИспользованиеЗаявокВМаг1С, Параметры);
		
	ИначеЕсли РезультатПроверки.ИспользованиеЗаявокВМобильныхПриложениях <> Неопределено Тогда
		
		РезультатОбработки = ОбработатьИспользованиеСостоянийВМобильныхПриложениях(
		РезультатПроверки.ИспользованиеЗаявокВМобильныхПриложениях, Параметры);
		
	КонецЕсли;
	
	Возврат РезультатОбработки;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработкаРезультатаПроверкиИспользованияСостояний

Функция ПредставленияСостоянийПослеПроверки(ДанныеПослеПроверкиНастройки)
	
	Результат = Новый Массив;
	
	Для Каждого КлючИЗначение Из ДанныеПослеПроверкиНастройки.ИспользованиеСостояний Цикл
		Результат.Добавить(КлючИЗначение.Значение.Представление);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеСостоянийСтрокой(ПредставленияСостояний)
	
	Результат = "";
	Для Каждого Представление Из ПредставленияСостояний Цикл
		Результат = СтрШаблон("%1, ""%2""", Результат, Представление);
	КонецЦикла;
	
	Возврат Сред(Результат, 3);
	
КонецФункции

Функция НовыйРезультатОбработкиРезультатаПроверкиИспользованияСостояний() Экспорт
	
	Результат = Новый Структура;
	
	ДанныеПредупреждения = Новый Структура;
	ДанныеПредупреждения.Вставить("Текст", "");
	
	ДанныеВопроса = Новый Структура;
	ДанныеВопроса.Вставить("Текст", "");
	ДанныеВопроса.Вставить("НавигационнаяСсылкаОбъекта", "");
	ДанныеВопроса.Вставить("ТекстКнопкиПереходаКОбъекту", "");
	
	Результат.Вставить("ДанныеПредупреждения", ДанныеПредупреждения);
	Результат.Вставить("ДанныеВопроса", ДанныеВопроса);
	Возврат Результат;
	
КонецФункции

Функция ОбработатьИспользованиеСостоянийВЗаявках(РезультатПроверки, Параметры)
	
	Результат = НовыйРезультатОбработкиРезультатаПроверкиИспользованияСостояний();
	
	ИспользоватьВидыЗаказов = Параметры.ИспользоватьВидыЗаказов;
	НаименованиеВидаЗаказа = Параметры.НаименованиеВидаЗаказа;
	СтроковыеФункцииМодуль = Параметры.СтроковыеФункцииМодуль;
	
	ПредставленияСостояний = ПредставленияСостоянийПослеПроверки(РезультатПроверки);
	Если ПредставленияСостояний.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЗаявкиОтключаютсяПолностью =
	(РезультатПроверки.ИспользованиеСостояний[РезультатПроверки.СостояниеЗавершен] <> Неопределено);
	
	Если ПредставленияСостояний.Количество() = 1 Тогда
		
		Если ИспользоватьВидыЗаказов Тогда
			
			Если ЗаявкиОтключаютсяПолностью Тогда
				
				ТекстПредупреждения =
				НСтр("ru = 'В виде ""%1"" в состоянии ""%2"" существуют заявки.
				|Переведите <a href = ""%3"">такие заявки</a> в заказы, чтобы режим ""Заявки"" можно было полностью отключить для данного вида заказов'");
				
			Иначе
				
				ТекстПредупреждения =
				НСтр("ru = 'В виде ""%1"" в состоянии ""%2"" существуют заявки.
				|Измените состояние у <a href = ""%3"">таких заявок</a> или переведите их в заказы, чтобы отключить настройку'");
				
			КонецЕсли;
			
			ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
			ТекстПредупреждения,
			НаименованиеВидаЗаказа,
			ПредставленияСостояний[0],
			РезультатПроверки.НавигационнаяСсылка);
			
		Иначе
			
			Если ЗаявкиОтключаютсяПолностью Тогда
				
				ТекстПредупреждения =
				НСтр("ru = 'В состоянии ""%1"" существуют заявки.
				|Переведите <a href = ""%2"">такие заявки</a> в заказы, чтобы режим ""Заявки"" можно было полностью отключить'");
				
			Иначе
				
				ТекстПредупреждения =
				НСтр("ru = 'В состоянии ""%1"" существуют заявки.
				|Измените состояние у <a href = ""%2"">таких заявок</a> или переведите их в заказы, чтобы отключить настройку'");
				
			КонецЕсли;
			
			ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
			ТекстПредупреждения,
			ПредставленияСостояний[0],
			РезультатПроверки.НавигационнаяСсылка);
			
		КонецЕсли;
		
	Иначе
		
		ПредставлениеСостояний = ПредставлениеСостоянийСтрокой(ПредставленияСостояний);
		
		Если ИспользоватьВидыЗаказов Тогда
			
			Если ЗаявкиОтключаютсяПолностью Тогда
				
				ТекстПредупреждения =
				НСтр("ru = 'В виде ""%1"" в состояниях ""%2"" существуют заявки.
				|Переведите <a href = ""%3"">такие заявки</a> в заказы, чтобы режим ""Заявки"" можно было полностью отключить для данного вида заказов'");
				
			Иначе
				
				ТекстПредупреждения =
				НСтр("ru = 'В виде ""%1"" в состояниях ""%2"" существуют заявки.
				|Измените состояние у <a href = ""%3"">таких заявок</a> или переведите их в заказы, чтобы отключить настройку'");
				
			КонецЕсли;
			
			ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
			ТекстПредупреждения,
			НаименованиеВидаЗаказа,
			ПредставлениеСостояний,
			РезультатПроверки.НавигационнаяСсылка);
			
		Иначе
			
			Если ЗаявкиОтключаютсяПолностью Тогда
				
				ТекстПредупреждения =
				НСтр("ru = 'В состояниях %1 существуют заявки.
				|Переведите <a href = ""%2"">такие заявки</a> в заказы, чтобы режим ""Заявки"" можно было полностью отключить'");
				
			Иначе
				
				ТекстПредупреждения =
				НСтр("ru = 'В состояниях %1 существуют заявки.
				|Измените состояние у <a href = ""%2"">таких заявок</a> или переведите их в заказы, чтобы отключить настройку'");
				
			КонецЕсли;
			
			ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
			ТекстПредупреждения,
			ПредставлениеСостояний,
			РезультатПроверки.НавигационнаяСсылка);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат.ДанныеПредупреждения.Текст = ТекстПредупреждения;
	Возврат Результат;
	
КонецФункции

Функция ОбработатьИспользованиеСостоянийВЗаказах(РезультатПроверки, Параметры)
	
	Результат = НовыйРезультатОбработкиРезультатаПроверкиИспользованияСостояний();
	
	ИспользоватьВидыЗаказов = Параметры.ИспользоватьВидыЗаказов;
	НаименованиеВидаЗаказа = Параметры.НаименованиеВидаЗаказа;
	ЗаявкиИспользуютсяДляВида = Параметры.ЗаявкиИспользуютсяДляВида;
	СтроковыеФункцииМодуль = Параметры.СтроковыеФункцииМодуль;
	
	ПредставленияСостояний = ПредставленияСостоянийПослеПроверки(РезультатПроверки);
	Если ПредставленияСостояний.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТекстПредупреждения = "";
	ТекстВопроса = "";
	
	Если ПредставленияСостояний.Количество() = 1 Тогда
		
		Если ИспользоватьВидыЗаказов Тогда
			
			Если ЗаявкиИспользуютсяДляВида Тогда
				
				ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
				НСтр("ru = 'В виде ""%1"" в состоянии ""%2"" существуют заказы.
				|Измените состояние у <a href =""%3"">таких заказов</a>, чтобы включить использование заявок'"),
				НаименованиеВидаЗаказа,
				ПредставленияСостояний[0],
				РезультатПроверки.НавигационнаяСсылка);
				
			Иначе
				
				ТекстВопроса = СтрШаблон(
				НСтр("ru = 'В виде ""%1"" в состоянии ""%2"" существуют заказы.
				|Чтобы включить заявки, создайте новое состояние
				|или переведите заказы в другое состояние.'"),
				НаименованиеВидаЗаказа,
				ПредставленияСостояний[0]);
				
			КонецЕсли;
			
		Иначе
			
			Если ЗаявкиИспользуютсяДляВида Тогда
				
				ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
				НСтр("ru = 'В состоянии ""%1"" существуют заказы.
				|Измените состояние у <a href = ""%2"">таких заказов</a>, чтобы включить использование заявок'"),
				ПредставленияСостояний[0],
				РезультатПроверки.НавигационнаяСсылка);
				
			Иначе
				
				ТекстВопроса = СтрШаблон(
				НСтр("ru = 'В состоянии ""%1"" существуют заказы.
				|Чтобы включить заявки, создайте новое состояние
				|или переведите заказы в другое состояние.'"),
				ПредставленияСостояний[0]);
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ПредставлениеСостояний = ПредставлениеСостоянийСтрокой(ПредставленияСостояний);
		
		Если ИспользоватьВидыЗаказов Тогда
			
			Если ЗаявкиИспользуютсяДляВида Тогда
				
				ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
				НСтр("ru = 'В виде ""%1"" в состояниях %2 существуют <a href = ""%2"">заказы</a>.
				|Измените состояние у <a href = ""%3"">таких заказов</a>, чтобы включить использование заявок'"),
				НаименованиеВидаЗаказа,
				ПредставлениеСостояний,
				РезультатПроверки.НавигационнаяСсылка);
				
			Иначе
				
				ТекстВопроса = СтрШаблон(
				НСтр("ru = 'В виде ""%1"" в состояниях ""%2"" существуют заказы.
				|Чтобы включить заявки, создайте новое состояние
				|или переведите заказы в другое состояние.'"),
				НаименованиеВидаЗаказа,
				ПредставлениеСостояний);
				
			КонецЕсли;
			
		Иначе
			
			Если ЗаявкиИспользуютсяДляВида Тогда
				
				ТекстПредупреждения = СтроковыеФункцииМодуль.ФорматированнаяСтрока(
				НСтр("ru = 'В состояниях ""%1"" существуют заказы.
				|Измените состояние у <a href = ""%2"">таких заказов</a>, чтобы включить использование заявок'"),
				ПредставлениеСостояний,
				РезультатПроверки.НавигационнаяСсылка);
				
			Иначе
				
				ТекстВопроса = СтрШаблон(
				НСтр("ru = 'В состояниях ""%1"" существуют заказы.
				|Чтобы включить заявки, создайте новое состояние
				|или переведите заказы в другое состояние.'"),
				ПредставлениеСостояний);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстПредупреждения) Тогда
		Результат.ДанныеПредупреждения.Текст = ТекстПредупреждения;
	Иначе
		Результат.ДанныеВопроса.Текст = ТекстВопроса;
		Результат.ДанныеВопроса.НавигационнаяСсылкаОбъекта = РезультатПроверки.НавигационнаяСсылка;
		Результат.ДанныеВопроса.ТекстКнопкиПереходаКОбъекту = НСтр("ru = 'Перейти к заказам'");
