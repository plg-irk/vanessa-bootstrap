Функция ОбработатьИспользованиеСостоянийВДругихНастройкахКартыПроцессов(РезультатПроверки, Параметры)
	
	Результат = НовыйРезультатОбработкиРезультатаПроверкиИспользованияСостояний();
	
	ЗаявкиИспользуютсяДляВида = Параметры.ЗаявкиИспользуютсяДляВида;
	
	ТекстПредупреждения = "";
	ТекстВопроса = "";
	
	Если РезультатПроверки.СостояниеОжидаетОтгрузки.Перекрывается Тогда
		
		Если ЗаявкиИспользуютсяДляВида Тогда
			
			ТекстПредупреждения = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" включена работа с маршрутными листами.
			|Чтобы включить заявки, измените состояние ожидания отгрузки заказов'"),
			РезультатПроверки.СостояниеОжидаетОтгрузки.Представление);
			
		Иначе
			
			ТекстВопроса = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" включена работа с маршрутными листами.
			|Чтобы включить заявки, создайте новое состояние
			|или измените состояние ожидания отгрузки заказов'"),
			РезультатПроверки.СостояниеОжидаетОтгрузки.Представление);
			
		КонецЕсли;
		
	ИначеЕсли РезультатПроверки.СостояниеОтгружен.Перекрывается Тогда
		
		Если ЗаявкиИспользуютсяДляВида Тогда
			
			ТекстПредупреждения = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" включена работа с маршрутными листами.
			|Чтобы включить заявки, измените состояние отгруженных заказов'"),
			РезультатПроверки.СостояниеОтгружен.Представление);
			
		Иначе
			
			ТекстВопроса = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" включена работа с маршрутными листами.
			|Чтобы включить заявки, создайте новое состояние
			|или измените состояние отгруженных заказов'"),
			РезультатПроверки.СостояниеОтгружен.Представление);
			
		КонецЕсли;
		
	ИначеЕсли РезультатПроверки.СостояниеДоставлен.Перекрывается Тогда
		
		Если ЗаявкиИспользуютсяДляВида Тогда
			
			ТекстПредупреждения = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" включена работа с маршрутными листами.
			|Чтобы включить заявки, измените состояние доставленных заказов'"),
			РезультатПроверки.СостояниеДоставлен.Представление);
			
		Иначе
			
			ТекстВопроса = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" включена работа с маршрутными листами.
			|Чтобы включить заявки, создайте новое состояние
			|или измените состояние доставленных заказов'"),
			РезультатПроверки.СостояниеДоставлен.Представление);
			
		КонецЕсли;
		
	ИначеЕсли РезультатПроверки.СостояниеВыполнения.Перекрывается Тогда
		
		Если ЗаявкиИспользуютсяДляВида Тогда
			
			ТекстПредупреждения = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" заказ имеет режим ""Выполнение"".
			|Для включения режима ""Заявка"" отключите режим ""Выполнение""'"),
			РезультатПроверки.СостояниеВыполнения.Представление);
			
		Иначе
			
			ТекстВопроса = СтрШаблон(
			НСтр("ru = 'В состоянии ""%1"" заказ имеет режим ""Выполнение"".
			|Для включения режима ""Заявка"" создайте новое состояние
			|или отключите режим ""Выполнение""'"),
			РезультатПроверки.СостояниеВыполнения.Представление);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстПредупреждения) Тогда
		Результат.ДанныеПредупреждения.Текст = ТекстПредупреждения;
	Иначе
		Результат.ДанныеВопроса.Текст = ТекстВопроса;
	КонецЕсли;
	
	Возврат Результат;
	
