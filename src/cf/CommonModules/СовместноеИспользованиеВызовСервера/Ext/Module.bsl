#Область СлужебныйПрограммныйИнтерфейс

Функция ДанныеСообщенияВнешнемуСайту(Действие, Отправитель, Получатель, ДополнительныеПараметры) Экспорт
	
	СтруктураСообщения = Новый Структура;
	СтруктураСообщения.Вставить("Действие", Действие);
	СтруктураСообщения.Вставить("Отправитель", Отправитель);
	СтруктураСообщения.Вставить("Получатель", Получатель);
	СтруктураСообщения.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
	
	Возврат ОбщегоНазначения.ЗначениеВJSON(СтруктураСообщения);
	
КонецФункции

Функция ОписаниеДействияОтВнешнегоПриложения(Данные) Экспорт
	
	ДанныеСообщения = ОбщегоНазначения.JSONВЗначение(Данные);
	
	Если ДанныеСообщения.Получить("Действие") = "ОтправитьСообщение" Тогда
		ДополнительныеПараметры = ДанныеСообщения.Получить("ДополнительныеПараметры");
		
		Действие = ДополнительныеПараметры.Получить("Действие");
		ПараметрыДействия = ДополнительныеПараметры.Получить("Параметры");
		Если Действие = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Возврат Новый Структура("Действие,ПараметрыДействия", Действие, ПараметрыДействия);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция АдресВнешнегоПриложения() Экспорт
	
	Результат = Новый Структура("АдресПриложения,ВнешняяУчетнаяСистема", "", Ложь);
	
	НаборЗаписей = РегистрыСведений.НастройкиИнтеграцииСБухгалтерией.СоздатьНаборЗаписей();
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() > 0 Тогда
		ЗаполнитьЗначенияСвойств(Результат, НаборЗаписей[0]);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция АльтернативнаяСсылкаДляПрямогоПерехода(ИсходнаяСсылка) Экспорт
	
	Возврат "СовместноеИспользование/АльтернативнаяСсылка?src-link=" + КодироватьСтроку(ИсходнаяСсылка, СпособКодированияСтроки.КодировкаURL);
	
КонецФункции

