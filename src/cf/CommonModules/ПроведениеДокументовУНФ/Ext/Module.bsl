Процедура ЗаполнитьОбъектПоСтроке(НоваяСтрока, ВариантИсключений, ВерхнийУровень)
	
	ИмяКолонки = ?(ЗначениеЗаполнено(НоваяСтрока.Объект), "Объект", "Номенклатура");
	
	Если ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоНоменклатуре Тогда
		
		НоваяСтрока.Объект = НоваяСтрока[ИмяКолонки].Родитель;
		Если Не НоваяСтрока.Объект.Пустая() Тогда
			ВерхнийУровень = (НоваяСтрока.Объект.Уровень() = 0);
		Иначе
			ВерхнийУровень = Истина;
		КонецЕсли;
		
	ИначеЕсли ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоКатегориям Тогда
		
		Если ИмяКолонки = "Объект" Тогда
			НоваяСтрока.Объект = НоваяСтрока[ИмяКолонки].Родитель;
		Иначе
			НоваяСтрока.Объект = НоваяСтрока[ИмяКолонки].КатегорияНоменклатуры;
		КонецЕсли;
		Если Не НоваяСтрока.Объект.Пустая() Тогда
			ВерхнийУровень = (НоваяСтрока.Объект.Уровень() = 0);
		Иначе
			ВерхнийУровень = Истина;
		КонецЕсли;
		
	ИначеЕсли ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоЦеновымГруппам Тогда
		
		НоваяСтрока.Объект = НоваяСтрока[ИмяКолонки].ЦеноваяГруппа;
		ВерхнийУровень = Истина;
		
	ИначеЕсли ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоСегменту Тогда
		
		ВерхнийУровень = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ОпределитьОписаниеТипаПоВариантуИсключений(ВариантИсключений)
	
	Если ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоНоменклатуре Тогда
		Возврат "СправочникСсылка.Номенклатура";
	ИначеЕсли ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоКатегориям Тогда
		Возврат "СправочникСсылка.КатегорииНоменклатуры";
	ИначеЕсли ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоЦеновымГруппам Тогда
		Возврат "СправочникСсылка.ЦеновыеГруппы";
	ИначеЕсли ВариантИсключений = Перечисления.ВариантыОграниченийСкидокПоНоменклатуре.ПоСегменту Тогда
		Возврат "СправочникСсылка.СегментыНоменклатуры";
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Процедура ПодготовитьПустуюТаблицуИсключений(МенеджерВременныхТаблиц)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НЕОПРЕДЕЛЕНО КАК СтруктурнаяЕдиница
	|ПОМЕСТИТЬ СкладыБезКонтроля
	|ГДЕ
	|	ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НЕОПРЕДЕЛЕНО КАК Номенклатура,
	|	НЕОПРЕДЕЛЕНО КАК СтруктурнаяЕдиница
	|ПОМЕСТИТЬ НоменклатураСкладыБезКонтроля
	|ГДЕ
	|	ЛОЖЬ");
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
КонецПроцедуры

