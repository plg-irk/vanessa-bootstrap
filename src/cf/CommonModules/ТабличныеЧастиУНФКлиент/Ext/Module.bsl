
#Область ПрограммныйИнтерфейс

// Пересчитывает суммы в строке ТЧ
//
// Параметры:
//  СтрокаТабличнойЧасти - ДанныеФормыСтруктура	 - Данные строки таблицы формы
//  ПараметрыРасчета	 - Структура			 - Содержит данные данные документа, необходимые для пересчета
//
Процедура РассчитатьСуммыВСтрокеТЧ(СтрокаТабличнойЧасти, ПараметрыРасчета) Экспорт
	
	Если НЕ ПараметрыРасчета.Свойство("РассчитатьСуммуСкидки") И НЕ ПараметрыРасчета.Свойство("РассчитатьПроцентСкидки") Тогда
		ПараметрыРасчета.Вставить("РассчитатьСуммуСкидки", Истина);
	КонецЕсли;
	
	РассчитатьЦену = Ложь;
	Если НЕ ПараметрыРасчета.Свойство("РассчитатьЦену", РассчитатьЦену) И НЕ ПараметрыРасчета.Свойство("РассчитатьСумму") Тогда
		ПараметрыРасчета.Вставить("РассчитатьСумму", Истина);
	КонецЕсли;
	Если РассчитатьЦену = Неопределено Тогда
		РассчитатьЦену = Ложь;
	КонецЕсли;
	Если СтрокаТабличнойЧасти.Свойство("Кратность") И СтрокаТабличнойЧасти.Свойство("Коэффициент") Тогда
		КоличествоСтроки = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Кратность * СтрокаТабличнойЧасти.Коэффициент;
	Иначе
		КоличествоСтроки = СтрокаТабличнойЧасти.Количество;
	КонецЕсли; 
	
	ЗадаватьВопрос = Ложь;
	КорректировкаСуммыЗаСчетРучнойСкидки = Неопределено;
	ЕстьРучнаяСкидка = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТабличнойЧасти, "СуммаСкидкиНаценки");
	ПараметрыРасчета.Свойство("КорректировкаСуммыЗаСчетРучнойСкидки", КорректировкаСуммыЗаСчетРучнойСкидки);
	Если КорректировкаСуммыЗаСчетРучнойСкидки = Истина Тогда
		ПараметрыРасчета.Вставить("РассчитатьЦену", Ложь);
	ИначеЕсли РассчитатьЦену 
		И КорректировкаСуммыЗаСчетРучнойСкидки = Неопределено 
		И ЕстьРучнаяСкидка Тогда
		// Ранее при изменении суммы строки вручную, всегда происходил пересчет цены. Поэтому флаг передается всегда.
		// Но теперь есть два варианта, как корректировать данные строки - за счет цены, как и ранее, или за счет ручной скидки.
		// Выбор пользователя может сохраняться в персональных настройках. Если там нет сохраненной настройки, то зададим вопрос.
		ВариантРаспределения = ПерсональныеНастройкиРУНФВызовСервера.Прочитать("ВариантИзмененияСуммыДокумента");
		Если ВариантРаспределения = ПредопределенноеЗначение("Перечисление.ВариантыИзмененияСуммыДокумента.ЗаСчетРучнойСкидки") Тогда
			ПараметрыРасчета.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", Истина);
			ПараметрыРасчета.Вставить("РассчитатьЦену", Ложь);
		ИначеЕсли Не ЗначениеЗаполнено(ВариантРаспределения) Тогда
			ЗадаватьВопрос = Истина;
		КонецЕсли;
	КонецЕсли;
	Если ЗадаватьВопрос Тогда
		ДопПараметр = Новый Структура("КоличествоСтроки", КоличествоСтроки);
		ДопПараметр.Вставить("ПараметрыРасчета", ПараметрыРасчета);
		ДопПараметр.Вставить("СтрокаТабличнойЧасти", СтрокаТабличнойЧасти);
		Оповещение = Новый ОписаниеОповещения("ПослеВыбораВариантаРаспределенияСуммы", ЭтотОбъект, ДопПараметр);
		ОткрытьФорму("ОбщаяФорма.ПодтверждениеРаспределенияКорректировкиСуммы", , , , , , Оповещение);
	Иначе
		ПродолжитьРасчетСуммыВСтрокеТЧ(СтрокаТабличнойЧасти, ПараметрыРасчета, КоличествоСтроки);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПослеВыбораВариантаРаспределенияСуммы(Результат, ДополнительныеПараметры) Экспорт
	ПараметрыРасчета = ДополнительныеПараметры.ПараметрыРасчета;
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("КорректировкаСуммыЗаСчетРучнойСкидки") 
			И Результат.КорректировкаСуммыЗаСчетРучнойСкидки Тогда
			ПараметрыРасчета.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", Истина);
			ПараметрыРасчета.Вставить("РассчитатьЦену", Ложь);
		Иначе
			ПараметрыРасчета.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", Ложь);
			ПараметрыРасчета.Вставить("РассчитатьЦену", Истина);
		КонецЕсли;
		Если Результат.Свойство("ЗапрашиватьВариантКорректировкиСуммы") Тогда
			ПараметрыРасчета.Вставить("ЗапрашиватьРаспределение", Результат.ЗапрашиватьВариантКорректировкиСуммы);
		КонецЕсли;
		ПараметрыРасчета.Вставить("ВыполнятьОповещениеФорм", Истина);
	КонецЕсли;
	СтрокаТабличнойЧасти = ДополнительныеПараметры.СтрокаТабличнойЧасти;
	КоличествоСтроки = ДополнительныеПараметры.КоличествоСтроки;
	ПродолжитьРасчетСуммыВСтрокеТЧ(СтрокаТабличнойЧасти, ПараметрыРасчета, КоличествоСтроки);
КонецПроцедуры

Процедура ПродолжитьРасчетСуммыВСтрокеТЧ(СтрокаТабличнойЧасти, ПараметрыРасчета, КоличествоСтроки)

	ВыполнятьОповещениеФорм = ПараметрыРасчета.Свойство("ВыполнятьОповещениеФорм") И ПараметрыРасчета.ВыполнятьОповещениеФорм;
	Если СтрокаТабличнойЧасти.Свойство("ПроцентСкидкиНаценки") Тогда
		
		ЕстьСкидкаБонусом = СтрокаТабличнойЧасти.Свойство("СуммаСкидкиОплатыБонусом");
		ЕстьАвтоматическаяСкидка = СтрокаТабличнойЧасти.Свойство("СуммаАвтоматическойСкидки");
		ЕстьРучнаяСкидка = СтрокаТабличнойЧасти.Свойство("СуммаСкидкиНаценки");
		ЕстьЗаказ = СтрокаТабличнойЧасти.Свойство("Заказ") И ЗначениеЗаполнено(СтрокаТабличнойЧасти.Заказ);
		
		ФиксированнаяСуммаАвтоматическихСкидок = Ложь;
		СуммаДоВсехСкидок = КоличествоСтроки * СтрокаТабличнойЧасти.Цена;

		Если ПараметрыРасчета.Свойство("СброситьФлагСкидкиРассчитаны") И ПараметрыРасчета.СброситьФлагСкидкиРассчитаны
			И ЕстьАвтоматическаяСкидка Тогда
			СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки = 0;
			СтрокаТабличнойЧасти.ПроцентАвтоматическойСкидки = 0;
		ИначеЕсли ЕстьАвтоматическаяСкидка И ЕстьЗаказ Тогда			
			ФиксированнаяСуммаАвтоматическихСкидок = Истина;
		ИначеЕсли ЕстьАвтоматическаяСкидка И СуммаДоВсехСкидок = 0 Тогда
			СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки = 0;
			СтрокаТабличнойЧасти.ПроцентАвтоматическойСкидки = 0;
		ИначеЕсли ЕстьАвтоматическаяСкидка Тогда
			// Оптимистичный сценарий, что процент скидки не изменится
			ПроцентАвтоматическойСкидки = 100 * СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки / СуммаДоВсехСкидок;
			СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки = Окр(СуммаДоВсехСкидок * ПроцентАвтоматическойСкидки / 100, 2);			
		КонецЕсли;
		
		СуммаОплатБонусом = ?(ЕстьСкидкаБонусом, СтрокаТабличнойЧасти.СуммаСкидкиОплатыБонусом, 0); 
		СуммаРучныхСкидок = ?(ЕстьРучнаяСкидка, СтрокаТабличнойЧасти.СуммаСкидкиНаценки, 0);	
		СуммаАвтоматическихСкидок = ?(ЕстьАвтоматическаяСкидка, СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки, 0);
		СуммаСкидок = СуммаРучныхСкидок + СуммаАвтоматическихСкидок + СуммаОплатБонусом;
		СуммаДоРучнойСкидки = СуммаДоВсехСкидок - СуммаОплатБонусом - СуммаАвтоматическихСкидок;		
		
		Если ПараметрыРасчета.Свойство("РассчитатьЦену") И ПараметрыРасчета.РассчитатьЦену = Истина Тогда //Введена сумма строки, нужно пересчитать цену и сумму скидки
			Если КоличествоСтроки <> 0 Тогда
				Если СтрокаТабличнойЧасти.ПроцентСкидкиНаценки >= 100 И СуммаДоРучнойСкидки = 0 Тогда
					СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0;
					СтрокаТабличнойЧасти.СуммаСкидкиНаценки = 0;	
				ИначеЕсли СтрокаТабличнойЧасти.ПроцентСкидкиНаценки >= 100 Тогда
					// Если введена сумма строки и скидка 100%, меняем процент скидки
					СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = Окр(100* (1 - СтрокаТабличнойЧасти.Сумма / (СуммаДоРучнойСкидки)), 2);
					СтрокаТабличнойЧасти.СуммаСкидкиНаценки = Окр(СуммаДоВсехСкидок * СтрокаТабличнойЧасти.ПроцентСкидкиНаценки / 100, 2);	
				Иначе
					ПроцентРучной = ?(ЕстьРучнаяСкидка, СтрокаТабличнойЧасти.ПроцентСкидкиНаценки, 0);
					ПроцентАвтоматической = ?(ЕстьАвтоматическаяСкидка, СтрокаТабличнойЧасти.ПроцентАвтоматическойСкидки, 0);
					НоваяСуммаДоСкидок = СуммаСкидок;
					Если ФиксированнаяСуммаАвтоматическихСкидок Тогда
						НоваяСуммаДоСкидок = (СтрокаТабличнойЧасти.Сумма + СуммаОплатБонусом + СуммаАвтоматическихСкидок) / ((100 - ПроцентРучной)/100);	
						ПроцентАвтоматической = 100 * СуммаАвтоматическихСкидок / НоваяСуммаДоСкидок;
					ИначеЕсли ПроцентРучной + ПроцентАвтоматической <> 100 Тогда
						НоваяСуммаДоСкидок = (СтрокаТабличнойЧасти.Сумма + СуммаОплатБонусом) / ((100 - ПроцентРучной - ПроцентАвтоматической)/100);	
					КонецЕсли;
					СтрокаТабличнойЧасти.Цена = Окр(НоваяСуммаДоСкидок / КоличествоСтроки, 2);
					Если ЕстьРучнаяСкидка Тогда
						СтрокаТабличнойЧасти.СуммаСкидкиНаценки = Окр(НоваяСуммаДоСкидок * ПроцентРучной / 100, 2);
						СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = Окр(ПроцентРучной, 2);
					КонецЕсли;
					Если ЕстьАвтоматическаяСкидка Тогда
						// Сумма автоматической скидки подставляем из предположения, что процент останется тем же.
						// На практике, способы предоставления скидки могут быть разными, и процент может измениться.
						// Однако, это произойдет после нового расчета скидки, что будет более понятным. До пересчета, внутренняя арифметика строки будет сходоится.
						СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки = Окр(НоваяСуммаДоСкидок * ПроцентАвтоматической / 100, 2);
						СтрокаТабличнойЧасти.ПроцентАвтоматическойСкидки = Окр(ПроцентАвтоматической, 2);
					КонецЕсли;
					Если ЕстьРучнаяСкидка и ЕстьАвтоматическаяСкидка Тогда                                                                                                        
						// Возможные ошибки округления
						ОшибкаОкругления = НоваяСуммаДоСкидок * (ПроцентАвтоматической+ПроцентРучной)/100 - СтрокаТабличнойЧасти.СуммаСкидкиНаценки - СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки;
						СтрокаТабличнойЧасти.СуммаСкидкиНаценки = СтрокаТабличнойЧасти.СуммаСкидкиНаценки + ОшибкаОкругления;
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ПараметрыРасчета.Свойство("КорректировкаСуммыЗаСчетРучнойСкидки") И ПараметрыРасчета.КорректировкаСуммыЗаСчетРучнойСкидки = Истина Тогда //Введена сумма строки, нужно пересчитать цену и сумму скидки
			Если КоличествоСтроки <> 0 Тогда
				СуммаРучныхСкидок = СуммаДоРучнойСкидки - СтрокаТабличнойЧасти.Сумма;
				СуммаСкидок = СуммаРучныхСкидок + СуммаАвтоматическихСкидок + СуммаОплатБонусом;				
				СтрокаТабличнойЧасти.СуммаСкидкиНаценки = СуммаРучныхСкидок;
				Если НЕ СуммаДоВсехСкидок = 0 Тогда
					СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = Окр(100 * СуммаРучныхСкидок / СуммаДоВсехСкидок, 2);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ПараметрыРасчета.Свойство("РассчитатьПроцентСкидки") И ПараметрыРасчета.РассчитатьПроцентСкидки Тогда //Введена сумма скидки, нужно пересчитать процент скидки
			
			Если СуммаДоВсехСкидок = 0 Тогда
				СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0;
				СтрокаТабличнойЧасти.Сумма = Макс(СуммаДоВсехСкидок - СуммаСкидок, 0);
				СтрокаТабличнойЧасти.СуммаСкидкиНаценки = СуммаДоВсехСкидок - СтрокаТабличнойЧасти.Сумма - СуммаАвтоматическихСкидок - СуммаОплатБонусом; 
			ИначеЕсли СтрокаТабличнойЧасти.СуммаСкидкиНаценки >= СуммаДоВсехСкидок - СуммаОплатБонусом - СуммаАвтоматическихСкидок Тогда
				СтрокаТабличнойЧасти.СуммаСкидкиНаценки = СуммаДоВсехСкидок - СуммаОплатБонусом - СуммаАвтоматическихСкидок;
				СуммаРучныхСкидок = СтрокаТабличнойЧасти.СуммаСкидкиНаценки;
				СуммаСкидок = СуммаРучныхСкидок + СуммаАвтоматическихСкидок + СуммаОплатБонусом;				
				СтрокаТабличнойЧасти.Сумма = 0;
				СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = Окр(100 * СуммаРучныхСкидок / СуммаДоВсехСкидок, 2);
			Иначе
				СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = Окр(100 * СуммаРучныхСкидок / СуммаДоВсехСкидок, 2);
				СтрокаТабличнойЧасти.Сумма = СуммаДоВсехСкидок - СуммаСкидок;
			КонецЕсли;
			
		Иначе  // Если введен процент скидки, или если указаны и процент, и сумма, пересчитываем сумму скидки из процента, указанного в строке
			СуммаРучныхСкидок = Окр(СуммаДоВсехСкидок * СтрокаТабличнойЧасти.ПроцентСкидкиНаценки / 100, 2);
			СуммаСкидок = СуммаРучныхСкидок + СуммаАвтоматическихСкидок + СуммаОплатБонусом;
			СтрокаТабличнойЧасти.СуммаСкидкиНаценки = СуммаРучныхСкидок;
			СтрокаТабличнойЧасти.Сумма = СуммаДоВсехСкидок - СуммаСкидок;  			
		КонецЕсли; 		
		
		Если СтрокаТабличнойЧасти.Сумма >= 0 Тогда
			
			ЦенообразованиеКлиентСервер.ПересчитатьСтрокуТЧПоМинимальнымЦенам(СтрокаТабличнойЧасти, КоличествоСтроки, ПараметрыРасчета);
			
		КонецЕсли;	
	Иначе 	
		Если ПараметрыРасчета.Свойство("РассчитатьЦену") И ПараметрыРасчета.РассчитатьЦену = Истина Тогда //Введена сумма строки, нужно пересчитать цену с сумму скидки
			СтрокаТабличнойЧасти.Цена = ?(КоличествоСтроки=0, 0, СтрокаТабличнойЧасти.Сумма / КоличествоСтроки);
		Иначе
			СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Цена * КоличествоСтроки;
		КонецЕсли;
	КонецЕсли;
	
	Если СтрокаТабличнойЧасти.Свойство("СуммаСкидки") Тогда
		СтрокаТабличнойЧасти.СуммаСкидки = СтрокаТабличнойЧасти.СуммаСкидкиНаценки;
	КонецЕсли; 
	
	Если СтрокаТабличнойЧасти.Свойство("СтавкаНДС") Тогда
		РассчитатьСуммуНДСИВсего(СтрокаТабличнойЧасти, ПараметрыРасчета); 
	КонецЕсли; 
	
	Если ВыполнятьОповещениеФорм Тогда
		Оповестить("ИзменениеСуммыСтроки",ПараметрыРасчета, СтрокаТабличнойЧасти);
	КонецЕсли;
	
КонецПроцедуры

// Пересчитывает сумму НДС и Всего
//
// Параметры:
//  СтрокаТабличнойЧасти - ДанныеФормыСтруктура	 - Данные строки таблицы формы
//  ПараметрыРасчета	 - Структура			 - Содержит данные данные документа, необходимые для пересчета
//
Процедура РассчитатьСуммуНДСИВсего(СтрокаТабличнойЧасти, ПараметрыРасчета) Экспорт
	
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
	
	СтрокаТабличнойЧасти.СуммаНДС = ?(ПараметрыРасчета.СуммаВключаетНДС, 
									  СтрокаТабличнойЧасти.Сумма - (СтрокаТабличнойЧасти.Сумма) / ((СтавкаНДС + 100) / 100),
									  СтрокаТабличнойЧасти.Сумма * СтавкаНДС / 100);
									  
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТабличнойЧасти, "Всего") Тогда
		СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + ?(ПараметрыРасчета.СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТабличнойЧасти, "СуммаСНДС") Тогда // в документе ВыводИзОборотаИСМП
		СтрокаТабличнойЧасти.СуммаСНДС = СтрокаТабличнойЧасти.Сумма + ?(ПараметрыРасчета.СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
	КонецЕсли;
	
КонецПроцедуры

// Пересчитывает стоимость с учетом изменений по НДС от 2018 г.
//
// Параметры:
//  СтоимостьТекущая - Число - Стоимость до пересчета
//  СтавкаНДСТекущая - Число - Текущая ставка НДС
//  СтавкаНДСНовая	 - Число - Новая ставка НДС
// 
// Возвращаемое значение:
//  Число - Стоимость после пересчета
//
Функция НоваяСтоимостьСУчетомИзмененийПоНДС2018(СтоимостьТекущая, СтавкаНДСТекущая, СтавкаНДСНовая) Экспорт
	
	СтавкаНДСРасчетная = СтавкаНДСТекущая + 100;
	
	СтоимостьНовая = (СтоимостьТекущая - (СтоимостьТекущая*СтавкаНДСТекущая/СтавкаНДСРасчетная)) + (СтоимостьТекущая - (СтоимостьТекущая*СтавкаНДСТекущая/СтавкаНДСРасчетная)) * СтавкаНДСНовая / 100;
	
	Возврат СтоимостьНовая;
	
КонецФункции

// Добавляет ключ связи в табличную часть.
//
// Параметры:
//  ФормаДокумента	 - ФормаКлиентскогоПриложения	 - Форма документа, реквизиты которой обрабатываются процедурой
//  Строка			 - ДанныеФормыСтруктура			 - Данные текущей строки таблицы формы
//
Процедура ДобавитьКлючСвязиВСтрокуТабличнойЧасти(ФормаДокумента, Строка = Неопределено) Экспорт
	
	Если Строка <> Неопределено Тогда
		СтрокаТабличнойЧасти = Строка;
	Иначе
		СтрокаТабличнойЧасти = ФормаДокумента.Элементы[ФормаДокумента.ИмяТабличнойЧасти].ТекущиеДанные;
	КонецЕсли;
	
	СтрокаТабличнойЧасти.КлючСвязи = ТабличныеЧастиУНФКлиентСервер.СоздатьНовыйКлючСвязи(ФормаДокумента);
	
КонецПроцедуры

// Добавляет ключ связи в подчиненную табличную часть.
//
// Параметры:
//  ФормаДокумента				 - ФормаКлиентскогоПриложения	 - Форма документа, реквизиты которой обрабатываются процедурой
//	ИмяПодчиненнойТабличнойЧасти - Строка						 - Имя подчиненной табличной части
//  Строка						 - ДанныеФормыСтруктура			 - Данные текущей строки таблицы формы
//
Процедура ДобавитьКлючСвязиВСтрокуПодчиненнойТабличнойЧасти(ФормаДокумента, ИмяПодчиненнойТабличнойЧасти, Строка = Неопределено) Экспорт
	
	ПодчиненнаяТабличнаяЧасть = ФормаДокумента.Элементы[ИмяПодчиненнойТабличнойЧасти];
	
	Если Строка = Неопределено Тогда
		СтрокаПодчиненнойТабличнойЧасти = ПодчиненнаяТабличнаяЧасть.ТекущиеДанные;
	Иначе
		СтрокаПодчиненнойТабличнойЧасти = Строка;
	КонецЕсли;
	СтрокаПодчиненнойТабличнойЧасти.КлючСвязи = ПодчиненнаяТабличнаяЧасть.ОтборСтрок["КлючСвязи"];
	
	СтрОтбора = Новый ФиксированнаяСтруктура("КлючСвязи", ПодчиненнаяТабличнаяЧасть.ОтборСтрок["КлючСвязи"]);
	ФормаДокумента.Элементы[ИмяПодчиненнойТабличнойЧасти].ОтборСтрок = СтрОтбора;

КонецПроцедуры

// Проверка выбора основной строки перед операциями с подчиненной ТЧ.
//
// Параметры:
//  ФормаДокумента				 - ФормаКлиентскогоПриложения	 - Форма документа, реквизиты которой обрабатываются процедурой
//	ИмяПодчиненнойТабличнойЧасти - Строка						 - Имя подчиненной табличной части
//
// Возвращаемое значение:
//  Булево - Истина, если строка не выбрана
//
Функция НеВыбранаСтрокаОсновнойТЧ(ФормаДокумента, ИмяПодчиненнойТабличнойЧасти) Экспорт

	Если ФормаДокумента.Элементы[ФормаДокумента.ИмяТабличнойЧасти].ТекущиеДанные = Неопределено Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Не выбрана строка основной табличной части.'");
		Сообщение.Сообщить();
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		
КонецФункции

// Удаляет строки из подчиненной табличной части.
//
// Параметры:
//  ФормаДокумента				 - ФормаКлиентскогоПриложения	 - Форма документа, реквизиты которой обрабатываются процедурой
//	ИмяПодчиненнойТабличнойЧасти - Строка						 - Имя подчиненной табличной части
//
Процедура УдалитьСтрокиПодчиненнойТабличнойЧасти(ФормаДокумента, ИмяПодчиненнойТабличнойЧасти, ОтменаСтроки = Ложь, СтрокаТабличнойЧасти = Неопределено) Экспорт
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		СтрокаТабличнойЧасти = ФормаДокумента.Элементы[ФормаДокумента.ИмяТабличнойЧасти].ТекущиеДанные;
	КонецЕсли;
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПодчиненнаяТабличнаяЧасть = ФормаДокумента.Объект[ИмяПодчиненнойТабличнойЧасти];
	
	РезультатПоиска = ПодчиненнаяТабличнаяЧасть.НайтиСтроки(Новый Структура("КлючСвязи", СтрокаТабличнойЧасти.КлючСвязи));
	Для каждого СтрокаПоиска Из  РезультатПоиска Цикл
		
		ИндексУдаления = ПодчиненнаяТабличнаяЧасть.Индекс(СтрокаПоиска);
		Если НЕ ОтменаСтроки Тогда
			ПодчиненнаяТабличнаяЧасть.Удалить(ИндексУдаления);
		Иначе
			СтрокаПоиска.Отменен = СтрокаТабличнойЧасти.Отменен;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Устанавливает отбор на подчиненную табличную часть.
//
// Параметры:
//  ФормаДокумента				 - ФормаКлиентскогоПриложения	 - Форма документа, реквизиты которой обрабатываются процедурой
//	ИмяПодчиненнойТабличнойЧасти - Строка						 - Имя подчиненной табличной части
//  Строка						 - ДанныеФормыСтруктура			 - Данные текущей строки таблицы формы
//
Процедура УстановитьОтборНаПодчиненнуюТабличнуюЧасть(ФормаДокумента, ИмяПодчиненнойТабличнойЧасти, Строка = Неопределено) Экспорт
	
	Если Строка <> Неопределено Тогда
		СтрокаТабличнойЧасти = Строка;
	Иначе
		СтрокаТабличнойЧасти = ФормаДокумента.Элементы[ФормаДокумента.ИмяТабличнойЧасти].ТекущиеДанные;
	КонецЕсли;
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	СтрОтбора = Новый ФиксированнаяСтруктура("КлючСвязи", СтрокаТабличнойЧасти.КлючСвязи);
	ФормаДокумента.Элементы[ИмяПодчиненнойТабличнойЧасти].ОтборСтрок = СтрОтбора;
	
КонецПроцедуры

#КонецОбласти


 
