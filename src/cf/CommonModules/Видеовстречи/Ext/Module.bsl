
#Область ПрограммныйИнтерфейс

// Создать видеовстречу.
// 
// Параметры:
//  ОписаниеВидеовстречи - см. ВидеовстречиКлиентСервер.ОписаниеВидеовстречи
// 
// Возвращаемое значение:
//  Структура - см. ВидеовстречиКлиентСервер.РезультатСозданияВидеовстречи
//
Функция СоздатьВидеовстречу(ОписаниеВидеовстречи) Экспорт
	
	Результат = ВидеовстречиКлиентСервер.РезультатСозданияВидеовстречи();
	
	СоздатьОбсуждение(ОписаниеВидеовстречи, Результат);
	ЗаполнитьАдресОбсуждения(Результат);
	ОтправитьУведомлениеВОбсуждение(ОписаниеВидеовстречи.ОтправитьСсылкуПриглашениеВОбсуждение, Результат);
	ДобавитьЗаписьВИсториюДействий(ОписаниеВидеовстречи, Результат);
	СоздатьСобытие(ОписаниеВидеовстречи, Результат);
	
	Возврат Результат;

КонецФункции

// См. ПодключаемыеКомандыПереопределяемый.ПриОпределенииКомандПодключенныхКОбъекту
Процедура ПриОпределенииКомандПодключенныхКОбъекту(НастройкиФормы, Источники, ПодключенныеОтчетыИОбработки, Команды) Экспорт
	
	Если Не ИспользованиеФункционалаДоступно() Тогда
		Возврат;
	КонецЕсли;
	
	Команда								= Команды.Добавить();
	Команда.Вид							= "Отправить";
	Команда.Идентификатор				= "ПригласитьВОбсуждениеВидеозвонок";
	Команда.Представление				= НСтр("ru = 'Пригласить в обсуждение/видеозвонок'");
	Команда.Важность					= "СмТакже";
	Команда.Порядок						= 210;
	Команда.ОтображениеКнопки			= ОтображениеКнопки.Картинка;
	Команда.Картинка					= БиблиотекаКартинок.НачатьВидеоконференцию;
	Команда.ТипПараметра				= Метаданные.ОпределяемыеТипы.ОснованиеВидеовстречи.Тип;
	Команда.ИзменяетВыбранныеОбъекты	= Ложь;
	Команда.РежимЗаписи					= "Записывать";
	Команда.Обработчик					= "ВидеовстречиКлиент.ОткрытьФормуСозданияВстречи";
	Команда.МножественныйВыбор 			= Ложь;
	Команда.ТолькоВоВсехДействиях		= Ложь;  
	
КонецПроцедуры

// Проверяет доступность использования функционала в зависимости от версии платформы.
//
// Возвращаемое значение:
//  Булево
//
Функция ИспользованиеФункционалаДоступно() Экспорт
	
	СистемнаяИнформация = Новый СистемнаяИнформация;
	ТекущаяВерсияПлатформы = СистемнаяИнформация.ВерсияПриложения;
	НеобходимаяВерсияПлатформы = "8.3.26.1498";
	
	Возврат ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ТекущаяВерсияПлатформы, НеобходимаяВерсияПлатформы) >= 0;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СоздатьОбсуждение(ОписаниеВидеовстречи, Результат)

	НовоеОбсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
	НовоеОбсуждение.Групповое 		= Истина;
	НовоеОбсуждение.Отображаемое 	= Истина;
	
	// Из-за особенностей Системы Взаимодействия требуется дополнительная проверка
	Если Не ПустаяСтрока(ОписаниеВидеовстречи.Тема) Тогда
		НовоеОбсуждение.Заголовок = ОписаниеВидеовстречи.Тема;
	КонецЕсли;
	
	НовоеОбсуждение.Участники.Добавить(
		СистемаВзаимодействия.ИдентификаторТекущегоПользователя());
	
	Попытка
		
		УстановитьПривилегированныйРежим(Истина);
		НовоеОбсуждение.Записать();	
		УстановитьПривилегированныйРежим(Ложь);
		
	Исключение 
		
		ИмяСобытия = ВидеовстречиКлиентСервер.НаименованиеСобытияЖурналаРегистрации();
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , ,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		
		Результат.Отказ = Истина;
		Результат.ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);

		Возврат;
		
	КонецПопытки;
	
	Результат.ИдентификаторОбсуждения = НовоеОбсуждение.Идентификатор;
	Результат.ОбсуждениеСоздано = Истина;
	
КонецПроцедуры

Процедура ЗаполнитьАдресОбсуждения(Результат)

	Если Результат.Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		
		УстановитьПривилегированныйРежим(Истина);
		
		Параметры = Новый Структура("ИдентификаторОбсуждения", Результат.ИдентификаторОбсуждения);
		АдресОбсуждения = ОбщегоНазначения.ВычислитьВБезопасномРежиме(
			"СистемаВзаимодействия.ПолучитьНавигационнуюСсылкуПриглашенияВОбсуждение(Параметры.ИдентификаторОбсуждения, Ложь)",
			Параметры);		

		УстановитьПривилегированныйРежим(Ложь);
		
	Исключение
		
		ИмяСобытия = ВидеовстречиКлиентСервер.НаименованиеСобытияЖурналаРегистрации();
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , ,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		
		Результат.Отказ = Истина;
		Результат.ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);
		
		Возврат;
		
	КонецПопытки;
	
	Результат.АдресОбсуждения = АдресОбсуждения;
	Результат.ВнешнийАдресОбсуждения = КодироватьСтроку(АдресОбсуждения, СпособКодированияСтроки.КодировкаURL);
	
КонецПроцедуры

Процедура ОтправитьУведомлениеВОбсуждение(ОтправитьСсылкуВОбсуждение, Результат)
	
	Если Результат.Отказ Или Не ОтправитьСсылкуВОбсуждение Тогда
		Возврат;
	КонецЕсли;

	ШаблонСообщения = НСтр("ru='Ссылка-приглашение: 
		|%1'");

	ТекстСообщения = СтрШаблон(ШаблонСообщения, Результат.АдресОбсуждения);
	ДобавитьСообщениеВОбсуждение(Результат.ИдентификаторОбсуждения, ТекстСообщения);

КонецПроцедуры

Процедура ДобавитьЗаписьВИсториюДействий(ОписаниеВидеовстречи, Результат)
	
	Если Результат.Отказ Или Не ОписаниеВидеовстречи.ДобавитьВИсториюДействийПользователя Тогда
		Возврат;
	КонецЕсли;

	ТекстСообщения = СтрШаблон(НСтр("ru='Создано обсуждение: %1'"), Результат.АдресОбсуждения);
	ДобавитьСообщениеВОбсуждение(ОписаниеВидеовстречи.Основание, ТекстСообщения, Истина);
	
КонецПроцедуры

Процедура ДобавитьСообщениеВОбсуждение(ОбъектСообщения, ТекстСообщения, СистемноеСообщение = Ложь)
	
	ДанныеСообщения = ОбсужденияУНФ.НовыйДанныеСообщения();
	ДанныеСообщения.Объект 		= ОбъектСообщения;
	ДанныеСообщения.Текст 		= ТекстСообщения;
	ДанныеСообщения.Дата 		= ТекущаяДатаСеанса();
	ДанныеСообщения.Автор 		= Пользователи.АвторизованныйПользователь();
	ДанныеСообщения.Системный 	= СистемноеСообщение;
	
	ДанныеСообщения.ОтключитьУведомление = Истина;
	
	ОбсужденияУНФ.СоздатьСообщение(ДанныеСообщения);
	
КонецПроцедуры

Процедура СоздатьСобытие(ОписаниеВидеовстречи, Результат)
	
	Если Результат.Отказ Или Не ОписаниеВидеовстречи.СоздатьСобытие Тогда
		Возврат;
	КонецЕсли;
	
	ДокументСобытия = Документы.Событие.СоздатьДокумент();
	ДокументСобытия.Дата 				= ТекущаяДатаСеанса();
	ДокументСобытия.НачалоСобытия 		= ОписаниеВидеовстречи.ДатаНачала;
	ДокументСобытия.ОкончаниеСобытия 	= ОписаниеВидеовстречи.ДатаОкончания;
	ДокументСобытия.Тема 				= ОписаниеВидеовстречи.Тема;
	ДокументСобытия.Содержание 			= ОписаниеВидеовстречи.Содержание;
	ДокументСобытия.КалендарьСотрудника = ОписаниеВидеовстречи.КалендарьСотрудника;
	ДокументСобытия.АдресОбсуждения 	= Результат.АдресОбсуждения;
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ТипСобытия", Перечисления.ТипыСобытий.ЛичнаяВстреча);
	
	Если ТипЗнч(ОписаниеВидеовстречи.Основание) = Тип("СправочникСсылка.Контрагенты") Тогда
		ДанныеЗаполнения.Вставить("Контрагент", ОписаниеВидеовстречи.Основание);
	ИначеЕсли ТипЗнч(ОписаниеВидеовстречи.Основание) = Тип("СправочникСсылка.Лиды") Тогда
		ДанныеЗаполнения.Вставить("Лид", ОписаниеВидеовстречи.Основание);
	Иначе
		ДанныеЗаполнения.Вставить("ОснованиеЗаполнения", ОписаниеВидеовстречи.Основание);
	КонецЕсли;
	
	ДокументСобытия.Заполнить(ДанныеЗаполнения);

	Попытка
		
		ДокументСобытия.Записать();
		
	Исключение
		
		ИмяСобытия = ВидеовстречиКлиентСервер.НаименованиеСобытияЖурналаРегистрации();
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , ,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		
		Результат.Отказ = Истина;
		Результат.ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке);

		Возврат;
		
	КонецПопытки;
	
	Результат.ДокументСобытия = ДокументСобытия.Ссылка;
	Результат.СобытиеСоздано = Истина;
	
КонецПроцедуры

#КонецОбласти 
