 #Область ПрограммныйИнтерфейс
 
// Формирует надпись навигационной ссылки на Счет-фактуру.
// 
// Параметры:
// 	Дата - Дата - дата счета фактуры,
// 	Номер - Строка - номер счета фактуры,
//	НомерДляПечати - Булево - Истина, если номер преобразован для печати
// Возвращаемое значение:
// 	Строка - представление навигационной ссылки счета-фактуры.
Функция ПредставлениеСчетаФактуры(Дата, Номер, НомерДляПечати = Ложь) Экспорт

	Если НомерДляПечати Тогда
		ТекстНомер = Номер;
	Иначе
		ТекстНомер = РаботаСФормойДокументаКлиентСервер.ПолучитьКороткийНомерДокумента(Номер);
	КонецЕсли;
	
	ТекстДата = Формат(Дата, "ДЛФ=D");
	ТекстПроСчетФактуру = СтрШаблон(НСтр("ru = '%1 от %2'"), ТекстНомер, ТекстДата);
	
	Возврат ТекстПроСчетФактуру;

КонецФункции

// Возвращает текст - наименование для документа отгрузки с товарами для строки (5а) счета-фактуры
// 
// Возвращаемое значение:
//   - Строка
//
Функция НаименованиеОтгрузочногоДокументаТовары() Экспорт
	
	Возврат НСтр("ru = 'Товарная накладная'");
	
КонецФункции

// Возвращает текст - наименование для документа отгрузки с услугами для строки (5а) счета-фактуры
// 
// Возвращаемое значение:
//   - Строка
//
Функция НаименованиеОтгрузочногоДокументаУслуги() Экспорт
	
	Возврат НСтр("ru = 'Акт'");
	
КонецФункции

// Возвращает текст - наименование для УПД в качестве документа отгрузки в строке (5а) счета-фактуры
// 
// Возвращаемое значение:
//   - Строка
//
Функция НаименованиеОтгрузочногоДокументаУПД() Экспорт
	
	Возврат НСтр("ru = 'Универсальный передаточный документ'");
	
КонецФункции

// Возвращает текст - наименование для документа отгрузки строки (5а) счета-фактуры в зависимости от типа документа
// 
// Параметры:
//	 - ДокументСсылка - ДокументСсылка - ссылка на документ-основание счета-фактуры
// Возвращаемое значение:
//   - Строка
//
Функция НаименованиеОтгузочногоДокумента(ДокументСсылка) Экспорт
	
	ДокументыУслуги = Новый Массив;
	ДокументыУслуги.Добавить(Тип("ДокументСсылка.АктВыполненныхРабот"));
	ДокументыУслуги.Добавить(Тип("ДокументСсылка.ЗаказПокупателя"));
	ДокументыУслуги.Добавить(Тип("ДокументСсылка.ОтчетКомитенту"));
	ДокументыУслуги.Добавить(Тип("ДокументСсылка.ОтчетОПереработке"));
	ДокументыУслуги.Добавить(Тип("ДокументСсылка.ПриемИПередачаВРемонт"));
	
	Если ДокументыУслуги.Найти(ТипЗнч(ДокументСсылка)) <> Неопределено Тогда
		Возврат НаименованиеОтгрузочногоДокументаУслуги();
	КонецЕсли;
	
	Возврат НаименованиеОтгрузочногоДокументаТовары();
	
КонецФункции

#КонецОбласти