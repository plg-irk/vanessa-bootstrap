
#Область ПрограммныйИнтерфейс

// Описание видеовстречи.
// 
// Возвращаемое значение:
//  Структура - Описание видеовстречи:
// * Основание           - Неопределено - Основание видеовстречи 
// * Тема                - Строка - Тема
// * ДатаНачала          - Дата - Дата начала
// * ДатаОкончания       - Дата - Дата окончания
// * Содержание          - Строка - Содержание
// * СоздатьСобытие      - Булево - Создать документ Событие 
// * КалендарьСотрудника - СправочникСсылка.КалендариСотрудников - Календарь сотрудника для записи события
// * ОтправитьСсылкуПриглашениеВОбсуждение - Булево - Отправить ссылку в обсуждение
// * ДобавитьВИсториюДействийПользователя  - Булево - отразить в истории действия пользователя
// 
Функция ОписаниеВидеовстречи() Экспорт
	
	ОписаниеВидеовстречи = Новый Структура;
	ОписаниеВидеовстречи.Вставить("Основание", 		Неопределено);
	ОписаниеВидеовстречи.Вставить("Тема", 			"");
	ОписаниеВидеовстречи.Вставить("ДатаНачала", 	Дата(1, 1, 1));
	ОписаниеВидеовстречи.Вставить("ДатаОкончания", 	Дата(1, 1, 1));
	
	ОписаниеВидеовстречи.Вставить("ОтправитьСсылкуПриглашениеВОбсуждение", Истина);
	ОписаниеВидеовстречи.Вставить("ДобавитьВИсториюДействийПользователя", Истина);
	
	ОписаниеВидеовстречи.Вставить("Содержание",		"");
	ОписаниеВидеовстречи.Вставить("СоздатьСобытие",	Ложь);
	ОписаниеВидеовстречи.Вставить("КалендарьСотрудника", ПредопределенноеЗначение("Справочник.КалендариСотрудников.ПустаяСсылка"));

	Возврат ОписаниеВидеовстречи;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Результат создания видеовстречи.
// 
// Возвращаемое значение:
//  Структура - Результат создания видеовстречи:
// * Отказ              - Булево - Признак отказа
// * ТекстОшибки        - Строка - Текст ошибки
// * ОбсуждениеСоздано  - Булево - Признак того, что обсуждение было создано
// * СобытиеСоздано     - Булево - Был создан документ Событие
// * АдресОбсуждения    - Строка - Адрес обсуждения
// * ДокументСобытия    - Неопределено, ДокументСсылка.Событие - Ссылка на документ Событие
// * ИдентификаторОбсуждения - Строка - Идентификатор обсуждения Системы Взаимодействия
// * ВнешнийАдресОбсуждения  - Строка - URL обсуждения для гостевого пользователя
// 
Функция РезультатСозданияВидеовстречи() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("Отказ", 					Ложь);
	Результат.Вставить("ТекстОшибки", 				"");
	Результат.Вставить("ОбсуждениеСоздано",			Ложь);
	Результат.Вставить("СобытиеСоздано", 			Ложь);
	Результат.Вставить("ИдентификаторОбсуждения",	"");
	Результат.Вставить("АдресОбсуждения",			"");
	Результат.Вставить("ВнешнийАдресОбсуждения",	"");
	Результат.Вставить("ДокументСобытия", 			Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция НаименованиеСобытияЖурналаРегистрации() Экспорт
	
	Возврат НСтр("ru='Видеовстречи'");
	
КонецФункции

#КонецОбласти
