
#Область ПрограммныйИнтерфейс

// Устанавливает состояние для массива объектов
//
// Параметры:
//  НаименованиеКоманды - Строка - Имя команды установки состояния на форме          
//  ДоступныеСостояния - ДанныеФормыКоллекция - Значение реквизита ДоступныеСостояния формы
//  МассивОбъектов - Массив из ДокументСсылка, СправочникСсылка - изменяемые объекты
//  ОбработанныеТипыОбъектов - Массив из Тип -  Если параметр равен Неопределено, то не заполняется
//
Процедура УстановитьСостояние(НаименованиеКоманды, ДоступныеСостояния, МассивОбъектов, 
	ОбработанныеТипыОбъектов = Неопределено) Экспорт
	
	Если ТипЗнч(МассивОбъектов) <> Тип("Массив") Или МассивОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 
	
	НомерСостояния = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(СтрРазделить(НаименованиеКоманды, "_")[1]);
	
	СостоянияТаблицы = ДоступныеСостояния.НайтиСтроки(Новый Структура("Номер", НомерСостояния));		
	Если Не СостоянияТаблицы.Количество() Тогда
		Возврат;
	КонецЕсли;  

	Состояние = СостоянияТаблицы[0].Состояние;
	КоличествоДокументов = МассивОбъектов.Количество();
	КоличествоИзмененных = 0;
	
	Если КоличествоДокументов = 1 Тогда 
		
		СостоянияДокументовВызовСервера.УстановитьСостояние(Состояние, МассивОбъектов,
			КоличествоИзмененных, ОбработанныеТипыОбъектов);
		
		ТекстОповещения = НСтр("ru='Изменение:'");
		Пояснение = СтрШаблон(НСтр("ru='%1'"), Строка(МассивОбъектов[0]));
		НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(МассивОбъектов[0]);
		ПоказатьОповещениеПользователя(ТекстОповещения, НавигационнаяСсылка, 
			Пояснение, БиблиотекаКартинок.Информация32); 
			
	Иначе

		Состояние(НСтр("ru='Изменение состояния'"), 49);
		
		СостоянияДокументовВызовСервера.УстановитьСостояние(Состояние, МассивОбъектов, КоличествоИзмененных, 
			ОбработанныеТипыОбъектов);
			
		Состояние(НСтр("ru='Изменение состояния'"), 100);
		
		ТекстОповещения = СтрШаблон(НСтр("ru='Изменение (%1)'"), КоличествоИзмененных);
		Пояснение = НСтр("ru='События'");
		ПоказатьОповещениеПользователя(ТекстОповещения, , Пояснение, БиблиотекаКартинок.Информация32);
			
	КонецЕсли;
	
	Если КоличествоДокументов <> КоличествоИзмененных Тогда

		Шаблон = НСтр("ru = ';%1 события;;%1 событий;%1 событий;%1 события'");
		ПредставлениеКоличестваИзмененных = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(Шаблон, 
			КоличествоИзмененных);
					
		ТекстПредупреждения = НСтр("ru='Было изменено состояние для %1 из %2.'");
		ТекстПредупреждения = СтрШаблон(ТекстПредупреждения, ПредставлениеКоличестваИзмененных, КоличествоДокументов);
				 
		ПоказатьПредупреждение( , ТекстПредупреждения); 

	КонецЕсли;

КонецПроцедуры

// Устанавливает отметку "Выполнена" для 
//
// Параметры:
//  МассивОбъектов - Массив из ДокументСсылка.ЗадачаСотрудника
//
Процедура УстановитьОтметкуВыполненияЗадачи(МассивОбъектов) Экспорт
		
	Если ТипЗнч(МассивОбъектов) <> Тип("Массив") Или МассивОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли; 

	КоличествоДокументов = МассивОбъектов.Количество();
	КоличествоИзмененных = 0;
	
	Если КоличествоДокументов = 1 Тогда 
		
		СостоянияДокументовВызовСервера.УстановитьОтметкуВыполненияЗадачи(МассивОбъектов, КоличествоИзмененных);
		
		ТекстОповещения = НСтр("ru='Изменение:'");
		НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(МассивОбъектов[0]);
		Пояснение = СтрШаблон(НСтр("ru='%1'"), Строка(МассивОбъектов[0]));
		
		ПоказатьОповещениеПользователя(ТекстОповещения, НавигационнаяСсылка, Пояснение, БиблиотекаКартинок.Информация32); 
			
	Иначе
		
		Состояние(НСтр("ru='Изменение отметки выполнения'"), 49);
		СостоянияДокументовВызовСервера.УстановитьОтметкуВыполненияЗадачи(МассивОбъектов, КоличествоИзмененных);
		Состояние(НСтр("ru='Изменение отметки выполнения'"), 100);

		ТекстОповещения = СтрШаблон(НСтр("ru='Изменение (%1)'"), КоличествоИзмененных);
		Пояснение = НСтр("ru='Задачи'");
		ПоказатьОповещениеПользователя(ТекстОповещения, , Пояснение, БиблиотекаКартинок.Информация32);
			
	КонецЕсли;
	
	Если КоличествоДокументов <> КоличествоИзмененных Тогда

		Шаблон = НСтр("ru = ';%1 задачи;;%1 задач;%1 задач;%1 задач'");
		ПредставлениеКоличестваИзмененных = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(Шаблон, 
			КоличествоИзмененных);
				
		Шаблон = НСтр("ru='Было изменено состояние для %1 из %2.'");	
		ТекстПредупреждения = СтрШаблон(Шаблон, ПредставлениеКоличестваИзмененных, КоличествоДокументов);
				 
		ПоказатьПредупреждение( , ТекстПредупреждения); 

	КонецЕсли;

КонецПроцедуры

// Возвращает имя события для оповещения форм об изменениях
// 
// Параметры:
//  ТипОбъекта - Тип
// 
// Возвращаемое значение:
//  Строка - Имя события
//
Функция ПолучитьИмяСобытияОповещения(ТипОбъекта) Экспорт
	
	ИменаСобытий = ИменаСобытийОповещений();
	
	Возврат ИменаСобытий.Получить(ТипОбъекта);
		
КонецФункции

// Возвращает соответствие типов объектов именам событий для оповещения форм об изменениях
// 
// Возвращаемое значение:
//  Соответствие:
// * Ключ - Тип 
// * Значение - Строка
//
Функция ИменаСобытийОповещений() Экспорт
	
	ИменаСобытий = Новый Соответствие;
	ИменаСобытий.Вставить(Тип("ДокументСсылка.Событие"), 			"Запись_Событие");
	ИменаСобытий.Вставить(Тип("ДокументСсылка.ЗаданиеНаРаботу"), 	"Запись_ЗаданиеНаРаботу");
	
	Возврат ИменаСобытий;
	
КонецФункции  

// Возвращает документы выделенных событий планировщика для обработки в зависимости от типа.
//
// Параметры:
//  ЭлементПланировщика - ПолеФормы - Обычно Элементы.Планировщик
//
// Возвращаемое значение:
//  Массив из ДокументСсылка
//
Функция ДокументыВыбранныхСобытийПланировщика(ЭлементПланировщика) Экспорт

	ДокументыВыбранныхСобытий = Новый Массив;
	
	Для Каждого ВыбранныйЭлемент Из ЭлементПланировщика.ВыделенныеЭлементы Цикл
		
		ЗаписьКалендаря = ВыбранныйЭлемент.Значение.ЗаписьКалендаря;
		ИсточникЗаписи	= ВыбранныйЭлемент.Значение.Источник;
		
		Если ТипЗНЧ(ЗаписьКалендаря) = Тип("ДокументСсылка.ЗадачаСотрудника") Тогда
			ДокументыВыбранныхСобытий.Добавить(ЗаписьКалендаря);
		ИначеЕсли ЗначениеЗаполнено(ИсточникЗаписи) Тогда
			ДокументыВыбранныхСобытий.Добавить(ИсточникЗаписи);
		Иначе
			Продолжить;
		КонецЕсли; 
		
	КонецЦикла;

	Возврат ДокументыВыбранныхСобытий;
		
КонецФункции

// Документы выбранных событий задачи на весь день.
// 
// Параметры:
//  ЭлементТаблицы - ТаблицаФормы
//  РеквизитФормыТаблицы - РеквизитФормы
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка
//
Функция ДокументыВыбранныхСобытийЗадачиНаВесьДень(ЭлементТаблицы, РеквизитФормыТаблицы) Экспорт
	
	ИзменяемыеСобытия = Новый Массив;
	
	ВыбранныеЭлементы = ЭлементТаблицы.ВыделенныеСтроки; 
		
	// Проверять в ОМ на "Редактирование запрещено"
	Для Каждого ВыбранныйЭлемент Из ВыбранныеЭлементы Цикл
		СтрокаТаблицы = РеквизитФормыТаблицы.НайтиПоИдентификатору(ВыбранныйЭлемент);
		ИзменяемыеСобытия.Добавить(СтрокаТаблицы.Задача);
	КонецЦикла; 
	
	Возврат ИзменяемыеСобытия;
	
КонецФункции

// Обработчик активизации формы Справочник.ЗаписиКалендаряСотрудника.Календарь и вида "Календарь" Контакт-центра
// 
// Параметры:
//  ЭлементПланировщика - Планировщик
//  ЭлементУстановитьСостояние - ГруппаФормы
//  ЭлементыЗавершитьЗадачу - Кнопка
Процедура ПриАктивизацииПланировщикаКалендаря(ЭлементПланировщика, ЭлементУстановитьСостояние,
	ЭлементыЗавершитьЗадачу) Экспорт
	
	// Устанавливаем видимость элементов
	
	ОтображатьВыполнитьЗадачу	= Ложь;
	ОтображатьУстановитьСостояние = Ложь;
	
	ВыбранныеЭлементы = ЭлементПланировщика.ВыделенныеЭлементы; 
	
	// Отображаем команды в контекстном меню, только для всех элементов планировщика не запрещено редактирование
	ЗапретОтображенияКоманд = Ложь;
	
	Для Каждого ВыбранныйЭлемент Из ВыбранныеЭлементы Цикл
		Если Не ЗапретОтображенияКоманд И ВыбранныйЭлемент.Значение.РедактированиеЗапрещено Тогда
			ЗапретОтображенияКоманд = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла; 
	
	Если Не ЗапретОтображенияКоманд Тогда
		
		ДопустимыеТипыДокументовИзмененияСостояния = 
			СостоянияДокументовКлиентСервер.ДопустимыеТипыДокументовИзмененияСостояния();
		
		ИзменяемыеСобытия = ДокументыВыбранныхСобытийПланировщика(ЭлементПланировщика);
		
		Для Каждого ИзменяемоеСобытие Из ИзменяемыеСобытия Цикл
			
			ТипСобытия = ТипЗнч(ИзменяемоеСобытие);
			ИзменениеСостоянияДопустимоДляТипа = 
				ДопустимыеТипыДокументовИзмененияСостояния.Найти(ТипСобытия) <> Неопределено;
			
			Если Не ОтображатьВыполнитьЗадачу И ТипЗНЧ(ИзменяемоеСобытие) = Тип("ДокументСсылка.ЗадачаСотрудника") Тогда
				ОтображатьВыполнитьЗадачу = Истина;
			ИначеЕсли Не ОтображатьУстановитьСостояние И ИзменениеСостоянияДопустимоДляТипа Тогда
				ОтображатьУстановитьСостояние = Истина;
			Иначе
				Продолжить;
			КонецЕсли;
			
		КонецЦикла;

	КонецЕсли;
	
	ЭлементыЗавершитьЗадачу.Видимость 		= ОтображатьВыполнитьЗадачу;
	ЭлементУстановитьСостояние.Видимость 	= ОтображатьУстановитьСостояние;

КонецПроцедуры

// Обработчик ПриАктивизацииЯчейкиАктивизации таблицы задач на весь день
// формы Справочник.ЗаписиКалендаряСотрудника.Календарь и вида "Календарь" Контакт-центра
// 
// Параметры:
//  РеквизитФормыТаблицы - РеквизитФормы
//  ЭлементТаблицы - ТаблицаФормы
//  ЭлементУстановитьСостояние - ГруппаФормы
//  ЭлементыЗавершитьЗадачу - Кнопка
//
Процедура ПриАктивизацииЯчейкиЗадачиНаВесьДень(РеквизитФормыТаблицы, ЭлементТаблицы, ЭлементУстановитьСостояние,
	ЭлементыЗавершитьЗадачу) Экспорт
	
	// Устанавливаем видимость элементов
	
	ОтображатьВыполнитьЗадачу	= Ложь;
	ОтображатьУстановитьСостояние = Ложь;
	
	ВыбранныеЭлементы = ЭлементТаблицы.ВыделенныеСтроки; 

	// Отображаем команды в контекстном меню, только для всех элементов планировщика не запрещено редактирование
	ЗапретОтображенияКоманд = Ложь;
	
	Для Каждого ВыбранныйЭлемент Из ВыбранныеЭлементы Цикл
		СтрокаТаблицы = РеквизитФормыТаблицы.НайтиПоИдентификатору(ВыбранныйЭлемент);
		Если Не ЗапретОтображенияКоманд И СтрокаТаблицы.РедактированиеЗапрещено Тогда
			ЗапретОтображенияКоманд = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла; 
	
	Если Не ЗапретОтображенияКоманд Тогда
		
		ДопустимыеТипыДокументовИзмененияСостояния = 
			СостоянияДокументовКлиентСервер.ДопустимыеТипыДокументовИзмененияСостояния();
		
		ИзменяемыеСобытия = ДокументыВыбранныхСобытийЗадачиНаВесьДень(ЭлементТаблицы, РеквизитФормыТаблицы); 

		Для Каждого ИзменяемоеСобытие Из ИзменяемыеСобытия Цикл
			
			ТипСобытия = ТипЗнч(ИзменяемоеСобытие);
			ИзменениеСостоянияДопустимоДляТипа = 
				ДопустимыеТипыДокументовИзмененияСостояния.Найти(ТипСобытия) <> Неопределено;
			
			Если Не ОтображатьВыполнитьЗадачу И ТипЗНЧ(ИзменяемоеСобытие) = Тип("ДокументСсылка.ЗадачаСотрудника") Тогда
				ОтображатьВыполнитьЗадачу = Истина;
			ИначеЕсли Не ОтображатьУстановитьСостояние И ИзменениеСостоянияДопустимоДляТипа Тогда
				ОтображатьУстановитьСостояние = Истина;
			Иначе
				Продолжить;
			КонецЕсли;
			
		КонецЦикла;

	КонецЕсли;
	
	ЭлементыЗавершитьЗадачу.Видимость 		= ОтображатьВыполнитьЗадачу;
	ЭлементУстановитьСостояние.Видимость 	= ОтображатьУстановитьСостояние;

КонецПроцедуры

#КонецОбласти
