#Область СлужебныйПрограммныйИнтерфейс

Процедура НастроитьИнтерфейсРежимаКассыСамообслуживания(Форма) Экспорт
	
	ЭлементыФормы = Форма.Элементы;
	
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаДанныеДляТекущейСтроки, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.СкидкаНаЧек, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаРучнаяСкидкаНаТовар, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ОтложитьЧек, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.КоманднаяПанельРежим, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.КоманднаяПанельЕще, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.Каталог, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.НайтиВЧеке, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.НайтиПоШтрихкодуКСО, Истина);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ПозватьСотрудника, Истина);
	
	УстановитьДоступностьЭлементаФормы(ЭлементыФормы.СкидкаНаЧек, Ложь);
	УстановитьДоступностьЭлементаФормы(ЭлементыФормы.ОтложитьЧек, Ложь);
	УстановитьДоступностьЭлементаФормы(ЭлементыФормы.КоманднаяПанельРежим, Ложь);
	УстановитьДоступностьЭлементаФормы(ЭлементыФормы.КоманднаяПанельЕще, Ложь);
	УстановитьДоступностьЭлементаФормы(ЭлементыФормы.ГруппаДанныеДляТекущейСтроки, Ложь);
	
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаВидОплатыПредоплата, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаРазделВыдачиНаличных, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаВидОплатыЗачетАванса, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаВидОплатыНСПК, Ложь);
	
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ОтменаРасчетаСкидок, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаВидОплатыВРассрочку, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаРазделДенежныйЯщик, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаВидОплатыКредитом, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаВидОплатыБезнал, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ГруппаЗаменаТоваров, Ложь);
	
	ПараметрыПлиточногоИнтерфейса = ПараметрыПлиточногоИнтерфейса();
	ВидимостьУдалитьЧек = (Форма.Объект.Товары.Количество() > 0);
	Если Не ЭлементыФормы.УдалитьЧек.Видимость = ВидимостьУдалитьЧек Тогда
		УстановитьВидимостьЭлементаФормы(ЭлементыФормы.УдалитьЧек, ВидимостьУдалитьЧек);
		Если Не (Форма.РежимПлитки Или ЭлементыФормы.Декорация1.Видимость = ВидимостьУдалитьЧек) Тогда
			УстановитьВидимостьЭлементаФормы(ЭлементыФормы.Декорация1, ВидимостьУдалитьЧек);
		КонецЕсли;
	КонецЕсли;
	
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ВыбратьКонтрагента, Ложь);
	УстановитьВидимостьЭлементаФормы(ЭлементыФормы.ВыбратьКонтрагентаКартаНеНайдена, Ложь);
	
	УстановитьПараметрыЭлементовКСО(ЭлементыФормы.ГруппаПанельДействий);
	УстановитьПараметрыЭлементовКСО(ЭлементыФормы.ГруппаПлатежнаяСистемаКоманднаяПанель);
	УстановитьПараметрыЭлементовКСО(ЭлементыФормы.ГруппаЗаголовокПлатежнаяСистема);
	
	ЭлементыФормы.ПодтвердитьВозраст.Картинка = БиблиотекаКартинок.ПодтверждениеДействияРМК;
	ЭлементыФормы.ОпровергнутьВозраст.Картинка = БиблиотекаКартинок.ОтказОтДействияРМК;
	
	ЭлементыФормы.ПродолжитьРаботуСЧеком.Картинка = БиблиотекаКартинок.ПодтверждениеДействияРМК;
	ЭлементыФормы.УдалитьЧекИзФормыЗапретаПродажи.Картинка = БиблиотекаКартинок.ОтказОтДействияРМК;

	КрупныйШрифт = ЭлементыФормы.СуммаИтого.Шрифт;
	ЭлементыФормы.ДекорацияВводПромокода.Заголовок = НСтр("ru = 'Просканируйте промокод'");
	ЭлементыФормы.ДекорацияВводПромокода.Шрифт = КрупныйШрифт;
	ЭлементыФормы.ДекорацияВводПромокода.Высота = 2;
	ЭлементыФормы.ОписаниеНайденнойСкидки.Шрифт = КрупныйШрифт;
	ЭлементыФормы.ОписаниеНайденнойСкидки.Высота = 2;
	
КонецПроцедуры

Процедура УстановитьВидимостьГруппыОперации(Элементы) Экспорт
	
	УстановитьВидимостьЭлементаФормы(Элементы.ГруппаОперации, Истина);
	Элементы.ГруппаУправления.ТекущаяСтраница = Элементы.ГруппаСтраницаОперации;
	
КонецПроцедуры

Функция ПараметрыРазмеровКомандУправленияЧекомДляКСО() Экспорт
	
	ПараметрыИнтерфейсаКСО = ПараметрыИнтерфейсаКСО();
	ПараметрыПлиточногоИнтерфейса = ПараметрыПлиточногоИнтерфейса();
	ПараметрыРазмеров = Новый Структура;
	ПараметрыРазмеров.Вставить("ВысотаКоманды", ПараметрыИнтерфейсаКСО.ВысотаКоманды);
	ПараметрыРазмеров.Вставить("ШиринаКоманды", ПараметрыИнтерфейсаКСО.ШиринаКоманды);
	ПараметрыРазмеров.Вставить("ВысотаКомандыОперации", ПараметрыПлиточногоИнтерфейса.ВысотаКоманды);
	ПараметрыРазмеров.Вставить("ШиринаКомандыОперации", ПараметрыПлиточногоИнтерфейса.ШиринаКоманды);
	
	Возврат ПараметрыРазмеров;
	
КонецФункции

// Настраивает размеры команд управления составом чека.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма РМК.
//  ПараметрыРазмеровКоманд - структура:
//		* ВысотаКоманды - Число,
//		* ШиринаКоманды - Число,
//		* ВысотаКомандыОперации - Число,
//		* ШиринаКомандыОперации - Число.
//  Инициализация - Булево, устанавливать размеры команд, только при инициализации формы.
//
Процедура НастроитьРазмерКомандУправленияСоставомЧека(Форма, ПараметрыРазмеровКоманд, НастройкиЭлементов,
		Инициализация = Ложь) Экспорт
	
	ЭлементыФормы = Форма.Элементы;
	РежимПлитки = Форма.РежимПлитки;

	ВысотаКомандыОперации = ПараметрыРазмеровКоманд.ВысотаКомандыОперации;
	ШиринаКомандыОперации = ПараметрыРазмеровКоманд.ШиринаКомандыОперации;
	
	СтандартныеРазмеры = Новый Структура();
	СтандартныеРазмеры.Вставить("Ширина", ПараметрыРазмеровКоманд.ШиринаКоманды);
	СтандартныеРазмеры.Вставить("Высота", ПараметрыРазмеровКоманд.ВысотаКоманды);
	УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементыФормы.УдалитьТовар, Форма,
		СтандартныеРазмеры, НастройкиЭлементов);
	
	Если Инициализация Тогда
		УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементыФормы.ПоказатьОстатки, Форма,
			СтандартныеРазмеры, НастройкиЭлементов);
	КонецЕсли;
	УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементыФормы.ТекущийТоварУменьшитьКоличество, Форма,
		СтандартныеРазмеры, НастройкиЭлементов);
	УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементыФормы.ТекущийТоварУвеличитьКоличество, Форма,
		СтандартныеРазмеры, НастройкиЭлементов);
	УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементыФормы.ПолучитьВес, Форма,
		СтандартныеРазмеры, НастройкиЭлементов);
		
	Если Не Форма.РежимПлитки Тогда
		СтандартныеРазмеры.Ширина = 4;
	КонецЕсли;
	УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементыФормы.ТекущийТоварУстановитьДробноеКоличество, Форма,
		СтандартныеРазмеры, НастройкиЭлементов);
		
	СтандартныеРазмеры.Вставить("Высота", ВысотаКомандыОперации);
	СтандартныеРазмеры.Вставить("Ширина", ШиринаКомандыОперации);
	УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементыФормы.ОткрытьПанельИзбранныхТоваров, Форма,
		СтандартныеРазмеры, НастройкиЭлементов);
	
КонецПроцедуры

Процедура НастроитьОтображениеКнопкиФормы(КнопкаФормы, НаборСвойств) Экспорт
	
	УстановленЗаголовокДробноеКоличество = Ложь;
	ИмяКнопкиДробноеКоличество = "ТекущийТоварУстановитьДробноеКоличество";
	ФигураОвальная = "Овальная";
	Для Каждого СвойствоНабора Из НаборСвойств Цикл
		
		Если СвойствоНабора.Ключ = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ВысотаКнопок") Тогда
			КнопкаФормы.Высота = СвойствоНабора.Значение;
		ИначеЕсли СвойствоНабора.Ключ = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ШиринаКнопок") Тогда
			КнопкаФормы.Ширина = СвойствоНабора.Значение;
		ИначеЕсли СвойствоНабора.Ключ = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ФигураКнопок") Тогда
			КнопкаФормы.Фигура = ?(СвойствоНабора.Значение = ФигураОвальная, ФигураКнопки.Овал, ФигураКнопки.Обычная);
		ИначеЕсли СвойствоНабора.Ключ = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ЦветКнопок") Тогда
			КнопкаФормы.ЦветФона = СвойствоНабора.Значение;
		ИначеЕсли СвойствоНабора.Ключ = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ЦветШрифта") Тогда
			КнопкаФормы.ЦветТекста = СвойствоНабора.Значение;
		ИначеЕсли СвойствоНабора.Ключ = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ШрифтКнопок") Тогда
			КнопкаФормы.Шрифт = СвойствоНабора.Значение;
		ИначеЕсли СвойствоНабора.Ключ
				= ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ВеличинаДробногоКоличества") Тогда
				
			КнопкаФормы.Видимость = Истина;
			Если Не УстановленЗаголовокДробноеКоличество Тогда
				КнопкаФормы.Заголовок = Формат(СвойствоНабора.Значение, "ЧГ=");
			КонецЕсли;
				
		ИначеЕсли СвойствоНабора.Ключ = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ЗаголовокКнопки") Тогда
			КнопкаФормы.Заголовок = СвойствоНабора.Значение;
			Если КнопкаФормы.имя = ИмяКнопкиДробноеКоличество Тогда
				УстановленЗаголовокДробноеКоличество = Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьФормуИРазмерыЭлементаСУчетомНастроек(ЭлементФормы, Форма, СтандартныеРазмеры,
		НастройкиЭлементов) Экспорт
		
	РежимПлитки = Форма.РежимПлитки;
	ЗаголовкиОбластей = ИнтерфейсРМКСлужебныйКлиентСервер.ПолучитьЗаголовкиОбластейДляНастроек();
	
	СвойствоВысота = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ВысотаКнопок");
	СвойствоШирина = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ШиринаКнопок");
	СвойствоФигура = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ФигураКнопок");
	СвойствоЦвет = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ЦветКнопок");
	СвойствоШрифт = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ШрифтКнопок");
	
	ФигураЭлемента = ФигураКнопки.Авто;
	АвтоШрифт = Новый Шрифт();
	ЦветЭлемента = Новый Цвет();
	ШрифтЭлемента = АвтоШрифт;
	Если ЭлементФормы = Форма.Элементы.ТекущийТоварУстановитьДробноеКоличество Тогда
		ШрифтЭлемента = Форма.Элементы.ТекущийТоварУстановитьДробноеКоличество.Шрифт;
	КонецЕсли;
	ВысотаЭлемента = СтандартныеРазмеры.Высота;
	ШиринаЭлемента = СтандартныеРазмеры.Ширина;
	НаборСвойствИндивидуальный = Неопределено;
	Если РежимПлитки Тогда
		НаборСвойств = НастройкиЭлементов.Получить(ЗаголовкиОбластей.ПлиточныйИнтерфейс);
		Если Форма.РежимКассыСамообслуживания Тогда
			НаборСвойствИндивидуальный = НастройкиЭлементов.Получить(ЭлементФормы.Имя);
		КонецЕсли;
	Иначе
		НаборСвойств = НастройкиЭлементов.Получить(ЭлементФормы.Имя);
	КонецЕсли;
	Если Не НаборСвойств = Неопределено Тогда
		ЗначениеВысоты = НаборСвойств.Получить(СвойствоВысота);
		ЗначениеШирины = НаборСвойств.Получить(СвойствоШирина);
		Если РежимПлитки И Не НаборСвойствИндивидуальный = Неопределено Тогда
			ЗначениеШириныИндивидуальное = НаборСвойствИндивидуальный.Получить(СвойствоШирина);
			Если ЗначениеЗаполнено(ЗначениеШириныИндивидуальное) Тогда
				ЗначениеШирины = ЗначениеШириныИндивидуальное;
			КонецЕсли;
		КонецЕсли;
		ЗначениеФигуры = НаборСвойств.Получить(СвойствоФигура);
		ЗначениеЦвета = НаборСвойств.Получить(СвойствоЦвет);
		ЗначениеШрифта = НаборСвойств.Получить(СвойствоШрифт);
		Если ЗначениеЗаполнено(ЗначениеВысоты) Тогда
			ВысотаЭлемента = ЗначениеВысоты;
		КонецЕсли;
		Если ЗначениеЗаполнено(ЗначениеШирины) Тогда
			ШиринаЭлемента = ЗначениеШирины;
		КонецЕсли;
		Если Не ЗначениеФигуры = Неопределено И Не ЗначениеФигуры = "Авто" Тогда
			ФигураЭлемента = ?(ЗначениеФигуры = "Овальная", ФигураКнопки.Овал, ФигураКнопки.Обычная);
		КонецЕсли;
		Если Не ЗначениеЦвета = Неопределено Тогда
			ЦветЭлемента = ЗначениеЦвета;
		КонецЕсли;
		Если Не ЗначениеШрифта = Неопределено И Не ЗначениеШрифта = АвтоШрифт Тогда
			ШрифтЭлемента = ЗначениеШрифта;
		КонецЕсли;
	КонецЕсли;
	ЭлементФормы.Высота = ВысотаЭлемента;
	ЭлементФормы.Ширина = ШиринаЭлемента;
	ЭлементФормы.ЦветФона = ЦветЭлемента;
	ЭлементФормы.Фигура = ФигураЭлемента;
	ЭлементФормы.Шрифт = ШрифтЭлемента;
	
КонецПроцедуры

Функция ПолучитьЗначениеСвойстваИзНастроек(ИмяЭлемента, НастройкиЭлементов, СвойствоЭлементов) Экспорт
	
	ЗначениеСвойства = Неопределено;
	
	НаборСвойств = НастройкиЭлементов.Получить(ИмяЭлемента);
	Если Не НаборСвойств = Неопределено Тогда
		ЗначениеСвойства = НаборСвойств.Получить(СвойствоЭлементов);
	КонецЕсли;
	
	Возврат ЗначениеСвойства;
	
КонецФункции

Процедура УстановитьШиринуЭлементаПриОтсутствииПерсональнойНастройки(НастройкиЭлементов, ЭлементФормы, Ширина) Экспорт
	
	СвойствоШирина = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ШиринаКнопок");
	ШиринаИзНастроек = ПолучитьЗначениеСвойстваИзНастроек(ЭлементФормы.Имя, НастройкиЭлементов, СвойствоШирина);
	Если Не ЗначениеЗаполнено(ШиринаИзНастроек) Тогда
		ЭлементФормы.Ширина = Ширина;
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьВысотуЭлементаПриОтсутствииПерсональнойНастройки(НастройкиЭлементов, ЭлементФормы, Высота) Экспорт
	
	СвойствоВысота = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ВысотаКнопок");
	ВысотаИзНастроек = ПолучитьЗначениеСвойстваИзНастроек(ЭлементФормы.Имя, НастройкиЭлементов, СвойствоВысота);
	Если Не ЗначениеЗаполнено(ВысотаИзНастроек) Тогда
		ЭлементФормы.Высота = Высота;
	КонецЕсли;
	
