Процедура ДобавитьНовыеДанныеКэшаПродаж(ДанныеПриемник, ДанныеИсточник, ЭтоКэшПлитки = Ложь) Экспорт

	Если ДанныеПриемник.Количество() = 0 Или ДанныеИсточник.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Общий контроль продаж
	ПеренестиНедостающиеЭлементыПростогоМассива(ДанныеИсточник.ОбщийКонтрольПродаж, ДанныеПриемник.ОбщийКонтрольПродаж);
	
	// Контроль продаж по номенклатуре
	Для Каждого СтрокаНоменклатурыКонтроляИсточник Из ДанныеИсточник.НоменклатураКонтроляПродаж Цикл
		
		СтрокаНоменклатурыКонтроляПриемник
			= ПолучитьСтрокуНоменклатурыКонтроляПродаж(ДанныеПриемник.НоменклатураКонтроляПродаж,
				СтрокаНоменклатурыКонтроляИсточник);
		
		СтрокаНоменклатурыКонтроляПлиткиПриемник
			= ПолучитьСтрокуНоменклатурыКонтроляПродаж(ДанныеПриемник.НоменклатураПлиткиКонтроляПродаж,
				СтрокаНоменклатурыКонтроляИсточник);
		
		Если СтрокаНоменклатурыКонтроляПриемник = Неопределено
				И СтрокаНоменклатурыКонтроляПлиткиПриемник = Неопределено Тогда
			
			НоменклатураКонтроляПродажПриемник
				= ?(ЭтоКэшПлитки, ДанныеПриемник.НоменклатураПлиткиКонтроляПродаж, ДанныеПриемник.НоменклатураКонтроляПродаж);
			НоменклатураКонтроляПродажПриемник.Добавить(СтрокаНоменклатурыКонтроляИсточник);
			
		Иначе
			Если Не СтрокаНоменклатурыКонтроляПриемник = Неопределено Тогда
				ПеренестиНедостающиеЭлементыПростогоМассива(СтрокаНоменклатурыКонтроляИсточник.МассивКонтролейПродаж,
					СтрокаНоменклатурыКонтроляПриемник.МассивКонтролейПродаж);
			КонецЕсли;
			Если Не СтрокаНоменклатурыКонтроляПлиткиПриемник = Неопределено Тогда
				ПеренестиНедостающиеЭлементыПростогоМассива(СтрокаНоменклатурыКонтроляИсточник.МассивКонтролейПродаж,
					СтрокаНоменклатурыКонтроляПлиткиПриемник.МассивКонтролейПродаж);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// Элементы контроля продаж
	Для Каждого СтрокаЭлементаКонтроляИсточник Из ДанныеИсточник.ЭлементыКонтроляПродаж Цикл
		СтрокаЭлементаКонтроляПриемник = ПолучитьСтрокуЭлементаКонтроляПродаж(ДанныеПриемник.ЭлементыКонтроляПродаж,
			СтрокаЭлементаКонтроляИсточник.КонтрольПродаж);
		
		Если СтрокаЭлементаКонтроляПриемник = Неопределено Тогда
			ДанныеПриемник.ЭлементыКонтроляПродаж.Добавить(СтрокаЭлементаКонтроляИсточник);
		Иначе
			Для Каждого СтрокаКонтроляИсточник Из СтрокаЭлементаКонтроляИсточник.СтрокиКонтроля Цикл
				СтрокаКонтроляПриемник
					= ПолучитьСтрокуКонтроля(СтрокаЭлементаКонтроляПриемник.СтрокиКонтроля, СтрокаКонтроляИсточник);
				Если СтрокаКонтроляПриемник = Неопределено Тогда
					СтрокаЭлементаКонтроляПриемник.СтрокиКонтроля.Добавить(СтрокаКонтроляИсточник);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	// Строки вида контроля
	Для Каждого СтрокаВидаКонтроляИсточник Из ДанныеИсточник.СтрокиВидовКонтроля Цикл
		СтрокаВидаКонтроляПриемник = ПолучитьСтрокуВидаКонтроля(ДанныеПриемник.СтрокиВидовКонтроля,
			СтрокаВидаКонтроляИсточник.ВидКонтроля);
		
		Если СтрокаВидаКонтроляПриемник = Неопределено Тогда
			 ДанныеПриемник.СтрокиВидовКонтроля.Добавить(СтрокаВидаКонтроляИсточник);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция DecToHex(Знач Значение) Экспорт
	
	РезультатФункции = "";
	Если Значение <= 0 Тогда
		РезультатФункции = "0";
	Иначе
		Размерность = 16;
		Значение = Цел(Значение);
		Пока Значение > 0 Цикл
			СимволЦифра = Сред("0123456789ABCDEF", Значение%Размерность + 1, 1);
			РезультатФункции = СтрШаблон("%1%2", СимволЦифра, РезультатФункции);
			Значение = Цел(Значение/Размерность);
		КонецЦикла;
	КонецЕсли;

	Пока СтрДлина(РезультатФункции) <= 1 Цикл
		РезультатФункции = СтрШаблон("%1%2", "0", РезультатФункции);
	КонецЦикла;

	Возврат РезультатФункции;

КонецФункции

Функция ОпределитьПрименитьВыравниваниеГруппыОперации(Форма, НаборСвойств) Экспорт
	
	ПоложениеЛево = НСтр("ru = 'Лево'");
	ПоложениеЦентр = НСтр("ru = 'Центр'");
	ПоложениеПраво = НСтр("ru = 'Право'");
	ВыравниваниеАвто = НСтр("ru = 'Авто'");
	СвойствоВыравнивание = ПредопределенноеЗначение("Перечисление.СвойстваЭлементовРМК.ВыравниваниеЭлементов");
	ЗначениеВыравнивания = НаборСвойств.Получить(СвойствоВыравнивание);
	РастягиватьСередину = Истина;
	ГоризонтальноеПоложениеКоманд = ГоризонтальноеПоложениеЭлемента.Авто;
	
	Если Не (ЗначениеВыравнивания = Неопределено Или ЗначениеВыравнивания = ВыравниваниеАвто) Тогда
		
		РастягиватьСередину = Ложь;
		
		Если ЗначениеВыравнивания = ПоложениеЛево Тогда
			ГоризонтальноеПоложениеКоманд = ГоризонтальноеПоложениеЭлемента.Лево;
		ИначеЕсли ЗначениеВыравнивания = ПоложениеЦентр Тогда
			ГоризонтальноеПоложениеКоманд = ГоризонтальноеПоложениеЭлемента.Центр;
		ИначеЕсли ЗначениеВыравнивания = ПоложениеПраво Тогда
			ГоризонтальноеПоложениеКоманд = ГоризонтальноеПоложениеЭлемента.Право;
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы = Форма.Элементы;
	Если Не Элементы.ДекорацияРастяжениеСправа.Видимость = РастягиватьСередину Тогда
		Элементы.ДекорацияРастяжениеСправа.Видимость = РастягиватьСередину;
		Элементы.ДекорацияОперацияОтступСправа.Видимость = Не РастягиватьСередину;
	КонецЕсли;
	Если Не Элементы.ГруппаОперации.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеКоманд Тогда
		Элементы.ГруппаОперации.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеКоманд;
	КонецЕсли;
	
КонецФункции

