Функция ПолучитьГрупповойСтатусКассовыхСмен(Форма, ДатаТекущая, СтатусСменИзменился) Экспорт
	
	ГрупповыеСтатусы = ГрупповыеСтатусыКассовыхСмен();
	РезультатФункции = ГрупповыеСтатусы.Неопределен;
	
	Сутки = 86400;
	ВремяНачалаСменыВСекундах = Форма.ВремяНачалаСмены - Дата(1, 1, 1);
	МинимальнаяДатаНачалаСмены = НачалоДня(ДатаТекущая) + ВремяНачалаСменыВСекундах;
	Если ДатаТекущая < МинимальнаяДатаНачалаСмены Тогда
		МинимальнаяДатаНачалаСмены = МинимальнаяДатаНачалаСмены - Сутки;
	КонецЕсли;
	ЕстьАктуальнаяСмена = Ложь;
	ЕстьУстаревшаяСмена = Ложь;
	
	КоличествоКасс = Форма.ТаблицаКассККМОрганизаций.Количество();
	ИндексСтроки = 0;
	Пока ИндексСтроки < КоличествоКасс И НЕ (ЕстьАктуальнаяСмена И ЕстьУстаревшаяСмена) Цикл
		СтрокаКассыККМ = Форма.ТаблицаКассККМОрганизаций[ИндексСтроки];
		Если СтрокаКассыККМ.Открыта Тогда
			Если ДатаТекущая - СтрокаКассыККМ.НачалоКассовойСмены >= Сутки
					Или СтрокаКассыККМ.НачалоКассовойСмены < МинимальнаяДатаНачалаСмены Тогда
				ЕстьУстаревшаяСмена = Истина;
			Иначе
				ЕстьАктуальнаяСмена = Истина;
			КонецЕсли;
		Иначе
			ЕстьУстаревшаяСмена = Истина;
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	Если ЕстьАктуальнаяСмена И ЕстьУстаревшаяСмена Тогда
		РезультатФункции = ГрупповыеСтатусы.СменыАктуальныЧастично;
	ИначеЕсли ЕстьАктуальнаяСмена Тогда
		РезультатФункции = ГрупповыеСтатусы.СменыАктуальны;
	ИначеЕсли ЕстьУстаревшаяСмена Тогда
		РезультатФункции = ГрупповыеСтатусы.ТребуетсяОткрытиеСмен;
	КонецЕсли;
	Если Не Форма.ГрупповойСтатусСмен = РезультатФункции Тогда
		СтатусСменИзменился = Истина;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

