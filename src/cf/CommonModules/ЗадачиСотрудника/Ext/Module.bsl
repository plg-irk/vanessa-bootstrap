КонецФункции

Процедура ПроверитьИзменениеПоЗадачеПередЗаписью(Источник)     
	
	Если ТипЗнч(Источник) <> Тип("ДокументОбъект.ЗадачаСотрудника") Тогда
		Возврат;
	КонецЕсли;
	
	СтарыеЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Источник.Ссылка, 
		"Ответственный, Выполнена, ДатаНачала, ДатаОкончания, Календарь, Описание, Основание, Результат, ВесьДень");
	
	Источник.ДополнительныеСвойства.АссистентУправления.ЗадачиСотрудника.Вставить("СтарыеЗначенияРеквизитов", СтарыеЗначенияРеквизитов);
	Источник.ДополнительныеСвойства.АссистентУправления.ЗадачиСотрудника.Вставить("ЭтоНовый", Источник.ЭтоНовый());
	
КонецПроцедуры	

Процедура ПроверитьИзменениеРеквизитовЗадачиСотрудникаПриЗаписи(Источник)
	
	Если ТипЗнч(Источник) <> Тип("ДокументОбъект.ЗадачаСотрудника") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Источник.ДополнительныеСвойства.АссистентУправления.Свойство("ЗадачиСотрудника") Тогда
		Возврат;
	КонецЕсли;      
	
	Если Не Источник.ДополнительныеСвойства.АссистентУправления.ЗадачиСотрудника.Свойство("СтарыеЗначенияРеквизитов") Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоНовый = Источник.ДополнительныеСвойства.АссистентУправления.ЗадачиСотрудника.ЭтоНовый;
	МассивСообщений = Новый Массив;
	
	Если ЭтоНовый = Ложь Тогда           
			
		СтарыеЗначенияРеквизитов = Источник.ДополнительныеСвойства.АссистентУправления.ЗадачиСотрудника.СтарыеЗначенияРеквизитов;
		Если СтарыеЗначенияРеквизитов.ДатаНачала <> Источник.ДатаНачала Тогда
			МассивСообщений.Добавить("Дата начала: " + СтарыеЗначенияРеквизитов.ДатаНачала 
				+ " → " + Источник.ДатаНачала);
		КонецЕсли;
		Если СтарыеЗначенияРеквизитов.ДатаОкончания <> Источник.ДатаОкончания Тогда
			МассивСообщений.Добавить("Дата окончания: " + СтарыеЗначенияРеквизитов.ДатаОкончания 
				+ " → " + Источник.ДатаОкончания);
		КонецЕсли;                         
		Если СтарыеЗначенияРеквизитов.Ответственный <> Источник.Ответственный Тогда
			МассивСообщений.Добавить("Ответственный: " + СтарыеЗначенияРеквизитов.Ответственный 
				+ " → " + Источник.Ответственный);
		КонецЕсли;                         
		
		Если СтарыеЗначенияРеквизитов.Календарь <> Источник.Календарь Тогда
			МассивСообщений.Добавить("Календарь: " + СтарыеЗначенияРеквизитов.Календарь 
				+ " → " + Источник.Календарь);
		КонецЕсли;      
		
		Если СтарыеЗначенияРеквизитов.Основание <> Источник.Основание Тогда    
			Если ЗначениеЗаполнено(СтарыеЗначенияРеквизитов.Основание) И ЗначениеЗаполнено(Источник.Основание) Тогда
				МассивСообщений.Добавить("Основание: " + СтарыеЗначенияРеквизитов.Основание 
				+ " → " + Источник.Основание);
			ИначеЕсли ЗначениеЗаполнено(СтарыеЗначенияРеквизитов.Основание) И НЕ ЗначениеЗаполнено(Источник.Основание) Тогда
	       		МассивСообщений.Добавить("Основание очищено");	
			ИначеЕсли НЕ ЗначениеЗаполнено(СтарыеЗначенияРеквизитов.Основание) И ЗначениеЗаполнено(Источник.Основание) Тогда
	       		МассивСообщений.Добавить("Основание стало: " + Источник.Основание);	
			КонецЕсли;     		
		КонецЕсли;     		
		
		Если СтарыеЗначенияРеквизитов.Описание <> Источник.Описание Тогда
			МассивСообщений.Добавить("Описание стало: " + Источник.Описание);
		КонецЕсли;   
		
		Если СтарыеЗначенияРеквизитов.Результат <> Источник.Результат Тогда
			МассивСообщений.Добавить("Результат стал: " + Источник.Результат);
		КонецЕсли;
		
		Если СтарыеЗначенияРеквизитов.Выполнена <> Источник.Выполнена Тогда 
			Если Источник.Выполнена Тогда
				МассивСообщений.Добавить("Стала выполненной");
			Иначе
				МассивСообщений.Добавить("Стала невыполненной");				
			КонецЕсли;
		КонецЕсли;  
	Иначе
		МассивСообщений.Добавить("Дата начала: " + Источник.ДатаНачала); 
		МассивСообщений.Добавить("Дата окончания: " + Источник.ДатаОкончания); 
		МассивСообщений.Добавить("Ответственный: " + Источник.Ответственный); 
		МассивСообщений.Добавить("Календарь: " + Источник.Календарь); 
		МассивСообщений.Добавить("Описание: " + Источник.Описание); 
		Если ЗначениеЗаполнено (Источник.Основание) Тогда 
			 МассивСообщений.Добавить("Основание: " + 
			 ?(ОбщегоНазначения.ЭтоСсылка(ТипЗнч(Источник.Основание)), 
			 Строка(ПолучитьНавигационнуюСсылку(Источник.Основание)),
			 Источник.Основание)); 
		КонецЕсли;
		
	КонецЕсли;
		
	Если МассивСообщений.Количество() <> 0 Тогда
		ТекстСообщенияВсеЗадачиСтрокой = СтрСоединить(МассивСообщений, Символы.ПС);          
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ИзмененияПоЗадаче", ТекстСообщенияВсеЗадачиСтрокой);
		ДопПараметры.Вставить("СтарыеЗначенияРеквизитов", СтарыеЗначенияРеквизитов);
		ДопПараметры.Вставить("ЭтоНовый", ЭтоНовый);
		
		ТекущееСобытие = "ПриИзмененииДанныхЗадачаСотрудника";                       
		
		АссистентУправления.ПриСрабатыванииСобытия2(ТекущийМенеджер(), ТекущееСобытие, Источник.Ссылка,, ДопПараметры);			
	КонецЕсли;
				
	
КонецПроцедуры

Функция ТекущийМенеджер()
	
	Возврат "ЗадачиСотрудника";
	
КонецФункции

Процедура ДобавитьДополнительныеСвойства(Объект)
	
	Если НЕ Объект.ДополнительныеСвойства.АссистентУправления.Свойство(ТекущийМенеджер()) Тогда
		Объект.ДополнительныеСвойства.АссистентУправления.Вставить(ТекущийМенеджер(), Новый Структура);
	КонецЕсли;
	
КонецПроцедуры 

Функция СоздатьГрупповойЧатПоКалендарю(ПараметрыЗадачи, ЗадачаАссистента)
	
	УстановитьПривилегированныйРежим(Истина);
	МассивПользователей = ПолучитьПользователейКалендаряОтправки(ПараметрыЗадачи.КалендарьОтправки);
	КалендарьСотрудникСотрудники = ПараметрыЗадачи.КалендарьСотрудникСотрудники;
	
	НовоеОбсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
	НовоеОбсуждение.Групповое = Истина;
	Для Каждого Пользователь Из МассивПользователей Цикл
		ИдентификаторПользователя = Обсуждения.ПользовательСистемыВзаимодействия(Пользователь, Истина);
		НовоеОбсуждение.Участники.Добавить(ИдентификаторПользователя);  
	КонецЦикла;  
	
	ШаблонЗаголовок = НСтр("ru='%1: изменения в задачах по %2'"); 
	Если КалендарьСотрудникСотрудники = 0 Тогда 
		СтрокаПо = "сотруднику " + ПараметрыЗадачи.КонтролируемыйСотрудник;	 
	ИначеЕсли КалендарьСотрудникСотрудники = 1 Тогда	   
		СтрокаПо = "календарю " + ПараметрыЗадачи.КонтролируемыйКалендарь;
	ИначеЕсли КалендарьСотрудникСотрудники = 2 Тогда	   
		СтрокаПо = "сотрудникам календаря " + ПараметрыЗадачи.КонтролируемыйКалендарь;
	Иначе
		СтрокаПо = "нескольким сотрудникам";
	КонецЕсли;                  
	НовыйЗаголовок = СтрШаблон(ШаблонЗаголовок, Строка(ПараметрыЗадачи.КалендарьОтправки), СтрокаПо);
	НовоеОбсуждение.Заголовок = НовыйЗаголовок; 
	НовоеОбсуждение.Записать();    
	
	ЗадачаАссистентаОбъект = ЗадачаАссистента.ПолучитьОбъект();
	ЗадачаАссистентаОбъект.ОбменДанными.Загрузка = Истина;    
	ПараметрыЗадачиСохраненные = ЗадачаАссистентаОбъект.ЗначенияЗаполнения[0].Значение.Получить();
	ПараметрыЗадачиСохраненные.ИдентификаторОбщегоОбсуждения = НовоеОбсуждение.Идентификатор;   
	ЗадачаАссистентаОбъект.ЗначенияЗаполнения.Очистить();
	СтрокаНастройки = ЗадачаАссистентаОбъект.ЗначенияЗаполнения.Добавить();
	СтрокаНастройки.Параметр = "СтруктураНастроек";
	СтрокаНастройки.Значение = Новый ХранилищеЗначения(ПараметрыЗадачиСохраненные);
	ЗадачаАссистентаОбъект.Записать();
	ЗадачаАссистентаОбъект.ОбменДанными.Загрузка = Ложь;
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат НовоеОбсуждение.Идентификатор;
	
КонецФункции 

Процедура ОбновитьГрупповойЧатПоКалендарю(ПараметрыЗадачи)
	
	УстановитьПривилегированныйРежим(Истина);       
	КалендарьСотрудникСотрудники = ПараметрыЗадачи.КалендарьСотрудникСотрудники;

	ШаблонЗаголовок = НСтр("ru='%1: изменения в задачах по %2'"); 
	Если КалендарьСотрудникСотрудники = 0 Тогда 
		СтрокаПо = "сотруднику " + ПараметрыЗадачи.КонтролируемыйСотрудник;	 
	ИначеЕсли КалендарьСотрудникСотрудники = 1 Тогда	   
		СтрокаПо = "календарю " + ПараметрыЗадачи.КонтролируемыйКалендарь;
	ИначеЕсли КалендарьСотрудникСотрудники = 2 Тогда	   
		СтрокаПо = "сотрудникам календаря " + ПараметрыЗадачи.КонтролируемыйКалендарь;
	Иначе
		СтрокаПо = "нескольким сотрудникам";
	КонецЕсли;                  
	НовыйЗаголовок = СтрШаблон(ШаблонЗаголовок, Строка(ПараметрыЗадачи.КалендарьОтправки), СтрокаПо);
	
	МассивПользователей = ПолучитьПользователейКалендаряОтправки(ПараметрыЗадачи.КалендарьОтправки);
	ОбновляемоеОбсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(Новый ИдентификаторОбсужденияСистемыВзаимодействия(ПараметрыЗадачи.ИдентификаторОбщегоОбсуждения));
    ЕстьИзменения = Ложь;              
	МассивИдентификаторовАктуальныхПользователей = Новый Массив;
	Для Каждого Пользователь Из МассивПользователей Цикл
		ИдентификаторПользователя = Обсуждения.ПользовательСистемыВзаимодействия(Пользователь, Истина);
		МассивИдентификаторовАктуальныхПользователей.Добавить(ИдентификаторПользователя);
		Если НЕ ОбновляемоеОбсуждение.Участники.Содержит(ИдентификаторПользователя) Тогда
			ОбновляемоеОбсуждение.Участники.Добавить(ИдентификаторПользователя); 
			ЕстьИзменения = Истина;
		КонецЕсли;
	КонецЦикла;     
	
	МассивНеактуальныхИдентификаторов = Новый Массив;
	Для Каждого Участник Из ОбновляемоеОбсуждение.Участники Цикл
		Если МассивИдентификаторовАктуальныхПользователей.Найти(Участник) = Неопределено Тогда	
			МассивНеактуальныхИдентификаторов.Добавить(Участник);
		КонецЕсли;
	КонецЦикла;       
	
	Для Каждого НеактуальныйУчастник Из МассивНеактуальныхИдентификаторов Цикл   
		ЕстьИзменения = Истина;		
		ОбновляемоеОбсуждение.Участники.Удалить(НеактуальныйУчастник);
	КонецЦикла;       
	
	Если ОбновляемоеОбсуждение.Заголовок <> НовыйЗаголовок Тогда
		ЕстьИзменения = Истина;		
		ОбновляемоеОбсуждение.Заголовок = НовыйЗаголовок;	
	КонецЕсли;
	Если ЕстьИзменения = Истина Тогда         	
		ОбновляемоеОбсуждение.Записать();  
	КонецЕсли;         
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры 

Функция ПолучитьПользователейКалендаряОтправки(КалендарьОтправки)
	
	МассивПользователей = Новый Массив;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КалендариСотрудниковДоступ.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ втСотрудникиОтправки
		|ИЗ
		|	Справочник.КалендариСотрудников.Доступ КАК КалендариСотрудниковДоступ
		|ГДЕ
		|	КалендариСотрудниковДоступ.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	КалендариСотрудников.ВладелецКалендаря
		|ИЗ
		|	Справочник.КалендариСотрудников КАК КалендариСотрудников
		|ГДЕ
		|	КалендариСотрудников.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СотрудникиПользователя.Пользователь КАК Пользователь
		|ИЗ
		|	РегистрСведений.СотрудникиПользователя КАК СотрудникиПользователя
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСотрудникиОтправки КАК втСотрудникиОтправки
		|		ПО СотрудникиПользователя.Сотрудник = втСотрудникиОтправки.Сотрудник";
	
	Запрос.УстановитьПараметр("Ссылка", КалендарьОтправки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивПользователей.Добавить(ВыборкаДетальныеЗаписи.Пользователь);
	КонецЦикла;
	
	Возврат МассивПользователей;
	
КонецФункции

Процедура ОбработатьОтправкуПисьмаПоИзменениямВЗадаче(ПараметрыЗадачи, ЗадачаСотрудника, ТекстСообщения, ЭтоНовый)
	
	ПользовательОтветственный = ПараметрыЗадачи.ПользовательДляПисем;
	КонтактнаяИнформацияПользователя = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
	ПользовательОтветственный, Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты,, Ложь);
	
	АдресаЭлектроннойПочты = Новый Массив;
	Для каждого ДанныеКонтактнойИнформации Из КонтактнаяИнформацияПользователя Цикл
		ОписаниеПолучателя = Новый Структура;
		ОписаниеПолучателя.Вставить("Адрес", ДанныеКонтактнойИнформации.Представление);
		ОписаниеПолучателя.Вставить("Представление", Строка(ПользовательОтветственный));
		АдресаЭлектроннойПочты.Добавить(ОписаниеПолучателя);
	КонецЦикла;                                          
	
	Если АдресаЭлектроннойПочты.Количество() = 0 Тогда
		ТекстСообщенияОшибка = НСтр("ru='У пользователя %1 не указано ни одного адреса электронной почты'");
		ТекстСообщенияОшибка = СтрШаблон(ТекстСообщенияОшибка, Строка(ПользовательОтветственный));
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиПочтовогоОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Предупреждение,,ПользовательОтветственный, ТекстСообщенияОшибка);
		Возврат;
	КонецЕсли;	
	
	ТекстПисьма = ТекстСообщения;  
	
	КомпонентыСтроки = Новый Массив;
	КомпонентыСтроки.Добавить(НСтр("ru='Добрый день!'"));
