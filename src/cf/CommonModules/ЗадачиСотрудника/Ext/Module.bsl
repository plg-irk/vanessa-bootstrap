	ТипыОснований.Добавить(Тип("СправочникСсылка.Лиды"));
	ТипыОснований.Добавить(Тип("СправочникСсылка.КонтактныеЛица"));
	ТипыОснований.Добавить(Тип("СправочникСсылка.Контрагенты"));
	ТипыОснований.Добавить(Тип("ДокументСсылка.ЗаказПокупателя"));
	ТипыОснований.Добавить(Тип("ДокументСсылка.Событие"));
	
	Возврат ТипыОснований;
	
КонецФункции

Функция ФункциональныеОпцииТиповОснованийМенюПодбора()
	
	ФункциональныеОпцииТипов = Новый Соответствие;

	ФункциональныеОпцииТипов.Вставить(Тип("СправочникСсылка.Лиды"),           "ИспользоватьЛиды");
	ФункциональныеОпцииТипов.Вставить(Тип("СправочникСсылка.КонтактныеЛица"), "ИспользоватьКонтактыКонтрагентов");
	ФункциональныеОпцииТипов.Вставить(Тип("СправочникСсылка.Контрагенты"),    "");
	ФункциональныеОпцииТипов.Вставить(Тип("ДокументСсылка.ЗаказПокупателя"),  "");
	ФункциональныеОпцииТипов.Вставить(Тип("ДокументСсылка.Событие"),          "ИспользоватьСобытия");	

	Возврат ФункциональныеОпцииТипов;
	
КонецФункции

