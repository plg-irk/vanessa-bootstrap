	ФункциональныеОпцииТипов.Вставить(Тип("ДокументСсылка.ЗаданиеНаРаботу"), 		"ИспользоватьЗаданияНаРаботу");
	ФункциональныеОпцииТипов.Вставить(Тип("ДокументСсылка.ЗаказНаПеремещение"), 	"УчетПоНесколькимСкладам");
	
	ИмяФункциональнойОпции = "ИспользоватьПодсистемуЗакупки"; 
	ФункциональныеОпцииТипов.Вставить(Тип("ДокументСсылка.СчетНаОплатуПоставщика"), ИмяФункциональнойОпции);
	ФункциональныеОпцииТипов.Вставить(Тип("ДокументСсылка.ЗаказПоставщику"), 		ИмяФункциональнойОпции);
	
