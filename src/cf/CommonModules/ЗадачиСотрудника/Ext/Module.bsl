
#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// См. РаботаСФайламиПереопределяемый.ПриСозданииФормыСпискаФайлов
Процедура ПриСозданииФормыСпискаФайлов(Форма) Экспорт
	
	Если ТипЗнч(Форма.ВладелецФайла) <> Тип("ДокументСсылка.ЗадачаСотрудника") Тогда
		Возврат;
	КонецЕсли;
	
	Форма.Ширина = 40;
	Форма.Высота = 30;
	
КонецПроцедуры

// См. ПодключаемыеКомандыПереопределяемый.ПриОпределенииКомандПодключенныхКОбъекту
Процедура ПриОпределенииКомандПодключенныхКОбъекту(НастройкиФормы, Источники, ПодключенныеОтчетыИОбработки, Команды) Экспорт
	
	Команда = Команды.Добавить();
	Команда.Вид = "Органайзер";
	Команда.Идентификатор = "ЗадачаСотрудника";
	Команда.Представление = НСтр("ru = 'Создать задачу'");
	Команда.Важность = "Обычное";
	Команда.Порядок = 100;
	Команда.ОтображениеКнопки = ОтображениеКнопки.Картинка;
	Команда.Картинка = БиблиотекаКартинок.ЗадачаСотрудника;
	Команда.ТипПараметра = Метаданные.ОпределяемыеТипы.ОснованиеЗадачи.Тип;
	Команда.ФункциональныеОпции = "ИспользоватьЗадачиСотрудников";
	Команда.ИзменяетВыбранныеОбъекты = Ложь;
	Команда.РежимЗаписи = "Записывать";
	Команда.Обработчик = "ЗадачиСотрудникаКлиент.СоздатьЗадачу";
	Команда.ТолькоВоВсехДействиях = Ложь;

КонецПроцедуры

#КонецОбласти

Процедура ПриОпределенииНастроек(Настройки) Экспорт
	
	Настройки.ПроверкаДокументаПередЗаписью = Истина;
	Настройки.ПроверкаДокументаПриЗаписи = Истина;
	
КонецПроцедуры

// Проверка документа перед записью.
// 
// Параметры:
//  Источник - ДокументОбъект.ЗадачаСотрудника - Источник
Процедура ПроверкаДокументаПередЗаписью(Источник) Экспорт
	
	Если Источник.ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ АссистентУправления.Используется() Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьДополнительныеСвойства(Источник);
	
	ПроверитьИзменениеПоЗадачеПередЗаписью(Источник);
	
КонецПроцедуры

// Проверка документа при записи.
// 
// Параметры:
//  Источник - ДокументОбъект.ЗадачаСотрудника - Источник
Процедура ПроверкаДокументаПриЗаписи(Источник) Экспорт
	
	Если Источник.ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ АссистентУправления.Используется() Тогда
		Возврат;
	КонецЕсли;
	
	ПроверитьИзменениеРеквизитовЗадачиСотрудникаПриЗаписи(Источник);
	
КонецПроцедуры

Процедура ВыполнитьДействие(Действие, Контекст, ПараметрыЗадачи, ДополнительныеПараметры, Результат) Экспорт

	Если Действие = "ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаВОбсуждении" ИЛИ
		Действие = "ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаПоEmail" Тогда        
		
		Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура") Тогда
			ДополнительныеПараметры.Вставить("Действие", Действие);
		Иначе     
			ТекстСообщенияОшибки = НСтр("ru='Дополнительные параметры не являются структурой'");
			ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщенияОшибки);
			Возврат;
		КонецЕсли;
		ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаВОбсуждении(Контекст, ПараметрыЗадачи, ДополнительныеПараметры, Результат);		
	КонецЕсли;
	
КонецПроцедуры        

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает доступные типы для формирования меню создания записи календаряподбора типа основания 
// для формы документа ЗадачаСотрудника
// 
// Возвращаемое значение:
//  Массив из Тип
Функция ДоступныеТипыМенюСозданияСобытияКалендаря() Экспорт

	ТипыЗаписей = Метаданные.ОпределяемыеТипы.ИсточникЗаписейКалендаря.Тип.Типы();
	ФункциональныеОпцииТиповЗаписей = ФункциональныеОпцииМенюСозданияЗаписиКалендаря();
	
	ДоступныеТипы = ФункциональныеОпцииУНФ.ДоступныеТипыПоФункциональнымОпциям(
		ТипыЗаписей, ФункциональныеОпцииТиповЗаписей);
	
	Возврат ДоступныеТипы;
	
КонецФункции

// Доступные типы меню выбора основания.
// 
// Возвращаемое значение:
//  СписокЗначений:
//		* Представление - Строка - Тип или "ПоказатьВсе"
//		* Значение - Строка - Представление в меню
Функция ДоступныеТипыМенюВыбораОснования() Экспорт

	ФункциональныеОпцииТиповОснований = ФункциональныеОпцииТиповОснованийМенюПодбора();
	
	ТипыОснований = ТипыОснованийМенюПодбора();
	ДоступныеТипы = ФункциональныеОпцииУНФ.ДоступныеТипыПоФункциональнымОпциям(
		ТипыОснований, ФункциональныеОпцииТиповОснований);
	
	ТипыОснованийЗадачи = Новый СписокЗначений;
	
	Для Каждого ДоступныйТип Из ДоступныеТипы Цикл
		
		Если ДоступныйТип = Тип("СправочникСсылка.Лиды") Тогда
			Представление = НСтр("ru = 'Лид'");
		ИначеЕсли ДоступныйТип = Тип("СправочникСсылка.КонтактныеЛица") Тогда
			Представление = НСтр("ru = 'Контакт'");
		ИначеЕсли ДоступныйТип = Тип("СправочникСсылка.Контрагенты") Тогда
			Представление = НСтр("ru = 'Контрагент'");
		ИначеЕсли ДоступныйТип = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
			Представление = НСтр("ru = 'Заказ покупателя'");
		ИначеЕсли ДоступныйТип = Тип("ДокументСсылка.Событие") Тогда
			Представление = НСтр("ru = 'Событие'");
		Иначе
			ТипМетаданных = Метаданные.НайтиПоТипу(ДоступныйТип);
			ПредставлениеОбъекта = ТипМетаданных.ПредставлениеОбъекта;
			Представление = ?(ПустаяСтрока(ПредставлениеОбъекта), ТипМетаданных.Синоним, ПредставлениеОбъекта);
		КонецЕсли;
		
		ТипыОснованийЗадачи.Добавить(ДоступныйТип, Представление);
		
	КонецЦикла;
	
	ТипыОснованийЗадачи.Добавить("ПоказатьВсе", НСтр("ru = 'Показать все'"));
	
	Возврат ТипыОснованийЗадачи;
	
КонецФункции

// Возвращает доступные типы оснований документа ЗадачаСотрудника согласно установленным Функциональным опциям.
// 
// Возвращаемое значение:
//  Массив из Тип
Функция ДоступныеТипыОснованийЗадачиСотрудника() Экспорт	
	
	ТипыОснований = Метаданные.ОпределяемыеТипы.ОснованиеЗадачи.Тип.Типы();
	ФункциональныеОпцииТиповОснований = ФункциональныеОпцииТиповОснований();
	
	ДоступныеТипы = ФункциональныеОпцииУНФ.ДоступныеТипыПоФункциональнымОпциям(
		ТипыОснований, ФункциональныеОпцииТиповОснований);
	
	Возврат ДоступныеТипы;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции


Процедура ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаВОбсуждении(Контекст, ПараметрыЗадачи, ДополнительныеПараметры, Результат) Экспорт
	
	ЗадачаСотрудника = Контекст.Предмет;    
	ЗадачаАссистента = Контекст.Задача;
	ТекстСообщения = "";
	ЗадачаАссистентаОбъект = ЗадачаАссистента.ПолучитьОбъект();	
	Если ЗадачаАссистентаОбъект.ЗначенияЗаполнения.Количество() = 0 Тогда
		ТекстСообщенияОшибки = НСтр("ru='Не заполнены параметры Задачи ассистента'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;       
	
	Если ТипЗнч(ЗадачаАссистента.ЗначенияЗаполнения[0].Значение) <> Тип("ХранилищеЗначения") Тогда
		ТекстСообщенияОшибки = НСтр("ru='Неверный тип параметров Задачи ассистента'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      
	
	ПараметрыЗадачи = ЗадачаАссистента.ЗначенияЗаполнения[0].Значение.Получить();   
	Если ТипЗнч(ПараметрыЗадачи) <> Тип("Структура") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента сохранена не структура'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      
	
	Если НЕ ПараметрыЗадачи.Свойство("МассивСотрудников") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан Массив сотрудников'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      
	
	МассивКонтролируемыхСотрудников = ПараметрыЗадачи.МассивСотрудников;	
	
	Если ТипЗнч(ЗадачаСотрудника) <> Тип("ДокументСсылка.ЗадачаСотрудника") Тогда
		ТекстСообщенияОшибки = НСтр("ru='Попытка отправки сообщения по объекту, не являющемуся Задачей сотрудника'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      

	Если НЕ ПараметрыЗадачи.Свойство("КалендарьСотрудникСотрудники") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан параметр КалендарьСотрудникСотрудники'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;   
	
	Если НЕ ПараметрыЗадачи.Свойство("КонтролируемыйСотрудник") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан параметр Контролируемый сотрудник'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      
	
	Если НЕ ПараметрыЗадачи.Свойство("КонтролируемыйКалендарь") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан параметр Контролируемый календарь'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      
	
	ЭтоНовый = ДополнительныеПараметры.ЭтоНовый;
	Действие = ДополнительныеПараметры.Действие;        
	КалендарьСотрудникСотрудники = ПараметрыЗадачи.КалендарьСотрудникСотрудники;
	ЭтоКонтрольСотрудника = (КалендарьСотрудникСотрудники = 0);
	ЭтоКонтрольКалендарь = (КалендарьСотрудникСотрудники = 1);
	ЭтоКонтрольСотрудникиКалендарь = (КалендарьСотрудникСотрудники = 2);
	ЭтоКонтрольСотрудников = (КалендарьСотрудникСотрудники = 3);
	ЭтоОбсуждение = (Действие = "ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаВОбсуждении");
	ЭтоEmail      = (Действие = "ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаПоEmail");

	ОтветственныйИлиАвтор = ПараметрыЗадачи.ОтветственныйИлиАвтор;  
	КонтролируемыйКалендарь = ПараметрыЗадачи.КонтролируемыйКалендарь;  
	
	СтруктураПараметровЗадачи = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЗадачаСотрудника, "Ответственный, Календарь, Автор");
	Если ЭтоНовый = Ложь Тогда
		ПредыдущийОтветственный = ДополнительныеПараметры.СтарыеЗначенияРеквизитов.Ответственный;
		ПредыдущийКалендарь = ДополнительныеПараметры.СтарыеЗначенияРеквизитов.Календарь;    
	Иначе 
		ПредыдущийОтветственный = Неопределено;
		ПредыдущийКалендарь = Неопределено;
	КонецЕсли;      
	
	СтруктураПараметровЗадачи.Вставить("ПредыдущийОтветственный", ПредыдущийОтветственный);
	СтруктураПараметровЗадачи.Вставить("ПредыдущийКалендарь", ПредыдущийКалендарь);
	СтруктураПараметровЗадачи.Вставить("КонтролируемыйКалендарь", КонтролируемыйКалендарь);
	СтруктураПараметровЗадачи.Вставить("КалендарьСотрудникСотрудники", КалендарьСотрудникСотрудники);
	СтруктураПараметровЗадачи.Вставить("ОтветственныйИлиАвтор", ОтветственныйИлиАвтор);
	Автор  = СтруктураПараметровЗадачи.Автор;
	
	
	НужноОтправитьСообщение = Ложь;
	Если ЭтоКонтрольСотрудника = Истина Тогда    
		КонтролируемыйСотрудник = ПараметрыЗадачи.КонтролируемыйСотрудник;	
		Если СотрудникСоответствуетКритериямОтправкиСообщения(СтруктураПараметровЗадачи, КонтролируемыйСотрудник) Тогда 
			НужноОтправитьСообщение = Истина;   			
		КонецЕсли;      

		Если НужноОтправитьСообщение = Ложь И ОтветственныйИлиАвтор = 1 ИЛИ ОтветственныйИлиАвтор = 2 Тогда 
			СотрудникиАвтора = РегистрыСведений.СотрудникиПользователя.ПолучитьСотрудниковПользователя(Автор);
			Если СотрудникиАвтора.Найти(КонтролируемыйСотрудник) <> Неопределено Тогда  
				НужноОтправитьСообщение = Истина;   			
			КонецЕсли;      
		КонецЕсли;      
	ИначеЕсли ЭтоКонтрольКалендарь Тогда   
		Если КонтролируемыйКалендарь = СтруктураПараметровЗадачи.Календарь ИЛИ КонтролируемыйКалендарь = СтруктураПараметровЗадачи.ПредыдущийКалендарь  Тогда
			НужноОтправитьСообщение = Истина;   
		КонецЕсли;      		
	ИначеЕсли ЭтоКонтрольСотрудникиКалендарь = Истина Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КалендариСотрудниковДоступ.Сотрудник КАК Сотрудник
		|ИЗ
		|	Справочник.КалендариСотрудников.Доступ КАК КалендариСотрудниковДоступ
		|ГДЕ
		|	КалендариСотрудниковДоступ.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	КалендариСотрудников.ВладелецКалендаря
		|ИЗ
		|	Справочник.КалендариСотрудников КАК КалендариСотрудников
		|ГДЕ
		|	КалендариСотрудников.Ссылка = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка", ПараметрыЗадачи.КонтролируемыйКалендарь);  
		Выборка = Запрос.Выполнить().Выбрать();       
		МассивСотрудников = Новый Массив;
		Пока Выборка.Следующий() Цикл    
			МассивСотрудников.Добавить(Выборка.Сотрудник);
			Если СотрудникСоответствуетКритериямОтправкиСообщения(СтруктураПараметровЗадачи, Выборка.Сотрудник)  Тогда
				НужноОтправитьСообщение = Истина;   
				Прервать;
			КонецЕсли;      
		КонецЦикла;	
		Если НужноОтправитьСообщение = Ложь И ОтветственныйИлиАвтор = 1 ИЛИ ОтветственныйИлиАвтор = 2 Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	СотрудникиПользователя.Пользователь КАК Пользователь
			|ИЗ
			|	РегистрСведений.СотрудникиПользователя КАК СотрудникиПользователя
			|ГДЕ
			|	СотрудникиПользователя.Сотрудник В (&МассивСотрудников)
			|	И  НЕ СотрудникиПользователя.Пользователь.Недействителен
			|
			|УПОРЯДОЧИТЬ ПО
			|	СотрудникиПользователя.Пользователь.Наименование";
			Запрос.УстановитьПараметр("МассивСотрудников", МассивСотрудников); 
			Выборка = Запрос.Выполнить().Выбрать();   
			Пока Выборка.Следующий() Цикл  
				Если Выборка.Пользователь = Автор Тогда
					НужноОтправитьСообщение = Истина;   
					Прервать;
				КонецЕсли;      
			КонецЦикла;	
					
		КонецЕсли;
	ИначеЕсли ЭтоКонтрольСотрудников = Истина Тогда
		
		Для Каждого КонтролируемыйСотрудник Из МассивКонтролируемыхСотрудников Цикл
			Если СотрудникСоответствуетКритериямОтправкиСообщения(СтруктураПараметровЗадачи, КонтролируемыйСотрудник) Тогда   
				НужноОтправитьСообщение = Истина;   				
				Прервать;
			КонецЕсли;      
		КонецЦикла;             
		
		Если НужноОтправитьСообщение = Ложь И ОтветственныйИлиАвтор = 1 ИЛИ ОтветственныйИлиАвтор = 2 Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	СотрудникиПользователя.Пользователь КАК Пользователь
			|ИЗ
			|	РегистрСведений.СотрудникиПользователя КАК СотрудникиПользователя
			|ГДЕ
			|	СотрудникиПользователя.Сотрудник В (&МассивСотрудников)
			|	И  НЕ СотрудникиПользователя.Пользователь.Недействителен
			|
			|УПОРЯДОЧИТЬ ПО
			|	СотрудникиПользователя.Пользователь.Наименование";
			Запрос.УстановитьПараметр("МассивСотрудников", МассивКонтролируемыхСотрудников); 
			Выборка = Запрос.Выполнить().Выбрать();   
			Пока Выборка.Следующий() Цикл  
				Если Выборка.Пользователь = Автор Тогда
					НужноОтправитьСообщение = Истина;   
					Прервать;
				КонецЕсли;      
			КонецЦикла;	
		КонецЕсли;  
	КонецЕсли;  
	
	Если НужноОтправитьСообщение = Ложь Тогда
		Возврат;		
	КонецЕсли;  
	
	Если ТипЗнч(ДополнительныеПараметры) <> Тип("Структура") Тогда     
		ТекстСообщенияОшибки = НСтр("ru='В дополнительны параметрах передана не структура'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
		
	КонецЕсли;
	
	Если НЕ ДополнительныеПараметры.Свойство("ИзмененияПоЗадаче") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан тест изменений по задаче'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      
	
	Если ЭтоНовый = Ложь Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru='По задаче %1 произошли следующие изменения:
							|%2'"),
		?(ЭтоEmail = Истина, Строка(ЗадачаСотрудника),ПолучитьНавигационнуюСсылку(ЗадачаСотрудника)),
		ДополнительныеПараметры.ИзмененияПоЗадаче);  
	Иначе  
		ТекстСообщения = СтрШаблон(НСтр("ru='Создана новая задача %1:
							|%2'"), 
		?(ЭтоEmail = Истина, Строка(ЗадачаСотрудника),ПолучитьНавигационнуюСсылку(ЗадачаСотрудника)),
		ДополнительныеПараметры.ИзмененияПоЗадаче);  		
	КонецЕсли;
	
	Если ТекстСообщения = "" Тогда
		ТекстСообщенияОшибки = НСтр("ru='По задаче %1 имеются проблемы с переданными данными отправки сообщения'");
		ТекстСообщенияОшибки = СтрШаблон(ТекстСообщения, Строка(ЗадачаСотрудника));
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;                 
	
	Если НЕ ПараметрыЗадачи.Свойство("КалендарьОтправки") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан параметр Календарь отправки'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;      
	Если ЭтоОбсуждение И НЕ ПараметрыЗадачи.Свойство("ИдентификаторОбщегоОбсуждения") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан параметр Идентификатор общего обсуждения'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;       
	Если ЭтоEmail И НЕ ПараметрыЗадачи.Свойство("УчетнаяЗапись") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан параметр Учетная запись'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;       
	
	Если НЕ ПараметрыЗадачи.Свойство("ПользовательДляОповещения") Тогда
		ТекстСообщенияОшибки = НСтр("ru='В параметрах Задачи ассистента не передан параметр Пользователь для оповещения'");
		ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
		Возврат;
	КонецЕсли;     
	
	Действие = ДополнительныеПараметры.Действие;
	Если Действие = "ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаВОбсуждении" Тогда	

		Если НЕ ОбсужденияУНФ.ЭтоСеансАвторизованногоПользователя()	Тогда    
			ПользовательАссистент = АссистентУправления.ПользовательАссистент();
			Если ПользовательАссистент <> Неопределено И ОбщегоНазначения.ЭтоСсылка(ТипЗнч(ПользовательАссистент)) Тогда
				ИдентификаторПользователяИБ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПользовательАссистент, "ИдентификаторПользователяИБ");
				СистемаВзаимодействия.УстановитьТекущегоПользователя(ИдентификаторПользователяИБ);   
			Иначе
				ТекстСообщенияОшибки = НСтр("ru='Не удалось определить пользователя Ассистента взаимодействия. Для создания пользователя внесите изменения во включенный навык Ассистента.'");
				ЗаписьЖурналаРегистрации("ОшибкаОтправкиОповещенияПользователюПоЗадаче", УровеньЖурналаРегистрации.Ошибка,,ЗадачаСотрудника, ТекстСообщенияОшибки);
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		ДанныеСообщения = ОбсужденияУНФ.НовыйДанныеСообщения();
		Если ЗначениеЗаполнено(ПараметрыЗадачи.КалендарьОтправки) Тогда
			Если Не ЗначениеЗаполнено(ПараметрыЗадачи.ИдентификаторОбщегоОбсуждения) Тогда
				НовыйИдентификаторОбщегоОбсуждения = СоздатьГрупповойЧатПоКалендарю(ПараметрыЗадачи, ЗадачаАссистента);	
			Иначе
				ОбновитьГрупповойЧатПоКалендарю(ПараметрыЗадачи);  
				НовыйИдентификаторОбщегоОбсуждения = ПараметрыЗадачи.ИдентификаторОбщегоОбсуждения;
			КонецЕсли; 
			ОбъектСообщения = НовыйИдентификаторОбщегоОбсуждения;    
			
		ИначеЕсли ЗначениеЗаполнено(ПараметрыЗадачи.ИдентификаторОбщегоОбсуждения) Тогда 
			ОбъектСообщения = ПараметрыЗадачи.ИдентификаторОбщегоОбсуждения;    
		ИначеЕсли ЗначениеЗаполнено(ПараметрыЗадачи.ПользовательДляОповещения) Тогда
			ОбъектСообщения = ПараметрыЗадачи.ПользовательДляОповещения;   
		КонецЕсли;
		
		ДанныеСообщения.Текст = ТекстСообщения;      
		ДанныеСообщения.Объект = ОбъектСообщения;      
		ДанныеСообщения.Автор = АссистентУправления.ПользовательАссистент(); 
		Результат.ДанныеСообщений.Добавить(ДанныеСообщения);
		
	ИначеЕсли Действие = "ОповеститьСотрудникаОбИзмененииЗадачиСотрудникаПоEmail" Тогда	     
		
		ОбработатьОтправкуПисьмаПоИзменениямВЗадаче(ПараметрыЗадачи, ЗадачаСотрудника, ТекстСообщения, ЭтоНовый);
	
	КонецЕсли;
	
	
КонецПроцедуры

Функция СотрудникСоответствуетКритериямОтправкиСообщения(СтруктураПараметровЗадачи, КонтролируемыйСотрудник)
	
	//КонтролируемыйСотрудник  = СтруктураПараметровЗадачи.КонтролируемыйСотрудник;
	ОтветственныйИлиАвтор  = СтруктураПараметровЗадачи.ОтветственныйИлиАвтор;
	Ответственный  = СтруктураПараметровЗадачи.Ответственный;
	ПредыдущийОтветственный  = СтруктураПараметровЗадачи.ПредыдущийОтветственный;
	Автор  = СтруктураПараметровЗадачи.Автор;
	Календарь  = СтруктураПараметровЗадачи.Календарь;
	ПредыдущийКалендарь  = СтруктураПараметровЗадачи.ПредыдущийКалендарь;
	КонтролируемыйКалендарь  = СтруктураПараметровЗадачи.КонтролируемыйКалендарь;
	КалендарьСотрудникСотрудники  = СтруктураПараметровЗадачи.КалендарьСотрудникСотрудники;
	  
	Если КалендарьСотрудникСотрудники <> 1 Тогда
		Если (ОтветственныйИлиАвтор = 0 ИЛИ ОтветственныйИлиАвтор = 2) И (КонтролируемыйСотрудник = Ответственный
			ИЛИ КонтролируемыйСотрудник = ПредыдущийОтветственный) Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;	
		КонецЕсли;
	Иначе   
		Возврат Календарь = КонтролируемыйКалендарь ИЛИ ПредыдущийКалендарь = КонтролируемыйКалендарь;		
	КонецЕсли; 	
	
КонецФункции

