Функция СообщениеОНедоступностиСостоянияВЗаказе(ВидОперации, ВидЗаказа, СостояниеЗаказа) Экспорт
	
	Ссылки = Новый Массив;
	Ссылки.Добавить(ВидЗаказа);
	Ссылки.Добавить(СостояниеЗаказа);
	Представления = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Ссылки, "Представление");
	
	Возврат СтрШаблон(
	НСтр("ru = 'Состояние заказа ""%1"" недоступно для использования с видом заказа ""%2"" или с операцией заказа ""%3""'"),
	Представления[СостояниеЗаказа], Представления[ВидЗаказа], ВидОперации);
	
КонецФункции

