Процедура ДействияПриСозданииНаСервереЗаказа(Параметры, МожноИспользоватьЗавершенногоЛида) Экспорт
	
	Если Параметры.Свойство("МожноИспользоватьЗавершенногоЛида") Тогда
		МожноИспользоватьЗавершенногоЛида = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДействияПередЗаписьюЗаказа(ДополнительныеСвойства, МожноИспользоватьЗавершенногоЛида) Экспорт
	
	Если МожноИспользоватьЗавершенногоЛида Тогда
		ДополнительныеСвойства.Вставить("МожноИспользоватьЗавершенногоЛида");
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обновить отображение элементов заказа
//
// Параметры:
//  Параметры - Структура:
//   * ИспользоватьЗаявки - Булево
//   * ПереработкаДавальческогоСырья - Булево
//   * Объект - ДанныеФормыСтруктура - данные заказа
//   * ЭлементВидОперации - ПолеФормы
//
Процедура УстановитьСписокВыбораВидаОперацииЗаказаНаПродажу(Параметры) Экспорт
	
	Объект = Параметры.Объект;
	ЭлементВидОперации = Параметры.ЭлементВидОперации;
	ИспользоватьЗаявкиДляВида = Параметры.ИспользоватьЗаявки И ЗаявкиИспользуются(Объект.ВидЗаказа);
	
	ЭлементВидОперации.СписокВыбора.Очистить();
	
	Если ИспользоватьЗаявкиДляВида Или Параметры.ПереработкаДавальческогоСырья Тогда
		
		ЭлементВидОперации.ТолькоПросмотр = Ложь;
		ЭлементВидОперации.Видимость = Истина;
		
		Если ИспользоватьЗаявкиДляВида И Параметры.ПереработкаДавальческогоСырья Тогда
			
			ЭлементВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу);
			ЭлементВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу);
			ЭлементВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПереработку);
			
		ИначеЕсли ИспользоватьЗаявкиДляВида Тогда
			
			ЭлементВидОперации.СписокВыбора.Добавить(
			Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу, НСтр("ru = 'Заявка'"));
			ЭлементВидОперации.СписокВыбора.Добавить(
			Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу, НСтр("ru = 'Заказ'"));
			
		Иначе
			
			ЭлементВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу);
			ЭлементВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПереработку);
			
		КонецЕсли;
		
	Иначе
		
		ЭлементВидОперации.ТолькоПросмотр = Истина;
		ЭлементВидОперации.Видимость = Ложь;
		
		ЭлементВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обновить отображение элементов заказа
//
// Параметры:
//  Параметры - Структура:
//   * ИспользоватьЗаявки - Булево
//   * ЭлементВидОперации - ПолеФормы
//
Процедура УстановитьСписокВыбораВидаОперацииЗаказНаряд(Параметры) Экспорт
	
	ЭлементВидОперации = Параметры.ЭлементВидОперации;
	ЭлементВидОперации.СписокВыбора.Очистить();
	
	Если Параметры.ИспользоватьЗаявки Тогда
		
		ЭлементВидОперации.ТолькоПросмотр = Ложь;
		ЭлементВидОперации.Видимость = Истина;
		
		ЭлементВидОперации.СписокВыбора.Добавить(
		Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд, НСтр("ru = 'Заявка'"));
		ЭлементВидОперации.СписокВыбора.Добавить(
		Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд, НСтр("ru = 'Заказ'"));
		
	Иначе
		
		ЭлементВидОперации.ТолькоПросмотр = Истина;
		ЭлементВидОперации.Видимость = Ложь;
		
		ЭлементВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд);
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - Обновить отображение элементов заказа
//
// Параметры:
//  Параметры - Структура:
//   * Объект - ДанныеФормыСтруктура
//   * ИспользоватьЗаявки - Булево
//   * ВестиРасчетыПоДоговорам - Булево
//   * МожноИспользоватьЗавершенногоЛида - Булево
//   * СвязанныйКонтрагентСЛидом - СправочникСсылка.Контрагенты
//   * Элементы - Структура:
//      ** Лид - ПолеФормы
//      ** Контрагент - ПолеФормы
//      ** ЗаполнитьПокупателяПоЛиду - ДекорацияФормы
//      ** СоздатьКонтрагентаПоЛиду - ДекорацияФормы
//      ** Договор - ПолеФормы
//      ** ОстатокВзаиморасчетов - ДекорацияФормы
//
Процедура ОбновитьОтображениеЭлементовЗаказа(Параметры) Экспорт
	
	Объект = Параметры.Объект;
	Элементы = Параметры.Элементы;
	
	Если Не Параметры.ИспользоватьЗаявки Тогда
		Элементы.Лид.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Параметры.ВестиРасчетыПоДоговорам) Тогда
		Параметры.ВестиРасчетыПоДоговорам = Ложь;
	КонецЕсли;
	
	ДлинаПоляКонтрагентЕслиПоказаноЗаполнениеПоЛиду = 28;
	ДлинаПоляКонтрагентЕслиПоказаноСозданиеПоЛиду = 29;
	
	ВидимостьЛида = Ложь;
	ВидимостьПодсказкиЛида = Ложь;
	ТекстПодсказкиЛида = "";
	
	ВидимостьКонтрагента = Ложь;
	ВидимостьПодсказкиКонтрагента = Ложь;
	ВидимостьКнопкиЗаполненияКонтрагентаПоЛиду = Ложь;
	ВидимостьКнопкиСозданияКонтрагентаПоЛиду = Ложь;
	ВидимостьДоговора = Ложь;
	
	КонтрагентЗаполнен = ЗначениеЗаполнено(Объект.Контрагент);
	ЛидЗаполнен = ЗначениеЗаполнено(Объект.Лид);
	
	Если ЛидЗаполнен Тогда
		ЛидЗавершен = РаботаСЛидами.ЛидЗавершен(Объект.Лид);
	Иначе
		ЛидЗавершен = Ложь;
	КонецЕсли;
	
	Если ЛидЗавершен И Не Объект.Ссылка.Пустая() Тогда
		ЗаказПоЛиду = РегистрыСведений.СвязиКонтрагентЛид.ЗаказПоЛиду(Объект.Лид);
		ЭтоЗаказОтЛида = (Объект.Ссылка = ЗаказПоЛиду);
	Иначе
		ЭтоЗаказОтЛида = Ложь;
	КонецЕсли;
	
	Если ЭтоЗаявка(Объект.ВидОперации) Тогда
		
		ВидимостьЛида = Истина;
		
		Если ЛидЗаполнен Тогда
			
			Если ЛидЗавершен И Не ЭтоЗаказОтЛида И Не Параметры.МожноИспользоватьЗавершенногоЛида Тогда
				
				ВидимостьПодсказкиЛида = Истина;
				
				Если Объект.ВариантЗавершения = Перечисления.ВариантыЗавершенияЗаказа.Отменен
					Или Объект.Ссылка.Пустая() Тогда
					ТекстПодсказкиЛида = НСтр("ru = 'Работа с лидом завершена.'");
				Иначе
					ТекстПодсказкиЛида = НСтр("ru = 'Работа с лидом завершена. Рекомендуется отменить заявку'");
				КонецЕсли;
				
			ИначеЕсли ЗначениеЗаполнено(Параметры.СвязанныйКонтрагентСЛидом) Тогда
				ВидимостьПодсказкиЛида = Истина;
				ТекстПодсказкиЛида = ТекстПодсказкиПроСвязанногоКонтрагента(Параметры.СвязанныйКонтрагентСЛидом);
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		Если ЛидЗавершен И Не ЭтоЗаказОтЛида И Не Параметры.МожноИспользоватьЗавершенногоЛида Тогда
			
			ВидимостьЛида = Истина;
			ВидимостьПодсказкиЛида = Истина;
			
			Если Объект.ВариантЗавершения = Перечисления.ВариантыЗавершенияЗаказа.Отменен Тогда
				ТекстПодсказкиЛида = НСтр("ru = 'Работа с лидом завершена.'");
			Иначе
				ТекстПодсказкиЛида = НСтр("ru = 'Работа с лидом завершена. Рекомендуется отменить заявку'");
			КонецЕсли;
			
		Иначе
			
			ВидимостьКонтрагента = Истина;
			
			Если КонтрагентЗаполнен Тогда
				
				Если ЛидЗаполнен Тогда
					
					Если ЗначениеЗаполнено(Параметры.СвязанныйКонтрагентСЛидом)
						И Объект.Контрагент = Параметры.СвязанныйКонтрагентСЛидом
						Или ЛидЗавершен Тогда
						ВидимостьДоговора = Истина;
					Иначе
						ВидимостьЛида = Истина;
						ВидимостьПодсказкиКонтрагента = Истина;
					КонецЕсли;
					
				Иначе
					ВидимостьДоговора = Истина;
				КонецЕсли;
				
			ИначеЕсли ЛидЗаполнен Тогда
				
				ВидимостьЛида = Истина;
				
				Если ЗначениеЗаполнено(Параметры.СвязанныйКонтрагентСЛидом) Тогда
					ВидимостьКнопкиЗаполненияКонтрагентаПоЛиду = Истина;
				Иначе
					ВидимостьКнопкиСозданияКонтрагентаПоЛиду = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ВидимостьПодсказкиЛида Тогда
		ОтображениеПодсказкиЛида = ОтображениеПодсказки.ОтображатьСнизу;
	Иначе
		ОтображениеПодсказкиЛида = ОтображениеПодсказки.Авто;
	КонецЕсли;
	Если ВидимостьПодсказкиКонтрагента Тогда
		ВертикальноеПоложениеЭлементовВГруппеКонтрагента = ВертикальноеПоложениеЭлемента.Авто;
		ОтображениеПодсказкиКонтрагента = ОтображениеПодсказки.ОтображатьСнизу;
		ТекстПодсказкиКонтрагента = НСтр("ru = 'При записи заказа покупатель будет привязан к лиду'");
	Иначе
		ВертикальноеПоложениеЭлементовВГруппеКонтрагента = ВертикальноеПоложениеЭлемента.Центр;
		ОтображениеПодсказкиКонтрагента = ОтображениеПодсказки.Авто;
		ТекстПодсказкиКонтрагента = "";
	КонецЕсли;
	
	Если Не Параметры.ВестиРасчетыПоДоговорам Тогда
		ВидимостьДоговора = Ложь;
	КонецЕсли;
	
	Элементы.Лид.Видимость = ВидимостьЛида;
	Элементы.Лид.ОтображениеПодсказки = ОтображениеПодсказкиЛида;
	Элементы.Лид.Подсказка = ТекстПодсказкиЛида;
	
	Элементы.Контрагент.Видимость = ВидимостьКонтрагента;
	Элементы.Контрагент.ОтображениеПодсказки = ОтображениеПодсказкиКонтрагента;
	Элементы.Контрагент.Подсказка = ТекстПодсказкиКонтрагента;
	Элементы.КонтрагентИнформация.ВертикальноеПоложениеПодчиненных = ВертикальноеПоложениеЭлементовВГруппеКонтрагента;
	
	Элементы.ЗаполнитьПокупателяПоЛиду.Видимость = ВидимостьКнопкиЗаполненияКонтрагентаПоЛиду;
	Элементы.СоздатьКонтрагентаПоЛиду.Видимость = ВидимостьКнопкиСозданияКонтрагентаПоЛиду;
	Элементы.Контрагент.АвтоМаксимальнаяШирина =
	Не ВидимостьКнопкиЗаполненияКонтрагентаПоЛиду
	И Не ВидимостьКнопкиСозданияКонтрагентаПоЛиду
	И Не Элементы.ОстатокВзаиморасчетов.Видимость;
	
	Если ВидимостьКнопкиЗаполненияКонтрагентаПоЛиду Тогда
		Элементы.Контрагент.МаксимальнаяШирина = ДлинаПоляКонтрагентЕслиПоказаноЗаполнениеПоЛиду;
	КонецЕсли;
	Если ВидимостьКнопкиСозданияКонтрагентаПоЛиду Тогда
		Элементы.Контрагент.МаксимальнаяШирина = ДлинаПоляКонтрагентЕслиПоказаноСозданиеПоЛиду;
	КонецЕсли;
	
	Элементы.Договор.Видимость = ВидимостьДоговора;
	
КонецПроцедуры

// Процедура - Обновить отображение элементов заказа
//
// Параметры:
//  Параметры - Структура:
//   * Объект - ДанныеФормыСтруктура
//   * ИспользоватьЗаявки - Булево
//   * ИзменятьВид - Булево
//   * ИзменятьСостояние - Булево
//   * МожноИспользоватьЗавершенногоЛида - Булево
//   * СвязанныйКонтрагентСЛидом - СправочникСсылка.Контрагенты
//   * ПредыдущийВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
//   * ПараметрыОтображенияЭлементов - см ОбновитьОтображениеЭлементовЗаказа
// 
// Возвращаемое значение:
//  Структура - см РезультатИзмененияВидаОперации
//
//@skip-check doc-comment-field-type-strict
//@skip-check doc-comment-field-type
Функция ОбработатьИзменениеВидаОперацииЗаказа(Параметры) Экспорт
	
	Результат = РезультатИзмененияВидаОперации();
	Объект = Параметры.Объект;
	
	Если Не Параметры.ИспользоватьЗаявки Тогда
		Возврат Результат;
	КонецЕсли;
	
	СохраненныйВидОперации = Неопределено;
	Если Не ЗначениеЗаполнено(Объект.ВидОперации) Тогда
		СохраненныйВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "ВидОперации");
		Объект.ВидОперации = СохраненныйВидОперации;
	КонецЕсли;
	
	Если ЭтоЗаявка(Объект.ВидОперации) Тогда
		
		Если СохраненныйВидОперации = Неопределено Тогда
			СохраненныйВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "ВидОперации");
		КонецЕсли;
		
		Если ЭтоЗаказ(СохраненныйВидОперации) Тогда
			
			Объект.ВидОперации = СохраненныйВидОперации;
			Результат.ПереводЗаказаВЗаявку = Истина;
			Возврат Результат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат.ВидОперацииИзменен = Истина;
	ЭтоЗаявка = ЭтоЗаявка(Объект.ВидОперации);
	
	Если Параметры.ИзменятьВид Тогда
		
		ЗаявкиИспользуются = ЗаявкиИспользуются(Объект.ВидЗаказа);
		Если Не ЗаявкиИспользуются Тогда
			Объект.ВидЗаказа = ВидЗаказаСЗаявками(Объект.ВидОперации);
		КонецЕсли;
		
	КонецЕсли;
	
	НужноУстановитьНовоеСостояниеЗаявки =
	Параметры.ИзменятьСостояние
	И Не (ЭтоЗаявка
	И Объект.СостояниеЗаказа = Справочники.СостоянияЗаказовПокупателей.Завершен
	И Объект.ВариантЗавершения = Перечисления.ВариантыЗавершенияЗаказа.Отменен);
	
	Если НужноУстановитьНовоеСостояниеЗаявки Тогда
		Объект.СостояниеЗаказа = ПервоеДоступноеСостояние(Объект.ВидЗаказа, Объект.ВидОперации);
	КонецЕсли;
	
	Если Параметры.МожноПереводитьЗаявкуВЗаказСЗавершеннымЛидом И ЭтоЗаказ(Объект.ВидОперации) Тогда
		
		ЛидЗавершен = РаботаСЛидами.ЛидЗавершен(Объект.Лид);
		Если ЛидЗавершен Тогда
			
			Объект.Лид = Неопределено;
			Результат.ЛидИзменен = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоТипЗаказаСЗаявками(Объект.ВидОперации)
		И Не ЗначениеЗаполнено(Объект.Контрагент)
		И ЗначениеЗаполнено(Параметры.СвязанныйКонтрагентСЛидом) Тогда
		
		Если Не РаботаСЛидами.ЛидЗавершен(Объект.Лид) Тогда
			
			Объект.Контрагент = Параметры.СвязанныйКонтрагентСЛидом;
			
			Результат.КонтрагентИзменен = Истина;
			Возврат Результат;
			
		КонецЕсли;
		
		Если Не Объект.Ссылка.Пустая() Тогда
			
			ЗаказПоЛиду = РегистрыСведений.СвязиКонтрагентЛид.ЗаказПоЛиду(Объект.Лид);
			Если Объект.Ссылка = ЗаказПоЛиду Тогда
				
				Объект.Контрагент = Параметры.СвязанныйКонтрагентСЛидом;
				
				Результат.КонтрагентИзменен = Истина;
				Возврат Результат;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоЗаявка И ЗначениеЗаполнено(Объект.Контрагент) Тогда
		
		Объект.Контрагент = Неопределено;
		
		Результат.КонтрагентИзменен = Истина;
		Возврат Результат;
		
	КонецЕсли;
	
	ОбновитьОтображениеЭлементовЗаказа(Параметры.ПараметрыОтображенияЭлементов);
	Возврат Результат;
	
КонецФункции

// Процедура - Обновить отображение элементов заказа
//
// Параметры:
//  Параметры - Структура:
//   * Объект - ДанныеФормыСтруктура
//   * ИспользоватьЗаявки - Булево
//   * ПараметрыИзмененияВидаОперации - см ОбработатьИзменениеВидаОперацииЗаказа
//   * ПараметрыОтображенияЭлементов - см ОбновитьОтображениеЭлементовЗаказа
// 
// Возвращаемое значение:
//  Структура - РезультатИзмененияВидаОперации
//
//@skip-check doc-comment-field-type-strict
Функция ОбработатьИзменениеСостоянияЗаказа(Параметры) Экспорт
	
	Результат = РезультатИзмененияВидаОперации();
	Объект = Параметры.Объект;
	
	Если Не Параметры.ИспользоватьЗаявки Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЭтоСостояниеЗаявки = ЭтоСостояниеЗаявки(Объект.СостояниеЗаказа, Объект.ВидЗаказа, Объект.ВидОперации);
	
	ВидОперацииИзменен = Ложь;
	Если ЭтоСостояниеЗаявки Тогда
		
		Если ЭтоЗаказНаряд(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд;
			ВидОперацииИзменен = Истина;
		ИначеЕсли ЭтоЗаказ(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу;
			ВидОперацииИзменен = Истина;
		КонецЕсли;
		
	Иначе
		
		Если ЭтоЗаявкаЗаказНаряд(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд;
			ВидОперацииИзменен = Истина;
		ИначеЕсли ЭтоЗаявка(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу;
			ВидОперацииИзменен = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ВидОперацииИзменен Тогда
		
		Результат = ОбработатьИзменениеВидаОперацииЗаказа(Параметры.ПараметрыИзмененияВидаОперации);
		Если Результат.ПереводЗаказаВЗаявку Тогда
			Объект.СостояниеЗаказа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "СостояниеЗаказа");
		КонецЕсли;
		
	ИначеЕсли Объект.СостояниеЗаказа = Справочники.СостоянияЗаказовПокупателей.Завершен Тогда
		ОбновитьОтображениеЭлементовЗаказа(Параметры.ПараметрыОтображенияЭлементов);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Процедура - Обновить отображение элементов заказа
//
// Параметры:
//  Параметры - Структура:
//   * Объект - ДанныеФормыСтруктура
//   * ИспользоватьЗаявки - Булево
//   * ЭлементВидОперации - ПолеФормы
//   * ПараметрыИзмененияВидаОперации - см ОбработатьИзменениеВидаОперацииЗаказа
//   * ПараметрыУстановкиСпискаВыбораВидаОперации - см УстановитьСписокВыбораВидаОперацииЗаказаНаПродажу,
//                                                  см УстановитьСписокВыбораВидаОперацииЗаказНаряд
// 
// Возвращаемое значение:
//  Структура - см РезультатИзмененияВидаОперации
//
//@skip-check doc-comment-field-type
//@skip-check doc-comment-field-type-strict
Функция ОбработатьИзменениеВидаЗаказа(Параметры) Экспорт
	
	Результат = РезультатИзмененияВидаОперации();
	Объект = Параметры.Объект;
	
	Если Не Параметры.ИспользоватьЗаявки Тогда
		Объект.СостояниеЗаказа = ПервоеДоступноеСостояние(Объект.ВидЗаказа, Объект.ВидОперации);
		Возврат Результат;
	КонецЕсли;
	
	РаботаСЗаявкамиДоступнаНаФорме = РаботаСЗаявкамиДоступнаНаФорме(
	Параметры.ПараметрыУстановкиСпискаВыбораВидаОперации.ЭлементВидОперации);
	ЗаявкиИспользуются = ЗаявкиИспользуются(Объект.ВидЗаказа);
	
	ВидОперацииИзменен = Ложь;
	Если РаботаСЗаявкамиДоступнаНаФорме <> ЗаявкиИспользуются И Не ЗаявкиИспользуются Тогда
		
		Если ЭтоЗаявкаЗаказНаряд(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд;
			ВидОперацииИзменен = Истина;
		ИначеЕсли ЭтоЗаявка(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу;
			ВидОперацииИзменен = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	ОбновитьСписокВидаОперацийЗаказаНаФорме(
	ЗаявкиИспользуются, Объект.ВидОперации, Параметры.ПараметрыУстановкиСпискаВыбораВидаОперации);
	
	Если ВидОперацииИзменен Тогда
		Результат = ОбработатьИзменениеВидаОперацииЗаказа(Параметры.ПараметрыИзмененияВидаОперации);
	Иначе
		Объект.СостояниеЗаказа = ПервоеДоступноеСостояние(Объект.ВидЗаказа, Объект.ВидОперации);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбработатьИзменениеВариантаЗавершенияЗаказа(Параметры) Экспорт
	
	Результат = РезультатИзмененияВидаОперации();
	Объект = Параметры.Объект;
	
	Если Не ЭтоЗаявка(Объект.ВидОперации) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Объект.ВариантЗавершения = Перечисления.ВариантыЗавершенияЗаказа.Успешно Тогда
		
		ВидОперацииИзменен = Ложь;
		
		Если ЭтоЗаявкаЗаказНаряд(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд;
			ВидОперацииИзменен = Истина;
		ИначеЕсли ЭтоЗаявкаНаПродажу(Объект.ВидОперации) Тогда
			Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу;
			ВидОперацииИзменен = Истина;
		КонецЕсли;
		
		Если ВидОперацииИзменен Тогда
			Возврат ОбработатьИзменениеВидаОперацииЗаказа(Параметры.ПараметрыИзмененияВидаОперации);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбработкаОповещенияПриЗаписиВидаЗаказа(Параметры) Экспорт
	
	Результат = РезультатИзмененияВидаОперации();
	
	Объект = Параметры.Объект;
	
	ЗаявкиИспользуются = ЗаявкиИспользуются(Объект.ВидЗаказа);
	Если Не ЭтоСостояниеЗаявки(Объект.СостояниеЗаказа, Объект.ВидЗаказа, Объект.ВидОперации) Тогда
		
		Если ЗначениеЗаполнено(Объект.Лид) Тогда
			Объект.Лид = Неопределено;
			Результат.ЛидИзменен = Истина;
		КонецЕсли;
		
		Если Не ЗаявкиИспользуются И ЭтоЗаявка(Объект.ВидОперации) Тогда
			
			Если ЭтоТипЗаказНаряда(Объект.ВидОперации) Тогда
				Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд;
			Иначе
				Объект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу;
			КонецЕсли;
			
			Результат.ВидОперацииИзменен = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Результат.ВидОперацииИзменен Тогда
		
		РезультатИзмененияВидаОперации = ОбработатьИзменениеВидаОперацииЗаказа(Параметры.ПараметрыИзмененияВидаОперации);
		
		Если РезультатИзмененияВидаОперации.КонтрагентИзменен Тогда
			Результат.КонтрагентИзменен = Истина;
		КонецЕсли;
		Если РезультатИзмененияВидаОперации.ЛидИзменен Тогда
			Результат.ЛидИзменен = Истина;
		КонецЕсли;
		
		ОбновитьСписокВидаОперацийЗаказаНаФорме(
		ЗаявкиИспользуются, Объект.ВидОперации, Параметры.ПараметрыУстановкиСпискаВыбораВидаОперации);
		
		Возврат Результат;
		
	КонецЕсли;
	
	Если Не ВидСодержитСостояние(Объект.ВидЗаказа, Объект.СостояниеЗаказа) Тогда
		Объект.СостояниеЗаказа = ПервоеДоступноеСостояние(Объект.ВидЗаказа, Объект.ВидОперации);
	КонецЕсли;
	
	РезультатИзмененияСостояния = ОбработатьИзменениеСостоянияЗаказа(Параметры.ПараметрыИзмененияСостоянияЗаказа);
	Если Результат.ЛидИзменен Тогда
		ЗаполнитьЗначенияСвойств(Результат, РезультатИзмененияСостояния, , "ЛидИзменен");
	Иначе
		ЗаполнитьЗначенияСвойств(Результат, РезультатИзмененияСостояния);
	КонецЕсли;
	
	ОбновитьСписокВидаОперацийЗаказаНаФорме(
	ЗаявкиИспользуются, Объект.ВидОперации, Параметры.ПараметрыУстановкиСпискаВыбораВидаОперации);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область РаботаНаФормеВидаСостояний

Функция ПроверкаВозможностиИзмененияИспользованияЗаявокДляСостояния(
	ЗаявкиБылиВключены, ВидЗаказаОбъект, Знач ИндексСостояния) Экспорт
	
	Результат = НовыйРезультатПроверкиВозможностиИзмененияИспользованияЗаявок();
	
	ВидЗаказа = ВидЗаказаОбъект.Ссылка;
	ПорядокСостояний = ВидЗаказаОбъект.ПорядокСостояний;
	
	КоличествоСостояний = ПорядокСостояний.Количество();
	КоличествоСостоянийЗавершения = 2;
	Если ИндексСостояния >= КоличествоСостояний - 1 Тогда
		
		ИндексСостояния = КоличествоСостояний - КоличествоСостоянийЗавершения;
		Если ИндексСостояния < 0 Тогда
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;
	
	Состояние = ПорядокСостояний[ИндексСостояния].Состояние;
	СостояниеЗаявки = ВидЗаказаОбъект.СостояниеЗаявки;
	НомерСостоянияЗаявки = НомерСостоянияИзДанныхФормы(ПорядокСостояний, СостояниеЗаявки);
	
	Состояния = СостоянияМеждуИндексами(ПорядокСостояний, НомерСостоянияЗаявки - 1, ИндексСостояния);
	Состояния.Добавить(Состояние);
	Если ИндексСостояния <= НомерСостоянияЗаявки - 1 И Состояние <> СостояниеЗаявки Тогда
		Состояния.Добавить(СостояниеЗаявки);
	КонецЕсли;
	
	НужноДобавитьСостояниеЗавершения = 
	ЗаявкиБылиВключены
	И Состояния.Количество()
	И Состояния.Найти(ПорядокСостояний[0].Состояние) <> Неопределено;
	Если НужноДобавитьСостояниеЗавершения Тогда
		
		Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
			Состояния.Добавить(Справочники.СостоянияЗаказНарядов.Завершен);
		Иначе
			Состояния.Добавить(Справочники.СостоянияЗаказовПокупателей.Завершен);
		КонецЕсли;
		
	КонецЕсли;
	
	ИспользованиеСостоянийВЗаказах = ИспользованиеСостоянийВЗаказах(ВидЗаказа, Состояния, ЗаявкиБылиВключены);
	Если ИспользованиеСостоянийВЗаказах.Используются Тогда
		
		Если ЗаявкиБылиВключены Тогда
			Результат.ИспользованиеСостоянийВЗаявках = ИспользованиеСостоянийВЗаказах;
		Иначе
			Результат.ИспользованиеСостоянийВЗаказах = ИспользованиеСостоянийВЗаказах;
		КонецЕсли;
		
		Результат.ИзменениеВозможно = Ложь;
		Возврат Результат;
		
	КонецЕсли;
	
	Если ЗаявкиБылиВключены Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = ИспользованиеСостоянийЗаявок(
	Результат, ВидЗаказаОбъект, ИндексСостояния, Состояния);
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

