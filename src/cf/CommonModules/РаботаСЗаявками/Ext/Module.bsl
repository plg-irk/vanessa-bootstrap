
#Область СлужебныйПрограммныйИнтерфейс

#Область Лиды

// Функция - Количество заявок лида
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
// 
// Возвращаемое значение:
//  Структура:
//   * КоличествоЗаявокВРаботе - Число
//   * КоличествоОтмененныхЗаявок - Число
//
Функция КоличествоЗаявокЛида(Лид, ВидОперации = Неопределено) Экспорт
	
	Возврат Документы.ЗаказПокупателя.КоличествоЗаявокЛида(Лид, ВидОперации);
	
КонецФункции

// Функция - Данные количества заявок лида
// 
// Возвращаемое значение:
//  Структура:
//   * КоличествоЗаявокВРаботе - Число
//   * КоличествоОтмененныхЗаявок - Число
//
Функция ДанныеКоличестваЗаявокЛида() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("КоличествоЗаявокВРаботе", 0);
	Результат.Вставить("КоличествоОтмененныхЗаявок", 0);
	
	Возврат Результат;
	
КонецФункции

Функция ЕстьЗаявкиПоЛиду(Лид) Экспорт
	
	Возврат Документы.ЗаказПокупателя.ЕстьЗаявкиПоЛиду(Лид);
	
КонецФункции

// Функция - Наличие заявок в работе по лиду по виду операции
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - вид операции, для которого проверяется существование
//                                                             заявок в базе
//   * Значение - Булево
//
Функция НаличиеЗаявокВРаботеПоЛидуПоВидуОперации(Лид) Экспорт
	
	Возврат Документы.ЗаказПокупателя.НаличиеЗаявокВРаботеПоЛидуПоВидуОперации(Лид);
	
КонецФункции

Функция ЗаявкиЛидаВРаботе(Лид) Экспорт
	
	Возврат Документы.ЗаказПокупателя.ЗаявкиЛидаВРаботе(Лид);
	
КонецФункции

// Функция - Это заявка лида
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  Заявка - ДокументСсылка.ЗаказПокупателя
// 
// Возвращаемое значение:
//  Булево - проверяется соответствие реквизита заказа переданному лиду
//
Функция ЭтоЗаявкаЛида(Лид, Заявка) Экспорт
	
	Возврат (Лид = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Заявка, "Лид"));
	
КонецФункции

#КонецОбласти

#Область Заказы

// Есть заявки.
// 
// Параметры:
//  Заказы - Массив из ДокументСсылка.ЗаказПокупателя
// 
// Возвращаемое значение:
//  Булево - Есть заявки
Функция ЕстьЗаявки(Заказы) Экспорт
	
	ДанныеЗаказов = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Заказы, "ВидОперации");
	Для Каждого КлючЗначение Из ДанныеЗаказов Цикл
		Если ЭтоЗаявка(КлючЗначение.Значение) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти

#Область ВидыИСостояния

// Проверка, можно ли использовать состояние с переданными видом заказа и видом операции заказа
//
// Параметры:
//  Состояние - СправочникСсылка.СостоянияЗаказовПокупателей, СправочникСсылка.СостоянияЗаказНарядов - состояние
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
// 
// Возвращаемое значение:
//  Булево
//
Функция СостояниеДоступно(Состояние, ВидЗаказа, ВидОперации) Экспорт
	
	Если Не ВидСодержитСостояние(ВидЗаказа, Состояние) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЭтоСостояниеЗаявки = ЭтоСостояниеЗаявки(Состояние, ВидЗаказа, ВидОперации);
	ЭтоЗаявка = ЭтоЗаявка(ВидОперации);
	Возврат ЭтоСостояниеЗаявки И ЭтоЗаявка Или Не ЭтоСостояниеЗаявки И Не ЭтоЗаявка;
	
КонецФункции

// Функция - Первое доступное состояние по переданным параметрам
//
// Параметры:
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
// 
// Возвращаемое значение:
//  СправочникСсылка.СостоянияЗаказовПокупателей
//
Функция ПервоеДоступноеСостояние(ВидЗаказа, ВидОперации) Экспорт
	
	Результат = Неопределено;
	
	Если ЭтоЗаказНаПродажу(ВидОперации) Или ЭтоЗаказНаПереработку(ВидОперации) Тогда
		Результат = Справочники.ВидыЗаказовПокупателей.ПервоеСостояниеПослеЗаявки(ВидЗаказа);
	ИначеЕсли ЭтоЗаявкаНаПродажу(ВидОперации) Тогда
		Результат = Справочники.ВидыЗаказовПокупателей.ПервоеСостояние(ВидЗаказа);
	ИначеЕсли ЭтоЗаказНаряд(ВидОперации) Тогда
		Результат = Справочники.ВидыЗаказНарядов.ПервоеСостояниеПослеЗаявки(ВидЗаказа);
	ИначеЕсли ЭтоЗаявкаЗаказНаряд(ВидОперации) Тогда
		Результат = Справочники.ВидыЗаказНарядов.ПервоеСостояние(ВидЗаказа);
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не СостояниеДоступно(Результат, ВидЗаказа, ВидОперации) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Функция - Первое состояние после последнего состояния заявки
//
// Параметры:
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
// 
// Возвращаемое значение:
//  - СправочникСсылка.СостоянияЗаказовПокупателей
//  - СправочникСсылка.СостоянияЗаказНарядов
//
Функция ПервоеСостояниеПослеЗаявки(ВидЗаказа) Экспорт
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ПервоеСостояниеПослеЗаявки(ВидЗаказа);
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ПервоеСостояниеПослеЗаявки(ВидЗаказа);
	КонецЕсли;
	
КонецФункции

// Функция - Это состояние заявки
//
// Параметры:
//  Состояние - СправочникСсылка.СостоянияЗаказовПокупателей, СправочникСсылка.СостоянияЗаказНарядов - состояние заказа
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//  ВидОперации - Неопределено, ПеречислениеСсылка.ВидыОперацийЗаказПокупателя - вид операции заказа
// 
// Возвращаемое значение:
//  Булево - передано состояние заявки
//
Функция ЭтоСостояниеЗаявки(Состояние, ВидЗаказа, ВидОперации = Неопределено) Экспорт
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ЭтоСостояниеЗаявки(Состояние, ВидЗаказа, ВидОперации);
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ЭтоСостояниеЗаявки(Состояние, ВидЗаказа, ВидОперации);
	КонецЕсли;
	
КонецФункции

// Функция - Есть вид с включенными заявками
// 
// Возвращаемое значение:
//  Булево
//
Функция ЕстьВидСВключеннымиЗаявками() Экспорт
	
	ЕстьЗаявкиУЗаказовПокупателей = Справочники.ВидыЗаказовПокупателей.ЕстьВидСВключеннымиЗаявками();
	Если ЕстьЗаявкиУЗаказовПокупателей Тогда
		Возврат Истина;
	КонецЕсли;
	
	ЕстьЗаявкиУЗаказНарядов = Справочники.ВидыЗаказНарядов.ЕстьВидСВключеннымиЗаявками();
	Если ЕстьЗаявкиУЗаказНарядов Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Все состояния заявки у вида
//
// Параметры:
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.СостоянияЗаказовПокупателей
//  Массив из СправочникСсылка.СостоянияЗаказНарядов
//
Функция ВсеСостоянияЗаявки(ВидЗаказа) Экспорт
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ВсеСостоянияЗаявки(ВидЗаказа);
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ВсеСостоянияЗаявки(ВидЗаказа);
	КонецЕсли;
	
КонецФункции

// Все состояния обычных заказов (не заявок) у вида
//
// Параметры:
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.СостоянияЗаказовПокупателей
//  Массив из СправочникСсылка.СостоянияЗаказНарядов
//
Функция ВсеСостоянияЗаказа(ВидЗаказа) Экспорт
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ВсеСостоянияЗаказа(ВидЗаказа);
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ВсеСостоянияЗаказа(ВидЗаказа);
	КонецЕсли;
	
КонецФункции

// Состояние заказа (не заявки) с учетом уже существующего состояния
//
// Параметры:
//  ТекущееСостояниеЗаказа - СправочникСсылка.СостоянияЗаказовПокупателей, СправочникСсылка.СостоянияЗаказНарядов - текущее состояние заказа
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
// 
// Возвращаемое значение:
//  - СправочникСсылка.СостоянияЗаказовПокупателей
//  - СправочникСсылка.СостоянияЗаказНарядов
//
Функция СостояниеЗаказа(ТекущееСостояниеЗаказа, ВидЗаказа, ВидОперации) Экспорт
	
	Если ЗначениеЗаполнено(ТекущееСостояниеЗаказа) Тогда
		
		ЭтоСостояниеЗаявки = ЭтоСостояниеЗаявки(ТекущееСостояниеЗаказа, ВидЗаказа, ВидОперации);
		Если ЭтоСостояниеЗаявки Тогда
			Возврат ПервоеСостояниеПослеЗаявки(ВидЗаказа);
		КонецЕсли;
		
		Возврат ТекущееСостояниеЗаказа;
		
	Иначе
		Возврат ПервоеСостояниеПослеЗаявки(ВидЗаказа);
	КонецЕсли;
	
КонецФункции

Функция ПоследнийИспользованныйДоступныйВидЗаказа(ВидОперации, Состояние = Неопределено) Экспорт
	
	Если ЭтоТипЗаказНаряда(ВидОперации) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ПоследнийИспользованныйДоступныйВидЗаказа(ВидОперации, Состояние);
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ПоследнийИспользованныйДоступныйВидЗаказа(ВидОперации, Состояние);
	КонецЕсли;
	
КонецФункции

// Функция - Вид содержит состояние
//
// Параметры:
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//  СостояниеЗаказа - СправочникСсылка.СостоянияЗаказовПокупателей, СправочникСсылка.СостоянияЗаказНарядов - состояние заказа
// 
// Возвращаемое значение:
//  Булево
//
Функция ВидСодержитСостояние(ВидЗаказа, СостояниеЗаказа) Экспорт
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ВидСодержитСостояние(ВидЗаказа, СостояниеЗаказа);
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ВидСодержитСостояние(ВидЗаказа, СостояниеЗаказа);
	КонецЕсли;
	
КонецФункции

// Функция - Вид заказа с заявками
//
// Параметры:
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
// 
// Возвращаемое значение:
//  - СправочникСсылка.ВидыЗаказовПокупателей
//  - СправочникСсылка.ВидыЗаказНарядов
//
Функция ВидЗаказаСЗаявками(ВидОперации) Экспорт
	
	Если ЭтоТипЗаказНаряда(ВидОперации) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ВидЗаказаСЗаявками();
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ВидЗаказаСЗаявками();
	КонецЕсли;
	
КонецФункции

Функция ВидыЗаказовГдеСостояниеИспользуетЗаявки(СостояниеЗаказа) Экспорт
	
	Если ЭтоСостояниеЗаказНаряда(СостояниеЗаказа) Тогда
		Возврат Справочники.ВидыЗаказНарядов.ВидыЗаказовГдеСостояниеИспользуетЗаявки(СостояниеЗаказа);
	Иначе
		Возврат Справочники.ВидыЗаказовПокупателей.ВидыЗаказовГдеСостояниеИспользуетЗаявки(СостояниеЗаказа);
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ИспользованиеЗаявок

// Функция - Заявки доступны по правам и опциям
// 
// Возвращаемое значение:
//  Булево
//
Функция ЗаявкиДоступны() Экспорт
	
	Возврат РаботаСЛидами.ЛидыДоступны();
	
КонецФункции

// Функция - Заявки используются
//
// Параметры:
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//  ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
// 
// Возвращаемое значение:
//  Булево
//
Функция ЗаявкиИспользуются(ВидЗаказа = Неопределено, ВидОперации = Неопределено) Экспорт
	
	Если Не ЗаявкиДоступны() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидЗаказа) Тогда
		СостояниеЗаявки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидЗаказа, "СостояниеЗаявки");
		Возврат ЗначениеЗаполнено(СостояниеЗаявки);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидОперации) Тогда
		Если ЭтоЗаказНаряд(ВидОперации) Тогда
			Возврат Справочники.ВидыЗаказНарядов.ЕстьВидСВключеннымиЗаявками();
		Иначе
			Возврат Справочники.ВидыЗаказовПокупателей.ЕстьВидСВключеннымиЗаявками();
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЕстьВидСВключеннымиЗаявками();
	
КонецФункции

// Функция - Использование заявок по виду операции
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
//   * Значение - Булево
//
Функция ИспользованиеЗаявокПоВидуОперации() Экспорт
	
	Результат = Новый Соответствие;
	
	Результат[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу] = 
	Справочники.ВидыЗаказовПокупателей.ЕстьВидСВключеннымиЗаявками();
	
	Результат[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд] = 
	Справочники.ВидыЗаказНарядов.ЕстьВидСВключеннымиЗаявками();
	
	Возврат Результат;
	
КонецФункции

// Функция - Наличие заказов по состояниям
//
// Параметры:
//  ВидЗаказа - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//  СостоянияЗаказов - СправочникСсылка.СостоянияЗаказовПокупателей, СправочникСсылка.СостоянияЗаказНарядов - состояние заказа
//  ПоискЗаявок - Булево - если Истина, то будут искаться заявки
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ - СправочникСсылка.СостоянияЗаказовПокупателей, СправочникСсылка.СостоянияЗаказНарядов - состояние заказа
//   * Значение - Структура:
//      ** ЕстьЗаказ - Булево
//      ** Представление - Строка - представление состояния
//
Функция НаличиеЗаказовПоСостояниям(ВидЗаказа, СостоянияЗаказов, ПоискЗаявок = Ложь) Экспорт
	
	Возврат Документы.ЗаказПокупателя.НаличиеЗаказовПоСостояниям(ВидЗаказа, СостоянияЗаказов, ПоискЗаявок);
	
КонецФункции

Функция ЕстьЗаказыВСостоянии(ВидЗаказа, СостояниеЗаказа, ПоискЗаявок = Ложь) Экспорт
	
	СостояниеЗаказаВСписке = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СостояниеЗаказа);
	НаличиеЗаказов = НаличиеЗаказовПоСостояниям(ВидЗаказа, СостояниеЗаказаВСписке, ПоискЗаявок);
	
	Возврат НаличиеЗаказов[СостояниеЗаказа].ЕстьЗаказ;
	
КонецФункции

#КонецОбласти

