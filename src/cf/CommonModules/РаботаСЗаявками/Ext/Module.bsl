Функция СоответствиеВидовОпераций() Экспорт
	
	Результат = Новый Соответствие;
	
	Результат[Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу] =
	Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу;
	Результат[Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд] =
	Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд;
	
	Результат[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу] =
	Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу;
	Результат[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд] =
	Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд;
	
	Возврат Результат;
	
КонецФункции

Процедура ВызватьИсключениеЕслиЗаявка(СсылкаИлиСсылки) Экспорт
	
	Если ТипЗнч(СсылкаИлиСсылки) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		
		ВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаИлиСсылки, "ВидОперации");
		Если РаботаСЗаявкамиКлиентСервер.ЭтоЗаявка(ВидОперации) Тогда
			ВызватьИсключение РаботаСЗаявкамиКлиентСервер.СообщениеОНеобходимостиПереводаЗаявкиВЗаказ(СсылкаИлиСсылки);
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(СсылкаИлиСсылки) = Тип("Массив") И СсылкаИлиСсылки.Количество() Тогда
		
		ЗаказыПокупателя = Новый Массив;
		Для Каждого Ссылка Из СсылкаИлиСсылки Цикл
			Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
				ЗаказыПокупателя.Добавить(Ссылка);
			КонецЕсли;
		КонецЦикла;
		
		ВидыОпераций = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ЗаказыПокупателя, "ВидОперации");
		Для Каждого КлючЗначение Из ВидыОпераций Цикл
			Если РаботаСЗаявкамиКлиентСервер.ЭтоЗаявка(КлючЗначение.Значение) Тогда
				ВызватьИсключение РаботаСЗаявкамиКлиентСервер.СообщениеОНеобходимостиПереводаЗаявкиВЗаказ(КлючЗначение.Ключ);
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

