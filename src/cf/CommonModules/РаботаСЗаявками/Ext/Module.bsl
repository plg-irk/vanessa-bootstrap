КонецФункции

Функция ТекстПодсказкиПроСвязанногоКонтрагента(Контрагент)
	
	ПредставлениеКонтрагента = Строка(Контрагент);
	
	ТекстПодсказкиБезКонтрагента = НСтр("ru = 'Повторное обращение от ""%1""'");
	
	ДлинаПодсказкиБезКонтрагента = СтрДлина(ТекстПодсказкиБезКонтрагента) - 2;
	МаксимальнаяДлинаПодсказки = 60;
	ДлинаПостфикса = 3;
	СокращенноеПредставлениеКонтрагента = СокращеннаяСтрока(
	ПредставлениеКонтрагента, МаксимальнаяДлинаПодсказки - ДлинаПодсказкиБезКонтрагента - ДлинаПостфикса, "...");
	
	Возврат СтрШаблон(ТекстПодсказкиБезКонтрагента, СокращенноеПредставлениеКонтрагента);
	
КонецФункции

Функция СокращеннаяСтрока(Строка, КоличествоСимволовВРезультате, Постфикс = "")
	
	Если СтрДлина(Строка) <= КоличествоСимволовВРезультате Тогда
		Возврат Строка;
	КонецЕсли;
	
	Результат = Сред(Строка, 1, КоличествоСимволовВРезультате);
	
	Если Не ПустаяСтрока(Постфикс) Тогда
		Возврат СтрШаблон("%1%2", Результат, Постфикс);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти