// Обработка проверки заполнения виды заказа, результат нужно передать в
// РаботаСЗаявкамиКлиентСервер.ОбработатьРезультатПроверкиВозможностиИзмененияИспользованияЗаявокДляСостояния
//
// Параметры:
//  Данные - Структура:
//   * Ссылка - СправочникСсылка.ВидыЗаказовПокупателей, СправочникСсылка.ВидыЗаказНарядов - вид заказа
//   * СостояниеЗаявки - СправочникСсылка.СостоянияЗаказовПокупателей, СправочникСсылка.СостоянияЗаказНарядов - состояние заявки
//   * СостояниеВыполнения - Неопределено, СправочникСсылка.СостоянияЗаказНарядов - состояние выполнения заказа
//   * СостояниеДоставлен - Неопределено, СправочникСсылка.СостоянияЗаказовПокупателей - состояние доставки заказа
//   * СостояниеОжидаетОтгрузки - Неопределено, СправочникСсылка.СостоянияЗаказовПокупателей - состояние ожидания отгрузки заказа
//   * СостояниеОтгружен - Неопределено, СправочникСсылка.СостоянияЗаказовПокупателей - состояние отгрузки заказа
//   * ПорядокСостояний - ТабличнаяЧасть - см СправочникСсылка.ВидыЗаказовПокупателей
// 
// Возвращаемое значение:
//  Структура - см НовыйРезультатПроверкиВозможностиИзмененияИспользованияЗаявок
//
Функция ОбработкаПроверкиЗаполненияВидыЗаказа(Данные) Экспорт
	
	Результат = НовыйРезультатПроверкиВозможностиИзмененияИспользованияЗаявок();
	
	ВидЗаказа = Данные.Ссылка;
	СостояниеЗаявки = Данные.СостояниеЗаявки;
	ПорядокСостояний = Данные.ПорядокСостояний;
	
	Если Не НужноПроводитьПроверкуИспользованияСостоянийПриОбработкеПроверкиЗаполнения(Данные) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СостояниеЗаявкиЗаполнено = ЗначениеЗаполнено(СостояниеЗаявки);
	
	Если СостояниеЗаявкиЗаполнено Тогда
		
		НомерСостоянияЗаявки = Справочники.ВидыЗаказовПокупателей.НомерСостояния(ПорядокСостояний, СостояниеЗаявки);
		ИндексПоследнегоСостояния = ПорядокСостояний.Количество() - 1;
		
		СостоянияОбычныхЗаказов = СостоянияМеждуИндексами(
		ПорядокСостояний, НомерСостоянияЗаявки - 1, ИндексПоследнегоСостояния);
		
		СостоянияЗаявок = СостоянияМеждуИндексами(ПорядокСостояний, НомерСостоянияЗаявки - 1, 0);
		СостоянияЗаявок.Добавить(ПорядокСостояний[0].Состояние);
		Если ПорядокСостояний[0].Состояние <> СостояниеЗаявки Тогда
			СостоянияЗаявок.Добавить(СостояниеЗаявки);
		КонецЕсли;
		
	Иначе
		
		НомерСостоянияЗаявки = 0;
		
		СостоянияОбычныхЗаказов = Новый Массив;
		Для Каждого СтрокаПорядка Из ПорядокСостояний Цикл
			СостоянияОбычныхЗаказов.Добавить(СтрокаПорядка.Состояние);
		КонецЦикла;
		
		СостоянияЗаявок = Новый Массив;
		
	КонецЕсли;
	
	Если СостояниеЗаявкиЗаполнено Тогда
		
		ИспользованиеСостоянийВЗаказах = ИспользованиеСостоянийВЗаказах(ВидЗаказа, СостоянияЗаявок, Ложь);
		Если ИспользованиеСостоянийВЗаказах.Используются Тогда
			Результат.Вставить("ИспользованиеСостоянийВЗаказах", ИспользованиеСостоянийВЗаказах);
			Результат.Вставить("ИзменениеВозможно", Ложь);
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;
	
	ИспользованиеСостоянийВЗаявках = ИспользованиеСостоянийВЗаказах(ВидЗаказа, СостоянияОбычныхЗаказов, Истина);
	Если ИспользованиеСостоянийВЗаявках.Используются Тогда
		Результат.Вставить("ИспользованиеСостоянийВЗаявках", ИспользованиеСостоянийВЗаявках);
		Результат.Вставить("ИзменениеВозможно", Ложь);
		Возврат Результат;
	КонецЕсли;
	
	Результат = ИспользованиеСостоянийЗаявок(Результат, Данные, НомерСостоянияЗаявки - 1, СостоянияЗаявок);
	Возврат Результат;
	
КонецФункции

