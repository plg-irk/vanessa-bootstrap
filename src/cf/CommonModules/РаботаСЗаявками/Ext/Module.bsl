// Действия при обработке заполнения заказа
//
// Параметры:
//  Отказ - Булево
//  ПроверяемыеРеквизиты - Массив из Строка
//  Данные - Структура:
//   * ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
//   * Лид - СправочникСсылка.Лиды
//   * Контрагент - СправочникСсылка.Контрагенты
//   * ЭтоНовый - Булево
//
Процедура ОбработкаПроверкиЗаполненияЗаказа(Отказ, ПроверяемыеРеквизиты, Данные) Экспорт
	
	Если ЭтоЗаказ(Данные.ВидОперации) Тогда
		
		ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Лид");
		
		Если ЗначениеЗаполнено(Данные.Лид) И Не ЗначениеЗаполнено(Данные.Контрагент) Тогда
			ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Контрагент");
			ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Договор");
			ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "ВалютаДокумента");
		КонецЕсли;
		
	Иначе
		
		ПроверяемыеРеквизиты.Очистить();
		ПроверяемыеРеквизиты.Добавить("Лид");
		
	КонецЕсли;
	
КонецПроцедуры

// Действия при обработке перед записью заказа
//
// Параметры:
//  Отказ - Булево
//  Данные - Структура:
//  * Ссылка - ДокументСсылка.ЗаказПокупателя
//  * Контрагент - СправочникСсылка.Контрагенты
//  * Лид - СправочникСсылка.Лиды
//  * ВидОперации - ПеречислениеСсылка.ВидыОперацийЗаказПокупателя
//  * ЭтоНовый - Булево
//  * ДополнительныеСвойства - Структура
//
Процедура ОбработкаПередЗаписьюЗаказа(Отказ, Данные) Экспорт
	
	ПрошлыйВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные.Ссылка, "ВидОперации");
	ЭтоЗаявка = ЭтоЗаявка(Данные.ВидОперации);
	
	Если ЭтоЗаказ(ПрошлыйВидОперации) И ЭтоЗаявка Тогда
		ВызватьИсключение НСтр("ru = 'Заказ не может быть переведен в заявку'");
	КонецЕсли;
	
	Если ЭтоЗаявка Тогда
		
		Данные.Контрагент = Неопределено;
		
		Если ЗначениеЗаполнено(Данные.Лид) И Данные.ЭтоНовый Тогда
			
			Если РаботаСЛидами.ЛидЗавершен(Данные.Лид) Тогда
				ТекстСообщения = НСтр("ru = 'Работа с лидом завершена.
				|Измените лида для создания заявки'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "Объект.Лид", , Отказ);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоЗаявка Или Не ЗначениеЗаполнено(Данные.Лид) Или ЗначениеЗаполнено(Данные.Контрагент) Тогда
		Возврат;
	КонецЕсли;
	
	МожноИспользоватьЗавершенногоЛида = Данные.ДополнительныеСвойства.Свойство("МожноИспользоватьЗавершенногоЛида");
	Если ЭтоЗаявка(ПрошлыйВидОперации) И Не МожноИспользоватьЗавершенногоЛида Тогда
		
		Если РаботаСЛидами.ЛидЗавершен(Данные.Лид) Тогда
			
			ТекстСообщения = НСтр("ru = 'Заявку нельзя перевести в заказ, так как работа с лидом завершена.
			|Измените лида для продолжения работы с заказом'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "Объект.Лид", , Отказ);
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	СвязанныйКонтрагент = Справочники.Лиды.СвязанныйКонтрагент(Данные.Лид);
	Если ЗначениеЗаполнено(СвязанныйКонтрагент) Тогда
		ТекстСообщения = НСтр("ru = 'Поле ""Покупатель"" не заполнено.
		|Следует заполнить его по лиду'");
	Иначе
		ТекстСообщения = НСтр("ru = 'Поле ""Покупатель"" не заполнено.
		|Для его заполнения следует перевести используемого лида в нового покупателя'");
	КонецЕсли;
	
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "Объект.Контрагент", , Отказ);
	
КонецПроцедуры

// Действия при обработке при записи заказа
//
// Параметры:
//  Отказ - Булево
//  Данные - Структура:
//   * Лид - СправочникСсылка.Лиды
//   * Контрагент - СправочникСсылка.Контрагенты
//   * Ссылка - ДокументСсылка.ЗаказПокупателя
//
Процедура ОбработкаПриЗаписиЗаказа(Отказ, Данные) Экспорт
	
	Если Не ЗначениеЗаполнено(Данные.Лид) Тогда
		Возврат;
	КонецЕсли;
	
	ВариантЗавершенияЛида = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Данные.Лид, "ВариантЗавершения");
	Если ВариантЗавершенияЛида = Перечисления.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя Тогда
		
		ДанныеСвязиЛида = РегистрыСведений.СвязиКонтрагентЛид.СвязьПоЛиду(Данные.Лид);
		Если ДанныеСвязиЛида = Неопределено Тогда
			РегистрыСведений.СвязиКонтрагентЛид.НоваяСвязь(Данные.Контрагент, Данные.Лид, Данные.Ссылка);
		ИначеЕсли Данные.Ссылка <> ДанныеСвязиЛида.Заказ Тогда
			РегистрыСведений.СвязиКонтрагентЛид.ДобавитьЗаказВСвязь(Данные.Лид, Данные.Контрагент, Данные.Ссылка);
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	ЛидОбъект = Данные.Лид.ПолучитьОбъект();
	ЛидОбъект.Заблокировать();
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ПереводВКачественныйЛид", Истина);
	ДанныеЗаполнения.Вставить("Вид", Перечисления.ВидыЛидов.ПовторноеОбращение);
	ЛидОбъект.Заполнить(ДанныеЗаполнения);
	Если Не ЛидОбъект.ПроверитьЗаполнение() Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ЛидОбъект.ДополнительныеСвойства.Вставить("Контрагент", Данные.Контрагент);
	ЛидОбъект.ДополнительныеСвойства.Вставить("Заказ", Данные.Ссылка);
	
	ЛидОбъект.Записать();
	
КонецПроцедуры

#КонецОбласти

