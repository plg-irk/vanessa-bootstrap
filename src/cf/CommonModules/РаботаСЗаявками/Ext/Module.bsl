КонецФункции

Функция ИспользованиеЗаявокВАссистентеУправления(ВидЗаказа, Состояния)
	
	Результат = НовыйРезультатПроверки();
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд;
	Иначе
		ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗадачиАссистентаУправленияПараметрыУсловия.Ссылка КАК Ссылка,
		|	ЗадачиАссистентаУправленияПараметрыУсловия.Значение КАК Значение
		|ПОМЕСТИТЬ втВидыОперации
		|ИЗ
		|	Справочник.ЗадачиАссистентаУправления.ПараметрыУсловия КАК ЗадачиАссистентаУправленияПараметрыУсловия
		|ГДЕ
		|	ЗадачиАссистентаУправленияПараметрыУсловия.Параметр = ""ВидОперации""
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗадачиАссистентаУправленияПараметрыУсловия.Ссылка КАК Ссылка,
		|	ЗадачиАссистентаУправленияПараметрыУсловия.Значение КАК Значение
		|ПОМЕСТИТЬ втВидыЗаказов
		|ИЗ
		|	Справочник.ЗадачиАссистентаУправления.ПараметрыУсловия КАК ЗадачиАссистентаУправленияПараметрыУсловия
		|ГДЕ
		|	ЗадачиАссистентаУправленияПараметрыУсловия.Параметр = ""ВидЗаказа""
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗадачиАссистентаУправленияЗначенияЗаполнения.Ссылка КАК Ссылка,
		|	ЗадачиАссистентаУправленияЗначенияЗаполнения.Значение КАК СостояниеЗаказаХранилищеЗначения,
		|	втВидыОперации.Значение КАК ВидОперацииХранилищеЗначения,
		|	втВидыЗаказов.Значение КАК ВидЗаказаХранилищеЗначения
		|ИЗ
		|	Справочник.ЗадачиАссистентаУправления.ЗначенияЗаполнения КАК ЗадачиАссистентаУправленияЗначенияЗаполнения
		|		ЛЕВОЕ СОЕДИНЕНИЕ втВидыОперации КАК втВидыОперации
		|		ПО ЗадачиАссистентаУправленияЗначенияЗаполнения.Ссылка = втВидыОперации.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ втВидыЗаказов КАК втВидыЗаказов
		|		ПО ЗадачиАссистентаУправленияЗначенияЗаполнения.Ссылка = втВидыЗаказов.Ссылка
		|ГДЕ
		|	ЗадачиАссистентаУправленияЗначенияЗаполнения.Параметр = ""СостояниеЗаказа""";
	
	СписокНайденныхСостояний = Новый Массив;
	
	ТипХранилищеЗначения = Тип("ХранилищеЗначения");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если ТипЗнч(Выборка.ВидОперацииХранилищеЗначения) <> ТипХранилищеЗначения
			Или ТипЗнч(Выборка.ВидЗаказаХранилищеЗначения) <> ТипХранилищеЗначения
			Или ТипЗнч(Выборка.СостояниеЗаказаХранилищеЗначения) <> ТипХранилищеЗначения Тогда
			Продолжить;
		КонецЕсли;
		
		ВидОперацииВыбор = Выборка.ВидОперацииХранилищеЗначения.Получить();
		Если ВидОперацииВыбор <> ВидОперации Тогда
			Продолжить;
		КонецЕсли;
		
		ВидЗаказаВыбор = Выборка.ВидЗаказаХранилищеЗначения.Получить();
		Если ВидЗаказаВыбор <> ВидЗаказа Тогда
			Продолжить;
		КонецЕсли;
		
		СостояниеЗаказаВыбор = Выборка.СостояниеЗаказаХранилищеЗначения.Получить();
		Если Не ЗначениеЗаполнено(СостояниеЗаказаВыбор) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Состояния.Найти(СостояниеЗаказаВыбор) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СписокНайденныхСостояний.Добавить(СостояниеЗаказаВыбор);
		
		Если Результат.Ссылка = Неопределено Тогда
			Результат.Вставить("Ссылка", Выборка.Ссылка);
		КонецЕсли;
		
	КонецЦикла;
	
	ПредставленияСостояний = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СписокНайденныхСостояний, "Представление");
	Для Каждого КлючЗначение Из ПредставленияСостояний Цикл
		
		ДанныеСостояния = Новый Структура("Представление", КлючЗначение.Значение);
		Результат.ИспользованиеСостояний[КлючЗначение.Ключ] = ДанныеСостояния;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Результат.Ссылка) Тогда
		Результат.НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Метаданные.Обработки.АссистентУправления);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИспользованиеЗаявокВМаг1С(ВидЗаказа, Состояния)
	
	Результат = НовыйРезультатПроверки();
	Результат.Вставить("Используются", Ложь);
	
	Если ВидЗаказа <> Справочники.ВидыЗаказовПокупателей.Основной Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПоказыватьКомандуУстановитьРасширениеМаг1с = ПолучитьФункциональнуюОпцию(
	"ПоказыватьКомандуУстановитьРасширениеМаг1с");
	Если ПоказыватьКомандуУстановитьРасширениеМаг1с Тогда
		Возврат Результат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	СписокВитрин = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища("Маг1С_.СписокВитринБазы");
	
	Если СписокВитрин = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	СписокНайденныхСостояний = Новый Массив;
	
	Для Каждого Витрина Из СписокВитрин Цикл
		
		КлючДанных = СтрШаблон("Маг1С_%1.НастройкиВитрины", Витрина.Ключ);
		ДанныеВитрины = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(КлючДанных);
		Если ДанныеВитрины = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СоответствияСостояний = ДанныеВитрины.НастройкиВитрины.ДополнительныеНастройки.СоответствияСтатусовЗаказов;
		Для Каждого КлючЗначение Из СоответствияСостояний Цикл
			
			СписокНастроенныхСостояний = КлючЗначение.Значение;
			Для Каждого НастроенноеСостояние Из СписокНастроенныхСостояний Цикл
				Если Состояния.Найти(НастроенноеСостояние) <> Неопределено Тогда
					СписокНайденныхСостояний.Добавить(НастроенноеСостояние);
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла;
		
		Если СписокНайденныхСостояний.Количество() Тогда
			Результат.Используются = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Результат.Используются Тогда
		
		ПредставленияСостояний = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СписокНайденныхСостояний, "Представление");
		Для Каждого КлючЗначение Из ПредставленияСостояний Цикл
			
			ДанныеСостояния = Новый Структура("Представление", КлючЗначение.Значение);
			Результат.ИспользованиеСостояний[КлючЗначение.Ключ] = ДанныеСостояния;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#Область МобильныеПриложения

Функция ИспользованиеЗаявокВМобильныхПриложениях(ВидЗаказа, Состояния)
	
	Результат = НовыйРезультатПроверки();
	Результат.Вставить("Представление", "");
	
	ВариантыНастроекМП = "Заказы, Кладовщик";
	НаименованияПолейНастроек = Новый Структура(ВариантыНастроекМП, Новый Структура, Новый Структура);
	
	НаименованияПолейНастроек.Заказы.Вставить("ВидЗаказа1", "ВидЗаказаПокупателяЗаданиеТорговомуПредставителю");
	НаименованияПолейНастроек.Заказы.Вставить("СостояниеЗаказа1", "СостояниеЗаданиеТорговомуПредставителю");
	
	НаименованияПолейНастроек.Кладовщик.Вставить("ВидЗаказа1", "ВидЗаказаПокупателяДляСборки");
	НаименованияПолейНастроек.Кладовщик.Вставить("СостояниеЗаказа1", "СостояниеЗаказаДляСборки");
	НаименованияПолейНастроек.Кладовщик.Вставить("ВидЗаказа2", "ВидЗаказаПокупателяСобран");
	НаименованияПолейНастроек.Кладовщик.Вставить("СостояниеЗаказа2", "СостояниеЗаказаСобран");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбменСМобильнымиПриложениями.Ссылка КАК Ссылка,
		|	ОбменСМобильнымиПриложениями.НастройкиОбмена КАК НастройкиОбмена,
		|	ОбменСМобильнымиПриложениями.МобильноеПриложение КАК МобильноеПриложение,
		|	ОбменСМобильнымиПриложениями.МобильноеПриложение.ВариантНастройки КАК ВариантНастройки,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ОбменСМобильнымиПриложениями.МобильноеПриложение) КАК Представление
		|ИЗ
		|	ПланОбмена.ОбменСМобильнымиПриложениями КАК ОбменСМобильнымиПриложениями";
	
	СписокНайденныхСостояний = Новый Массив;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Не ЗначениеЗаполнено(Выборка.МобильноеПриложение) Тогда
			Продолжить;
		КонецЕсли;
		
		НастройкаКомпоновки = Выборка.НастройкиОбмена.Получить();
		Если НастройкаКомпоновки = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованияПолей = НаименованияПолейНастроек[Выборка.ВариантНастройки];
		
		КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
		УправлениеМобильнымиПриложениями.ЗаполнитьНастройкиКомпоновщика(
		КомпоновщикНастроек, Выборка.МобильноеПриложение, НастройкаКомпоновки);
		
		НастроенныйВидЗаказа = ЗначениеЭлементаОтбораИзПользовательскихНастроек(
		КомпоновщикНастроек, НаименованияПолей.ВидЗаказа1);
		Если НастроенныйВидЗаказа <> Неопределено И НастроенныйВидЗаказа = ВидЗаказа Тогда
			
			НастроенноеСостояниеЗаказа = ЗначениеЭлементаОтбораИзПользовательскихНастроек(
			КомпоновщикНастроек, НаименованияПолей.СостояниеЗаказа1);
			Если ЗначениеЗаполнено(НастроенноеСостояниеЗаказа)
				И Состояния.Найти(НастроенноеСостояниеЗаказа) <> Неопределено Тогда
				
				СписокНайденныхСостояний.Добавить(НастроенноеСостояниеЗаказа);
				
				Если Результат.Ссылка = Неопределено Тогда
					Результат.Ссылка = Выборка.Ссылка;
					Результат.Представление = Выборка.Представление;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если Выборка.ВариантНастройки = "Заказы" Тогда
			Продолжить;
		КонецЕсли;
		
		НастроенныйВидЗаказа = ЗначениеЭлементаОтбораИзПользовательскихНастроек(
		КомпоновщикНастроек, НаименованияПолей.ВидЗаказа2);
		Если НастроенныйВидЗаказа <> Неопределено И НастроенныйВидЗаказа = ВидЗаказа Тогда
			
			НастроенноеСостояниеЗаказа = ЗначениеЭлементаОтбораИзПользовательскихНастроек(
			КомпоновщикНастроек, НаименованияПолей.СостояниеЗаказа2);
			Если ЗначениеЗаполнено(НастроенноеСостояниеЗаказа)
				И Состояния.Найти(НастроенноеСостояниеЗаказа) <> Неопределено Тогда
				
				СписокНайденныхСостояний.Добавить(НастроенноеСостояниеЗаказа);
				
				Если Результат.Ссылка = Неопределено Тогда
					Результат.Ссылка = Выборка.Ссылка;
					Результат.Представление = Выборка.Представление;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ПредставленияСостояний = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СписокНайденныхСостояний, "Представление");
	Для Каждого КлючЗначение Из ПредставленияСостояний Цикл
		
		ДанныеСостояния = Новый Структура("Представление", КлючЗначение.Значение);
		Результат.ИспользованиеСостояний[КлючЗначение.Ключ] = ДанныеСостояния;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Результат.Ссылка) Тогда
		Результат.НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Результат.Ссылка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗначениеЭлементаОтбораИзПользовательскихНастроек(КомпоновщикНастроек, ИмяЭлемента)
	
	Если ТипЗнч(КомпоновщикНастроек) <> Тип("КомпоновщикНастроекКомпоновкиДанных") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ЭлементыОтбора = ОбщегоНазначенияКлиентСервер.НайтиЭлементыИГруппыОтбора(
	КомпоновщикНастроек.Настройки.Отбор, ИмяЭлемента);
	
	Для Каждого ЭлементОтбора Из ЭлементыОтбора Цикл
		
		ИдентификаторПользовательскойНастройки = ЭлементОтбора.ИдентификаторПользовательскойНастройки;
		КомпоновщикНастроек.ПользовательскиеНастройки.ДополнительныеСвойства.Вставить(
		ИмяЭлемента, ИдентификаторПользовательскойНастройки);
		
		ЭлементПользовательскихНастроек = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(
		ЭлементОтбора.ИдентификаторПользовательскойНастройки);
		
		Если ЭлементПользовательскихНастроек <> Неопределено И ЭлементПользовательскихНастроек.Использование Тогда
			Возврат ЭлементПользовательскихНастроек.ПравоеЗначение;
		ИначеЕсли ЭлементПользовательскихНастроек = Неопределено И ЭлементОтбора.Использование Тогда
			Возврат ЭлементОтбора.ПравоеЗначение;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти

#КонецОбласти

Процедура ОбновитьСписокВидаОперацийЗаказаНаФорме(
	ЗаявкиИспользуются, ВидОперации, ПараметрыУстановкиСпискаВыбораВидаОперации)
	
	РаботаСЗаявкамиДоступнаНаФорме = РаботаСЗаявкамиДоступнаНаФорме(
	ПараметрыУстановкиСпискаВыбораВидаОперации.ЭлементВидОперации);
	
	Если РаботаСЗаявкамиДоступнаНаФорме <> ЗаявкиИспользуются Тогда
		
		Если ЭтоТипЗаказНаряда(ВидОперации) Тогда
			УстановитьСписокВыбораВидаОперацииЗаказНаряд(ПараметрыУстановкиСпискаВыбораВидаОперации);
		Иначе
			УстановитьСписокВыбораВидаОперацииЗаказаНаПродажу(ПараметрыУстановкиСпискаВыбораВидаОперации);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция НомерСостоянияИзДанныхФормы(ПорядокСостояний, Состояние)
	
	Список = ПорядокСостояний.НайтиСтроки(Новый Структура("Состояние", Состояние));
	Если Список.Количество() Тогда
		Возврат Список[0].НомерСтроки;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция РаботаСЗаявкамиДоступнаНаФорме(ЭлементВидОперации)
	
	Для Каждого ЭлементСписка Из ЭлементВидОперации.СписокВыбора Цикл
		Если ЭтоЗаявка(ЭлементСписка.Значение) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция ПорядкиСостоянийВидовЗаказовОдинаковы(ПорядокСостояний1, ПорядокСостояний2)
	
	КоличествоСостояний = ПорядокСостояний1.Количество();
	
	Если КоличествоСостояний <> ПорядокСостояний2.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Индекс = 0 По КоличествоСостояний - 1 Цикл
		
		Строка1 = ПорядокСостояний1[Индекс];
		Строка2 = ПорядокСостояний2[Индекс];
		
		Если Строка1.НомерСтроки <> Строка2.НомерСтроки
			Или Строка1.Состояние <> Строка2.Состояние Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция РезультатИзмененияВидаОперации()
	
	Результат = Новый Структура;
	Результат.Вставить("КонтрагентИзменен", Ложь);
	Результат.Вставить("ЛидИзменен", Ложь);
	Результат.Вставить("ВидОперацииИзменен", Ложь);
	Результат.Вставить("ПереводЗаказаВЗаявку", Ложь);
	
	Возврат Результат;
	
КонецФункции

