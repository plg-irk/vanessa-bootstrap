			|ИЗ
			|	Справочник.НастройкиПубликацииМЛК КАК НастройкиПубликацииМЛК
			|ГДЕ
			|	НастройкиПубликацииМЛК.Ссылка.ВидЗаказаПокупателя = &ВидЗаказа
			|	И НастройкиПубликацииМЛК.СостояниеЗаказаПокупателя В(&СостоянияЗаказа)";
		
	КонецЕсли;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ВидЗаказа", ВидЗаказа);
	Запрос.УстановитьПараметр("СостоянияЗаказа", Состояния);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Результат.Ссылка = Неопределено Тогда
			Результат.Вставить("Ссылка", Выборка.Ссылка);
		КонецЕсли;
		
		ДанныеСостояния = Новый Структура("Представление", Выборка.Представление);
		Результат.ИспользованиеСостояний[Выборка.Состояние] = ДанныеСостояния;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Результат.Ссылка) Тогда
		Результат.НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Результат.Ссылка);
	КонецЕсли;
	
