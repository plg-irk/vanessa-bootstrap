Функция НужноПроводитьПроверкуИспользованияСостоянийПриОбработкеПроверкиЗаполнения(Данные)
	
	ВидЗаказа = Данные.Ссылка;
	Если ВидЗаказа.Пустая() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ВидЗаказа, "СостояниеЗаявки, СостояниеВыполнения, ПорядокСостояний");
		
	Иначе
		
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ВидЗаказа, "СостояниеЗаявки, СостояниеДоставлен, СостояниеОтгружен, СостояниеОжидаетОтгрузки, ПорядокСостояний");
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЗначенияРеквизитов.СостояниеЗаявки) И Не ЗначениеЗаполнено(Данные.СостояниеЗаявки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПорядокСостоянийИзменился = Не ПорядкиСостоянийВидовЗаказовОдинаковы(
	ЗначенияРеквизитов.ПорядокСостояний.Выгрузить(), Данные.ПорядокСостояний);
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		
		КартаПроцессовИзменилась = ЗначениеЗаполнено(Данные.СостояниеВыполнения)
		И Данные.СостояниеВыполнения <> ЗначенияРеквизитов.СостояниеВыполнения;
		
	Иначе
		
		КартаПроцессовИзменилась = 
		(ЗначениеЗаполнено(Данные.СостояниеДоставлен)
		И Данные.СостояниеДоставлен <> ЗначенияРеквизитов.СостояниеДоставлен)
		Или (ЗначениеЗаполнено(Данные.СостояниеОтгружен)
		И Данные.СостояниеОтгружен <> ЗначенияРеквизитов.СостояниеОтгружен)
		Или (ЗначениеЗаполнено(Данные.СостояниеОжидаетОтгрузки)
		И Данные.СостояниеОжидаетОтгрузки <> ЗначенияРеквизитов.СостояниеОжидаетОтгрузки);
		
	КонецЕсли;
	
	Возврат ПорядокСостоянийИзменился Или КартаПроцессовИзменилась;
	
КонецФункции

Функция СостоянияМеждуИндексами(ПорядокСостояний, Знач Индекс1, Знач Индекс2)
	
	Результат = Новый Массив;
	
	Если Индекс1 = Индекс2 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Индекс1Больше = (Индекс1 > Индекс2);
	
	Если Индекс1Больше Тогда
		Индекс1 = Индекс1 - 1;
	Иначе
		Индекс1 = Индекс1 + 1;
	КонецЕсли;
	
	Пока Индекс1 <> Индекс2 Цикл
		
		Если Индекс1 = Индекс2 Тогда
			Возврат Результат;
		КонецЕсли;
		
		Результат.Добавить(ПорядокСостояний[Индекс1].Состояние);
		
		Если Индекс1Больше Тогда
			Индекс1 = Индекс1 - 1;
		Иначе
			Индекс1 = Индекс1 + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция НовыйРезультатПроверки()
	
	Возврат Новый Структура(
	"Ссылка,НавигационнаяСсылка,ИспользованиеСостояний",
	Неопределено, Неопределено, Новый Соответствие);
	
КонецФункции

Функция НовыйРезультатПроверкиВозможностиИзмененияИспользованияЗаявок()
	
	Результат = Новый Структура;
	Результат.Вставить("ИзменениеВозможно", Истина);
	Результат.Вставить("ИспользованиеСостоянийВЗаказах", Неопределено);
	Результат.Вставить("ИспользованиеСостоянийВЗаявках", Неопределено);
	Результат.Вставить("ИспользованиеСостоянийВИнтернетМагазине", Неопределено);
	Результат.Вставить("ИспользованиеСостоянийВМагазинахСоцсетей", Неопределено);
	Результат.Вставить("ИспользованиеСостоянийВМаркетплейсах", Неопределено);
	Результат.Вставить("ИспользованиеСостоянийВКабинетеКлиента", Неопределено);
	Результат.Вставить("ИспользованиеЗаявокВАссистентеУправления", Неопределено);
	Результат.Вставить("ИспользованиеЗаявокВМаг1С", Неопределено);
	Результат.Вставить("ИспользованиеЗаявокВМобильныхПриложениях", Неопределено);
	Результат.Вставить("ИспользованиеСостоянийВДругихНастройкахКартыПроцессов", Неопределено);
	
	Возврат Результат;
	
КонецФункции

Функция ИспользованиеСостоянийВЗаказах(ВидЗаказа, Состояния, ПоискЗаявок)
	
	Результат = НовыйРезультатПроверки();
	Результат.Вставить("Используются", Ложь);
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		Результат.Вставить("СостояниеЗавершен", Справочники.СостоянияЗаказНарядов.Завершен);
	Иначе
		Результат.Вставить("СостояниеЗавершен", Справочники.СостоянияЗаказовПокупателей.Завершен);
	КонецЕсли;
	
	НаличиеЗаказовПоСостояниям = НаличиеЗаказовПоСостояниям(ВидЗаказа, Состояния, ПоискЗаявок);
	
	ПараметрыНС = Новый Структура;
	ПараметрыНС.Вставить("ВидЗаказа", ВидЗаказа);
	ПараметрыНС.Вставить("Состояния", Новый Массив);
	
	Если ПоискЗаявок Тогда
		ПараметрыНС.Вставить("МожноПереводитьЗаявкуВЗаказСЗавершеннымЛидом");
	КонецЕсли;
	
	Для Каждого Состояние Из Состояния Цикл
		Если НаличиеЗаказовПоСостояниям[Состояние].ЕстьЗаказ Тогда
			
			Результат.Используются = Истина;
			
			ДанныеСостояния = Новый Структура("Представление", НаличиеЗаказовПоСостояниям[Состояние].Представление);
			Результат.ИспользованиеСостояний[Состояние] = ДанныеСостояния;
			
			ПараметрыНС.Состояния.Добавить(Состояние);
			
		КонецЕсли;
	КонецЦикла;
	
	Если ПараметрыНС.Состояния.Найти(Результат.СостояниеЗавершен) <> Неопределено Тогда
		
		Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
			ПараметрыНС.Вставить("ВидОперации", Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд);
		Иначе
			ПараметрыНС.Вставить("ВидОперации", Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		МетаданныеДляОткрытия = Метаданные.Документы.ЗаказПокупателя.Команды.ОткрытьЗаказыНаряды;
	Иначе
		МетаданныеДляОткрытия = Метаданные.Документы.ЗаказПокупателя;
	КонецЕсли;
	
	Результат.НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(
	МетаданныеДляОткрытия, "ИспользованиеСостоянийВЗаказах", ПараметрыНС);
	
	Возврат Результат;
	
КонецФункции

Функция ИспользованиеСостоянийЗаявок(Результат, Данные, ИндексСостояния, Состояния)
	
	ВидЗаказа = Данные.Ссылка;
	
	ИспользованиеСостоянийВДругихНастройкахКартыПроцессов =
	ИспользованиеСостоянийВДругихНастройкахКартыПроцессов(Данные, ИндексСостояния);
	Если ИспользованиеСостоянийВДругихНастройкахКартыПроцессов.Используются Тогда
		Результат.ИспользованиеСостоянийВДругихНастройкахКартыПроцессов =
		ИспользованиеСостоянийВДругихНастройкахКартыПроцессов;
		Результат.ИзменениеВозможно = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЭтоВидЗаказНаряда(ВидЗаказа) Тогда
		
		ИспользованиеСостоянийВИнтернетМагазине = ИспользованиеСостоянийВИнтернетМагазине(ВидЗаказа, Состояния);
		Если ЗначениеЗаполнено(ИспользованиеСостоянийВИнтернетМагазине.Ссылка) Тогда
			Результат.ИспользованиеСостоянийВИнтернетМагазине = ИспользованиеСостоянийВИнтернетМагазине;
			Результат.ИзменениеВозможно = Ложь;
			Возврат Результат;
		КонецЕсли;
		
		ИспользованиеСостоянийВМагазинахСоцсетей = ИспользованиеСостоянийВМагазинахСоцсетей(ВидЗаказа, Состояния);
		Если ЗначениеЗаполнено(ИспользованиеСостоянийВМагазинахСоцсетей.Ссылка) Тогда
			Результат.ИспользованиеСостоянийВМагазинахСоцсетей = ИспользованиеСостоянийВМагазинахСоцсетей;
			Результат.ИзменениеВозможно = Ложь;
			Возврат Результат;
		КонецЕсли;
		
		ИспользованиеСостоянийВМаркетплейсах = ИспользованиеСостоянийВМаркетплейсах(ВидЗаказа, Состояния);
		Если ЗначениеЗаполнено(ИспользованиеСостоянийВМаркетплейсах.Ссылка) Тогда
			Результат.ИспользованиеСостоянийВМаркетплейсах = ИспользованиеСостоянийВМаркетплейсах;
			Результат.ИзменениеВозможно = Ложь;
			Возврат Результат;
		КонецЕсли;
		
	КонецЕсли;
	
	ИспользованиеСостоянийВКабинетеКлиента = ИспользованиеСостоянийВКабинетеКлиента(ВидЗаказа, Состояния);
	Если ЗначениеЗаполнено(ИспользованиеСостоянийВКабинетеКлиента.Ссылка) Тогда
		Результат.ИспользованиеСостоянийВКабинетеКлиента = ИспользованиеСостоянийВКабинетеКлиента;
		Результат.ИзменениеВозможно = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	ИспользованиеЗаявокВАссистентеУправления = ИспользованиеЗаявокВАссистентеУправления(ВидЗаказа, Состояния);
	Если ЗначениеЗаполнено(ИспользованиеЗаявокВАссистентеУправления.Ссылка) Тогда
		Результат.ИспользованиеЗаявокВАссистентеУправления = ИспользованиеЗаявокВАссистентеУправления;
		Результат.ИзменениеВозможно = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	ИспользованиеЗаявокВМаг1С = ИспользованиеЗаявокВМаг1С(ВидЗаказа, Состояния);
	Если ИспользованиеЗаявокВМаг1С.Используются Тогда
		Результат.ИспользованиеЗаявокВМаг1С = ИспользованиеЗаявокВМаг1С;
		Результат.ИзменениеВозможно = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	ИспользованиеЗаявокВМобильныхПриложениях = ИспользованиеЗаявокВМобильныхПриложениях(ВидЗаказа, Состояния);
	Если ЗначениеЗаполнено(ИспользованиеЗаявокВМобильныхПриложениях.Ссылка) Тогда
		Результат.ИспользованиеЗаявокВМобильныхПриложениях = ИспользованиеЗаявокВМобильныхПриложениях;
		Результат.ИзменениеВозможно = Ложь;
		Возврат Результат;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИспользованиеСостоянийВДругихНастройкахКартыПроцессов(Данные, ИндексСостояния)
	
	Результат = Новый Структура;
	Результат.Вставить("Используются", Ложь);
	Результат.Вставить("СостояниеОжидаетОтгрузки", Новый Структура("Перекрывается", Ложь));
	Результат.Вставить("СостояниеОтгружен", Новый Структура("Перекрывается", Ложь));
	Результат.Вставить("СостояниеДоставлен", Новый Структура("Перекрывается", Ложь));
	Результат.Вставить("СостояниеВыполнения", Новый Структура("Перекрывается", Ложь));
	
	Если ЭтоВидЗаказНаряда(Данные.Ссылка) Тогда
		ИспользованиеСостоянийВДругихНастройкахКартыПроцессовЗаказНарядов(Результат, Данные, ИндексСостояния);
	Иначе
		ИспользованиеСостоянийВДругихНастройкахКартыПроцессовЗаказовПокупателей(Результат, Данные, ИндексСостояния);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ИспользованиеСостоянийВДругихНастройкахКартыПроцессовЗаказовПокупателей(Результат, Данные, ИндексСостояния)
	
	ИспользоватьМаршрутныеЛисты  = ПолучитьФункциональнуюОпцию("ИспользоватьМаршрутныеЛисты");
	Если Не ИспользоватьМаршрутныеЛисты Тогда
		Возврат;
	КонецЕсли;
	
	СостояниеОжидаетОтгрузки = Данные.СостояниеОжидаетОтгрузки;
	СостояниеОтгружен = Данные.СостояниеОтгружен;
	СостояниеДоставлен = Данные.СостояниеДоставлен;
	
	Если ЗначениеЗаполнено(СостояниеОжидаетОтгрузки) Тогда
		
		Если ТипЗнч(Данные.ПорядокСостояний) = Тип("ДанныеФормыКоллекция") Тогда
			
			Отбор = Новый Структура("Состояние", СостояниеОжидаетОтгрузки);
			СтрокаСостояния = Данные.ПорядокСостояний.НайтиСтроки(Отбор)[0];
			
		Иначе
			СтрокаСостояния = Данные.ПорядокСостояний.Найти(СостояниеОжидаетОтгрузки);
		КонецЕсли;
		
		Если ИндексСостояния >= СтрокаСостояния.НомерСтроки - 1 Тогда
			
			Результат.СостояниеОжидаетОтгрузки.Вставить("Перекрывается", Истина);
			Результат.СостояниеОжидаетОтгрузки.Вставить("Представление", Строка(СостояниеОжидаетОтгрузки));
			Результат.Используются = Истина;
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СостояниеОтгружен) Тогда
		
		Если ТипЗнч(Данные.ПорядокСостояний) = Тип("ДанныеФормыКоллекция") Тогда
			
			Отбор = Новый Структура("Состояние", СостояниеОтгружен);
			СтрокаСостояния = Данные.ПорядокСостояний.НайтиСтроки(Отбор)[0];
			
		Иначе
			СтрокаСостояния = Данные.ПорядокСостояний.Найти(СостояниеОтгружен);
		КонецЕсли;
		
		Если ИндексСостояния >= СтрокаСостояния.НомерСтроки - 1 Тогда
			
			Результат.СостояниеОтгружен.Вставить("Перекрывается", Истина);
			Результат.СостояниеОтгружен.Вставить("Представление", Строка(СостояниеОтгружен));
			Результат.Используются = Истина;
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СостояниеДоставлен) Тогда
		
		Если ТипЗнч(Данные.ПорядокСостояний) = Тип("ДанныеФормыКоллекция") Тогда
			
			Отбор = Новый Структура("Состояние", СостояниеДоставлен);
			СтрокаСостояния = Данные.ПорядокСостояний.НайтиСтроки(Отбор)[0];
			
		Иначе
			СтрокаСостояния = Данные.ПорядокСостояний.Найти(СостояниеДоставлен);
		КонецЕсли;
		
		Если ИндексСостояния >= СтрокаСостояния.НомерСтроки - 1 Тогда
			
			Результат.СостояниеДоставлен.Вставить("Перекрывается", Истина);
			Результат.СостояниеДоставлен.Вставить("Представление", Строка(СостояниеДоставлен));
			Результат.Используются = Истина;
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ИспользованиеСостоянийВДругихНастройкахКартыПроцессовЗаказНарядов(Результат, Данные, ИндексСостояния)
	
	СостояниеВыполнения = Данные.СостояниеВыполнения;
	
	Если ЗначениеЗаполнено(СостояниеВыполнения) Тогда
		
		Если ТипЗнч(Данные.ПорядокСостояний) = Тип("ДанныеФормыКоллекция") Тогда
			
			Отбор = Новый Структура("Состояние", СостояниеВыполнения);
			СтрокаСостояния = Данные.ПорядокСостояний.НайтиСтроки(Отбор)[0];
			
		Иначе
			СтрокаСостояния = Данные.ПорядокСостояний.Найти(СостояниеВыполнения);
		КонецЕсли;
		
		Если ИндексСостояния >= СтрокаСостояния.НомерСтроки - 1 Тогда
			
			Результат.СостояниеВыполнения.Вставить("Перекрывается", Истина);
			Результат.СостояниеВыполнения.Вставить("Представление", Строка(СостояниеВыполнения));
			Результат.Используются = Истина;
			Возврат;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ИспользованиеСостоянийВИнтернетМагазине(ВидЗаказа, Состояния)
	
	Результат = НовыйРезультатПроверки();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НастройкиИнтеграцииСИнтернетМагазиномСоответствиеСтатусовЗаказов.Ссылка КАК Ссылка,
		|	НастройкиИнтеграцииСИнтернетМагазиномСоответствиеСтатусовЗаказов.СостояниеЗаказаПокупателя КАК Состояние,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(НастройкиИнтеграцииСИнтернетМагазиномСоответствиеСтатусовЗаказов.СостояниеЗаказаПокупателя) КАК Представление
		|ИЗ
		|	Справочник.НастройкиИнтеграцииСИнтернетМагазином.СоответствиеСтатусовЗаказов КАК НастройкиИнтеграцииСИнтернетМагазиномСоответствиеСтатусовЗаказов
		|ГДЕ
		|	НастройкиИнтеграцииСИнтернетМагазиномСоответствиеСтатусовЗаказов.Ссылка.ВидЗаказа = &ВидЗаказа
		|	И НастройкиИнтеграцииСИнтернетМагазиномСоответствиеСтатусовЗаказов.СостояниеЗаказаПокупателя В(&СостоянияЗаказаПокупателя)";
	
	Запрос.УстановитьПараметр("ВидЗаказа", ВидЗаказа);
	Запрос.УстановитьПараметр("СостоянияЗаказаПокупателя", Состояния);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ПараметрыНС = Новый Структура("ВидЗаказа,Состояния", ВидЗаказа, Новый Массив);
	
	Пока Выборка.Следующий() Цикл
		
		Если Результат.Ссылка = Неопределено Тогда
			Результат.Вставить("Ссылка", Выборка.Ссылка);
		КонецЕсли;
		
		ДанныеСостояния = Новый Структура("Представление", Выборка.Представление);
		Результат.ИспользованиеСостояний[Выборка.Состояние] = ДанныеСостояния;
		
		ПараметрыНС.Состояния.Добавить(Выборка.Состояние);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Результат.Ссылка) Тогда
		Результат.НавигационнаяСсылка = ПолучитьНавигационнуюСсылку(Результат.Ссылка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

