// Функция определяет допустимые суммы оплаты подарочными сертификатами для таблицы товаров.
//
// Параметры:
//  ТаблицаОплатыСертификатами - ТаблицаЗначений - таблица оплаты сертификатами, содержащая колонки:
//    * Сертификат - СправочникСсылка.Номенклатура - ссылка на подарочный сертификат.
//    * НомерСертификата - СправочникСсылка.СерииНоменклатуры - ссылка на серию номенклатуры, соответствующую номеру подарочного сертификата.
//    * Регистратор - ДокументСсылка - Документ, в котором принимается оплата этим сертификатом.
//    * Сумма - Число - сумма оплаты сертификатом.
//  ОрганизацииПродажи - Массив из СправочникСсылка.Организации - Организации для которых получается баланс сертификата
//  ТаблицаТоваров - см. ПустаяТаблицаТоваровПодарочныхСертификатов - таблица товаров, содержащая колонки:
//
// Возвращаемое значение:
//  ТаблицаЗначений - см. ПустаяТаблицаОписанияДоступныхСуммПоСертификатам - 
//
Функция ДопустимыеСуммыОплатыСертификатами(ТаблицаОплатыСертификатами, ОрганизацииПродажи = Неопределено, ТаблицаТоваров = Неопределено) Экспорт
	
	ОписаниеСертификатов = ПустаяТаблицаОписанияДоступныхСуммПоСертификатам();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапросаПроверкиСертификата();
	
	Запрос.УстановитьПараметр("ДатаЗапроса"				, ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Сертификаты"				, ТаблицаОплатыСертификатами);
	Запрос.УстановитьПараметр("ОрганизацииПродажи"		, ОрганизацииПродажи);
	ЕстьТоварыКПроверке = Истина;
	Если ТаблицаТоваров = Неопределено Тогда
		ЕстьТоварыКПроверке = Ложь;
		ТаблицаТоваров =  ПустаяТаблицаТоваровПодарочныхСертификатов();
	КонецЕсли;
	Запрос.УстановитьПараметр("Товары"					, ТаблицаТоваров);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ТЗОстаткиСертификатаПоОрганизации = РезультатЗапроса[РезультатЗапроса.Количество() - 2].Выгрузить();
	ОстаткиСертификатов = РезультатЗапроса[РезультатЗапроса.Количество() - 1].Выгрузить();
	
	СуммаТоваровКОплате = ТаблицаТоваров.Скопировать(,"Организация, Сумма");
	СуммаТоваровКОплате.Свернуть("Организация", "Сумма");
	
	Для Каждого ТекСертификат Из ОстаткиСертификатов Цикл
		
		ОписаниеСертификата = ОписаниеСертификатов.Добавить();
		ЗаполнитьЗначенияСвойств(ОписаниеСертификата, ТекСертификат);
		СуммаКОплате = ОписаниеСертификата.Остаток;
		Если ЕстьТоварыКПроверке Тогда
			СуммаКОплате = Мин(ОписаниеСертификата.Остаток, СуммаТоваровКОплате.Итог("Сумма"));
		КонецЕсли;
		ОписаниеСертификата.ДоступнаяСумма = Мин(ОписаниеСертификата.Остаток, СуммаКОплате);
		Если ТекСертификат.ТребуетсяПроверкаПострочно И ЕстьТоварыКПроверке Тогда

			ЗапросОграничения = Новый Запрос;
			ЗапросОграничения.Текст = ТекстЗапросаОграниченийПодарочногоСертификата();
			СуммаВозможнойОплаты = 0;
			ЗапросОграничения.УстановитьПараметр("Товары", ТаблицаТоваров);
			УстановитьПараметрыЗапросаОграниченийПодарочногоСертификата(ЗапросОграничения, ТекСертификат.ПодарочныйСертификат);
			СуммаВозможнойОплатыПоОрганизациям = ЗапросОграничения.Выполнить().Выгрузить();
			СуммаДоступногоОстатка = 0;
			ОтборСертификата = Новый Структура("ПодарочныйСертификат, НомерСертификата", ТекСертификат.ПодарочныйСертификат, ТекСертификат.НомерСертификата);
			ОстаткиСертификатаПоОрганизации = ТЗОстаткиСертификатаПоОрганизации.НайтиСтроки(ОтборСертификата); 
			Для Каждого ОстатокПоОрганизации Из ОстаткиСертификатаПоОрганизации Цикл;
				ОрганизацияОстатка = ОстатокПоОрганизации.Организация;
				СуммаДоступнойОплатыОрганизации = 0;
				Если НЕ ТекСертификат.КонтрольОрганизации = ЗначениеЗаполнено(ОрганизацияОстатка) Тогда
					// Остаток не корректный. Для сертификатов с контролем, он должен быть на конкретной организации.
					// А для сертификатов без контроля, на пустой организации.
					// Оплачивать таким остатком нельзя.
					Продолжить;
				ИначеЕсли ЗначениеЗаполнено(ОрганизацияОстатка) Тогда
					ОтборПоОрганизации = Новый Структура("Организация", ОрганизацияОстатка);
					СтрокиВозможнойОплаты = СуммаВозможнойОплатыПоОрганизациям.НайтиСтроки(ОтборПоОрганизации);
					СуммаДоступнойОплатыОрганизации = СуммаВозможнойОплатыПоОрганизациям.Скопировать(СтрокиВозможнойОплаты).Итог("Сумма");						
				Иначе
					СуммаДоступнойОплатыОрганизации = СуммаВозможнойОплатыПоОрганизациям.Итог("Сумма");
				КонецЕсли;
				СуммаДоступногоОстатка = СуммаДоступногоОстатка + ОстатокПоОрганизации.Сумма;
				СуммаВозможнойОплаты = СуммаВозможнойОплаты + СуммаДоступнойОплатыОрганизации;
			КонецЦикла;
			
			ОписаниеСертификата.ДоступнаяСумма = Мин(СуммаВозможнойОплаты, СуммаДоступногоОстатка);
			ОписаниеСертификата.СработалиОграничения = НЕ ОписаниеСертификата.ДоступнаяСумма = ОписаниеСертификата.Остаток;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ОписаниеСертификатов;
КонецФункции	

// Проверяет позволяет ли область действия сертификатов оплатить все товары документа
// Параметры:
//   ОплатаСертификатами - ТаблицаЗначений - Таблица сертификатов с колонками:
//    * ПодарочныйСертификат - СправочникСсылка.Номенклатура - 
//    * НомерСертификата - СправочникСсылка.СерииНоменклатуры - 
//    * Сумма - Число - 
//   Товары - ТаблицаЗначений - Таблица товаров с колонками:
//    * Номенклатура - СправочникСсылка.Номенклатура - 
//    * Характеристика - СправочникСсылка.ХарактеристикиНоменклатуры - 
//    * Организация - СправочникСсылка.Организации - Организация, которой принадлежит продаваемый товар
//    * Сумма - Число - 
//  Возвращаемое значение:
//   - Булево
Функция ОплатаСертификатамиКорректна(ОплатаСертификатами, Организация, Товары) Экспорт
	
	РезультатКорректен = Истина;
	// Если не было оплаты сертификатами
	Если ОплатаСертификатами.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	ВремяНачала = ОценкаПроизводительности.НачатьЗамерВремени();

	РезультатыПроверки = ДопустимыеСуммыОплатыСертификатами(ОплатаСертификатами, Организация, Товары);
	Для Каждого ОплатаДокумента Из ОплатаСертификатами Цикл
		Отбор = Новый Структура("ПодарочныйСертификат, НомерСертификата",
			ОплатаДокумента.ПодарочныйСертификат, ОплатаДокумента.НомерСертификата);
		РезультатПроверки = РезультатыПроверки.НайтиСтроки(Отбор);
		Если НЕ РезультатПроверки.Количество() Тогда
			СуммаСовпадает = Ложь;
		Иначе
			ОписаниеСертификата = РезультатПроверки[0];
			СуммаСовпадает = ОписаниеСертификата.ДоступнаяСумма >= ОплатаДокумента.Сумма;
			Если НЕ СуммаСовпадает 
				И ЗначениеЗаполнено(ОписаниеСертификата.Сообщение) Тогда
				ОбщегоНазначения.СообщитьПользователю(ОписаниеСертификата.Сообщение);
			КонецЕсли;
		КонецЕсли;
		Если НЕ СуммаСовпадает Тогда
			РезультатКорректен = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени("ПроверкаОбластиДействияСертификатов", ВремяНачала);
	Возврат РезультатКорректен;
КонецФункции

Процедура ПроверитьОбластьДействияСертификатов(СтруктураДляПроверки, Отказ) Экспорт
	Организация = Неопределено;
	Если СтруктураДляПроверки.Свойство("Организация") Тогда
		Организация = СтруктураДляПроверки.Организация;
	КонецЕсли;
	ЗаблокироватьПроведение = НЕ ОплатаСертификатамиКорректна(СтруктураДляПроверки.Сертификаты, Организация, СтруктураДляПроверки.Запасы);
	Отказ = Отказ ИЛИ ЗаблокироватьПроведение;
КонецПроцедуры

Процедура УстановитьЦенуВозвращаемыхСертификатов(Запасы, СерииНоменклатуры, СуммаВключаетНДС, Регистратор) Экспорт
	Для Каждого СтрокаЗапасы Из Запасы Цикл
		ТипНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаЗапасы.Номенклатура, "ТипНоменклатуры"); 
		Если НЕ ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат") Тогда
			Продолжить;
		ИначеЕсли СтрокаЗапасы.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		Отбор = Новый Структура("КлючСвязи", СтрокаЗапасы.КлючСвязи);
		СерииЭтогоСертификата = СерииНоменклатуры.НайтиСтроки(Отбор);
		СуммаСертификатов = 0;
		Для Каждого СтрокаСерии Из СерииЭтогоСертификата Цикл
			ДанныеСертификата = РаботаСПодарочнымиСертификатами.ПолучитьСтруктуруДанныхСертификата(СтрокаЗапасы.Номенклатура, 
				СтрокаСерии.Серия, Регистратор);
			СуммаСертификатов = СуммаСертификатов + ДанныеСертификата.Остаток;
		КонецЦикла;
		
		ДанныеСтроки = Новый Структура;
		ДанныеСтроки.Вставить("Количество", СтрокаЗапасы.Количество);
		ДанныеСтроки.Вставить("Цена", Окр(СуммаСертификатов / СтрокаЗапасы.Количество, 2));
		ДанныеСтроки.Вставить("Сумма", 0);
		ДанныеСтроки.Вставить("ПроцентСкидкиНаценки", СтрокаЗапасы.ПроцентСкидкиНаценки);
		ДанныеСтроки.Вставить("СуммаСкидкиНаценки", 0);
		ДанныеСтроки.Вставить("СтавкаНДС", СтрокаЗапасы.СтавкаНДС);
		ДанныеСтроки.Вставить("СуммаНДС", 0);
		ДанныеСтроки.Вставить("СуммаВключаетНДС", СуммаВключаетНДС);
		ДанныеСтроки.Вставить("Всего", 0);
		ЗаполнениеОбъектовУНФ.РассчитатьСуммыВСтрокеТабличнойЧасти(ДанныеСтроки);
		ЗаполнитьЗначенияСвойств(СтрокаЗапасы, ДанныеСтроки);
	КонецЦикла;
КонецПроцедуры
#КонецОбласти
