		|	"""" КАК СодержаниеПроводки,
		|	0 КАК СуммаДоходов,
		|	0 КАК СуммаРасходов,
		|	0 КАК Сумма
		|Где
		|	Ложь";
	КонецЕсли;
	Возврат Текст;
КонецФункции

Функция ТекстЗапросаДвиженийЗапасыОприходованиеДляПовторнойПродажи(ВыполнятьДвижения = Истина) Экспорт
	
	Если ВыполнятьДвижения И ПолучитьФункциональнуюОпцию("ИспользоватьПодарочныеСертификаты") Тогда	
		Текст = 
		"ВЫБРАТЬ
		|	ТаблицаЗапасы.Ссылка КАК Ссылка,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ТаблицаЗапасы.Период КАК Период,
		|	ТаблицаЗапасы.Организация КАК Организация,
		|	ВременнаяТаблицаШапка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПараметрыСклада.ОрдерныйСклад КАК ОрдерныйСклад,
		|	Выбор
		|		когда ПараметрыСклада.УчетОстатковПоЯчейкам
		|			Тогда ПараметрыСклада.ЯчейкаПолучателяПеремещения
		|		ИНАЧЕ Значение(Справочник.Ячейки.ПустаяСсылка)
		|	Конец КАК Ячейка,
		|	ВременнаяТаблицаШапка.Контрагент КАК Контрагент,
		|	ВЫБОР
		|		КОГДА ПараметрыСклада.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)
		|		ИЛИ ПараметрыСклада.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница)
		|		ИЛИ ПараметрыСклада.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.РозницаСуммовойУчет)
		|			ТОГДА ПараметрыСертификата.СчетУчетаЗапасов
		|		ИНАЧЕ ПараметрыСертификата.СчетУчетаЗатрат
		|	КОНЕЦ КАК СчетУчета,
		|	ТаблицаЗапасы.ПодарочныйСертификат КАК Номенклатура,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка) КАК Партия,
		|	ТаблицаЗапасы.НомерСертификата КАК Серия,
		|	ИСТИНА КАК ФиксированнаяСтоимость,
		|	0 КАК Сумма,
		|	0 КАК СуммаБезНДС,
		|	ЗНАЧЕНИЕ(ВидДвиженияБухгалтерии.Дебет) КАК ВидДвиженияУправленческий,
		|	ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка) КАК СтранаПроисхождения,
		|	ЗНАЧЕНИЕ(Справочник.НомераГТД.ПустаяСсылка) КАК НомерГТД,
		|	&ОприходованиеЗапасов КАК СодержаниеПроводки
		|ИЗ
		|	ВременнаяТаблицаДвиженийСертификатов КАК ТаблицаЗапасы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ПараметрыСертификата
		|		ПО ТаблицаЗапасы.ПодарочныйСертификат = ПараметрыСертификата.Ссылка
		|		И ПараметрыСертификата.ПриходоватьПодарочныйСертификатПриОплате
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
		|		ПО ТаблицаЗапасы.Ссылка = ВременнаяТаблицаШапка.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК ПараметрыСклада
		|		ПО ВременнаяТаблицаШапка.СтруктурнаяЕдиница = ПараметрыСклада.Ссылка
		|ГДЕ
		|	ТаблицаЗапасы.СертификатПогашенПолностью
		|	И НЕ ТаблицаЗапасы.СуммаДвиженияПоРасчетам = 0";
		Текст = СтрЗаменить(Текст,"&ОприходованиеЗапасов", """" + СодержанияПроводок.ОприходованиеЗапасов() + """");
	Иначе
		Текст = 
		"ВЫБРАТЬ
		|	Неопределено КАК Ссылка,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ДатаВремя(1, 1, 1) КАК Период,
		|	Значение(Справочник.Организации.ПустаяСсылка) КАК Организация,
		|	Значение(Справочник.СтруктурныеЕдиницы.ПустаяСсылка) КАК СтруктурнаяЕдиница,
		|	Ложь КАК ОрдерныйСклад,
		|	Значение(Справочник.Ячейки.ПустаяСсылка) КАК Ячейка,
		|	ВременнаяТаблицаШапка.Контрагент КАК Контрагент,
		|	Значение(ПланСчетов.Управленческий.ПустаяСсылка) КАК СчетУчета,
		|	Значение(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
		|	Значение(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	Значение(Справочник.ПартииНоменклатуры.ПустаяСсылка) КАК Партия,
		|	Значение(Справочник.СерииНоменклатуры.ПустаяСсылка) КАК Серия,
		|	Ложь КАК ФиксированнаяСтоимость,
		|	0 КАК Сумма,
		|	0 КАК СуммаБезНДС,
		|	ЗНАЧЕНИЕ(ВидДвиженияБухгалтерии.Дебет) КАК ВидДвиженияУправленческий,
		|	Значение(Справочник.СтраныМира.ПустаяСсылка) КАК СтранаПроисхождения,
		|	Значение(Справочник.НомераГТД.ПустаяСсылка) КАК НомерГТД,
		|	"""" КАК СодержаниеПроводки
		|Где
		|	Ложь";
	КонецЕсли;
	Возврат Текст;
КонецФункции

// Создает и возвращает пустую таблицу значений для описания доступных сумм по сертификатам.
//
// Возвращаемое значение:
//  ТаблицаЗначений - Пустая таблица описания доступных сумм по сертификатам:
//   * ПодарочныйСертификат - СправочникСсылка.Номенклатура - Ссылка на подарочный сертификат.
//   * НомерСертификата - СправочникСсылка.СерииНоменклатуры - Ссылка на номер сертификата.
//   * Номинал - Число - Номинал сертификата.
//   * Остаток - Число - Остаток доступной суммы по сертификату.
//   * Заблокирован - Булево - Признак блокировки сертификата.
//   * СгораетПриОплате - Булево - Признак сгорания сертификата при оплате.
//   * ДатаОкончанияДействия - Дата - Для сертификатов с ограничением срока действия возвращается дата окончания.
Функция ПустаяТаблицаОписанияДоступныхСуммПоСертификатам()
	ОписаниеСертификатов = Новый ТаблицаЗначений();
	ОписаниеСертификатов.Колонки.Добавить("ПодарочныйСертификат", 	Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ОписаниеСертификатов.Колонки.Добавить("НомерСертификата", 		Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ОписаниеСертификатов.Колонки.Добавить("Номинал", 				Новый ОписаниеТипов("Число"));
	ОписаниеСертификатов.Колонки.Добавить("Остаток", 				Новый ОписаниеТипов("Число"));
	ОписаниеСертификатов.Колонки.Добавить("Заблокирован", 			Новый ОписаниеТипов("Булево"));
	ОписаниеСертификатов.Колонки.Добавить("СгораетПриОплате", 		Новый ОписаниеТипов("Булево"));
	ОписаниеСертификатов.Колонки.Добавить("СработалиОграничения",	Новый ОписаниеТипов("Булево"));
	ОписаниеСертификатов.Колонки.Добавить("ДоступнаяСумма", 		Новый ОписаниеТипов("Число"));
	ОписаниеСертификатов.Колонки.Добавить("Сообщение", 				Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(250)));
	ОписаниеСертификатов.Колонки.Добавить("ДатаОкончанияДействия", 	Новый ОписаниеТипов("Дата"));
	ОписаниеСертификатов.Колонки.Добавить("ИспользоватьСерииНоменклатуры", 	Новый ОписаниеТипов("Булево"));
	ОписаниеСертификатов.Колонки.Добавить("ПроизвольныйНоминал", 	Новый ОписаниеТипов("Булево"));
	ОписаниеСертификатов.Колонки.Добавить("ЧастичноеПогашение", 	Новый ОписаниеТипов("Булево"));
	ОписаниеСертификатов.Колонки.Добавить("КонтрольОрганизации", 	Новый ОписаниеТипов("Булево"));
	
	Возврат ОписаниеСертификатов;
КонецФункции

// Функция формирует текст запроса для проверки подарочных сертификатов.
//
// Возвращаемое значение:
//  Строка - текст запроса.
//
Функция ТекстЗапросаПроверкиСертификата()
	Возврат
	"ВЫБРАТЬ
	|	ТаблицаТоваров.Номенклатура КАК Номенклатура,
	|	ТаблицаТоваров.Характеристика КАК Характеристика,
	|	ТаблицаТоваров.Организация КАК Организация,
	|	ТаблицаТоваров.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК ТаблицаТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОплатыСертификатами.ПодарочныйСертификат КАК ПодарочныйСертификат,
	|	ТаблицаОплатыСертификатами.НомерСертификата КАК НомерСертификата,
	|	ТаблицаОплатыСертификатами.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТ_ОплатаСертификатами
	|ИЗ
	|	&Сертификаты КАК ТаблицаОплатыСертификатами
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДанныеПродажи.Организация КАК Организация,
	|	СУММА(ДанныеПродажи.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ВТ_ОрганизацииПродажи
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТоварыЧека.Организация КАК Организация,
	|		СУММА(ТоварыЧека.Сумма) КАК Сумма
	|	ИЗ
	|		ВТ_Товары КАК ТоварыЧека
	|	СГРУППИРОВАТЬ ПО
	|		ТоварыЧека.Организация
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		Организация.Ссылка КАК Организация,
	|		0 КАК Сумма
	|	ИЗ
	|		Справочник.Организации КАК Организация) КАК ДанныеПродажи
	|СГРУППИРОВАТЬ ПО
	|	ДанныеПродажи.Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК ПодарочныйСертификат,
	|	ЕСТЬNULL(СерииНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) КАК СерийныйНомер,
	|	Номенклатура.ЧастичноеПогашение КАК ЧастичноеПогашение,
	|	Номенклатура.СпособОграниченияСертификата КАК СпособОграниченияСертификата,
	|	Номенклатура.Номинал КАК Номинал,
	|	Номенклатура.ПроизвольныйНоминал КАК ПроизвольныйНоминал,
	|	Номенклатура.ИспользоватьСерииНоменклатуры КАК ИспользоватьСерииНоменклатуры,
	|	Номенклатура.ПодарочныйСертификатПринимаетКОплатеТолькоОрганизациеяЭмитент КАК КонтрольОрганизации,
	|	Номенклатура.ДатаОкончанияДействия КАК ДатаОкончанияДействия,
	|	Номенклатура.КоличествоПериодовДействия КАК КоличествоПериодовДействия,
	|	Номенклатура.Периодичность КАК Периодичность,
	|	Номенклатура.ТипСрокаДействия КАК ТипСрокаДействия
	|ПОМЕСТИТЬ втПодарочныйСертификат
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|		ПО Номенклатура.Ссылка = СерииНоменклатуры.Владелец
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОплатаСертификатами КАК ОплатаСертификатами
	|		ПО Номенклатура.Ссылка = ОплатаСертификатами.ПодарочныйСертификат
	|		И ЕСТЬNULL(СерииНоменклатуры.Ссылка,
	|			ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)) = ОплатаСертификатами.НомерСертификата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СерииНоменклатурыОбороты.Серия КАК Серия,
	|	МАКСИМУМ(СерииНоменклатурыОбороты.Период) КАК Период
	|ПОМЕСТИТЬ ПродажиСерийНоменклатуры
	|ИЗ
	|	РегистрНакопления.ДвиженияСерииНоменклатуры.Обороты(,, Регистратор, Серия В
	|		(ВЫБРАТЬ
	|			ТаблицаСертификатов.СерийныйНомер КАК СерийныйНомер
	|		ИЗ
	|			втПодарочныйСертификат КАК ТаблицаСертификатов
	|		ГДЕ
	|			НЕ ТаблицаСертификатов.ТипСрокаДействия В
	|			(ЗНАЧЕНИЕ(Перечисление.СрокДействияПодарочныхСертификатов.БезОграниченияСрока),
	|				ЗНАЧЕНИЕ(Перечисление.СрокДействияПодарочныхСертификатов.ПустаяСсылка)))) КАК СерииНоменклатурыОбороты
	|ГДЕ
	|	СерииНоменклатурыОбороты.Регистратор ССЫЛКА Документ.РасходнаяНакладная
	|	ИЛИ СерииНоменклатурыОбороты.Регистратор ССЫЛКА Документ.ЧекККМ
	|	ИЛИ СерииНоменклатурыОбороты.Регистратор ССЫЛКА Документ.ОтчетОРозничныхПродажах
	|	ИЛИ СерииНоменклатурыОбороты.Регистратор ССЫЛКА Документ.ЗаказПокупателя
	|	ИЛИ СерииНоменклатурыОбороты.Регистратор ССЫЛКА Документ.ВводНачальныхОстатков
	|СГРУППИРОВАТЬ ПО
	|	СерииНоменклатурыОбороты.Серия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДатыДействияСертификатов.ПодарочныйСертификат КАК ПодарочныйСертификат,
	|	ДатыДействияСертификатов.СерийныйНомер КАК СерийныйНомер,
	|	ВЫРАЗИТЬ(ДатыДействияСертификатов.ДатаОкончания КАК ДАТА) КАК ДатаОкончания
	|ПОМЕСТИТЬ ВТ_ДатыОкончанияДействияСертификатов
	|ИЗ
	|	(ВЫБРАТЬ
	|		Сертификаты.ПодарочныйСертификат КАК ПодарочныйСертификат,
	|		Сертификаты.СерийныйНомер КАК СерийныйНомер,
	|		ВЫБОР
	|			КОГДА Сертификаты.ТипСрокаДействия = ЗНАЧЕНИЕ(Перечисление.СрокДействияПодарочныхСертификатов.БезОграниченияСрока)
	|			ИЛИ Сертификаты.ТипСрокаДействия = ЗНАЧЕНИЕ(Перечисление.СрокДействияПодарочныхСертификатов.ПустаяСсылка)
	|				ТОГДА НЕОПРЕДЕЛЕНО
	|			КОГДА Сертификаты.ТипСрокаДействия = ЗНАЧЕНИЕ(Перечисление.СрокДействияПодарочныхСертификатов.СОграничениемНаДату)
	|				ТОГДА Сертификаты.ДатаОкончанияДействия
	|			КОГДА Сертификаты.ТипСрокаДействия = ЗНАЧЕНИЕ(Перечисление.СрокДействияПодарочныхСертификатов.ПериодПослеПродажи)
	|			И ПродажиСерийНоменклатуры.Период ЕСТЬ NULL
	|				ТОГДА НЕОПРЕДЕЛЕНО
	|			КОГДА Сертификаты.ТипСрокаДействия = ЗНАЧЕНИЕ(Перечисление.СрокДействияПодарочныхСертификатов.ПериодПослеПродажи)
	|				ТОГДА ВЫБОР
	|					КОГДА Сертификаты.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.День)
	|						ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ПродажиСерийНоменклатуры.Период, ДЕНЬ,
	|							Сертификаты.КоличествоПериодовДействия), ДЕНЬ)
	|					КОГДА Сертификаты.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Неделя)
	|						ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ПродажиСерийНоменклатуры.Период, НЕДЕЛЯ,
	|							Сертификаты.КоличествоПериодовДействия), ДЕНЬ)
	|					КОГДА Сертификаты.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Декада)
	|						ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ПродажиСерийНоменклатуры.Период, ДЕКАДА,
	|							Сертификаты.КоличествоПериодовДействия), ДЕНЬ)
	|					КОГДА Сертификаты.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Месяц)
	|						ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ПродажиСерийНоменклатуры.Период, МЕСЯЦ,
	|							Сертификаты.КоличествоПериодовДействия), ДЕНЬ)
	|					КОГДА Сертификаты.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Квартал)
	|						ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ПродажиСерийНоменклатуры.Период, КВАРТАЛ,
	|							Сертификаты.КоличествоПериодовДействия), ДЕНЬ)
	|					КОГДА Сертификаты.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Полугодие)
	|						ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ПродажиСерийНоменклатуры.Период, ПОЛУГОДИЕ,
	|							Сертификаты.КоличествоПериодовДействия), ДЕНЬ)
	|					КОГДА Сертификаты.Периодичность = ЗНАЧЕНИЕ(Перечисление.Периодичность.Год)
	|						ТОГДА НАЧАЛОПЕРИОДА(ДОБАВИТЬКДАТЕ(ПродажиСерийНоменклатуры.Период, ГОД, Сертификаты.КоличествоПериодовДействия),
	|							ДЕНЬ)
	|					ИНАЧЕ НЕОПРЕДЕЛЕНО
	|				КОНЕЦ
	|			ИНАЧЕ НЕОПРЕДЕЛЕНО
	|		КОНЕЦ КАК ДатаОкончания
	|	ИЗ
	|		втПодарочныйСертификат КАК Сертификаты
	|			ЛЕВОЕ СОЕДИНЕНИЕ ПродажиСерийНоменклатуры КАК ПродажиСерийНоменклатуры
	|			ПО Сертификаты.СерийныйНомер = ПродажиСерийНоменклатуры.Серия) КАК ДатыДействияСертификатов
	|ГДЕ
	|	НЕ ДатыДействияСертификатов.ДатаОкончания = НЕОПРЕДЕЛЕНО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПодарочныеСертификаты.ПодарочныйСертификат КАК ПодарочныйСертификат,
	|	ПодарочныеСертификаты.СерийныйНомер КАК СерийныйНомер
	|ПОМЕСТИТЬ вт_ФильтрОстаткаСертификатов
	|ИЗ
	|	втПодарочныйСертификат КАК ПодарочныеСертификаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОрганизацииПродажи КАК ОрганизацииПродажи
	|		ПО ПодарочныеСертификаты.КонтрольОрганизации
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДатыОкончанияДействияСертификатов КАК ДатыДействия
	|		ПО ПодарочныеСертификаты.ПодарочныйСертификат = ДатыДействия.ПодарочныйСертификат
	|		И ПодарочныеСертификаты.СерийныйНомер = ДатыДействия.СерийныйНомер
	|ГДЕ
	|	ЕСТЬNULL(ДатыДействия.ДатаОкончания, &ДатаЗапроса) >= &ДатаЗапроса
	|СГРУППИРОВАТЬ ПО
	|	ПодарочныеСертификаты.ПодарочныйСертификат,
	|	ПодарочныеСертификаты.СерийныйНомер
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПодарочныеСертификаты.ПодарочныйСертификат КАК ПодарочныйСертификат,
	|	ПодарочныеСертификаты.СерийныйНомер КАК СерийныйНомер
	|ИЗ
	|	втПодарочныйСертификат КАК ПодарочныеСертификаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ОрганизацииПродажи КАК ОрганизацииПродажи
	|		ПО ПодарочныеСертификаты.КонтрольОрганизации = ЛОЖЬ
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДатыОкончанияДействияСертификатов КАК ДатыДействия
	|		ПО ПодарочныеСертификаты.ПодарочныйСертификат = ДатыДействия.ПодарочныйСертификат
	|		И ПодарочныеСертификаты.СерийныйНомер = ДатыДействия.СерийныйНомер
	|ГДЕ
	|	ЕСТЬNULL(ДатыДействия.ДатаОкончания, &ДатаЗапроса) >= &ДатаЗапроса
	|СГРУППИРОВАТЬ ПО
	|	ПодарочныеСертификаты.ПодарочныйСертификат,
	|	ПодарочныеСертификаты.СерийныйНомер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
