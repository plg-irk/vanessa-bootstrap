#Область ПрограммныйИнтерфейс

// Показать окно начало работы с программой при начале работы системы
//
// Параметры:
//  ПараметрыРаботыКлиента - См. СтандартныеПодсистемыКлиент.ПараметрыРаботыКлиентаПриЗапуске
// 
// Возвращаемое значение:
//  Булево - значение параметра "ПоказатьОкноНачалоРаботыСПрограммой"
//
Функция ДанныеИзПараметровРаботыКлиента(ПараметрыРаботыКлиента) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ПоказатьОкноНачалоРаботыСПрограммой", Ложь);
	Результат.Вставить("ПоказатьВыборДемоПриложений", Ложь);
	
	Если ПараметрыРаботыКлиента.Свойство("ПоказатьОкноНачалоРаботыСПрограммой")
		И ПараметрыРаботыКлиента.ПоказатьОкноНачалоРаботыСПрограммой = Истина Тогда
		Результат.ПоказатьОкноНачалоРаботыСПрограммой = Истина;
	КонецЕсли;
	
	Если ПараметрыРаботыКлиента.Свойство("ПоказатьВыборДемоПриложений")
		И ПараметрыРаботыКлиента.ПоказатьВыборДемоПриложений = Истина Тогда
		Результат.ПоказатьВыборДемоПриложений = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ОбработкаЗакрытияФормыНачалаРаботы(РезультатЗакрытия, ПараметрыНачалаРаботы) Экспорт
	
	Перем ОбработкаЗавершена;
	
	Результат = Новый Структура;
	Результат.Вставить("РаботуСистемыНужноЗавершить", Ложь);
	Результат.Вставить("ПерезапуститьПриЗавершении", Ложь);
	Результат.Вставить("ДополнительныеПараметрыКоманднойСтроки", "");
	
	Если РезультатЗакрытия = Неопределено Тогда
		Результат.РаботуСистемыНужноЗавершить = Истина;
		ЗавершитьРаботуСистемы(Ложь, Ложь);
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(РезультатЗакрытия) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если РезультатЗакрытия.ДополнительныйПараметр = НачалоРаботыСПрограммойКлиентСервер.ЗначениеДополнительногоПараметра() Тогда
		НачалоРаботыСПрограммойВызовСервера.УстановитьСтандартныйИнтерфейс();
		ОбновитьИнтерфейс();
		Возврат Результат;
	КонецЕсли;
	
	НачалоРаботыСПрограммойВызовСервера.ОбработкаЗакрытияФормыНачалаРаботы(
	РезультатЗакрытия, ПараметрыНачалаРаботы, ОбработкаЗавершена);
	
	Если ОбработкаЗавершена = Истина Тогда
		Ответ = ЗавершитьОбработкуЗакрытияФормы(РезультатЗакрытия, ПараметрыНачалаРаботы);
		Если Ответ.РаботуСистемыНужноЗавершить Тогда
			ЗаполнитьЗначенияСвойств(Результат, Ответ);
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если РезультатЗакрытия.НачатьРаботу <> Истина Тогда
		Результат.РаботуСистемыНужноЗавершить = Истина;
		ЗавершитьРаботуСистемы(Ложь, Ложь);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Обработка закрытия формы начала работы при ошибке.
// 
// Параметры:
//  Результат - Структура - Результат
//  ПараметрыНачалаРаботы - Структура - Параметры начала работы
Процедура ОбработкаЗакрытияФормыНачалаРаботыПриОшибке(Результат, ПараметрыНачалаРаботы) Экспорт
	
	РезультатЗакрытия = НачалоРаботыСПрограммойВызовСервера.РезультатЗакрытияФормыНачалаРаботыПриОшибке(
	Результат, ПараметрыНачалаРаботы);
	
	Если Не РезультатЗакрытия.ПользовательСоздан Тогда
		Результат.Удалить("ПользовательИмя");
	КонецЕсли;
	
	ЗавершитьОбработкуЗакрытияФормы(Результат, ПараметрыНачалаРаботы);
	
КонецПроцедуры

Процедура УстановитьВыборДемоПриложений() Экспорт
	
	НачалоРаботыСПрограммойВызовСервера.УстановитьВыборДемоПриложений();
	
КонецПроцедуры

#конецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЗавершитьОбработкуЗакрытияФормы(РезультатЗакрытия, ПараметрыНачалаРаботы)
	
	Результат = Новый Структура;
	Результат.Вставить("РаботуСистемыНужноЗавершить", Ложь);
	Результат.Вставить("ПерезапуститьПриЗавершении", Ложь);
	Результат.Вставить("ДополнительныеПараметрыКоманднойСтроки", "");
	
	ПользовательСоздан = РезультатЗакрытия.Свойство("ПользовательИмя");
	
	Если ПользовательСоздан Тогда
		НачалоРаботыСПрограммойВызовСервера.УстановитьСтандартныйИнтерфейс(РезультатЗакрытия.ПользовательИмя);
	КонецЕсли;
	
	Если Не ПараметрыНачалаРаботы.РазделениеВключено И РезультатЗакрытия.НачатьРаботу = Истина Тогда
		
		ДополнительныеПараметрыКоманднойСтроки = "";
		Если ПользовательСоздан Тогда
			ДополнительныеПараметрыКоманднойСтроки = СтрШаблон("/N""%1""", РезультатЗакрытия.ПользовательИмя);
		КонецЕсли;
		
		Результат.РаботуСистемыНужноЗавершить = Истина;
		Результат.ПерезапуститьПриЗавершении = Истина;
		Результат.ДополнительныеПараметрыКоманднойСтроки = ДополнительныеПараметрыКоманднойСтроки;
		ЗавершитьРаботуСистемы(Ложь, Истина, ДополнительныеПараметрыКоманднойСтроки);
		
	Иначе
		
		ОбновитьИнтерфейс();
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти