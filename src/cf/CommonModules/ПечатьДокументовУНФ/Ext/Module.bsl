// Формирует представление заголовка для колонки НДС в зависимости от входных параметров.
//
// Параметры:
//  СуммаНДС - Число - Сумма НДС.
//  СуммаВключаетНДС - Булево - Признак включения НДС в сумму.
//  ЧастичнаяОплата - Булево - Признак частичной оплаты.
//  ЕстьСтавкаНольПроцентов - Булево - Признак наличия ставки НДС 0%.
//
// Возвращаемое значение:
//  Строка - Представление заголовка для колонки НДС.
//
Функция ПредставлениеЗаголовкаНДС(СуммаНДС, СуммаВключаетНДС, ЧастичнаяОплата, ЕстьСтавкаНольПроцентов = Ложь) Экспорт
	
	ЗаголовокИтоговНДС = "";
	
	ТекстНДС = НСтр("ru ='НДС'");
	Если ЧастичнаяОплата Тогда
		
		ТекстНДС = СтрШаблон(НСтр("ru ='%1 оплаты'"), ТекстНДС);
		
	КонецЕсли;
	
	Если СуммаНДС = 0 И Не ЕстьСтавкаНольПроцентов Тогда
		
		ЗаголовокИтоговНДС = НСтр("ru ='Без налога (НДС)'");
		
	ИначеЕсли СуммаВключаетНДС Тогда
		
		ЗаголовокИтоговНДС = СтрШаблон(НСтр("ru ='В том числе %1:'"), ТекстНДС);
		
	Иначе
		
		ЗаголовокИтоговНДС = СтрШаблон(НСтр("ru ='Сумма %1:'"), ТекстНДС);
		
	КонецЕсли;
	
	Возврат ЗаголовокИтоговНДС;
	
КонецФункции

// Строка - представление итогов НДС документа с выводом % ставки, если она одна
//
// Параметры:
//  СуммаНДС		 - Число
//  СуммаВключаетНДС - Булево
//  ЧастичнаяОплата	 - Булево
//  СтавкиНДС		 - Массив из СправочникСсылка.СтавкиНДС
// 
// Возвращаемое значение:
//   - Строка - представление строки итогов
//
Функция ПредставлениеИтоговНДС(СуммаНДС, СуммаВключаетНДС, СтавкиНДС) Экспорт
	
	ЗаголовокИтоговНДС = "";
	
	Если СуммаНДС = 0 Тогда
		
		Если СтавкиНДС.Найти(УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль()) = Неопределено Тогда
			ЗаголовокИтоговНДС      = НСтр("ru='Без налога (НДС)'");
 		Иначе
			ЗаголовокИтоговНДС      = НСтр("ru='НДС 0%'");
		КонецЕсли; 
		
	Иначе
		
		ЧастиЗаголовка = Новый Массив;
		Если СуммаВключаетНДС Тогда
			ЧастиЗаголовка.Добавить(НСтр("ru='В том числе НДС'"));
		Иначе
			ЧастиЗаголовка.Добавить(НСтр("ru='Сумма НДС'"));
		КонецЕсли; 
		
		УникальныеСтавкиНДС = ОбщегоНазначенияКлиентСервер.СвернутьМассив(СтавкиНДС);
		Если УникальныеСтавкиНДС.Количество() = 1 Тогда
			ЧастиЗаголовка.Добавить(УникальныеСтавкиНДС[0]);
		КонецЕсли; 
		
		ЗаголовокИтоговНДС = СтрШаблон("%1:", СтрСоединить(ЧастиЗаголовка, " "));
	КонецЕсли;
	
	Возврат ЗаголовокИтоговНДС;	
КонецФункции

// Функция формирует представление основания печати.
// 
// Параметры:
//  ОснованиеПечатиСсылка - ДокументСсылка, СправочникСсылка.ДоговорыКонтрагентов - ссылка на документ
//                                          или договор контрагента, для которого необходимо сформировать представление.
// 
// Возвращаемое значение:
//  Строка - Представление основания печати.
Функция ПредставлениеОснованияПечати(ОснованиеПечатиСсылка) Экспорт
	
	Если НЕ ЗначениеЗаполнено(ОснованиеПечатиСсылка) Тогда
		
		Если ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
			
			Возврат ПараметрЭтотДокументЗаказПокупателя();
			
		ИначеЕсли ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.СчетНаОплату") Тогда
			
			Возврат ПараметрЭтотДокументСчетНаОплату();
			
		Иначе
			
			Возврат "";
			
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ОснованиеПечатиСсылка) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		
		ЗаголовокПредставления = "";
		Если Константы.ДобавитьСловоДоговорВПредставлениеДоговораОснованияПечати.Получить() Тогда
			
			ЗаголовокПредставления = НСтр("ru = 'Договор:'") + " ";
			
		КонецЕсли;
		
		Возврат ЗаголовокПредставления + ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОснованиеПечатиСсылка,
			"Наименование");
		
	ИначеЕсли ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.СчетНаОплату")
		ИЛИ ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.ЗаказПокупателя")
		ИЛИ ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.ЗаказПоставщику")
		ИЛИ ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.РасходнаяНакладная")
		ИЛИ ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот")
		ИЛИ ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.ПриемИПередачаВРемонт")
		Тогда
		
		Основание = ДобавитьЗначокНомераКПредставлению(ОснованиеПечатиСсылка);
		Возврат Основание;
		
	КонецЕсли;
	
КонецФункции

// Возвращает структуру с номером и датой основания печати.
// 
// Параметры:
//  ОснованиеПечатиСсылка - СправочникСсылка.ДоговорыКонтрагентов, ДокументСсылка - основание печати
// 
// Возвращаемое значение:
//  Структура - Структура:
//   * Номер - Строка - номер основания печати
//   * Дата - Дата - дата основания печати
Функция ПредставлениеНомераДатыОснованияПечати(ОснованиеПечатиСсылка) Экспорт
	
	ДанныеОснованияПечати = Новый Структура("Номер, Дата", "", '00010101');
	
	Если ЗначениеЗаполнено(ОснованиеПечатиСсылка) Тогда
		
		Если ТипЗнч(ОснованиеПечатиСсылка) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			
			ДанныеОснованияПечати.Номер = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОснованиеПечатиСсылка,
				"НомерДоговора");
			ДанныеОснованияПечати.Дата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОснованиеПечатиСсылка,
				"ДатаДоговора");
			
		ИначеЕсли ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.СчетНаОплату")
			ИЛИ ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.ЗаказПокупателя")
			ИЛИ ТипЗнч(ОснованиеПечатиСсылка) = Тип("ДокументСсылка.ЗаказПоставщику")
			Тогда
			
			ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ОснованиеПечатиСсылка, "Номер, Дата");
			ЗаполнитьЗначенияСвойств(ДанныеОснованияПечати, ЗначенияРеквизитов);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДанныеОснованияПечати;
	
КонецФункции

// Формирует представление кода номенклатуры в соответствии с настройками представления кодов в печатных формах.
//
// Параметры:
//  ПараметрыНоменклатуры - СтрокаТаблицыЗначений, СтрокаДереваЗначений, ВыборкаИзРезультатаЗапроса, Структура - поля:
//   * Код - Строка - код номенклатуры.
//   * Артикул - Строка - артикул номенклатуры.
//   * ШтрихКод - Строка - штрихкод номенклатуры.
//   * ПредставлениеКодаНоменклатуры - Строка - представление кода номенклатуры
//
// Возвращаемое значение:
//  Строка - представление кода номенклатуры.
//
Функция ПредставлениеКодаНоменклатуры(ПараметрыНоменклатуры) Экспорт
	
	ПредставлениеКодаНоменклатуры = "";
	ИмяПоля = "";
	
	ВидПредставления = Константы.ПредставлениеКодовВПечатныхФормах.Получить();
	Если ВидПредставления = Перечисления.КодыНоменклатурыВДокументах.Код Тогда
		
		ИмяПоля = "Код";
		
	ИначеЕсли ВидПредставления = Перечисления.КодыНоменклатурыВДокументах.Артикул Тогда
		
		ИмяПоля = "Артикул";
		
	ИначеЕсли ВидПредставления = Перечисления.КодыНоменклатурыВДокументах.Штрихкод Тогда
		
		ИмяПоля = "ШтрихКод";
		
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяПоля) Тогда
		
		// обработка не требуется
		
	ИначеЕсли ТипЗнч(ПараметрыНоменклатуры) = Тип("СтрокаТаблицыЗначений")
		ИЛИ ТипЗнч(ПараметрыНоменклатуры) = Тип("СтрокаДереваЗначений")
		ИЛИ ТипЗнч(ПараметрыНоменклатуры) = Тип("ВыборкаИзРезультатаЗапроса") Тогда
		
		ОбработчикПредставленияНоменклатуры = Новый Структура(ИмяПоля, "");
		ЗаполнитьЗначенияСвойств(ОбработчикПредставленияНоменклатуры, ПараметрыНоменклатуры);
		ПредставлениеКодаНоменклатуры = ОбработчикПредставленияНоменклатуры[ИмяПоля];
		
	ИначеЕсли ТипЗнч(ПараметрыНоменклатуры) = Тип("Структура") Тогда
		
		ПараметрыНоменклатуры.Свойство(ИмяПоля, ПредставлениеКодаНоменклатуры);
		
	КонецЕсли;
	
	Возврат ПредставлениеКодаНоменклатуры;
	
КонецФункции

// Формирует представление серии номенклатуры по ключу связи.
//
// Параметры:
//  ТаблицаСерийНоменклатуры - ТаблицаЗначений - таблица значений, содержащая серии номенклатуры.
//  КлючСвязи - Число - ключ связи для поиска строк в таблице серий номенклатуры.
//
// Возвращаемое значение:
//  Строка - представление серии номенклатуры, соответствующей ключу связи.
//
Функция ПредставлениеСерииНоменклатурыПоКлючу(ТаблицаСерийНоменклатуры, КлючСвязи) Экспорт
	
	Если ТипЗнч(ТаблицаСерийНоменклатуры) <> Тип("ТаблицаЗначений") Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТаблицаСерийНоменклатуры.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	ПредставленияСерийНоменклатуры = Новый Массив;
	
	МассивНайденныхСтрок = ТаблицаСерийНоменклатуры.НайтиСтроки(Новый Структура("КлючСвязи", КлючСвязи));
	Для каждого СтрокаМассива Из МассивНайденныхСтрок Цикл
		
		Если ЗначениеЗаполнено(СтрокаМассива.Серия) Тогда
			ПредставленияСерийНоменклатуры.Добавить(СокрЛП(СтрокаМассива.Серия));
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = СтрСоединить(ПредставленияСерийНоменклатуры, ", ");
	Возврат Результат;
	
КонецФункции

// Формирует представление скидки в виде процента или суммы.
//
// Параметры:
//  СтрокаТабличнойЧасти - СтрокаТаблицыЗначений - строка табличной части документа.
//  СтруктураИтогов - Структура:
//   * СкидкаПоСтроке - Число - скидка по строке
//   * ПредставлениеСкидки - ПеречислениеСсылка.СпособОтображенияСкидок
//
// Возвращаемое значение:
//  Строка - представление скидки в виде процента или суммы.
//
Функция ПредставлениеСкидки(СтрокаТабличнойЧасти, СтруктураИтогов) Экспорт
	
	СкидкаСумма = 0;
	СкидкаПроцент = 0;
	
	ТочностьОкругленияСкидки = 2; // Знаков после запятой
	
	Если СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 100 Тогда
		
		СкидкаСумма = СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.Количество;
		СкидкаПроцент = НСтр("ru ='100%'");
		
	ИначеЕсли СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0 
		И СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки = 0 Тогда
		
		СкидкаСумма = 0;
		СкидкаПроцент = НСтр("ru ='-'");
		
	Иначе
		
		СкидкаСумма = (СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена) - СтрокаТабличнойЧасти.Сумма;
		
		Если СкидкаСумма > 0 Тогда
			
			Знаменатель = (СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена);
			Если Знаменатель = 0 Тогда
				
				СкидкаПроцент = 0;
				
			Иначе
				
				СкидкаПроцент = (СтрокаТабличнойЧасти.Сумма * 100) / Знаменатель;
				СкидкаПроцент = Строка(100 - Окр(СкидкаПроцент, ТочностьОкругленияСкидки)) + "%";
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если СтруктураИтогов.Свойство("СкидкаПоСтроке") Тогда
		
		СтруктураИтогов.СкидкаПоСтроке = СкидкаСумма;
		
	КонецЕсли;
	
	Результат = "";
	
	Если СтруктураИтогов.ПредставлениеСкидки = Перечисления.СпособОтображенияСкидок.Процент Тогда
		Результат = СокрЛП(СкидкаПроцент);
	Иначе
		Результат = Формат(СкидкаСумма, "ЧДЦ=2; ЧГ=");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

