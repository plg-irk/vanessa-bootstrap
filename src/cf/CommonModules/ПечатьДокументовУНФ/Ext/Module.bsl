Функция НовыйТекстЗапросаСведенийОЮрФизЛице(Запрос, ИмяСправочника, ТекБанковскийСчет)
	
	Результат = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Таблица.Представление КАК Наименование,
	|	Таблица.НаименованиеПолное КАК ПолноеНаименование,
	|	"""" КАК СокращенноеНаименование,
	|	"""" КАК СвидетельствоСерияНомер,
	|	"""" КАК СвидетельствоДатаВыдачи,
	|	"""" КАК ИНН,
	|	"""" КАК КПП,
	|	"""" КАК КодПоОКПО,
	|	"""" КАК РегистрационныйНомер,
	|	"""" КАК ДатаРегистрации,
	|	"""" КАК СтранаРегистрации,
	|	"""" КАК НомерСчета,
	|	"""" КАК ТекстКорреспондента,
	|	"""" КАК Банк,
	|	"""" КАК БИК,
	|	"""" КАК КоррСчет,
	|	"""" КАК ВидКонтрагента,
	|	"""" КАК АдресБанка,
	|	"""" КАК ЮридическоеФизическоеЛицо,
	|	"""" КАК ОГРН
	|ИЗ
	|	&ИмяТаблицы КАК Таблица
	|ГДЕ
	|	Таблица.Ссылка = &ПарЮрФизЛицо";
	
	Если ИмяСправочника = "Организации" Тогда
		Результат = СтрЗаменить(Результат, """"" КАК СокращенноеНаименование",
			"Таблица.НаименованиеСокращенное КАК СокращенноеНаименование");
		Результат = СтрЗаменить(Результат, """"" КАК СвидетельствоСерияНомер",
			"Таблица.СвидетельствоСерияНомер КАК СвидетельствоСерияНомер");
		Результат = СтрЗаменить(Результат, """"" КАК СвидетельствоДатаВыдачи",
			"Таблица.СвидетельствоДатаВыдачи КАК СвидетельствоДатаВыдачи");
		Результат = СтрЗаменить(Результат, """"" КАК ИНН", "Таблица.ИНН КАК ИНН");
		Результат = СтрЗаменить(Результат, """"" КАК КПП", "Таблица.КПП КАК КПП");
		Результат = СтрЗаменить(Результат, """"" КАК КодПоОКПО", "Таблица.КодПоОКПО КАК КодПоОКПО");
		Результат = СтрЗаменить(Результат, """"" КАК ОГРН", "Таблица.ОГРН КАК ОГРН");
		Результат = СтрЗаменить(Результат, """"" КАК ДатаРегистрации", "Таблица.ДатаРегистрации КАК ДатаРегистрации");
		Результат = СтрЗаменить(Результат, """"" КАК ЮридическоеФизическоеЛицо",
			"Таблица.ЮридическоеФизическоеЛицо КАК ЮридическоеФизическоеЛицо");
	КонецЕсли;
	
	Если ИмяСправочника = "Контрагенты" Тогда
		Результат = СтрЗаменить(Результат, """"" КАК РегистрационныйНомер",
			"Таблица.РегистрационныйНомер КАК РегистрационныйНомер");
		Результат = СтрЗаменить(Результат, """"" КАК СтранаРегистрации",
			"Таблица.СтранаРегистрации КАК СтранаРегистрации");
		Результат = СтрЗаменить(Результат, """"" КАК ИНН", "Таблица.ИНН КАК ИНН");
		Результат = СтрЗаменить(Результат, """"" КАК КПП", "Таблица.КПП КАК КПП");
		Результат = СтрЗаменить(Результат, """"" КАК КодПоОКПО", "Таблица.КодПоОКПО КАК КодПоОКПО");
		Результат = СтрЗаменить(Результат, """"" КАК ВидКонтрагента",
		"Таблица.ВидКонтрагента КАК ВидКонтрагента");
		Результат = СтрЗаменить(Результат, """"" КАК ДатаРегистрации", "Таблица.ДатаСоздания КАК ДатаРегистрации");
		Результат = СтрЗаменить(Результат, """"" КАК ЮридическоеФизическоеЛицо",
			"Таблица.ЮридическоеФизическоеЛицо КАК ЮридическоеФизическоеЛицо");
	КонецЕсли;
	
	ИмяРеквизитаБанка = ИмяРеквизитаБанка(ТекБанковскийСчет);
	
	Если ЗначениеЗаполнено(ТекБанковскийСчет) Тогда
		Результат = СтрЗаменить(Результат, """"" КАК НомерСчета", "БанковскиеСчета.НомерСчета КАК НомерСчета");
		Результат = СтрЗаменить(Результат, """"" КАК ТекстКорреспондента",
			"БанковскиеСчета.ТекстКорреспондента КАК ТекстКорреспондента");
		Результат = СтрЗаменить(Результат, """"" КАК Банк", СтрШаблон("БанковскиеСчета.%1 КАК Банк", ИмяРеквизитаБанка));
		Результат = СтрЗаменить(Результат, """"" КАК БИК", СтрШаблон("БанковскиеСчета.%1.Код КАК БИК", ИмяРеквизитаБанка));
		Результат = СтрЗаменить(Результат, """"" КАК КоррСчет",
			СтрШаблон("БанковскиеСчета.%1.КоррСчет КАК КоррСчет", ИмяРеквизитаБанка));
		Результат = СтрЗаменить(Результат, """"" КАК АдресБанка",
			СтрШаблон("БанковскиеСчета.%1.Адрес КАК АдресБанка", ИмяРеквизитаБанка));
		Результат = СтрЗаменить(Результат, "&ИмяТаблицы КАК Таблица",
			"&ИмяТаблицы КАК Таблица, Справочник.БанковскиеСчета КАК БанковскиеСчета");
		Результат = СтрЗаменить(Результат, "Таблица.Ссылка = &ПарЮрФизЛицо",
			"Таблица.Ссылка = &ПарЮрФизЛицо И БанковскиеСчета.Ссылка = &ПарБанковскийСчет");
	КонецЕсли;
	
	Результат = СтрЗаменить(Результат, "&ИмяТаблицы", СтрШаблон("Справочник.%1", ИмяСправочника));
	
	Возврат Результат;
	
КонецФункции

Функция ВидыКонтактнойИнформации(ЮрФизЛицо)
	
	Результат = НовыеВидыКонтактнойИнформации();
	
	Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.Организации") Тогда
		Результат.Телефон = Справочники.ВидыКонтактнойИнформации.ТелефонОрганизации;
		Результат.Факс = Справочники.ВидыКонтактнойИнформации.ФаксОрганизации;
		Результат.ЮрАдрес = Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации;
		Результат.ФактАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации;
		Результат.ПочтАдрес = Справочники.ВидыКонтактнойИнформации.ПочтовыйАдресОрганизации;
		Результат.ЭлПочта = Справочники.ВидыКонтактнойИнформации.EmailОрганизации;
		Возврат Результат;
	КонецЕсли;
		
	Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Результат.Телефон = Справочники.ВидыКонтактнойИнформации.ТелефонФизЛица;
		Результат.ЮрАдрес = Справочники.ВидыКонтактнойИнформации.АдресПоПропискеФизическиеЛица;
		Результат.ФактАдрес = Справочники.ВидыКонтактнойИнформации.АдресПоПропискеФизическиеЛица;
		Результат.ЭлПочта = Справочники.ВидыКонтактнойИнформации.EmailФизическиеЛица;
		Возврат Результат;
	КонецЕсли;
		
	Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.Контрагенты") Тогда
		Результат.Телефон = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента;
		Результат.Факс = Справочники.ВидыКонтактнойИнформации.ФаксКонтрагента;
		Результат.ЮрАдрес = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
		Результат.ФактАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента;
		Результат.ПочтАдрес = Справочники.ВидыКонтактнойИнформации.ПочтовыйАдресКонтрагента;
		Результат.ЭлПочта = Справочники.ВидыКонтактнойИнформации.EmailКонтрагента;
		Возврат Результат;
	КонецЕсли;
		
	Если ТипЗнч(ЮрФизЛицо) = Тип("СправочникСсылка.СтруктурныеЕдиницы") Тогда
		Результат.Телефон = Справочники.ВидыКонтактнойИнформации.ТелефонСтруктурнойЕдиницы;
		Результат.ФактАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы;
		Возврат Результат;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НовыеВидыКонтактнойИнформации()
	
	Результат = Новый Структура;
	Результат.Вставить("Телефон", Справочники.ВидыКонтактнойИнформации.ПустаяСсылка());
	Результат.Вставить("Факс", Справочники.ВидыКонтактнойИнформации.ПустаяСсылка());
	Результат.Вставить("ЮрАдрес", Справочники.ВидыКонтактнойИнформации.ПустаяСсылка());
	Результат.Вставить("ФактАдрес", Справочники.ВидыКонтактнойИнформации.ПустаяСсылка());
	Результат.Вставить("ПочтАдрес", Справочники.ВидыКонтактнойИнформации.ПустаяСсылка());
	Результат.Вставить("ЭлПочта", Справочники.ВидыКонтактнойИнформации.ПустаяСсылка());
	
	Возврат Результат;
	
КонецФункции

Функция ИмяРеквизитаБанка(ТекБанковскийСчет)
	
	ИмяРеквизитаПоУмолчанию = "Банк";
	
	Если Не ЗначениеЗаполнено(ТекБанковскийСчет) Тогда
		Возврат ИмяРеквизитаПоУмолчанию;
	КонецЕсли;
	
	БанкРасчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекБанковскийСчет, "БанкРасчетов", Истина);
	Если Не ЗначениеЗаполнено(БанкРасчетов) Тогда
		Возврат ИмяРеквизитаПоУмолчанию;
	КонецЕсли;
	
	Возврат "БанкРасчетов";
	
КонецФункции

Функция ДобавитьСуммовыеПоля(ПараметрыЗапроса, ТабличнаяЧастьДокумента, ЗначениеПеречисленияТабличныеЧастиДокументов)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ПараметрыЗапроса.Ссылка);
	Запрос.УстановитьПараметр("КурсДокумента", ПараметрыЗапроса.КурсДокумента);
	Запрос.УстановитьПараметр("КратностьДокумента", ПараметрыЗапроса.КратностьДокумента);
	Запрос.УстановитьПараметр("ТабличнаяЧастьДокумента", ТабличнаяЧастьДокумента);
	Запрос.УстановитьПараметр("СтрокиДокументаНоменклатураНабора", Истина);
	Запрос.УстановитьПараметр("ТабличнаяЧастьДокументаНоменклатураНабора", Истина);
	Запрос.УстановитьПараметр("ЗначениеПеречисленияТабличныеЧастиДокументов",
		ЗначениеПеречисленияТабличныеЧастиДокументов);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТабличнаяЧастьДокумента.НомерСтроки КАК НомерСтроки,
	|	ТабличнаяЧастьДокумента.ПредставлениеНоменклатуры КАК ПредставлениеНоменклатуры,
	|	ТабличнаяЧастьДокумента.Код КАК Код,
	|	ТабличнаяЧастьДокумента.Артикул КАК Артикул,
	|	ТабличнаяЧастьДокумента.Штрихкод КАК Штрихкод,
	|	ТабличнаяЧастьДокумента.ТипНоменклатуры КАК ТипНоменклатуры,
	|	ТабличнаяЧастьДокумента.Склад КАК Склад,
	|	ТабличнаяЧастьДокумента.Ячейка КАК Ячейка,
	|	ТабличнаяЧастьДокумента.Характеристика КАК Характеристика,
	|	ТабличнаяЧастьДокумента.Партия КАК Партия,
	|	ТабличнаяЧастьДокумента.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ТабличнаяЧастьДокумента.ЕдиницаИзмеренияПоОКЕИ_Наименование КАК ЕдиницаИзмеренияПоОКЕИ_Наименование,
	|	ТабличнаяЧастьДокумента.ЕдиницаИзмеренияПоОКЕИ_Код КАК ЕдиницаИзмеренияПоОКЕИ_Код,
	|	ТабличнаяЧастьДокумента.Цена КАК Цена,
	|	ТабличнаяЧастьДокумента.Сумма КАК Сумма,
	|	ТабличнаяЧастьДокумента.СтавкаНДС КАК СтавкаНДС,
	|	ТабличнаяЧастьДокумента.СуммаНДС КАК СуммаНДС,
	|	ТабличнаяЧастьДокумента.Всего КАК Всего,
	|	ТабличнаяЧастьДокумента.Количество КАК Количество,
	|	ТабличнаяЧастьДокумента.КоличествоПоКоэффициенту КАК КоличествоПоКоэффициенту,
	|	ТабличнаяЧастьДокумента.Содержание КАК Содержание,
	|	ТабличнаяЧастьДокумента.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ТабличнаяЧастьДокумента.ЕстьСкидка КАК ЕстьСкидка,
	|	ТабличнаяЧастьДокумента.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки,
	|	ТабличнаяЧастьДокумента.КлючСвязи КАК КлючСвязи,
	|	ТабличнаяЧастьДокумента.Заказ КАК Заказ,
	|	ТабличнаяЧастьДокумента.ЭтоРазделитель КАК ЭтоРазделитель,
	|	ТабличнаяЧастьДокумента.СуммаБезСкидки КАК СуммаБезСкидки,
	|	&ТабличнаяЧастьДокументаНоменклатураНабора
	|ПОМЕСТИТЬ ТабличнаяЧастьДокумента
	|ИЗ
	|	&ТабличнаяЧастьДокумента КАК ТабличнаяЧастьДокумента
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтрокиДокумента.НомерСтроки КАК НомерСтроки,
	|	СтрокиДокумента.ПредставлениеНоменклатуры,
	|	СтрокиДокумента.Код,
	|	СтрокиДокумента.Артикул,
	|	СтрокиДокумента.Штрихкод,
	|	СтрокиДокумента.ТипНоменклатуры,
	|	СтрокиДокумента.Склад,
	|	СтрокиДокумента.Ячейка,
	|	СтрокиДокумента.Характеристика,
	|	СтрокиДокумента.Партия,
	|	СтрокиДокумента.ЕдиницаИзмерения,
	|	СтрокиДокумента.ЕдиницаИзмеренияПоОКЕИ_Наименование,
	|	СтрокиДокумента.ЕдиницаИзмеренияПоОКЕИ_Код,
	|	СтрокиДокумента.Цена,
	|	СтрокиДокумента.Сумма,
	|	СтрокиДокумента.СтавкаНДС,
	|	СтрокиДокумента.СуммаНДС,
	|	ЕСТЬNULL(СуммыДокументовРегламентированныйУчет.НДС, СтрокиДокумента.СуммаНДС * &КурсДокумента /
	|		&КратностьДокумента) КАК СуммаНДСВНациональнойВалюте,
	|	СтрокиДокумента.Всего,
	|	ЕСТЬNULL(СуммыДокументовРегламентированныйУчет.Всего, СтрокиДокумента.Всего * &КурсДокумента /
	|		&КратностьДокумента) КАК ВсегоВНациональнойВалюте,
	|	СтрокиДокумента.Количество,
	|	СтрокиДокумента.КоличествоПоКоэффициенту,
	|	СтрокиДокумента.Содержание,
	|	СтрокиДокумента.ПроцентСкидкиНаценки,
	|	СтрокиДокумента.ЕстьСкидка,
	|	СтрокиДокумента.СуммаАвтоматическойСкидки,
	|	СтрокиДокумента.КлючСвязи,
	|	СтрокиДокумента.Заказ,
	|	СтрокиДокумента.ЭтоРазделитель,
	|	СтрокиДокумента.СуммаБезСкидки,
	|	&СтрокиДокументаНоменклатураНабора
	|ИЗ
	|	ТабличнаяЧастьДокумента КАК СтрокиДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СуммыДокументовРегламентированныйУчет КАК СуммыДокументовРегламентированныйУчет
	|		ПО СуммыДокументовРегламентированныйУчет.Регистратор = &Ссылка
	|		И СуммыДокументовРегламентированныйУчет.ТабличнаяЧастьДокумента = &ЗначениеПеречисленияТабличныеЧастиДокументов
	|		И СтрокиДокумента.НомерСтроки = СуммыДокументовРегламентированныйУчет.НомерСтрокиДокумента
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	// Наборы
	Если ТабличнаяЧастьДокумента.Колонки.Найти("НоменклатураНабора") <> Неопределено Тогда
		Запрос.Текст = СтрЗаменить(
		Запрос.Текст,
		"	&ТабличнаяЧастьДокументаНоменклатураНабора", 
		"	ТабличнаяЧастьДокумента.НоменклатураНабора КАК НоменклатураНабора, 
		|	ТабличнаяЧастьДокумента.ХарактеристикаНабора КАК ХарактеристикаНабора,
		|	ТабличнаяЧастьДокумента.ЭтоНабор КАК ЭтоНабор,
		|	ТабличнаяЧастьДокумента.НеобходимоВыделитьКакСоставНабора КАК НеобходимоВыделитьКакСоставНабора");
		Запрос.Текст = СтрЗаменить(
		Запрос.Текст,
		"	&СтрокиДокументаНоменклатураНабора", 
		"	СтрокиДокумента.НоменклатураНабора,
		|	СтрокиДокумента.ХарактеристикаНабора,
		|	СтрокиДокумента.ЭтоНабор,
		|	СтрокиДокумента.НеобходимоВыделитьКакСоставНабора");
	КонецЕсли; 
	// Конец Наборы
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ИсключитьНедоступнуюТаблицуИзТекстаЗапроса(Запрос, ИмяТаблицы)
	
	Если ПравоДоступа("Чтение", Метаданные.Документы[ИмяТаблицы]) Тогда
		Возврат;
	КонецЕсли;
	
	// Привилегированный режим нужен, т.к. при отсутствии доступа схема запроса будет выдавать ошибки.
	УстановитьПривилегированныйРежим(Истина);
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(Запрос.Текст);
	
	ИндексыДляУдаления = Новый Соответствие;
	
	Для Каждого ТекПакет Из СхемаЗапроса.ПакетЗапросов Цикл
		
		Для Каждого ТекОператор Из ТекПакет.Операторы Цикл
			
			ИндексыДляУдаления.Очистить();
			
			Для Каждого ТекИсточник Из ТекОператор.Источники Цикл
				Если ТипЗнч(ТекИсточник.Источник) <> Тип("ТаблицаСхемыЗапроса") Тогда
					Продолжить;
				КонецЕсли;
				Если СтрНайти(ТекИсточник.Источник.ИмяТаблицы, ИмяТаблицы) <> 0 Тогда
					ИндексыДляУдаления[ТекПакет.Операторы.Индекс(ТекОператор)] = Истина;
				КонецЕсли;
			КонецЦикла;
			
			// BSLLS:DeletingCollectionItem-off
			// Удаление выполняется для каждого оператора пакета
			Для Каждого ТекИндексДляУдаления Из ИндексыДляУдаления Цикл
				ТекПакет.Операторы.Удалить(ТекИндексДляУдаления.Ключ);
			КонецЦикла;
			// BSLLS:DeletingCollectionItem-on
			
		КонецЦикла;
		
	КонецЦикла;
	
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	
КонецПроцедуры

Функция ЗаполнитьТаблицуТоваров(Товары, СтруктураДействий)
	
	ИспользоватьХарактеристикиНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики");
	ИспользоватьПартииНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьПартии");
	ИспользоватьСерииНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьСерииНоменклатуры");
	ИспользоватьSKU = ПолучитьФункциональнуюОпцию("ИспользоватьОбменСПодключаемымОборудованиемOffline");
	ИспользоватьЕдиницыИзмерения = ПолучитьФункциональнуюОпцию("УчетВРазличныхЕдиницахИзмерения"); 
	
	ИсходныеДанные = Новый ТаблицаЗначений;
	ИсходныеДанные.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ИсходныеДанные.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ИсходныеДанные.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	ИсходныеДанные.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ИсходныеДанные.Колонки.Добавить("Партия", Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"));
	ИсходныеДанные.Колонки.Добавить("Серия", Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ИсходныеДанные.Колонки.Добавить("ЕдиницаИзмерения", Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения"));
	
	Для Каждого Товар Из Товары Цикл
		Строка = ИсходныеДанные.Добавить();
		Строка.Номенклатура = Товар.Номенклатура;
		Строка.Количество = Товар.Количество;
		Строка.Характеристика = Товар.Характеристика;
		Строка.Организация = Товар.Организация;
		Строка.Партия = Товар.Партия;
		Строка.Серия = Товар.Серия;
		Строка.ЕдиницаИзмерения = Товар.ЕдиницаИзмерения;
	КонецЦикла;
	
	НастройкиПечати = Обработки.ПечатьЭтикетокИЦенников.НовыеНастройкиПечати();
	
	НастройкиПечати.ОбязательныеПоля.Добавить("Цена");
	НастройкиПечати.ОбязательныеПоля.Добавить("Весовой");
	НастройкиПечати.ОбязательныеПоля.Добавить("Штрихкод");
	НастройкиПечати.ОбязательныеПоля.Добавить("Количество");
	НастройкиПечати.ОбязательныеПоля.Добавить("Номенклатура");
	Если ИспользоватьSKU Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("SKU");
	КонецЕсли;
	Если ИспользоватьХарактеристикиНоменклатуры Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("Характеристика");
	КонецЕсли;
	Если ИспользоватьПартииНоменклатуры Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("Партия");
	КонецЕсли;
	Если ИспользоватьСерииНоменклатуры Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("Серия");
	КонецЕсли;
	Если ИспользоватьЕдиницыИзмерения Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("ЕдиницаИзмерения");
	КонецЕсли;
	НастройкиПечати.ОбязательныеПоля.Добавить("ОстатокНаСкладе");
	НастройкиПечати.ОбязательныеПоля.Добавить("Организация");
	
	НастройкиПечати.ОбязательныеПоля.Добавить("НоменклатураНаименованиеПолное");
	
	// Шаблоны этикеток и ценников.
	НастройкиПечати.ОбязательныеПоля.Добавить("Номенклатура.КатегорияНоменклатуры.ШаблонЭтикетки");
	НастройкиПечати.ОбязательныеПоля.Добавить("Номенклатура.КатегорияНоменклатуры.ШаблонЦенника");
	ПолеСКДШаблонЦенникаБПО = "Номенклатура.КатегорияНоменклатуры.ШаблонЦенникаБПО";
	НастройкиПечати.ОбязательныеПоля.Добавить(ПолеСКДШаблонЦенникаБПО);
	
	ВидЦены = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойВидЦенПродажи");
	ДатаЦены = ТекущаяДатаСеанса();
	
	НастройкиПечати.ПараметрыДанных.Вставить("ВидЦен"    , ВидЦены);
	НастройкиПечати.ПараметрыДанных.Вставить("ВидЦенАкционный"    , ВидЦены);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныНаДату" , ДатаЦены);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныНаДатуАкционные" , ДатаЦены);
	
	НастройкиПечати.ПараметрыДанных.Вставить("ИспользоватьАссортимент", Ложь);
	
	Компоновщик = Неопределено;
	СтруктураДействий.Свойство("КомпоновщикНастроек", Компоновщик);
	Если Компоновщик = Неопределено Тогда
		СхемаКомпоновкиДанных = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("ПоляШаблонаПоУмолчанию");
		Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
		АдресСКД = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных);
		Источник = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСКД);
		Компоновщик.Инициализировать(Источник);
		Компоновщик.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
		Компоновщик.Восстановить(СпособВосстановленияНастроекКомпоновкиДанных.ПроверятьДоступность);
	КонецЕсли;
	НастройкиПечати.КомпоновщикНастроек = Компоновщик;
	НастройкиПечати.ИмяМакетаСхемыКомпоновкиДанных = "ПоляШаблонаПоУмолчанию";
	НастройкиПечати.ИсходныеДанные = ИсходныеДанные;
	
	Если ИспользоватьSKU Тогда
		НастройкиПечати.ИсходныеДанные.Колонки.Добавить("ШтрихАвтопроверки", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(500)));
	КонецЕсли;
	
	// Загрузка сформированного списка товаров.
	ДанныеДляПечати = Обработки.ПечатьЭтикетокИЦенников.ПодготовитьДанныеДляПечати(НастройкиПечати);
	
	Если Не ЗначениеЗаполнено(СтруктураДействий.ЗаполнитьОрганизацию) Тогда
		СтруктураДействий.ЗаполнитьОрганизацию = УправлениеНебольшойФирмойПовтИсп.ОрганизацияПоУмолчанию();
	КонецЕсли;
	
	ТоварыДляПечати = Новый Массив;
	Для Каждого Товар Из ДанныеДляПечати.ТаблицаТоваров Цикл
		СтруктураТовара = ПечатьЭтикетокИЦенниковБПОКлиентСервер.ТоварДляПечати();
		СтруктураТовара.НоменклатураБПО = Товар.Номенклатура;
		Если ИспользоватьПартииНоменклатуры Тогда
			СтруктураТовара.Вставить("Партия", Товар.Партия);
		КонецЕсли;
		Если ИспользоватьСерииНоменклатуры Тогда
			СтруктураТовара.Вставить("Серия", Товар.Серия);
		КонецЕсли;
		Если ИспользоватьХарактеристикиНоменклатуры Тогда
			СтруктураТовара.ХарактеристикаБПО = Товар.Характеристика;
		КонецЕсли;
		Если ИспользоватьЕдиницыИзмерения Тогда
			СтруктураТовара.УпаковкаБПО       = Товар.ЕдиницаИзмерения;
		КонецЕсли;
		СтруктураТовара.ОрганизацияБПО = СтруктураДействий.ЗаполнитьОрганизацию;
		СтруктураТовара.Штрихкод = Товар.Штрихкод;
		СтруктураТовара.Цена = Товар.Цена;
		Если ИспользоватьSKU Тогда
			СтруктураТовара.Вставить("SKU", Товар.SKU);
			СтруктураТовара.Вставить("ШтрихАвтопроверки", СформироватьСобственныйШтрихкод(СтруктураТовара));
		КонецЕсли;
		Если СтруктураДействий.Свойство("ЗаполнитьКоличествоЭтикетокПоДокументу") Тогда
			СтруктураТовара.Вставить("Количество", Товар.Количество);
		Иначе
			Если СтруктураДействий.УстановитьРежим = "ПечатьЭтикеток" Тогда
				СтруктураТовара.Вставить("Количество", Товар.ОстатокНаСкладе);
			Иначе
				СтруктураТовара.Вставить("Количество", 1);
			КонецЕсли;
		КонецЕсли;
		КолонкаШаблон = ДанныеДляПечати.СоответствиеПолейСКДКолонкамТаблицыТоваров.Получить(ПолеСКДШаблонЦенникаБПО);
		СтруктураТовара.Вставить("ШаблонЦенникаЭтикетки", Товар[КолонкаШаблон]);
		
		ТоварыДляПечати.Добавить(СтруктураТовара);
	КонецЦикла;
	
	Возврат ТоварыДляПечати;
	
КонецФункции

Функция ДобавитьЗначокНомераКПредставлению(ОснованиеПечати)
	
	Источник = ОснованиеПечати.Метаданные().Имя;
	ПустаяСсылкаОбъекта = Документы[Источник].ПустаяСсылка();
	ПредставленияОбъектовМетаданных = ДокументыУНФКлиентСерверПовтИсп.ПредставленияОбъектовМетаданных();
	ПредставлениеМетаданных = ПредставленияОбъектовМетаданных[ПустаяСсылкаОбъекта];
	ПредставлениеДокумента = Строка(ОснованиеПечати);
	ШаблонПредставления = НСтр("ru = '%1 №'");
	НовоеПредставлениеМетаданных = СтрШаблон(ШаблонПредставления, ПредставлениеМетаданных);
	ИтоговаяСтрока = СтрЗаменить(ПредставлениеДокумента, ПредставлениеМетаданных + " ", НовоеПредставлениеМетаданных);
	
	Возврат ИтоговаяСтрока;
	
КонецФункции

Процедура НастроитьФормуПечатьДокументов(Форма);
	
	СписокОбъектов = Форма.ОбъектыПечати;
	Организация = ПолучитьОрганизациюОбъектов(СписокОбъектов);
	ИмяРеквизитаОрганизация = "Организация";
	НовыеРеквизитыФормы = Новый Массив;
	РеквизитФормы = Новый РеквизитФормы(ИмяРеквизитаОрганизация,
		Новый ОписаниеТипов("СправочникСсылка.Организации"),
		,
		НСтр("ru = 'Организация'"));
	НовыеРеквизитыФормы.Добавить(РеквизитФормы);
	Форма.ИзменитьРеквизиты(НовыеРеквизитыФормы);
	Если Не Организация.Пустая() Тогда
		Форма[ИмяРеквизитаОрганизация] = Организация;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает организацию списка документов. Если организации различаются, то возвращает пустую ссылку
//
Функция ПолучитьОрганизациюОбъектов(СписокОбъектов)
	
	ОрганизацииОбъектов = Новый Массив;
	Для Каждого ОбъектПечати Из СписокОбъектов Цикл
		
		Если ТипЗнч(ОбъектПечати.Значение) = Тип("СправочникСсылка.Организации") Тогда
			ОрганизацииОбъектов.Добавить(ОбъектПечати.Значение);
			Продолжить;
		КонецЕсли;
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ОбъектПечати.Значение, "Организация") Тогда
			Если ОрганизацииОбъектов.Найти(ОбъектПечати.Значение.Организация) = Неопределено Тогда
				ОрганизацииОбъектов.Добавить(ОбъектПечати.Значение.Организация);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Результат = Справочники.Организации.ПустаяСсылка();
	
	Если ОрганизацииОбъектов.Количество() = 1 Тогда
		Результат = ОрганизацииОбъектов[0];
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЕстьПечатныеФормыСПодписьюИПечатью(НастройкиПечатныхФорм)
	
	Результат = Ложь;
	Для Каждого НастройкаПечатнойФормы Из НастройкиПечатныхФорм Цикл
		Результат = Результат Или НастройкаПечатнойФормы.ПодписьИПечать;
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

Процедура ОформитьФлажокПодписиИПечати(Форма)
	
	ЭлементФлагПодписьИПечать =  Форма.Элементы.Найти("ФлажокПодписьИПечать");
	Если ЭлементФлагПодписьИПечать = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// Флажок всегда показываем для поддерживаемых документов, чтобы пользователь знал о возможности вывести факсимиле
	Если Не ЭлементФлагПодписьИПечать.Видимость И ЕстьПечатныеФормыСПодписьюИПечатью(Форма.НастройкиПечатныхФорм) Тогда
		 ЭлементФлагПодписьИПечать.Видимость = Истина;
		 ЭлементФлагПодписьИПечать.Доступность = Ложь;
		 Форма.ПодписьИПечать = Ложь;
	КонецЕсли;
	
	ГруппаПодписьИПечать = Форма.Элементы.Вставить("ГруппаПодписьИПечатьУНФ", Тип("ГруппаФормы"),
		Форма.Элементы.ГруппаКоманднаяПанель, Форма.Элементы.КоманднаяПанельПраваяЧасть);
	ГруппаПодписьИПечать.Вид                      = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаПодписьИПечать.ОтображатьЗаголовок      = Ложь;
	ГруппаПодписьИПечать.Отображение              = ОтображениеОбычнойГруппы.Нет;
	ГруппаПодписьИПечать.ЦветФона                 = ЦветаСтиля.БыстрыеНастройкиФонГруппы;
	
	Форма.Элементы.Переместить(ЭлементФлагПодписьИПечать, ГруппаПодписьИПечать);
	
	ТекстПодсказки = ТекстПодсказкиПодписьИПечать(Форма);
	ЭлементФлагПодписьИПечать.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	ЭлементФлагПодписьИПечать.РасширеннаяПодсказка.УстановитьДействие("ОбработкаНавигационнойСсылки",
		 "Подключаемый_ОбработкаНавигационнойСсылки");
	
КонецПроцедуры

Функция ТекстПодсказкиПодписьИПечать(Форма)
	
	ОрганизацииОбъектов = Новый Массив;
	Для Каждого ОбъектПечати Из Форма.ОбъектыПечати Цикл
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ОбъектПечати.Значение, "Организация") Тогда
			Если ОрганизацииОбъектов.Найти(ОбъектПечати.Значение.Организация) = Неопределено Тогда
				ОрганизацииОбъектов.Добавить(ОбъектПечати.Значение.Организация);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ОрганизацииОбъектов.Количество() = 1 Тогда
		СтрокаЗаголовок = Новый ФорматированнаяСтрока(НСтр(
			"ru = 'Заполнить факсимиле подписей и печати можно в карточке'"));
		СтрокаСсылка =  Новый ФорматированнаяСтрока(НСтр("ru = 'организации'"), , , , "ФаксимилеОрганизации");
		ТекстПодсказки = Новый ФорматированнаяСтрока(СтрокаЗаголовок, " ", СтрокаСсылка, ".");
	Иначе
		ТекстПодсказки = НСтр("ru = 'Заполнить факсимиле подписей и печати можно в карточке организации.'");
	КонецЕсли;
	
	Возврат ТекстПодсказки;
	
КонецФункции

Функция ПолучитьПодписиТипа(ТипДанных)
	
	Результат = Новый Массив;
	
	РеквизитыОбъектаМетаданных = Метаданные.НайтиПоТипу(ТипДанных).Реквизиты;
	Для Каждого Реквизит Из РеквизитыОбъектаМетаданных Цикл
		Если Реквизит.Тип = Новый ОписаниеТипов("СправочникСсылка.Подписи") Тогда
			Результат.Добавить(Реквизит.Имя);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ЕстьРеквизитОрганизация(ТипДанных)
	
	Если ТипДанных = Тип("СправочникСсылка.Организации") Тогда
		Возврат Истина;
	КонецЕсли;
	
	МетаданныеОбъекта = Метаданные.НайтиПоТипу(ТипДанных);
	Возврат ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", МетаданныеОбъекта);
	
КонецФункции

Процедура ДополнитьПодписиФаксимилеПечати(Подписи, СсылкаНаОбъект)
	
	Если ТипЗнч(СсылкаНаОбъект) = Тип("СправочникСсылка.Организации") Тогда
		Организация = СсылкаНаОбъект;
	Иначе
		Организация = СсылкаНаОбъект.Организация;
	КонецЕсли;
	
	ФаксимилеПечати = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ФайлФаксимильнаяПечать");
	Если ЗначениеЗаполнено(ФаксимилеПечати) Тогда
		ДанныеКартинки = РаботаСФайлами.ДанныеФайла(ФаксимилеПечати);
		ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(ДанныеКартинки.СсылкаНаДвоичныеДанныеФайла);
		Если ДвоичныеДанныеКартинки <> Неопределено Тогда
			КартинкаФаксимилеПодписанта = Новый Картинка(ДвоичныеДанныеКартинки);
			Подписи.Вставить("ПечатьОрганизации", КартинкаФаксимилеПодписанта);
			Подписи.Вставить("ПечатьПредпринимателя", КартинкаФаксимилеПодписанта);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДополнитьШтрихкодамиСерий(ТаблицаСерий)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ТаблицаСерий.EPCGTIN,
	|	ТаблицаСерий.RFIDEPC,
	|	ТаблицаСерий.RFIDTID,
	|	ТаблицаСерий.RFIDUser,
	|	ТаблицаСерий.ГоденДо,
	|	ТаблицаСерий.ДатаПроизводства,
	|	ТаблицаСерий.ЗаполненRFIDTID,
	|	ТаблицаСерий.ИсходныйНомерСтроки,
	|	ТаблицаСерий.КлючСвязи,
	|	ТаблицаСерий.Количество,
	|	ТаблицаСерий.НовыйНомер,
	|	ТаблицаСерий.НомерГИСМ,
	|	ТаблицаСерий.НомерКИЗГИСМ,
	|	ТаблицаСерий.НомерСтроки,
	|	ТаблицаСерий.НужноЗаписатьМетку,
	|	ТаблицаСерий.Серия,
	|	ТаблицаСерий.СерияЧисло,
	|	ТаблицаСерий.СтатусРаботыRFID
	|ПОМЕСТИТЬ Серии
	|ИЗ
	|	&ТаблицаСерий КАК ТаблицаСерий
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Серии.EPCGTIN,
	|	Серии.RFIDEPC,
	|	Серии.RFIDTID,
	|	Серии.RFIDUser,
	|	Серии.ГоденДо,
	|	Серии.ДатаПроизводства,
	|	Серии.ЗаполненRFIDTID,
	|	Серии.ИсходныйНомерСтроки,
	|	Серии.КлючСвязи,
	|	Серии.Количество,
	|	Серии.НовыйНомер,
	|	Серии.НомерГИСМ,
	|	Серии.НомерКИЗГИСМ,
	|	Серии.НомерСтроки,
	|	Серии.НужноЗаписатьМетку,
	|	Серии.Серия,
	|	Серии.СерияЧисло,
	|	Серии.СтатусРаботыRFID,
	|	ШтрихкодыНоменклатуры.Штрихкод
	|ИЗ
	|	Серии КАК Серии
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|			ПО ШтрихкодыНоменклатуры.Номенклатура = СерииНоменклатуры.Владелец
	|			И ШтрихкодыНоменклатуры.Штрихкод = СерииНоменклатуры.Наименование
	|		ПО Серии.Серия = СерииНоменклатуры.Ссылка");
	Запрос.УстановитьПараметр("ТаблицаСерий", ТаблицаСерий);
	
	ТаблицаСерий = Запрос.Выполнить().Выгрузить();
	
КонецПроцедуры

