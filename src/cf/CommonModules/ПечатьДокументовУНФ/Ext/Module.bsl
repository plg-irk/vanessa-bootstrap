	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КорректировкаПоступления.Организация,
	|	КорректировкаПоступления.СтруктурнаяЕдиница,
	|	КорректировкаПоступления.СтруктурнаяЕдиница.РозничныйВидЦен
	|ИЗ
	|	Документ.КорректировкаПоступления КАК КорректировкаПоступления
	|ГДЕ
	|	КорректировкаПоступления.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОтчетОПереработке.Организация,
	|	ОтчетОПереработке.СтруктурнаяЕдиница,
	|	ОтчетОПереработке.СтруктурнаяЕдиница.РозничныйВидЦен
	|ИЗ
	|	Документ.ОтчетОПереработке КАК ОтчетОПереработке
	|ГДЕ
	|	ОтчетОПереработке.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПередачаТоваровМеждуОрганизациями.Организация,
	|	ПередачаТоваровМеждуОрганизациями.СтруктурнаяЕдиница,
	|	ПередачаТоваровМеждуОрганизациями.СтруктурнаяЕдиница.РозничныйВидЦен
	|ИЗ
	|	Документ.ПередачаТоваровМеждуОрганизациями КАК ПередачаТоваровМеждуОрганизациями
	|ГДЕ
	|	ПередачаТоваровМеждуОрганизациями.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПоступлениеТоваровУслуг.Организация,
	|	ПоступлениеТоваровУслуг.СтруктурнаяЕдиница,
	|	ПоступлениеТоваровУслуг.СтруктурнаяЕдиница.РозничныйВидЦен
	|ИЗ
	|	Документ.ПриходнаяНакладная КАК ПоступлениеТоваровУслуг
	|ГДЕ
	|	ПоступлениеТоваровУслуг.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасходнаяНакладная.Организация,
	|	РасходнаяНакладная.СтруктурнаяЕдиница,
	|	РасходнаяНакладная.СтруктурнаяЕдиница.РозничныйВидЦен
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказНаПроизводство.Организация,
	|	ЗаказНаПроизводство.СтруктурнаяЕдиница,
	|	ЗаказНаПроизводство.СтруктурнаяЕдиница.РозничныйВидЦен
	|ИЗ
	|	Документ.ЗаказНаПроизводство КАК ЗаказНаПроизводство
	|ГДЕ
	|	ЗаказНаПроизводство.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПеремещениеЗапасов.Организация,
	|	ПеремещениеЗапасов.СтруктурнаяЕдиницаПолучатель,
	|	ПеремещениеЗапасов.СтруктурнаяЕдиницаПолучатель.РозничныйВидЦен
	|ИЗ
	|	Документ.ПеремещениеЗапасов КАК ПеремещениеЗапасов
	|ГДЕ
	|	ПеремещениеЗапасов.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОприходованиеЗапасов.Организация,
	|	ОприходованиеЗапасов.СтруктурнаяЕдиница,
	|	ОприходованиеЗапасов.ВидЦен
	|ИЗ
	|	Документ.ОприходованиеЗапасов КАК ОприходованиеЗапасов
	|ГДЕ
	|	ОприходованиеЗапасов.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказПокупателя.Организация,
	|	ЗаказПокупателя.СтруктурнаяЕдиницаПродажи,
	|	ЗаказПокупателя.ВидЦен
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|ГДЕ
	|	ЗаказПокупателя.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СборкаЗапасов.Организация,
	|	СборкаЗапасов.СтруктурнаяЕдиницаПродукции,
	|	ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|ИЗ
	|	Документ.СборкаЗапасов КАК СборкаЗапасов
	|ГДЕ
	|	СборкаЗапасов.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка),
	|	ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка),
	|	УстановкаЦенНоменклатурыЗапасы.ВидЦены
	|ИЗ
	|	Документ.УстановкаЦенНоменклатуры.Запасы КАК УстановкаЦенНоменклатурыЗапасы
	|ГДЕ
	|	УстановкаЦенНоменклатурыЗапасы.Ссылка В(&МассивДокументов)");
	
	// АПК:96 -вкл
	
	ИсключитьНедоступнуюТаблицуИзТекстаЗапроса(Запрос, "ЗаказНаПроизводство");
	ИсключитьНедоступнуюТаблицуИзТекстаЗапроса(Запрос, "СборкаЗапасов");
	ИсключитьНедоступнуюТаблицуИзТекстаЗапроса(Запрос, "ПеремещениеЗапасов");
	ИсключитьНедоступнуюТаблицуИзТекстаЗапроса(Запрос, "ОприходованиеЗапасов");
	ИсключитьНедоступнуюТаблицуИзТекстаЗапроса(Запрос, "КомплектацияЗапасов");
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	ТаблицаРеквизитыДокументов	= МассивРезультатов[1].Выгрузить();
	МассивОрганизаций			= Обработки.ПечатьЭтикетокИЦенников.СвернутьТаблицуЗначенийПоРеквизиту(ТаблицаРеквизитыДокументов, "Организация").ВыгрузитьКолонку(0);
	МассивСкладов				= Обработки.ПечатьЭтикетокИЦенников.СвернутьТаблицуЗначенийПоРеквизиту(ТаблицаРеквизитыДокументов, "СтруктурнаяЕдиница").ВыгрузитьКолонку(0);
	МассивВидовЦен				= Обработки.ПечатьЭтикетокИЦенников.СвернутьТаблицуЗначенийПоРеквизиту(ТаблицаРеквизитыДокументов, "ВидЦен").ВыгрузитьКолонку(0);
	
	// Подготовка структуры действий для обработки печати этикеток и ценников
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьОрганизацию", ?(МассивОрганизаций.Количество() = 1,МассивОрганизаций[0],
		ПерсональныеНастройкиРУНФ.Прочитать("ОсновнаяОрганизация")));
	СтруктураДействий.Вставить("ЗаполнитьСклад", ?(МассивСкладов.Количество() = 1,МассивСкладов[0], МассивСкладов));
	СтруктураДействий.Вставить("ЗаполнитьВидЦен", ?(МассивВидовЦен.Количество() = 1,МассивВидовЦен[0],
		ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойВидЦенПродажи")));
	СтруктураДействий.Вставить("ПоказыватьКолонкуКоличествоВДокументе", Истина);
	СтруктураДействий.Вставить("УстановитьРежимПечатиИзДокумента");
	Если ЭтоЦенники Тогда
		
		СтруктураДействий.Вставить("УстановитьРежим", "ПечатьЦенников");
		СтруктураДействий.Вставить("ЗаполнитьКоличествоЦенниковПоДокументу");
		
	Иначе
		
		СтруктураДействий.Вставить("УстановитьРежим", "ПечатьЭтикеток");
		СтруктураДействий.Вставить("ЗаполнитьКоличествоЭтикетокПоДокументу");
		
	КонецЕсли;
	СтруктураДействий.Вставить("ЗаполнитьТаблицуТоваров");
	
	Если КомпоновщикНастроек <> Неопределено Тогда
		СтруктураДействий.Вставить("КомпоновщикНастроек", КомпоновщикНастроек);
	КонецЕсли;
	
	Если Не ВыключеноИспользованиеНовойПечатиЦенников() Тогда
		ТоварыДляПечати = Новый Массив();
		Товары = МассивРезультатов[0].Выгрузить();
		ТоварыДляПечати = ЗаполнитьТаблицуТоваров(Товары, СтруктураДействий);
	Иначе
		ТоварыДляПечати = МассивРезультатов[0].Выгрузить();
	КонецЕсли;
	
	// Подготовка данных для заполнения табличной части обработки печати этикеток и ценников
	СтруктураРезультат = Новый Структура;
	СтруктураРезультат.Вставить("Запасы", ТоварыДляПечати);
	СтруктураРезультат.Вставить("МассивДокументов", МассивДокументов);
	СтруктураРезультат.Вставить("СтруктураДействий", СтруктураДействий);
	
	Возврат ПоместитьВоВременноеХранилище(СтруктураРезультат);
	
КонецФункции // ПодготовитьСтруктуруДанныхПечатиЭтикетокИЦенниковИзДокументов()

// Возвращает список макетов для печати счетов-фактур, перечисленных через запятую.
// 
// Параметры:
//  СчетаФактуры - Массив из ДокументСсылка.СчетФактура, ДокументСсылка.СчетФактураПолученный - счета-фактуры
// 
// Возвращаемое значение:
//  Строка - список макетов для печати счетов-фактур, перечисленных через запятую.
Функция СписокМакетовСчетовФактур(СчетаФактуры) Экспорт
	
	УникальныеЗначения = Новый Соответствие;
	
	ВидыОперацийСчетовФактур = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СчетаФактуры, "ВидОперации");
	
	Для Каждого ТекущийСчетФактура Из СчетаФактуры Цикл
		Если ТипЗнч(ТекущийСчетФактура) = Тип("ДокументСсылка.СчетФактура") Тогда
			Если ВидыОперацийСчетовФактур[ТекущийСчетФактура] = Перечисления.ВидыОперацийСчетФактура.Корректировка Тогда
				УникальныеЗначения["СчетФактураКорректировочный"] = Истина;
			Иначе
				УникальныеЗначения["СчетФактура"] = Истина;
			КонецЕсли;
		Иначе
			Если ВидыОперацийСчетовФактур[ТекущийСчетФактура]
				= Перечисления.ВидыОперацийСчетФактураПолученный.Корректировка Тогда
				УникальныеЗначения["СчетФактураКорректировочный"] = Истина;
			Иначе
				УникальныеЗначения["СчетФактура"] = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	СписокМакетов = Новый Массив;
	Для Каждого КлючИЗначение Из УникальныеЗначения Цикл
		СписокМакетов.Добавить(КлючИЗначение.Ключ);
	КонецЦикла;
	
	Возврат СтрСоединить(СписокМакетов, ",");
	
КонецФункции

// Возвращает ссылку на Организацию, указанную в первом документе параметра команды.
//
// Параметры:
//  ПараметрКоманды	 - Массив Из ДокументСсылка - массив ссылок на документы для печати.
// 
// Возвращаемое значение:
//  СправочникСсылка.Организации - организация, для которой вызывается печатная форма.
//  В случае если печать вызывается для форм разных организаций - возвращается пустая ссылка.
Функция ОрганизацияИзПараметраКоманды(ПараметрКоманды) Экспорт
	
	Результат = Справочники.Организации.ПустаяСсылка();
	
	Если ТипЗнч(ПараметрКоманды) <> Тип("Массив") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПараметрКоманды) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого ТекПараметр Из ПараметрКоманды Цикл
		
		Если ТипЗнч(ПараметрКоманды[0]) <> ТипЗнч(ТекПараметр) Тогда
			Возврат Результат;
		КонецЕсли;
		
		Если Не ОбщегоНазначения.ЗначениеСсылочногоТипа(ТекПараметр) Тогда
			Возврат Результат;
		КонецЕсли;
		
		Если Не ОбщегоНазначения.ЕстьРеквизитОбъекта("Организация", ТекПараметр.Метаданные()) Тогда
			Возврат Результат;
		КонецЕсли;
		
	КонецЦикла;
	
	//@skip-check bsl-legacy-check-string-literal
	ЗначенияРеквизитаОбъектов = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ПараметрКоманды, "Организация");
	
	Для Каждого КлючИЗначение Из ЗначенияРеквизитаОбъектов Цикл
		Если Не ЗначениеЗаполнено(Результат) Тогда
			Результат = КлючИЗначение.Значение;
		КонецЕсли;
		Если Результат <> КлючИЗначение.Значение Тогда
			Возврат Справочники.Организации.ПустаяСсылка();
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Процедура обновляет цены в табличной части "Товары" объекта при изменении вида цены.
//
// Параметры:
//  ОбработкаОбъект - ОбработкаОбъект.ПечатьЭтикетокИЦенниковБПО - объект обработки, в которой нужно обновить цены.
//
Процедура ПриИзмененииВидаЦены(ОбработкаОбъект) Экспорт
	
	Запрос = Обработки.ПечатьЭтикетокИЦенников.НовыйЗапросЗаполнитьПоляТаблицы();
	ТоварыЗапроса = ОбработкаОбъект.Товары.Выгрузить(,"НоменклатураБПО, ХарактеристикаБПО, Партия, УпаковкаБПО");
	Колонка = ТоварыЗапроса.Колонки.Найти("НоменклатураБПО");
	Колонка.Имя = "Номенклатура";
	Колонка = ТоварыЗапроса.Колонки.Найти("ХарактеристикаБПО");
	Колонка.Имя = "Характеристика";
	
	Колонка = ТоварыЗапроса.Колонки.Найти("УпаковкаБПО");
	Колонка.Имя = "ЕдиницаИзмерения";
	
	Запрос.УстановитьПараметр("Товары",			ТоварыЗапроса);
	Запрос.УстановитьПараметр("НуженШтрихкод",	Ложь);
	Запрос.УстановитьПараметр("НуженОстаток",	Ложь);
	Запрос.УстановитьПараметр("НужныШаблоны",	Ложь);
	Запрос.УстановитьПараметр("НужнаЦена",		Истина);
	Запрос.УстановитьПараметр("Период",			ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ВидЦен",			ОбработкаОбъект.ВидЦены);
	Запрос.УстановитьПараметр("ИспользоватьНаборы", ПолучитьФункциональнуюОпцию("ИспользоватьНаборы"));
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТоварыСЦеной = РезультатЗапроса[4].Выгрузить();
	
	Для Каждого Товар Из ОбработкаОбъект.Товары Цикл
		
		РезультатПоиска = ТоварыСЦеной.НайтиСтроки(Новый Структура("Номенклатура, Характеристика",
			Товар.НоменклатураБПО, Товар.ХарактеристикаБПО));
		Если РезультатПоиска.Количество() > 0 Тогда
			Товар.Цена = РезультатПоиска[0].Цена;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры 

// Получает данные по штрихкодам.
//
// Параметры:
//  СтруктураДанные - Структура - структура данных, содержащая массив штрихкодов и организацию.
//  МассивШтрихкодов - Массив из Строка - штрихкоды, по которым необходимо получить данные.
//
// СтруктураДанные после выполнения процедуры будет содержать:
//  МассивШтрихкодов - Массив - штрихкоды, по которым были получены данные.
//  Организация - СправочникСсылка.Организации - основная организация пользователя.
//  ДанныеПоШтрихКодам - ТаблицаЗначений - таблица данных по штрихкодам.
//
Процедура ПолучитьДанныеПоШтрихКодам(СтруктураДанные, МассивШтрихкодов) Экспорт
	
	Организация = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнаяОрганизация");
	
	СтруктураДанные.Вставить("МассивШтрихкодов", МассивШтрихкодов);
	СтруктураДанные.Вставить("Организация", Организация);
	
	Для каждого ТекШтрихкод Из СтруктураДанные.МассивШтрихкодов Цикл
		
		РегистрыСведений.ШтрихкодыНоменклатуры.ПреобразоватьВесовойШтрихкод(ТекШтрихкод);
		
	КонецЦикла;
	
	ДанныеПоШтрихКодам = РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьДанныеПоШтрихкодамВМассиве(МассивШтрихкодов);
	
	СтруктураДанные.Вставить("ДанныеПоШтрихКодам", ДанныеПоШтрихКодам); 
	
КонецПроцедуры

// Обрабатывает подбор товаров по отбору для печати этикеток и ценников
//
// Параметры:
//  ПараметрыОперации - Структура - параметры операции подбора товаров, содержит компоновщик настроек и другие параметры
//  МассивТоваровДляПечати - Массив из см. ПечатьЭтикетокИЦенниковБПОКлиентСервер.ТоварДляПечати
//
Процедура ОбработкаПодбораТоваровПоОтборуДляПечатиЭтикетокИЦенниковЗавершение(ПараметрыОперации,
	МассивТоваровДляПечати) Экспорт
	
	ИспользоватьХарактеристикиНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики");
	ИспользоватьПартииНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьПартии");
	ИспользоватьСерииНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьСерииНоменклатуры");
	ИспользоватьЕдиницыИзмерения = ПолучитьФункциональнуюОпцию("УчетВРазличныхЕдиницахИзмерения");
	ИспользоватьSKU = ПолучитьФункциональнуюОпцию("ИспользоватьОбменСПодключаемымОборудованиемOffline");
	
	ЭлементыОтбора = ПараметрыОперации.КомпоновщикНастроек.Настройки.Отбор.Элементы;
	
	Для Каждого ЭлементОтбора Из ЭлементыОтбора Цикл
		
		Если ТипЗнч(ЭлементОтбора) <> Тип("ГруппаЭлементовОтбораКомпоновкиДанных")
			И ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СправочникСсылка.Организации") Тогда
			Организация = ЭлементОтбора.ПравоеЗначение;
		КонецЕсли;
		
	КонецЦикла;
	
	НастройкиПечати = Обработки.ПечатьЭтикетокИЦенников.НовыеНастройкиПечати();
	
	НастройкиПечати.ОбязательныеПоля.Добавить("Цена");
	НастройкиПечати.ОбязательныеПоля.Добавить("Весовой");
	НастройкиПечати.ОбязательныеПоля.Добавить("Штрихкод");
	НастройкиПечати.ОбязательныеПоля.Добавить("Количество");
	НастройкиПечати.ОбязательныеПоля.Добавить("Номенклатура");
	Если ИспользоватьSKU Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("SKU");
	КонецЕсли;
	Если ИспользоватьХарактеристикиНоменклатуры Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("Характеристика");
	КонецЕсли;
	Если ИспользоватьПартииНоменклатуры Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("Партия");
	КонецЕсли;
	Если ИспользоватьСерииНоменклатуры Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("Серия");
	КонецЕсли;
	Если ИспользоватьЕдиницыИзмерения Тогда
		НастройкиПечати.ОбязательныеПоля.Добавить("ЕдиницаИзмерения");
	КонецЕсли;
	НастройкиПечати.ОбязательныеПоля.Добавить("ОстатокНаСкладе");
	НастройкиПечати.ОбязательныеПоля.Добавить("Организация");
	
	НастройкиПечати.ОбязательныеПоля.Добавить("НоменклатураНаименованиеПолное");
	
	// Шаблоны этикеток и ценников.
	НастройкиПечати.ОбязательныеПоля.Добавить("Номенклатура.КатегорияНоменклатуры.ШаблонЭтикетки");
	НастройкиПечати.ОбязательныеПоля.Добавить("Номенклатура.КатегорияНоменклатуры.ШаблонЦенника");
	ПолеСКДШаблонЦенникаБПО = "Номенклатура.КатегорияНоменклатуры.ШаблонЦенникаБПО";
	НастройкиПечати.ОбязательныеПоля.Добавить(ПолеСКДШаблонЦенникаБПО);
	
	НастройкиПечати.ПараметрыДанных.Вставить("ВидЦен"              , ПараметрыОперации.ВидЦены);
	НастройкиПечати.ПараметрыДанных.Вставить("ВидЦенАкционный"     , ПараметрыОперации.ВидЦеныАкционный);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныПоВидуЦены"      , Ложь);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныНаДату"          , ПараметрыОперации.ЦеныНаДату);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныНаДатуАкционные" , ПараметрыОперации.ЦеныНаДату);
	
	НастройкиПечати.ПараметрыДанных.Вставить("ИспользоватьАссортимент", Ложь);
	
	НастройкиПечати.КомпоновщикНастроек = ПараметрыОперации.КомпоновщикНастроек;
	НастройкиПечати.ИмяМакетаСхемыКомпоновкиДанных = "ПоляШаблонаБД";
	
	// Загрузка сформированного списка товаров.
	ДанныеДляПечати = Обработки.ПечатьЭтикетокИЦенников.ПодготовитьДанныеДляПечати(НастройкиПечати);
	
	Для Каждого Товар Из ДанныеДляПечати.ТаблицаТоваров Цикл
		
		СтруктураТовара = ПечатьЭтикетокИЦенниковБПОКлиентСервер.ТоварДляПечати();
		Если ИспользоватьПартииНоменклатуры Тогда
			СтруктураТовара.Вставить("Партия", Товар.Партия);
		КонецЕсли;
		Если ИспользоватьСерииНоменклатуры Тогда
			СтруктураТовара.Вставить("Серия", Товар.Серия);
		КонецЕсли;
		Если ИспользоватьХарактеристикиНоменклатуры Тогда
			СтруктураТовара.ХарактеристикаБПО = Товар.Характеристика;
		КонецЕсли;
		Если ИспользоватьЕдиницыИзмерения Тогда
			СтруктураТовара.УпаковкаБПО       = Товар.ЕдиницаИзмерения;
		КонецЕсли;
		Если ИспользоватьSKU Тогда
			СтруктураТовара.Вставить("ШтрихАвтопроверки", СформироватьСобственныйШтрихкод(Товар));
		КонецЕсли;
		СтруктураТовара.НоменклатураБПО   = Товар.Номенклатура;
		СтруктураТовара.ОрганизацияБПО    = Организация;
		СтруктураТовара.Штрихкод = Товар.Штрихкод;
		СтруктураТовара.Цена = Товар.Цена;
		Если ПараметрыОперации.РежимПечати = "ПечатьЭтикеток" Тогда
			СтруктураТовара.Количество = Товар.ОстатокНаСкладе;
		Иначе
			СтруктураТовара.Количество = 1;
		КонецЕсли;
		КолонкаШаблон = ДанныеДляПечати.СоответствиеПолейСКДКолонкамТаблицыТоваров.Получить(ПолеСКДШаблонЦенникаБПО);
		СтруктураТовара.Вставить("ШаблонЦенникаЭтикетки", Товар[КолонкаШаблон]);
		
		МассивТоваровДляПечати.Добавить(СтруктураТовара);
		
	КонецЦикла;
	
КонецПроцедуры

// Обрабатывает результат подбора товаров для печати этикеток и ценников.
//
// Параметры:
//  Результат - Структура - результат подбора товаров.
//  ПараметрыОперации - Структура - параметры операции подбора товаров.
//  МассивТоваровДляПечати - Массив из см. ПечатьЭтикетокИЦенниковБПОКлиентСервер.ТоварДляПечати
//
Процедура ОбработкаПодбораТоваровДляПечатиЭтикетокИЦенниковЗавершение(Результат, ПараметрыОперации,
	МассивТоваровДляПечати) Экспорт
	
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
		
	АдресЗапасовВХранилище	= Результат.АдресКорзиныВХранилище;
	
	ЗаполняемыеПоля = Новый Структура;
	ЗаполняемыеПоля.Вставить("Цена");
	ЗаполняемыеПоля.Вставить("ОстатокНаСкладе");
	ЗаполняемыеПоля.Вставить("Шаблоны");
	ЗаполняемыеПоля.Вставить("Штрихкод");
	
	Если ПустаяСтрока(АдресЗапасовВХранилище) Тогда
		Возврат;
	КонецЕсли;
		
	ТаблицаДляЗагрузки = ПолучитьИзВременногоХранилища(АдресЗапасовВХранилище);
	
	Товары = Новый ТаблицаЗначений();
	Товары.Колонки.Добавить("Номенклатура",         Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Товары.Колонки.Добавить("Характеристика",       Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	Товары.Колонки.Добавить("Партия",               Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"));
	Товары.Колонки.Добавить("ЕдиницаИзмерения",     Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения"));
	
	Для Каждого Товар Из ТаблицаДляЗагрузки Цикл 
		НовыйТовар = Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НовыйТовар, Товар);
	КонецЦикла;
	
	Запрос = Обработки.ПечатьЭтикетокИЦенников.НовыйЗапросЗаполнитьПоляТаблицы();
	Запрос.УстановитьПараметр("Товары",			Товары);
	Запрос.УстановитьПараметр("НуженШтрихкод",	ЗаполняемыеПоля.Свойство("Штрихкод"));
	Запрос.УстановитьПараметр("НуженОстаток",	ЗаполняемыеПоля.Свойство("ОстатокНаСкладе"));
	Запрос.УстановитьПараметр("НужныШаблоны",	ЗаполняемыеПоля.Свойство("Шаблоны"));
	Запрос.УстановитьПараметр("НужнаЦена",		ЗаполняемыеПоля.Свойство("Цена"));
	Запрос.УстановитьПараметр("Период",			ПараметрыОперации.ЦеныНаДату);
	Запрос.УстановитьПараметр("ВидЦен",			ПараметрыОперации.ВидЦены);
	Запрос.УстановитьПараметр("ИспользоватьНаборы", ПолучитьФункциональнуюОпцию("ИспользоватьНаборы"));
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	          
	ТоварыСоШтрихкодом = РезультатЗапроса[2].Выгрузить();
	ТоварыСЦеной = РезультатЗапроса[4].Выгрузить();
	ТоварыСШаблонами = РезультатЗапроса[5].Выгрузить();
	
	Для Каждого Товар Из ТаблицаДляЗагрузки Цикл
		
		СтруктураТовара = ПечатьЭтикетокИЦенниковБПОКлиентСервер.ТоварДляПечати();
		СтруктураТовара.Вставить("Партия", Товар.Партия);
		СтруктураТовара.НоменклатураБПО   = Товар.Номенклатура;
		СтруктураТовара.ХарактеристикаБПО = Товар.Характеристика;
		СтруктураТовара.УпаковкаБПО       = Товар.ЕдиницаИзмерения;
		СтруктураТовара.ОрганизацияБПО    = Товар.СтруктурнаяЕдиница.Организация;
		РезультатПоиска = ТоварыСоШтрихкодом.НайтиСтроки(Новый Структура("Номенклатура, Характеристика, Партия",
			Товар.Номенклатура, Товар.Характеристика, Товар.Партия));
		Если РезультатПоиска.Количество() > 0 Тогда
			СтруктураТовара.Штрихкод = РезультатПоиска[0].Штрихкод;
			СтруктураТовара.Вставить("SKU", РезультатПоиска[0].SKU);
		КонецЕсли;
		
		РезультатПоиска = ТоварыСЦеной.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", Товар.Номенклатура,
			Товар.Характеристика));
		Если РезультатПоиска.Количество() > 0 Тогда
			СтруктураТовара.Цена = РезультатПоиска[0].Цена;
		Иначе
			СтруктураТовара.Цена = Товар.Цена;
		КонецЕсли;
		
		Если СтруктураТовара.Свойство("SKU") Тогда
			СтруктураТовара.Вставить("ШтрихАвтопроверки", СформироватьСобственныйШтрихкод(СтруктураТовара));
		КонецЕсли;
		
		СтруктураТовара.Количество = Товар.Количество;
		РезультатПоиска = ТоварыСШаблонами.НайтиСтроки(Новый Структура("Номенклатура", Товар.Номенклатура));
		Если РезультатПоиска.Количество() > 0 Тогда
			СтруктураТовара.Вставить("ШаблонЦенникаЭтикетки", РезультатПоиска[0].ШаблонЦенникаБПО);
		КонецЕсли;
		
		МассивТоваровДляПечати.Добавить(СтруктураТовара);
		
	КонецЦикла;
	
КонецПроцедуры 

// Завершает операцию заполнения данных по штрихкодам.
//
// Параметры:
//  ПараметрыОперации - Структура:
//   * МассивНоменклатуры - Массив из Структура - массив структур с данными номенклатуры, полученными по штрихкодам.
//   * ТекШтрихкод - Структура - структура с данными текущего штрихкода.
//  Параметры - Структура - содержит следующие ключи:
//   * СтруктураДанные - Структура - структура с дополнительными данными для заполнения.
//
Процедура ЗаполнитьПоДаннымШтрихкодовЗавершение(ПараметрыОперации, Параметры) Экспорт
	
	ДанныеШтрихкода = ПараметрыОперации.МассивНоменклатуры[0];
	ТекШтрихкод = ПараметрыОперации.ТекШтрихкод;
	
	ТаблицаТоваров = Новый ТаблицаЗначений;
	ТаблицаТоваров.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаТоваров.Колонки.Добавить("Характеристика",
		Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТаблицаТоваров.Колонки.Добавить("Партия", Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"));
	ТаблицаТоваров.Колонки.Добавить("ЕдиницаИзмерения", Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения"));
	ТаблицаТоваров.Колонки.Добавить("Штрихкод", Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(200)));
	
	Товар = ТаблицаТоваров.Добавить();
	Товар.ЕдиницаИзмерения = ДанныеШтрихкода.ЕдиницаИзмерения;
	Товар.Партия           = ДанныеШтрихкода.Партия;
	Товар.Характеристика   = ДанныеШтрихкода.Характеристика;
	Товар.Номенклатура     = ДанныеШтрихкода.Номенклатура;
	Товар.Штрихкод         = ТекШтрихкод.Штрихкод;
	Запрос = Обработки.ПечатьЭтикетокИЦенников.НовыйЗапросЗаполнитьПоляТаблицы();
	
	Запрос.УстановитьПараметр("Товары", ТаблицаТоваров.Скопировать( ,
		"Номенклатура, Характеристика, Партия, ЕдиницаИзмерения"));
	Запрос.УстановитьПараметр("НуженШтрихкод", Ложь);
	Запрос.УстановитьПараметр("НуженОстаток", Ложь);
	Запрос.УстановитьПараметр("НужныШаблоны", Истина);
	Запрос.УстановитьПараметр("НужнаЦена", Истина);
	Запрос.УстановитьПараметр("Период", Параметры.СтруктураДанные.Дата);
	Запрос.УстановитьПараметр("ВидЦен", Параметры.СтруктураДанные.ВидЦены);
	Запрос.УстановитьПараметр("ИспользоватьНаборы", ПолучитьФункциональнуюОпцию("ИспользоватьНаборы"));
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТоварыСЦеной = РезультатЗапроса[4].Выгрузить();
	ТоварыСШаблонами = РезультатЗапроса[5].Выгрузить();
	МассивТоваровДляПечати = Новый Массив;
	Для Каждого Товар Из ТаблицаТоваров Цикл
		
		СтруктураТовара = ПечатьЭтикетокИЦенниковБПОКлиентСервер.ТоварДляПечати();
		СтруктураТовара.Вставить("Партия", Товар.Партия);
		СтруктураТовара.НоменклатураБПО   = Товар.Номенклатура;
		СтруктураТовара.ХарактеристикаБПО = Товар.Характеристика;
		СтруктураТовара.УпаковкаБПО       = Товар.ЕдиницаИзмерения;
		СтруктураТовара.ОрганизацияБПО    = Параметры.СтруктураДанные.Организация;
		
		РезультатПоиска = ТоварыСЦеной.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", Товар.Номенклатура,
			Товар.Характеристика));
		Если РезультатПоиска.Количество() > 0 Тогда
			СтруктураТовара.Цена = РезультатПоиска[0].Цена;
		Иначе
			СтруктураТовара.Цена = Товар.Цена;
		КонецЕсли;
		
		СтруктураТовара.Штрихкод = Товар.Штрихкод;
		
		СтруктураТовара.Количество = 1;
		РезультатПоиска = ТоварыСШаблонами.НайтиСтроки(Новый Структура("Номенклатура", Товар.Номенклатура));
		Если РезультатПоиска.Количество() > 0 Тогда
			СтруктураТовара.Вставить("ШаблонЦенникаЭтикетки", РезультатПоиска[0].ШаблонЦенникаБПО);
		КонецЕсли;
		
		МассивТоваровДляПечати.Добавить(СтруктураТовара);
		
	КонецЦикла; 
	ПараметрыОперации.Вставить("МассивТоваровДляПечати", МассивТоваровДляПечати);
	
КонецПроцедуры

//  Процедура устанавливает начальные значения реквизитов формы, добавляет необходимые реквизиты и элементы управления,
//  а также заполняет табличную часть формы товарами из переданного параметра "АдресВХранилище".
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма, для которой выполняется инициализация.
//
Процедура ФормаПечатьЭтикетокИЦенниковПриСозданииНаСервере(Форма) Экспорт
	
	ПараметрыФормы = Форма.Параметры;
	
	Форма.Объект.ВидЦены = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойВидЦенПродажи");
	
	Форма.Элементы.ПечатьНаОбычномПринтере.ВидФлажка    = ВидФлажка.Флажок;
	Форма.Элементы.КаждаяЭтикеткаНаНовомЛисте.ВидФлажка = ВидФлажка.Флажок;
	
	Форма.Элементы.ТоварыУпаковкаБПО.Заголовок = НСтр("ru = 'Ед. изм.'");
	
	Если Не ЗначениеЗаполнено(Форма.Объект.ВидЦены) Тогда
		Форма.Объект.ВидЦены = ПредопределенноеЗначение("Справочник.ВидыЦен.Учетная");
	КонецЕсли;
	
	ДобавляемыеРеквизиты = Новый Массив;
	
	ДобавляемыйРеквизит = Новый РеквизитФормы("Партия", Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"),
		"Объект.Товары", "Партия");
	ДобавляемыеРеквизиты.Добавить(ДобавляемыйРеквизит);
	
	ДобавляемыйРеквизит = Новый РеквизитФормы("Серия", Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"),
		"Объект.Товары", "Серия");
	ДобавляемыеРеквизиты.Добавить(ДобавляемыйРеквизит);
	
	ДобавляемыйРеквизит = Новый РеквизитФормы("ШтрихАвтопроверки", Новый ОписаниеТипов("Строка"), "Объект.Товары",
		"ШтрихАвтопроверки");
	ДобавляемыеРеквизиты.Добавить(ДобавляемыйРеквизит);
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	НовыйЭлемент = Форма.Элементы.Добавить("КолонкаПартия", Тип("ПолеФормы"), Форма.Элементы.Товары); 
	НовыйЭлемент.ПутьКДанным = "Объект.Товары.Партия";
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.Доступность = Ложь;
	Форма.Элементы.Переместить(НовыйЭлемент, Форма.Элементы.Товары, Форма.Элементы.ТоварыУпаковкаБПО);
	
	НовыйЭлемент = Форма.Элементы.Добавить("КолонкаСерия", Тип("ПолеФормы"), Форма.Элементы.Товары); 
	НовыйЭлемент.ПутьКДанным = "Объект.Товары.Серия";
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.КнопкаВыпадающегоСписка = Ложь;
	НовыйЭлемент.БыстрыйВыбор = Истина;
	НовыйЭлемент.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
	НовыйЭлемент.РедактированиеТекста = Ложь;
	НовыйЭлемент.УстановитьДействие("НачалоВыбора", "НовыйЭлемент_НачалоВыбора");
	Форма.Элементы.Переместить(НовыйЭлемент, Форма.Элементы.Товары, Форма.Элементы.ТоварыУпаковкаБПО);
	
	НовыйЭлемент = Форма.Элементы.Добавить("КолонкаШтрихАвтопроверки", Тип("ПолеФормы"), Форма.Элементы.Товары); 
	НовыйЭлемент.ПутьКДанным = "Объект.Товары.ШтрихАвтопроверки";
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.Видимость = Ложь;
	
	Если ПараметрыФормы.Свойство("АдресВХранилище") И ЗначениеЗаполнено(ПараметрыФормы.АдресВХранилище) Тогда
		
		ПараметрыЗаполнения = ПолучитьИзВременногоХранилища(Форма.Параметры.АдресВХранилище);
		ТоварыФормы = Форма.Объект.Товары;
		
		Для Каждого Товар Из ПараметрыЗаполнения.Запасы Цикл
			НовыйТовар = ТоварыФормы.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйТовар, Товар);
		КонецЦикла;
		
		НовыйРеквизит = Новый РеквизитФормы("МассивДокументов", Новый ОписаниеТипов("СписокЗначений"));
		МассивДобавляыемыхРеквизитов = Новый Массив;
		МассивДобавляыемыхРеквизитов.Добавить(НовыйРеквизит);
		Форма.ИзменитьРеквизиты(МассивДобавляыемыхРеквизитов);
		Форма.МассивДокументов.ЗагрузитьЗначения(ПараметрыЗаполнения.МассивДокументов);
		
		НоваяКоманда = Форма.Команды.Добавить("Перезаполнить");
		НоваяКоманда.Действие = "Подключаемый_Перезаполнить";
		НоваяКоманда.Заголовок = НСтр("ru = 'Перезаполнить'");
		
		НовыйЭлемент = Форма.Элементы.Добавить("КомандаПерезаполнить", Тип("КнопкаФормы"), Форма.Элементы.ГруппаКоманднаяПанельТовары);
		НовыйЭлемент.ИмяКоманды = "Перезаполнить";
		
		Форма.Элементы.Переместить(НовыйЭлемент, Форма.Элементы.ГруппаКоманднаяПанельТовары, Форма.Элементы.ЗаполнитьПоОтбору);
		
		Форма.Элементы.ЗаполнитьПоОтбору.Видимость = Ложь;
		
		Форма.Заголовок = Форма.Заголовок + НСтр("ru = ' по объекту'");
		
		Форма.Элементы.КомпоновщикНастроекНастройкиОтбор.ИзменятьСоставСтрок = Ложь;
		Форма.Элементы.КомпоновщикНастроекНастройкиОтбор.КоманднаяПанель.Видимость = Ложь;
		
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Форма.Элементы, "НовыйШтрихкод", "Заголовок", НСтр("ru = 'Новый штрихкод EAN-13'"));
	
КонецПроцедуры

// Процедура инициализации списка выбора типа ценника или этикетки в форме шаблонов этикеток и ценников БПО.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма шаблонов этикеток и ценников БПО.
//
Процедура ФормаШаблоныЭтикетокИЦенниковБПОПриСозданииНаСервере(Форма) Экспорт
	Форма.Элементы.ТипЦенника.СписокВыбора.Вставить(0, "Ценник акционный");
	Форма.Элементы.ТипЦенника.СписокВыбора.Вставить(1, "Ценник");
	Форма.Элементы.ТипЦенника.СписокВыбора.Вставить(2, "Этикетка для обуви");
КонецПроцедуры

// Функция формирует данные для печатных форм этикеток и ценников.
//
// Параметры:
//  ПараметрыПечати - Структура - Параметры печати, содержащая свойства:
//    * Товары - Массив из Структура - Товары для печати.
//    * ВидЦены - СправочникСсылка.ВидыЦен - Вид цены для печати.
//    * ВидЦеныАкционный - СправочникСсылка.ВидыЦен - Акционный вид цены для печати.
//    * ЦеныНаДату - Дата - Дата, на которую необходимо получить цены.
//    * ТорговыйОбъект - СправочникСсылка.Организации - Торговый объект для печати.
//  ПоляДляЗаполнения - Соответствие из КлючИЗначение - Соответствие шаблонов и списков полей для заполнения.
//
// Возвращаемое значение:
//  Массив из Структура - данные для формирования печатных форм:
//    * Шаблон - СправочникСсылка.ШаблоныЭтикетокИЦенниковБПО - Шаблон этикетки или ценника.
//    * ТаблицаНоменклатуры - ТаблицаЗначений - Таблица товаров для печати.
Функция ДанныеДляФормированияПечатныхФорм(ПараметрыПечати, ПоляДляЗаполнения) Экспорт
	
	НастройкиПечати = Обработки.ПечатьЭтикетокИЦенников.НовыеНастройкиПечати();
	
	НастройкиПечати.ОбязательныеПоля.Добавить("КоличествоЦенниковДляПечати");
	НастройкиПечати.ОбязательныеПоля.Добавить("КоличествоЭтикетокДляПечати");
	НастройкиПечати.ОбязательныеПоля.Добавить("ШаблонЦенникаДляПечати");
	НастройкиПечати.ОбязательныеПоля.Добавить("ШаблонЭтикеткиДляПечати");
	НастройкиПечати.ОбязательныеПоля.Добавить("Номенклатура");
	
	ИсходныеДанные = Новый ТаблицаЗначений;
	ИсходныеДанные.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ИсходныеДанные.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ИсходныеДанные.Колонки.Добавить("КоличествоЦенников", Новый ОписаниеТипов("Число"));
	ИсходныеДанные.Колонки.Добавить("ШаблонЦенника", Новый ОписаниеТипов("СправочникСсылка.ШаблоныЭтикетокИЦенниковБПО"));
	ИсходныеДанные.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ИсходныеДанные.Колонки.Добавить("Партия", Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"));
	ИсходныеДанные.Колонки.Добавить("Серия", Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ИсходныеДанные.Колонки.Добавить("КоличествоЭтикеток", Новый ОписаниеТипов("Число"));
	ИсходныеДанные.Колонки.Добавить("ШаблонЭтикетки", Новый ОписаниеТипов("СправочникСсылка.ХранилищеШаблонов"));
	ИсходныеДанные.Колонки.Добавить("Штрихкод", Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(128)));
	ИсходныеДанные.Колонки.Добавить("ЕдиницаИзмерения", Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения"));
	ИсходныеДанные.Колонки.Добавить("ШтрихАвтопроверки", Новый ОписаниеТипов("Строка"));
	
	Для Каждого Товар Из ПараметрыПечати.Товары Цикл
		Если Товар.Выбран Тогда
			Строка = ИсходныеДанные.Добавить();
			Строка.Номенклатура = Товар.НоменклатураБПО;
			Строка.ШаблонЦенника = Товар.ШаблонЦенникаЭтикетки;
			Строка.КоличествоЦенников = Товар.Количество;
			Строка.Характеристика = Товар.ХарактеристикаБПО;
			Строка.ЕдиницаИзмерения = Товар.УпаковкаБПО;
			Строка.Организация = Товар.ОрганизацияБПО;
			Строка.Партия = Товар.Партия;
			Строка.Серия = Товар.Серия;
			Строка.Штрихкод = Товар.Штрихкод;
			Строка.ШтрихАвтопроверки = Товар.ШтрихАвтопроверки;
		КонецЕсли;
	КонецЦикла;
	
	НастройкиПечати.ИсходныеДанные = ИсходныеДанные;
	
	ВидЦены = ПараметрыПечати.ВидЦены;
	ВидЦеныАкционный = ПараметрыПечати.ВидЦеныАкционный;
	
	Если Не ЗначениеЗаполнено(ВидЦены) Тогда 
		ВидЦены = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойВидЦенПродажи");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ВидЦены) Тогда
		ВидЦены = ПредопределенноеЗначение("Справочник.ВидыЦен.Учетная");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПараметрыПечати.ТорговыйОбъект) Тогда
		Организация = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнаяОрганизация");
	Иначе
		Организация = ПараметрыПечати.ТорговыйОбъект;
	КонецЕсли;
	
	НастройкиПечати.ПараметрыДанных.Вставить("ВидЦен", ВидЦены);
	НастройкиПечати.ПараметрыДанных.Вставить("ВидЦенАкционный", ВидЦеныАкционный);
	НастройкиПечати.ПараметрыДанных.Вставить("Организация", Организация);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныПоВидуЦены", Ложь);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныНаДату", ПараметрыПечати.ЦеныНаДату);
	НастройкиПечати.ПараметрыДанных.Вставить("ЦеныНаДатуАкционные", ПараметрыПечати.ЦеныНаДату);
	
	ДанныеНоменклатурыДляФормированияПечатныхФорм = Новый Массив;
	Для Каждого Шаблон Из ПоляДляЗаполнения Цикл;
		ШаблонМакета = Шаблон.Ключ;
		СписокПолей = Шаблон.Значение;
		
		ДобавленныеПоля = Новый Массив;
		СтруктураШаблона = Новый Структура;
		СтруктураШаблона.Вставить("Шаблон", ШаблонМакета);
		СтруктураШаблона.Вставить("ИмяКолонкиШаблон", "ШаблонЦенника");
		Если Не ПустаяСтрока(ШаблонМакета.ТипЦенника) Тогда
			НастройкиПечати.ИмяМакетаСхемыКомпоновкиДанных = МакетСхемыКомпоновкиДанных(ШаблонМакета.ТипЦенника);
		Иначе
			НастройкиПечати.ИмяМакетаСхемыКомпоновкиДанных = "ПоляШаблона";
		КонецЕсли;
		// Заполняем коллекцию обязательных полей и формируем соответствие шаблонов.
		Для Каждого Поле Из СписокПолей Цикл
			Если Не ЗначениеЗаполнено(ДобавленныеПоля.Найти(Поле.Значение)) Тогда
				НастройкиПечати.ОбязательныеПоля.Добавить(Поле);
				ДобавленныеПоля.Добавить(Поле.Значение);
			КонецЕсли;
		КонецЦикла;
		
		ТаблицаДанных = Обработки.ПечатьЭтикетокИЦенников.ПодготовитьДанныеДляПечати(НастройкиПечати, СтруктураШаблона);
		КолонкаИзображений = ТаблицаДанных.ТаблицаТоваров.Колонки.Найти("НоменклатураФайлКартинки"); 
		КолонкаИзображенийХарактеристик = ТаблицаДанных.ТаблицаТоваров.Колонки.Найти("ХарактеристикаФайлКартинки");

		Если КолонкаИзображений <> Неопределено Тогда
			МассивФайлов = ТаблицаДанных.ТаблицаТоваров.ВыгрузитьКолонку("НоменклатураФайлКартинки");
			ЗаголовокКолонки = КолонкаИзображений.Заголовок;
			ТаблицаДанных.ТаблицаТоваров.Колонки.Удалить("НоменклатураФайлКартинки");
			ТаблицаДанных.ТаблицаТоваров.Колонки.Добавить("НоменклатураФайлКартинки", Новый ОписаниеТипов("Строка"), ЗаголовокКолонки);
			ИндексКартинки = 0;
			Для Каждого ФайлКартинки Из МассивФайлов Цикл
				Если ЗначениеЗаполнено(ФайлКартинки) Тогда
					ДанныеФайла = РаботаСФайлами.ДанныеФайла(ФайлКартинки);
					ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);
					СтрокаBase64 = Base64Строка(ДвоичныеДанныеКартинки);
					СтрокаBase64 = СтрЗаменить(СтрокаBase64, Символы.ПС, "");
					ТаблицаДанных.ТаблицаТоваров[ИндексКартинки].НоменклатураФайлКартинки = СтрокаBase64;
				Иначе
					ТаблицаДанных.ТаблицаТоваров[ИндексКартинки].НоменклатураФайлКартинки = "";
				КонецЕсли;
				ИндексКартинки = ИндексКартинки + 1;
			КонецЦикла;
		КонецЕсли;
		
		Если КолонкаИзображенийХарактеристик <> Неопределено Тогда
			МассивФайлов = ТаблицаДанных.ТаблицаТоваров.ВыгрузитьКолонку("ХарактеристикаФайлКартинки");
			ЗаголовокКолонки = КолонкаИзображенийХарактеристик.Заголовок;
			ТаблицаДанных.ТаблицаТоваров.Колонки.Удалить("ХарактеристикаФайлКартинки");
			ТаблицаДанных.ТаблицаТоваров.Колонки.Добавить("ХарактеристикаФайлКартинки", Новый ОписаниеТипов("Строка"), ЗаголовокКолонки);
			ИндексКартинки = 0;
			Для Каждого ФайлКартинки Из МассивФайлов Цикл
				Если ЗначениеЗаполнено(ФайлКартинки) Тогда
					ДанныеФайла = РаботаСФайлами.ДанныеФайла(ФайлКартинки);
					ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);
					СтрокаBase64 = Base64Строка(ДвоичныеДанныеКартинки);
					СтрокаBase64 = СтрЗаменить(СтрокаBase64, Символы.ПС, "");
					ТаблицаДанных.ТаблицаТоваров[ИндексКартинки].ХарактеристикаФайлКартинки = СтрокаBase64;
				Иначе
					ТаблицаДанных.ТаблицаТоваров[ИндексКартинки].ХарактеристикаФайлКартинки = "";
				КонецЕсли;
				ИндексКартинки = ИндексКартинки + 1;
			КонецЦикла;
		КонецЕсли;
		
		СтруктураДанных = Новый Структура;
		СтруктураДанных.Вставить("Шаблон", ШаблонМакета);
		СтруктураДанных.Вставить("ТаблицаНоменклатуры", ТаблицаДанных.ТаблицаТоваров);
		ДанныеНоменклатурыДляФормированияПечатныхФорм.Добавить(СтруктураДанных);
		
	КонецЦикла;
	
	Возврат ДанныеНоменклатурыДляФормированияПечатныхФорм;
	
КонецФункции

// Возвращает макет схемы компоновки данных для печати ценников или этикеток.
//
// Параметры:
//  ТипЦенника - Строка - тип ценника или этикетки. Может принимать значения "Ценник акционный",
//  "Этикетка для обуви" или пустую строку. Если параметр не указан или пустой, то возвращается макет по умолчанию.
//
// Возвращаемое значение:
//  СхемаКомпоновкиДанных - макет для печати ценников или этикеток.
//
Функция МакетСхемыКомпоновкиДанных(ТипЦенника = "") Экспорт
	
	Если ПустаяСтрока(ТипЦенника) Тогда
		Макет = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("ПоляШаблонаПоУмолчанию");
	ИначеЕсли ТипЦенника = "Ценник акционный" Тогда
		Макет = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("ПоляШаблонаЦенникАкционный");
	ИначеЕсли ТипЦенника = "Этикетка для обуви" Тогда
		Макет = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("ПоляШаблонаЦенникАкционный");
	Иначе
		Макет = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("ПоляШаблона");
	КонецЕсли;
	
	Возврат Макет;
	
КонецФункции

// Возвращает макет схемы компоновки данных для отбора в зависимости от параметров формы.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма, для которой необходимо получить макет схемы компоновки данных.
//
// Возвращаемое значение:
//  СхемаКомпоновкиДанных - макет схемы компоновки данных для отбора.
//  	Если в параметрах формы указан и заполнен "АдресВХранилище", то возвращается макет "ПоляШаблонаПоУмолчанию".
//  	Иначе возвращается макет "ПоляШаблонаБД" и устанавливается флаг "ПечатьПоОтбору" в форме.
//
Функция МакетСхемыКомпоновкиДанныхДляОтбора(Форма) Экспорт
	
	Если Форма.Параметры.Свойство("АдресВХранилище") И ЗначениеЗаполнено(Форма.Параметры.АдресВХранилище) Тогда
		Макет = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("ПоляШаблонаПоУмолчанию");
	Иначе
		Макет = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("ПоляШаблонаБД");
		Форма.ПечатьПоОтбору = Истина;
	КонецЕсли;
	
	Возврат Макет;
	
КонецФункции

// Определяет, выключено ли использование новой печати ценников.
//
// Параметры:
//  ТипЦенника - Строка - Тип ценника, не используется в данной функции.
//
// Возвращаемое значение:
//  Булево - Истина, если используется старая обработка печати ценников, иначе Ложь.
//
Функция ВыключеноИспользованиеНовойПечатиЦенников(ТипЦенника = "") Экспорт
	Возврат ПолучитьФункциональнуюОпцию("ИспользоватьСтаруюОбработкуПечатиЦенников");
КонецФункции

// Подбирает подходящий штрихкод номенклатуры из найденных штрихкодов
// 
// Параметры:
//  СтрокаТаблицы - СтрокаТаблицыЗначений, Структура - строка таблицы, в которой необходимо определить штрихкод
//  НайденныеСтрокиШтрихкоды - Массив из СтрокаТаблицыЗначений - штрихкоды, подходящие номенклатуре в строке таблицы
Процедура ПодобратьШтрихкодНоменклатуры(СтрокаТаблицы, НайденныеСтрокиШтрихкоды) Экспорт
	
	Если Не ЗначениеЗаполнено(НайденныеСтрокиШтрихкоды) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(СтрокаТаблицы) = Тип("Структура") И Не СтрокаТаблицы.Свойство("Штрихкод") Тогда
		СтрокаТаблицы.Вставить("Штрихкод", "");
	КонецЕсли;
	
	Если НайденныеСтрокиШтрихкоды.Количество() = 1 Тогда
		СтрокаТаблицы.Штрихкод = НайденныеСтрокиШтрихкоды[0].Штрихкод;
		Возврат;
	КонецЕсли;
	
	ПодходящийШтрихкод = "";
	Для Каждого НайденнаяСтрока Из НайденныеСтрокиШтрихкоды Цикл
		Если ЗначениеЗаполнено(СтрокаТаблицы.Штрихкод) И НайденнаяСтрока.Штрихкод = СтрокаТаблицы.Штрихкод Тогда
			Возврат;
		КонецЕсли;
		ПодходящийШтрихкод = НайденнаяСтрока.Штрихкод;
	КонецЦикла; 
	
	Если ЗначениеЗаполнено(ПодходящийШтрихкод) Тогда
		СтрокаТаблицы.Штрихкод = ПодходящийШтрихкод;
	КонецЕсли;

КонецПроцедуры

// Устанавливает штрихкоды для выделенных товаров в табличной части "Товары".
//
// Параметры:
//  ВыделенныеТовары - Массив из Число - Массив идентификаторов строк табличной части "Товары".
//  Товары - ТабличнаяЧасть - Табличная часть "Товары".
//  Штрихкоды - Соответствие из КлючИЗначение - Соответствие номеров строк и штрихкодов.
//
Процедура УстановитьШтрихкодыНоменклатуры(ВыделенныеТовары, Товары, Штрихкоды) Экспорт
	
	EAN = 13;
	
	НачатьТранзакцию();
	
	Попытка
		
		Блокировка = Новый БлокировкаДанных();
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ШтрихкодыНоменклатуры");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		Блокировка = Новый БлокировкаДанных();
		ЭлементБлокировки = Блокировка.Добавить("Справочник.Номенклатура");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		Блокировка.Заблокировать();
		
		ПрефиксШтучногоТовара = РегистрыСведений.ШтрихкодыНоменклатуры.ПрефиксШтучногоТовара();
		ПрефиксУзлаШтрихкода = РегистрыСведений.ШтрихкодыНоменклатуры.ПрефиксУзлаШтрихкода();
		
		КодШтучногоТовара = РегистрыСведений.ШтрихкодыНоменклатуры.ПоследнийКодШтучногоТовара(ПрефиксШтучногоТовара,
			ПрефиксУзлаШтрихкода, EAN);
		
		Для Каждого НомерСтроки Из ВыделенныеТовары Цикл
			
			СтрокаТЧ = Товары.НайтиПоИдентификатору(НомерСтроки);
			
			Если КодШтучногоТовара >= РегистрыСведений.ШтрихкодыНоменклатуры.МаксимальныйКодШтучногоТовара(EAN) Тогда
				ВызватьИсключение РегистрыСведений.ШтрихкодыНоменклатуры.ТекстСообщенияНетСвободныхКодовШтучныхШтрихкодов();
			КонецЕсли;

			КодШтучногоТовара = КодШтучногоТовара + 1;

			Штрихкод = РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьШтрихкодПоКоду(КодШтучногоТовара,
				ПрефиксШтучногоТовара, ПрефиксУзлаШтрихкода, EAN);

			НовыйШтрихкод = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьМенеджерЗаписи();
			НовыйШтрихкод.Номенклатура = СтрокаТЧ.НоменклатураБПО;
			Если ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики") Тогда
				НовыйШтрихкод.Характеристика = СтрокаТЧ.ХарактеристикаБПО;
			КонецЕсли;
			Если ПолучитьФункциональнуюОпцию("ИспользоватьПартии") Тогда
				НовыйШтрихкод.Партия = СтрокаТЧ.Партия;
			КонецЕсли;
			Если ПолучитьФункциональнуюОпцию("УчетВРазличныхЕдиницахИзмерения") Тогда
				НовыйШтрихкод.ЕдиницаИзмерения = СтрокаТЧ.УпаковкаБПО;
			КонецЕсли;
			НовыйШтрихкод.Штрихкод = Штрихкод;
			НовыйШтрихкод.Записать();
			
			НоменклатураОбъект = НовыйШтрихкод.Номенклатура.ПолучитьОбъект();
			НоменклатураОбъект.Штрихкод = НовыйШтрихкод.Штрихкод;
			НоменклатураОбъект.Записать();
			
			Штрихкоды.Вставить(НомерСтроки, НовыйШтрихкод.Штрихкод);
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ТекстСообщенияПользователю = СтрШаблон(
		НСтр(
		"ru = 'При записи штрихкодов произошла ошибка.
		|Запись штрихкодов не выполнена.
		|Дополнительное описание:
		|%1'"),
		ИнформацияОбОшибке().Описание);
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщенияПользователю);
		
	КонецПопытки;
	
КонецПроцедуры

// Перезаполняет данные для печати этикеток или ценников с учетом отбора.
//
// Параметры:
//  МассивДокументов - Массив из ДокументСсылка - Массив документов, для которых необходимо перезаполнить данные.
//  РежимПечати - Строка - Режим печати: "ПечатьЭтикеток" или "ПечатьЦенников".
//  Компоновщик - КомпоновщикНастроекКомпоновкиДанных - Компоновщик настроек для отбора данных.
//
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица значений с колонками "Номенклатура", "Характеристика", "Упаковка", "Количество", "Цена".
Функция ПерезаполнитьСУчетомОтбора(МассивДокументов, РежимПечати, Компоновщик) Экспорт
	
	АдресВХранилище = ПодготовитьСтруктуруДанныхПечатиЭтикетокИЦенниковИзДокументов(
		МассивДокументов,
		РежимПечати = "ПечатьЦенников",
		Компоновщик);
	
	ТоварыДляПечати = ПолучитьИзВременногоХранилища(АдресВХранилище).Запасы;
	
	Возврат ТоварыДляПечати;
	
КонецФункции

// Формирует строку-представление веса и объема для печатных форм УПД
//  
// Параметры:
//	ЗначениеДляПечати - Число - значение веса или объема
//  ЭтоВес - Булево
// Возвращаемое значение:
//  Строка
//
Функция ИнформацияОГрузеПрописью(ЗначениеДляПечати, ЭтоВес) Экспорт

	Если Не ЗначениеЗаполнено(ЗначениеДляПечати) Тогда

		Возврат "";

	КонецЕсли;

	Если ЭтоВес Тогда
		СтрокаЕдиницыИзмерения = НСтр("ru = 'килограмм,килограмма,килограммов,м,грамм,грамма,граммов,м,3'");
		Возврат НРег(ЧислоПрописью(ЗначениеДляПечати, "ДП=Истина",
			СтрокаЕдиницыИзмерения));
	Иначе

		Возврат Формат(ЗначениеДляПечати, "ЧГ=0") + НСтр("ru = ' м³'");

	КонецЕсли;

КонецФункции

// См. УправлениеПечатьюПереопределяемый.ПриОпределенииНастроекПечати
Процедура ПриОпределенииНастроекПечати(Настройки) Экспорт
	
	Настройки.ИспользоватьПодписиИПечати = Истина;
	Настройки.СкрыватьПодписиИПечатиДляРедактирования = Истина;
	
КонецПроцедуры

// Определяет набор подписей и печатей для документов.
//
// Параметры:
//  Документы      - Массив Из ЛюбаяСсылка   - коллекция ссылок на объекты печати;
//  ПодписиИПечати - Соответствие из КлючИЗначение - коллекция объектов печати и комплектов подписей/печатей к ним:
//   * Ключ     - ЛюбаяСсылка - ссылка на объект печати;
//   * Значение - Структура   - комплект подписей и печатей:
//     ** Ключ     - Строка - идентификатор подписи или печати в макете печатной формы, 
//                            должен начинаться с "Подпись...", "Печать..." или "Факсимиле...",
//                            например, "ПодписьРуководителя", "ПечатьОрганизации";
//     ** Значение - Картинка - изображение подписи или печати.
//
Процедура ПриПолученииПодписейИПечатей(Документы, ПодписиИПечати) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОбъектыПоТипам = Новый Соответствие;
	Для Каждого Документ Из Документы Цикл // Разбираем объекты по типам
		ТипДокумента = ТипЗнч(Документ);
		Если ОбъектыПоТипам[ТипДокумента] = Неопределено Тогда
			ОбъектыПоТипам[ТипДокумента] = Новый Массив;
		КонецЕсли;
		КоллекцияДокументов = ОбъектыПоТипам[ТипДокумента];
		КоллекцияДокументов.Добавить(Документ); 
	КонецЦикла;
	
	Для Каждого ОбъектыПоТипу Из ОбъектыПоТипам Цикл // по объектам каждого типа получаем подписи
		ТипОбъекта = ОбъектыПоТипу.Ключ;
		СписокОбъектов = ОбъектыПоТипу.Значение;
		
		ПодписиТипа = ПолучитьПодписиТипа(ТипОбъекта);
		ЕстьОрганизация = ЕстьРеквизитОрганизация(ТипОбъекта); 
		Для Каждого ОбъектСписка Из СписокОбъектов Цикл
			ПодписиОбъекта = Новый Структура;
			Для Каждого ПодписьТипа Из ПодписиТипа Цикл
				ЗначениеПодписи = ОбъектСписка[ПодписьТипа];
				Если ЗначениеЗаполнено(ЗначениеПодписи) Тогда
					ПрисоединенныйФайл = ЗначениеПодписи.Факсимиле;
					ИмяПодписи = ПодписьТипа;
					Если ЗначениеЗаполнено(ПрисоединенныйФайл) Тогда
						ДанныеКартинки = РаботаСФайлами.ДанныеФайла(ПрисоединенныйФайл);
						ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(ДанныеКартинки.СсылкаНаДвоичныеДанныеФайла);
						Если ДвоичныеДанныеКартинки <> Неопределено Тогда
							КартинкаФаксимилеПодписанта = Новый Картинка(ДвоичныеДанныеКартинки);
							ПодписиОбъекта.Вставить(ИмяПодписи, КартинкаФаксимилеПодписанта);
							Если ИмяПодписи = "ПодписьРуководителя" Тогда
								ПодписиОбъекта.Вставить("ПодписьПредпринимателя", КартинкаФаксимилеПодписанта);
								ПодписиОбъекта.Вставить("ПодписьПБОЮЛ", КартинкаФаксимилеПодписанта);
								ПодписиОбъекта.Вставить("ПодписьОтветственногоЗаОформление", КартинкаФаксимилеПодписанта);
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			Если ЕстьОрганизация Тогда
				ДополнитьПодписиФаксимилеПечати(ПодписиОбъекта, ОбъектСписка);
			КонецЕсли;
			// Название картинки в макетах может быть как "Подпись...", так и "Факсимиле..."
			Для Каждого Подпись Из ПодписиОбъекта Цикл
				Если СтрНайти(Подпись.Ключ, "Подпись") <> 0 Тогда
					ИмяФаксимиле = СтрЗаменить(Подпись.Ключ, "Подпись", "Факсимиле");
					ПодписиОбъекта.Вставить(ИмяФаксимиле, Подпись.Значение);
				КонецЕсли;
			КонецЦикла;
			
			ПодписиИПечати.Вставить(ОбъектСписка, ПодписиОбъекта);
			
		КонецЦикла;
		
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Определяет наличие реквизитов подписей и организации у типа данных
// 
// Параметры:
//  ТипДанных - Тип
//  
// Возвращаемое значение:
//  Булево
//
Функция ЕстьРеквизитыПодписиИПечать(ТипДанных) Экспорт
	
	ПодписиТипа = ПолучитьПодписиТипа(ТипДанных);
	ЕстьОрганизация = ЕстьРеквизитОрганизация(ТипДанных);
	
	Если ПодписиТипа.Количество() > 0 И ЕстьОрганизация Тогда
		Результат = Истина;
	Иначе
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

// Вызывается из обработчика ПриСозданииНаСервере формы печати документов (ОбщаяФорма.ПечатьДокументов).
// Позволяет изменить внешний вид и поведение формы, например, разместить на ней дополнительные элементы:
// информационные надписи, кнопки, гиперссылки, различные настройки и т.п.
// 
// Параметры:
//  Форма                - ФормаКлиентскогоПриложения - форма ОбщаяФорма.ПечатьДокументов.
//  Отказ                - Булево - признак отказа от создания формы. Если установить
//                                  данному параметру значение Истина, то форма создана не будет.
//  СтандартнаяОбработка - Булево - в данный параметр передается признак выполнения стандартной (системной) обработки
//                                  события. Если установить данному параметру значение Ложь, 
//                                  стандартная обработка события производиться не будет.
//
Процедура ПечатьДокументовПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка) Экспорт
	
	НастроитьФормуПечатьДокументов(Форма);
	ОформитьФлажокПодписиИПечати(Форма);
	
КонецПроцедуры

// Добавляет на форму группу элементов с подсказкой о новой схеме печати факсимиле.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма объекта
//  МладшийЭлемент - Строка - имя элемента формы, над которым вставляем группу
//
Процедура ДобавитьИнформациюПоНовомуФаксимиле(Форма, МладшийЭлемент = "Шапка") Экспорт
	
	Контекст = Форма.Объект;
	ИмяКлючаОбъекта = "Информирование/НовоеВВерсии";
	ИмяНастройки = "ПоказыватьИнформациюОНовомФаксимиле";
	ПоказыватьИнформациюОНовомФаксимиле = ХранилищеСистемныхНастроек.Загрузить(ИмяКлючаОбъекта, ИмяНастройки);
	
	Если ПоказыватьИнформациюОНовомФаксимиле = Неопределено Тогда
		ПоказыватьИнформациюОНовомФаксимиле = Истина;
	КонецЕсли;
	
	Если Не ПоказыватьИнформациюОНовомФаксимиле Тогда
		Возврат;
	КонецЕсли;
	
	КонтекстОрганизация = Контекст.Организация; // СправочникСсылка.Организации
	ФаксимилеПечати = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КонтекстОрганизация, "ФайлФаксимильнаяПечать");
	ЕстьЗаполненныеРеквизитыПодписи =  ЗначениеЗаполнено(ФаксимилеПечати);
	
	Если Не ЕстьЗаполненныеРеквизитыПодписи Тогда
		ТипДанных = ТипЗнч(Контекст.Ссылка);
		РеквизитыПодписей = ПолучитьПодписиТипа(ТипДанных);
		Для Каждого РеквизитПодписи Из РеквизитыПодписей Цикл
			Если ЗначениеЗаполнено(Контекст[РеквизитПодписи]) Тогда
				ЕстьЗаполненныеРеквизитыПодписи = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЕстьЗаполненныеРеквизитыПодписи Тогда
		Возврат;
	КонецЕсли;
	
	// Группа
	ЭлементШапка = Форма.Элементы.Найти(МладшийЭлемент);
	Группа = Форма.Элементы.Вставить("ГруппаИнформацияНовоеФаксимиле", Тип("ГруппаФормы"), , ЭлементШапка);
	Группа.Вид                      = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.ОтображатьЗаголовок      = Ложь;
	Группа.Отображение              = ОтображениеОбычнойГруппы.Нет;
	Группа.ЦветФона                 = ЦветаСтиля.ЦветФонаПодсказки;
	Группа.РастягиватьПоГоризонтали = Истина;
	
	// Надпись
	Элемент = Форма.Элементы.Вставить("ДекорацияИнформацияНовоеФаксимиле", Тип("ДекорацияФормы"), Группа);
	Элемент.АвтоМаксимальнаяШирина = Ложь;
	СтрокаЗаголовок = Новый ФорматированнаяСтрока(НСтр(
		"ru = 'Новое в версии: для печати документа с факсимиле сформируйте печатную форму без факсимиле и в открывшемся окне установите флажок ""Подпись и печать"".'"));
	Элемент.Заголовок = СтрокаЗаголовок;
	Элемент.РастягиватьПоГоризонтали = Истина;
	
	// Кнопка
	Элемент = Форма.Элементы.Вставить("ДекорацияИнформацияНовоеФаксимилеЗакрыть", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид = ВидДекорацииФормы.Картинка;
	Элемент.Картинка = БиблиотекаКартинок.ОчиститьЗначение;
	Элемент.Гиперссылка = Истина;
	Элемент.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
	Элемент.УстановитьДействие("Нажатие", "Подключаемый_НажатиеДекорацияИнформацияНовоеФаксимилеЗакрыть");
	
КонецПроцедуры

// Выключает в формах документов вывод уведомлений о новом факсимиле
// Параметры:
//  ИмяПользователя - Строка
//
Процедура ВыключитьИнформированиеНовоеФаксимиле(ИмяПользователя = "") Экспорт
	
	ИмяКлючаОбъекта = "Информирование/НовоеВВерсии";
	ИмяНастройки = "ПоказыватьИнформациюОНовомФаксимиле";
	ЗначениеНастройки = Ложь;
	
	Если ПустаяСтрока(ИмяПользователя) Тогда
		ХранилищеСистемныхНастроек.Сохранить(ИмяКлючаОбъекта, ИмяНастройки, ЗначениеНастройки);
	Иначе
		УстановитьПривилегированныйРежим(Истина);
		ХранилищеСистемныхНастроек.Сохранить(ИмяКлючаОбъекта, ИмяНастройки, ЗначениеНастройки, , ИмяПользователя);
	КонецЕсли;
	
КонецПроцедуры

// Формирует текст сообщения пользователю об измененном макете.
// 
// Параметры:
//  ИмяПечатнойФормы - Строка
//  
// Возвращаемое значение:
//  Строка
//
Функция ТекстСообщенияМакетИзменен(ИмяПечатнойФормы) Экспорт
	
	ШаблонСообщения = НСтр(
		"ru = 'Изменился типовой макет печатной формы %1. Для корректной
		|работы печатной формы необходимо обновить отредактированный ранее макет. 
		|Это можно выполнить самостоятельно в разделе ""Настройки - Администрирование - Печатные формы,
		|отчеты, обработки - Макеты печатных форм"" или обратиться к специалисту обслуживающей организации.'");
	
	ТекстСообщения = СтрШаблон(ШаблонСообщения, ИмяПечатнойФормы);
	
	Возврат ТекстСообщения;
	
КонецФункции

// Записывает настройку пользователя по заполнению факсимиле в печатных формах
//
// Параметры:
//  ЗначениеНастройки  - Булево
//  ИменаМакетов - Строка - Имена макетов, для которых сохраняется настройка
//
Процедура ЗаписатьНастройкуПользователяЗаполнятьФаксимиле(ЗначениеНастройки, ИменаМакетов = "") Экспорт
	
	ИмяКлючаОбъекта = "НастройкиПользователя/Печать";
	ИмяНастройки = "ЗаполнятьФаксимиле_" + ИменаМакетов;
	ЗначениеНастройки = ЗначениеНастройки;
	
	ХранилищеСистемныхНастроек.Сохранить(ИмяКлючаОбъекта, ИмяНастройки, ЗначениеНастройки);
	
КонецПроцедуры

// Возвращает настройку пользователя по заполнению факсимиле в печатных формах
// 
// Параметры:
//   ИменаМакетов - Строка - Имена макетов, для которых необходимо получить настройку
// 
// Возвращаемое значение:
//   Булево
//
Функция НастройкаПользователяЗаполнятьФаксимиле(ИменаМакетов = "") Экспорт
	
	ИмяКлючаОбъекта = "НастройкиПользователя/Печать";
	ИмяНастройки = "ЗаполнятьФаксимиле_" + ИменаМакетов;
	ЗначениеНастройки = ХранилищеСистемныхНастроек.Загрузить(ИмяКлючаОбъекта, ИмяНастройки);
	Если ЗначениеНастройки = Неопределено Тогда
		ЗначениеНастройки = Ложь;
	КонецЕсли;
	
	Возврат ЗначениеНастройки;
	
КонецФункции

// Вызывается из обработчика ПриЗагрузкеДанныхИзНастроекНаСервере формы печати документов (ОбщаяФорма.ПечатьДокументов).
// Совместно с ПечатьДокументовПриСохраненииДанныхВНастройкахНаСервере позволяет реализовать загрузку и сохранение 
// настроек элементов управления, размещенных с помощью ПечатьДокументовПриСозданииНаСервере.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма ОбщаяФорма.ПечатьДокументов.
//  Настройки - Соответствие из КлючИЗначение - значения реквизитов формы.
//
Процедура ПечатьДокументовПриЗагрузкеДанныхИзНастроекНаСервере(Форма, Настройки) Экспорт
	
	Если Не Настройки["ПодписьИПечать"] = Неопределено Тогда
		ИменаМакетов = Форма.ИменаМакетов;
		ПодписьИПечать = НастройкаПользователяЗаполнятьФаксимиле(ИменаМакетов);
		Настройки["ПодписьИПечать"] = ПодписьИПечать;
		Форма.ПодписьИПечать = ПодписьИПечать;
	КонецЕсли;
	
КонецПроцедуры

// Вызывается из обработчика ПриСохраненииДанныхВНастройкахНаСервере формы печати документов (ОбщаяФорма.ПечатьДокументов).
// Совместно с ПечатьДокументовПриЗагрузкеДанныхИзНастроекНаСервере позволяет реализовать загрузку и сохранение 
// настроек элементов управления, размещенных с помощью ПечатьДокументовПриСозданииНаСервере.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма ОбщаяФорма.ПечатьДокументов.
//  Настройки - Соответствие из КлючИЗначение- значения реквизитов формы.
//
Процедура ПечатьДокументовПриСохраненииДанныхВНастройкахНаСервере(Форма, Настройки) Экспорт
	
	Если Не Настройки["ПодписьИПечать"] = Неопределено Тогда
		ЗначениеНастройки = Настройки["ПодписьИПечать"];
		ИменаМакетов = Форма.ИменаМакетов;
		Если ЗначениеНастройки = Неопределено Тогда
			ЗначениеНастройки = Ложь;
		КонецЕсли;
		ЗаписатьНастройкуПользователяЗаполнятьФаксимиле(ЗначениеНастройки, ИменаМакетов);
	КонецЕсли;
	
КонецПроцедуры

#Область ПечатьПоУмолчанию

// Вызывается из обработчика ПриСозданииНаСервере формы документа.
// Позволяет настроить кнопку печати по умолчанию, исходя из настроек пользователя
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - форма документа.
//
Процедура ПечатьПоУмолчаниюПриСозданииНаСервере(Форма) Экспорт

	СведенияОКомандахПечати = Форма.СведенияОКомандахПечати;
	СведенияОКомандахПечати.Очистить();
	Для Каждого Команда Из Форма.Команды Цикл
		СведенияОКомандахПечати.Добавить(Команда.Имя, Команда.Заголовок);
	КонецЦикла;

	СведенияОПечатныхФормахПоУмолчанию = Форма.СведенияОПечатныхФормахПоУмолчанию;
	ЗаполнитьСписокЭлементовРекурсивно(Форма, СведенияОПечатныхФормахПоУмолчанию, Форма.Элементы.ПодменюПечать);

	ГруппаПечатьПоУмолчанию = Форма.Элементы.ПодменюПечатьПоУмолчанию;
	Форма.Элементы.Переместить(ГруппаПечатьПоУмолчанию, ГруппаПечатьПоУмолчанию.Родитель);
	
	СтруктураНастроек = РегистрыСведений.НастройкиПечатныхФормПоУмолчанию.НастройкиПользователя(
		Пользователи.ТекущийПользователь(),
		Форма.ИмяФормы);
	Если СтруктураНастроек = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Форма.СведенияОПечатныхФормах = СтруктураНастроек.ПечатныеФормы;

	ИмяПечатнойФормыПоУмолчанию = СтруктураНастроек.ПечатнаяФормаПоУмолчанию;
	Если ИмяПечатнойФормыПоУмолчанию <> Неопределено Тогда
		Команда = Форма.Команды.Найти(ИмяПечатнойФормыПоУмолчанию);
	КонецЕсли;
	
	ПечатьДокументовУНФКлиентСервер.ОбновитьСостояниеКомандПечатиПоУмолчанию(Форма);
	
КонецПроцедуры

// Сокращает полное имя формы до имени объекта.
//
// Параметры:
//  ПолноеИмяФормы - Строка - Полное имя формы.
//
// Возвращаемое значение:
//  Строка - Сокращенное имя формы.
Функция СократитьПолноеИмяФормы(ПолноеИмяФормы) Экспорт
	КомпонентыИмениФормы = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ПолноеИмяФормы, ".");
	Если СтрНайти(КомпонентыИмениФормы[3], "ЗаказНаряд") <> 0 Тогда
		КомпонентыИмениФормы[1] = "ЗаказНаряд";
	КонецЕсли;
	СокращенноеИмяФормы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтрокуИзМассива("%1.%2",
		КомпонентыИмениФормы);
	Возврат СокращенноеИмяФормы;
КонецФункции

#КонецОбласти 

#КонецОбласти  

#Область СлужебныйПрограммныйИнтерфейс

Процедура ОбновитьСКДШаблоновЭтикеток(Параметры) Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ШаблоныЭтикетокИЦенниковБПО.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ШаблоныЭтикетокИЦенниковБПО КАК ШаблоныЭтикетокИЦенниковБПО
	|ГДЕ
	|	НЕ ШаблоныЭтикетокИЦенниковБПО.Предопределенный");
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Параметры.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ШаблонОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		Попытка
			ШаблонОбъект.Заблокировать();
			СхемаКомпоновкиДанных = МакетСхемыКомпоновкиДанных(ШаблонОбъект.ТипЦенника);
			ШаблонОбъект.СхемаКомпоновкиДанных = Новый ХранилищеЗначения(СхемаКомпоновкиДанных);
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ШаблонОбъект);
		Исключение
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ПодробноеПредставлениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			КодЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
			Событие = НСтр("ru = 'Ошибка выполнения обработчика обновления СКД в шаблонах этикеток и ценников'",
				КодЯзыка);
			ЗаписьЖурналаРегистрации(
				Событие, УровеньЖурналаРегистрации.Ошибка,, ШаблонОбъект, ПодробноеПредставлениеОшибки);
			Параметры.ОбработкаЗавершена = Ложь;
			Возврат;
		КонецПопытки;
		
		Параметры.ОбработкаЗавершена = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПодборСерий(Параметр, Товары) Экспорт
	
	ТаблицаСерий = ПолучитьИзВременногоХранилища(Параметр.АдресВоВременномХранилище);
	Если ТаблицаСерий.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	ДополнитьШтрихкодамиСерий(ТаблицаСерий);
	
	НайденныеСтроки = Товары.НайтиСтроки(Новый Структура("НомерСтроки", Параметр.КлючСтроки));
	Если Не НайденныеСтроки.Количество() Тогда
		Возврат Неопределено;
	КонецЕсли;
	ВыбраннаяСтрока = НайденныеСтроки[0];
	Для Каждого СтрокаСерии Из ТаблицаСерий Цикл
		Если ЗначениеЗаполнено(ВыбраннаяСтрока.Серия) Тогда
			СтруктураОтбора = Новый Структура();
			СтруктураОтбора.Вставить("НоменклатураБПО", ВыбраннаяСтрока.НоменклатураБПО);
			СтруктураОтбора.Вставить("ХарактеристикаБПО", ВыбраннаяСтрока.ХарактеристикаБПО);
			СтруктураОтбора.Вставить("УпаковкаБПО", ВыбраннаяСтрока.УпаковкаБПО);
			СтруктураОтбора.Вставить("Партия", ВыбраннаяСтрока.Партия);
			СтруктураОтбора.Вставить("Серия", СтрокаСерии.Серия);
			СтрокиСерии = Товары.НайтиСтроки(СтруктураОтбора);
			Если СтрокиСерии.Количество() Тогда
				СтрокиСерии[0].Количество = СтрокиСерии[0].Количество + СтрокаСерии.Количество; 
			Иначе
				НоваяСтрока = Товары.Вставить(Параметр.КлючСтроки);
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыбраннаяСтрока);
				НоваяСтрока.Серия = СтрокаСерии.Серия;
				НоваяСтрока.Количество = СтрокаСерии.Количество;
				Если ЗначениеЗаполнено(СтрокаСерии.Штрихкод) Тогда
					НоваяСтрока.Штрихкод = СтрокаСерии.Штрихкод;
				КонецЕсли;
			КонецЕсли;
		Иначе
			ВыбраннаяСтрока.Серия = СтрокаСерии.Серия;
			ВыбраннаяСтрока.Количество = СтрокаСерии.Количество;
			Если ЗначениеЗаполнено(СтрокаСерии.Штрихкод) Тогда
				ВыбраннаяСтрока.Штрихкод = СтрокаСерии.Штрихкод;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Товары;
	
КонецФункции

Процедура ДополнитьКолонкиТаблицыЗначенийТоваров(СтандартнаяОбработка, ТаблицаЗначенийТоваров) Экспорт
	
	ТаблицаЗначенийТоваров.Колонки.Добавить("Партия", Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"));
	ТаблицаЗначенийТоваров.Колонки.Добавить("Серия", Новый ОписаниеТипов("СправочникСсылка.СерииНоменклатуры"));
	ТаблицаЗначенийТоваров.Колонки.Добавить("Штрихавтопроверки", Новый ОписаниеТипов("Строка"));
	
КонецПроцедуры

