#Область ПрограммныйИнтерфейс

// Функция-конструктор описания дополнительных данных строки
// 
// Возвращаемое значение:
//  Структура - дополнительные настройки строки отчета:
//  * Картинка - Строка - имя картинки из БиблиотекиКартинок, которая должна быть выведена в первую колонку отчета.
//  * ПримечаниеКартинки - Строка - произвольное примечание для картинки.
//
Функция НовыйНастройкиСтроки() Экспорт

	Результат = Новый Структура;
	
	Результат.Вставить("Картинка",           "");
	Результат.Вставить("ПримечаниеКартинки", "");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти