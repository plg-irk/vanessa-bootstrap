Процедура СформироватьПервоначальныйКонтрольПродаж() Экспорт
	
	ГУИДКонтрольПродажЗапретОплатыБонусами = Новый УникальныйИдентификатор("db74ecfe-14f4-4dc8-96dd-874c74a41b3d");
	ГУИДКонтрольПродажПроверкаВозраста18 = Новый УникальныйИдентификатор("e5286376-1454-4613-8e78-a2b74266920a");
	
	СтруктураСлужебныхПалитр = ОбщегоНазначенияРМК.ПодготовитьСлужебныеПалитрыДляКонтроляПродаж();
	
	ВидКонтроляЗапретОплатыБонусами = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтроля.ЗапретОплатыБонусами");
	Если ВидКонтроляЗапретОплатыБонусами = Неопределено
			Или Не ЗначениеЗаполнено(ВидКонтроляЗапретОплатыБонусами.ТипКонтроля) Тогда
		ОбщегоНазначенияРМК.ЗаполнитьВидКонтроляЗапретОплатыБонусами(ВидКонтроляЗапретОплатыБонусами);
		Константы.ИспользоватьКонтрольПродаж.Установить(Истина);
	КонецЕсли;
	
	КонтрольПродажЗапретОплатыБонусами
		= Справочники.КонтрольПродаж.ПолучитьСсылку(ГУИДКонтрольПродажЗапретОплатыБонусами);
	Если Не (ОбщегоНазначения.СсылкаСуществует(КонтрольПродажЗапретОплатыБонусами)
			Или СтруктураСлужебныхПалитр.ПалитраЗапретаОплатыБонусами = Неопределено) Тогда
		ОбщегоНазначенияРМК.ЗаполнитьКонтрольПродажЗапретОплатыБонусами(КонтрольПродажЗапретОплатыБонусами,
			СтруктураСлужебныхПалитр);
	КонецЕсли;
	
	КонтрольПродажПроверкаВозраста18 = Справочники.КонтрольПродаж.ПолучитьСсылку(ГУИДКонтрольПродажПроверкаВозраста18);
	Если Не (ОбщегоНазначения.СсылкаСуществует(КонтрольПродажПроверкаВозраста18)
			Или СтруктураСлужебныхПалитр.ПалитраПроверкиВозраста = Неопределено) Тогда
		ОбщегоНазначенияРМК.ЗаполнитьКонтрольПродажПроверкаВозраста18(КонтрольПродажПроверкаВозраста18,
			СтруктураСлужебныхПалитр);
	КонецЕсли;
	
	Если ОбщегоНазначенияРМК.ИспользоватьЗапретыПродаж() Тогда
		ОбщегоНазначенияРМК.СоздатьКонтрольПродажПоДаннымРегистраЗапретовПродаж();
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьВложенныеПалитрыНастроек() Экспорт
	
	ЗапросНастроекСПалитрами = Новый Запрос;
	ЗапросНастроекСПалитрами.Текст =
	"ВЫБРАТЬ
	|	НастройкиРабочегоМестаКассира.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.НастройкиРабочегоМестаКассира КАК НастройкиРабочегоМестаКассира
	|ГДЕ
	|	НЕ(НастройкиРабочегоМестаКассира.СтруктураПлиточногоИнтерфейсаПодбора = ЗНАЧЕНИЕ(Справочник.ПалитраТоваровРМК.ПустаяСсылка)
	|				И НастройкиРабочегоМестаКассира.СтруктураБыстрыхТоваров = ЗНАЧЕНИЕ(Справочник.ПалитраТоваровРМК.ПустаяСсылка))
	|	И НЕ НастройкиРабочегоМестаКассира.ПометкаУдаления";
	
	РезультатЗапроса = ЗапросНастроекСПалитрами.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			НастройкаОбъект = Выборка.Ссылка.ПолучитьОбъект();
			АктуализироватьСписокПалитр(НастройкаОбъект, "СтруктураПлиточногоИнтерфейсаПодбора", "ПалитрыПлиточныйИнтерфейс");
			АктуализироватьСписокПалитр(НастройкаОбъект, "СтруктураБыстрыхТоваров", "ПалитрыИзбранное");
			НастройкаОбъект.ОбменДанными.Загрузка = Истина;
			НастройкаОбъект.Записать();
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура АктуализироватьСписокПалитр(НастройкаОбъект, ИмяРеквизита, ИмяТабличнойЧасти)
	
	НастройкаОбъект[ИмяТабличнойЧасти].Очистить();
	Если ЗначениеЗаполнено(НастройкаОбъект[ИмяРеквизита]) Тогда
		ИсходныйМассив = Новый Массив;
		ИсходныйМассив.Добавить(НастройкаОбъект[ИмяРеквизита]);
		ПодчиненныеПалитры = ИнтерфейсРМКСлужебный.ПолучитьВложенныеПалитры(ИсходныйМассив);
		ПалитрыПризнакСлужебная = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ПодчиненныеПалитры, "Служебная");
		НоваяСтрока = НастройкаОбъект[ИмяТабличнойЧасти].Добавить();
		НоваяСтрока.Палитра = НастройкаОбъект[ИмяРеквизита];
		Для Каждого ПалитраСПризнаком Из ПалитрыПризнакСлужебная Цикл
			Если Не ПалитраСПризнаком.Значение Тогда
				НоваяСтрока = НастройкаОбъект[ИмяТабличнойЧасти].Добавить();
				НоваяСтрока.Палитра = ПалитраСПризнаком.Ключ;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Функция НеобходимоОбновитьПалитру(ПалитраСсылка, ЦветаПалитры)
	
	РезультатФункции = Ложь;
	
	Если СокрЛП(ПалитраСсылка.ЦветФонаКнопки) = "" Или СокрЛП(ПалитраСсылка.ЦветФонаПапки) = "" Тогда
		РезультатФункции = Истина;
	Иначе
		КоличествоСтрок = ПалитраСсылка.Состав.Количество();
		ИндексСтроки = 0;
		Пока ИндексСтроки < КоличествоСтрок И Не РезультатФункции Цикл
			СтрокаСостава = ПалитраСсылка.Состав.Получить(ИндексСтроки);
			Если ЗначениеЗаполнено(СтрокаСостава.Номенклатура)
				И СтрокаСостава.ЦветФона = ЦветаПалитры.ЦветФонаКнопкиУстаревшийСтрокой Тогда
				
				РезультатФункции = Истина;
				
			КонецЕсли;
			ИндексСтроки = ИндексСтроки + 1;
		КонецЦикла;
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Процедура ОбновитьЦветаПалитрыЗначениямиПоУмолчанию(ПалитраСсылка, ЦветаПалитры)
	
	НачатьТранзакцию();
	Попытка
		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("Справочник.ПалитраТоваровРМК");
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ПалитраСсылка);
		Блокировка.Заблокировать();
		
		ПалитраОбъект = ПалитраСсылка.ПолучитьОбъект();
		
		Если СокрЛП(ПалитраОбъект.ЦветФонаКнопки) = "" Тогда
			ПалитраОбъект.ЦветФонаКнопки = ЦветаПалитры.ЦветФонаКнопкиСтрокой;
		КонецЕсли;
		Если СокрЛП(ПалитраОбъект.ЦветФонаПапки) = "" Тогда
			ПалитраОбъект.ЦветФонаПапки = ЦветаПалитры.ЦветФонаПапкиСтрокой;
		КонецЕсли;
		Для Каждого СтрокаСостава Из ПалитраОбъект.Состав Цикл
			
			Если ЗначениеЗаполнено(СтрокаСостава.Номенклатура)
				И СтрокаСостава.ЦветФона = ЦветаПалитры.ЦветФонаКнопкиУстаревшийСтрокой Тогда
				
				СтрокаСостава.ЦветФона = ЦветаПалитры.ЦветФонаКнопкиСтрокой;
				
			КонецЕсли;
			
		КонецЦикла;
		
		ПалитраОбъект.ОбменДанными.Загрузка = Истина;
		ПалитраОбъект.Записать();
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		КодОсновногоЯзыка = ОбщегоНазначения.КодОсновногоЯзыка();
		ТекстСообщения = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ИмяСобытия = НСтр("ru = 'Ошибка при обновлении палитры РМК'", КодОсновногоЯзыка);
		ЗаписьЖурналаРегистрации(ИмяСобытия,
			УровеньЖурналаРегистрации.Ошибка,
			ПалитраСсылка,
			,
			ТекстСообщения);
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнитьЦветаПалитрыПоУмолчанию() Экспорт
	
	ЦветаПалитры = Новый Структура();
	
	ЦветФонаКнопкиСтрокой = ОбщегоНазначения.ЗначениеВСтрокуXML(ЦветаСтиля.ЦветФонаСтаканаРМК);
	ЦветФонаПапкиСтрокой = ОбщегоНазначения.ЗначениеВСтрокуXML(ЦветаСтиля.ЦветПапкиКнопкиРМК);
	ЦветФонаКнопкиУстаревшийСтрокой = ОбщегоНазначения.ЗначениеВСтрокуXML(ЦветаСтиля.ЦветАктивнойКнопкиРМК);
	
	ЦветаПалитры.Вставить("ЦветФонаКнопкиСтрокой", ЦветФонаКнопкиСтрокой);
	ЦветаПалитры.Вставить("ЦветФонаПапкиСтрокой", ЦветФонаПапкиСтрокой);
	ЦветаПалитры.Вставить("ЦветФонаКнопкиУстаревшийСтрокой", ЦветФонаКнопкиУстаревшийСтрокой);
	
	ЗапросПалитр = Новый Запрос;
	ЗапросПалитр.Текст =
	"ВЫБРАТЬ
	|	ПалитраТоваровРМК.Ссылка КАК Палитра
	|ИЗ
	|	Справочник.ПалитраТоваровРМК КАК ПалитраТоваровРМК";
	
	РезультатЗапроса = ЗапросПалитр.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаПалитр = РезультатЗапроса.Выбрать();
		Пока ВыборкаПалитр.Следующий() Цикл
			
			ПалитраСсылка = ВыборкаПалитр.Палитра;
			Если НеобходимоОбновитьПалитру(ПалитраСсылка, ЦветаПалитры) Тогда
				
				ОбновитьЦветаПалитрыЗначениямиПоУмолчанию(ПалитраСсылка, ЦветаПалитры);
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
