#Область СлужебныеПроцедурыИФункции

Функция ДлительностьХраненияЗаписейДнейПоУмолчанию() Экспорт
	Возврат 3;
КонецФункции

Функция ДлительностьХраненияЗаписейДнейМаксимальная() Экспорт
	Возврат 7;
КонецФункции

Функция ДлительностьОтключенияЛогаДнейПоУмолчанию() Экспорт
	Возврат 1;
КонецФункции

Функция ДлительностьОтключенияЛогаДнейМаксимальная() Экспорт
	Возврат 7;
КонецФункции

Функция КоличествоСекундВСутках() Экспорт
  Возврат 86400;
КонецФункции

Функция ПлановаяДатаОтключенияЛогаПоУмолчанию() Экспорт

	#Если Сервер Тогда
		Дата = ТекущаяДатаСеанса();
	#Иначе
		Дата = ТекущаяДата();
	#КонецЕсли
	
	Результат = ДатаДобавитьДни( Дата, ДлительностьОтключенияЛогаДнейПоУмолчанию() );
	
	Возврат Результат;
	
КонецФункции

Функция ПлановаяДатаОтключенияЛогаМаксимальная() Экспорт

	#Если Сервер Тогда
		Дата = ТекущаяДатаСеанса();
	#Иначе
		Дата = ТекущаяДата();
	#КонецЕсли
	
	Результат = ДатаДобавитьДни( Дата, ДлительностьОтключенияЛогаДнейМаксимальная() );
	
	Возврат Результат;
	
КонецФункции

Функция ДатаДобавитьДни( ПараметрДата, КоличествоДней ) Экспорт

	Если ТипЗнч( ПараметрДата ) <> Тип( "Дата" ) Тогда
		ТекстОшибкиШаблон = НСтр( "ru = 'В функцию ДатаДобавитьДни передан некорректный тип параметра ПараметрДата: %1'" );
		ТекстОшибки = СтрШаблон( ТекстОшибкиШаблон, ТипЗнч( ПараметрДата ) );
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;

	Если ТипЗнч( КоличествоДней ) <> Тип( "Число" ) Тогда
		ТекстОшибкиШаблон = НСтр( "ru = 'В функцию ДатаДобавитьДни передан некорректный тип параметра КоличествоДней: %1'" );
		ТекстОшибки = СтрШаблон( ТекстОшибкиШаблон, ТипЗнч( КоличествоДней ) );
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	Результат = ПараметрДата + КоличествоДней*КоличествоСекундВСутках();
	
	Возврат Результат;
КонецФункции

#КонецОбласти