
#Область ПрограммныйИнтерфейс

// Создает актуальные элементы и команды для установки состояний на форме списка документов
//
// Параметры:
//	Форма - ФормаКлиентскогоПриложения
//	Родитель - ГруппаФормы
//
Процедура ЗаполнитьКомандыИзмененияСостояний(Форма, Родитель) Экспорт
	
	УдаляемыеЭлементы = Новый Массив;

	Для каждого ЭлементСостояния Из Родитель.ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ЭлементСостояния);
	КонецЦикла;

	Для каждого ЭлементСостояния Из УдаляемыеЭлементы Цикл
		Форма.Элементы.Удалить(ЭлементСостояния);
	КонецЦикла;

	Форма.ДоступныеСостояния.Очистить();
	
	ДоступныеСостоянияСобытий = ДоступныеСостояния(Ложь);
	
	Для каждого СостояниеСобытий Из ДоступныеСостоянияСобытий Цикл
		
		ЗаполнитьЗначенияСвойств(Форма.ДоступныеСостояния.Добавить(), СостояниеСобытий);
		
		НазваниеКоманды = СтрШаблон("Состояние_%1", Формат(СостояниеСобытий.Номер, "ЧН=0; ЧГ="));
		
		Если Форма.Команды.Найти(НазваниеКоманды) <> Неопределено Тогда
			КомандаУстановитьСостояние = Форма.Команды[НазваниеКоманды];
		Иначе
			КомандаУстановитьСостояние = Форма.Команды.Добавить(НазваниеКоманды);
		КонецЕсли;
			
		КомандаУстановитьСостояние.Действие = "Подключаемый_ИзменитьСостояние";
		КомандаУстановитьСостояние.Заголовок = СостояниеСобытий.Наименование;
		
		ИмяКнопки = СтрШаблон("%1%2", Родитель.Имя, НазваниеКоманды);
		КнопкаУстановитьСостояние = Форма.Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"), Родитель);
			
		КнопкаУстановитьСостояние.Заголовок = СостояниеСобытий.Наименование;
		КнопкаУстановитьСостояние.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВДополнительномПодменю;
		КнопкаУстановитьСостояние.ИмяКоманды = КомандаУстановитьСостояние.Имя;

	КонецЦикла;
                	
КонецПроцедуры

// Создает актуальные элементы и команды для установки состояний документа ЗаказНаряд на форме списка документов
//
// Параметры:
//	Форма - ФормаКлиентскогоПриложения
//	Родитель - ГруппаФормы
//
Процедура ЗаполнитьКомандыИзмененияСостоянийЗаказНарядов(Форма, Родитель) Экспорт
	
	УдаляемыеЭлементы = Новый Массив;

	Для каждого ЭлементСостояния Из Родитель.ПодчиненныеЭлементы Цикл
		УдаляемыеЭлементы.Добавить(ЭлементСостояния);
	КонецЦикла;

	Для каждого ЭлементСостояния Из УдаляемыеЭлементы Цикл
		Форма.Элементы.Удалить(ЭлементСостояния);
	КонецЦикла;

	Форма.ДоступныеСостояния.Очистить();
	
	ДоступныеСостоянияСобытий = ДоступныеСостояния(Ложь);
	
	Для каждого СостояниеСобытий Из ДоступныеСостоянияСобытий Цикл
		
		ЗаполнитьЗначенияСвойств(Форма.ДоступныеСостояния.Добавить(), СостояниеСобытий);
		
		НазваниеКоманды = "СостояниеЗаказНаряда_" + Формат(СостояниеСобытий.Номер, "ЧН=0; ЧГ=");
		
		Если Форма.Команды.Найти(НазваниеКоманды) <> Неопределено Тогда
			КомандаУстановитьСостояние = Форма.Команды[НазваниеКоманды];
		Иначе
			КомандаУстановитьСостояние = Форма.Команды.Добавить(НазваниеКоманды);
		КонецЕсли;
			
		КомандаУстановитьСостояние.Действие = "ИзменитьСостояниеЗаказНаряда";
		КомандаУстановитьСостояние.Заголовок = СостояниеСобытий.Наименование;
		
		ТипКнопкиФормы = Тип("КнопкаФормы"); 
		КнопкаУстановитьСостояние = Форма.Элементы.Добавить(НазваниеКоманды, ТипКнопкиФормы, Родитель);
			
		КнопкаУстановитьСостояние.Заголовок = СостояниеСобытий.Наименование;
		КнопкаУстановитьСостояние.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВДополнительномПодменю;
		КнопкаУстановитьСостояние.ИмяКоманды = КомандаУстановитьСостояние.Имя;

	КонецЦикла;
                	
КонецПроцедуры

// Выполняет установку состояния для объекта
//
// Параметры:
//	Состояние - СправочникСсылка.СостоянияСобытий
//	МассивОбъектов - Массив из ДокументСсылка
//	КоличествоИзмененныхОбъектов - Число - Количество измененных объектов
//  ОбработанныеТипыОбъектов - Массив из Тип - Обработанные типы объектов. 
//  Если параметр равен Неопределено, то не заполняется
//
Процедура УстановитьСостояние(Состояние, МассивОбъектов, КоличествоИзмененныхОбъектов,
	ОбработанныеТипыОбъектов = Неопределено) Экспорт
	
	// В массиве объектов могут быть документы разных типов, разделим по типам для различной обработки
	
	ДанныеОбработки = Новый Соответствие;	
	ТипыОбъектов = Новый Массив;
	
	ДопустимыеТипыОбъектов = СостоянияДокументовКлиентСервер.ДопустимыеТипыДокументовИзмененияСостояния();	
	
	Для Каждого Объект Из МассивОбъектов Цикл

		ТипОбъекта = ТипЗнч(Объект);
		
		ОбработкаТипаОбъектаРазрешена = ДопустимыеТипыОбъектов.Найти(ТипОбъекта) <> Неопределено;
		
		Если Не ОбработкаТипаОбъектаРазрешена Тогда
			ТекстСообщения = нСтр("ru='Изменение состояния для данного типа документа недопустимо: %1'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, Строка(Объект));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);				
			Продолжить;
		КонецЕсли;
			
		Если ТипыОбъектов.Найти(ТипОбъекта) = Неопределено Тогда
			ТипыОбъектов.Добавить(ТипОбъекта);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ТипОбъекта Из ТипыОбъектов Цикл

		ОбъектыТипа = Новый Массив;
		
		Для Каждого Объект Из МассивОбъектов Цикл
			Если ТипЗнч(Объект) = ТипОбъекта Тогда
				ОбъектыТипа.Добавить(Объект);
			КонецЕсли;
		КонецЦикла;
						
		ОбработчикИзмененияСостояния = ПолучитьОбработчикИзмененияСостояния(ТипОбъекта);
		
		ДанныеОбработки.Вставить(ОбработчикИзмененияСостояния, ОбъектыТипа);
		
		Если ОбработанныеТипыОбъектов <> Неопределено Тогда
			ОбработанныеТипыОбъектов.Добавить(ТипОбъекта);	
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ДанныеОбработкиТипа Из ДанныеОбработки Цикл
		
		ИзмененныеДокументы = Новый Массив;
		
		МенеджерДокумента = ДанныеОбработкиТипа.Ключ;
		МенеджерДокумента.УстановитьСостояние(Состояние, МассивОбъектов, ИзмененныеДокументы);
		
		КоличествоИзмененныхОбъектов = КоличествоИзмененныхОбъектов + ИзмененныеДокументы.Количество();
		
		АссистентУправления.ВыполнитьТекущиеЗадачиСейчасВФоне(ИзмененныеДокументы);
		
	КонецЦикла;
	
КонецПроцедуры

// Выполняет установку состояния для объекта
//
// Параметры:
//	МассивОбъектов - Массив из ДокументСсылка.ЗадачаСотрудника
//	КоличествоИзмененныхОбъектов - Число - Количество измененных объектов
//
Процедура УстановитьОтметкуВыполненияЗадачи(МассивОбъектов, КоличествоИзмененныхОбъектов) Экспорт
	
	ДопустимыеТипыОбъектов = СостоянияДокументовКлиентСервер.ДопустимыеТипыДокументовИзмененияРеквизитаВыполнена();
	
	ОбрабатываемыеДокументы = Новый Массив; 
	
	ТипЗадачаСотрудника = Тип("ДокументСсылка.ЗадачаСотрудника");
	МенеджерДокумента = ПолучитьОбработчикИзмененияСостояния(ТипЗадачаСотрудника);
	Для Каждого Объект Из МассивОбъектов Цикл		
		
		ТипОбъекта = ТипЗнч(Объект);
		ОбработкаТипаОбъектаРазрешена = ДопустимыеТипыОбъектов.Найти(ТипОбъекта) <> Неопределено;
		
		Если Не ОбработкаТипаОбъектаРазрешена Тогда
			ТекстСообщения = нСтр("ru='Установка отметки выполнения для данного типа документа недопустима: %1'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, Строка(Объект));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);				
			Продолжить;
		КонецЕсли;

		ОбрабатываемыеДокументы.Добавить(Объект);

	КонецЦикла;

	ИзмененныеДокументы = Новый Массив;
	
	МенеджерДокумента.ЗавершитьЗадачу(МассивОбъектов, ИзмененныеДокументы);	
	
	КоличествоИзмененныхОбъектов = ИзмененныеДокументы.Количество();
	
	АссистентУправления.ВыполнитьТекущиеЗадачиСейчасВФоне(ИзмененныеДокументы);
	
КонецПроцедуры

// Возвращает отсортированный по реквизиту РеквизитДопУпорядочивания список состояний без пометки удаления
// 
// Возвращаемое значение:
//  СписокЗначений - СписокЗначений
Функция СписокДоступныхСостояний() Экспорт
	
	СписокСостояний = Новый СписокЗначений;
	                   
	ДоступныеСостоянияДокумента = ДоступныеСостояния(Ложь);	
	
	Для каждого СостояниеСобытия Из ДоступныеСостоянияДокумента Цикл
		СписокСостояний.Добавить(СостояниеСобытия.Состояние, СостояниеСобытия.Наименование);
	КонецЦикла;
	
	Возврат СписокСостояний;
		
КонецФункции

// Возвращает отсортированные по реквизиту РеквизитДопУпорядочивания состояния без пометки удаления
//
// Параметры:
//  ВозвратМассива - Булево - Если отмечено, возвращается массив, иначе - таблица значений
// 
// Возвращаемое значение:
//  ТаблицаЗначений
//  Массив
//
Функция ДоступныеСостояния(ВозвратМассива = Истина) Экспорт
              	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СостоянияСобытий.Ссылка КАК Состояние,
	|	СостоянияСобытий.Наименование КАК Наименование
	|ИЗ
	|	Справочник.СостоянияСобытий КАК СостоянияСобытий
	|ГДЕ
	|	НЕ СостоянияСобытий.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	СостоянияСобытий.РеквизитДопУпорядочивания";    
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если ВозвратМассива Тогда
		
		ДоступныеСостояния = Новый Массив;
		
		Если РезультатЗапроса.Пустой() Тогда
			Возврат ДоступныеСостояния;
		КонецЕсли;
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			ДоступныеСостояния.Добавить(Выборка.Ссылка);
		КонецЦикла;
		
		Возврат ДоступныеСостояния;
		
	КонецЕсли;

	ДоступныеСостояния = Запрос.Выполнить().Выгрузить();
	ДоступныеСостояния.Колонки.Добавить("Номер", Новый ОписаниеТипов("Число"));

	ПорядковыйНомер = 1;
	Для каждого ДоступноеСостояние Из ДоступныеСостояния Цикл
		ДоступноеСостояние.Номер = ПорядковыйНомер;
		ПорядковыйНомер = ПорядковыйНомер + 1;
	КонецЦикла;
	
	Возврат ДоступныеСостояния;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает модуль менеджера объекта в зависимости от типа в соответствии с логикой работы.
//
// Параметры:
//  ТипОбъекта - Тип - Тип объекта
//
// Возвращаемое значение:
//   ОбщийМодуль
//   МодульМенеджераОбъекта
//
Функция ПолучитьОбработчикИзмененияСостояния(ТипОбъекта)
	
	Если ТипОбъекта = Тип("ДокументСсылка.Событие") Тогда
		ИмяМодуля = "Документы.Событие";
	ИначеЕсли ТипОбъекта = Тип("ДокументСсылка.ЗаданиеНаРаботу") Тогда
		ИмяМодуля = "Документы.ЗаданиеНаРаботу";
	ИначеЕсли ТипОбъекта = Тип("ДокументСсылка.ЗадачаСотрудника") Тогда
		ИмяМодуля = "Документы.ЗадачаСотрудника";
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ОбщегоНазначения.ОбщийМодуль(ИмяМодуля);
	
КонецФункции

#КонецОбласти
