

#Область ПрограммныйИнтерфейс

#Область Курьерика

// Дополняет массив типов документов, используемых в качестве оснований для заказов на доставку
// сервиса Курьерика.
//
// Параметры:
//	МассивТипов - Массив Из Тип - массив типов документов.
//
Процедура ПриОпределенииТиповДокументовОснованийКурьерика(МассивТипов) Экспорт
	
	МассивТипов.Добавить(Тип("ДокументСсылка.ЗаказПокупателя"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ЗаказПоставщику"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ПриходнаяНакладная"));
	МассивТипов.Добавить(Тип("ДокументСсылка.РасходнаяНакладная"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ЧекККМ"));
	
КонецПроцедуры

// Заполняет представление адреса склада
//
// Параметры:
//	Склад - ОпределяемыйТип.СкладСервисДоставки - элемент справочника
//	Адрес - Строка - представление адреса склада
//	
// Пример:
//  Адрес = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(Склад,
//		    Справочники.ВидыКонтактнойИнформации.АдресСклада)
//	
Процедура ЗаполнитьПредставлениеАдресаСклада(Склад, Адрес) Экспорт
	#Если Сервер Тогда
	ВидаКонтактнойИнформацииДляАдресаДоставкиСклада = Неопределено;
	СервисДоставкиПереопределяемый.ПолучитьЗначениеВидаКонтактнойИнформацииДляАдресаДоставкиСкладаОрганизации(ВидаКонтактнойИнформацииДляАдресаДоставкиСклада);
	Адрес = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(Склад, ВидаКонтактнойИнформацииДляАдресаДоставкиСклада);
	#КонецЕсли
КонецПроцедуры

#КонецОбласти

#КонецОбласти
