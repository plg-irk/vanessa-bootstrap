
#Область ПрограммныйИнтерфейс

// Проверяет параметр Типы и возвращает Массив с типами этого параметра, для которых включены функциональные опции,
// переданные в соответствующем параметре. Проверяются только опции с типом значения Булево. Если имя функциональной 
// опции задано пустой строкой, тип исключен оне будет.
//
// Параметры:
//  Типы - Массив из Тип - Исходные типы
//  ФункциональныеОпции - Соответствие из Тип-Строка - Ключом является тип, значением - Имя функциональной опции
//
// Возвращаемое значение:
//  Массив из Тип
//
Функция ДоступныеТипыПоФункциональнымОпциям(Типы, ФункциональныеОпции) Экспорт

	ИсключаемыеТипы = Новый Массив;
	ПроверяемыеФункциональныеОпции = Новый Массив;
	ОтключенныеФункциональныеОпции = Новый Массив;

	Для Каждого ФункциональнаяОпция Из ФункциональныеОпции Цикл
		Если ПроверяемыеФункциональныеОпции.Найти(ФункциональнаяОпция.Значение) = Неопределено 
			И Не ПустаяСтрока(ФункциональнаяОпция.Значение) Тогда
				ПроверяемыеФункциональныеОпции.Добавить(ФункциональнаяОпция.Значение);
		КонецЕсли;
	КонецЦикла;

	УстановитьПривилегированныйРежим(Истина);
	
	Для Каждого ПроверяемаяФО Из ПроверяемыеФункциональныеОпции Цикл
		
		Попытка	
			ЗначениеФункциональнойОпции = ПолучитьФункциональнуюОпцию(ПроверяемаяФО);
		Исключение
			Продолжить;
		КонецПопытки;
		
		Если ТипЗнч(ЗначениеФункциональнойОпции) = Тип("Булево") И Не ЗначениеФункциональнойОпции Тогда
			ОтключенныеФункциональныеОпции.Добавить(ПроверяемаяФО);
		КонецЕсли;

	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Для Каждого ТипОснования Из Типы Цикл
		
		ФункциональнаяОпция = ФункциональныеОпции.Получить(ТипОснования);
		Если ФункциональнаяОпция = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОтключенныеФункциональныеОпции.Найти(ФункциональнаяОпция) <> Неопределено Тогда
			ИсключаемыеТипы.Добавить(ТипОснования);
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = ОбщегоНазначенияКлиентСервер.РазностьМассивов(Типы, ИсключаемыеТипы);
	
	Возврат Результат;
	
КонецФункции


#КонецОбласти
