//
// Параметры:
//  ДатаЗапроса - Дата - дата, на которую получают доступные коды операций НДС 0%
//  ВключаемыеКодыКлассификаций - Массив - коды предопределенных значений справочника Операции0, 
//											которые должны быть включены в результирующую таблицу
//  ИсключаемыеКодыКлассификаций - Массив - коды предопределенных значений справочника Операции0, 
//											которые должны быть исключены из результирующей таблицы
//
// Возвращаемое значение:
//  - ТаблицаЗначений
//		- Колонки:
//			КодОперации - Строка - код операции НДС 0%
//			Операции - СправочникСсылкаОперации0 - классификация кодов операций НДС 0%
//			ПредставлениеОпераций - Строка - представление классификация кодов операций НДС 0%
//											с расшифровкой по кодам операций НДС 0%
Функция ПредставлениеОперацийПоСтавке0(Знач ДатаЗапроса, ВключаемыеКодыКлассификаций = Неопределено,
	ИсключаемыеКодыКлассификаций = Неопределено) Экспорт

	Если Не ЗначениеЗаполнено(ДатаЗапроса) Тогда

		ДатаЗапроса = ТекущаяДатаСеанса();

	КонецЕсли;

	КлассификаторXML = ПолучитьОбщийМакет("ПереченьКодовОпераций0").ПолучитьТекст();

	Чтение = Новый ЧтениеXML;
	Чтение.УстановитьСтроку(КлассификаторXML);
	ТаблицаКодовОпераций0 = СериализаторXDTO.ПрочитатьXML(Чтение); // ТаблицаЗначений

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;

	ШаблонЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаКодовОпераций0.Код КАК КодОперации,
	|	ТаблицаКодовОпераций0.ДатаНачала КАК ДатаНачала,
	|	ТаблицаКодовОпераций0.ДатаОкончания КАК ДатаОкончания,
	|	ТаблицаКодовОпераций0.Классификация КАК Классификация
	|ПОМЕСТИТЬ КодыОпераций0
	|ИЗ
	|	&ТаблицаКодовОпераций0 КАК ТаблицаКодовОпераций0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Классификация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КодыОпераций0.КодОперации КАК КодОперации,
	|	Операции0.Ссылка КАК Операции,
	|	Операции0.Представление КАК Представление
	|ИЗ
	|	Справочник.Операции0 КАК Операции0
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КодыОпераций0 КАК КодыОпераций0
	|		ПО Операции0.Код = КодыОпераций0.Классификация
	|ГДЕ
	|	(КодыОпераций0.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|				И КодыОпераций0.ДатаНачала <= &ДатаЗапроса
	|			ИЛИ &ДатаЗапроса МЕЖДУ КодыОпераций0.ДатаНачала И КодыОпераций0.ДатаОкончания)
	|	И &ВключаемыеКодыКлассификаций
	|	И &ИсключаемыеКодыКлассификаций
	|
	|УПОРЯДОЧИТЬ ПО
	|	Представление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ КодыОпераций0";

	Запрос.Параметры.Вставить("ДатаЗапроса", ДатаЗапроса);
	Запрос.Параметры.Вставить("ТаблицаКодовОпераций0", ТаблицаКодовОпераций0);

	Если ВключаемыеКодыКлассификаций <> Неопределено Тогда

		ШаблонЗапроса = СтрЗаменить(ШаблонЗапроса, "&ВключаемыеКодыКлассификаций",
			"КодыОпераций0.Классификация В (&ВключаемыеКодыКлассификаций)");
		Запрос.Параметры.Вставить("ВключаемыеКодыКлассификаций", ВключаемыеКодыКлассификаций);

	Иначе

		Запрос.Параметры.Вставить("ВключаемыеКодыКлассификаций", Истина);

	КонецЕсли;

	Если ИсключаемыеКодыКлассификаций <> Неопределено Тогда

		ШаблонЗапроса = СтрЗаменить(ШаблонЗапроса, "&ИсключаемыеКодыКлассификаций",
			"НЕ КодыОпераций0.Классификация В (&ИсключаемыеКодыКлассификаций)");
		Запрос.Параметры.Вставить("ИсключаемыеКодыКлассификаций", ИсключаемыеКодыКлассификаций);

	Иначе

		Запрос.Параметры.Вставить("ИсключаемыеКодыКлассификаций", Истина);

	КонецЕсли;

	Запрос.Текст = ШаблонЗапроса;

	КС7 = Новый КвалификаторыСтроки(7);
	КС1000 = Новый КвалификаторыСтроки(1000);
	
	// Создание описателя типов для таблицы значений

	Массив = Новый Массив;
	Массив.Добавить(Тип("Строка"));
	ОписаниеТиповС7 = Новый ОписаниеТипов(Массив, , КС7);
	ОписаниеТиповС1000 = Новый ОписаниеТипов(Массив, , КС1000);

	// Создание таблицы значений 

	ТаблицаСКодами = Новый ТаблицаЗначений;

	ТаблицаСКодами.Колонки.Добавить("КодОперации", ОписаниеТиповС7);
	ТаблицаСКодами.Колонки.Добавить("Операции", Новый ОписаниеТипов("СправочникСсылка.Операции0"));
	ТаблицаСКодами.Колонки.Добавить("ПредставлениеОпераций", ОписаниеТиповС1000);
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл

		СтрокаТаблицы = ТаблицаСКодами.Добавить();
		СтрокаТаблицы.ПредставлениеОпераций = Выборка.Представление + НСтр("ru = ' (коды операций: '");
		СтрокаТаблицы.КодОперации = Выборка.КодОперации;
		СтрокаТаблицы.Операции = Выборка.Операции;

	КонецЦикла;

	Для Каждого СтрокаТаблицы Из ТаблицаСКодами Цикл

		Отбор = Новый Структура;
		Отбор.Вставить("Операции", СтрокаТаблицы.Операции);
		Результат = ТаблицаСКодами.НайтиСтроки(Отбор);
		КодыОпераций = "";

		Для Каждого СтрокаРезультата Из Результат Цикл
			КодыОпераций = КодыОпераций + ?(ЗначениеЗаполнено(КодыОпераций), "; ", "") + СтрокаРезультата.КодОперации;
		КонецЦикла;

		СтрокаТаблицы.ПредставлениеОпераций = СтрокаТаблицы.ПредставлениеОпераций + КодыОпераций + ")";

	КонецЦикла;

	Возврат ТаблицаСКодами;

КонецФункции

// Возвращает признак того, есть ли в базе хоть одна организация, классифицирующая номенклатуру по операциям НДС 0%
//
// Возвращаемое значение - булево:
//                         ИСТИНА - есть организация, классифицирующая номенклатуру по операциям НДС 0%;
//                         ЛОЖЬ   - нет организаций, классифицирующих номенклатуру по операциям НДС 0%.
//
Функция ЕстьКлассификацияНоменклатурПоОперациям0() Экспорт

	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НастройкиУчетаНДС.КлассифицироватьНоменклатуруПоОперациям0
	|ИЗ
	|	РегистрСведений.НастройкиУчетаНДС КАК НастройкиУчетаНДС
	|ГДЕ
	|	НастройкиУчетаНДС.КлассифицироватьНоменклатуруПоОперациям0";

	Возврат Не Запрос.Выполнить().Пустой();

КонецФункции

