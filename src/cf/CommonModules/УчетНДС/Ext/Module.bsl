Процедура ОпределитьСуммуИСтавкуНДСПоДокументамОтгрузки(Реквизиты, ТаблицаСтавкаНеПодтверждена)

	ТаблицаСтавкаНДСНеПодтвержденаПоСчетуФактуре = ТаблицаСтавкаНеПодтверждена.СкопироватьКолонки();
	
	Для каждого СтрокаНеПодтверждения Из ТаблицаСтавкаНеПодтверждена Цикл
		
		МассивДокументов = Новый Массив;
		
		Если ТипЗнч(СтрокаНеПодтверждения.СчетФактура) = Тип("ДокументСсылка.СчетФактура") Тогда
			
			ДокументОснование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаНеПодтверждения.СчетФактура, "ДокументОснование");
			
			Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда
				Продолжить;
			КонецЕсли;
			
			МенеджерДокумента = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ДокументОснование);
			МассивДокументов.Добавить(ДокументОснование);
			
		Иначе
			
			Если ТипЗнч(СтрокаНеПодтверждения.СчетФактура) = Тип("ДокументСсылка.ДокументРасчетовСКонтрагентом") Тогда
				Продолжить
			КонецЕсли;
			
			МенеджерДокумента = ОбщегоНазначения.МенеджерОбъектаПоСсылке(СтрокаНеПодтверждения.СчетФактура);
			МассивДокументов.Добавить(СтрокаНеПодтверждения.СчетФактура);
			
		КонецЕсли;
		
		ТаблицаДанных = МенеджерДокумента.ДанныеДокументовРегУчет(МассивДокументов, Ложь);
		РеквизитыДокументаОтгрузки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Реквизиты.Регистратор, "Организация, Дата");
		ПараметрыДокумента = Новый Структура("ТаблицаДокумента", ПодготовитьТаблицуДокументаДляПолученияСуммСтавка0(ТаблицаДанных, Истина, РеквизитыДокументаОтгрузки));
		
		Если ПараметрыДокумента.ТаблицаДокумента.Количество() Тогда
			
			// Формируем строки таблицы по конкретному документу реализации
			
			ТаблицаДокумента = ПараметрыДокумента.ТаблицаДокумента;
			ТаблицаДокумента.Свернуть("СтавкаНДС", "СуммаБезНДС,СуммаНДС");
			
			Если Реквизиты.КлассифицироватьНоменклатуруПоОперациям0 Тогда
				
				СтрокаНеПодтверждения.СчетФактура = СтрокаНеПодтверждения.СчетФактураВыданный;
				СтрокаНеПодтверждения.СтавкаНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТаблицаДокумента[0].СтавкаНДС, "ПеречислениеСтавкаНДС");
			Иначе
				
				Для каждого СтрокаДокумента Из ТаблицаДокумента Цикл
					
					НоваяСтрока = ТаблицаСтавкаНДСНеПодтвержденаПоСчетуФактуре.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаНеПодтверждения, , "СтавкаНДС,СуммаБезНДС,НДС,СчетФактура");
					
					НоваяСтрока.СчетФактура = СтрокаНеПодтверждения.СчетФактураВыданный;
					
					НоваяСтрока.СтавкаНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаДокумента.СтавкаНДС, "ПеречислениеСтавкаНДС");
					НоваяСтрока.СуммаБезНДС = СтрокаДокумента.СуммаБезНДС;
					НоваяСтрока.НДС = СтрокаДокумента.СуммаНДС;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если НЕ Реквизиты.КлассифицироватьНоменклатуруПоОперациям0 Тогда
		ТаблицаСтавкаНеПодтверждена = ТаблицаСтавкаНДСНеПодтвержденаПоСчетуФактуре;
	КонецЕсли;
	
КонецПроцедуры

Функция ПодготовитьТаблицуДокументаДляПолученияСуммСтавка0(ТаблицаДанных, НеподтверждениеНулевойСтавки, РеквизитыДокументаОтгрузки) Экспорт
	
	ПониженныеВидыСтавок = Новый Массив;
	ЗначениеОбщейСтавкиНДС = 0;
	ЗначениеПониженнойСтавкиНДС = 0;
	ОбщаяСтавкаНДС = Перечисления.СтавкиНДС.ПустаяСсылка();
	ПониженнаяСтавкаНДС = Перечисления.СтавкиНДС.ПустаяСсылка();
	
	Если НеподтверждениеНулевойСтавки Тогда
		
		// Ставка НДС на УСН при неподтверждении экспорта определяется на дату отгрузки.
		СтавкаНДСПриУСН = РегистрыСведений.НастройкиУчетаНДС.СтавкаНалогообложенияПриУСН(
		РеквизитыДокументаОтгрузки.Организация, РеквизитыДокументаОтгрузки.Дата);
		Если СтавкаНДСПриУСН <> Перечисления.ВидыСтавокНДС.ПустаяСсылка()
			И СтавкаНДСПриУСН <> Перечисления.ВидыСтавокНДС.Общая Тогда
			ПониженныеВидыСтавок.Добавить(СтавкаНДСПриУСН);
			ОбщаяСтавкаНДС      = Перечисления.СтавкиНДС.СтавкаНДС(СтавкаНДСПриУСН, РеквизитыДокументаОтгрузки.Дата);
			ПониженнаяСтавкаНДС = ОбщаяСтавкаНДС;
		Иначе
			ПониженныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.Пониженная);
			ПониженныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная);
			ОбщаяСтавкаНДС      = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Общая, РеквизитыДокументаОтгрузки.Дата);
			ПониженнаяСтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Пониженная, РеквизитыДокументаОтгрузки.Дата);
		КонецЕсли;
		
		ЗначениеОбщейСтавкиНДС      = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(ОбщаяСтавкаНДС);
		ЗначениеПониженнойСтавкиНДС = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(ПониженнаяСтавкаНДС);
		
	КонецЕсли;
	
	Если ТипЗнч(ТаблицаДанных) = Тип("СтрокаТаблицыЗначений") Тогда
		ТаблицаЗапасы = ТаблицаДанных.ТаблицаЗапасы;
	Иначе
		ТаблицаЗапасы = ТаблицаДанных[0].ТаблицаЗапасы;

		Если ТипЗнч(ТаблицаДанных[0].Ссылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
			ТаблицаРаботыИУслуги = ТаблицаДанных[0].ТаблицаРаботыУслуги;
			Для Каждого СтрокаРаботИУслуг Из ТаблицаРаботыИУслуги Цикл
				НоваяСтрока = ТаблицаЗапасы.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРаботИУслуг);
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	Массив = Новый Массив;
	Массив.Добавить(Тип("Число"));
	ОписаниеТиповЧисло15_2 = Новый ОписаниеТипов(Массив, , Новый КвалификаторыЧисла(15,2));
	ТаблицаЗапасы.Колонки.Добавить("СуммаБезНДС", ОписаниеТиповЧисло15_2);
	
	Ставка0 = Справочники.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Нулевая);
	СтрокиКУдалению = Новый Массив;
	
	СоответствиеСтавок = Справочники.СтавкиНДС.СоответствиеСтавокНДС();
	
	Для Каждого СтрокаЗапасов Из ТаблицаЗапасы Цикл
		
		Если НЕ СтрокаЗапасов.СтавкаНДС = Ставка0 Тогда 
			СтрокиКУдалению.Добавить(СтрокаЗапасов);
			Продолжить;
		КонецЕсли;
		
		ВидСтавкиНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаЗапасов.СтавкаНДС, "ВидСтавкиНДС");
		
		СтавкаДляДеления = ЗначениеОбщейСтавкиНДС;
		СтавкаНДС = СоответствиеСтавок.Получить(СтавкаНДСПриУСН);
		
		Если Не ПониженныеВидыСтавок.Найти(ВидСтавкиНДС) = Неопределено Тогда
			СтавкаДляДеления = ЗначениеПониженнойСтавкиНДС;
		КонецЕсли;
		
		СтрокаЗапасов.СтавкаНДС = СтавкаНДС;
		СтрокаЗапасов.СуммаБезНДС = СтрокаЗапасов.Сумма;
		
		Если НеподтверждениеНулевойСтавки Тогда
			СтрокаЗапасов.СуммаНДС = СтрокаЗапасов.СуммаБезНДС*СтавкаДляДеления/100;
		КонецЕсли;
		
		СтрокаЗапасов.Всего = СтрокаЗапасов.Сумма + СтрокаЗапасов.СуммаНДС;
		
		Если ТаблицаДанных[0].СуммаВключаетНДС Тогда
			СтрокаЗапасов.Сумма = СтрокаЗапасов.Сумма + СтрокаЗапасов.СуммаНДС;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
		ТаблицаЗапасы.Удалить(СтрокаКУдалению);
	КонецЦикла;
	
	Возврат ТаблицаЗапасы;
КонецФункции

// ДВИЖЕНИЯ РЕГИСТРА "НДС ПО РЕАЛИЗАЦИИ 0%"

Процедура СформироватьДвиженияНДСПредъявленныйРеализация0СнятиеБлокировкиВычета(Реквизиты, ТаблицаСнятиеБлокировкиВычета, Движения, Отказ) Экспорт

