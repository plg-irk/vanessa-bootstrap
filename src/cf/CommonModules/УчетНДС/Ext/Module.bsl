// ОПЕРАЦИИ ПО СТАВКЕ НДС 0%

// Функция возвращает таблицу значений кодов операций НДС 0% с описанием из шаблона с учетом массивов включаемых и исключаемых операций НДС 0%
//
// Параметры:
//  ДатаЗапроса - Дата - дата, на которую получают доступные коды операций НДС 0%
//  ВключаемыеКодыКлассификаций - Массив - коды предопределенных значений справочника Операции0, 
//											которые должны быть включены в результирующую таблицу
//  ИсключаемыеКодыКлассификаций - Массив - коды предопределенных значений справочника Операции0, 
//											которые должны быть исключены из результирующей таблицы
//
// Возвращаемое значение:
//  - ТаблицаЗначений
//		- Колонки:
//			Код - Строка - код операции НДС 0%
//			Название - Строка - описание код операции НДС 0%
//			Номер - Число - порядковый номер строки таблицы для сортировки
Функция КлассификаторКодовОперацийПоСтавке0(Знач ДатаЗапроса, ВключаемыеКодыКлассификаций = Неопределено,
	ИсключаемыеКодыКлассификаций = Неопределено) Экспорт

	Если Не ЗначениеЗаполнено(ДатаЗапроса) Тогда

		ДатаЗапроса = ТекущаяДатаСеанса();

	КонецЕсли;

	КлассификаторXML = ПолучитьОбщийМакет("ПереченьКодовОпераций0").ПолучитьТекст();

	Чтение = Новый ЧтениеXML;
	Чтение.УстановитьСтроку(КлассификаторXML);
	ТаблицаКодовОпераций0 = СериализаторXDTO.ПрочитатьXML(Чтение); // ТаблицаЗначений

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;

	ШаблонЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаКодовОпераций0.Код КАК Код,
	|	ТаблицаКодовОпераций0.ДатаНачала КАК ДатаНачала,
	|	ТаблицаКодовОпераций0.ДатаОкончания КАК ДатаОкончания,
	|	ТаблицаКодовОпераций0.Классификация КАК Классификация,
	|	ТаблицаКодовОпераций0.Наименование КАК Название,
	|	АВТОНОМЕРЗАПИСИ() КАК Номер
	|ПОМЕСТИТЬ КодыОпераций0
	|ИЗ
	|	&ТаблицаКодовОпераций0 КАК ТаблицаКодовОпераций0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДатаОкончания,
	|	ДатаНачала
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КодыОпераций0.Код КАК Код,
	|	КодыОпераций0.Название КАК Название,
	|	МАКСИМУМ(КодыОпераций0.Номер) КАК Номер
	|ИЗ
	|	КодыОпераций0 КАК КодыОпераций0
	|ГДЕ
	|	(КодыОпераций0.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|				И КодыОпераций0.ДатаНачала <= &ДатаЗапроса
	|			ИЛИ &ДатаЗапроса МЕЖДУ КодыОпераций0.ДатаНачала И КодыОпераций0.ДатаОкончания)
	|	И &ВключаемыеКодыКлассификаций
	|	И &ИсключаемыеКодыКлассификаций
	|
	|СГРУППИРОВАТЬ ПО
	|	КодыОпераций0.Код,
	|	КодыОпераций0.Название
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номер
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ КодыОпераций0";

	Запрос.Параметры.Вставить("ДатаЗапроса", ДатаЗапроса);
	Запрос.Параметры.Вставить("ТаблицаКодовОпераций0", ТаблицаКодовОпераций0);

	Если ВключаемыеКодыКлассификаций <> Неопределено Тогда

		ШаблонЗапроса = СтрЗаменить(ШаблонЗапроса, "&ВключаемыеКодыКлассификаций",
			"КодыОпераций0.Классификация В (&ВключаемыеКодыКлассификаций)");
		Запрос.Параметры.Вставить("ВключаемыеКодыКлассификаций", ВключаемыеКодыКлассификаций);

	Иначе

		Запрос.Параметры.Вставить("ВключаемыеКодыКлассификаций", Истина);

	КонецЕсли;

	Если ИсключаемыеКодыКлассификаций <> Неопределено Тогда

		ШаблонЗапроса = СтрЗаменить(ШаблонЗапроса, "&ИсключаемыеКодыКлассификаций",
			"НЕ КодыОпераций0.Классификация В (&ИсключаемыеКодыКлассификаций)");
		Запрос.Параметры.Вставить("ИсключаемыеКодыКлассификаций", ИсключаемыеКодыКлассификаций);

	Иначе

		Запрос.Параметры.Вставить("ИсключаемыеКодыКлассификаций", Истина);

	КонецЕсли;

	Запрос.Текст = ШаблонЗапроса;

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

