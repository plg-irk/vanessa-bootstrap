
#Область ПрограммныйИнтерфейс

// Возвращает доступные варианты учета партий товаров в целях формирования КУДиР
// 
// Возвращаемое значение:
//   - Структура - в качестве ключа выступает имя регистра, в котором ведется учет партий товаров:
//		* ПартииТоваровДляКУДиР - Строка
//		* ПартииТоваровУСН - Строка
//		* ПартииТоваров - Строка
//
Функция РегистрыУчетаПартийТоваров() Экспорт
	
	ВсеРегистры = Метаданные.РегистрыНакопления;
	
	СписокРегистров = Новый Структура;
	СписокРегистров.Вставить("ПартииТоваровДляКУДиР", ВсеРегистры.ПартииТоваровДляКУДиР.Имя);
	СписокРегистров.Вставить("ПартииТоваровУСН", ВсеРегистры.ПартииТоваровУСН.Имя);
	СписокРегистров.Вставить("ПартииТоваров", ВсеРегистры.ПартииТоваров.Имя);
	
	Возврат СписокРегистров;
	
КонецФункции

// Возвращает имя регистра, в котором учитываются движения по партиям для формирования КУДиР
// 
// Возвращаемое значение:
//   - Строка
//
Функция ТекущийРегистрУчетаПартийТоваров() Экспорт

	СтарыйУчетПартий = Константы.ИспользоватьСтарыйУчетПартийУСН.Получить();
	ПоследовательностьПартий = Константы.ИспользоватьПоследовательностьПартийКУДиР.Получить();

	СпособыУчета = РегистрыУчетаПартийТоваров();
	Если ПоследовательностьПартий Тогда
		ИмяРегистра = СпособыУчета.ПартииТоваровДляКУДиР;
	ИначеЕсли СтарыйУчетПартий Тогда
		ИмяРегистра = СпособыУчета.ПартииТоваров;
	Иначе
		ИмяРегистра = СпособыУчета.ПартииТоваровУСН;
	КонецЕсли;
	
	Возврат ИмяРегистра;

КонецФункции

// Определяет, требуется ли организации учитывать партии УСН с использованием регистра ПартииТоваровУСН
// 
// Параметры:
//  Организация - СправочникСсылка.Организации - Организация
//  Период - Дата - Период
// 
// Возвращаемое значение:
//  Булево - Используется регистр накопления ПартииТоваровУСН
//
Функция ИспользуетсяРегистрПартииУСН(Организация, Период) Экспорт

	Если ПолучитьФункциональнуюОпцию("ИспользоватьОтчетность") Тогда
		СистемаНалогообложения = РегистрыСведений.СистемыНалогообложенияОрганизаций.ОпределитьСистемуНалогообложенияОрганизации(Организация, Период);
		
		ИспользуетсяРегистрПартииУСН = НЕ СистемаНалогообложения.ПрименяетсяАУСН
			И СистемаНалогообложения.ПлательщикУСН
			И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ЮридическоеФизическоеЛицо")
				= Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо
			И НЕ Константы.ИспользоватьСтарыйУчетПартийУСН.Получить()
			И НЕ Константы.ИспользоватьПоследовательностьПартийКУДиР.Получить();
	Иначе
		ИспользуетсяРегистрПартииУСН = Ложь;		
	КонецЕсли;
	
	Возврат ИспользуетсяРегистрПартииУСН;
	
КонецФункции

// Устанавливает константы, от которых зависит способ учета движений по партиям в целях формирования КУДиР
//
// Параметры:
//  ИмяРегистраПартий - Строка	- Имя регистра, в котором должны учитываться движения по партиям для КУДиР
//
Процедура УстановитьРегистрУчетаПартийТоваров(ИмяРегистраПартий) Экспорт
	
	СпособыУчета = РегистрыУчетаПартийТоваров();
	Если ИмяРегистраПартий = СпособыУчета.ПартииТоваров Тогда
		СтарыйУчетПартий = Истина;
		ПоследовательностьПартий = Ложь;
	ИначеЕсли ИмяРегистраПартий = СпособыУчета.ПартииТоваровДляКУДиР Тогда
		СтарыйУчетПартий = Ложь;
		ПоследовательностьПартий = Истина;
	Иначе
		СтарыйУчетПартий = Ложь;
		ПоследовательностьПартий = Ложь;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	НачатьТранзакцию();
	Попытка
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.ПоследовательностьПартийДляКУДиР");
		ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		БлокировкаДанных.Заблокировать();
		
		ГраницаПоследовательности = ОпределитьМинимальнуюДатуНачала();
		
		НаборЗаписей = РегистрыСведений.ПоследовательностьПартийДляКУДиР.СоздатьНаборЗаписей();
		Если СтарыйУчетПартий Тогда
			РегламентированнаяОтчетностьУСН.УстановитьДатуНачалаФормированияЗаписейКУДиР(ГраницаПоследовательности);
		Иначе
			ВыборкаОрганизации = Справочники.Организации.Выбрать();
			Пока ВыборкаОрганизации.Следующий() Цикл
				НоваяЗапись = НаборЗаписей.Добавить();
				НоваяЗапись.Организация = ВыборкаОрганизации.Ссылка;
				НоваяЗапись.НачалоМесяца = ГраницаПоследовательности;
				НоваяЗапись.НарушенПорядок = НЕ ПоследовательностьПартий;
			КонецЦикла;
		КонецЕсли;	
		
		Константы.ИспользоватьСтарыйУчетПартийУСН.Установить(СтарыйУчетПартий);
		Константы.ИспользоватьПоследовательностьПартийКУДиР.Установить(ПоследовательностьПартий);
		НаборЗаписей.Записать(Истина);
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ТекстОшибки(НСтр("ru = 'Ошибка при изменении способа учета партий'"), ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытияЖурналаРегистрации(), УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

// Возвращает дату, с которой нужно пересчитывать движения по регистру ПартииТоваровУСН
//
// Возвращаемое значение:
//   - Дата
//
Функция ДатаНачалаФормированияЗаписей() Экспорт
	
	ДатаГраницы = РегистрыСведений.ПоследовательностьПартийДляКУДиР.ПолучитьДатуГраницыОбщую();
	НачалоПоследовательности = ДатаНачалаПересчетаПартий(ДатаГраницы);
	
	Возврат НачалоПоследовательности;
	
КонецФункции

// Обновление движений документов по регистру накопления ПартииТоваровУСН.
// Формирует движения, начиная с меньшей из дат: переданная дата начала и дата документа-регистратора, проведенного "задним числом"
//
// Параметры:
//  ДатаНачала	 - Дата - дата, начиная с которой нужно обновить движения документов
//
Процедура ОбновитьДвиженияПоРегиструПартииТоваровУСН(ДатаНачала) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	ТекстОбновление = НСтр("ru = 'Обновление движений товаров (партий)'");
	
	МаксимальнаяДата = Дата(3999, 12, 31);
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МаксДата", МаксимальнаяДата);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПоследовательностьПартийДляКУДиР.Организация КАК Организация,
	               |	МИНИМУМ(ПоследовательностьПартийДляКУДиР.НачалоМесяца) КАК НачалоМесяца
	               |ПОМЕСТИТЬ ВТНарушенПорядокПартий
	               |ИЗ
	               |	РегистрСведений.ПоследовательностьПартийДляКУДиР КАК ПоследовательностьПартийДляКУДиР
	               |ГДЕ
	               |	ПоследовательностьПартийДляКУДиР.НарушенПорядок
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПоследовательностьПартийДляКУДиР.Организация
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Организации.Ссылка КАК Организация,
	               |	Организации.ИспользуетсяОтчетность КАК ИспользуетсяОтчетность,
	               |	Организации.ЮридическоеФизическоеЛицо = ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ФизическоеЛицо) КАК ЭтоИП
	               |ПОМЕСТИТЬ ВТДанныеОрганизации
	               |ИЗ
	               |	Справочник.Организации КАК Организации
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТДанныеОрганизации.Организация КАК Организация,
	               |	ВТДанныеОрганизации.ЭтоИП КАК ЭтоИП,
	               |	ВТДанныеОрганизации.ИспользуетсяОтчетность КАК ИспользуетсяОтчетность,
	               |	ЕСТЬNULL(ВТНарушенПорядокПартий.НачалоМесяца, &МаксДата) КАК НачалоНарушенийПорядка
	               |ИЗ
	               |	ВТДанныеОрганизации КАК ВТДанныеОрганизации
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТНарушенПорядокПартий КАК ВТНарушенПорядокПартий
	               |		ПО ВТДанныеОрганизации.Организация = ВТНарушенПорядокПартий.Организация
	               |ИТОГИ
	               |	МИНИМУМ(ВЫБОР
	               |			КОГДА ЭтоИП
	               |					И ИспользуетсяОтчетность
	               |				ТОГДА НачалоНарушенийПорядка
	               |			ИНАЧЕ &МаксДата
	               |		КОНЕЦ) КАК НачалоНарушенийПорядка
	               |ПО
	               |	ОБЩИЕ";
	
	ДанныеПерепровести = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	Для Каждого МинимальнаяДата Из ДанныеПерепровести.Строки Цикл
		
		ДатаПересчетаПартий = ДатаНачалаПересчетаПартий(МинимальнаяДата.НачалоНарушенийПорядка);
		ДатаОтсчета = Мин(ДатаПересчетаПартий, ДатаНачала);
		
		ДатаЗавершения = КонецМесяца(ТекущаяДатаСеанса());
		
		ТребуетсяОбработка = Новый Массив;
		Для Каждого ДатыОрганизации Из МинимальнаяДата.Строки Цикл
			Если ДатыОрганизации.ЭтоИП И ДатыОрганизации.ИспользуетсяОтчетность Тогда
				// ИП со сдачей отчетности - сдвинуть до месяца пересчета, включить в обрабатываемые
				//@skip-check query-in-loop - обработка порциями по организации
				УстановитьНачалоПоследовательностиПартий(ДатыОрганизации.Организация, ДатаОтсчета, Ложь);
				ТребуетсяОбработка.Добавить(ДатыОрганизации);
			Иначе
				// Сдача отчетности не предполагается, данные в регистре очищаются.
				// Для ИП сохраняется месяц начала нарушения последовательности на случай включения сдачи отчетности				
				НаборЗаписей = РегистрыСведений.ПоследовательностьПартийДляКУДиР.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Организация.Установить(ДатыОрганизации.Организация);
				ЗаписьРегистра = НаборЗаписей.Добавить();
				ЗаписьРегистра.Организация = ДатыОрганизации.Организация;
				Если ДатыОрганизации.ЭтоИП И ДатыОрганизации.НачалоНарушенийПорядка < МаксимальнаяДата Тогда
					ЗаписьРегистра.НачалоМесяца = НачалоМесяца(ДатыОрганизации.НачалоНарушенийПорядка);
					ЗаписьРегистра.НарушенПорядок = Истина;
				Иначе
					ЗаписьРегистра.НачалоМесяца = НачалоМесяца(ДатаЗавершения);
				КонецЕсли;
				ЗаписьРегистра.ДатаДокумента = ЗаписьРегистра.НачалоМесяца - 1;
				НаборЗаписей.Записать();
			КонецЕсли;
		КонецЦикла;	
		
		Если ТребуетсяОбработка.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
		// Выполняем пересчет партий по месяцам
		ДатаЗавершения = КонецМесяца(ТекущаяДатаСеанса());
		Пока ДатаОтсчета < ДатаЗавершения Цикл
			
			КонецПериода = КонецМесяца(ДатаОтсчета);
			ПоследнийМесяц = (КонецПериода = ДатаЗавершения);
			
			ТекстМесяц = Формат(ДатаОтсчета, НСтр("ru='ДФ=''ММММ гггг ""г.""'''"));
			ДлительныеОперации.СообщитьПрогресс(0, СтрШаблон("%1: %2", ТекстОбновление, ТекстМесяц));
			
			Для Каждого ДатыОрганизаций Из ТребуетсяОбработка Цикл
				
			    //@skip-check query-in-loop - обработка порции по организации и периоду
			    ВыборкаДокументов = ВыборкаДокументовДляОбновленияДвиженийПартийТоваровУСН(
					ДатыОрганизаций.Организация, ДатаОтсчета, КонецПериода);
				Пока ВыборкаДокументов.Следующий() Цикл
					//@skip-check query-in-loop - обновление движений по регистру ПартииТоваровУСН по документу
					ОбновитьДвиженияПоРегиструПартииТоваровУСНДокумента(ВыборкаДокументов);
				КонецЦикла;
				
				СдвинутьГраницуПоследовательностиПартий(ДатыОрганизаций.Организация, ДатаОтсчета, НЕ ПоследнийМесяц);
			КонецЦикла;
			ДатаОтсчета = ДобавитьМесяц(ДатаОтсчета, 1);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// Процедура обновления - включить использование старого регистра по партиям,
// если не используются регистры ПартииТоваровДляКУДиР или ПартииТоваровУСН 
//
Процедура ВключитьИспользованиеСтарогоРегистра() Экспорт
		
	Если ОбщегоНазначения.ЭтоПодчиненныйУзелРИБ() Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьОтчетность") Тогда
		Возврат;
	КонецЕсли;
	
	Если Константы.ИспользоватьСтарыйУчетПартийУСН.Получить()
		ИЛИ Константы.ИспользоватьПоследовательностьПартийКУДиР.Получить() Тогда
		Возврат;
	КонецЕсли;
	
	// Есть записи в ПоследовательностьПартийДляКУДиР, используется регистр ПартииТоваровУСН,
	// устанавливать константы не требуется
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПоследовательностьПартийДляКУДиР.Организация КАК Организация
	|ИЗ
	|	РегистрСведений.ПоследовательностьПартийДляКУДиР КАК ПоследовательностьПартийДляКУДиР";
	
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	// В регистре ПартииТоваров есть движения, в этом случае устанавливаем его использование
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПартииТоваров.Организация КАК Организация
	               |ИЗ
	               |	РегистрНакопления.ПартииТоваров КАК ПартииТоваров";
	
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Константы.ИспользоватьСтарыйУчетПартийУСН.Установить(Истина);
	КонецЕсли;

КонецПроцедуры

#Область ДвиженияПоПартииТоваровУСН

// Создание структуры для движений по регистру ПартииТоваровУСН
//
// Параметры:
//  Организация	 - СправочникСсылка.Организации
//  Период		 - Дата 
// 
// Возвращаемое значение:
//   - Структура:
//		* ПроводитьПоПартиямУСН - Булево - Истина, если нужно заполнять движения по регистру ПартииТоваровУСН
//		* ТаблицаОписаниеОперацииКУДиР - ТаблицаЗначений - таблица движений по регистру ОписаниеОперацииКУДиР
//		* ТаблицаПартииТоваровУСН - ТаблицаЗначений - таблица движения по регистру ПартииТоваровУСН
//
Функция ТаблицыДвиженийПоПартиямУСН(Организация, Период) Экспорт
	
	Таблицы = Новый Структура;
	
	ИспользуетсяРегистрПартииУСН = ИспользуетсяРегистрПартииУСН(Организация, Период);

	Таблицы.Вставить("ПроводитьПоПартиямУСН", ИспользуетсяРегистрПартииУСН);
	Если ИспользуетсяРегистрПартииУСН Тогда
		Таблицы.Вставить("ТаблицаОписаниеОперацииКУДиР", ТаблицаДвиженийПоРегистру(РегистрыСведений.ОписаниеОперацииКУДиР));
		Таблицы.Вставить("ТаблицаПартииТоваровУСН", ТаблицаДвиженийПоРегистру(РегистрыНакопления.ПартииТоваровУСН));
	Иначе	
		Таблицы.Вставить("ТаблицаОписаниеОперацииКУДиР", Новый ТаблицаЗначений);
		Таблицы.Вставить("ТаблицаПартииТоваровУСН", Новый ТаблицаЗначений);
	КонецЕсли;
	
	Возврат Таблицы;

КонецФункции

// Создание временной таблицы ВТДанныеПервичныхДокументов, в которой содержатся основные реквизиты документов,
// которые используются в описании операции по партиям
//
// Параметры:
//  МенеджерВременныхТаблиц		 - МенеджерВременныхТаблиц 
//  ТипыДокументов				 - Массив из Тип	 - список типов документов
//  ИмяВременнойТаблицыДокументы - Строка	- имя временной таблицы, содержащей список документов в поле ДокументСсылка
//
Процедура СоздатьВТДанныеПервичныхДокументов(МенеджерВременныхТаблиц, ТипыДокументов, ИмяВременнойТаблицыДокументы = "") Экспорт
	
	ТекстЗапроса = "ВЫБРАТЬ
	                 |	НЕОПРЕДЕЛЕНО КАК Ссылка,
	                 |	ДАТАВРЕМЯ(1, 1, 1) КАК Дата,
	                 |	"""" КАК Номер,
	                 |	ИСТИНА КАК УчитыватьВНУ,
	                 |	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаВходящегоДокумента,
	                 |	"""" КАК НомерВходящегоДокумента
	                 |ПОМЕСТИТЬ ВТДанныеПервичныхДокументов";
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0];

	Для Каждого ТипДокумента Из ТипыДокументов Цикл
		Документ = Метаданные.НайтиПоТипу(ТипДокумента);
		
		Выбор = ЗапросВыбора.Операторы.Добавить(ЗапросВыбора.Операторы[0]);
		Выбор.ТипОбъединения = ТипОбъединенияСхемыЗапроса.Объединить;
		
		Выбор.Источники.Добавить(Документ.ПолноеИмя(), "ДокументИсточник");
		
		Если ЗначениеЗаполнено(ИмяВременнойТаблицыДокументы) Тогда
			СписокДокументов = Выбор.Источники.Добавить(Тип("ОписаниеВременнойТаблицыСхемыЗапроса"), ИмяВременнойТаблицыДокументы, "ВТДокументы");
			СписокДокументов.Источник.ДоступныеПоля.Добавить("ДокументСсылка");
			СписокДокументов.Соединения.Добавить("ДокументИсточник", "ДокументИсточник.Ссылка = ВТДокументы.ДокументСсылка");
			СписокДокументов.Соединения[0].ТипСоединения = ТипСоединенияСхемыЗапроса.Внутреннее;
		КонецЕсли;
		Выбор.ВыбираемыеПоля[0] = Новый ВыражениеСхемыЗапроса("Ссылка");
		Выбор.ВыбираемыеПоля[1] = Новый ВыражениеСхемыЗапроса("Дата");
		Выбор.ВыбираемыеПоля[2] = Новый ВыражениеСхемыЗапроса("Номер");
		
		Если Документ.Реквизиты.Найти("УчитыватьВНУ") <> Неопределено Тогда
			Выбор.ВыбираемыеПоля[3] = Новый ВыражениеСхемыЗапроса("УчитыватьВНУ");
		КонецЕсли;
		
		Если Документ.Реквизиты.Найти("ДатаВходящегоДокумента") <> Неопределено Тогда
			Выбор.ВыбираемыеПоля[4] = Новый ВыражениеСхемыЗапроса("ДатаВходящегоДокумента");
		КонецЕсли;
		
		Если Документ.Реквизиты.Найти("НомерВходящегоДокумента") <> Неопределено Тогда
			Выбор.ВыбираемыеПоля[5] = Новый ВыражениеСхемыЗапроса("НомерВходящегоДокумента");
		КонецЕсли;
	КонецЦикла;
	
	ЗапросВыбора.Операторы.Удалить(0);
	
	Запрос = Новый Запрос;
    Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	Запрос.Выполнить();
	
КонецПроцедуры

// Формирует текст запроса остатков по регистру ПартииТоваровУСН для отражения списания (продажа товаров, списание и пр.)
//
// Параметры:
//  ТолькоТовары - Булево - требуется списать только товары (продажа)
// 
// Возвращаемое значение:
//   - Строка - текст запроса
//
Функция ТекстЗапросаПартииДляСписания(ТолькоТовары) Экспорт
	
	Условия = Новый Массив;
	Условия.Добавить("Организация = &Организация");
	Условия.Добавить("Номенклатура В (&Номенклатура)");
	Условия.Добавить("СтатусРасхода В (ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеСписано), ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеСписаноНеОплачено))");
	Если ТолькоТовары Тогда
		Условия.Добавить("ЭтоТоварыКРеализации");
	КонецЕсли;
	
	Сортировка = Новый Массив;
	Сортировка.Добавить("Номенклатура");
	Сортировка.Добавить("ДатаПоступления");
	Сортировка.Добавить("ЭтоТоварыКРеализации УБЫВ");
	Сортировка.Добавить("СтатусРасходаПорядок");
	Сортировка.Добавить("ДокументПартии");
	Сортировка.Добавить("НомерСтрокиДокумента");
	
	Возврат ТекстЗапросаОстаткиПоПартиям(Условия, Сортировка);
	
КонецФункции

// Заполнение параметров запроса, получающего остатки партий в целях их списания
//
// Параметры:
//  Запрос			 - Запрос
//  Организация		 - СправочникСсылка.Организации
//	Период			 - Дата - период для таблицы движений по регистру
//  Номенклатура	 - Массив из СправочникСсылка.Номенклатура
//  МоментВремени	 - МоментВремени, Дата - период получения остатков
//
Процедура ЗаполнитьПараметрыЗапросаПартииДляСписания(Запрос, Организация, Период, Номенклатура, МоментВремени) Экспорт
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("МоментВремени", МоментВремени);
	
КонецПроцедуры

// Формирует текст запроса остатков по регистру ПартииТоваровУСН для отражения оплаты поставщику
// 
// Возвращаемое значение:
//   - Строка - текст запроса
//
Функция ТекстЗапросаПартииДляОплаты() Экспорт

	Условия = Новый Массив;
	Условия.Добавить("Организация = &Организация");
	Условия.Добавить("ДокументПартии В (&ДокументыПартии)");
	Условия.Добавить("СтатусРасхода В (ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеОплачено), ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеСписаноНеОплачено))");
	
	Сортировка = Новый Массив;
	Сортировка.Добавить("ДатаПоступления");
	Сортировка.Добавить("СтатусРасходаПорядок");
	Сортировка.Добавить("ЭтоТоварыКРеализации");
	Сортировка.Добавить("ДокументПартии");
	Сортировка.Добавить("НомерСтрокиДокумента");
	
	Возврат ТекстЗапросаОстаткиПоПартиям(Условия, Сортировка);

КонецФункции

// Формирует текст запроса остатков по регистру ПартииТоваровУСН для отражения возврата от покупателя
// 
// Возвращаемое значение:
//   - Строка - текст запроса
//
Функция ТекстЗапросаПартииДляВозвратаОтПокупателя() Экспорт
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	ПродажиОбороты.Регистратор КАК ДокументПродажи,
	               |	ПродажиОбороты.Номенклатура КАК Номенклатура,
	               |	МАКСИМУМ(ПродажиОбороты.Регистратор В (&ДокументыПродажи)) КАК СовпадаетДокументПродажи,
	               |	МАКСИМУМ(ПродажиОбороты.ЗаказПокупателя В (&ЗаказыПокупателей)) КАК СовпадаетЗаказПокупателя
	               |ПОМЕСТИТЬ ДокументыПродажи
	               |ИЗ
	               |	РегистрНакопления.Продажи.Обороты(, &ГраницаДвижения, Регистратор, Номенклатура В (&Номенклатура)) КАК ПродажиОбороты
	               |ГДЕ
	               |	ПродажиОбороты.КоличествоОборот > 0
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПродажиОбороты.Регистратор,
	               |	ПродажиОбороты.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПартииТоваровУСН.Регистратор КАК ДокументПродажи,
	               |	ПартииТоваровУСН.Номенклатура КАК Номенклатура,
	               |	ПартииТоваровУСН.ДокументПартии КАК ДокументПартии,
	               |	ПартииТоваровУСН.НомерСтрокиДокумента КАК НомерСтрокиДокумента,
	               |	&ДатаДокумента КАК Период,
	               |	ПартииТоваровУСН.Организация КАК Организация,
	               |	ПартииТоваровУСН.ДокументРегистрацииВКУДиР КАК ДокументРегистрацииВКУДиР,
	               |	ПартииТоваровУСН.СтатусРасхода КАК СтатусРасхода,
	               |	ПартииТоваровУСН.ЭтоТоварыКРеализации КАК ЭтоТоварыКРеализации,
	               |	ПартииТоваровУСН.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	СУММА(ПартииТоваровУСН.Количество) КАК Количество,
	               |	СУММА(ПартииТоваровУСН.Сумма) КАК Сумма,
	               |	СУММА(ПартииТоваровУСН.СуммаНДС) КАК СуммаНДС,
	               |	ПартииТоваровУСН.ОтражатьВКУДиР КАК ОтражатьВКУДиР,
	               |	ДокументыПродажи.СовпадаетДокументПродажи КАК СовпадаетДокументПродажи,
	               |	ДокументыПродажи.СовпадаетЗаказПокупателя КАК СовпадаетЗаказПокупателя
	               |ПОМЕСТИТЬ ВТПроданныеПартии
	               |ИЗ
	               |	ДокументыПродажи КАК ДокументыПродажи
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПартииТоваровУСН КАК ПартииТоваровУСН
	               |		ПО ДокументыПродажи.ДокументПродажи = ПартииТоваровУСН.Регистратор
	               |			И ДокументыПродажи.Номенклатура = ПартииТоваровУСН.Номенклатура
	               |			И (ПартииТоваровУСН.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход))
	               |			И (ПартииТоваровУСН.Период < &ДатаДокумента)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПартииТоваровУСН.ОтражатьВКУДиР,
	               |	ПартииТоваровУСН.ДокументРегистрацииВКУДиР,
	               |	ПартииТоваровУСН.НомерСтрокиДокумента,
	               |	ПартииТоваровУСН.СтатусРасхода,
	               |	ПартииТоваровУСН.Организация,
	               |	ПартииТоваровУСН.ЭтоТоварыКРеализации,
	               |	ПартииТоваровУСН.Номенклатура,
	               |	ПартииТоваровУСН.ДокументПартии,
	               |	ПартииТоваровУСН.УчитыватьВНУ,
	               |	ПартииТоваровУСН.Регистратор,
	               |	ДокументыПродажи.СовпадаетДокументПродажи,
	               |	ДокументыПродажи.СовпадаетЗаказПокупателя
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ПартииТоваров.Номенклатура КАК Номенклатура,
	               |	ПартииТоваров.ДокументПартии КАК ДокументПартии,
	               |	МИНИМУМ(ПартииТоваров.Период) КАК Период,
	               |	ПартииТоваров.Организация КАК Организация,
	               |	ПартииТоваров.НомерСтрокиДокумента КАК НомерСтрокиДокумента
	               |ПОМЕСТИТЬ ВТДатыПоступленияПартии
	               |ИЗ
	               |	ВТПроданныеПартии КАК ВТПроданныеПартии
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПартииТоваровУСН КАК ПартииТоваров
	               |		ПО ВТПроданныеПартии.Организация = ПартииТоваров.Организация
	               |			И ВТПроданныеПартии.Номенклатура = ПартииТоваров.Номенклатура
	               |			И ВТПроданныеПартии.ДокументПартии = ПартииТоваров.ДокументПартии
	               |			И (ПартииТоваров.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход))
	               |			И ВТПроданныеПартии.НомерСтрокиДокумента = ПартииТоваров.НомерСтрокиДокумента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПартииТоваров.Номенклатура,
	               |	ПартииТоваров.ДокументПартии,
	               |	ПартииТоваров.Организация,
	               |	ПартииТоваров.НомерСтрокиДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТПроданныеПартии.ДокументПродажи КАК ДокументПродажи,
	               |	ВТПроданныеПартии.Номенклатура КАК Номенклатура,
	               |	ВТПроданныеПартии.ДокументПартии КАК ДокументПартии,
	               |	ВТПроданныеПартии.Период КАК Период,
	               |	ВТПроданныеПартии.Организация КАК Организация,
	               |	ВТПроданныеПартии.ДокументРегистрацииВКУДиР КАК ДокументРегистрацииВКУДиР,
	               |	ВТПроданныеПартии.СтатусРасхода КАК СтатусРасхода,
	               |	ВТПроданныеПартии.ЭтоТоварыКРеализации КАК ЭтоТоварыКРеализации,
	               |	ВТПроданныеПартии.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	СУММА(ПартииТоваровУСН.Количество) КАК Количество,
	               |	СУММА(ПартииТоваровУСН.Сумма) КАК Сумма,
	               |	СУММА(ПартииТоваровУСН.СуммаНДС) КАК СуммаНДС,
	               |	ПартииТоваровУСН.ОтражатьВКУДиР КАК ОтражатьВКУДиР,
	               |	ВТПроданныеПартии.СовпадаетДокументПродажи КАК СовпадаетДокументПродажи,
	               |	ВТПроданныеПартии.СовпадаетЗаказПокупателя КАК СовпадаетЗаказПокупателя,
	               |	ВТПроданныеПартии.НомерСтрокиДокумента КАК НомерСтрокиДокумента
	               |ПОМЕСТИТЬ ВТОплаченныеПартии
	               |ИЗ
	               |	ВТПроданныеПартии КАК ВТПроданныеПартии
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПартииТоваровУСН КАК ПартииТоваровУСН
	               |		ПО ВТПроданныеПартии.ДокументПродажи = ПартииТоваровУСН.ДокументРегистрацииВКУДиР
	               |			И ВТПроданныеПартии.ДокументПартии = ПартииТоваровУСН.ДокументПартии
	               |			И ВТПроданныеПартии.Номенклатура = ПартииТоваровУСН.Номенклатура
	               |			И (ВТПроданныеПартии.СтатусРасхода = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеСписаноНеОплачено))
	               |			И (ПартииТоваровУСН.СтатусРасхода = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеОплачено))
	               |			И (ПартииТоваровУСН.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход))
	               |			И (ПартииТоваровУСН.Период < &ДатаДокумента)
	               |			И ВТПроданныеПартии.УчитыватьВНУ = ПартииТоваровУСН.УчитыватьВНУ
	               |			И ВТПроданныеПартии.НомерСтрокиДокумента = ПартииТоваровУСН.НомерСтрокиДокумента
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТПроданныеПартии.ДокументПродажи,
	               |	ВТПроданныеПартии.Период,
	               |	ВТПроданныеПартии.СтатусРасхода,
	               |	ВТПроданныеПартии.ЭтоТоварыКРеализации,
	               |	ВТПроданныеПартии.Организация,
	               |	ВТПроданныеПартии.ДокументРегистрацииВКУДиР,
	               |	ВТПроданныеПартии.ДокументПартии,
	               |	ВТПроданныеПартии.Номенклатура,
	               |	ПартииТоваровУСН.ОтражатьВКУДиР,
	               |	ВТПроданныеПартии.УчитыватьВНУ,
	               |	ВТПроданныеПартии.СовпадаетДокументПродажи,
	               |	ВТПроданныеПартии.СовпадаетЗаказПокупателя,
	               |	ВТПроданныеПартии.НомерСтрокиДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТПроданныеПартии.ДокументПродажи КАК ДокументПродажи,
	               |	ВТПроданныеПартии.Номенклатура КАК Номенклатура,
	               |	ВТПроданныеПартии.ДокументПартии КАК ДокументПартии,
	               |	ВТПроданныеПартии.НомерСтрокиДокумента КАК НомерСтрокиДокумента,
	               |	ВТПроданныеПартии.Период КАК Период,
	               |	ВТПроданныеПартии.Организация КАК Организация,
	               |	ВТПроданныеПартии.ДокументРегистрацииВКУДиР КАК ДокументРегистрацииВКУДиР,
	               |	ВТПроданныеПартии.СтатусРасхода КАК СтатусРасхода,
	               |	ВТПроданныеПартии.ЭтоТоварыКРеализации КАК ЭтоТоварыКРеализации,
	               |	ВТПроданныеПартии.Количество - ЕСТЬNULL(ВТОплаченныеПартии.Количество, 0) КАК Количество,
	               |	ВТПроданныеПартии.Сумма - ЕСТЬNULL(ВТОплаченныеПартии.Сумма, 0) КАК Сумма,
	               |	ВТПроданныеПартии.СуммаНДС - ЕСТЬNULL(ВТОплаченныеПартии.СуммаНДС, 0) КАК СуммаНДС,
	               |	ВТПроданныеПартии.ОтражатьВКУДиР
	               |		И ВТПроданныеПартии.СовпадаетДокументПродажи КАК ОтражатьВКУДиР,
	               |	ВТПроданныеПартии.УчитыватьВНУ
	               |		И ВТПроданныеПартии.СовпадаетДокументПродажи КАК УчитыватьВНУ,
	               |	СтатусыРасходовУСН.Порядок КАК СтатусРасходаПорядок,
	               |	ВТПроданныеПартии.СовпадаетДокументПродажи КАК СовпадаетДокументПродажи,
	               |	ВТПроданныеПартии.СовпадаетЗаказПокупателя КАК СовпадаетЗаказПокупателя,
	               |	ВТДатыПоступленияПартии.Период КАК ДатаПоступления
	               |ИЗ
	               |	ВТПроданныеПартии КАК ВТПроданныеПартии
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТОплаченныеПартии КАК ВТОплаченныеПартии
	               |		ПО ВТПроданныеПартии.ДокументПродажи = ВТОплаченныеПартии.ДокументПродажи
	               |			И ВТПроданныеПартии.Номенклатура = ВТОплаченныеПартии.Номенклатура
	               |			И ВТПроданныеПартии.ДокументПартии = ВТОплаченныеПартии.ДокументПартии
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Перечисление.СтатусыРасходовУСН КАК СтатусыРасходовУСН
	               |		ПО ВТПроданныеПартии.СтатусРасхода = СтатусыРасходовУСН.Ссылка
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДатыПоступленияПартии КАК ВТДатыПоступленияПартии
	               |		ПО ВТПроданныеПартии.Номенклатура = ВТДатыПоступленияПартии.Номенклатура
	               |			И ВТПроданныеПартии.ДокументПартии = ВТДатыПоступленияПартии.ДокументПартии
	               |			И ВТПроданныеПартии.Организация = ВТДатыПоступленияПартии.Организация
	               |			И ВТПроданныеПартии.НомерСтрокиДокумента = ВТДатыПоступленияПартии.НомерСтрокиДокумента
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ВТОплаченныеПартии.ДокументПродажи,
	               |	ВТОплаченныеПартии.Номенклатура,
	               |	ВТОплаченныеПартии.ДокументПартии,
	               |	ВТОплаченныеПартии.НомерСтрокиДокумента,
	               |	ВТОплаченныеПартии.Период,
	               |	ВТОплаченныеПартии.Организация,
	               |	ВТОплаченныеПартии.ДокументРегистрацииВКУДиР,
	               |	ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеСписано),
	               |	ВТОплаченныеПартии.ЭтоТоварыКРеализации,
	               |	ВТОплаченныеПартии.Количество,
	               |	ВТОплаченныеПартии.Сумма,
	               |	ВТОплаченныеПартии.СуммаНДС,
	               |	ВТОплаченныеПартии.ОтражатьВКУДиР
	               |		И ВТОплаченныеПартии.СовпадаетДокументПродажи,
	               |	ВТОплаченныеПартии.УчитыватьВНУ
	               |		И ВТОплаченныеПартии.СовпадаетДокументПродажи,
	               |	0,
	               |	ВТОплаченныеПартии.СовпадаетДокументПродажи,
	               |	ВТОплаченныеПартии.СовпадаетЗаказПокупателя,
	               |	ВТДатыПоступленияПартии.Период
	               |ИЗ
	               |	ВТОплаченныеПартии КАК ВТОплаченныеПартии
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДатыПоступленияПартии КАК ВТДатыПоступленияПартии
	               |		ПО ВТОплаченныеПартии.Номенклатура = ВТДатыПоступленияПартии.Номенклатура
	               |			И ВТОплаченныеПартии.ДокументПартии = ВТДатыПоступленияПартии.ДокументПартии
	               |			И ВТОплаченныеПартии.Организация = ВТДатыПоступленияПартии.Организация
	               |			И ВТОплаченныеПартии.НомерСтрокиДокумента = ВТДатыПоступленияПартии.НомерСтрокиДокумента
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СовпадаетДокументПродажи УБЫВ,
	               |	СовпадаетЗаказПокупателя УБЫВ,
	               |	Номенклатура,
	               |	ДатаПоступления,
	               |	СтатусРасходаПорядок УБЫВ";
	
	Возврат ТекстЗапроса;
	
КонецФункции

// Создает таблицу партий, выбранного товара, который уже возвращали ранее для исключения при следующих возвратах
//
// Параметры:
//	ИсключаемыйРегистратор - ДокументСсылка - документы, который нужно исключить из анализа
//  Номенклатура - Массив из СправочникСсылка.Номенклатура - список товаров
//  ОкончаниеПериода - Дата
// 
// Возвращаемое значение:
//	- ТаблицаЗначений - таблица движения по регистру ПартииУСН с предыдущими возвратами:
//		* Организация - СправочникСсылка.Организации
//		* Номенклатура - СправочникСсылка.Номенклатура
//		* СтатусРасхода - ПеречислениеСсылка.СтатусыРасходовУСН
//		* ДокументПартии - ДокументСсылка
//		* НомерСтрокиДокумента - Число
//		* ДокументРегистрацииВКУДиР - ДокументСсылка
//		* УчитыватьВНУ - Булево
//		* ЭтоТоварыКРеализации - Булево
//		* Количество - Число
//		* Сумма - Число
//		* СуммаНДС - Число
//
Функция ВозвращенныеПартии(ИсключаемыйРегистратор, Номенклатура, ОкончаниеПериода) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ИсключаемыйРегистратор);
	Запрос.УстановитьПараметр("ДатаДокумента", ОкончаниеПериода);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПартииТоваровУСН.Организация КАК Организация,
	               |	ПартииТоваровУСН.Номенклатура КАК Номенклатура,
	               |	ПартииТоваровУСН.СтатусРасхода КАК СтатусРасхода,
	               |	ПартииТоваровУСН.ДокументПартии КАК ДокументПартии,
	               |	ПартииТоваровУСН.НомерСтрокиДокумента КАК НомерСтрокиДокумента,
	               |	ПартииТоваровУСН.ДокументРегистрацииВКУДиР КАК ДокументРегистрацииВКУДиР,
	               |	ПартииТоваровУСН.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	ПартииТоваровУСН.ЭтоТоварыКРеализации КАК ЭтоТоварыКРеализации,
	               |	-ПартииТоваровУСН.Количество КАК Количество,
	               |	-ПартииТоваровУСН.Сумма КАК Сумма,
	               |	-ПартииТоваровУСН.СуммаНДС КАК СуммаНДС
	               |ИЗ
	               |	РегистрНакопления.ПартииТоваровУСН КАК ПартииТоваровУСН
	               |ГДЕ
	               |	ПартииТоваровУСН.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	               |	И ПартииТоваровУСН.Количество < 0
	               |	И ПартииТоваровУСН.Регистратор <> &Ссылка
	               |	И ПартииТоваровУСН.Период < &ДатаДокумента
	               |	И ПартииТоваровУСН.Регистратор ССЫЛКА Документ.ПриходнаяНакладная
	               |	И ПартииТоваровУСН.Номенклатура В(&Номенклатура)";
	
	Партии = Запрос.Выполнить().Выгрузить();

	Возврат Партии;
	
КонецФункции

// Заполняет таблицу движений по регистру ПартииТоваровУСН для отражения оплаты поставщику 
//
// Параметры:
//  Регистратор			 	- ДокументСсылка - документы оплаты (РасходСоСчета, РасходИзКассы и пр.)
//  ВыборкаЗапасы		 	- ВыборкаИзРезультатаЗапроса - выборка остатков партий, которые должны быть оплачены
//  ТаблицаОплаты		 	- ТаблицаЗначений:
//	 * ДокументПартии 		- ДокументСсылка - оплачиваемый документ прихода
//	 * Сумма		        - Число	- сумма оплаты
//  ТаблицаПартииТоваров - 	ТаблицаЗначений - таблица с движениями по регистру ПартииТоваровУСН
//
Процедура ЗаполнитьДвиженияОплатаПартий(Регистратор, ВыборкаЗапасы, ТаблицаОплаты, ТаблицаПартииТоваров) Экспорт
	
	Пока ВыборкаЗапасы.Следующий() Цикл
		
		Ресурсы = Новый Структура("Сумма, СуммаНДС, Количество");
		ЗаполнитьЗначенияСвойств(Ресурсы, ВыборкаЗапасы);
		
		СтрокиОплаты = ТаблицаОплаты.НайтиСтроки(Новый Структура("ДокументПартии", ВыборкаЗапасы.ДокументПартии));
		Для Каждого СтрокаОплаты Из СтрокиОплаты Цикл
			Если СтрокаОплаты.Сумма <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если Ресурсы.Сумма = 0 Тогда
				Прервать;
			КонецЕсли;
			
			СтрокаРасход = ТаблицаПартииТоваров.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРасход, СтрокаОплаты);
			ЗаполнитьЗначенияСвойств(СтрокаРасход, ВыборкаЗапасы);
			СтрокаРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
			                 
			Если СтрокаОплаты.Сумма < Ресурсы.Сумма Тогда
				Коэффициент = ?(Ресурсы.Сумма = 0, 1, СтрокаОплаты.Сумма / Ресурсы.Сумма);
				СтрокаРасход.Количество = Ресурсы.Количество * Коэффициент;
				СтрокаРасход.Сумма = Ресурсы.Сумма * Коэффициент;
				СтрокаРасход.СуммаНДС = Ресурсы.СуммаНДС * Коэффициент;
			Иначе
				СтрокаРасход.Количество = Ресурсы.Количество;
				СтрокаРасход.Сумма = Ресурсы.Сумма;
				СтрокаРасход.СуммаНДС = Ресурсы.СуммаНДС;
			КонецЕсли;
			
			Для Каждого Элемент Из Ресурсы Цикл
				Ресурсы[Элемент.Ключ] = Ресурсы[Элемент.Ключ] - СтрокаРасход[Элемент.Ключ];
			КонецЦикла;
			
			// В КУДиР попадает запись при соблюдении условий:
			// 1. В документе оплаты УчитыватьВНУ = Истина
			// 2. - Либо это товар, который уже был продан/списан и УчитыватьВНУ = Истина в документе продажи/списания
			//    - Либо это материал/услуга - достаточно факта поставки и оплаты
			СтрокаРасход.ОтражатьВКУДиР = СтрокаОплаты.УчитыватьВНУ
				И (НЕ ВыборкаЗапасы.ЭтоТоварыКРеализации
					ИЛИ ВыборкаЗапасы.УчитыватьВНУ И ВыборкаЗапасы.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеОплачено);
			
			СтрокаОплаты.Сумма = СтрокаОплаты.Сумма - СтрокаРасход.Сумма;
			
			Если ВыборкаЗапасы.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеСписаноНеОплачено Тогда
				СтрокаПриход = ТаблицаПартииТоваров.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаПриход, СтрокаРасход);
				СтрокаПриход.ВидДвижения = ВидДвиженияНакопления.Приход;
				СтрокаПриход.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеСписано;
				СтрокаПриход.ДокументРегистрацииВКУДиР = Регистратор;
				СтрокаПриход.УчитыватьВНУ = СтрокаОплаты.УчитыватьВНУ;
				СтрокаПриход.ОтражатьВКУДиР = Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Если по документу не было движений по партиям (создан Вводом остатков), нужно отразить расходы
	// без указания товаров
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПартииТоваровУСНОбороты.ДокументПартии КАК ДокументПартии
	               |ИЗ
	               |	РегистрНакопления.ПартииТоваровУСН.Обороты(
	               |			,
	               |			,
	               |			,
	               |			ДокументПартии В (&ДокументыПартии)
	               |				И ДокументПартии = ДокументРегистрацииВКУДиР) КАК ПартииТоваровУСНОбороты";
	
	Запрос.УстановитьПараметр("ДокументыПартии", ТаблицаОплаты.ВыгрузитьКолонку("ДокументПартии"));
	ДокументыЕстьПартии = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаОплаты Из ТаблицаОплаты Цикл
		Если Неопределено <> ДокументыЕстьПартии.Найти(СтрокаОплаты.ДокументПартии) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Неопределено <> ТаблицаПартииТоваров.Найти(СтрокаОплаты.ДокументПартии) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаПриход = ТаблицаПартииТоваров.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаПриход, СтрокаОплаты);
		СтрокаПриход.ВидДвижения = ВидДвиженияНакопления.Приход;
		СтрокаПриход.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеОплачено;
		СтрокаПриход.Количество = 1;
		СтрокаПриход.ДокументРегистрацииВКУДиР = Регистратор;
		СтрокаПриход.УчитыватьВНУ = СтрокаОплаты.УчитыватьВНУ;
		СтрокаПриход.ОтражатьВКУДиР = Ложь;
		
		СтрокаРасход = ТаблицаПартииТоваров.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаРасход, СтрокаПриход);
		СтрокаРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
		СтрокаРасход.ОтражатьВКУДиР = Истина;
	КонецЦикла;
	
КонецПроцедуры

// Заполняет таблицу движений по регистру ПартииТоваровУСН для отражения расхода со склада (продажа, списание и пр.) 
//
// Параметры:
//  Регистратор			 	- ДокументСсылка - документы расхода (РасходнаяНакладная, СписаниеЗапасов и пр.)
//  ВыборкаПартии		 	- ВыборкаИзРезультатаЗапроса - выборка остатков партий номенклатуры, которые доступны для списания
//  ТаблицаЗапасы		 	- ТаблицаЗначений:
//	 * Номенклатура 		- СправочникСсылка.Номенклатура
//	 * Количество		    - Число
//  ТаблицаПартииТоваров - 	ТаблицаЗначений - таблица с движениями по регистру ПартииТоваровУСН
//
Процедура ЗаполнитьДвиженияСписаниеПартий(Регистратор, ВыборкаПартии, ТаблицаЗапасы, ТаблицаПартииТоваров) Экспорт
	
	ЗапасыРаспределить = ТаблицаЗапасы.Скопировать();
	ЗапасыРаспределить.Колонки.Добавить("Распределено", Новый ОписаниеТипов("Булево"));
	
	Пока ВыборкаПартии.Следующий() Цикл
		Если ВыборкаПартии.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Ресурсы = Новый Структура("Сумма, СуммаНДС, Количество");
		ЗаполнитьЗначенияСвойств(Ресурсы, ВыборкаПартии);
		
		СтрокиЗапасы = ЗапасыРаспределить.НайтиСтроки(Новый Структура("Номенклатура, Распределено", ВыборкаПартии.Номенклатура, Ложь));
		Для Каждого СтрокаЗапас Из СтрокиЗапасы Цикл
			Если СтрокаЗапас.Количество = 0 Тогда
				СтрокаЗапас.Распределено = Истина;
				Продолжить;
			КонецЕсли;
			
			Если Ресурсы.Количество = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаРасход = ТаблицаПартииТоваров.Добавить();
			СтрокаРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
			ЗаполнитьЗначенияСвойств(СтрокаРасход, ВыборкаПартии);
			ЗаполнитьЗначенияСвойств(СтрокаРасход, Ресурсы);
			
			Если СтрокаЗапас.Количество < Ресурсы.Количество Тогда
				Коэффициент = ?(Ресурсы.Количество = 0, 1, СтрокаЗапас.Количество / Ресурсы.Количество);
				СтрокаРасход.Количество = СтрокаЗапас.Количество;
				СтрокаРасход.СуммаНДС = Ресурсы.СуммаНДС * Коэффициент;
				СтрокаРасход.Сумма = Ресурсы.Сумма * Коэффициент;
			КонецЕсли;
			Для Каждого Элемент Из Ресурсы Цикл
				Ресурсы[Элемент.Ключ] = Ресурсы[Элемент.Ключ] - СтрокаРасход[Элемент.Ключ];
			КонецЦикла;
			СтрокаЗапас.Количество = СтрокаЗапас.Количество - СтрокаРасход.Количество;
			СтрокаЗапас.Распределено = (СтрокаЗапас.Количество = 0);

			// В КУДиР попадает запись при соблюдении условий:
			// 1. В документе продажи/списания установлено УчитыватьВНУ = Истина (СтрокаЗапас.УчитыватьВНУ)
			// 2. Товар был оплачен 
			// 3. В документе оплаты установлено УчитыватьВНУ = Истина (СтрокаРасход.УчитыватьВНУ)
			СтрокаРасход.ОтражатьВКУДиР = (СтрокаЗапас.УчитыватьВНУ
				И СтрокаРасход.УчитыватьВНУ
				И (ВыборкаПартии.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеСписано));
			
			Если ВыборкаПартии.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеСписаноНеОплачено Тогда
				СтрокаПриход = ТаблицаПартииТоваров.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаПриход, СтрокаРасход);
				СтрокаПриход.ВидДвижения = ВидДвиженияНакопления.Приход;
				СтрокаПриход.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеОплачено;
				СтрокаПриход.ДокументРегистрацииВКУДиР = Регистратор;
				СтрокаПриход.УчитыватьВНУ = СтрокаЗапас.УчитыватьВНУ;
				СтрокаПриход.ОтражатьВКУДиР = Ложь;
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

// Заполняет таблицу движений по регистру ПартииТоваровУСН для отражения расхода со склада (продажа, списание и пр.) 
//
// Параметры:
//  Регистратор			 	- ДокументСсылка - документы расхода (РасходнаяНакладная, СписаниеЗапасов и пр.)
//  ПроданныеПартии		 	- ВыборкаИзРезультатаЗапроса - выборка партий номенклатуры, которые были ранее проданы
//	ПредыдущиеВозвраты		- см. УчетПартийУСН.ВозвращенныеПартии
//  ТаблицаВозврат		 	- ТаблицаЗначений:
//	 * Номенклатура 		- СправочникСсылка.Номенклатура
//	 * Количество		    - Число
//  ТаблицаПартииТоваров - 	ТаблицаЗначений - таблица с движениями по регистру ПартииТоваровУСН
//
Процедура ЗаполнитьДвиженияВозвратПартийОтПокупателя(Регистратор, ПроданныеПартии, ПредыдущиеВозвраты, ТаблицаВозврат, ТаблицаПартииТоваров) Экспорт
	
	ПоляРесурсов = Новый Массив;
	ПоляРесурсов.Добавить("Количество");
	ПоляРесурсов.Добавить("Сумма");
	ПоляРесурсов.Добавить("СуммаНДС");
	
	ОтборПартии = Новый Структура("ДокументПродажи, Номенклатура");
	
	ОтборВозвраты = Новый Структура;
	Для Каждого Колонка Из ПредыдущиеВозвраты.Колонки Цикл
		Если ПоляРесурсов.Найти(Колонка.Имя) = Неопределено Тогда
			ОтборВозвраты.Вставить(Колонка.Имя, Неопределено);
		КонецЕсли;
	КонецЦикла;
	
	ВсегоРаспределить = ТаблицаВозврат.Итог("Количество");
	Пока ПроданныеПартии.Следующий() И ВсегоРаспределить > 0 Цикл
		
		Ресурсы = Новый Структура();
		Для Каждого ИмяРесурса Из ПоляРесурсов Цикл
			Ресурсы.Вставить(ИмяРесурса, 0);
		КонецЦикла;
		ЗаполнитьЗначенияСвойств(Ресурсы, ПроданныеПартии);
		
		ЗаполнитьЗначенияСвойств(ОтборВозвраты, ПроданныеПартии);
		Возвращенные = ПредыдущиеВозвраты.НайтиСтроки(ОтборВозвраты);
		Для Каждого СтрокаВозврат Из Возвращенные Цикл
			Если СтрокаВозврат.Количество <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Если Ресурсы.Количество > СтрокаВозврат.Количество Тогда
				Коэффициент = СтрокаВозврат.Количество / Ресурсы.Количество;
				Ресурсы.Сумма = Ресурсы.Сумма - Ресурсы.Сумма * Коэффициент;
				Ресурсы.СуммаНДС = Ресурсы.СуммаНДС - Ресурсы.СуммаНДС * Коэффициент;
				Ресурсы.Количество = Ресурсы.Количество - СтрокаВозврат.Количество;
				
				СтрокаВозврат.Количество = 0;
			Иначе
				Ресурсы.Количество = 0;
			КонецЕсли;
		КонецЦикла;
		
		Если Ресурсы.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ОтборПартии, ПроданныеПартии);
		СтрокиЗапасов = ТаблицаВозврат.НайтиСтроки(ОтборПартии);
			
		Для Каждого СтрокаЗапас Из СтрокиЗапасов Цикл
			Если СтрокаЗапас.Количество <= 0 ИЛИ Ресурсы.Количество <= 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаРасход = ТаблицаПартииТоваров.Добавить();
			СтрокаРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
			ЗаполнитьЗначенияСвойств(СтрокаРасход, СтрокаЗапас);
			ЗаполнитьЗначенияСвойств(СтрокаРасход, ПроданныеПартии);
			ЗаполнитьЗначенияСвойств(СтрокаРасход, Ресурсы);
			Если Ресурсы.Количество > СтрокаЗапас.Количество Тогда
				СтрокаРасход.Количество = СтрокаЗапас.Количество;
				Коэффициент = ?(Ресурсы.Количество = 0, 1, СтрокаЗапас.Количество / Ресурсы.Количество);
				СтрокаРасход.СуммаНДС = Ресурсы.СуммаНДС * Коэффициент;
				СтрокаРасход.Сумма = Ресурсы.Сумма * Коэффициент;
			КонецЕсли;
			
			СтрокаЗапас.Количество = СтрокаЗапас.Количество - СтрокаРасход.Количество;
			ВсегоРаспределить = ВсегоРаспределить - СтрокаРасход.Количество;
			
			Для Каждого Элемент Из Ресурсы Цикл
				ИмяРесурса = Элемент.Ключ;
				Ресурсы[ИмяРесурса] = Ресурсы[ИмяРесурса] - СтрокаРасход[ИмяРесурса];
				СтрокаРасход[ИмяРесурса] = - СтрокаРасход[ИмяРесурса];
			КонецЦикла;
			
			Если СтрокаРасход.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеСписаноНеОплачено Тогда
				СтрокаПриход = ТаблицаПартииТоваров.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаПриход, СтрокаРасход);
				СтрокаПриход.ВидДвижения = ВидДвиженияНакопления.Приход;
				СтрокаПриход.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеОплачено;
				СтрокаПриход.ДокументРегистрацииВКУДиР = ПроданныеПартии.ДокументПродажи;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Возврат товара, для которого не найдено партий продажи
	Для Каждого СтрокаЗапас Из ТаблицаВозврат Цикл
		Если СтрокаЗапас.Количество <= 0 Тогда
			Продолжить;
		КонецЕсли;
			
		СтрокаРасход = ТаблицаПартииТоваров.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаРасход, СтрокаЗапас);
		СтрокаРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
		СтрокаРасход.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеСписано;
		СтрокаРасход.Количество = - СтрокаРасход.Количество;
		СтрокаРасход.Сумма = - СтрокаРасход.Сумма;
		СтрокаРасход.СуммаНДС = - СтрокаРасход.СуммаНДС;
		СтрокаРасход.УчитыватьВНУ = Ложь;
		СтрокаРасход.ОтражатьВКУДиР = Ложь;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ВыборкаДокументовДляОбновленияДвиженийПартийТоваровУСН(Организация, ДатаНачала, ДатаОкончания)

	ТекстЗапроса = "ВЫБРАТЬ
	               |	НЕОПРЕДЕЛЕНО КАК Ссылка,
				   |	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка) КАК Организация,
	               |	ДАТАВРЕМЯ(1, 1, 1) КАК Дата,
	               |	ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) КАК ВалютаДокумента,
	               |	1 КАК КурсДокумента,
	               |	1 КАК КратностьДокумента";
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0];

	Для Каждого ТипДокумента Из Метаданные.РегистрыНакопления.ПартииТоваровУСН.СтандартныеРеквизиты.Регистратор.Тип.Типы() Цикл
		Документ = Метаданные.НайтиПоТипу(ТипДокумента);
		Если Документ = Метаданные.Документы.КорректировкаРегистров Тогда
			Продолжить;
		КонецЕсли;
		
		Выбор = ЗапросВыбора.Операторы.Добавить(ЗапросВыбора.Операторы[0]);
		Выбор.ТипОбъединения = ТипОбъединенияСхемыЗапроса.Объединить;
		
		Выбор.Источники.Добавить(Документ.ПолноеИмя(), "ДокументИсточник");
		
		Выбор.ВыбираемыеПоля[0] = Новый ВыражениеСхемыЗапроса("ДокументИсточник.Ссылка");
		Выбор.ВыбираемыеПоля[1] = Новый ВыражениеСхемыЗапроса("ДокументИсточник.Организация");
		Выбор.ВыбираемыеПоля[2] = Новый ВыражениеСхемыЗапроса("ДокументИсточник.Дата");
		
		Если Документ.Реквизиты.Найти("ВалютаДокумента") <> Неопределено Тогда
			Выбор.ВыбираемыеПоля[3] = Новый ВыражениеСхемыЗапроса("ДокументИсточник.ВалютаДокумента");
		ИначеЕсли Документ.Реквизиты.Найти("ВалютаДенежныхСредств") <> Неопределено Тогда
			Выбор.ВыбираемыеПоля[3] = Новый ВыражениеСхемыЗапроса("ДокументИсточник.ВалютаДенежныхСредств");
		КонецЕсли;
		
		Если Документ.Реквизиты.Найти("Курс") <> Неопределено И Документ.Реквизиты.Найти("Кратность") <> Неопределено Тогда
			Выбор.ВыбираемыеПоля[4] = Новый ВыражениеСхемыЗапроса("ДокументИсточник.Курс");
			Выбор.ВыбираемыеПоля[5] = Новый ВыражениеСхемыЗапроса("ДокументИсточник.Кратность");
		КонецЕсли;
		
		Выбор.Отбор.Добавить("ДокументИсточник.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания");
		Выбор.Отбор.Добавить("ДокументИсточник.Проведен");
		Выбор.Отбор.Добавить("ДокументИсточник.Организация = &Организация");
		
		Если Документ = Метаданные.Документы.ЗаказПокупателя Тогда
			Выбор.Отбор.Добавить("ДокументИсточник.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд)");
		КонецЕсли;
		
	КонецЦикла;
	
	ЗапросВыбора.Операторы.Удалить(0);
	ЗапросВыбора.Порядок.Добавить("Организация");
	ЗапросВыбора.Порядок.Добавить("Дата");
	ЗапросВыбора.Порядок.Добавить("Ссылка");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Процедура ОбновитьДвиженияПоРегиструПартииТоваровУСНДокумента(ДанныеДокумента)

	Если ТипЗнч(ДанныеДокумента.Ссылка) = Тип("ДокументСсылка.КорректировкаРегистров") Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерДокумента = ОбщегоНазначения.МенеджерОбъектаПоСсылке(ДанныеДокумента.Ссылка);
	СтруктураДополнительныеСвойства = ПодготовитьДанныеДляОбновленияПартийТоваровУСН(ДанныеДокумента);
	
	Попытка
		ДокументОбъект = ДанныеДокумента.Ссылка.ПолучитьОбъект();
		Если ДокументОбъект.Проведен Тогда
			МенеджерДокумента.СформироватьТаблицаПартииТоваровУСН(ДанныеДокумента.Ссылка, СтруктураДополнительныеСвойства);
			ДокументОбъект.Движения.ПартииТоваровУСН.Записывать = Истина;
			ДокументОбъект.Движения.ПартииТоваровУСН.Загрузить(СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаПартииТоваровУСН);
			ДокументОбъект.Движения.ПартииТоваровУСН.Записать();
			ДокументОбъект.Движения.ПартииТоваровУСН.Записывать = Ложь;
			
			Если ТипЗнч(ДанныеДокумента.Ссылка) <> Тип("ДокументСсылка.ВводНачальныхОстатков") Тогда
				ДокументОбъект.Движения.ОписаниеОперацииКУДиР.Записывать = Истина;
				ДокументОбъект.Движения.ОписаниеОперацииКУДиР.Загрузить(СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаОписаниеОперацииКУДиР);
				ДокументОбъект.Движения.ОписаниеОперацииКУДиР.Записать();
				ДокументОбъект.Движения.ОписаниеОперацииКУДиР.Записывать = Ложь;
			КонецЕсли;
			
		КонецЕсли;
	Исключение
		ЗаголовокОшибки = НСтр("ru = 'Ошибка при обновлении по партиям документа'");
		ТекстОшибки = СтрШаблон("%1 %2: %3", ЗаголовокОшибки, ДанныеДокумента.Ссылка,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

Функция ПодготовитьДанныеДляОбновленияПартийТоваровУСН(ДанныеДокумента)
	
	// Инициализация дополнительных свойств для проведения документа
	СтруктураДополнительныеСвойства = Новый Структура("ВалютаДокумента, КратностьДокумента, КурсДокумента");
	ЗаполнитьЗначенияСвойств(СтруктураДополнительныеСвойства, ДанныеДокумента);
	ПроведениеДокументовУНФ.ИнициализироватьДополнительныеСвойстваДляПроведения(ДанныеДокумента.Ссылка, СтруктураДополнительныеСвойства);
	Если НЕ ЗначениеЗаполнено(СтруктураДополнительныеСвойства.ВалютаДокумента) Тогда
		СтруктураДополнительныеСвойства.ВалютаДокумента = СтруктураДополнительныеСвойства.НациональнаяВалюта;
	КонецЕсли;
	РасчетыПроведениеДокументов.ЗаполнитьКурсВалютыУчетаИРегВалюты(СтруктураДополнительныеСвойства);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасчетыСПоставщиками.Период КАК Дата,
	|	РасчетыСПоставщиками.НомерСтроки КАК НомерСтроки,
	|	РасчетыСПоставщиками.Контрагент КАК Контрагент,
	|	РасчетыСПоставщиками.Документ КАК Документ,
	|	РасчетыСПоставщиками.Сумма КАК Сумма,
	|	РасчетыСПоставщиками.ТипРасчетов КАК ТипРасчетов,
	|	РасчетыСПоставщиками.ДокументОплаты КАК ДокументОплаты
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПоставщиками
	|ИЗ
	|	РегистрНакопления.РасчетыСПоставщиками КАК РасчетыСПоставщиками
	|ГДЕ
	|	РасчетыСПоставщиками.Регистратор = &Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыСПокупателями.Период КАК Дата,
	|	РасчетыСПокупателями.НомерСтроки КАК НомерСтроки,
	|	РасчетыСПокупателями.Контрагент КАК Контрагент,
	|	РасчетыСПокупателями.Документ КАК Документ,
	|	РасчетыСПокупателями.Сумма КАК Сумма,
	|	РасчетыСПокупателями.ТипРасчетов КАК ТипРасчетов,
	|	РасчетыСПокупателями.ДокументОплаты КАК ДокументОплаты
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПокупателями
	|ИЗ
	|	РегистрНакопления.РасчетыСПокупателями КАК РасчетыСПокупателями
	|ГДЕ
	|	РасчетыСПокупателями.Регистратор = &Регистратор";
	
	Запрос.УстановитьПараметр("Регистратор", ДанныеДокумента.Ссылка);
	Запрос.Выполнить();
	
	Возврат СтруктураДополнительныеСвойства;
	
КонецФункции

Функция ОпределитьМинимальнуюДатуНачала()
	
	ДатаПоУмолчанию = '39991231';
	ДатаНачалаДвижений = ДатаПоУмолчанию;
	
	ИменаДокументов = Новый Массив;
	ИменаДокументов.Добавить(Метаданные.Документы.ПриходнаяНакладная.Имя);
	ИменаДокументов.Добавить(Метаданные.Документы.РасходнаяНакладная.Имя);
	ИменаДокументов.Добавить(Метаданные.Документы.ВводНачальныхОстатков.Имя);
	ИменаДокументов.Добавить(Метаданные.Документы.ПоступлениеВКассу.Имя);
	ИменаДокументов.Добавить(Метаданные.Документы.ПоступлениеНаСчет.Имя);
	
	Для Каждого ИмяДокумента Из ИменаДокументов Цикл
		Выборка = Документы[ИмяДокумента].Выбрать(МинимальнаяДатаДокумента(), ДатаНачалаДвижений, , "Дата");
		Если Выборка.Следующий() И Выборка.Дата < ДатаНачалаДвижений Тогда
			ДатаНачалаДвижений = Выборка.Дата;
		КонецЕсли;
	КонецЦикла;		
	
	ИменаРегистров = Новый Массив;
	ИменаРегистров.Добавить(Метаданные.РегистрыНакопления.ЗапасыНаСкладах.Имя);
	ИменаРегистров.Добавить(Метаданные.РегистрыНакопления.ЗакупкиДляКУДиР.Имя);
	ИменаРегистров.Добавить(Метаданные.РегистрыНакопления.Закупки.Имя);

	Для Каждого ИмяРегистра Из ИменаРегистров Цикл
		Выборка = РегистрыНакопления[ИмяРегистра].Выбрать(МинимальнаяДатаДокумента(), ДатаНачалаДвижений);
		Если Выборка.Следующий() И Выборка.Период < ДатаНачалаДвижений Тогда
			ДатаНачалаДвижений = Выборка.Период;
		КонецЕсли;
	КонецЦикла;
	
	Если ДатаНачалаДвижений < ДатаПоУмолчанию Тогда
		Возврат НачалоМесяца(НачалоГода(ДатаНачалаДвижений) - 1);
	Иначе
		Возврат '00010101';
	КонецЕсли;
	
КонецФункции

Процедура СдвинутьГраницуПоследовательностиПартий(Организация, ТекущийМесяц, НарушенПорядок)
	
	НаборЗаписей = РегистрыСведений.ПоследовательностьПартийДляКУДиР.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Организация.Установить(Организация);
	НаборЗаписей.Прочитать();
	
	ДатаДокументаНовая = КонецМесяца(ТекущийМесяц);
	СледующийМесяц = ДатаДокументаНовая + 1;
	
	ЗаписиУдалить = Новый Массив;
	Для Каждого Запись Из НаборЗаписей Цикл
		Если Запись.НачалоМесяца <= СледующийМесяц Тогда
			ЗаписиУдалить.Добавить(Запись);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Запись Из ЗаписиУдалить Цикл
		НаборЗаписей.Удалить(Запись);
	КонецЦикла;
	
	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.Организация = Организация;
	НоваяЗапись.ДатаДокумента = ДатаДокументаНовая;
	НоваяЗапись.НачалоМесяца = СледующийМесяц;
	НоваяЗапись.НарушенПорядок = НарушенПорядок;
	
	НаборЗаписей.Записать();
			
КонецПроцедуры

Процедура УстановитьНачалоПоследовательностиПартий(Организация, ДатаНачала, НарушенПорядок)
	
	НачатьТранзакцию();
	Попытка
		
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.ПоследовательностьПартийДляКУДиР");
		ЭлементБлокировкиДанных.УстановитьЗначение("Организация", Организация);
		ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Разделяемый;
		БлокировкаДанных.Заблокировать();
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ПоследовательностьПартийДляКУДиР.Организация КАК Организация,
		               |	ПоследовательностьПартийДляКУДиР.НачалоМесяца КАК НачалоМесяца
		               |ИЗ
		               |	РегистрСведений.ПоследовательностьПартийДляКУДиР КАК ПоследовательностьПартийДляКУДиР
		               |ГДЕ
		               |	ПоследовательностьПартийДляКУДиР.Организация = &Организация
		               |	И ПоследовательностьПартийДляКУДиР.НачалоМесяца < &НачалоМесяца
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	НачалоМесяца";
		
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("НачалоМесяца", ДатаНачала);
		
		Результат = Запрос.Выполнить();
		Выборка = Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			НаборЗаписей = РегистрыСведений.ПоследовательностьПартийДляКУДиР.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Организация.Установить(Организация);
			НаборЗаписей.Отбор.НачалоМесяца.Установить(Выборка.НачалоМесяца);
			НаборЗаписей.Записать();
		КонецЦикла;

		НоваяЗапись = РегистрыСведений.ПоследовательностьПартийДляКУДиР.СоздатьМенеджерЗаписи();
		НоваяЗапись.Организация = Организация;
		НоваяЗапись.НачалоМесяца = НачалоМесяца(ДатаНачала);
		НоваяЗапись.ДатаДокумента = НоваяЗапись.НачалоМесяца - 1;
		НоваяЗапись.НарушенПорядок = НарушенПорядок;
		НоваяЗапись.Записать();	
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ТекстОшибки(НСтр("ru = 'Обновление партий товаров для КУДиР'"), ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(ИмяСобытияЖурналаРегистрации(), УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Функция ТаблицаДвиженийПоРегистру(Регистр)
	
	НаборЗаписейРегистра = Регистр.СоздатьНаборЗаписей();
	ТаблицаДвижений = НаборЗаписейРегистра.ВыгрузитьКолонки();
	ТаблицаДвижений.Колонки.Удалить("Регистратор");
	ТаблицаДвижений.Колонки.Удалить("НомерСтроки");
	ТаблицаДвижений.Колонки.Удалить("Активность");
	
	Возврат ТаблицаДвижений;
КонецФункции

Функция ТекстЗапросаОстаткиПоПартиям(УсловияТаблицыОстатков, ПоляПорядка)
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	ПартииТоваровОстатки.Организация КАК Организация,
	               |	ПартииТоваровОстатки.Номенклатура КАК Номенклатура,
	               |	ПартииТоваровОстатки.ДокументПартии КАК ДокументПартии,
	               |	ПартииТоваровОстатки.ДокументРегистрацииВКУДиР КАК ДокументРегистрацииВКУДиР,
	               |	ПартииТоваровОстатки.СтатусРасхода КАК СтатусРасхода,
	               |	ПартииТоваровОстатки.КоличествоОстаток КАК Количество,
	               |	ПартииТоваровОстатки.СуммаОстаток КАК Сумма,
	               |	ПартииТоваровОстатки.СуммаНДСОстаток КАК СуммаНДС,
	               |	ПартииТоваровОстатки.НомерСтрокиДокумента КАК НомерСтрокиДокумента,
	               |	ПартииТоваровОстатки.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	ПартииТоваровОстатки.ЭтоТоварыКРеализации КАК ЭтоТоварыКРеализации
	               |ПОМЕСТИТЬ ВТОстаткиКСписанию
	               |ИЗ
	               |	РегистрНакопления.ПартииТоваровУСН.Остатки(&МоментВремени, ) КАК ПартииТоваровОстатки
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	ВТОстатки.ДокументПартии КАК ДокументПартии,
				   |	МИНИМУМ(ПартииТоваровУСН.Период) КАК Период
				   |ПОМЕСТИТЬ ВТДатыПоступленияПартии
				   |ИЗ
				   |	ВТОстаткиКСписанию КАК ВТОстатки
				   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПартииТоваровУСН КАК ПартииТоваровУСН
				   |		ПО ПартииТоваровУСН.Период <= &Период
				   |			И ПартииТоваровУСН.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
				   |			И ВТОстатки.ДокументПартии = ПартииТоваровУСН.ДокументПартии
				   |
				   |СГРУППИРОВАТЬ ПО
				   |	ВТОстатки.ДокументПартии
				   |;	
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	&Период КАК Период,
	               |	ВТОстаткиКСписанию.Организация КАК Организация,
	               |	ВТОстаткиКСписанию.Номенклатура КАК Номенклатура,
	               |	ВТОстаткиКСписанию.ДокументПартии КАК ДокументПартии,
	               |	ВТОстаткиКСписанию.ДокументРегистрацииВКУДиР КАК ДокументРегистрацииВКУДиР,
	               |	ВТОстаткиКСписанию.СтатусРасхода КАК СтатусРасхода,
	               |	ВТОстаткиКСписанию.Количество КАК Количество,
	               |	ВТОстаткиКСписанию.Сумма КАК Сумма,
	               |	ВТОстаткиКСписанию.СуммаНДС КАК СуммаНДС,
	               |	ЕСТЬNULL(ВТДатыПоступленияПартии.Период, ДАТАВРЕМЯ(3999, 12, 31)) КАК ДатаПоступления,
	               |	ВТОстаткиКСписанию.НомерСтрокиДокумента КАК НомерСтрокиДокумента,
	               |	ВТОстаткиКСписанию.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	ВТОстаткиКСписанию.ЭтоТоварыКРеализации КАК ЭтоТоварыКРеализации,
	               |	СтатусыРасходовУСН.Порядок КАК СтатусРасходаПорядок
	               |ИЗ
	               |	ВТОстаткиКСписанию КАК ВТОстаткиКСписанию
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТДатыПоступленияПартии КАК ВТДатыПоступленияПартии
	               |		ПО ВТОстаткиКСписанию.ДокументПартии = ВТДатыПоступленияПартии.ДокументПартии
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Перечисление.СтатусыРасходовУСН КАК СтатусыРасходовУСН
	               |		ПО ВТОстаткиКСписанию.СтатусРасхода = СтатусыРасходовУСН.Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |УНИЧТОЖИТЬ ВТОстаткиКСписанию
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |УНИЧТОЖИТЬ ВТДатыПоступленияПартии";
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	ЗапросОстатки = СхемаЗапроса.ПакетЗапросов[0];
	ВыборОстатки = ЗапросОстатки.Операторы[0];
	ТаблицаОстатки = ВыборОстатки.Источники[0];
	ТекстУсловияТаблицы = СтрСоединить(УсловияТаблицыОстатков, Символы.ПС + "И ");
	ТаблицаОстатки.Источник.Параметры[1].Выражение = Новый ВыражениеСхемыЗапроса(ТекстУсловияТаблицы);
	
	ЗапросРезультат = СхемаЗапроса.ПакетЗапросов[СхемаЗапроса.ПакетЗапросов.Количество() - 3];
	Для Каждого СтрокаПорядка Из ПоляПорядка Цикл
		ЧастиВыражения = СтрРазделить(СтрокаПорядка, " ", Ложь);
		Если ЧастиВыражения.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Выражение = ЗапросРезультат.Порядок.Добавить(ЧастиВыражения[0]);
		Если ЧастиВыражения.Количество() = 2 И ЧастиВыражения[1] = "УБЫВ" Тогда
			Выражение.Направление = НаправлениеПорядкаСхемыЗапроса.ПоУбыванию;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СхемаЗапроса.ПолучитьТекстЗапроса();
	
КонецФункции

Функция ИмяСобытияЖурналаРегистрации()
	
