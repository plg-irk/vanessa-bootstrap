// Распределяет сумму по колонке таблицы.
Процедура РаспределитьСуммуНаЦены(Таблица, ИмяКолонки, СуммаРаспределения, ПараметрыОтбора = Неопределено)
	
	Если Таблица.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СуммаОсталосьРаспределить = СуммаРаспределения;
	ПриводитьКМинимальным 	= ЦенообразованиеСерверПовтИсп.МинимальныеЦеныИспользуются()
								И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "МинимальнаяЦена");
	ЕстьСкидкаБонусом 		= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "СуммаСкидкиОплатыБонусом");
	ЕстьАвтоматическаяСкидка= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "СуммаАвтоматическойСкидки");
	ЕстьРучнаяСкидка 		= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "СуммаСкидкиНаценки");
							
	ЭтоЗаказПокупателяИлиРасходная = ТипЗнч(Таблица) = Тип("ДокументТабличнаяЧасть.ЗаказПокупателя.Запасы")
								ИЛИ ТипЗнч(Таблица) = Тип("ДокументТабличнаяЧасть.РасходнаяНакладная.Запасы");

	// Посчитаем общую сумму помеченных позиций                                
	
	ОбщаяСуммаВозможнойСкидки = 0;
	ОставшаясяСуммаДокумента = 0;
	ОбщаяМинимальнаяСумма = 0;
	СтрокиТоваров = Новый ТаблицаЗначений();
	СтрокиТоваров.Колонки.Добавить("СуммаДоступнойСкидки", Новый ОписаниеТипов("Число"));
	СтрокиТоваров.Колонки.Добавить("СсылкаНаСтрокуТаблицы");
	
	Для каждого СтрокаТабличнойЧасти Из Таблица Цикл
		
		Если ПараметрыОтбора <> Неопределено Тогда
			Если НЕ ОбщегоНазначенияУНФКлиентСервер.ОбъектСоответствуетПараметрамОтбора(СтрокаТабличнойЧасти, ПараметрыОтбора) Тогда
				Продолжить;
			КонецЕсли;
		ИначеЕсли СтрокаТабличнойЧасти.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Цена = СтрокаТабличнойЧасти.Цена;		
		СуммаДоВсехСкидок = Цена * СтрокаТабличнойЧасти.Количество;
		Если СуммаДоВсехСкидок = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЭтоЗаказПокупателяИлиРасходная Тогда
			СуммаДоВсехСкидок = СуммаДоВсехСкидок 
			* ?(СтрокаТабличнойЧасти.Свойство("Кратность"), СтрокаТабличнойЧасти.Кратность, 1) 
			* ?(СтрокаТабличнойЧасти.Свойство("Коэффициент"), СтрокаТабличнойЧасти.Коэффициент, 1);
		КонецЕсли;

		МаксимальноеУменьшениеСуммы = 0;
		МинимальнаяСуммаПоСтроке = 0;
		Если ПриводитьКМинимальным И СтрокаТабличнойЧасти.МинимальнаяЦена>0 Тогда
			
			МинимальнаяСуммаПоСтроке = СтрокаТабличнойЧасти.МинимальнаяЦена * СтрокаТабличнойЧасти.Количество;
			Если НЕ ЭтоЗаказПокупателяИлиРасходная Тогда
				МинимальнаяСуммаПоСтроке = МинимальнаяСуммаПоСтроке
				* ?(СтрокаТабличнойЧасти.Свойство("Кратность"), СтрокаТабличнойЧасти.Кратность, 1) 
				* ?(СтрокаТабличнойЧасти.Свойство("Коэффициент"), СтрокаТабличнойЧасти.Коэффициент, 1);
			КонецЕсли;
		КонецЕсли;
		ОбщийПроцентСкидок = 100 * (?(ЕстьАвтоматическаяСкидка, СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки, 0)
			+ ?(ЕстьРучнаяСкидка, СтрокаТабличнойЧасти.СуммаСкидкиНаценки, 0)) / СуммаДоВсехСкидок;
		Если ОбщийПроцентСкидок = 100 Тогда
			МаксимальноеУменьшениеСуммы = 0;
		Иначе//Если ОбщийПроцентСкидок = 0 Тогда
			МаксимальноеУменьшениеСуммы = СтрокаТабличнойЧасти.Сумма - МинимальнаяСуммаПоСтроке;
		КонецЕсли;
		
		Если МаксимальноеУменьшениеСуммы > 0 Тогда
			НовыйУказательСтроки = СтрокиТоваров.Добавить();
			НовыйУказательСтроки.СсылкаНаСтрокуТаблицы = СтрокаТабличнойЧасти;
			НовыйУказательСтроки.СуммаДоступнойСкидки = МаксимальноеУменьшениеСуммы;
			ОбщаяСуммаВозможнойСкидки = ОбщаяСуммаВозможнойСкидки + МаксимальноеУменьшениеСуммы;
			ОставшаясяСуммаДокумента = ОставшаясяСуммаДокумента + СтрокаТабличнойЧасти.Сумма;
			ОбщаяМинимальнаяСумма = ОбщаяМинимальнаяСумма + МинимальнаяСуммаПоСтроке;
		КонецЕсли;
		
	КонецЦикла;
	
	СтрокиТоваров.Сортировать("СуммаДоступнойСкидки Возр");
	
	ОбщаяСуммаСкидки = 0;
	ПоследняяСтрока = Неопределено;
	Для каждого УказательСтроки Из СтрокиТоваров Цикл
		
		Если УказательСтроки.СуммаДоступнойСкидки = 0 Тогда
			Продолжить;
		КонецЕсли;
		СтрокаТабличнойЧасти = УказательСтроки.СсылкаНаСтрокуТаблицы;
		МаксимальнаяСуммаСкидки = УказательСтроки.СуммаДоступнойСкидки;
		
		СуммаСУчетомВсехСкидок = СтрокаТабличнойЧасти.Сумма;
		СуммаДоВсехСкидок = СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.Количество;
		Если НЕ ЭтоЗаказПокупателяИлиРасходная Тогда
			СуммаДоВсехСкидок = СуммаДоВсехСкидок 
				* ?(СтрокаТабличнойЧасти.Свойство("Кратность"), СтрокаТабличнойЧасти.Кратность, 1) 
				* ?(СтрокаТабличнойЧасти.Свойство("Коэффициент"), СтрокаТабличнойЧасти.Коэффициент, 1);
		КонецЕсли;
 		ОбщийПроцентСкидок = 100 * (?(ЕстьАвтоматическаяСкидка, СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки, 0)
			+ ?(ЕстьРучнаяСкидка, СтрокаТабличнойЧасти.СуммаСкидкиНаценки, 0)) / СуммаДоВсехСкидок;

		ПроцентУменьшения = СуммаОсталосьРаспределить / ОставшаясяСуммаДокумента * 100;
		Если ПроцентУменьшения > 100 Тогда
			ПроцентУменьшения = 100;
		КонецЕсли;
		ОставшаясяСуммаДокумента = ОставшаясяСуммаДокумента - СтрокаТабличнойЧасти.Сумма;
		СуммаНеобходимоУменьшить = Мин(СтрокаТабличнойЧасти.Сумма * ПроцентУменьшения / 100, МаксимальнаяСуммаСкидки);
		
		НоваяСуммаСУчетомВсехСкидок = СтрокаТабличнойЧасти.Сумма - Мин(СуммаНеобходимоУменьшить, МаксимальнаяСуммаСкидки);
		НоваяСуммаДоВсехСкидок =Окр(НоваяСуммаСУчетомВсехСкидок / ((100 - ОбщийПроцентСкидок) / 100), 2);
		НоваяЦена = НоваяСуммаДоВсехСкидок / СтрокаТабличнойЧасти.Количество;
		Если НЕ ЭтоЗаказПокупателяИлиРасходная Тогда
			НоваяЦена = НоваяЦена /
				?(СтрокаТабличнойЧасти.Свойство("Кратность"), СтрокаТабличнойЧасти.Кратность, 1) /
				?(СтрокаТабличнойЧасти.Свойство("Коэффициент"), СтрокаТабличнойЧасти.Коэффициент, 1);
		КонецЕсли;
		СтрокаТабличнойЧасти.Цена = НоваяЦена;
		СтрокаТабличнойЧасти.Пометка = Истина;
		
		ДоступныйОстатокСкидки = Окр(НоваяСуммаДоВсехСкидок * ОбщийПроцентСкидок / 100, 2) + ?(ЕстьСкидкаБонусом, СтрокаТабличнойЧасти.СуммаСкидкиОплатыБонусом, 0);
		СуммаВсехСкидок = 0;
		Если ЕстьАвтоматическаяСкидка Тогда
			Если НоваяСуммаДоВсехСкидок > 0 Тогда
				ПроцентАвтоматическойСкидки = 100 * СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки / СуммаДоВсехСкидок;  
				СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки = Мин(ДоступныйОстатокСкидки, Окр(НоваяСуммаДоВсехСкидок * ПроцентАвтоматическойСкидки / 100, 2));
				СтрокаТабличнойЧасти.ПроцентАвтоматическойСкидки = Окр(100 * СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки / НоваяСуммаДоВсехСкидок, 2); 
			Иначе
				СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки = 0;
				СтрокаТабличнойЧасти.ПроцентАвтоматическойСкидки = 0; 
			КонецЕсли;
			ДоступныйОстатокСкидки = ДоступныйОстатокСкидки - СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки;
			СуммаВсехСкидок = СуммаВсехСкидок + СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки;
		КонецЕсли;
		Если ЕстьРучнаяСкидка Тогда
			Если НоваяСуммаДоВсехСкидок > 0 Тогда
				СтрокаТабличнойЧасти.СуммаСкидкиНаценки = Мин(ДоступныйОстатокСкидки, Окр(НоваяСуммаДоВсехСкидок * СтрокаТабличнойЧасти.ПроцентСкидкиНаценки / 100, 2));
				СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = Окр(100 * СтрокаТабличнойЧасти.СуммаСкидкиНаценки / НоваяСуммаДоВсехСкидок, 2); 
			Иначе
				СтрокаТабличнойЧасти.СуммаСкидкиНаценки = 0;
				СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 0; 
			КонецЕсли;
			ДоступныйОстатокСкидки = ДоступныйОстатокСкидки - СтрокаТабличнойЧасти.СуммаСкидкиНаценки;
			СуммаВсехСкидок = СуммаВсехСкидок + СтрокаТабличнойЧасти.СуммаСкидкиНаценки;
		КонецЕсли;
		Если ЕстьСкидкаБонусом Тогда
			ДоступныйОстатокСкидки = ДоступныйОстатокСкидки - СтрокаТабличнойЧасти.СуммаСкидкиОплатыБонусом;
			СуммаВсехСкидок = СуммаВсехСкидок + СтрокаТабличнойЧасти.СуммаСкидкиОплатыБонусом;
		КонецЕсли;
		СтрокаТабличнойЧасти.Сумма = НоваяСуммаДоВсехСкидок - СуммаВсехСкидок;
		ФактическаяСуммаСкидки =  СуммаСУчетомВсехСкидок - СтрокаТабличнойЧасти.Сумма;
		
		СуммаОсталосьРаспределить = СуммаОсталосьРаспределить - ФактическаяСуммаСкидки;
	КонецЦикла;
	
	Если СуммаОсталосьРаспределить > 0 И ПриводитьКМинимальным И ОбщаяМинимальнаяСумма > 0 Тогда 
		ТекстСообщения = НСтр("ru = 'Не удалось применить назначенную скидку в связи с установленными минимальными ценами: Сумма документа не может быть меньше %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбщаяМинимальнаяСумма);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;	
КонецПроцедуры

// Распределяет сумму по колонке таблицы.
Процедура РаспределитьСуммуНаСкидки(Таблица, ИмяКолонки, СуммаРаспределения, ПараметрыОтбора = Неопределено)
	
	Если Таблица.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СуммаОсталосьРаспределить = СуммаРаспределения;
	ПриводитьКМинимальным = ЦенообразованиеСерверПовтИсп.МинимальныеЦеныИспользуются()
							И Таблица.Количество()>0
							И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "МинимальнаяЦена");
							
	ЭтоЗаказПокупателяИлиРасходная = ТипЗнч(Таблица) = Тип("ДокументТабличнаяЧасть.ЗаказПокупателя.Запасы")
								ИЛИ ТипЗнч(Таблица) = Тип("ДокументТабличнаяЧасть.РасходнаяНакладная.Запасы");

	// Посчитаем общую сумму помеченных позиций
	ОбщаяСуммаВозможнойРучнойСкидки = 0;
	ОставшаясяСуммаДокумента = 0;
	ОбщаяМинимальнаяСумма = 0;
	СтрокиТоваров = Новый ТаблицаЗначений();
	СтрокиТоваров.Колонки.Добавить("СуммаДоступнойСкидки", Новый ОписаниеТипов("Число"));
	СтрокиТоваров.Колонки.Добавить("СсылкаНаСтрокуТаблицы");
	
	ЕстьСкидкаБонусом 		= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "СуммаСкидкиОплатыБонусом");
	ЕстьАвтоматическаяСкидка= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "СуммаАвтоматическойСкидки");
	ЕстьРучнаяСкидка 		= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "СуммаСкидкиНаценки");
 	ЕстьПродажаПодарка 		= ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Таблица[0], "ПродажаПодарка");

	Для каждого СтрокаТабличнойЧасти Из Таблица Цикл
		
		Цена = СтрокаТабличнойЧасти.Цена;		

		Если ПараметрыОтбора <> Неопределено Тогда
			Если НЕ ОбщегоНазначенияУНФКлиентСервер.ОбъектСоответствуетПараметрамОтбора(СтрокаТабличнойЧасти, ПараметрыОтбора) Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если ЕстьПродажаПодарка И СтрокаТабличнойЧасти.ПродажаПодарка Тогда
			Продолжить;
		КонецЕсли;
		
		СуммаОплатБонусом = ?(ЕстьСкидкаБонусом, СтрокаТабличнойЧасти.СуммаСкидкиОплатыБонусом, 0); 
		СуммаРучныхСкидок = ?(ЕстьРучнаяСкидка, СтрокаТабличнойЧасти.СуммаСкидкиНаценки, 0);	
		СуммаАвтоматическихСкидок = ?(ЕстьАвтоматическаяСкидка, СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки, 0);
		СуммаСкидок = СуммаРучныхСкидок + СуммаАвтоматическихСкидок + СуммаОплатБонусом;
		СуммаДоВсехСкидок = 0;
		Если ЭтоЗаказПокупателяИлиРасходная Тогда	
			СуммаДоВсехСкидок = Цена * СтрокаТабличнойЧасти.Количество;
		Иначе
			СуммаДоВсехСкидок = Цена * СтрокаТабличнойЧасти.Количество 
			* ?(СтрокаТабличнойЧасти.Свойство("Кратность"), СтрокаТабличнойЧасти.Кратность, 1) 
			* ?(СтрокаТабличнойЧасти.Свойство("Коэффициент"), СтрокаТабличнойЧасти.Коэффициент, 1);
		КонецЕсли;
		СуммаДоРучнойСкидки = СуммаДоВсехСкидок - СуммаОплатБонусом - СуммаАвтоматическихСкидок;		

		
		МаксимальнаяРучнаяСкидка = СуммаДоРучнойСкидки;
		МинимальнаяСуммаПоСтроке = 0;
		Если ПриводитьКМинимальным И СтрокаТабличнойЧасти.МинимальнаяЦена>0 Тогда
			
			Если ЭтоЗаказПокупателяИлиРасходная Тогда
				МинимальнаяСуммаПоСтроке = СтрокаТабличнойЧасти.МинимальнаяЦена * СтрокаТабличнойЧасти.Количество;
			Иначе
				МинимальнаяСуммаПоСтроке = СтрокаТабличнойЧасти.МинимальнаяЦена * СтрокаТабличнойЧасти.Количество
				* ?(СтрокаТабличнойЧасти.Свойство("Кратность"), СтрокаТабличнойЧасти.Кратность, 1) 
				* ?(СтрокаТабличнойЧасти.Свойство("Коэффициент"), СтрокаТабличнойЧасти.Коэффициент, 1);
			КонецЕсли;
			
			МаксимальнаяРучнаяСкидка = СуммаДоРучнойСкидки - МинимальнаяСуммаПоСтроке;
			
		КонецЕсли;               				
		
		ОбщаяСуммаВозможнойРучнойСкидки = ОбщаяСуммаВозможнойРучнойСкидки + МаксимальнаяРучнаяСкидка;
		ОставшаясяСуммаДокумента = ОставшаясяСуммаДокумента + СуммаДоВсехСкидок;
		НовыйУказательСтроки = СтрокиТоваров.Добавить();
		НовыйУказательСтроки.СсылкаНаСтрокуТаблицы = СтрокаТабличнойЧасти;
		НовыйУказательСтроки.СуммаДоступнойСкидки = МаксимальнаяРучнаяСкидка;
		
		ОбщаяМинимальнаяСумма = ОбщаяМинимальнаяСумма + МинимальнаяСуммаПоСтроке;
		
	КонецЦикла;
	
	СтрокиТоваров.Сортировать("СуммаДоступнойСкидки Возр");
	
	ОбщаяСуммаСкидки = 0;
	ПоследняяСтрока = Неопределено;
	Для каждого УказательСтроки Из СтрокиТоваров Цикл
		
		СтрокаТабличнойЧасти = УказательСтроки.СсылкаНаСтрокуТаблицы;
		МаксимальнаяСуммаРучнойСкидки = УказательСтроки.СуммаДоступнойСкидки;
		
		Если ПараметрыОтбора <> Неопределено Тогда
			Если НЕ ОбщегоНазначенияУНФКлиентСервер.ОбъектСоответствуетПараметрамОтбора(СтрокаТабличнойЧасти, ПараметрыОтбора) Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		ПроцентСкидки = СуммаОсталосьРаспределить / ОставшаясяСуммаДокумента * 100;
		
		ЕстьСкидкаБонусом = СтрокаТабличнойЧасти.Свойство("СуммаСкидкиОплатыБонусом");
		ЕстьАвтоматическаяСкидка = СтрокаТабличнойЧасти.Свойство("СуммаАвтоматическойСкидки");
		ЕстьРучнаяСкидка = СтрокаТабличнойЧасти.Свойство("СуммаСкидкиНаценки");
		
		СуммаОплатБонусом = ?(ЕстьСкидкаБонусом, СтрокаТабличнойЧасти.СуммаСкидкиОплатыБонусом, 0); 
		СуммаРучныхСкидок = ?(ЕстьРучнаяСкидка, СтрокаТабличнойЧасти.СуммаСкидкиНаценки, 0);	
		СуммаАвтоматическихСкидок = ?(ЕстьАвтоматическаяСкидка, СтрокаТабличнойЧасти.СуммаАвтоматическойСкидки, 0);
		СуммаСкидок = СуммаРучныхСкидок + СуммаАвтоматическихСкидок + СуммаОплатБонусом;
		СуммаДоВсехСкидок = СтрокаТабличнойЧасти.Цена * СтрокаТабличнойЧасти.Количество 
			* ?(СтрокаТабличнойЧасти.Свойство("Кратность"), СтрокаТабличнойЧасти.Кратность, 1) 
			* ?(СтрокаТабличнойЧасти.Свойство("Коэффициент"), СтрокаТабличнойЧасти.Коэффициент, 1);
		СуммаДоРучнойСкидки = СуммаДоВсехСкидок - СуммаОплатБонусом - СуммаАвтоматическихСкидок;
		
		НоваяСуммаРучнойСкидки = Окр(Мин(СуммаДоВсехСкидок * ПроцентСкидки / 100, МаксимальнаяСуммаРучнойСкидки), 2);
 		СуммаСкидок = СуммаАвтоматическихСкидок + СуммаОплатБонусом + НоваяСуммаРучнойСкидки;
		
		СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = Окр(100 * НоваяСуммаРучнойСкидки / СуммаДоВсехСкидок, 2);
		Если ЭтоЗаказПокупателяИлиРасходная Тогда
			СтрокаТабличнойЧасти.СуммаСкидкиНаценки = НоваяСуммаРучнойСкидки;
		Иначе
			Если СтрокаТабличнойЧасти.Свойство("СуммаСкидкиНаценки") Тогда
				СтрокаТабличнойЧасти.СуммаСкидкиНаценки = НоваяСуммаРучнойСкидки;
			КонецЕсли;
			СтрокаТабличнойЧасти.Пометка = Истина;
		КонецЕсли;
		СтрокаТабличнойЧасти.Сумма = СуммаДоВсехСкидок - СуммаСкидок;
		
		ПоследняяСтрока = СтрокаТабличнойЧасти;
		СуммаОсталосьРаспределить = СуммаОсталосьРаспределить - СтрокаТабличнойЧасти.СуммаСкидкиНаценки;
		ОставшаясяСуммаДокумента = ОставшаясяСуммаДокумента - СуммаДоВсехСкидок;
		
	КонецЦикла;
	
	Если СуммаОсталосьРаспределить > 0 И ПриводитьКМинимальным И ОбщаяМинимальнаяСумма > 0 Тогда 
		ТекстСообщения = НСтр("ru = 'Не удалось применить назначенную скидку в связи с установленными минимальными ценами: Сумма документа не может быть меньше %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбщаяМинимальнаяСумма);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура УстановитьСвязиПараметровВыбора(НаборЭлементов) Экспорт
	
	Если НаборЭлементов.КолонкаОбъектИзменений <> Неопределено Тогда
		НаборЭлементов.ЗначениеЭлемент.СвязиПараметровВыбора = НаборЭлементов.КолонкаОбъектИзменений.СвязиПараметровВыбора;
	Иначе
		НаборЭлементов.ЗначениеЭлемент.СвязиПараметровВыбора = Новый ФиксированныйМассив(Новый Массив);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
