
#Область СлужебныйПрограммныйИнтерфейс

// Данные для формирования сообщения обсуждения
// 
// Параметры:
//  НомерТелефона - Строка - Номер телефона в международном формате
// 
// Возвращаемое значение:
//  См. ДанныеИнтеграции
Функция ДанныеИнтеграцииWhatsAppСАбонентом(НомерТелефона) Экспорт
	
	Обсуждение = Неопределено;
	
	ОбсужденияДоступны = Ложь;
	ИнтеграцияWhatsAppДоступна = Ложь;
	ИнтеграцияWhatsAppНастроена = Ложь;
	ДоступныИнтеграцииСПользователем = Ложь;
	
	ИнтеграцииWhatsApp = Новый СписокЗначений;
	ИнтеграцииWhatsAppСПользователем = Новый Массив;

	УстановитьПривилегированныйРежим(Истина);
	
	ОбсужденияДоступны = Обсуждения.СистемаВзаимодействийПодключена();
	Если ОбсужденияДоступны Тогда
		
		ТипыВнешнихСистем = СистемаВзаимодействия.ПолучитьТипыВнешнихСистем();
		
		ТипВнешнейИнтеграцииWhatsApp = МессенджерыКлиентСервер.ТипВнешнийСистемыWhatsApp();
		ИнтеграцияWhatsAppДоступна = ТипыВнешнихСистем.Найти(ТипВнешнейИнтеграцииWhatsApp) <> Неопределено;
		
		Если ИнтеграцияWhatsAppДоступна Тогда
		
			ДанныеИнтеграцийWhatsApp = ИнтеграцииWhatsApp();
			
			ИнтеграцииWhatsApp = ДанныеИнтеграцийWhatsApp.АктивныеИнтеграции;
			ИнтеграцииWhatsAppСПользователем = ДанныеИнтеграцийWhatsApp.АктивныеИнтеграцииСПользователем;
			ИнтеграцияWhatsAppНастроена = ДанныеИнтеграцийWhatsApp.АктивныеИнтеграции.Количество() > 0;
			ДоступныИнтеграцииСПользователем =
				ДанныеИнтеграцийWhatsApp.АктивныеИнтеграцииСПользователем.Количество() > 0;
				
			Если ДоступныИнтеграцииСПользователем 
				И ДанныеИнтеграцийWhatsApp.АктивныеИнтеграцииСПользователем.Количество() = 1 Тогда
				
				Обсуждение = ОбсуждениеИнтеграцииСЗаголовком(ИнтеграцииWhatsApp[0].Значение, НомерТелефона);
				
			КонецЕсли;									
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ОбнаруженаОшибка = Не ОбсужденияДоступны Или Не ИнтеграцияWhatsAppДоступна Или Не ИнтеграцияWhatsAppНастроена
		Или Не ДоступныИнтеграцииСПользователем;

	ДанныеИнтеграции = ДанныеИнтеграции();
	ДанныеИнтеграции.ОбнаруженаОшибка                 = ОбнаруженаОшибка;
	ДанныеИнтеграции.ОбсужденияДоступны               = ОбсужденияДоступны;
	ДанныеИнтеграции.ИнтеграцияWhatsAppДоступна       = ИнтеграцияWhatsAppДоступна;
	ДанныеИнтеграции.ИнтеграцияWhatsAppНастроена      = ИнтеграцияWhatsAppНастроена;
	ДанныеИнтеграции.ДоступныИнтеграцииСПользователем = ДоступныИнтеграцииСПользователем;
	ДанныеИнтеграции.Интеграции                       = ИнтеграцииWhatsApp;
	ДанныеИнтеграции.ИнтеграцииСПользователем         = ИнтеграцииWhatsAppСПользователем;
	ДанныеИнтеграции.Обсуждение                       = Обсуждение;
	ДанныеИнтеграции.ВнешнийИдентификатор             = НомерТелефона;
		
	Возврат ДанныеИнтеграции;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Данные интеграции.
// 
// Возвращаемое значение:
//  Структура - Данные интеграции:
// * ОбнаруженаОшибка - Булево
// * ОбсужденияДоступны - Булево 
// * ИнтеграцияWhatsAppДоступна - Булево
// * ИнтеграцияWhatsAppНастроена - Булево
// * ДоступныИнтеграцииСПользователем - Булево
// * ТекстОшибки - ФорматированнаяСтрока 
// * Интеграции - СписокЗначений из ЭлементСпискаЗначений
// * ИнтеграцииСПользователем - Массив из ИдентификаторИнтеграцииСистемыВзаимодействия
// * Обсуждение - Неопределено, ИдентификаторОбсужденияСистемыВзаимодействия - Идентификатор обсуждения 
// * ВнешнийИдентификатор - Строка
Функция ДанныеИнтеграции()

	ТекстОшибки = СтроковыеФункции.ФорматированнаяСтрока("");
	
	ДанныеИнтеграции = Новый Структура;
	ДанныеИнтеграции.Вставить("ОбнаруженаОшибка",                 Истина);
	ДанныеИнтеграции.Вставить("ОбсужденияДоступны",               Ложь);
	ДанныеИнтеграции.Вставить("ИнтеграцияWhatsAppДоступна",       Ложь);
	ДанныеИнтеграции.Вставить("ИнтеграцияWhatsAppНастроена",      Ложь);
	ДанныеИнтеграции.Вставить("ДоступныИнтеграцииСПользователем", Ложь);
	ДанныеИнтеграции.Вставить("ТекстОшибки",                      ТекстОшибки);
	ДанныеИнтеграции.Вставить("Интеграции",                       Новый СписокЗначений);
	ДанныеИнтеграции.Вставить("ИнтеграцииСПользователем",         Новый Массив);
	ДанныеИнтеграции.Вставить("Обсуждение",                       Неопределено);
	ДанныеИнтеграции.Вставить("ВнешнийИдентификатор",             "");

	Возврат ДанныеИнтеграции;
			
КонецФункции

// Возвращает список активных интеграций WhatsApp и список активных интеграций WhatsApp, участником которых
// является авторизованный пользователь.
// 
// Возвращаемое значение:
//  Структура:
//   * АктивныеИнтеграции - СписокЗначений из ЭлементСпискаЗначений - Список активных интеграций WhatsApp.
//   * АктивныеИнтеграцииСПользователем - Массив из ИдентификаторИнтеграцииСистемыВзаимодействия - Список 
//       идентификаторов активных интеграций WhatsApp, в которых участвует авторизованный пользователь.
//   
Функция ИнтеграцииWhatsApp()
	
	АктивныеИнтеграции = Новый СписокЗначений;
	АктивныеИнтеграцииСПользователем = Новый Массив;
	
	ТипВнешнейИнтеграцииWhatsApp = МессенджерыКлиентСервер.ТипВнешнийСистемыWhatsApp();

	УстановитьПривилегированныйРежим(Истина);
	
	ИнтеграцииСистемыВзаимодействия = ОбсужденияУНФ.ИнтеграцииСистемыВзаимодействия();
	
	АвторизованныйПользовательСВ = Обсуждения.ПользовательСистемыВзаимодействия(
		Пользователи.АвторизованныйПользователь(), Истина);
		
	Для Каждого ИнтеграцияСистемыВзаимодействия Из ИнтеграцииСистемыВзаимодействия Цикл
		
		Если ИнтеграцияСистемыВзаимодействия.Использование
			И ИнтеграцияСистемыВзаимодействия.ТипВнешнейСистемы = ТипВнешнейИнтеграцииWhatsApp Тогда
		
			АктивныеИнтеграции.Добавить(ИнтеграцияСистемыВзаимодействия.Идентификатор, 
				ИнтеграцияСистемыВзаимодействия.Представление);
			
			ПользовательЯвляетсяУчастником = ИнтеграцияСистемыВзаимодействия.Участники.Содержит(
				АвторизованныйПользовательСВ);
				
			Если ПользовательЯвляетсяУчастником Тогда
				АктивныеИнтеграцииСПользователем.Добавить(ИнтеграцияСистемыВзаимодействия.Идентификатор);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("АктивныеИнтеграции", АктивныеИнтеграции);
	Результат.Вставить("АктивныеИнтеграцииСПользователем", АктивныеИнтеграцииСПользователем);
	
	Возврат Результат;
	
КонецФункции

// Возвращает обсуждение интеграции с заголовком.
// 
// Параметры:
//  Интеграция - ИдентификаторИнтеграцииСистемыВзаимодействия
//  Заголовок - Строка
// 
// Возвращаемое значение:
//  Неопределено, ИдентификаторОбсужденияСистемыВзаимодействия - Обсуждение интеграции с заголовком
Функция ОбсуждениеИнтеграцииСЗаголовком(Интеграция, Заголовок) 
	
	Результат = Неопределено;
	
	Отбор = Новый ОтборОбсужденийСистемыВзаимодействия;
	Отбор.Интеграция = Интеграция;
	
	НайденныеОбсуждения = СистемаВзаимодействия.ПолучитьОбсуждения(Отбор);	
	Для Каждого НайденноеОбсуждение Из НайденныеОбсуждения Цикл
		Если НайденноеОбсуждение.Заголовок = Заголовок Тогда
			Результат = НайденноеОбсуждение.Идентификатор;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти