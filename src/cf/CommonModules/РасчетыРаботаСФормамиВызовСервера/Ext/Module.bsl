КонецФункции

// Выполняет контроль превышения суммы оплаты над суммой документа в строке ТЧ
// 
// Параметры:
// 	пФорма - УправляемаяФорма - Форма документа
// 	ИдентификаторСтроки - Число - Идентификатор текущей строки таблицы Предоплата
// 	СуммаДокумента - Число - Сумма документа
// 	ИмяТЧ - Строка - Имя табличной части
//
Процедура ВыполнитьКонтрольСуммыОплатыВСтроке(пФорма, ИдентификаторСтроки, СуммаДокумента,
	ИмяТЧ = "Предоплата") Экспорт
	
	Если ПроведениеДокументовУНФ.КонтрольОстатковВыключен() Тогда
		Возврат;	
	КонецЕсли;
	
	Объект = пФорма.Объект;
	СтрокаТабличнойЧасти = Объект[ИмяТЧ].НайтиПоИдентификатору(ИдентификаторСтроки);
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		Возврат;	
	КонецЕсли;
	
	Если СтрокаТабличнойЧасти.Свойство("ОплатаБонусами") Тогда
		ОплатыБезБонусов = Объект.Предоплата.НайтиСтроки(Новый Структура("ОплатаБонусами", Ложь));
	Иначе
		ОплатыБезБонусов = Неопределено;
	КонецЕсли;	
	
	ТЗПредоплата = Объект[ИмяТЧ].Выгрузить(ОплатыБезБонусов, "СуммаРасчетов");
	ОбщаяСуммаРасчетов = ТЗПредоплата.Итог("СуммаРасчетов");
	ПревышениеОплатыНадСуммойДокумента = ОбщаяСуммаРасчетов - СуммаДокумента; 
	
	Если ПревышениеОплатыНадСуммойДокумента > 0 Тогда
		Если ПревышениеОплатыНадСуммойДокумента >= СтрокаТабличнойЧасти.СуммаРасчетов Тогда
			Объект[ИмяТЧ].Удалить(СтрокаТабличнойЧасти);
		Иначе
			СтрокаТабличнойЧасти.СуммаРасчетов	= СтрокаТабличнойЧасти.СуммаРасчетов - ПревышениеОплатыНадСуммойДокумента;
			ПересчитатьСуммуПлатежа(пФорма, СтрокаТабличнойЧасти);
		КонецЕсли;
		СообщитьОПревышенииСуммыПлатежа();
	КонецЕсли;
	
КонецПроцедуры

// Выполняет контроль превышения суммы оплаты над суммой документа при добавлении строки в ТЧ
// 
// Параметры:
// 	СуммаОплаты - Число - Сумма оплаты
// 	СуммаДокумента - Число - Сумма документа
// 	Отказ - Булево - Признак отказа
//
Процедура ВыполнитьКонтрольСуммыОплатыДобавлениеСтроки(СуммаОплаты, СуммаДокумента, Отказ) Экспорт
	
	Если ПроведениеДокументовУНФ.КонтрольОстатковВыключен() Тогда
		Возврат;	
	КонецЕсли;
	
	РасчетыПроведениеДокументов.ВыполнитьКонтрольСуммыОплаты(СуммаОплаты, СуммаДокумента, Отказ);
	
КонецПроцедуры

// Выполняет контроль превышения суммы оплаты над суммой документа в таблице оплат
// 
// Параметры:
// 	пФорма - УправляемаяФорма - Форма документа
// 	СуммаДокумента - Число - Сумма документа
// 	ТаблицаОплат - ТаблицаЗначений - Таблица оплат для загрузки в ТЧ Предоплата
//
Процедура ВыполнитьКонтрольСуммыОплатыВТаблице(пФорма, СуммаДокумента, ТаблицаОплат) Экспорт
	
	Если ПроведениеДокументовУНФ.КонтрольОстатковВыключен() Тогда
		Возврат;	
	КонецЕсли;
	
	Если ТаблицаОплат.Колонки.Найти("ОплатаБонусами") = Неопределено Тогда
		ОбщаяСуммаРасчетов = ТаблицаОплат.Итог("СуммаРасчетов");
	Иначе
		ОплатыБезБонусов = ТаблицаОплат.НайтиСтроки(Новый Структура("ОплатаБонусами", Ложь));
		ОбщаяСуммаРасчетов = ТаблицаОплат.Скопировать(ОплатыБезБонусов, "СуммаРасчетов").Итог("СуммаРасчетов");
	КонецЕсли;
	
	ПревышениеОплатыНадСуммойДокумента = ОбщаяСуммаРасчетов - СуммаДокумента; 
	
	Если ПревышениеОплатыНадСуммойДокумента > 0 Тогда
		Для Итератор = 1 - ТаблицаОплат.Количество() По 0 Цикл
			Индекс = - Итератор;
			СтрокаТабличнойЧасти = ТаблицаОплат[Индекс];
			Если ПревышениеОплатыНадСуммойДокумента >= СтрокаТабличнойЧасти.СуммаРасчетов Тогда
				ПревышениеОплатыНадСуммойДокумента = ПревышениеОплатыНадСуммойДокумента - СтрокаТабличнойЧасти.СуммаРасчетов;
				ТаблицаОплат.Удалить(Индекс);
				Продолжить;
			КонецЕсли;

			СтрокаТабличнойЧасти.СуммаРасчетов = СтрокаТабличнойЧасти.СуммаРасчетов - ПревышениеОплатыНадСуммойДокумента;
			ПересчитатьСуммуПлатежа(пФорма, СтрокаТабличнойЧасти);
			Прервать;
		КонецЦикла;
		СообщитьОПревышенииСуммыПлатежа();
	КонецЕсли;
	
КонецПроцедуры

// Сообщает о превышения суммы оплаты над суммой документа
// 
// Параметры:
// 	Отказ - Булево - Признак отказа
//
Процедура СообщитьОПревышенииСуммыПлатежаОтказ(Отказ = Ложь) Экспорт
	
	ТекстСообщения = НСтр("ru = 'Сумма оплаты не может превышать сумму документа.'");
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Отказ);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьИнформациюОбИтогахПоВалюте(Форма)
	
	Если НЕ Форма.ОтборВалютаВедомости.Пустая() Тогда
		
		Если Форма.ИмяФормы = "Обработка.БанкИКасса.Форма.ФормаСписка" Тогда
			СтруктураДанные = ПолучитьДанныеПоВалюте(Форма.ОтборПериодБанковскиеВыписки, Форма.ОтборВалютаВедомости);
		Иначе
			СтруктураДанные = ПолучитьДанныеПоВалюте(Форма.ОтборПериод, Форма.ОтборВалютаВедомости);
		КонецЕсли;
		
		Форма.ТаблицаИтогов[0].Значение = СтруктураДанные.ИнформацияСуммаВалНачальныйОстаток;
		Форма.ТаблицаИтогов[1].Значение = СтруктураДанные.ИнформацияСуммаВалПриход;
		Форма.ТаблицаИтогов[2].Значение = СтруктураДанные.ИнформацияСуммаВалРасход;
		Форма.ТаблицаИтогов[3].Значение = СтруктураДанные.ИнформацияСуммаВалКонечныйОстаток;
		
	Иначе
		Форма.ИнформацияСуммаВалКонечныйОстаток = 0;
		Форма.ИнформацияСуммаВалНачальныйОстаток = 0;
		Форма.ИнформацияСуммаВалПриход = 0;
		Форма.ИнформацияСуммаВалРасход = 0;
		Форма.Дата = "";
	КонецЕсли;
	
КонецПроцедуры 

Функция ПолучитьДанныеПоВалюте(Период, Валюта)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДенежныеСредстваОстаткиИОбороты.СуммаВалНачальныйОстаток КАК ИнформацияСуммаВалНачальныйОстаток,
	|	ДенежныеСредстваОстаткиИОбороты.СуммаВалПриход КАК ИнформацияСуммаВалПриход,
	|	ДенежныеСредстваОстаткиИОбороты.СуммаВалРасход КАК ИнформацияСуммаВалРасход,
	|	ДенежныеСредстваОстаткиИОбороты.СуммаВалКонечныйОстаток КАК ИнформацияСуммаВалКонечныйОстаток
	|ИЗ
	|	РегистрНакопления.ДенежныеСредства.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, , , Валюта = &Валюта) КАК ДенежныеСредстваОстаткиИОбороты";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоДня(Период.ДатаНачала));
	Запрос.УстановитьПараметр("КонецПериода", ?(Период.ДатаОкончания = '00010101', '39991231', КонецДня(Период.ДатаОкончания)));
	Запрос.УстановитьПараметр("Валюта", Валюта);
	ВыборкаРезультата = Запрос.Выполнить().Выбрать();

	Результат = Новый Структура;
	Результат.Вставить("ИнформацияСуммаВалНачальныйОстаток", 0);
	Результат.Вставить("ИнформацияСуммаВалКонечныйОстаток", 0);
	Результат.Вставить("ИнформацияСуммаВалПриход", 0);
	Результат.Вставить("ИнформацияСуммаВалРасход", 0);
	Результат.Вставить("УчетВалютныхОпераций", ПолучитьФункциональнуюОпцию("УчетВалютныхОпераций"));
	Результат.Вставить("НомерБанковскогоСчета");
	
	Если ВыборкаРезультата.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, ВыборкаРезультата);
	КонецЕсли;
	
	Возврат Результат;	
	
КонецФункции // ПолучитьДанныеПоВалюте()

Функция ПолучитьОстатокВВалюте(Валюта)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЕСТЬNULL(КурсыВалютСрезПоследних.Курс, 1) КАК Курс,
		|	ЕСТЬNULL(КурсыВалютСрезПоследних.Кратность, 1) КАК Кратность
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(, Валюта = &Валюта) КАК КурсыВалютСрезПоследних";
	
	Запрос.УстановитьПараметр("Валюта", Валюта);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаПоВалюте = РезультатЗапроса.Выбрать();
	ВыборкаПоВалюте.Следующий();
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(ДенежныеСредстваОстатки.СуммаВалОстаток * ЕСТЬNULL(КурсыВалютСрезПоследних.Курс, 1) * &Кратность / (ЕСТЬNULL(КурсыВалютСрезПоследних.Кратность, 1) * &Курс)) КАК ОстатокВВалюте
		|ИЗ
		|	РегистрНакопления.ДенежныеСредства.Остатки(ДатаВремя(3999, 12, 31), ) КАК ДенежныеСредстваОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(, ) КАК КурсыВалютСрезПоследних
		|		ПО ДенежныеСредстваОстатки.Валюта = КурсыВалютСрезПоследних.Валюта";
	
	Запрос.УстановитьПараметр("Валюта", Валюта);
	Запрос.УстановитьПараметр("Кратность", ВыборкаПоВалюте.Кратность);
	Запрос.УстановитьПараметр("Курс", ВыборкаПоВалюте.Курс);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	СтруктураВозврата = Новый Структура("Курс, Остаток", ВыборкаПоВалюте.Курс, 0);
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		СтруктураВозврата.Вставить("Остаток", ВыборкаДетальныеЗаписи.ОстатокВВалюте);
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

Процедура ЗаполнитьТаблицуИтогов(Форма, ИмяФормы)
	
	СтрокаПоказателей = "";
	
	Если ИмяФормы = "БанкИКасса" ИЛИ ИмяФормы = "Банк" ИЛИ ИмяФормы = "Касса" Тогда
		СтрокаПоказателей = "Начало дня,Поступило,Списано,Конец дня";
	ИначеЕсли ИмяФормы = "ПланированиеДенег" Тогда
		СтрокаПоказателей = "Приход,Расход,В том числе,перемещения";
	КонецЕсли;
	
	Если СтрокаПоказателей = "" Тогда
		Возврат;
	КонецЕсли; 
	
	Форма.ТаблицаИтогов.Очистить();
	
	МассивПоказателей = СтрРазделить(СтрокаПоказателей, ",");
	
	// Начальные остатки
	Для каждого Показатель Из МассивПоказателей Цикл
		
		СтрокаИтогов = Форма.ТаблицаИтогов.Добавить();
		СтрокаИтогов.Показатель = Показатель;
		СтрокаИтогов.Значение = 0;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьАвтоОтметкуНезаполненногоДляПлатежногоДокумента(пФорма)
	
	Если пФорма.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПоставщика
		ИЛИ пФорма.ВидОперации = Перечисления.ВидыОперацийПоступлениеВКассу.ОтПоставщика Тогда
		пФорма.Элементы.РасшифровкаПлатежаДокумент.АвтоОтметкаНезаполненного = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПересчитатьСуммуПлатежа(пФорма, СтрокаТабличнойЧасти)
	
	Объект = пФорма.Объект;
	СтрокаТабличнойЧасти.СуммаПлатежа = ВалютыУНФКлиентСервер.Пересчитать(
		СтрокаТабличнойЧасти.СуммаРасчетов,
		СтрокаТабличнойЧасти.Курс,
		?(Объект.ВалютаДокумента = пФорма.НациональнаяВалюта, пФорма.КурсНациональнаяВалюта, Объект.Курс),
		СтрокаТабличнойЧасти.Кратность,
		?(Объект.ВалютаДокумента = пФорма.НациональнаяВалюта, пФорма.КратностьНациональнаяВалюта, Объект.Кратность));

КонецПроцедуры

Процедура СообщитьОПревышенииСуммыПлатежа()
	
	СообщитьОПревышенииСуммыПлатежаОтказ();
	ТекстСообщения = НСтр("ru = 'Сумма оплаты откорректирована.'");
	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);

КонецПроцедуры

