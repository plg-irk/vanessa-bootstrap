Функция ПолучитьКомпоновщикОтчетаПоИмени(ИмяОтчета) Экспорт
	Возврат Отчеты[ИмяОтчета].Создать().КомпоновщикНастроек;
КонецФункции

Функция СписокВидовНалоговПоЗадачамКалендаря(ЗадачиКалендаря, Период) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ТаблицаВидовНалоговЗадачКалендаря.ВидНалога КАК Справочник.ВидыНалогов) КАК ВидНалога,
		|	ВЫРАЗИТЬ(ТаблицаВидовНалоговЗадачКалендаря.ЗадачаКалендаряПодготовкиОтчетности КАК Справочник.ЗадачиКалендаряПодготовкиОтчетности) КАК ЗадачаКалендаряПодготовкиОтчетности
		|ПОМЕСТИТЬ втВходящаяТЗ
		|ИЗ
		|	&ТаблицаВидовНалоговЗадачКалендаря КАК ТаблицаВидовНалоговЗадачКалендаря
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВидНалога,
		|	ЗадачаКалендаряПодготовкиОтчетности
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втВходящаяТЗ.ВидНалога КАК ВидНалога
		|ИЗ
		|	Справочник.КалендарьПодготовкиОтчетности КАК КалендарьПодготовкиОтчетности
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втВходящаяТЗ КАК втВходящаяТЗ
		|		ПО КалендарьПодготовкиОтчетности.Задача = втВходящаяТЗ.ЗадачаКалендаряПодготовкиОтчетности
		|ГДЕ
		|	КалендарьПодготовкиОтчетности.Задача В ИЕРАРХИИ (&ЗадачиКалендаря)
		|	И КалендарьПодготовкиОтчетности.ДатаНачалаДокументов >= &ПериодН";
		
	Запрос.УстановитьПараметр("ЗадачиКалендаря", 					ЗадачиКалендаря.ВыгрузитьЗначения());
	Запрос.УстановитьПараметр("ПериодН", 							Период);	
	Запрос.УстановитьПараметр("ТаблицаВидовНалоговЗадачКалендаря", 	УчетУСНПовтИсп.ВидНалогаЗадачиКалендаряПодготовкиОтчетности());
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	МассивВидовНалогов = Новый Массив();
	
	Пока Выборка.Следующий() Цикл
		
		МассивВидовНалогов.Добавить(Выборка.ВидНалога);	

	КонецЦикла;

	Возврат МассивВидовНалогов;

КонецФункции	
#КонецОбласти
