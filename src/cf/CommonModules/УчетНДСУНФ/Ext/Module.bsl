    |ВЫБРАТЬ
    |    НалоговаяБазаИВычет.ПодтвержденнаяНалоговаяБаза КАК ПодтвержденнаяНалоговаяБаза,
    |    НалоговаяБазаИВычет.НачислениеНДС КАК НачислениеНДС,
    |    НалоговаяБазаИВычет.ВычетНДС КАК ВычетНДС,
    |    &КодОперацииПоУмолчанию КАК КодОперации
    |ПОМЕСТИТЬ НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи
    |ИЗ
    |    НалоговаяБазаИВычет КАК НалоговаяБазаИВычет
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |УНИЧТОЖИТЬ НалоговаяБазаИВычет
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |    СУММА(НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи.ПодтвержденнаяНалоговаяБаза) КАК
    |        ПодтвержденнаяНалоговаяБаза,
    |    СУММА(НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи.НачислениеНДС) КАК НачислениеНДС,
    |    СУММА(НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи.ВычетНДС) КАК ВычетНДС,
    |    НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи.КодОперации КАК КодОперации
    |ИЗ
    |    НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи КАК НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи
    |СГРУППИРОВАТЬ ПО
    |    НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи.КодОперации
    |
    |УПОРЯДОЧИТЬ ПО
    |    КодОперации
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |УНИЧТОЖИТЬ НалоговаяБазаИВычетПоКодамОперацийДетальныеЗаписи";
    
КонецФункции
#КонецОбласти

#Область ФормированиеДвижений

#Область НДСПродажи
 
// Формирует движения по регистру накопления "НДСЗаписиКнигиПродаж" для реализации запасов по документу Расходная накладная.
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.РасходнаяНакладная, ДокументСсылка.ЗаказПокупателя - Ссылка на документ продаж, для которого формируются движения.
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств для проведения.
//
Процедура СформироватьДвиженияНДСЗаписиКнигиПродажРеализация(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Если Не ПлательщикНДС Тогда 
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	УчетАгентскогоНДСПокупателем = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем");

	ЭтоОтчетКомиссионера = ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОтчетКомиссионера");
	ЭтоОтчетКомитенту = ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОтчетКомитенту");
	ЭтоАктВыполненныхРабот = ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот");
	ЭтоЗаказПокупателя = ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаказПокупателя");

	ЭтоКомиссия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВидДоговора")
		= Перечисления.ВидыДоговоров.СКомиссионером;
	ЭтоОтгрузкаБезПереходаПраваСобственности = СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратСОтветХранения
		Или СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаНаОтветХранение;
	ЭтоПередачаВПереработку = СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаВПереработку
		Или СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратИзПереработки;

	ЭтоВозвратПоставщику = СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратПоставщику;

	Если ЭтоВозвратПоставщику Тогда
		ПлательщикНДСНаУСНСВычетами =  УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
			СтруктураДополнительныеСвойства.ДляПроведения.Дата);

		ПлательщикНДС                      = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
			СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или ПлательщикНДСНаУСНСВычетами;

		Если Не ПлательщикНДС Тогда
			ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
			Возврат;
		КонецЕсли;

	КонецЕсли;

	Если ЭтоОтчетКомиссионера Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|    Шапка.Дата КАК Период,
		|    Шапка.Ссылка КАК Регистратор,
		|    &Организация КАК Организация,
		|    ТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|    ТаблицаЗапасы.Характеристика КАК Характеристика,
		|    ТаблицаЗапасы.Партия КАК Партия,
		|    ВЫБОР
		|        КОГДА Шапка.Контрагент = Покупатели.Покупатель
		|            ТОГДА Шапка.Ссылка
		|        ИНАЧЕ ВЫБОР
		|            КОГДА НЕ ТаблицаЗапасы.СчетФактура = ЗНАЧЕНИЕ(Документ.СчетФактура.ПустаяСсылка)
		|                ТОГДА ТаблицаЗапасы.СчетФактура
		|            ИНАЧЕ Шапка.Ссылка
		|        КОНЕЦ
		|    КОНЕЦ КАК СчетФактура,
		|    ВЫБОР
		|        КОГДА НЕ ТаблицаЗапасы.СчетФактура = ЗНАЧЕНИЕ(Документ.СчетФактура.ПустаяСсылка)
		|        ИЛИ ТаблицаЗапасы.Контрагент = Покупатели.Покупатель
		|            ТОГДА Покупатели.Покупатель
		|        ИНАЧЕ НЕОПРЕДЕЛЕНО
		|    КОНЕЦ КАК Контрагент,
		|    ЕСТЬNULL(ТаблицаЗапасы.КорректируемыйДокумент, Шапка.КорректируемыйДокумент) КАК КорректируемыйДокумент,
		|    ТаблицаЗапасы.СуммаНДСПродажи КАК СуммаНДСВалютаДокумента,
		|    ВЫБОР
		|        КОГДА Шапка.СуммаВключаетНДС
		|            ТОГДА ТаблицаЗапасы.СуммаРуб - ТаблицаЗапасы.СуммаНДСПродажи
		|        ИНАЧЕ ТаблицаЗапасы.СуммаРуб
		|    КОНЕЦ КАК СуммаБезНДС,
		|    ТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС
		|ИЗ
		|    ВременнаяТаблицаШапка КАК Шапка,
		|    ВременнаяТаблицаЗапасы КАК ТаблицаЗапасы
		|        ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаПокупатели КАК Покупатели
		|        ПО ТаблицаЗапасы.КлючСвязи = Покупатели.КлючСвязи
		|ГДЕ
		|    ТаблицаЗапасы.Сумма >= 0";

	ИначеЕсли ЭтоОтчетКомитенту Тогда

		ТекстЗапроса =
		"ВЫБРАТЬ
		|   Шапка.Дата КАК Период,
		|   Шапка.Ссылка КАК Регистратор,
		|   &Организация КАК Организация,
		|   ТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|   ТаблицаЗапасы.Характеристика КАК Характеристика,
		|   ТаблицаЗапасы.Партия КАК Партия,
		|   &Контрагент КАК Контрагент,
		|   Неопределено КАК КорректируемыйДокумент,
		|   ТаблицаЗапасы.СуммаНДСПродажиВознаграждения КАК СуммаНДСВалютаДокумента,
		|   ВЫБОР
		|       КОГДА Шапка.СуммаВключаетНДС
		|           ТОГДА ТаблицаЗапасы.СуммаВознаграждения - ТаблицаЗапасы.СуммаНДСПродажиВознаграждения
		|       ИНАЧЕ ТаблицаЗапасы.СуммаВознаграждения
		|   КОНЕЦ КАК СуммаБезНДС,
		|   ТаблицаЗапасы.СтавкаНДСВознаграждения.ПеречислениеСтавкаНДС КАК СтавкаНДС
		|ИЗ
		|   ВременнаяТаблицаШапка КАК Шапка,
		|   ВременнаяТаблицаЗапасы КАК ТаблицаЗапасы
		|ГДЕ
		|   ТаблицаЗапасы.СуммаВознаграждения > 0";

	ИначеЕсли ЭтоАктВыполненныхРабот Тогда

		ТекстЗапроса =
		"ВЫБРАТЬ
		|   Шапка.Дата КАК Период,
		|   Шапка.Ссылка КАК Регистратор,
		|   &Организация КАК Организация,
		|   ТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|   ТаблицаЗапасы.Характеристика КАК Характеристика,
		|   ТаблицаЗапасы.Партия КАК Партия,
		|   &Контрагент КАК Контрагент,
		|   ТаблицаЗапасы.СуммаНДСПродажи КАК СуммаНДСВалютаДокумента,
		|   ВЫБОР
		|       КОГДА Шапка.СуммаВключаетНДС
		|           ТОГДА ТаблицаЗапасы.СуммаРуб - ТаблицаЗапасы.СуммаНДСПродажи
		|       ИНАЧЕ ТаблицаЗапасы.СуммаРуб
		|   КОНЕЦ КАК СуммаБезНДС,
		|   ТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС
		|ИЗ
		|   ВременнаяТаблицаШапка КАК Шапка,
		|   ВременнаяТаблицаРаботыИУслуги КАК ТаблицаЗапасы
		|ГДЕ
		|   ТаблицаЗапасы.Сумма >= 0";
	ИначеЕсли ЭтоЗаказПокупателя Тогда

		СостояниеЗаказЗавершен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "СостояниеЗаказа")
			= Справочники.СостоянияЗаказНарядов.Завершен;

		Если (ЭтоКомиссия Или ЭтоПередачаВПереработку Или ЭтоОтгрузкаБезПереходаПраваСобственности
			Или Не СостояниеЗаказЗавершен) Тогда
			ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
			Возврат;
		КонецЕсли;

		ТекстЗапроса =
		"ВЫБРАТЬ
		|    Шапка.Дата КАК Период,
		|    Шапка.Ссылка КАК Регистратор,
		|    &Организация КАК Организация,
		|    ТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|    &Контрагент КАК Контрагент,
		|    ТаблицаЗапасы.СуммаНДСЗакупкиПродажи КАК СуммаНДСВалютаДокумента,
		|    ВЫБОР
		|        КОГДА Шапка.СуммаВключаетНДС
		|            ТОГДА ТаблицаЗапасы.СуммаРуб - ТаблицаЗапасы.СуммаНДСЗакупкиПродажи
		|        ИНАЧЕ ТаблицаЗапасы.СуммаРуб
		|    КОНЕЦ КАК СуммаБезНДС,
		|    ТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС
		|ИЗ
		|    ВременнаяТаблицаШапка КАК Шапка,
		|    ВременнаяТаблицаТовары КАК ТаблицаЗапасы
		|ГДЕ
		|    ТаблицаЗапасы.Сумма >= 0
		|    И (ТаблицаЗапасы.Партия = ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
		|    ИЛИ ТаблицаЗапасы.Партия.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|    Шапка.Дата КАК Период,
		|    Шапка.Ссылка КАК Регистратор,
		|    &Организация КАК Организация,
		|    ТаблицаРаботы.Номенклатура КАК Номенклатура,
		|    &Контрагент КАК Контрагент,
		|    ТаблицаРаботы.СуммаНДСПродажи КАК СуммаНДСВалютаДокумента,
		|    ВЫБОР
		|        КОГДА Шапка.СуммаВключаетНДС
		|            ТОГДА ТаблицаРаботы.СуммаРуб - ТаблицаРаботы.СуммаНДСПродажи
		|        ИНАЧЕ ТаблицаРаботы.СуммаРуб
		|    КОНЕЦ КАК СуммаБезНДС,
		|    ТаблицаРаботы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДСL
		|ИЗ
		|    ВременнаяТаблицаШапка КАК Шапка,
		|    ВременнаяТаблицаРаботы КАК ТаблицаРаботы
		|ГДЕ
		|    ТаблицаРаботы.Сумма >= 0";
	Иначе
		Если (ЭтоКомиссия Или ЭтоПередачаВПереработку Или ЭтоОтгрузкаБезПереходаПраваСобственности) И ТипЗнч(
			ДокументСсылка) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
			ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
			Возврат;
		КонецЕсли;

		ТекстЗапроса =
		"ВЫБРАТЬ
		|    Шапка.Дата КАК Период,
		|    Шапка.Ссылка КАК Регистратор,
		|    &Организация КАК Организация,
		|    ТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|    ТаблицаЗапасы.Характеристика КАК Характеристика,
		|    ТаблицаЗапасы.Партия КАК Партия,
		|    &Контрагент КАК Контрагент,
		|    ЕСТЬNULL(ТаблицаЗапасы.КорректируемыйДокумент, Шапка.КорректируемыйДокумент) КАК КорректируемыйДокумент,
		|    ТаблицаЗапасы.СуммаНДСЗакупкиПродажи КАК СуммаНДСВалютаДокумента,
		|    ВЫБОР
		|        КОГДА Шапка.СуммаВключаетНДС
		|            ТОГДА ТаблицаЗапасы.СуммаРуб - ТаблицаЗапасы.СуммаНДСЗакупкиПродажи
		|        ИНАЧЕ ТаблицаЗапасы.СуммаРуб
		|    КОНЕЦ КАК СуммаБезНДС,
		|    ТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС
		|ИЗ
		|    ВременнаяТаблицаШапка КАК Шапка,
		|    ВременнаяТаблицаЗапасы КАК ТаблицаЗапасы
		|ГДЕ
		|    ТаблицаЗапасы.Сумма >= 0
		|    И (ТаблицаЗапасы.Партия = ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
		|    ИЛИ ТаблицаЗапасы.Партия.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы))";
	КонецЕсли;

	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса;
	ТоварыУслуги  = Запрос.Выполнить().Выгрузить();

	Если ТоварыУслуги.Количество() = 0 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	ВерсияУчетаНДС = УчетНДСКлиентСервер.Версия(СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ТаблицаЗаписиКнигиПродаж = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПродаж");

	УчетНДС.ЗаполнитьВидыЦенностей(ТоварыУслуги, Неопределено, ДокументСсылка);

	Для Каждого СтрокаТаблицы Из ТоварыУслуги Цикл

		Если ВерсияУчетаНДС > 1 И СтрокаТаблицы.СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = ТаблицаЗаписиКнигиПродаж.Добавить();

		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);

		НоваяСтрока.Покупатель  = СтрокаТаблицы.Контрагент;
		НоваяСтрока.СуммаБезНДС = СтрокаТаблицы.СуммаБезНДС;
		НоваяСтрока.НДС         = СтрокаТаблицы.СуммаНДСВалютаДокумента;
		НоваяСтрока.СтавкаНДС   = СтрокаТаблицы.СтавкаНДС;

	КонецЦикла;

	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "ДатаСобытия");

	Если Не ЭтоОтчетКомиссионера Тогда
		ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(ДокументСсылка, "СчетФактура");
	КонецЕсли;

	Если УчетАгентскогоНДСПокупателем = Истина И УчетНДС.ВедетсяУчетНДСПоФЗ335(
			СтруктураДополнительныеСвойства.ДляПроведения.Дата) Тогда
		ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(Перечисления.СобытияПоНДСПродажи.НалогИсчисляетПокупатель, "Событие");
	ИначеЕсли ЭтоВозвратПоставщику Тогда
		ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(Перечисления.СобытияПоНДСПродажи.ВосстановлениеНДС, "Событие");
	Иначе
		ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(Перечисления.СобытияПоНДСПродажи.Реализация, "Событие");
	КонецЕсли;
	
	// Для операций поступления/реализации договор не заполняется
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(Справочники.ДоговорыКонтрагентов.ПустаяСсылка(), "ДоговорКонтрагента");

	ТаблицаЗаписиКнигиПродаж.Свернуть("Период,Организация,Покупатель,СчетФактура,ВидЦенности,СтавкаНДС,
									  |ДатаОплаты,ДокументОплаты,Событие,ДатаСобытия,ДоговорКонтрагента",
		"СуммаБезНДС,НДС");

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж", ТаблицаЗаписиКнигиПродаж);

КонецПроцедуры

// Формирует движения по регистру накопления "НДСЗаписиКнигиПродаж" для выписанного счета-фактуры на полученный аванс.
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.СчетФактура - Ссылка на документ "Счет-фактура".
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств для проведения.
//
Процедура СформироватьДвиженияВыписанСчетФактураНаПолученныйАванс(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ВедетсяУчетНДСПоФЗ134  = УчетНДС.ВедетсяУчетНДСПоФЗ134(СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Если Не ПлательщикНДС И Не ВедетсяУчетНДСПоФЗ134 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Если Не СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;

	ЭтоИсправление = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Исправление");

	ТекстЗапроса = "ВЫБРАТЬ
	|    СчетФактураВыданныйАвансы.Ссылка КАК Ссылка,
	|    СчетФактураВыданныйАвансы.Сумма КАК Сумма,
	|    СчетФактураВыданныйАвансы.Сумма КАК ВалютнаяСумма,
	|    СчетФактураВыданныйАвансы.СуммаНДС КАК СуммаНДС,
	|    СчетФактураВыданныйАвансы.Сумма - СчетФактураВыданныйАвансы.СуммаНДС КАК СуммаБезНДС,
	|    СчетФактураВыданныйАвансы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
	|    НЕОПРЕДЕЛЕНО КАК ВидЦенности,
	|    ВЫБОР
	|        КОГДА Реквизиты.ДокументОснование ССЫЛКА Документ.ОтчетКомиссионера
	|            ТОГДА ВЫБОР
	|                КОГДА Реквизиты.Исправление
	|                    ТОГДА Реквизиты.ИсправляемыйСчетФактура
	|                ИНАЧЕ Реквизиты.Ссылка
	|            КОНЕЦ
	|        ИНАЧЕ Реквизиты.ДокументОснование
	|    КОНЕЦ КАК СчетФактура,
	|    Реквизиты.ДокументОснование КАК ДокументОплаты,
	|    СчетФактураВыданныйАвансы.Номенклатура КАК Номенклатура,
	|    ВЫБОР
	|        КОГДА СчетФактураВыданныйАвансы.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|            ТОГДА Реквизиты.Контрагент
	|        ИНАЧЕ СчетФактураВыданныйАвансы.Контрагент
	|    КОНЕЦ КАК Контрагент,
	|    ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка) КАК ДоговорКонтрагента,
	|    ВЫБОР
	|        КОГДА Реквизиты.Исправление
	|            ТОГДА Реквизиты.Ссылка
	|        ИНАЧЕ НЕОПРЕДЕЛЕНО
	|    КОНЕЦ КАК ИсправленныйСчетФактура,
	|    ВЫБОР
	|        КОГДА КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(Реквизиты.ДокументОснованиеДата, КВАРТАЛ)
	|            ТОГДА ИСТИНА
	|        ИНАЧЕ ЛОЖЬ
	|    КОНЕЦ КАК ЗаписьДополнительногоЛиста,
	|    ВЫБОР
	|        КОГДА КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(Реквизиты.ДокументОснованиеДата, КВАРТАЛ)
	|            ТОГДА НАЧАЛОПЕРИОДА(Реквизиты.ДокументОснованиеДата, КВАРТАЛ)
	|        ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|    КОНЕЦ КАК КорректируемыйПериод,
	|    НЕОПРЕДЕЛЕНО КАК СторнирующаяЗаписьДопЛиста,
	|    Реквизиты.ДокументОснованиеДата КАК ДатаОплаты,
	|    Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|    СчетФактураВыданныйАвансы.Сумма КАК СуммаВВалютеРасчетов,
	|    Реквизиты.Дата КАК ДатаСобытия,
	|    СчетФактураВыданныйАвансы.ДатаПлатежноРасчетногоДокумента,
	|    СчетФактураВыданныйАвансы.НомерПлатежноРасчетногоДокумента,
	|    Реквизиты.Дата КАК Период
	|ИЗ
	|    Документ.СчетФактура.Авансы КАК СчетФактураВыданныйАвансы
	|        ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
	|        ПО ИСТИНА
	|ГДЕ
	|    СчетФактураВыданныйАвансы.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|    СчетФактураВыданныйАвансы.НомерСтроки";

	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса;
	ТаблицаАвансы  = Запрос.Выполнить().Выгрузить();

	ТаблицаАвансы.Свернуть(
        "СчетФактура, ДокументОплаты, Контрагент, ДоговорКонтрагента, ВидЦенности, ВалютаДокумента, СтавкаНДС,
		| ДатаОплаты, ДатаСобытия, ИсправленныйСчетФактура, ЗаписьДополнительногоЛиста, КорректируемыйПериод, СторнирующаяЗаписьДопЛиста, ДатаПлатежноРасчетногоДокумента, НомерПлатежноРасчетногоДокумента, Период",
		"СуммаНДС, СуммаБезНДС, СуммаВВалютеРасчетов");
		
	Если ТаблицаАвансы.Количество() = 0 Тогда
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж",
			Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;

	ТаблицаЗаписиКнигиПродаж = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПродаж");

	Для Каждого СтрокаТаблицы Из ТаблицаАвансы Цикл

		Движение = ТаблицаЗаписиКнигиПродаж.Добавить();

		ЗаполнитьЗначенияСвойств(Движение, СтрокаТаблицы);

		Движение.ВидЦенности = Перечисления.ВидыЦенностей.АвансыПолученные;
		Движение.НДС         = СтрокаТаблицы.СуммаНДС;
		Движение.Покупатель  = СтрокаТаблицы.Контрагент;

		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем") = Истина Тогда
			Движение.Событие = Перечисления.СобытияПоНДСПродажи.НалогИсчисляетПокупатель;
		Иначе
			Движение.Событие = Перечисления.СобытияПоНДСПродажи.ПолученАванс;
		КонецЕсли;

		Если ЭтоИсправление Тогда
			Движение.ДатаДокументаОплаты  = СтрокаТаблицы.ДатаПлатежноРасчетногоДокумента;
			Движение.НомерДокументаОплаты = СтрокаТаблицы.НомерПлатежноРасчетногоДокумента;
		КонецЕсли;

		Если УчетНДСПереопределяемый.ВерсияПостановленияНДС1137(СтруктураДополнительныеСвойства.ДляПроведения.Дата) >= 3
			И ТаблицаЗаписиКнигиПродаж.Количество() > 0 И Не ЭтоИсправление Тогда
			Если Не ЗначениеЗаполнено(СтрокаТаблицы.НомерПлатежноРасчетногоДокумента) И Не ЗначениеЗаполнено(
            СтрокаТаблицы.ДатаПлатежноРасчетногоДокумента) Тогда
				СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж",
					ТаблицаЗаписиКнигиПродаж);
				ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
				ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
				ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата,
					"ДатаСобытия");
				Возврат;
			КонецЕсли;

			Движение = ТаблицаЗаписиКнигиПродаж.Добавить();
			ЗаполнитьЗначенияСвойств(Движение, ТаблицаЗаписиКнигиПродаж[0], , "СуммаБезНДС, НДС");
			Движение.ДатаДокументаОплаты  = СтрокаТаблицы.ДатаПлатежноРасчетногоДокумента;
			Движение.НомерДокументаОплаты = СтрокаТаблицы.НомерПлатежноРасчетногоДокумента;

		КонецЕсли;

	КонецЦикла;

	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "ДатаСобытия");

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж", ТаблицаЗаписиКнигиПродаж);

КонецПроцедуры

Процедура СформироватьДвиженияСчетФактураВыданныйКорректировочныйНаАванс(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ВедетсяУчетНДСПоФЗ134  = УчетНДС.ВедетсяУчетНДСПоФЗ134(СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Если Не ПлательщикНДС И Не ВедетсяУчетНДСПоФЗ134 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Если Не СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;

	ЭтоИсправление = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Исправление");

	ТекстЗапроса = "ВЫБРАТЬ
	|	СчетФактураВыданныйАвансы.Ссылка КАК Ссылка,
	|	СчетФактураВыданныйАвансы.Сумма - СчетФактураВыданныйАвансы.СуммаДоКорректировки КАК Сумма,
	|	СчетФактураВыданныйАвансы.СуммаНДС - СчетФактураВыданныйАвансы.СуммаНДСДоКорректировки КАК СуммаНДС,
	|	СчетФактураВыданныйАвансы.Сумма - СчетФактураВыданныйАвансы.СуммаНДС -
	|		(СчетФактураВыданныйАвансы.СуммаДоКорректировки - СчетФактураВыданныйАвансы.СуммаНДСДоКорректировки) КАК
	|		СуммаБезНДС,
	|	СчетФактураВыданныйАвансы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
	|	НЕОПРЕДЕЛЕНО КАК ВидЦенности,
	|	ВЫБОР
	|		КОГДА Реквизиты.ДокументОснование ССЫЛКА Документ.ОтчетКомиссионера
	|			ТОГДА ВЫБОР
	|				КОГДА Реквизиты.Исправление
	|					ТОГДА Реквизиты.ИсправляемыйСчетФактура
	|				ИНАЧЕ Реквизиты.Ссылка
	|			КОНЕЦ
	|		ИНАЧЕ Реквизиты.ДокументОснование
	|	КОНЕЦ КАК СчетФактура,
	|	СчетФактураВыданныйАвансы.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА СчетФактураВыданныйАвансы.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА Реквизиты.Контрагент
	|		ИНАЧЕ СчетФактураВыданныйАвансы.Контрагент
	|	КОНЕЦ КАК Контрагент,
	|   ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка) КАК ДоговорКонтрагента,
	|	ВЫБОР
	|		КОГДА Реквизиты.Исправление
	|			ТОГДА Реквизиты.Ссылка
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ИсправленныйСчетФактура,
	|	ВЫБОР
	|		КОГДА КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(Реквизиты.ДокументОснованиеДата, КВАРТАЛ)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЗаписьДополнительногоЛиста,
	|	ВЫБОР
	|		КОГДА КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(Реквизиты.ДокументОснованиеДата, КВАРТАЛ)
	|			ТОГДА НАЧАЛОПЕРИОДА(Реквизиты.ДокументОснованиеДата, КВАРТАЛ)
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК КорректируемыйПериод,
	|	НЕОПРЕДЕЛЕНО КАК СторнирующаяЗаписьДопЛиста,
	|   СчетФактураВыданныйАвансы.ДатаПлатежноРасчетногоДокумента,
	|   СчетФактураВыданныйАвансы.НомерПлатежноРасчетногоДокумента,
	|	Реквизиты.Дата КАК ДатаСобытия
	|ИЗ
	|	Документ.СчетФактура.Авансы КАК СчетФактураВыданныйАвансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
	|		ПО ИСТИНА
	|ГДЕ
	|	СчетФактураВыданныйАвансы.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	СчетФактураВыданныйАвансы.НомерСтроки";

	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса;
	ТаблицаАвансы  = Запрос.Выполнить().Выгрузить();

//	ТаблицаАвансы.Свернуть(
//        "СчетФактура, ДокументОплаты, Контрагент, ДоговорКонтрагента, ВидЦенности, ВалютаДокумента, СтавкаНДС,
//		| ДатаОплаты, ДатаСобытия, ИсправленныйСчетФактура, ЗаписьДополнительногоЛиста, КорректируемыйПериод, СторнирующаяЗаписьДопЛиста, ДатаПлатежноРасчетногоДокумента, НомерПлатежноРасчетногоДокумента, Период",
//		"СуммаНДС, СуммаБезНДС, СуммаВВалютеРасчетов");
    ТаблицаАвансы.Свернуть(
		"СчетФактура, Контрагент, ДоговорКонтрагента, ВидЦенности, СтавкаНДС,
		| ДатаСобытия, ИсправленныйСчетФактура, ЗаписьДополнительногоЛиста, КорректируемыйПериод, СторнирующаяЗаписьДопЛиста, ДатаПлатежноРасчетногоДокумента, НомерПлатежноРасчетногоДокумента",
		"СуммаНДС, СуммаБезНДС");
		
	Если ТаблицаАвансы.Количество() = 0 Тогда
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж",
			Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;

	ТаблицаЗаписиКнигиПродаж = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПродаж");

	Для Каждого СтрокаТаблицы Из ТаблицаАвансы Цикл

		Движение = ТаблицаЗаписиКнигиПродаж.Добавить();

		ЗаполнитьЗначенияСвойств(Движение, СтрокаТаблицы);

		Движение.ВидЦенности = Перечисления.ВидыЦенностей.АвансыПолученные;
		Движение.НДС         = СтрокаТаблицы.СуммаНДС;
		Движение.Покупатель  = СтрокаТаблицы.Контрагент;

		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем") = Истина Тогда
			Движение.Событие = Перечисления.СобытияПоНДСПродажи.НалогИсчисляетПокупатель;
		Иначе
			Движение.Событие = Перечисления.СобытияПоНДСПродажи.ПолученАванс;
		КонецЕсли;

		Если ЭтоИсправление Тогда
			Движение.ДатаДокументаОплаты  = СтрокаТаблицы.ДатаПлатежноРасчетногоДокумента;
			Движение.НомерДокументаОплаты = СтрокаТаблицы.НомерПлатежноРасчетногоДокумента;
		КонецЕсли;

		Если УчетНДСПереопределяемый.ВерсияПостановленияНДС1137(СтруктураДополнительныеСвойства.ДляПроведения.Дата) >= 3
			И ТаблицаЗаписиКнигиПродаж.Количество() > 0 И Не ЭтоИсправление Тогда
			Если Не ЗначениеЗаполнено(СтрокаТаблицы.НомерПлатежноРасчетногоДокумента) И Не ЗначениеЗаполнено(
            СтрокаТаблицы.ДатаПлатежноРасчетногоДокумента) Тогда
				СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж",
					ТаблицаЗаписиКнигиПродаж);
				ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
				ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
				ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата,
					"ДатаСобытия");
				Возврат;
			КонецЕсли;

			Движение = ТаблицаЗаписиКнигиПродаж.Добавить();
			ЗаполнитьЗначенияСвойств(Движение, ТаблицаЗаписиКнигиПродаж[0], , "СуммаБезНДС, НДС");
			Движение.ДатаДокументаОплаты  = СтрокаТаблицы.ДатаПлатежноРасчетногоДокумента;
			Движение.НомерДокументаОплаты = СтрокаТаблицы.НомерПлатежноРасчетногоДокумента;

		КонецЕсли;

	КонецЦикла;

	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "ДатаСобытия");

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж", ТаблицаЗаписиКнигиПродаж);
	
КонецПроцедуры

Процедура СформироватьДвиженияНДСНомераДокументовОплаты(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	Если СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда
		Возврат;
	КонецЕсли;
	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Если Не ПлательщикНДС Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Запрос.УстановитьПараметр("ДокументОснование", ДокументСсылка.ДокументыОснования[0].ДокументОснование);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Период", СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Запрос.Текст = ТекстЗапросаНомераДокументовОплаты();

	ТоварыУслуги  = Запрос.Выполнить().Выгрузить();

	Если ТоварыУслуги.Количество() = 0 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	ТаблицаЗаписиКнигиПродаж = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПродаж");

	Для Каждого СтрокаТаблицы Из ТоварыУслуги Цикл

		Движение = ТаблицаЗаписиКнигиПродаж.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, СтрокаТаблицы);

	КонецЦикла;

	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
	ТаблицаЗаписиКнигиПродаж.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "ДатаСобытия");

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж", ТаблицаЗаписиКнигиПродаж);

КонецПроцедуры

Функция ТекстЗапросаНомераДокументовОплаты()

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	НДСЗаписиКнигиПродаж.Организация КАК Организация,
	|	НДСЗаписиКнигиПродаж.СчетФактура КАК СчетФактура,
	|	НДСЗаписиКнигиПродаж.Покупатель КАК Покупатель,
	|	&Ссылка КАК СчетФактураДокумент,
	|	НДСЗаписиКнигиПродаж.СтавкаНДС КАК СтавкаНДС,
	|	НДСЗаписиКнигиПродаж.ВидЦенности КАК ВидЦенности,
	|	НДСЗаписиКнигиПродаж.ДатаОплаты КАК ДатаОплаты,
	|	НДСЗаписиКнигиПродаж.ДокументОплаты КАК ДокументОплаты,
	|	НДСЗаписиКнигиПродаж.Событие КАК Событие,
	|	НДСЗаписиКнигиПродаж.ДатаСобытия КАК ДатаСобытия,
	|	НДСЗаписиКнигиПродаж.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	НДСЗаписиКнигиПродаж.ЗаписьДополнительногоЛиста КАК ЗаписьДополнительногоЛиста,
	|	НДСЗаписиКнигиПродаж.КорректируемыйПериод КАК КорректируемыйПериод,
	|	НДСЗаписиКнигиПродаж.СторнирующаяЗаписьДопЛиста КАК СторнирующаяЗаписьДопЛиста,
	|	НДСЗаписиКнигиПродаж.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура
	|ПОМЕСТИТЬ ВТ_ЗаписиКнигиПродажПредварительная
	|ИЗ
	|	РегистрНакопления.НДСЗаписиКнигиПродаж КАК НДСЗаписиКнигиПродаж
	|ГДЕ
	|	НДСЗаписиКнигиПродаж.СчетФактура = &ДокументОснование
	|	И НДСЗаписиКнигиПродаж.Активность
	|	И НДСЗаписиКнигиПродаж.Регистратор = &ДокументОснование
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НДСЗаписиКнигиПродаж.Организация,
	|	НДСЗаписиКнигиПродаж.СчетФактура,
	|	НДСЗаписиКнигиПродаж.Покупатель,
	|	НДСЗаписиКнигиПродаж.СчетФактура,
	|	НДСЗаписиКнигиПродаж.СтавкаНДС,
	|	НДСЗаписиКнигиПродаж.ВидЦенности,
	|	НДСЗаписиКнигиПродаж.ДатаОплаты,
	|	НДСЗаписиКнигиПродаж.ДокументОплаты,
	|	НДСЗаписиКнигиПродаж.Событие,
	|	НДСЗаписиКнигиПродаж.ДатаСобытия,
	|	НДСЗаписиКнигиПродаж.ДоговорКонтрагента,
	|	НДСЗаписиКнигиПродаж.ЗаписьДополнительногоЛиста,
	|	НДСЗаписиКнигиПродаж.КорректируемыйПериод,
	|	НДСЗаписиКнигиПродаж.СторнирующаяЗаписьДопЛиста,
	|	НДСЗаписиКнигиПродаж.ИсправленныйСчетФактура
	|ИЗ
	|	РегистрНакопления.НДСЗаписиКнигиПродаж КАК НДСЗаписиКнигиПродаж
	|ГДЕ
	|	НДСЗаписиКнигиПродаж.СчетФактура = &Ссылка
	|	И НДСЗаписиКнигиПродаж.Активность
	|	И НДСЗаписиКнигиПродаж.Регистратор = &ДокументОснование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВТ_ЗаписиКнигиПродажПредварительная.Организация КАК Организация,
	|	ВТ_ЗаписиКнигиПродажПредварительная.СчетФактура КАК СчетФактура,
	|	ВТ_ЗаписиКнигиПродажПредварительная.Покупатель КАК Покупатель,
	|	ВТ_ЗаписиКнигиПродажПредварительная.СчетФактураДокумент КАК СчетФактураДокумент,
	|	ВТ_ЗаписиКнигиПродажПредварительная.СтавкаНДС КАК СтавкаНДС,
	|	ВТ_ЗаписиКнигиПродажПредварительная.ВидЦенности КАК ВидЦенности,
	|	ВТ_ЗаписиКнигиПродажПредварительная.ДатаОплаты КАК ДатаОплаты,
	|	ВТ_ЗаписиКнигиПродажПредварительная.ДокументОплаты КАК ДокументОплаты,
	|	ВТ_ЗаписиКнигиПродажПредварительная.Событие КАК Событие,
	|	ВТ_ЗаписиКнигиПродажПредварительная.ДатаСобытия КАК ДатаСобытия,
	|	ВТ_ЗаписиКнигиПродажПредварительная.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ВТ_ЗаписиКнигиПродажПредварительная.ЗаписьДополнительногоЛиста КАК ЗаписьДополнительногоЛиста,
	|	ВТ_ЗаписиКнигиПродажПредварительная.КорректируемыйПериод КАК КорректируемыйПериод,
	|	ВТ_ЗаписиКнигиПродажПредварительная.СторнирующаяЗаписьДопЛиста КАК СторнирующаяЗаписьДопЛиста,
	|	ВТ_ЗаписиКнигиПродажПредварительная.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура
	|ПОМЕСТИТЬ ВТ_ЗаписиКнигиПродаж
	|ИЗ
	|	ВТ_ЗаписиКнигиПродажПредварительная КАК ВТ_ЗаписиКнигиПродажПредварительная
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЗаписиКнигиПродаж.Организация КАК Организация,
	|	ВТ_ЗаписиКнигиПродаж.СчетФактура КАК СчетФактура,
	|	&Период КАК Период,
	|	ВТ_ЗаписиКнигиПродаж.Покупатель КАК Покупатель,
	|	ВТ_ЗаписиКнигиПродаж.СтавкаНДС КАК СтавкаНДС,
	|	ВТ_ЗаписиКнигиПродаж.ВидЦенности КАК ВидЦенности,
	|	ВТ_ЗаписиКнигиПродаж.ДатаОплаты КАК ДатаОплаты,
	|	ВТ_ЗаписиКнигиПродаж.ДокументОплаты КАК ДокументОплаты,
	|	ВТ_ЗаписиКнигиПродаж.Событие КАК Событие,
	|	ВТ_ЗаписиКнигиПродаж.ДатаСобытия КАК ДатаСобытия,
	|	ВТ_ЗаписиКнигиПродаж.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ВТ_ЗаписиКнигиПродаж.ЗаписьДополнительногоЛиста КАК ЗаписьДополнительногоЛиста,
	|	ВТ_ЗаписиКнигиПродаж.КорректируемыйПериод КАК КорректируемыйПериод,
	|	ВТ_ЗаписиКнигиПродаж.СторнирующаяЗаписьДопЛиста КАК СторнирующаяЗаписьДопЛиста,
	|	ВТ_ЗаписиКнигиПродаж.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
	|	СчетФактураДатаНомерДокументовОплаты.НомерПлатежноРасчетногоДокумента КАК НомерДокументаОплаты,
	|	СчетФактураДатаНомерДокументовОплаты.ДатаПлатежноРасчетногоДокумента КАК ДатаДокументаОплаты,
	|	ВЫБОР
	|		КОГДА ВТ_ЗаписиКнигиПродаж.СчетФактураДокумент.Дата >= ДАТАВРЕМЯ(2026, 1, 1)
	|			ТОГДА СчетФактураДатаНомерДокументовОплаты.НомерСчетаФактурыНаАванс
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК НомерСчетаФактурыНаАванс,
	|	ВЫБОР
	|		КОГДА ВТ_ЗаписиКнигиПродаж.СчетФактураДокумент.Дата >= ДАТАВРЕМЯ(2026, 1, 1)
	|			ТОГДА СчетФактураДатаНомерДокументовОплаты.ДатаСчетаФактурыНаАванс
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК ДатаСчетаФактурыНаАванс,
	|	ВЫБОР
	|		КОГДА ВТ_ЗаписиКнигиПродаж.СчетФактураДокумент.Дата >= ДАТАВРЕМЯ(2026, 1, 1)
	|			ТОГДА СчетФактураДатаНомерДокументовОплаты.НомерИсправленияСчетаФактурыНаАванс
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК НомерИсправленияСчетаФактурыНаАванс,
	|	ВЫБОР
	|		КОГДА ВТ_ЗаписиКнигиПродаж.СчетФактураДокумент.Дата >= ДАТАВРЕМЯ(2026, 1, 1)
	|			ТОГДА СчетФактураДатаНомерДокументовОплаты.ДатаИсправленияСчетаФактурыНаАванс
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК ДатаИсправленияСчетаФактурыНаАванс
	|ИЗ
	|	ВТ_ЗаписиКнигиПродаж КАК ВТ_ЗаписиКнигиПродаж
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактура.ДатаНомерДокументовОплаты КАК СчетФактураДатаНомерДокументовОплаты
	|		ПО ВТ_ЗаписиКнигиПродаж.СчетФактураДокумент = СчетФактураДатаНомерДокументовОплаты.Ссылка
	|ГДЕ
	|	СчетФактураДатаНомерДокументовОплаты.Ссылка = &Ссылка";

	Возврат ТекстЗапроса + ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();

КонецФункции

// КОРРЕКТИРОВКА НДС

// Формирование движений при корректировке реализации
Процедура СформироватьДвиженияКорректировкиРеализацияТоваровУслуг(ДокументСсылка, СтруктураДополнительныеСвойства,
	ДокументРеализации) Экспорт

	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Если Не ПлательщикНДС Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Запрос.УстановитьПараметр("Период", СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	УчетАгентскогоНДСПокупателем = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем");

	ЭтоКомиссия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВидДоговора")
		= Перечисления.ВидыДоговоров.СКомиссионером;

	ИсправляемыйДокумент = УчетНДСПереопределяемый.ПолучитьИсправляемыйДокументРеализации(ДокументРеализации);
	ДатаИсправляемогоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсправляемыйДокумент, "Дата");
	СчетФактура = ?( СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийИсправленияПоступленияРеализации.ИсправлениеОшибки, ИсправляемыйДокумент,
		ДокументСсылка);
	СчетФактураДата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетФактура, "Дата");

	ИсходныйСчетФактураДата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументРеализации, "Дата");
	
	КорректироватьВТекущемпериоде = Ложь;
	Если УчетНДС.ПолучитьПорядокКорректировкиНДС(ДатаИсправляемогоДокумента) = 2 И ТипЗнч(ИсправляемыйДокумент) = Тип(
		"ДокументСсылка.КорректировкаРеализации") Тогда
		СчетФактураДата = ДатаИсправляемогоДокумента;
		ИсходныйСчетФактураДата = ДатаИсправляемогоДокумента;
		КорректироватьВТекущемпериоде = СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
			= Перечисления.ВидыОперацийИсправленияПоступленияРеализации.СогласованноеИзменение;
	ИначеЕсли УчетНДС.ПолучитьПорядокКорректировкиНДС(СчетФактураДата) = 2 Тогда
		КорректироватьВТекущемпериоде = Истина;
	Иначе
		СчетФактураДата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументРеализации, "Дата");
	КонецЕсли;

	Если УчетАгентскогоНДСПокупателем = Истина Тогда
		СобытиеРеализация   = Перечисления.СобытияПоНДСПродажи.НалогИсчисляетПокупатель;
		СобытиеПриобретение = Перечисления.СобытияПоНДСПокупки.НалогИсчисляетПокупатель;
	Иначе
		СобытиеРеализация   = Перечисления.СобытияПоНДСПродажи.Реализация;
		СобытиеПриобретение = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету;
	КонецЕсли;
	Запрос.УстановитьПараметр("СобытиеРеализация", СобытиеРеализация);
	Запрос.УстановитьПараметр("СобытиеПриобретение", СобытиеПриобретение);
	Запрос.УстановитьПараметр("ЭтоКомиссия", ЭтоКомиссия);
	Запрос.УстановитьПараметр("СчетФактура", СчетФактура);
	Запрос.УстановитьПараметр("СчетФактураДата", СчетФактураДата);
	Запрос.УстановитьПараметр("ИсправленныйСчетФактура", ?(СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийИсправленияПоступленияРеализации.ИсправлениеОшибки, ДокументСсылка, Неопределено));
	Запрос.УстановитьПараметр("ИсправляемыйСчетФактура", ИсправляемыйДокумент);
	Запрос.УстановитьПараметр("СчетФактураДата", СчетФактураДата);
	Запрос.УстановитьПараметр("КорректироватьВТекущемпериоде", КорректироватьВТекущемпериоде);
	Запрос.УстановитьПараметр("РасчетыВВалюте", СтруктураДополнительныеСвойства.ВалютаДокумента
		<> СтруктураДополнительныеСвойства.НациональнаяВалюта);
	Запрос.УстановитьПараметр("МоментДокумента",
		Новый Граница(Новый МоментВремени(СтруктураДополнительныеСвойства.ДляПроведения.Дата, ДокументСсылка),
		ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("ДатаИсправляемогоСчетаФактуры", ДатаИсправляемогоДокумента);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("ИсходныйСчетФактураДата", ИсходныйСчетФактураДата);
	Запрос.УстановитьПараметр("СуммаВключаетНДС", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"СуммаВключаетНДС"));
	
	// ТаблицаТоварыНДС
	ТекстЗапроса = "ВЫБРАТЬ
				   |    КорректировкаРеализацииЗапасы.Ссылка КАК Ссылка,
				   |    КорректировкаРеализацииЗапасы.Номенклатура КАК Номенклатура,
				   |    КорректировкаРеализацииЗапасы.Характеристика КАК Характеристика,
				   |    КорректировкаРеализацииЗапасы.Партия КАК Партия,
				   |    КорректировкаРеализацииЗапасы.СтранаПроисхождения КАК СтранаПроисхождения,
				   |    КорректировкаРеализацииЗапасы.НомерГТД КАК НомерГТД,
				   |    ВЫБОР
				   |        КОГДА НЕ КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
				   |            ТОГДА КорректировкаРеализацииЗапасы.Количество
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.Количество - КорректировкаРеализацииЗапасы.КоличествоДоИзменения
				   |    КОНЕЦ КАК Количество,
				   |    КорректировкаРеализацииЗапасы.СтавкаНДС КАК СтавкаНДС,
				   |    КорректировкаРеализацииЗапасы.НомерСтроки КАК НомерСтроки,
				   |    ВЫБОР
				   |        КОГДА
				   |            КорректировкаРеализацииЗапасы.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоСкладскимОрдерам)
				   |            ТОГДА КорректировкаРеализацииЗапасы.ДокументПоступления
				   |        КОГДА
				   |            КорректировкаРеализацииЗапасы.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоПрочимДокументам)
				   |            ТОГДА КорректировкаРеализацииЗапасы.Ссылка
				   |        ИНАЧЕ НЕОПРЕДЕЛЕНО
				   |    КОНЕЦ КАК ДокументПоступления,
				   |    КорректировкаРеализацииЗапасы.СуммаНДСДоКорректировки КАК СуммаНДСРубДоКорректировки,
				   |    КорректировкаРеализацииЗапасы.СуммаНДС КАК СуммаНДСРуб,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализацииЗапасы.СуммаДоКорректировки -
				   |                КорректировкаРеализацииЗапасы.СуммаНДСДоКорректировки
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.СуммаДоКорректировки
				   |    КОНЕЦ КАК СуммаБезНДСРубДоКорректировки,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализацииЗапасы.Сумма - КорректировкаРеализацииЗапасы.СуммаНДС
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.Сумма
				   |    КОНЕЦ КАК СуммаБезНДСРуб,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализацииЗапасы.СуммаДоКорректировки
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.СуммаДоКорректировки +
				   |            КорректировкаРеализацииЗапасы.СуммаНДСДоКорректировки
				   |    КОНЕЦ КАК СуммаРубДоКорректировки,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализацииЗапасы.Сумма
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.Сумма + КорректировкаРеализацииЗапасы.СуммаНДС
				   |    КОНЕЦ КАК СуммаРуб,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализацииЗапасы.СуммаДоКорректировки
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.СуммаДоКорректировки +
				   |            КорректировкаРеализацииЗапасы.СуммаНДСДоКорректировки
				   |    КОНЕЦ КАК СуммаВзаиморасчетовДоКорректировки,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализацииЗапасы.СуммаДоИзменения
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.СуммаДоИзменения + КорректировкаРеализацииЗапасы.СуммаНДСДоИзменения
				   |    КОНЕЦ КАК СуммаВзаиморасчетовДоИзменения,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализацииЗапасы.Сумма
				   |        ИНАЧЕ КорректировкаРеализацииЗапасы.Сумма + КорректировкаРеализацииЗапасы.СуммаНДС
				   |    КОНЕЦ КАК СуммаВзаиморасчетов
				   |ПОМЕСТИТЬ ТаблицаТоварыНДС
				   |ИЗ
				   |    Документ.КорректировкаРеализации.Запасы КАК КорректировкаРеализацииЗапасы
				   |ГДЕ
				   |    КорректировкаРеализацииЗапасы.Ссылка = &Ссылка
				   |    И КорректировкаРеализацииЗапасы.Ссылка.ОтражатьВУчете
				   |
				   |ОБЪЕДИНИТЬ ВСЕ
				   |
				   |ВЫБРАТЬ
				   |    КорректировкаРеализации.Ссылка,
				   |    КорректировкаРеализации.НоменклатураДоставки,
				   |    ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),
				   |    ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка),
				   |    КорректировкаРеализации.НоменклатураДоставки.СтранаПроисхождения,
				   |    ЗНАЧЕНИЕ(Справочник.НомераГТД.ПустаяСсылка),
				   |    ВЫБОР
				   |        КОГДА НЕ КорректировкаРеализации.ЕстьВДокументеРеализации
				   |        И КорректировкаРеализации.СтоимостьДоставки > 0
				   |            ТОГДА 1
				   |        КОГДА КорректировкаРеализации.ОтменаДоставки
				   |            ТОГДА -1
				   |        ИНАЧЕ 0
				   |    КОНЕЦ,
				   |    КорректировкаРеализации.СтавкаНДСДоставки,
				   |    0,
				   |    НЕОПРЕДЕЛЕНО,
				   |    КорректировкаРеализации.СуммаНДСДоставкиДоКорректировки,
				   |    КорректировкаРеализации.СуммаНДСДоставки,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализации.СуммаНДСДоставкиДоКорректировки -
				   |                КорректировкаРеализации.СуммаНДСДоставкиДоКорректировки
				   |        ИНАЧЕ КорректировкаРеализации.СуммаНДСДоставкиДоКорректировки
				   |    КОНЕЦ,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализации.СтоимостьДоставки - КорректировкаРеализации.СуммаНДСДоставки
				   |        ИНАЧЕ КорректировкаРеализации.СтоимостьДоставки
				   |    КОНЕЦ,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализации.СтоимостьДоставкиДоКорректировки
				   |        ИНАЧЕ КорректировкаРеализации.СтоимостьДоставкиДоКорректировки +
				   |            КорректировкаРеализации.СуммаНДСДоставкиДоКорректировки
				   |    КОНЕЦ,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализации.СтоимостьДоставки
				   |        ИНАЧЕ КорректировкаРеализации.СтоимостьДоставки + КорректировкаРеализации.СуммаНДСДоставки
				   |    КОНЕЦ,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализации.СтоимостьДоставкиДоКорректировки
				   |        ИНАЧЕ КорректировкаРеализации.СтоимостьДоставкиДоКорректировки +
				   |            КорректировкаРеализации.СуммаНДСДоставкиДоКорректировки
				   |    КОНЕЦ,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализации.СтоимостьДоставкиДоИзменения
				   |        ИНАЧЕ КорректировкаРеализации.СтоимостьДоставкиДоИзменения +
				   |            КорректировкаРеализации.СуммаНДСДоставкиДоИзменения
				   |    КОНЕЦ,
				   |    ВЫБОР
				   |        КОГДА &СуммаВключаетНДС
				   |            ТОГДА КорректировкаРеализации.СтоимостьДоставки
				   |        ИНАЧЕ КорректировкаРеализации.СтоимостьДоставки + КорректировкаРеализации.СуммаНДСДоставки
				   |    КОНЕЦ
				   |ИЗ
				   |    Документ.КорректировкаРеализации КАК КорректировкаРеализации
				   |ГДЕ
				   |    КорректировкаРеализации.Ссылка = &Ссылка
				   |    И КорректировкаРеализации.ОтражатьВУчете
				   |    И КорректировкаРеализации.НоменклатураДоставки <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)"
		+ ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();
		
    // ТаблицаНДСВычеты
	ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ
								  |    &СчетФактура КАК СчетФактура,
								  |    &ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
								  |    ""Корректировка НДС"" КАК Содержание,
								  |    ЛОЖЬ КАК ЭтоУслуга,
								  |    &СобытиеПриобретение КАК Событие,
								  |    ТаблицаТовары.Номенклатура,
								  |    ТаблицаТовары.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
								  |    ТаблицаТовары.СуммаНДСРубДоКорректировки - ТаблицаТовары.СуммаНДСРуб КАК НДС,
								  |    ВЫБОР
								  |        КОГДА &РасчетыВВалюте
								  |            ТОГДА ТаблицаТовары.СуммаБезНДСРубДоКорректировки - ТаблицаТовары.СуммаБезНДСРуб
								  |        ИНАЧЕ ТаблицаТовары.СуммаРубДоКорректировки - ТаблицаТовары.СуммаНДСРубДоКорректировки -
								  |            (ТаблицаТовары.СуммаРуб - ТаблицаТовары.СуммаНДСРуб)
								  |    КОНЕЦ КАК СуммаБезНДС,
								  |    Реквизиты.Дата КАК Период,
								  |    Реквизиты.Дата КАК ДатаСобытия,
								  |    &Организация,
								  |    Реквизиты.Контрагент КАК Поставщик,
								  |    ЛОЖЬ КАК ЗаписьДополнительногоЛиста,
								  |    ДАТАВРЕМЯ(1, 1, 1) КАК КорректируемыйПериод,
								  |    ЛОЖЬ КАК СторнирующаяЗаписьДопЛиста,
								  |    ТаблицаТовары.НомерСтроки,
								  |    Реквизиты.Ссылка КАК Регистратор,
								  |    НЕОПРЕДЕЛЕНО КАК ВидДвижения
								  |ИЗ
								  |    ТаблицаТоварыНДС КАК ТаблицаТовары
								  |        ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
								  |        ПО ИСТИНА
								  |ГДЕ
								  |    НЕ &ЭтоКомиссия
								  |    И ТаблицаТовары.СуммаВзаиморасчетовДоКорректировки - ТаблицаТовары.СуммаВзаиморасчетов > 0"
		+ ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();


	// ТаблицаНДСВосстановление
	ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ
								  |   &СчетФактура КАК СчетФактура,
								  |   &ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
								  |   ""Реализация товаров"" КАК Содержание,
								  |   ЛОЖЬ КАК ЭтоУслуга,
								  |   &СобытиеРеализация КАК Событие,
								  |   Реквизиты.Дата КАК ДатаСобытия,
								  |   ТаблицаТовары.Номенклатура,
								  |   ТаблицаТовары.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
								  |   ТаблицаТовары.СуммаНДСРуб - ТаблицаТовары.СуммаНДСРубДоКорректировки КАК НДС,
								  |   ВЫБОР
								  |       КОГДА &РасчетыВВалюте
								  |           ТОГДА ТаблицаТовары.СуммаБезНДСРуб - ТаблицаТовары.СуммаБезНДСРубДоКорректировки
								  |       ИНАЧЕ ТаблицаТовары.СуммаРуб - ТаблицаТовары.СуммаНДСРуб - (ТаблицаТовары.СуммаРубДоКорректировки - ТаблицаТовары.СуммаНДСРубДоКорректировки)
								  |   КОНЕЦ КАК СуммаБезНДС,
								  |   Реквизиты.Дата КАК Период,
								  |   &Организация,
								  |   Реквизиты.Контрагент КАК Покупатель,
								  |   ТаблицаТовары.НомерСтроки,
								  |   Реквизиты.Ссылка КАК Регистратор,
								  |   ВЫБОР
								  |       КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&СчетФактураДата, КВАРТАЛ)
								  |               ИЛИ &КорректироватьВТекущемпериоде
								  |           ТОГДА ЛОЖЬ
								  |       ИНАЧЕ ИСТИНА
								  |   КОНЕЦ КАК ЗаписьДополнительногоЛиста,
								  |   ЛОЖЬ КАК СторнирующаяЗаписьДопЛиста,
								  |   ВЫБОР
								  |       КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&СчетФактураДата, КВАРТАЛ)
								  |               ИЛИ &КорректироватьВТекущемпериоде
								  |           ТОГДА ДАТАВРЕМЯ(1, 1, 1)
								  |       ИНАЧЕ НАЧАЛОПЕРИОДА(&СчетФактураДата, КВАРТАЛ)
								  |   КОНЕЦ КАК КорректируемыйПериод,
								  |   ЛОЖЬ КАК УслугиЗаРубежом
								  |ИЗ
								  |   ТаблицаТоварыНДС КАК ТаблицаТовары
								  |       ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
								  |       ПО (ИСТИНА)
								  |ГДЕ
								  |   НЕ &ЭтоКомиссия
								  |   И ТаблицаТовары.СуммаВзаиморасчетовДоКорректировки - ТаблицаТовары.СуммаВзаиморасчетов < 0";

	Запрос.Текст = ТекстЗапроса;

	МассивРезультатов = Запрос.ВыполнитьПакет();

	ТаблицаНДСВычет = МассивРезультатов[1].Выгрузить();
	ТаблицаНДСВосстановление = МассивРезультатов[2].Выгрузить();
	Если СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийИсправленияПоступленияРеализации.СогласованноеИзменение Тогда
        
        // Корректировочный счет-фактура

		СформироватьКорректировочныеДвиженияКорректировкаРеализации(ДокументСсылка, СтруктураДополнительныеСвойства,
			ТаблицаНДСВычет, ТаблицаНДСВосстановление);

	Иначе    
// Исправительный счет-фактура

		Запрос.Текст = ТекстЗапросаДляИсправительныйСчетФактура();

		МассивРезультатов = Запрос.ВыполнитьПакет();
		ТаблицаНДССторноКнигиПродаж = МассивРезультатов[0].Выгрузить();
		ТаблицаНДССведенияПоДокументамОплаты = МассивРезультатов[1].Выгрузить();
		ТаблицаНДСОстаткиНДСПредъявленный = МассивРезультатов[2].Выгрузить();
		ТаблицаНДССторноКнигиПокупок = МассивРезультатов[4].Выгрузить();
		ТаблицаНДСНДСНачисление = МассивРезультатов[5].Выгрузить();
		
		СтруктураДополнительныеСвойства.Вставить("ТаблицаНДСНДСНачисление", ТаблицаНДСНДСНачисление);
        
        // Сторно движений исправляемого документа
		СформироватьДвиженияНДСЗаписиКнигиПродажНачислениеНДСПоРеализации(
            ТаблицаНДССторноКнигиПродаж, СтруктураДополнительныеСвойства);
//
		ОтразитьСведенияПоДокументамОплатыИсправляемогоСчетаФактуры(
           ТаблицаНДССторноКнигиПродаж, ТаблицаНДССведенияПоДокументамОплаты,
			СтруктураДополнительныеСвойства.ТаблицыДляДвижений);
//        // Формирование исправленных движений
		СформироватьИсправительныеДвиженияКорректировкаРеализации(ДокументСсылка, СтруктураДополнительныеСвойства,
			ТаблицаНДСВычет, ТаблицаНДСВосстановление, ТаблицаНДСОстаткиНДСПредъявленный, ТаблицаНДССторноКнигиПокупок, ТаблицаНДССведенияПоДокументамОплаты);
	КонецЕсли;

КонецПроцедуры

Функция ТекстЗапросаДляИсправительныйСчетФактура()
    
    // ТаблицаНДССторноКнигиПродаж
	ТекстЗапроса = "ВЫБРАТЬ
				   |    &Период КАК Период,
				   |    &Ссылка КАК Регистратор,
				   |    ""Сторнирование реализации"" КАК Содержание,
				   |    ЗаписиКнигиПродаж.Организация КАК Организация,
				   |    ЗаписиКнигиПродаж.Покупатель КАК Покупатель,
				   |    ЗаписиКнигиПродаж.СчетФактура КАК СчетФактура,
				   |    ЗаписиКнигиПродаж.ВидЦенности КАК ВидЦенности,
				   |    ЗаписиКнигиПродаж.СтавкаНДС КАК СтавкаНДС,
				   |    ЗаписиКнигиПродаж.ДатаОплаты КАК ДатаОплаты,
				   |    ЗаписиКнигиПродаж.ДокументОплаты КАК ДокументОплаты,
				   |    ЗаписиКнигиПродаж.Событие КАК Событие,
				   |    &Период КАК ДатаСобытия,
				   |    ВЫБОР
				   |        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ИсходныйСчетФактураДата, КВАРТАЛ)
				   |            ТОГДА ЛОЖЬ
				   |        ИНАЧЕ ИСТИНА
				   |    КОНЕЦ КАК ЗаписьДополнительногоЛиста,
				   |    ВЫБОР
				   |        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ИсходныйСчетФактураДата, КВАРТАЛ)
				   |            ТОГДА ЛОЖЬ
				   |        ИНАЧЕ ИСТИНА
				   |    КОНЕЦ КАК СторнирующаяЗаписьДопЛиста,
				   |    ВЫБОР
				   |        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ИсходныйСчетФактураДата, КВАРТАЛ)
				   |            ТОГДА ДАТАВРЕМЯ(1, 1, 1)
				   |        ИНАЧЕ НАЧАЛОПЕРИОДА(&ИсходныйСчетФактураДата, КВАРТАЛ)
				   |    КОНЕЦ КАК КорректируемыйПериод,
				   |    ЗаписиКнигиПродаж.ДоговорКонтрагента КАК ДоговорКонтрагента,
				   |    ЗаписиКнигиПродаж.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
				   |    ЗаписиКнигиПродаж.СуммаБезНДСОборот * -1 КАК СуммаБезНДС,
				   |    ЗаписиКнигиПродаж.НДСОборот * -1 КАК НДС
				   |ИЗ
				   |    РегистрНакопления.НДСЗаписиКнигиПродаж.Обороты(, &МоментДокумента,, Организация = &Организация
				   |    И СчетФактура = &ИсправляемыйСчетФактура
				   |    И НЕ ВидЦенности = ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.АвансыПолученные)) КАК ЗаписиКнигиПродаж"
		+ ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();
    
    // ТаблицаНДССведенияПоДокументамОплаты
	ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ РАЗЛИЧНЫЕ
								  |   НДСЗаписиКнигиПродаж.НомерДокументаОплаты КАК НомерДокументаОплаты,
								  |   НДСЗаписиКнигиПродаж.ДатаДокументаОплаты КАК ДатаДокументаОплаты
								  |ИЗ
								  |   РегистрНакопления.НДСЗаписиКнигиПродаж КАК НДСЗаписиКнигиПродаж
								  |ГДЕ
								  |   НДСЗаписиКнигиПродаж.Активность
								  |   И НДСЗаписиКнигиПродаж.Организация = &Организация
								  |   И НДСЗаписиКнигиПродаж.СчетФактура = &ИсправляемыйСчетФактура
								  |   И НДСЗаписиКнигиПродаж.ИсправленныйСчетФактура = НЕОПРЕДЕЛЕНО
								  |   И НДСЗаписиКнигиПродаж.НомерДокументаОплаты <> """"
								  |   И НДСЗаписиКнигиПродаж.ДатаДокументаОплаты <> ДАТАВРЕМЯ(1, 1, 1)
								  |   И НЕ НДСЗаписиКнигиПродаж.ЗаписьДополнительногоЛиста"
		+ ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();
    
    // ТаблицаНДСОстаткиНДСПредъявленный
	ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ
								  |   &Период КАК Период,
								  |   &Ссылка КАК Регистратор,
								  |   НДСПредъявленныйОстатки.Организация,
								  |   НДСПредъявленныйОстатки.СчетФактура,
								  |   НДСПредъявленныйОстатки.ВидЦенности,
								  |   НДСПредъявленныйОстатки.СтавкаНДС,
								  |   НДСПредъявленныйОстатки.СчетУчетаНДС,
								  |   НДСПредъявленныйОстатки.Поставщик,
								  |   НДСПредъявленныйОстатки.ДатаОплаты,
								  |   НДСПредъявленныйОстатки.ДоговорКонтрагента,
								  |   НДСПредъявленныйОстатки.ИсправленныйСчетФактура,
								  |   НДСПредъявленныйОстатки.СуммаБезНДСОстаток КАК СуммаБезНДС,
								  |   НДСПредъявленныйОстатки.НДСОстаток КАК НДС,
								  |   NULL КАК Событие,
								  |   NULL КАК ДатаСобытия
								  |ИЗ
								  |   РегистрНакопления.НДСПредъявленный.Остатки(
								  |           &МоментДокумента,
								  |           Организация = &Организация
								  |               И СчетФактура = &ИсправляемыйСчетФактура) КАК НДСПредъявленныйОстатки"
		+ ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();
    
    // ТаблицаНДССторноКнигиПокупок
	ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ ПЕРВЫЕ 1
								  |   НДСЗаписиКнигиПокупок.КодВидаОперации КАК КодВидаОперации
								  |ПОМЕСТИТЬ КодОперацииСторнируемойЗаписи
								  |ИЗ
								  |   РегистрНакопления.НДСЗаписиКнигиПокупок КАК НДСЗаписиКнигиПокупок
								  |ГДЕ
								  |   НДСЗаписиКнигиПокупок.Организация = &Организация
								  |   И НДСЗаписиКнигиПокупок.СчетФактура = &ИсправляемыйСчетФактура
								  |   И НДСЗаписиКнигиПокупок.Активность
								  |   И НДСЗаписиКнигиПокупок.КодВидаОперации <> """"
								  |;
								  |
								  |////////////////////////////////////////////////////////////////////////////////
								  |ВЫБРАТЬ
								  |   &Период КАК Период,
								  |   &Ссылка КАК Регистратор,
								  |   ""Сторнирование реализации"" КАК Содержание,
								  |   ЗаписиКнигиПокупок.Организация КАК Организация,
								  |   ЗаписиКнигиПокупок.Поставщик КАК Поставщик,
								  |   ЗаписиКнигиПокупок.СчетФактура КАК СчетФактура,
								  |   ЗаписиКнигиПокупок.ВидЦенности КАК ВидЦенности,
								  |   ЗаписиКнигиПокупок.СтавкаНДС КАК СтавкаНДС,
								  |   ЗаписиКнигиПокупок.ДатаОплаты КАК ДатаОплаты,
								  |   ЗаписиКнигиПокупок.ДокументОплаты КАК ДокументОплаты,
								  |   ЗаписиКнигиПокупок.Событие КАК Событие,
								  |   &Период КАК ДатаСобытия,
								  |   ВЫБОР
								  |       КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
								  |           ТОГДА ЛОЖЬ
								  |       ИНАЧЕ ИСТИНА
								  |   КОНЕЦ КАК ЗаписьДополнительногоЛиста,
								  |   ВЫБОР
								  |       КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
								  |           ТОГДА ДАТАВРЕМЯ(1, 1, 1)
								  |       ИНАЧЕ НАЧАЛОПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
								  |   КОНЕЦ КАК КорректируемыйПериод,
								  |   ЗаписиКнигиПокупок.ДоговорКонтрагента КАК ДоговорКонтрагента,
								  |   ЗаписиКнигиПокупок.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
								  |   ЗаписиКнигиПокупок.СуммаБезНДСОборот * -1 КАК СуммаБезНДС,
								  |   ЗаписиКнигиПокупок.НДСОборот * -1 КАК НДС,
								  |   КодОперацииСторнируемойЗаписи.КодВидаОперации КАК КодВидаОперации
								  |ИЗ
								  |   РегистрНакопления.НДСЗаписиКнигиПокупок.Обороты(
								  |           ,
								  |           &МоментДокумента,
								  |           ,
								  |           Организация = &Организация
								  |               И СчетФактура = &ИсправляемыйСчетФактура
								  |               И НЕ ВидЦенности = ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.АвансыПолученные)) КАК ЗаписиКнигиПокупок
								  |       ЛЕВОЕ СОЕДИНЕНИЕ КодОперацииСторнируемойЗаписи КАК КодОперацииСторнируемойЗаписи
								  |       ПО (ИСТИНА)"
		+ ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();
		
		  ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ
		  |    ТоварыУслуги.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
		  |    СУММА(ТоварыУслуги.СуммаБезНДСРуб) КАК СуммаБезНДС,
		  |    СУММА(ТоварыУслуги.СуммаНДСРуб) КАК НДС,
		  |    Реквизиты.Ссылка КАК Регистратор,
		  |    Реквизиты.Дата КАК Период,
		  |    &Организация КАК Организация,
		  |    Реквизиты.Контрагент КАК Покупатель,
		  |    Реквизиты.Ссылка КАК ИсправленныйСчетФактура,
		  |    ТоварыУслуги.Номенклатура,
		  |    &СобытиеРеализация КАК Событие,
		  |    Реквизиты.Дата КАК ДатаСобытия,
		  |    &ИсправляемыйСчетФактура КАК СчетФактура,
		  |    ВЫБОР
		  |        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
		  |            ТОГДА ЛОЖЬ
		  |        ИНАЧЕ ИСТИНА
		  |    КОНЕЦ КАК ЗаписьДополнительногоЛиста,
		  |    ЛОЖЬ КАК СторнирующаяЗаписьДопЛиста,
		  |    ВЫБОР
		  |        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
		  |            ТОГДА ДАТАВРЕМЯ(1, 1, 1)
		  |        ИНАЧЕ НАЧАЛОПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
		  |    КОНЕЦ КАК КорректируемыйПериод
		  |ИЗ
		  |    ТаблицаТоварыНДС КАК ТоварыУслуги
		  |        ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
		  |        ПО ИСТИНА
		  |СГРУППИРОВАТЬ ПО
		  |    ТоварыУслуги.СтавкаНДС,
		  |    Реквизиты.Ссылка,
		  |    &Организация,
		  |    Реквизиты.Контрагент,
		  |    Реквизиты.Дата,
		  |    ТоварыУслуги.Номенклатура,
		  |    ВЫБОР
		  |        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
		  |            ТОГДА ЛОЖЬ
		  |        ИНАЧЕ ИСТИНА
		  |    КОНЕЦ,
		  |    ВЫБОР
		  |        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
		  |            ТОГДА ДАТАВРЕМЯ(1, 1, 1)
		  |        ИНАЧЕ НАЧАЛОПЕРИОДА(&ДатаИсправляемогоСчетаФактуры, КВАРТАЛ)
		  |    КОНЕЦ"
		+ ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();

	Возврат ТекстЗапроса;
КонецФункции

Процедура СформироватьКорректировочныеДвиженияКорректировкаРеализации(ДокументСсылка, СтруктураДополнительныеСвойства,
	ТаблицаНДСВычет, ТаблицаНДСВосстановление)

	ТаблицаНДСВычет.Индексы.Добавить("Событие");

	ИсправляемыйДокумент = УчетНДСПереопределяемый.ПолучитьИсправляемыйДокументРеализации(
		СтруктураДополнительныеСвойства.ДляПроведения.ДокументРеализации);

	ДатаДокументаРеализации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсправляемыйДокумент, "Дата");

	СтруктураОтбора = Новый Структура("Событие", Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету);
	ТаблицаНДСПредъявленный = ТаблицаНДСВычет.Скопировать(СтруктураОтбора);
    // Отражение предъявленного НДС по строкам на уменьшение стоимости
	СформироватьДвиженияПредъявленНДС(ТаблицаНДСПредъявленный, ДатаДокументаРеализации,
		СтруктураДополнительныеСвойства, Истина, Ложь);

	СтруктураОтбора = Новый Структура("Событие", Перечисления.СобытияПоНДСПокупки.НалогИсчисляетПокупатель);
	ТаблицаНДСПокупки = ТаблицаНДСВычет.Скопировать(СтруктураОтбора);
    // Отражение вычета НДС по строкам на уменьшение стоимости
	УчетНДС.ЗаполнитьВидыЦенностей(ТаблицаНДСПокупки);
    // Отражение вычета НДС по строкам на уменьшение стоимости
	СформироватьДвиженияНДСЗаписиКнигиПокупок(ТаблицаНДСПокупки, СтруктураДополнительныеСвойства);

	СформироватьДвиженияЗаписьКнигиПродаж(ТаблицаНДСВосстановление, СтруктураДополнительныеСвойства);

КонецПроцедуры

Процедура СформироватьИсправительныеДвиженияКорректировкаРеализации(ДокументСсылка, СтруктураДополнительныеСвойства,
	ТаблицаНДСВычет, ТаблицаНДСВосстановление, ТаблицаНДСОстаткиНДСПредъявленный, ТаблицаНДССторноКнигиПокупок,
	ТаблицаНДССведенияПоДокументамОплаты)

	ИсправляемыйДокумент = УчетНДСПереопределяемый.ПолучитьИсправляемыйДокументРеализации(
		СтруктураДополнительныеСвойства.ДляПроведения.ДокументРеализации);
	ДатаДокументаРеализации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсправляемыйДокумент, "Дата");

	Если ТипЗнч(ИсправляемыйДокумент) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
    
        // Сторно движений исправляемого документа
		СформироватьДвиженияПредъявленНДС(ТаблицаНДСОстаткиНДСПредъявленный, ДатаДокументаРеализации,
			СтруктураДополнительныеСвойства, Истина, Ложь);
		СформироватьДвиженияНДСЗаписиКнигиПокупок(ТаблицаНДССторноКнигиПокупок, СтруктураДополнительныеСвойства);
        
        // Новые движения по исправленному корректировочному счету-фактуре
		СформироватьКорректировочныеДвиженияКорректировкаРеализации(ДокументСсылка, СтруктураДополнительныеСвойства,
			ТаблицаНДСВычет, ТаблицаНДСВосстановление);

	Иначе

		СформироватьДвиженияЗаписьКнигиПродаж(
            СтруктураДополнительныеСвойства.ТаблицаНДСНДСНачисление, СтруктураДополнительныеСвойства);

		ОтразитьСведенияПоДокументамОплатыИсправляемогоСчетаФактуры(
            СтруктураДополнительныеСвойства.ТаблицаНДСНДСНачисление, ТаблицаНДССведенияПоДокументамОплаты,
			СтруктураДополнительныеСвойства.ТаблицыДляДвижений);
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);	
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);

	КонецЕсли;

КонецПроцедуры

Процедура СформироватьДвиженияЗаписьКнигиПродаж(ТаблицаДвижений, СтруктураДополнительныеСвойства)

	Если ТаблицаДвижений.Количество() = 0 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	УчетНДС.ЗаполнитьВидыЦенностей(ТаблицаДвижений);
	КолонкиГруппировок = "ВидЦенности, СтавкаНДС, Покупатель, Организация, СчетФактура, ИсправленныйСчетФактура, Событие,
						 |ЗаписьДополнительногоЛиста, СторнирующаяЗаписьДопЛиста, КорректируемыйПериод, ДатаСобытия, Регистратор, Период";

	ТаблицаДвижений.Свернуть(КолонкиГруппировок, "СуммаБезНДС, НДС");

	Если Не СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаНДСЗаписиКнигиПродаж") Тогда
		ТаблицаЗаписиКнигиПродаж = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПродаж");
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж",
			ТаблицаЗаписиКнигиПродаж);
	КонецЕсли;
	Для Каждого СтрокаДвижения Из ТаблицаДвижений Цикл

		Если СтрокаДвижения.СуммаБезНДС = 0 И СтрокаДвижения.НДС = 0 Тогда
			Продолжить;
		КонецЕсли;


        
        // НДС Продажи
		Движение = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаНДСЗаписиКнигиПродаж.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, СтрокаДвижения);

	КонецЦикла;

КонецПроцедуры

// Процедура инициализирует пустую таблицу значений для проведения документа по регистру НДС записи книги продаж.
//
// Параметры:
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств, в которую будет добавлена пустая таблица значений.
//
Процедура ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства)

    Если СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаНДСЗаписиКнигиПродаж") Тогда
        Возврат;
    КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж", Новый ТаблицаЗначений);

КонецПроцедуры

Процедура СформироватьДвиженияНДСЗаписиКнигиПродажНачислениеНДСПоРеализации(ТаблицаПоРеализации, Движения)

	Если Не Движения.ТаблицыДляДвижений.Свойство("ТаблицаНДСЗаписиКнигиПродаж") Тогда
		ТаблицаЗаписиКнигиПродаж = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПродаж");
		Движения.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПродаж", ТаблицаЗаписиКнигиПродаж);
	КонецЕсли;

	Для Каждого СтрокаРеализации Из ТаблицаПоРеализации Цикл

		Движение = Движения.ТаблицыДляДвижений.ТаблицаНДСЗаписиКнигиПродаж.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, СтрокаРеализации);

	КонецЦикла;

КонецПроцедуры

Процедура ОтразитьСведенияПоДокументамОплатыИсправляемогоСчетаФактуры(ТаблицаНДСНачислениеНДС,
	ТаблицаНДССведенияПоДокументамОплаты, Движения)

	Если ТаблицаНДСНачислениеНДС.Количество() = 0 Или ТаблицаНДССведенияПоДокументамОплаты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	СведенияОНачислении = ТаблицаНДСНачислениеНДС[0];

	Для Каждого СтрокаСведений Из ТаблицаНДССведенияПоДокументамОплаты Цикл

		Если ЗначениеЗаполнено(СтрокаСведений.НомерДокументаОплаты) И ЗначениеЗаполнено(
			СтрокаСведений.ДатаДокументаОплаты) Тогда

			Движение = Движения.ТаблицаНДСЗаписиКнигиПродаж.Добавить();
			ЗаполнитьЗначенияСвойств(Движение, СведенияОНачислении, , "СуммаБезНДС,НДС");
			ЗаполнитьЗначенияСвойств(Движение, СтрокаСведений);

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры


// РЕАЛИЗАЦИЯ ПО СТАВКЕ 0%

Процедура СформироватьДвиженияНДСРеализация0(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	ПустаяТаблицаНДСРеализация0(СтруктураДополнительныеСвойства);
	
	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);
    Если Не ПлательщикНДС Тогда
		Возврат;
	КонецЕсли;
	
	ПлательщикНДСНаУСНБезВычетов = Не УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВременнаяТаблицаЗапасы.Период КАК Период,
	|	ВременнаяТаблицаЗапасы.Период КАК ДатаСобытия,
	|	ВременнаяТаблицаЗапасы.Организация КАК Организация,
	|	ВременнаяТаблицаЗапасы.Контрагент КАК Покупатель,
	|	ВременнаяТаблицаЗапасы.Документ КАК СчетФактура,
	|	ЗНАЧЕНИЕ(Перечисление.НДССостоянияРеализация0.ОжидаетсяПодтверждение) КАК Состояние,
	|	ЗНАЧЕНИЕ(Перечисление.СобытияПоНДСПродажи.Реализация) КАК Событие,
	|	ВЫБОР
	|		КОГДА ВременнаяТаблицаЗапасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ТоварыНесырьевые)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ПрочиеРаботыИУслуги)
	|	КОНЕЦ КАК ВидЦенности,
	|	ВременнаяТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
	|	СУММА(ВременнаяТаблицаЗапасы.СуммаНДСРег) КАК НДС,
	|	СУММА(ВременнаяТаблицаЗапасы.СуммаРег - ВременнаяТаблицаЗапасы.СуммаНДСРег) КАК СуммаБезНДС
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ВременнаяТаблицаЗапасы,
	|	ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
	|ГДЕ
	|	НЕ ЕСТЬNULL(ВременнаяТаблицаЗапасы.Номенклатура.ТоварнаяНоменклатураВЭД.СырьевойТовар, ЛОЖЬ)
	|	И ВременнаяТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС0)
	|	И (ВременнаяТаблицаЗапасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|			ИЛИ &ПлательщикНДСНаУСНБезВычетов)
	|	И (&НетВидаОперации
	|			ИЛИ ВременнаяТаблицаЗапасы.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю)
	|			ИЛИ ВременнаяТаблицаЗапасы.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходнаяНакладная.ВозвратКомитенту))
	|	И (НЕ &ЭтоЗаказНаряд
	|			ИЛИ &ЗаменитьНаУсловиеПоСостояниюЗаказНаряда)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВременнаяТаблицаЗапасы.Контрагент,
	|	ВЫБОР
	|		КОГДА ВременнаяТаблицаЗапасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ТоварыНесырьевые)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ПрочиеРаботыИУслуги)
	|	КОНЕЦ,
	|	ВременнаяТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС,
	|	ВременнаяТаблицаЗапасы.Организация,
	|	ВременнаяТаблицаЗапасы.Документ,
	|	ВременнаяТаблицаЗапасы.Период,
	|	ВременнаяТаблицаЗапасы.Период";

	// Для  налогоплательщиков НДС на УСН без вычетов дополнительно не фильтруем данные
	Запрос.УстановитьПараметр("ПлательщикНДСНаУСНБезВычетов", ПлательщикНДСНаУСНБезВычетов);
	Запрос.УстановитьПараметр("НетВидаОперации", Ложь);
	Запрос.УстановитьПараметр("ЭтоЗаказНаряд", Ложь);
	Запрос.УстановитьПараметр("ЗаменитьНаУсловиеПоСостояниюЗаказНаряда", Ложь);
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВременнаяТаблицаЗапасы КАК ВременнаяТаблицаЗапасы", "ВременнаяТаблицаРаботыИУслуги КАК ВременнаяТаблицаЗапасы");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВременнаяТаблицаЗапасы.ВидОперации", "НЕОПРЕДЕЛЕНО");
		Запрос.УстановитьПараметр("НетВидаОперации", Истина);
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВременнаяТаблицаЗапасы КАК ВременнаяТаблицаЗапасы", "ВременнаяТаблицаТовары КАК ВременнаяТаблицаЗапасы");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВременнаяТаблицаЗапасы.ВидОперации", "НЕОПРЕДЕЛЕНО");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ЗаменитьНаУсловиеПоСостояниюЗаказНаряда", "ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА");
		Запрос.УстановитьПараметр("НетВидаОперации", Истина);
		Запрос.УстановитьПараметр("ЭтоЗаказНаряд", Истина);
		
		Запрос.Текст = Запрос.Текст + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|" + 		
		"ВЫБРАТЬ
		|	ВременнаяТаблицаРаботы.Период,
		|	ВременнаяТаблицаРаботы.Период,
		|	ВременнаяТаблицаРаботы.Организация,
		|	ВременнаяТаблицаРаботы.Контрагент,
		|	ВременнаяТаблицаРаботы.Документ,
		|	ЗНАЧЕНИЕ(Перечисление.НДССостоянияРеализация0.ОжидаетсяПодтверждение),
		|	ЗНАЧЕНИЕ(Перечисление.СобытияПоНДСПродажи.Реализация),
		|	ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ПрочиеРаботыИУслуги),
		|	ВременнаяТаблицаРаботы.СтавкаНДС.ПеречислениеСтавкаНДС,
		|	СУММА(ВременнаяТаблицаРаботы.СуммаНДСРег),
		|	СУММА(ВременнаяТаблицаРаботы.СуммаРег - ВременнаяТаблицаРаботы.СуммаНДСРег)
		|ИЗ
		|	ВременнаяТаблицаРаботы КАК ВременнаяТаблицаРаботы,
		|	ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
		|ГДЕ
		|	&ЭтоЗаказНаряд
		|	И НЕ ЕСТЬNULL(ВременнаяТаблицаРаботы.Номенклатура.ТоварнаяНоменклатураВЭД.СырьевойТовар, ЛОЖЬ)
		|	И ВременнаяТаблицаРаботы.СтавкаНДС.ПеречислениеСтавкаНДС = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС0)
		|	И (ВременнаяТаблицаРаботы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
		|			ИЛИ &ПлательщикНДСНаУСНБезВычетов)
		|	И ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА
		|
		|СГРУППИРОВАТЬ ПО
		|	ВременнаяТаблицаРаботы.Контрагент,
		|	ВременнаяТаблицаРаботы.СтавкаНДС.ПеречислениеСтавкаНДС,
		|	ВременнаяТаблицаРаботы.Организация,
		|	ВременнаяТаблицаРаботы.Документ,
		|	ВременнаяТаблицаРаботы.Период,
		|	ВременнаяТаблицаРаботы.Период";
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();
	
	// Ресурс КурсоваяРазница заполнять не нужно, т.к.
	// начиная с 01.10.2011 налоговая база по НДС при подтверждении реализации со ставкой 0% 
	// должна определяться по курсу на дату реализации
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСРеализация0", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры

Процедура ПустаяТаблицаНДСРеализация0(СтруктураДополнительныеСвойства)

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСРеализация0", Новый ТаблицаЗначений);

КонецПроцедуры

#КонецОбласти

#Область НДСПокупки

// Формирует движения по регистру накопления "НДСЗаписиКнигиПокупок" для документа "Отчет комиссионера".
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.ОтчетКомиссионера - Ссылка на документ "Отчет комиссионера", для которого формируются движения.
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств для проведения.
//
Процедура СформироватьДвиженияНДСЗаписиКнигиПокупокОтчетКомиссионера(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	НаВозвратыВыставляетсяКорректировочныйСчетФактура = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "НаВозвратыВыставляетсяКорректировочныйСчетФактура");
	Если НаВозвратыВыставляетсяКорректировочныйСчетФактура = Ложь Тогда
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок", ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПокупок"));
		Возврат;
	КонецЕсли;
	
	ПлательщикНДСПрименяющийУСН =  УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ПлательщикНДС                      = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или ПлательщикНДСПрименяющийУСН;

	Если Не ПлательщикНДС Тогда
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;
	ВерсияУчетаНДС = УчетНДСКлиентСервер.Версия(СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	УчетАгентскогоНДСПокупателем = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем");

	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Шапка.Дата КАК Период,
	|	Шапка.Ссылка КАК Регистратор,
	|	&Организация КАК Организация,
	|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасы.Характеристика КАК Характеристика,
	|	ТаблицаЗапасы.Партия КАК Партия,
	|	ВЫБОР
	|		КОГДА НЕ ТаблицаЗапасы.СчетФактура = ЗНАЧЕНИЕ(Документ.СчетФактура.ПустаяСсылка)
	|			ТОГДА ТаблицаЗапасы.СчетФактура
	|		ИНАЧЕ Шапка.Ссылка
	|	КОНЕЦ КАК СчетФактура,
	|	ВЫБОР
	|		КОГДА НЕ ТаблицаЗапасы.СчетФактура = ЗНАЧЕНИЕ(Документ.СчетФактура.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(СчетФактураКорректировочный.Контрагент, &Контрагент)
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Поставщик,
	|	ЕСТЬNULL(ТаблицаЗапасы.КорректируемыйДокумент, Шапка.КорректируемыйДокумент) КАК КорректируемыйДокумент,
	|	ТаблицаЗапасы.СуммаНДСПродажи КАК СуммаНДСВалютаДокумента,
	|	ВЫБОР
	|		КОГДА Шапка.СуммаВключаетНДС
	|			ТОГДА ТаблицаЗапасы.СуммаРуб - ТаблицаЗапасы.СуммаНДСПродажи
	|		ИНАЧЕ ТаблицаЗапасы.СуммаРуб
	|	КОНЕЦ КАК СуммаБезНДС,
	|	ТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС
	|ИЗ
	|	ВременнаяТаблицаШапка КАК Шапка,
	|	ВременнаяТаблицаЗапасыВозвраты КАК ТаблицаЗапасы
	|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактура КАК СчетФактураКорректировочный
	|		ПО ТаблицаЗапасы.СчетФактура = СчетФактураКорректировочный.Ссылка";

	ТоварыУслуги  = Запрос.Выполнить().Выгрузить();

	Если ТоварыУслуги.Количество() = 0 Тогда
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок",
			Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;

	ТаблицаЗаписиКнигиПокупок = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПокупок");

	Для Каждого СтрокаТаблицы Из ТоварыУслуги Цикл

		Если ВерсияУчетаНДС > 1 И СтрокаТаблицы.СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = ТаблицаЗаписиКнигиПокупок.Добавить();

		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);

		НоваяСтрока.Поставщик  = СтрокаТаблицы.Поставщик;
		НоваяСтрока.СуммаБезНДС = -СтрокаТаблицы.СуммаБезНДС;
		НоваяСтрока.НДС         = -СтрокаТаблицы.СуммаНДСВалютаДокумента;
		НоваяСтрока.СтавкаНДС   = СтрокаТаблицы.СтавкаНДС;
		НоваяСтрока.ВидЦенности   = Перечисления.ВидыЦенностей.Возврат;
	КонецЦикла;

	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "ДатаСобытия");

	Если УчетАгентскогоНДСПокупателем = Истина И УчетНДС.ВедетсяУчетНДСПоФЗ335(
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Тогда
		ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(Перечисления.СобытияПоНДСПродажи.НалогИсчисляетПокупатель,
			"Событие");
	Иначе
		ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету, "Событие");
	КонецЕсли;
	
	// Для операций поступления/реализации договор не заполняется
	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(Справочники.ДоговорыКонтрагентов.ПустаяСсылка(), "ДоговорКонтрагента");

	ТаблицаЗаписиКнигиПокупок.Свернуть("Период,Организация,Поставщик,СчетФактура,ВидЦенности,СтавкаНДС,
									   |ДатаОплаты,ДокументОплаты,Событие,ДатаСобытия,ДоговорКонтрагента",
		"СуммаБезНДС,НДС");

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок",
		ТаблицаЗаписиКнигиПокупок);

КонецПроцедуры

Процедура СформироватьДвиженияНДСЗаписиКнигиПокупокОтчетОРозничныхПродажах(ДокументСсылка,
	СтруктураДополнительныеСвойства) Экспорт

	ПлательщикНДСПрименяющийУСН = УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или ПлательщикНДСПрименяющийУСН;

	Если Не ПлательщикНДС Тогда
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;
	ВерсияУчетаНДС = УчетНДСКлиентСервер.Версия(СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	УчетАгентскогоНДСПокупателем = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем");

	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Шапка.Дата КАК Период,
	|	Шапка.Ссылка КАК Регистратор,
	|	&Организация КАК Организация,
	|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасы.Характеристика КАК Характеристика,
	|	ТаблицаЗапасы.Партия КАК Партия,
	|	&Контрагент КАК Поставщик,
	|	ЕСТЬNULL(ТаблицаЗапасы.КорректируемыйДокумент, Шапка.КорректируемыйДокумент) КАК КорректируемыйДокумент,
	|	ТаблицаЗапасы.СуммаНДСЗакупкиПродажи КАК СуммаНДСВалютаДокумента,
	|	ВЫБОР
	|		КОГДА Шапка.СуммаВключаетНДС
	|			ТОГДА ТаблицаЗапасы.СуммаРуб - ТаблицаЗапасы.СуммаНДСЗакупкиПродажи
	|		ИНАЧЕ ТаблицаЗапасы.СуммаРуб
	|	КОНЕЦ КАК СуммаБезНДС,
	|	ТаблицаЗапасы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС
	|ИЗ
	|	ВременнаяТаблицаШапка КАК Шапка,
	|	ВременнаяТаблицаЗапасы КАК ТаблицаЗапасы
	|ГДЕ
	|	ТаблицаЗапасы.Сумма < 0";

	ТоварыУслуги  = Запрос.Выполнить().Выгрузить();

	Если ТоварыУслуги.Количество() = 0 Тогда
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок",
			Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;

	ТаблицаЗаписиКнигиПокупок = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПокупок");

	Для Каждого СтрокаТаблицы Из ТоварыУслуги Цикл

		Если ВерсияУчетаНДС > 1 И СтрокаТаблицы.СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = ТаблицаЗаписиКнигиПокупок.Добавить();

		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);

		НоваяСтрока.Поставщик  = СтрокаТаблицы.Поставщик;
		НоваяСтрока.СуммаБезНДС = -СтрокаТаблицы.СуммаБезНДС;
		НоваяСтрока.НДС         = -СтрокаТаблицы.СуммаНДСВалютаДокумента;
		НоваяСтрока.СтавкаНДС   = СтрокаТаблицы.СтавкаНДС;
		НоваяСтрока.ВидЦенности   = Перечисления.ВидыЦенностей.Возврат;
		НоваяСтрока.СчетФактура = ?(ЗначениеЗаполнено(СтрокаТаблицы.КорректируемыйДокумент),
			СтрокаТаблицы.КорректируемыйДокумент, ДокументСсылка);
	КонецЦикла;

	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, "Организация");
	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период");
	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "ДатаСобытия");

	Если УчетАгентскогоНДСПокупателем = Истина И УчетНДС.ВедетсяУчетНДСПоФЗ335(
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Тогда
		ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(Перечисления.СобытияПоНДСПродажи.НалогИсчисляетПокупатель,
			"Событие");
	Иначе
		ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету, "Событие");
	КонецЕсли;
	
	// Для операций поступления/реализации договор не заполняется
	ТаблицаЗаписиКнигиПокупок.ЗаполнитьЗначения(Справочники.ДоговорыКонтрагентов.ПустаяСсылка(), "ДоговорКонтрагента");

	ТаблицаЗаписиКнигиПокупок.Свернуть("Период,Организация,Поставщик,СчетФактура,ВидЦенности,СтавкаНДС,
									   |ДатаОплаты,ДокументОплаты,Событие,ДатаСобытия,ДоговорКонтрагента",
		"СуммаБезНДС,НДС");

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок",
		ТаблицаЗаписиКнигиПокупок);

КонецПроцедуры
// ПОЛУЧЕНИЕ СЧЕТА-ФАКТУРЫ

// Процедура формирует движения по вычету НДС по выданным авансам, вызывается Из документа СчетФактураПолученный
//
Процедура СформироватьДвиженияПолученСчетФактураНаВыданныйАванс(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	Если СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		<> Перечисления.ВидыОперацийСчетФактураПолученный.Аванс Тогда
		Возврат;
	КонецЕсли;

	ПлательщикНДСНаУСНСВычетами =  УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ПлательщикНДС                      = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или ПлательщикНДСНаУСНСВычетами;

	Если Не ПлательщикНДС Тогда
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;
	ВерсияУчетаНДС = УчетНДСКлиентСервер.Версия(СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	НДСПредъявленКВычету = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "НДСПредъявленКВычету");

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;

	РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
        Договор, "ВидДоговора,УчетАгентскогоНДС,ВидАгентскогоДоговора");

	НДСИсчисляетсяНалоговымАгентом = СтруктураДополнительныеСвойства.ДляПроведения.Дата >= '20180101'
		И РеквизитыДоговора.УчетАгентскогоНДС = Истина И РеквизитыДоговора.ВидАгентскогоДоговора
		= Перечисления.ВидыАгентскихДоговоров.РеализацияТоваров;

	Если ВерсияУчетаНДС = 1 Или Не НДСПредъявленКВычету Или ДокументСсылка.ДокументыОснования.Количество() = 0 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;

	Запрос.УстановитьПараметр("НДСИсчисляетсяНалоговымАгентом", НДСИсчисляетсяНалоговымАгентом);
	ИсходныйСчетФактура = ПолучитьИсходныйСчетФактуру(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"ИсправляемыйСчетФактура"));
	Запрос.УстановитьПараметр("ИсходныйСчетФактура", ИсходныйСчетФактура);

	ДатаИсходногоСчетаФактуры = Дата(1, 1, 1);
	Если ЗначениеЗаполнено(ИсходныйСчетФактура) Тогда
		ДатаИсходногоСчетаФактуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсходныйСчетФактура, "Дата");
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаИсходногоСчетаФактуры", ДатаИсходногоСчетаФактуры);
	ПравилаПостановления981 = УчетНДСПереопределяемый.ВерсияПостановленияНДС1137(ДатаИсходногоСчетаФактуры) >= 4;
	Запрос.УстановитьПараметр("РегистрироватьИсправлениеВДопЛисте", ПравилаПостановления981);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);

	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаНДСПоАвансамВыданным(НомераТаблиц, СтруктураДополнительныеСвойства);

	Если Не ПустаяСтрока(Запрос.Текст) Тогда
		Результат = Запрос.ВыполнитьПакет();
		Для Каждого НомерТаблицы Из НомераТаблиц Цикл
			СтруктураДополнительныеСвойства.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
		КонецЦикла;
	КонецЕсли;
	ПодготовитьПараметрыПолученСчетФактураНаВыданныйАванс(
        СтруктураДополнительныеСвойства, СтруктураДополнительныеСвойства.ТаблицаАвансов);

	Если НДСПредъявленКВычету Тогда

		СформироватьДвиженияНДСЗаписиКнигиПокупокВыданныйАванс(ДокументСсылка, СтруктураДополнительныеСвойства);

	КонецЕсли;

КонецПроцедуры

Процедура СформироватьДвиженияНДСЗаписиКнигиПокупокВыданныйАванс(ДокументСсылка, СтруктураДополнительныеСвойства)

	ТаблицаАвансов = СтруктураДополнительныеСвойства.Авансы;
	Если ТаблицаАвансов.Количество() = 0 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Для Каждого СтрокаТаблицы Из ТаблицаАвансов Цикл

		НоваяЗапись = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаНДСЗаписиКнигиПокупок.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяЗапись, СтруктураДополнительныеСвойства.ДляПроведения);
		ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТаблицы);
		НоваяЗапись.Период = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
		НоваяЗапись.ДатаСобытия = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
		НоваяЗапись.Организация = СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности;
		НоваяЗапись.ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();

		Если СтрокаТаблицы.НДСИсчисляетсяНалоговымАгентом Тогда
			НоваяЗапись.ВидЦенности = Перечисления.ВидыЦенностей.АвансыВыданныеНалоговыйАгент;
		Иначе
			НоваяЗапись.ВидЦенности = Перечисления.ВидыЦенностей.АвансыВыданные;
		КонецЕсли;

		НоваяЗапись.Поставщик = СтрокаТаблицы.Контрагент;
		НоваяЗапись.Событие   = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету;
	КонецЦикла;

КонецПроцедуры

// Подготовка таблицы для процедуры СформироватьДвиженияПолученСчетФактураНаВыданныйАванс()
//
Функция ПодготовитьПараметрыПолученСчетФактураНаВыданныйАванс(СтруктураДополнительныеСвойства, ТаблицаАвансов)

    Параметры = Новый Структура;

    // Список сумм авансов в разбивке по ставкам НДС:
    ОбязательныеКолонки = ""
    + "СчетФактура,"                    // <ДокументСсылка...>  - документ, являющийся основанием для счета-фактуры
    + "Контрагент,"                     // <СправочникСсылка.Контрагенты> контрагент для взаиморасчетов
    + "ДоговорКонтрагента,"             // <СправочникСсылка.ДоговорыКонтрагентов> - договор взаиморасчетов;
    + "НДСИсчисляетсяНалоговымАгентом," // <Булево> - признак исполнения обязанностей налогового агента при приобретении товаров,
    + "НДС,"                            // <Число> - сумма НДС;
    + "СуммаБезНДС,"                    // <Число> - сумма без НДС по определенной ставке НДС;
    + "СтавкаНДС,"                      // <перечислениеСсылка.СтавкаНДС> - ставка НДС;
    + "Содержание,"
    + "КодВидаОперации,"
    + "ЗаписьДополнительногоЛиста,"
    + "СторнирующаяЗаписьДопЛиста,"
    + "КорректируемыйПериод,"
    + "ДатаСобытия,"
    + "ИсправленныйСчетФактура,"
    + "ДатаДокументаОплаты,"
    + "НомерДокументаОплаты";
    
    СтруктураДополнительныеСвойства.Вставить("Авансы", ПрослеживаемостьПереопределяемый.ПолучитьТаблицуПараметровПроведения(
        ТаблицаАвансов, ОбязательныеКолонки));
    
    Возврат Параметры;

КонецФункции

Функция ТекстЗапросаНДСПоАвансамВыданным(НомераТаблиц, СтруктураДополнительныеСвойства)
	Если СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации <> Перечисления.ВидыОперацийСчетФактураПолученный.Аванс 
	И СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		<> Перечисления.ВидыОперацийСчетФактураПолученный.КорректировкаАванса Тогда
		СтруктураДополнительныеСвойства.Вставить("ТаблицаАвансов", Неопределено);
		Возврат "";
	КонецЕсли;

	НомераТаблиц.Вставить("ТаблицаАвансов", НомераТаблиц.Количество());

	ТекстЗапроса =
	"ВЫБРАТЬ
	|    Реквизиты.Контрагент КАК Контрагент,
	|    Реквизиты.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|    &НДСИсчисляетсяНалоговымАгентом КАК НДСИсчисляетсяНалоговымАгентом,
	|    ""Вычет НДС с выданного аванса"" КАК Содержание,
	|    Реквизиты.ДокументОснование КАК СчетФактура,
	|    ТаблицаАвансы.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
	|    ВЫБОР
	|        КОГДА (Реквизиты.ИсправлениеСобственнойОшибки
	|        ИЛИ &РегистрироватьИсправлениеВДопЛисте)
	|        И КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(&ДатаИсходногоСчетаФактуры, КВАРТАЛ)
	|            ТОГДА ИСТИНА
	|        ИНАЧЕ ЛОЖЬ
	|    КОНЕЦ КАК ЗаписьДополнительногоЛиста,
	|    ЛОЖЬ КАК СторнирующаяЗаписьДопЛиста,
	|    ВЫБОР
	|        КОГДА (Реквизиты.ИсправлениеСобственнойОшибки
	|        ИЛИ &РегистрироватьИсправлениеВДопЛисте)
	|        И КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(&ДатаИсходногоСчетаФактуры, КВАРТАЛ)
	|            ТОГДА НАЧАЛОПЕРИОДА(&ДатаИсходногоСчетаФактуры, КВАРТАЛ)
	|        ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|    КОНЕЦ КАК КорректируемыйПериод,
	|    Реквизиты.Дата КАК ДатаСобытия,
	|    ВЫБОР
	|        КОГДА Реквизиты.Исправление
	|        ИЛИ Реквизиты.ИсправлениеСобственнойОшибки
	|            ТОГДА Реквизиты.Ссылка
	|        ИНАЧЕ НЕОПРЕДЕЛЕНО
	|    КОНЕЦ КАК ИсправленныйСчетФактура,
	|    СУММА(ТаблицаАвансы.СуммаНДС) КАК НДС,
	|    СУММА(ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС) КАК СуммаБезНДС,
	|    ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаДокументаОплаты,
	|    ЕСТЬNULL(ДанныеПервичныхДокументов.Номер, НЕОПРЕДЕЛЕНО) КАК НомерДокументаОплаты,
	|    ВЫБОР
	|        КОГДА Реквизиты.Дата < ДАТАВРЕМЯ(2015, 1, 1)
	|            ТОГДА """"
	|        ИНАЧЕ Реквизиты.КодВидаОперации
	|    КОНЕЦ КАК КодВидаОперации
	|ИЗ
	|    Документ.СчетФактураПолученный.Авансы КАК ТаблицаАвансы
	|        ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
	|        ПО ИСТИНА
	|        ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
	|        ПО ДанныеПервичныхДокументов.Документ = Реквизиты.ДокументОснование
	|ГДЕ
	|    ТаблицаАвансы.Ссылка = &Ссылка
	|СГРУППИРОВАТЬ ПО
	|    Реквизиты.Контрагент,
	|    Реквизиты.ДоговорКонтрагента,
	|    &НДСИсчисляетсяНалоговымАгентом,
	|    Реквизиты.ДокументОснование,
	|    ТаблицаАвансы.СтавкаНДС,
	|    Реквизиты.Дата,
	|    ДанныеПервичныхДокументов.Дата,
	|    ДанныеПервичныхДокументов.Номер,
	|    ВЫБОР
	|        КОГДА (Реквизиты.ИсправлениеСобственнойОшибки
	|        ИЛИ &РегистрироватьИсправлениеВДопЛисте)
	|        И КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(&ДатаИсходногоСчетаФактуры, КВАРТАЛ)
	|            ТОГДА ИСТИНА
	|        ИНАЧЕ ЛОЖЬ
	|    КОНЕЦ,
	|    ВЫБОР
	|        КОГДА (Реквизиты.ИсправлениеСобственнойОшибки
	|        ИЛИ &РегистрироватьИсправлениеВДопЛисте)
	|        И КОНЕЦПЕРИОДА(Реквизиты.Дата, КВАРТАЛ) > КОНЕЦПЕРИОДА(&ДатаИсходногоСчетаФактуры, КВАРТАЛ)
	|            ТОГДА НАЧАЛОПЕРИОДА(&ДатаИсходногоСчетаФактуры, КВАРТАЛ)
	|        ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|    КОНЕЦ,
	|    ВЫБОР
	|        КОГДА Реквизиты.Исправление
	|        ИЛИ Реквизиты.ИсправлениеСобственнойОшибки
	|            ТОГДА Реквизиты.Ссылка
	|        ИНАЧЕ НЕОПРЕДЕЛЕНО
	|    КОНЕЦ,
	|    ВЫБОР
	|        КОГДА Реквизиты.Дата < ДАТАВРЕМЯ(2015, 1, 1)
	|            ТОГДА """"
	|        ИНАЧЕ Реквизиты.КодВидаОперации
	|    КОНЕЦ,
	|    ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, ДАТАВРЕМЯ(1, 1, 1)),
	|    ЕСТЬNULL(ДанныеПервичныхДокументов.Номер, НЕОПРЕДЕЛЕНО),
	|    ТаблицаАвансы.СтавкаНДС.ПеречислениеСтавкаНДС";

	Возврат ТекстЗапроса + ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();

КонецФункции
//
// Процедура формирует движения по вычету НДС и по обратному начислению НДС по поступлению,
// вызывается из документа СчетФактураПолученный.
//
Процедура СформироватьДвиженияПолученСчетФактураНаПоступление(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	ПлательщикНДСНаУСНСВычетами =  УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ПлательщикНДС                      = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или ПлательщикНДСНаУСНСВычетами;

	Если Не ПлательщикНДС Тогда
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;
	ВерсияУчетаНДС = УчетНДСКлиентСервер.Версия(СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	НДСПредъявленКВычету = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "НДСПредъявленКВычету");

	Если ВерсияУчетаНДС = 1 Или Не НДСПредъявленКВычету Или ДокументСсылка.ДокументыОснования.Количество() = 0 Тогда
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;

	НДСПредъявленный = ПодготовитьТаблицуПредъявленногоНДС(ДокументСсылка, СтруктураДополнительныеСвойства);
	ТаблицаНДСПредъявленный = ПустаяТаблицаРегистраНакопления("НДСПредъявленный");
	ТаблицаНДСПредъявленный.Колонки.Добавить("ВидДвижения");

	СформироватьДвиженияНДСПредъявленныйВычетНДС(НДСПредъявленный, ТаблицаНДСПредъявленный, , );
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСПредъявленный", ТаблицаНДСПредъявленный);

	Если 
// TODO
//    Реквизиты.ЗаявлениеОВвозеТоваровОтКомиссионера
//         
	Ложь И НДСПредъявленКВычету И СтруктураДополнительныеСвойства.ДляПроведения.Дата >= '20240101' Тогда

		ТаможенныйСоюз = Перечисления.ВидыЦенностей.ТаможенныйСоюз;

		Для Каждого СтрокаНДСПредъявленный Из НДСПредъявленный Цикл
			СтрокаНДСПредъявленный.ВидЦенности = ТаможенныйСоюз;
		КонецЦикла;

	КонецЕсли;

	ТаблицаЗаписиКнигиПокупок = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПокупок");
	СформироватьДвиженияНДСЗаписиКнигиПокупокПоступлениеТоваровУслуг(НДСПредъявленный, ТаблицаЗаписиКнигиПокупок);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок",
		ТаблицаЗаписиКнигиПокупок);

КонецПроцедуры

Процедура СформироватьДвиженияНДСПредъявленныйВычетНДС(ТаблицаДвижений, Движения, Списание = Ложь,
	РассчитыватьСуммы = Истина)

	Если ТаблицаДвижений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	Для Каждого СтрокаТаблицы Из ТаблицаДвижений Цикл

		Запись = Движения.Добавить();

		Если Списание Тогда
			Запись.ВидДвижения = ВидДвиженияНакопления.Приход;
		Иначе
			Запись.ВидДвижения = ВидДвиженияНакопления.Расход;
		КонецЕсли;

		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);

		Если РассчитыватьСуммы Тогда
			Запись.СуммаБезНДС = ?(Списание, -СтрокаТаблицы.СуммаБезНДС, СтрокаТаблицы.СуммаБезНДС);
			Запись.НДС         = ?(Списание, -СтрокаТаблицы.НДС, СтрокаТаблицы.НДС);
		Иначе
			Запись.СуммаБезНДС = СтрокаТаблицы.СуммаБезНДС;
			Запись.НДС         = СтрокаТаблицы.НДС;
		КонецЕсли;

		Если Не ЗначениеЗаполнено(Запись.Событие) Тогда
			Запись.Событие = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСПоставщиком;
		КонецЕсли;

		Если Перечисления.ВидыЦенностей.ЭтоНалоговыйАгент(СтрокаТаблицы.ВидЦенности) Тогда
			Запись.ДатаОплаты = '00010101';
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

Процедура СформироватьДвиженияНДСЗаписиКнигиПокупокПоступлениеТоваровУслуг(ДанныеДвижений, Движения)

	Если ДанныеДвижений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	Для Каждого СтрокаТаблицы Из ДанныеДвижений Цикл

		Запись = Движения.Добавить();

		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);
		Запись.Событие = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету;

	КонецЦикла;

КонецПроцедуры

Функция ПодготовитьТаблицуПредъявленногоНДС(ДокументСсылка, СтруктураДополнительныеСвойств) Экспорт

	ПустаяТаблица = Новый ТаблицаЗначений;
	ПустаяТаблица.Колонки.Добавить("Период");
	ПустаяТаблица.Колонки.Добавить("ДатаСобытия");
	ПустаяТаблица.Колонки.Добавить("Регистратор");
	ПустаяТаблица.Колонки.Добавить("Организация");
	ПустаяТаблица.Колонки.Добавить("СчетФактура");
	ПустаяТаблица.Колонки.Добавить("ВидЦенности");
	ПустаяТаблица.Колонки.Добавить("КодВидаОперации");
	ПустаяТаблица.Колонки.Добавить("СтавкаНДС");
	ПустаяТаблица.Колонки.Добавить("СчетУчетаНДС");
	ПустаяТаблица.Колонки.Добавить("Поставщик");
	ПустаяТаблица.Колонки.Добавить("ДатаОплаты");
	ПустаяТаблица.Колонки.Добавить("ДоговорКонтрагента");
	ПустаяТаблица.Колонки.Добавить("ИсправленныйСчетФактура");
	ПустаяТаблица.Колонки.Добавить("СуммаБезНДС");
	ПустаяТаблица.Колонки.Добавить("НДС");
	ПустаяТаблица.Колонки.Добавить("Содержание");
	ПустаяТаблица.Колонки.Добавить("НомерДокументаОплаты");
	ПустаяТаблица.Колонки.Добавить("ДатаДокументаОплаты");

//	Реквизиты = ТаблицаРеквизиты[0];

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойств.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	УчетАгентскогоНДСПокупателем = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем");

	Если Не ДокументСсылка.НДСПредъявленКВычету И Не УчетАгентскогоНДСПокупателем Тогда
		Возврат ПустаяТаблица;
	КонецЕсли;

	Регистратор = ДокументСсылка.ДокументыОснования[0].ДокументОснование;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойств.ДляПроведения.ОрганизацияДляРегОтчетности);
	Запрос.УстановитьПараметр("Период", СтруктураДополнительныеСвойств.ДляПроведения.Дата);
	Запрос.УстановитьПараметр("НомерДокументаОплаты", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"НомерПлатежноРасчетногоДокумента"));
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("КодВидаОперации", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"КодВидаОперации"));
	Запрос.УстановитьПараметр("МоментДокумента", СтруктураДополнительныеСвойств.ДляПроведения.МоментВремени);

	Запрос.УстановитьПараметр("ДатаДокументаОплаты", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"ДатаПлатежноРасчетногоДокумента"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|    &Период КАК Период,
	|    &Период КАК ДатаСобытия,
	|    ""НДС"" КАК Содержание,
	|    Сводный.Организация КАК Организация,
	|    Сводный.СчетФактура КАК СчетФактура,
	|    Сводный.ВидЦенности КАК ВидЦенности,
	|    Сводный.СтавкаНДС КАК СтавкаНДС,
	|    Сводный.СчетУчетаНДС КАК СчетУчетаНДС,
	|    Сводный.Поставщик КАК Поставщик,
	|    Сводный.ДатаОплаты КАК ДатаОплаты,
	|    Сводный.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|    Сводный.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
	|    СУММА(Сводный.СуммаБезНДС * Сводный.ЗнакДвижения) КАК СуммаБезНДС,
	|    СУММА(Сводный.НДС * Сводный.ЗнакДвижения) КАК НДС,
	|    Сводный.КодВидаОперации КАК КодВидаОперации,
	|    &НомерДокументаОплаты КАК НомерДокументаОплаты,
	|    &ДатаДокументаОплаты КАК ДатаДокументаОплаты
	|ИЗ
	|    (ВЫБРАТЬ
	|        НДСПредъявленный.Организация КАК Организация,
	|        НДСПредъявленный.СчетФактура КАК СчетФактура,
	|        НДСПредъявленный.ВидЦенности КАК ВидЦенности,
	|        НДСПредъявленный.СтавкаНДС КАК СтавкаНДС,
	|        НДСПредъявленный.СчетУчетаНДС КАК СчетУчетаНДС,
	|        НДСПредъявленный.Поставщик КАК Поставщик,
	|        НДСПредъявленный.ДатаОплаты КАК ДатаОплаты,
	|        НДСПредъявленный.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|        НДСПредъявленный.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
	|        ВЫБОР
	|            КОГДА НДСПредъявленный.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|                ТОГДА 1
	|            ИНАЧЕ -1
	|        КОНЕЦ КАК ЗнакДвижения,
	|        НДСПредъявленный.СуммаБезНДС КАК СуммаБезНДС,
	|        НДСПредъявленный.НДС КАК НДС,
	|        ВЫБОР
	|            КОГДА &Период < ДАТАВРЕМЯ(2015, 1, 1)
	|                ТОГДА """"
	|            КОГДА НДСПредъявленный.СчетФактура ССЫЛКА Документ.СчетФактураПолученный
	|            И СчетФактураПолученный.БланкСтрогойОтчетности
	|                ТОГДА ""23""
	|            ИНАЧЕ &КодВидаОперации
	|        КОНЕЦ КАК КодВидаОперации
	|    ИЗ
	|        Документ.СчетФактураПолученный.ДокументыОснования КАК СчетФактураПолученныйДокументыОснования
	|            ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный КАК СчетФактураПолученный
	|            ПО СчетФактураПолученныйДокументыОснования.Ссылка = СчетФактураПолученный.Ссылка
	|            ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.НДСПредъявленный КАК НДСПредъявленный
	|            ПО СчетФактураПолученныйДокументыОснования.ДокументОснование = НДСПредъявленный.Регистратор
	|    ГДЕ
	|        СчетФактураПолученныйДокументыОснования.Ссылка = &Ссылка
	|        И ((СчетФактураПолученныйДокументыОснования.ДокументОснование ССЫЛКА Документ.АвансовыйОтчет
	|        ИЛИ СчетФактураПолученныйДокументыОснования.ДокументОснование ССЫЛКА Документ.ОтчетКомиссионера
	|        И СчетФактураПолученный.ВозвратЧерезКомиссионера)
	|        И СчетФактураПолученныйДокументыОснования.Ссылка = НДСПредъявленный.СчетФактура
	|        ИЛИ НЕ СчетФактураПолученныйДокументыОснования.ДокументОснование ССЫЛКА Документ.АвансовыйОтчет
	|        И (НЕ СчетФактураПолученныйДокументыОснования.ДокументОснование ССЫЛКА Документ.ОтчетКомиссионера
	|        ИЛИ НЕ СчетФактураПолученный.ВозвратЧерезКомиссионера)
	|        И СчетФактураПолученныйДокументыОснования.ДокументОснование = НДСПредъявленный.СчетФактура)
	|        И НДСПредъявленный.ВидЦенности <> ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ТоварыНалоговыйАгент)
	|        И НДСПредъявленный.Организация = &Организация
	|
	|    ОБЪЕДИНИТЬ ВСЕ
	|
	|    ВЫБРАТЬ
	|        НДСПредъявленный.Организация,
	|        НДСПредъявленный.СчетФактура,
	|        НДСПредъявленный.ВидЦенности,
	|        НДСПредъявленный.СтавкаНДС,
	|        НДСПредъявленный.СчетУчетаНДС,
	|        НДСПредъявленный.Поставщик,
	|        НДСПредъявленный.ДатаОплаты,
	|        НДСПредъявленный.ДоговорКонтрагента,
	|        НДСПредъявленный.ИсправленныйСчетФактура,
	|        1,
	|        НДСПредъявленный.СуммаБезНДС,
	|        НДСПредъявленный.НДС,
	|        &КодВидаОперации
	|    ИЗ
	|        Документ.СчетФактураПолученный.ДокументыОснования КАК СчетФактураПолученныйДокументыОснования
	|            ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный КАК СчетФактураПолученный
	|            ПО СчетФактураПолученныйДокументыОснования.Ссылка = СчетФактураПолученный.Ссылка
	|            ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.НДСПредъявленный КАК НДСПредъявленный
	|            ПО СчетФактураПолученныйДокументыОснования.ДокументОснование = НДСПредъявленный.Регистратор
	|    ГДЕ
	|        СчетФактураПолученныйДокументыОснования.Ссылка = &Ссылка
	|        И НДСПредъявленный.ВидЦенности = ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ТоварыНалоговыйАгент)
	|        И НДСПредъявленный.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|        И НДСПредъявленный.Организация = &Организация) КАК Сводный
	|СГРУППИРОВАТЬ ПО
	|    Сводный.Организация,
	|    Сводный.СчетФактура,
	|    Сводный.ВидЦенности,
	|    Сводный.КодВидаОперации,
	|    Сводный.СтавкаНДС,
	|    Сводный.СчетУчетаНДС,
	|    Сводный.Поставщик,
	|    Сводный.ДатаОплаты,
	|    Сводный.ДоговорКонтрагента,
	|    Сводный.ИсправленныйСчетФактура
	|ИМЕЮЩИЕ
	|    СУММА(Сводный.СуммаБезНДС * Сводный.ЗнакДвижения) <> 0
	|    ИЛИ СУММА(Сводный.НДС * Сводный.ЗнакДвижения) <> 0";

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат ПустаяТаблица;
	Иначе

		ТаблицаПредъявленногоНДС = Результат.Выгрузить();
		ТаблицаПредъявленногоНДС.Колонки.Добавить("СчетУчетаЦенности");
		ТаблицаПредъявленногоНДС.ЗаполнитьЗначения(Неопределено, "СчетУчетаЦенности");

		ОтфильтрованнаяТаблицаПредъявленногоНДС = ТаблицаПредъявленногоНДС.СкопироватьКолонки();

		Для Каждого СтрокаДок Из ТаблицаПредъявленногоНДС Цикл

			Если Не ТипЗнч(Регистратор) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда

				Если СтрокаДок.ВидЦенности = Перечисления.ВидыЦенностей.НМА Или СтрокаДок.ВидЦенности
					= Перечисления.ВидыЦенностей.Оборудование Или СтрокаДок.ВидЦенности = Перечисления.ВидыЦенностей.ОбъектыНезавершенногоСтроительства
					Или СтрокаДок.ВидЦенности = Перечисления.ВидыЦенностей.ОС Или СтрокаДок.ВидЦенности
					= Перечисления.ВидыЦенностей.СМРПодрядные Или СтрокаДок.ВидЦенности
					= Перечисления.ВидыЦенностей.СМРСобственнымиСилами Тогда 
                    
                    // Не отражаем вычет для ОС и объектов строительства (в т.ч. СМР),
                    // и ценностей, использованных при строительстве
					Продолжить;

				КонецЕсли;

			КонецЕсли;

			НоваяСтрока = ОтфильтрованнаяТаблицаПредъявленногоНДС.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДок);

			Если ТипЗнч(Регистратор) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
				НоваяСтрока.СтавкаНДС = ДокументСсылка.Авансы[0];
			КонецЕсли;

		КонецЦикла;

		Возврат ОтфильтрованнаяТаблицаПредъявленногоНДС;

	КонецЕсли;

КонецФункции

Процедура СформироватьДвиженияНДСЗаписиКнигиПокупок(ДанныеДвижений, Движения)

	Если Не Движения.ТаблицыДляДвижений.Свойство("ТаблицаНДСЗаписиКнигиПокупок") Тогда
		ТаблицаЗаписиКнигиПокупок = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПокупок");
		Движения.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок", ТаблицаЗаписиКнигиПокупок);
	КонецЕсли;
	Для Каждого СтрокаТаблицы Из ДанныеДвижений Цикл

		Запись =  Движения.ТаблицыДляДвижений.ТаблицаНДСЗаписиКнигиПокупок.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);

	КонецЦикла;

КонецПроцедуры

// Процедура инициализирует пустую таблицу значений для проведения документа по регистру НДС записи книги покупок.
//
// Параметры:
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств, в которую будет добавлена пустая таблица значений.
//
Процедура ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства)
    
    Если СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаНДСЗаписиКнигиПокупок") Тогда
        Возврат;
    КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок", Новый ТаблицаЗначений);

КонецПроцедуры
#Область КорректировкаПоступления

Процедура СформироватьДвиженияНДСКорректировкиПоступлениеТоваровУслуг(ДокументСсылка, СтруктураДополнительныеСвойства,
	ДокументПоступление) Экспорт

	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(
		СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Если Не ПлательщикНДС Тогда
		ПустаяТаблицаНДСЗаписиКнигиПродаж(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСЗаписиКнигиПокупок(СтруктураДополнительныеСвойства);
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;
	СтруктураДополнительныеСвойства.Вставить("ПлательщикНДС", ПлательщикНДС);
	СтруктураДополнительныеСвойства.Вставить("ЕстьТовары", ДокументСсылка.Запасы.Количество() > 0);
	СтруктураДополнительныеСвойства.Вставить("ЕстьУслуги", ДокументСсылка.Расходы.Количество() > 0);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Запрос.УстановитьПараметр("Период", СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Договор",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Договор");
	Иначе
		Договор = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	УчетАгентскогоНДСПокупателем = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "УчетАгентскогоНДСПокупателем");

	ЭтоКомиссия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВидДоговора")
		= Перечисления.ВидыДоговоров.СКомиссионером;

	ВосстановитьНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка,
		"ВосстановитьНДС");

    ИсправляемыйДокумент = УчетНДСПереопределяемый.ПолучитьИсправляемыйДокументПоступления(
        ДокументПоступление);
    ДатаИсправляемогоДокумента = ?(ЗначениеЗаполнено(ИсправляемыйДокумент), 
        ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсправляемыйДокумент, "Дата"), СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Если СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		<> Перечисления.ВидыОперацийИсправленияПоступленияРеализации.СогласованноеИзменение Тогда
		СчетФактура = УчетНДСПереопределяемый.ПолучитьИсправляемыйДокументПоступления(ДокументПоступление);
	ИначеЕсли ВосстановитьНДС Тогда
		СчетФактура = ДокументСсылка;
	Иначе
		СчетФактура = УчетНДСПереопределяемый.ПолучитьИсправляемыйДокументПоступления(ДокументПоступление);
	КонецЕсли;
	Запрос.УстановитьПараметр("СчетФактура", СчетФактура);

	Если СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		= Перечисления.ВидыОперацийИсправленияПоступленияРеализации.СогласованноеИзменение Тогда
		СчетФактураПриУвеличенииСтоимости = ДокументСсылка;
	Иначе
		СчетФактураПриУвеличенииСтоимости = СчетФактура;
	КонецЕсли;

	СчетФактураДата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетФактура, "Дата");

	ИсходныйСчетФактураДата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументПоступление, "Дата");

	Если УчетАгентскогоНДСПокупателем = Истина Тогда
		СобытиеРеализация   = Перечисления.СобытияПоНДСПродажи.НалогИсчисляетПокупатель;
		СобытиеПриобретение = Перечисления.СобытияПоНДСПокупки.НалогИсчисляетПокупатель;
	Иначе
		СобытиеРеализация   = Перечисления.СобытияПоНДСПродажи.Реализация;
		СобытиеПриобретение = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СобытиеРеализация", СобытиеРеализация);
	Запрос.УстановитьПараметр("СобытиеПриобретение", СобытиеПриобретение);
	Запрос.УстановитьПараметр("ЭтоКомиссия", ЭтоКомиссия);
	Запрос.УстановитьПараметр("СчетФактураДата", СчетФактураДата);
	Запрос.УстановитьПараметр("СчетФактураПриУвеличенииСтоимости", СчетФактураПриУвеличенииСтоимости);
	Запрос.УстановитьПараметр("ИсправленныйСчетФактура", ?(СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации
		<> Перечисления.ВидыОперацийИсправленияПоступленияРеализации.СогласованноеИзменение, ДокументСсылка,
		Документы.ДокументРасчетовСКонтрагентом.ПустаяСсылка()));
	Запрос.УстановитьПараметр("ИсправляемыйСчетФактура", ИсправляемыйДокумент);
	Запрос.УстановитьПараметр("СчетФактураДата", СчетФактураДата);
	Запрос.УстановитьПараметр("РасчетыВВалюте", СтруктураДополнительныеСвойства.ВалютаУчета
		<> СтруктураДополнительныеСвойства.НациональнаяВалюта);
	Запрос.УстановитьПараметр("МоментДокумента",
		Новый Граница(Новый МоментВремени(СтруктураДополнительныеСвойства.ДляПроведения.Дата, ДокументСсылка),
		ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("ДатаИсправляемогоСчетаФактуры", ДатаИсправляемогоДокумента);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("ИсходныйСчетФактураДата", ИсходныйСчетФактураДата);
	Запрос.УстановитьПараметр("СуммаВключаетНДС", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"СуммаВключаетНДС"));
    Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ЕстьРасхождения",
        ДокументПоступление.Метаданные()) Тогда
        ЕстьРасхождения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументПоступление, "ЕстьРасхождения");
    Иначе
        ЕстьРасхождения = Ложь;
    КонецЕсли;

	Запрос.УстановитьПараметр("ЕстьРасхождения", ЕстьРасхождения);
	Запрос.УстановитьПараметр("ДокументПоступления", ДокументПоступление);
	Запрос.УстановитьПараметр("РасчетКорректировокСУчетомРекомендацийПоНДС", Истина);
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	Запрос.УстановитьПараметр("ВалютаНациональная", Константы.НациональнаяВалюта.Получить());
	Запрос.УстановитьПараметр("КурсДокумента", СтруктураДополнительныеСвойства.КурсДокумента);
	Запрос.УстановитьПараметр("КратностьДокумента", СтруктураДополнительныеСвойства.КратностьДокумента);

	ТекстЗапроса = "ВЫБРАТЬ
				   |    ВТ_РасхожденияПриПриемке.ИдентификаторСтроки КАК ИдентификаторСтроки,
				   |    ВТ_РасхожденияПриПриемке.СуммаПодтвержденнаяРуб КАК СуммаПодтвержденнаяРуб,
				   |    ВТ_РасхожденияПриПриемке.СуммаНДСПодтвержденнаяРуб КАК СуммаНДСПодтвержденнаяРуб
				   |ПОМЕСТИТЬ ВТ_РасхожденияПриПриемке
				   |ИЗ
				   |    (ВЫБРАТЬ
				   |        АктОРасхожденияхТовары.ИдентификаторСтроки КАК ИдентификаторСтроки,
				   |        ВЫБОР
				   |            КОГДА АктОРасхожденияхТовары.СуммаДоИзменения < АктОРасхожденияхТовары.Сумма
				   |                ТОГДА ВЫБОР
				   |                    КОГДА АктОРасхожденияхТовары.Ссылка.СуммаВключаетНДС
				   |                        ТОГДА АктОРасхожденияхТовары.СуммаДоИзменения
