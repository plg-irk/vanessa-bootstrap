Функция ПолучитьТаблицуОтчетКомиссионераОПродажах(ДокументСсылка, Ошибка)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);

	// По вознаграждению комиссионера
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СуммыВознаграждения.Ссылка,
	|	СУММА(СуммыВознаграждения.СуммаБезНДС) КАК СуммаБезНДС,
	|	СУММА(СуммыВознаграждения.НДС) КАК НДС
	|ПОМЕСТИТЬ ВТ_СуммыВознаграждения
	|ИЗ
	|	(ВЫБРАТЬ
	|		ОтчетКомиссионераТовары.Ссылка КАК Ссылка,
	|		ВЫБОР
	|			КОГДА ОтчетКомиссионераТовары.Ссылка.СуммаВключаетНДС
	|				ТОГДА ОтчетКомиссионераТовары.СуммаВознаграждения - ОтчетКомиссионераТовары.СуммаНДСВознаграждения
	|			ИНАЧЕ ОтчетКомиссионераТовары.СуммаВознаграждения
	|		КОНЕЦ КАК СуммаБезНДС,
	|		ОтчетКомиссионераТовары.СуммаНДСВознаграждения КАК НДС
	|	ИЗ
	|		Документ.ОтчетКомиссионера.Запасы КАК ОтчетКомиссионераТовары
	|	ГДЕ
	|		ОтчетКомиссионераТовары.Ссылка = &Ссылка) КАК СуммыВознаграждения
	|СГРУППИРОВАТЬ ПО
	|	СуммыВознаграждения.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	1 КАК НомерСтроки,
	|	Док.Договор.УслугаКомиссионногоВознаграждения КАК Номенклатура,
	|	ИСТИНА КАК Услуга,
	|	1 КАК Количество,
	|	ЕСТЬNULL(ВТ_СуммыВознаграждения.СуммаБезНДС + ВТ_СуммыВознаграждения.НДС, 0) КАК Сумма,
	|	ЕСТЬNULL(ВТ_СуммыВознаграждения.СуммаБезНДС, 0) КАК СуммаБезНДС,
	|	Док.СтавкаНДСВознаграждения.ПеречислениеСтавкаНДС КАК СтавкаНДС,
	|	ЕСТЬNULL(ВТ_СуммыВознаграждения.НДС, 0) КАК НДС,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПустаяСсылка) КАК СчетЗатрат,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПустаяСсылка) КАК СчетУчетаНДС,
	|	""Комиссионное вознаграждение"" КАК Содержание,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПустаяСсылка) КАК СчетДоходов,
	|	НЕОПРЕДЕЛЕНО КАК Субконто,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПустаяСсылка) КАК СчетРасходов,
	|	ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПустаяСсылка) КАК СчетУчетаНДСПоРеализации,
	|	ЕСТЬNULL(ВТ_СуммыВознаграждения.СуммаБезНДС + ВТ_СуммыВознаграждения.НДС, 0) КАК СуммаВознаграждения,
	|	ЕСТЬNULL(ВТ_СуммыВознаграждения.НДС, 0) КАК СуммаНДСВознаграждения,
	|	ЛОЖЬ КАК ЭтоКомиссия
	|ИЗ
	|	Документ.ОтчетКомиссионера КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СуммыВознаграждения КАК ВТ_СуммыВознаграждения
	|		ПО Док.Ссылка = ВТ_СуммыВознаграждения.Ссылка
	|ГДЕ
	|	Док.Ссылка = &Ссылка";

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

