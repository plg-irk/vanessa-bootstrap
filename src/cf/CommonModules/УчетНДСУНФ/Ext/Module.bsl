		+ "СчетФактураВыданныйПокупателю,"					// <ДокументСсылка.СчетФактураВыданный> - Счет-фактура выданный покупателю при реализации товаров комитента
		+ "КодВидаСделки,"									// <Строка, 2> - Код вида сделки
		+ "НомерСчетаФактурыПродавца,"						// <Строка, 50> - Номер счета-фактуры продавца
		+ "ДатаСчетаФактурыПродавца,"						// <Дата> - Дата счета-фактуры продавца
		+ "ИндексСтроки,"									// <Число,10,0> - Служебное измерение для сводного корректировочного счета-фактуры
		+ "ИсправлениеСобственнойОшибки,"					// <Булево> - Исправление собственной ошибки
		+ "ИсправляемыйСчетФактура,"						// <ДокументСсылка.*> - Исправляемый счет-фактура
		+ "ИсправленныйСчетФактура,"						// <ДокументСсылка.*> - Исправленный счет-фактура
		+ "ИННКонтрагента,"									// <Строка> - ИНН контрагента, может отличаться от Контрагент.ИНН
		+ "Сторно,"											// <Булево> - Сторно
		+ "ИННПродавца,"									// <Строка> - ИНН продавца,используется при исправлении собственных ошибок
		+ "КПППродавца,"									// <Строка> - КПП продавца,используется при исправлении собственных ошибок
		+ "ИННСубкомиссионера,"								// <Строка> - ИНН субкомиссионера,используется при исправлении собственных ошибок
		+ "КППСубкомиссионера,"								// <Строка> - КПП субкомиссионера,используется при исправлении собственных ошибок
		+ "СчетФактураПолученныйОтПродавца";				// <ДокументСсылка.СчетФактураПолученный> - Счет-фактура полученный от продавца
		
	Если ТаблицаРеквизиты = Неопределено Тогда
		
		ЗаписиЖурнала = Новый ТаблицаЗначений;
		Колонки = Новый Структура(СписокОбязательныхКолонок);
		Для каждого Колонка Из Колонки Цикл
			ЗаписиЖурнала.Колонки.Добавить(Колонка.Ключ);
		КонецЦикла;

	Иначе

		ЗаписиЖурнала = ТаблицаРеквизиты.Скопировать(, СписокОбязательныхКолонок);

	КонецЕсли;
		
	Возврат ЗаписиЖурнала;

КонецФункции

// Функция находит и возвращает исходный счет-фактуру в цепочке исправлений собственных ошибок
// Параметры:
//	СчетФактура - ДокументСсылка.СчетФактура
Функция ПолучитьИсходныйСчетФактуру(СчетФактура) Экспорт
    
    Если ЗначениеЗаполнено(СчетФактура) Тогда
        РеквизитыСчетаФактуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СчетФактура,
            "ИсправлениеСобственнойОшибки, ИсправляемыйСчетФактура");
        
        Если РеквизитыСчетаФактуры.ИсправлениеСобственнойОшибки Тогда
            Возврат ПолучитьИсходныйСчетФактуру(РеквизитыСчетаФактуры.ИсправляемыйСчетФактура)
        Иначе
            Возврат СчетФактура;
        КонецЕсли;
    Иначе
        Возврат СчетФактура;
    КонецЕсли;
    
КонецФункции

#КонецОбласти

#Область НДСАвансыПолученные

Процедура СформироватьТаблицаНДСАвансыПолученные(ДокументСсылка,
	СтруктураДополнительныеСвойства) Экспорт 
	
	Если УчетнаяПолитика.ПрименяетсяАУСН(СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности, СтруктураДополнительныеСвойства.ДляПроведения.Дата) Тогда
		ПустаТаблицаНДСАвансыПолученные(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Если Не СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс
	И Не СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса Тогда
		ПустаТаблицаНДСАвансыПолученные(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Покупатель", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Покупатель", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;
	
	ДокументОплаты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "ДокументОснование");
	Запрос.УстановитьПараметр("ДокументОплаты", ДокументОплаты);
	Запрос.УстановитьПараметр("ДатаПолученияАванса", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОплаты, "Дата"));
	Запрос.УстановитьПараметр("Исправление", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Исправление"));

	
	Запрос.УстановитьПараметр("ТипыЗапасовСобственные",     ТипыЗапасовСобственные());
	Запрос.УстановитьПараметр("ВалютаНациональная",            СтруктураДополнительныеСвойства.НациональнаяВалюта);
	Запрос.УстановитьПараметр("ВалютаУчета",             СтруктураДополнительныеСвойства.ВалютаУчета);
	Запрос.УстановитьПараметр("ВалютаНакладной", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"ВалютаДокумента"));
	Запрос.УстановитьПараметр("МоментВремени",
		Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Период", СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	
	Если СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда
		Запрос.Текст = ТекстЗапросаТаблицаНДСАвансыПолученные();
	Иначе
		Запрос.Текст = ТекстЗапросаТаблицаНДСАвансыПолученныеКорреквтировкаАванса();
	КонецЕсли;
	
	АвансыПолученные  = Запрос.Выполнить().Выгрузить();
	
	Если АвансыПолученные.Количество() = 0 Тогда
		ПустаТаблицаНДСАвансыПолученные(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСАвансыПолученные", АвансыПолученные);
	
КонецПроцедуры

// Процедура инициализирует пустую таблицу значений для проведения документа по регистру НДС авансы полученные.
//
// Параметры:
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств, в которую будет добавлена пустая таблица значений.
//
Процедура ПустаТаблицаНДСАвансыПолученные(СтруктураДополнительныеСвойства) Экспорт

    Если СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаНДСАвансыПолученные") Тогда
        Возврат;
    КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСАвансыПолученные", Новый ТаблицаЗначений);

КонецПроцедуры

Функция ТекстЗапросаТаблицаНДСАвансыПолученные()

	ТекстЗапроса = "ВЫБРАТЬ
	|	КурсыВалютСрезПоследних.Валюта КАК Валюта,
	|	ВЫБОР
	|		КОГДА КурсыВалютСрезПоследних.Курс = 0
	|			ТОГДА 1
	|		ИНАЧЕ КурсыВалютСрезПоследних.Курс
	|	КОНЕЦ КАК Курс,
	|	ВЫБОР
	|		КОГДА КурсыВалютСрезПоследних.Кратность = 0
	|			ТОГДА 1
	|		ИНАЧЕ КурсыВалютСрезПоследних.Кратность
	|	КОНЕЦ КАК Кратность
	|ПОМЕСТИТЬ ВременнаяТаблицаКурсыВалютСрезПоследних
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаУчета, &ВалютаНациональная,
	|		&ВалютаНакладной)) КАК КурсыВалютСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&ДатаПолученияАванса КАК Период,
	|	&Организация КАК Организация,
	|	&ДокументОплаты КАК СчетФактура,
	|	&Покупатель КАК Покупатель,
	|	&ДокументОплаты КАК ДокументОплаты,
	|	&ДатаПолученияАванса КАК ДатаОплаты,
	|	&ДатаПолученияАванса КАК ДатаСобытия,
	|	ТаблицаАвансы.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ТаблицаАвансы.СуммаНДС) КАК НДС,
	|	СУММА(ВЫБОР
	|		КОГДА ТаблицаАвансы.Сумма = 0
	|			ТОГДА 0
	|		ИНАЧЕ ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС
	|	КОНЕЦ) КАК СуммаБезНДС,
	|	СУММА(ВЫБОР
	|		КОГДА ЕСТЬNULL(КурсВалютыУпрУчета.Курс, 0) = 0
	|			ТОГДА ТаблицаАвансы.СуммаНДС
	|		ИНАЧЕ ТаблицаАвансы.СуммаНДС * КурсВалютыУпрУчета.Курс / КурсВалютыУпрУчета.Кратность
	|	КОНЕЦ) КАК НДСУпр,
	|	СУММА(ВЫБОР
	|		КОГДА ТаблицаАвансы.Сумма = 0
	|			ТОГДА 0
	|		КОГДА ЕСТЬNULL(КурсВалютыУпрУчета.Кратность, 0) = 0
	|			ТОГДА ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС
	|		ИНАЧЕ (ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС) * КурсВалютыУпрУчета.Курс / КурсВалютыУпрУчета.Кратность
	|	КОНЕЦ) КАК СуммаБезНДСУпр,
	|	ТаблицаАвансы.НомерПлатежноРасчетногоДокумента КАК НомерДокументаОплаты,
	|	ТаблицаАвансы.ДатаПлатежноРасчетногоДокумента КАК ДатаДокументаОплаты,
	|	ТаблицаАвансы.Ссылка.ДокументОснование КАК ОбъектРасчетов,
	|	ТаблицаАвансы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ТаблицаАвансы.Ссылка.Договор КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ ВтТаблицаАвансы
	|ИЗ
	|	Документ.СчетФактура.Авансы КАК ТаблицаАвансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсВалютыУпрУчета
	|		ПО КурсВалютыУпрУчета.Валюта = &ВалютаУчета
	|ГДЕ
	|	ТаблицаАвансы.Ссылка = &Ссылка
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаАвансы.СтавкаНДС,
	|	ТаблицаАвансы.НомерПлатежноРасчетногоДокумента,
	|	ТаблицаАвансы.ДатаПлатежноРасчетногоДокумента,
	|	ТаблицаАвансы.Ссылка.ДокументОснование,
	|	ТаблицаАвансы.НаправлениеДеятельности,
	|	ТаблицаАвансы.Ссылка.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &Исправление
	|			ТОГДА &Период
	|		ИНАЧЕ ТаблицаАвансы.Период
	|	КОНЕЦ КАК Период,
	|	ТаблицаАвансы.Организация КАК Организация,
	|	ТаблицаАвансы.ДокументОплаты КАК ДокументОплаты,
	|	ТаблицаАвансы.Покупатель КАК Контрагент,
	|	ВЫБОР
	|		КОГДА &Исправление
	|			ТОГДА &Ссылка
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ИсправленныйСчетФактура,
	|	ТаблицаАвансы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ТаблицаАвансы.СтавкаНДС КАК СтавкаНДС,
	|	ТаблицаАвансы.СуммаБезНДС КАК СуммаБезНДС,
	|	ТаблицаАвансы.НДС КАК НДС,
	|	ТаблицаАвансы.НДСУпр КАК НДСУпр,
	|	ЗНАЧЕНИЕ(Перечисление.СобытияНДСАвансы.НачислениеСПолученногоАванса) КАК Событие,
	|	НЕОПРЕДЕЛЕНО КАК ДокументЗачетаАванса,
	|	ЛОЖЬ КАК РегламентнаяОперация,
	|	ЛОЖЬ КАК Сторно,
	|	ТаблицаАвансы.Период КАК ДатаСобытия,
	|	ТаблицаАвансы.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ИЗ
	|	ВтТаблицаАвансы КАК ТаблицаАвансы";

	Возврат ТекстЗапроса;

КонецФункции

Функция ТекстЗапросаТаблицаНДСАвансыПолученныеКорреквтировкаАванса()

	ТекстЗапроса = "ВЫБРАТЬ
				   |	КурсыВалютСрезПоследних.Валюта КАК Валюта,
				   |	ВЫБОР
				   |		КОГДА КурсыВалютСрезПоследних.Курс = 0
				   |			ТОГДА 1
				   |		ИНАЧЕ КурсыВалютСрезПоследних.Курс
				   |	КОНЕЦ КАК Курс,
				   |	ВЫБОР
				   |		КОГДА КурсыВалютСрезПоследних.Кратность = 0
				   |			ТОГДА 1
				   |		ИНАЧЕ КурсыВалютСрезПоследних.Кратность
				   |	КОНЕЦ КАК Кратность
				   |ПОМЕСТИТЬ ВременнаяТаблицаКурсыВалютСрезПоследних
				   |ИЗ
				   |	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаУчета, &ВалютаНациональная,
				   |		&ВалютаНакладной)) КАК КурсыВалютСрезПоследних
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	&ДатаПолученияАванса КАК Период,
				   |	&Организация КАК Организация,
				   |	&ДокументОплаты КАК СчетФактура,
				   |	&Покупатель КАК Покупатель,
				   |	&ДокументОплаты КАК ДокументОплаты,
				   |	&ДатаПолученияАванса КАК ДатаОплаты,
				   |	&ДатаПолученияАванса КАК ДатаСобытия,
				   |	ТаблицаАвансы.СтавкаНДС КАК СтавкаНДС,
				   |	СУММА(ТаблицаАвансы.СуммаНДС - ТаблицаАвансы.СуммаНДСДоКорректировки) КАК НДС,
				   |	СУММА(ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС - (ТаблицаАвансы.СуммаДоКорректировки -
				   |		ТаблицаАвансы.СуммаНДСДоКорректировки)) КАК СуммаБезНДС,
				   |	СУММА(ВЫБОР
				   |		КОГДА ЕСТЬNULL(КурсВалютыУпрУчета.Курс, 0) = 0
				   |			ТОГДА ТаблицаАвансы.СуммаНДС - ТаблицаАвансы.СуммаНДСДоКорректировки
				   |		ИНАЧЕ (ТаблицаАвансы.СуммаНДС - ТаблицаАвансы.СуммаНДСДоКорректировки) * КурсВалютыУпрУчета.Курс /
				   |			КурсВалютыУпрУчета.Кратность
				   |	КОНЕЦ) КАК НДСУпр,
				   |	СУММА(ВЫБОР
				   |		КОГДА ТаблицаАвансы.Сумма = 0
				   |			ТОГДА 0
				   |		КОГДА ЕСТЬNULL(КурсВалютыУпрУчета.Кратность, 0) = 0
				   |			ТОГДА ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС - (ТаблицаАвансы.СуммаДоКорректировки -
				   |				ТаблицаАвансы.СуммаНДСДоКорректировки)
				   |		ИНАЧЕ (ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС - (ТаблицаАвансы.СуммаДоКорректировки -
				   |			ТаблицаАвансы.СуммаНДСДоКорректировки)) * КурсВалютыУпрУчета.Курс / КурсВалютыУпрУчета.Кратность
				   |	КОНЕЦ) КАК СуммаБезНДСУпр,
				   |	ТаблицаАвансы.НомерПлатежноРасчетногоДокумента КАК НомерДокументаОплаты,
				   |	ТаблицаАвансы.ДатаПлатежноРасчетногоДокумента КАК ДатаДокументаОплаты,
				   |	ТаблицаАвансы.Ссылка.ДокументОснование КАК ОбъектРасчетов,
				   |	ТаблицаАвансы.НаправлениеДеятельности КАК НаправлениеДеятельности,
				   |	ТаблицаАвансы.Ссылка.Договор КАК ДоговорКонтрагента
				   |ПОМЕСТИТЬ ВтТаблицаАвансы
				   |ИЗ
				   |	Документ.СчетФактура.Авансы КАК ТаблицаАвансы
				   |		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсВалютыУпрУчета
				   |		ПО КурсВалютыУпрУчета.Валюта = &ВалютаУчета
				   |ГДЕ
				   |	ТаблицаАвансы.Ссылка = &Ссылка
				   |СГРУППИРОВАТЬ ПО
				   |	ТаблицаАвансы.СтавкаНДС,
				   |	ТаблицаАвансы.НомерПлатежноРасчетногоДокумента,
				   |	ТаблицаАвансы.ДатаПлатежноРасчетногоДокумента,
				   |	ТаблицаАвансы.Ссылка.ДокументОснование,
				   |	ТаблицаАвансы.НаправлениеДеятельности,
				   |	ТаблицаАвансы.Ссылка.Договор
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |ВЫБРАТЬ
				   |	ВЫБОР
				   |		КОГДА &Исправление
				   |			ТОГДА &Период
				   |		ИНАЧЕ ТаблицаАвансы.Период
				   |	КОНЕЦ КАК Период,
				   |	ТаблицаАвансы.Организация КАК Организация,
				   |	ТаблицаАвансы.ДокументОплаты КАК ДокументОплаты,
				   |	ТаблицаАвансы.Покупатель КАК Контрагент,
				   |	ВЫБОР
				   |		КОГДА &Исправление
				   |			ТОГДА &Ссылка
				   |		ИНАЧЕ НЕОПРЕДЕЛЕНО
				   |	КОНЕЦ КАК ИсправленныйСчетФактура,
				   |	ТаблицаАвансы.НаправлениеДеятельности КАК НаправлениеДеятельности,
				   |	ТаблицаАвансы.СтавкаНДС КАК СтавкаНДС,
				   |	ТаблицаАвансы.СуммаБезНДС КАК СуммаБезНДС,
				   |	ТаблицаАвансы.НДС КАК НДС,
				   |	ТаблицаАвансы.НДСУпр КАК НДСУпр,
				   |	ЗНАЧЕНИЕ(Перечисление.СобытияНДСАвансы.НачислениеСПолученногоАванса) КАК Событие,
				   |	НЕОПРЕДЕЛЕНО КАК ДокументЗачетаАванса,
				   |	ЛОЖЬ КАК РегламентнаяОперация,
				   |	ЛОЖЬ КАК Сторно,
				   |	ТаблицаАвансы.Период КАК ДатаСобытия,
				   |	ТаблицаАвансы.ДоговорКонтрагента КАК ДоговорКонтрагента
				   |ИЗ
				   |	ВтТаблицаАвансы КАК ТаблицаАвансы";

	Возврат ТекстЗапроса;

КонецФункции

#КонецОбласти

#Область НДСАвансыВыданные

Процедура СформироватьТаблицаНДСАвансыВыданные(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт

	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ВедетсяУчетНДСПоФЗ134  = УчетНДС.ВедетсяУчетНДСПоФЗ134(СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Если Не ПлательщикНДС И Не ВедетсяУчетНДСПоФЗ134 Тогда
		ПустаТаблицаНДСАвансыВыданные(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Если Не СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийСчетФактураПолученный.Аванс Тогда
		ПустаТаблицаНДСАвансыВыданные(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности);
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Контрагент",
		СтруктураДополнительныеСвойства.ДляПроведения.МетаданныеДокумента) Тогда
		Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Контрагент");
		Запрос.УстановитьПараметр("Поставщик", Контрагент);
	Иначе
		Запрос.УстановитьПараметр("Покупатель", Справочники.Контрагенты.ПустаяСсылка());
	КонецЕсли;

	ДокументОплаты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "ДокументОснование");
	Запрос.УстановитьПараметр("ДокументОплаты", ДокументОплаты);
	Запрос.УстановитьПараметр("ДатаПолученияАванса", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОплаты, "Дата"));
	Запрос.УстановитьПараметр("Исправление", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Исправление"));

	Запрос.УстановитьПараметр("ВалютаНациональная", СтруктураДополнительныеСвойства.НациональнаяВалюта);
	Запрос.УстановитьПараметр("ВалютаУчета", СтруктураДополнительныеСвойства.ВалютаУчета);
	Запрос.УстановитьПараметр("ВалютаНакладной", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,
		"ВалютаДокумента"));
	Запрос.УстановитьПараметр("МоментВремени",
		Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Дата", СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	Запрос.Текст = ТекстЗапросаТаблицаНДСАвансыВыданные();

	АвансыВыданные  = Запрос.Выполнить().Выгрузить();

	Если АвансыВыданные.Количество() = 0 Тогда
		ПустаТаблицаНДСАвансыВыданные(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСАвансыВыданные", АвансыВыданные);

КонецПроцедуры

// Процедура инициализирует пустую таблицу значений для проведения документа по регистру НДС авансы полученные.
//
// Параметры:
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств, в которую будет добавлена пустая таблица значений.
//
Процедура ПустаТаблицаНДСАвансыВыданные(СтруктураДополнительныеСвойства)

	Если СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаНДСАвансыВыданные") Тогда
		Возврат;
	КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСАвансыВыданные", Новый ТаблицаЗначений);

КонецПроцедуры

Функция ТекстЗапросаТаблицаНДСАвансыВыданные()

	ТекстЗапроса = "ВЫБРАТЬ
	|	КурсыВалютСрезПоследних.Валюта КАК Валюта,
	|	ВЫБОР
	|		КОГДА КурсыВалютСрезПоследних.Курс = 0
	|			ТОГДА 1
	|		ИНАЧЕ КурсыВалютСрезПоследних.Курс
	|	КОНЕЦ КАК Курс,
	|	ВЫБОР
	|		КОГДА КурсыВалютСрезПоследних.Кратность = 0
	|			ТОГДА 1
	|		ИНАЧЕ КурсыВалютСрезПоследних.Кратность
	|	КОНЕЦ КАК Кратность
	|ПОМЕСТИТЬ ВременнаяТаблицаКурсыВалютСрезПоследних
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаУчета, &ВалютаНациональная,
	|		&ВалютаНакладной)) КАК КурсыВалютСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаАвансы.СтавкаНДС КАК СтавкаНДС,
	|	ТаблицаАвансы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	СУММА(ВЫБОР
	|		КОГДА ТаблицаАвансы.Сумма = 0
	|			ТОГДА 0
	|		ИНАЧЕ ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС
	|	КОНЕЦ) КАК СуммаБезНДС,
	|	СУММА(ТаблицаАвансы.СуммаНДС) КАК НДС,
	|	СУММА(ВЫБОР
	|		КОГДА ТаблицаАвансы.Сумма <> 0
	|			ТОГДА ВЫБОР
	|				КОГДА ЕСТЬNULL(КурсВалютыУпрУчета.Курс, 0) = 0
	|					ТОГДА ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС
	|				ИНАЧЕ (ТаблицаАвансы.Сумма - ТаблицаАвансы.СуммаНДС) * КурсВалютыУпрУчета.Курс / КурсВалютыУпрУчета.Кратность
	|			КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаБезНДСУпр,
	|	СУММА(ВЫБОР
	|		КОГДА ЕСТЬNULL(КурсВалютыУпрУчета.Курс, 0) = 0
	|			ТОГДА ТаблицаАвансы.СуммаНДС
	|		ИНАЧЕ ТаблицаАвансы.СуммаНДС * КурсВалютыУпрУчета.Курс / КурсВалютыУпрУчета.Кратность
	|	КОНЕЦ) КАК НДСУпр,
	|	ТаблицаАвансы.Ссылка.Договор КАК ДокументОснованиеДоговор
	|ПОМЕСТИТЬ втАвансы
	|ИЗ
	|	Документ.СчетФактураПолученный.Авансы КАК ТаблицаАвансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсВалютыУпрУчета
	|		ПО КурсВалютыУпрУчета.Валюта = &ВалютаУчета
	|ГДЕ
	|	ТаблицаАвансы.Ссылка = &Ссылка
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаАвансы.НаправлениеДеятельности,
	|	ТаблицаАвансы.СтавкаНДС,
	|	ТаблицаАвансы.Ссылка.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	&Организация КАК Организация,
	|	&ДокументОплаты КАК ДокументОплаты,
	|	&ДатаПолученияАванса КАК ДатаСобытия,
	|	&Поставщик КАК Контрагент,
	|	ВЫБОР
	|		КОГДА &Исправление
	|			ТОГДА &Ссылка
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ИсправленныйСчетФактура,
	|	ТаблицаАвансы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ТаблицаАвансы.СтавкаНДС КАК СтавкаНДС,
	|	ТаблицаАвансы.СуммаБезНДС КАК СуммаБезНДС,
	|	ТаблицаАвансы.НДС КАК НДС,
	|	ТаблицаАвансы.НДСУпр КАК НДСУпр,
	|	ЗНАЧЕНИЕ(Перечисление.СобытияНДСАвансы.ВычетСВыданногоАванса) КАК Событие,
	|	НЕОПРЕДЕЛЕНО КАК ДокументЗачетаАванса,
	|	ЛОЖЬ КАК РегламентнаяОперация,
	|	ЛОЖЬ КАК Сторно,
	|	ТаблицаАвансы.ДокументОснованиеДоговор КАК ДоговорКонтрагента
	|ИЗ
	|	втАвансы КАК ТаблицаАвансы";

	Возврат ТекстЗапроса;

КонецФункции

