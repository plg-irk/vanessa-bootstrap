Процедура СформироватьДвиженияВозвратТоваровОтПокупателя(ДокументСсылка, СтруктураДополнительныеСвойства,
	ТаблицаТовары) Экспорт

	ВидЦенности = Перечисления.ВидыЦенностей.Возврат;

	УчетНДС.ЗаполнитьВидыЦенностей(ТаблицаТовары, ВидЦенности, "СчетУчета");

	ДанныеДвижений = ПодготовитьДанныеДвиженийВозвратТоваровОтПокупателя(ТаблицаТовары, СтруктураДополнительныеСвойства);
	ТаблицаЗаписиКнигиПокупок = ПустаяТаблицаРегистраНакопления("НДСЗаписиКнигиПокупок");

	Если ДанныеДвижений.Итог("НДС") <> 0 Тогда

		ДокументОтгрузки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "ДокументОснование");
            
            // С 01.01.2019 года вычет по возврату формируем сразу.
		Если СтруктураДополнительныеСвойства.ДляПроведения.Дата >= '20190101' И ЗначениеЗаполнено(ДокументОтгрузки) Тогда
			Если ТипЗнч(ДокументОтгрузки) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда
				ДанныеДвижений.ЗаполнитьЗначения(Справочники.Контрагенты.ПустаяСсылка(), "Поставщик");
				ДанныеДвижений.ЗаполнитьЗначения("17", "КодВидаОперации");
			КонецЕсли;
			Если СтруктураДополнительныеСвойства.ПлательщикНДС Тогда
				ТаблицаНДСПредъявленный = ПустаяТаблицаРегистраНакопления("НДСПредъявленный");
				ТаблицаНДСПредъявленный.Колонки.Добавить("ВидДвижения");

				СформироватьДвиженияНДСПредъявленныйВычетНДС(ДанныеДвижений, ТаблицаНДСПредъявленный, Ложь, Ложь);
				СформироватьДвиженияНДСПредъявленныйВычетНДС(ДанныеДвижений, ТаблицаНДСПредъявленный, Истина, Ложь);
				СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСПредъявленный",
					ТаблицаНДСПредъявленный);
			КонецЕсли;

			СформироватьДвиженияНДСЗаписиКнигиПокупокПоступлениеТоваровУслуг(ДанныеДвижений, ТаблицаЗаписиКнигиПокупок);

		Иначе
			СформироватьДвиженияНДСЗаписиКнигиПокупокПоступлениеТоваровУслуг(ДанныеДвижений, ТаблицаЗаписиКнигиПокупок);
		КонецЕсли;
	КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСЗаписиКнигиПокупок",
		ТаблицаЗаписиКнигиПокупок);

КонецПроцедуры

