//		НайденнаяКолонка = ПустаяТаблица.Колонки.Найти("СуммаБезНДСРуб");
//		Если НайденнаяКолонка <> Неопределено Тогда
//			НайденнаяКолонка.Имя = "СуммаБезНДС";
//		КонецЕсли;
//		НайденнаяКолонка = ПустаяТаблица.Колонки.Найти("СуммаНДСВалютаДокумента");
//		Если НайденнаяКолонка <> Неопределено Тогда
//			НайденнаяКолонка.Имя = "НДС";
//		КонецЕсли;
//		Возврат ПустаяТаблица;
//	КонецЕсли;

	ДанныеДвижений = Товары.Скопировать( , "Регистратор,СтавкаНДС,ВидЦенности,
										   |СуммаБезНДС,СуммаНДСВалютаДокумента");

	ДанныеДвижений.Свернуть(
        "Регистратор,СтавкаНДС,ВидЦенности", "СуммаБезНДС,СуммаНДСВалютаДокумента");

	ДанныеДвижений.Колонки.Добавить("Период", Новый ОписаниеТипов("Дата"));
	ДанныеДвижений.Колонки.Добавить("ДатаСобытия", Новый ОписаниеТипов("Дата"));
	ДанныеДвижений.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.Дата, "Период,ДатаСобытия");

	ДанныеДвижений.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ДанныеДвижений.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		"Организация");

	ДанныеДвижений.Колонки.Добавить("ПродавцомВыступаетОрганизация", Новый ОписаниеТипов("Булево"));
	ДанныеДвижений.ЗаполнитьЗначения(Истина, "ПродавцомВыступаетОрганизация");

    // Для отражения в книге покупок
	ДанныеДвижений.Колонки.Добавить("Поставщик", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
    // Для отражения в книге продаж
	ДанныеДвижений.Колонки.Добавить("Покупатель", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ДанныеДвижений.ЗаполнитьЗначения(СтруктураДополнительныеСвойства.Контрагент, "Поставщик,Покупатель");

    // Договор указывается только для налогового агента, при возврате от покупателя всегда пустой
	ДанныеДвижений.Колонки.Добавить("ДоговорКонтрагента", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));

	ДанныеДвижений.Колонки.Регистратор.Имя    = "СчетФактура";
	ДанныеДвижений.Колонки.СуммаНДСВалютаДокумента.Имя = "НДС";

	ДанныеДвижений.Колонки.Добавить("КодВидаОперации", Новый ОписаниеТипов("Строка"));

	Возврат ДанныеДвижений;

КонецФункции

Процедура СформироватьДвиженияНДСПредъявленныйВключениеВСтоимость(ДанныеДвижений, Движения,
	НДСОтПодотчетногоЛица = Ложь, ЕстьРасхождения) Экспорт

	Если ДанныеДвижений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	Для Каждого СтрокаТаблицы Из ДанныеДвижений Цикл

		Если НДСОтПодотчетногоЛица И Не СтрокаТаблицы.НДСВключенВСтоимость Тогда
			Продолжить;
		КонецЕсли;

		Запись = Движения.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);

		Запись.Поставщик  = СтрокаТаблицы.Поставщик;
		Запись.СуммаБезНДС = СтрокаТаблицы.СуммаБезНДС;
		Запись.НДС         = СтрокаТаблицы.СуммаНДСВалютаДокумента;
		Запись.СтавкаНДС   = СтрокаТаблицы.СтавкаНДС;
		Если ЕстьРасхождения И (СтрокаТаблицы.СуммаПодтвержденнаяРуб <> 0 Или СтрокаТаблицы.СуммаНДСПодтвержденнаяРуб
			<> 0) Тогда
			Запись.СуммаБезНДС = СтрокаТаблицы.СуммаПодтвержденнаяРуб - СтрокаТаблицы.СуммаНДСПодтвержденнаяРуб;
			Запись.НДС        = СтрокаТаблицы.СуммаНДСПодтвержденнаяРуб;
		КонецЕсли;

		Запись.ВидДвижения = ВидДвиженияНакопления.Расход;
		Запись.Событие = Перечисления.СобытияПоНДСПокупки.НДСВключенВСтоимость;

	КонецЦикла;

КонецПроцедуры

// Формирует движения регистра "НДС предъявленный, реализация 0%" по данным таблицы значений.
//
// Параметры:
//  ТаблицаДвижений - ТаблицаЗначений - таблица значений с колонками, соответствующими регистрам накопления "НДС предъявленный, реализация 0%".
//  Движения - КоллекцияДвижений - коллекция движений регистра накопления "НДС предъявленный, реализация 0%".
//  Отказ - Булево - флаг отказа от проведения документа.
//
Процедура СформироватьДвиженияНДСПредъявленныйРеализация0ВычетПоРеализации(ТаблицаДвижений, Движения, Отказ) Экспорт

	Для Каждого СтрокаТаблицы Из ТаблицаДвижений Цикл

		Запись = Движения.НДСПредъявленныйРеализация0.ДобавитьРасход();
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);

	КонецЦикла;

	Движения.НДСПредъявленныйРеализация0.Записывать = Истина;

КонецПроцедуры

Процедура СформироватьТаблицаНДСПредъявленный(ДокументСсылкаОтчетКомиссионера, СтруктураДополнительныеСвойства) Экспорт

	ПлательщикНДСПрименяющийУСН =  УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);

	ПлательщикНДС                      = УчетнаяПолитика.ПлательщикНДС(
        СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата) Или ПлательщикНДСПрименяющийУСН;

	Если Не ПлательщикНДС Тогда
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаНДСПредъявленный.Документ КАК СчетФактура,
	|	ТаблицаНДСПредъявленный.Период КАК Период,
	|	ТаблицаНДСПредъявленный.Период КАК ДатаСобытия,
	|	ТаблицаНДСПредъявленный.Организация КАК Организация,
	|	ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ПосредническиеУслуги) КАК ВидЦенности,
	|	НЕОПРЕДЕЛЕНО КАК СчетУчетаНДС,
	|	ТаблицаНДСПредъявленный.СтавкаНДСВознаграждения.ПеречислениеСтавкаНДС КАК СтавкаНДС,
	|	ТаблицаНДСПредъявленный.Контрагент КАК Поставщик,
	|	ЗНАЧЕНИЕ(Перечисление.СобытияПоНДСПокупки.ПредъявленНДСПоставщиком) КАК Событие,
	|	ТаблицаНДСПредъявленный.СуммаНДСВознагражденияДляУслуги КАК НДС,
	|	СУММА(ТаблицаНДСПредъявленный.СуммаВознаграждения) КАК Сумма,
	|	СУММА(ТаблицаНДСПредъявленный.СуммаВознаграждения - ТаблицаНДСПредъявленный.СуммаНДСВознагражденияДляУслуги) КАК СуммаБезНДС
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаНДСПредъявленный
	|ГДЕ
	|	НЕ ТаблицаНДСПредъявленный.СуммаВознаграждения = 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаНДСПредъявленный.Организация,
	|	ТаблицаНДСПредъявленный.Документ,
	|	ТаблицаНДСПредъявленный.СуммаНДСВознагражденияДляУслуги,
	|	ТаблицаНДСПредъявленный.Контрагент,
	|	ТаблицаНДСПредъявленный.СтавкаНДСВознаграждения.ПеречислениеСтавкаНДС,
	|	ТаблицаНДСПредъявленный.Период,
	|	ТаблицаНДСПредъявленный.Период
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаНДСПредъявленныйВозвраты.Документ,
	|	ТаблицаНДСПредъявленныйВозвраты.Период,
	|	ТаблицаНДСПредъявленныйВозвраты.Период,
	|	ТаблицаНДСПредъявленныйВозвраты.Организация,
	|	ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.ПосредническиеУслуги),
	|	НЕОПРЕДЕЛЕНО,
	|	ТаблицаНДСПредъявленныйВозвраты.СтавкаНДСВознаграждения.ПеречислениеСтавкаНДС,
	|	ТаблицаНДСПредъявленныйВозвраты.Контрагент,
	|	ЗНАЧЕНИЕ(Перечисление.СобытияПоНДСПокупки.ПредъявленНДСПоставщиком),
	|	СУММА(ТаблицаНДСПредъявленныйВозвраты.СуммаНДСВознагражденияДляУслуги),
	|	ТаблицаНДСПредъявленныйВозвраты.СуммаВознаграждения,
	|	СУММА(ТаблицаНДСПредъявленныйВозвраты.СуммаВознаграждения - ТаблицаНДСПредъявленныйВозвраты.СуммаНДСВознагражденияДляУслуги)
	|ИЗ
	|	ВременнаяТаблицаЗапасыВозвраты КАК ТаблицаНДСПредъявленныйВозвраты
	|ГДЕ
	|	НЕ ТаблицаНДСПредъявленныйВозвраты.СуммаВознаграждения = 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаНДСПредъявленныйВозвраты.Организация,
