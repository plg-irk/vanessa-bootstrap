	|	Итог.Событие,
	|	Итог.СтавкаНДС,
	|	Итог.СчетУчетаНДС";

	РезультатЗапроса = Запрос.Выполнить();

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСПредъявленный", РезультатЗапроса.Выгрузить());

КонецПроцедуры

Процедура СформироватьДвиженияПредъявленНДС(ТаблицаПредъявленногоНДС, ДатаДокументаРеализации,
	СтруктураДополнительныеСвойства, ЗаполнятьВидЦенности = Ложь, Сторно = Ложь)

	Если ТаблицаПредъявленногоНДС.Количество() = 0 Тогда
		ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	Если ЗаполнятьВидЦенности Тогда
		УчетНДС.ЗаполнитьВидыЦенностей(ТаблицаПредъявленногоНДС);
	КонецЕсли;

	КолонкиГруппировок = "ВидЦенности, СтавкаНДС, Поставщик, Организация, СчетФактура, ИсправленныйСчетФактура, Событие,
						 |ДатаСобытия, Регистратор, Период, ВидДвижения";

	ТаблицаПредъявленногоНДС.Свернуть(КолонкиГруппировок, "СуммаБезНДС, НДС");

	Если Сторно Тогда
		ТаблицаПредъявленногоНДС.ЗаполнитьЗначения(
        ВидДвиженияНакопления.Расход, "ВидДвижения");
	Иначе
		ТаблицаПредъявленногоНДС.ЗаполнитьЗначения(
        ВидДвиженияНакопления.Приход, "ВидДвижения");
	КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСПредъявленный", ТаблицаПредъявленногоНДС);

КонецПроцедуры

// Процедура инициализирует пустую таблицу значений для проведения документа по регистру НДС записи книги покупок.
//
// Параметры:
//  СтруктураДополнительныеСвойства - Структура - Структура дополнительных свойств, в которую будет добавлена пустая таблица значений.
//
Процедура ПустаяТаблицаНДСПредъявленный(СтруктураДополнительныеСвойства)
    
    Если СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаНДСПредъявленный") Тогда
        Возврат;
    КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНДСПредъявленный", Новый ТаблицаЗначений);

КонецПроцедуры

#КонецОбласти

#Область ЖурналУчетаСчетовФактур

Функция ПодготовитьЗаписьЖурналаУчетаСчетовФактур(ТаблицаРеквизиты) Экспорт

	Если ТаблицаРеквизиты = Неопределено
		ИЛИ ТаблицаРеквизиты.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
