		|    Реквизиты.Организация,
		|    Реквизиты.Контрагент КАК Покупатель,
		|    ВЫБОР
		|        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&СчетФактураДата, КВАРТАЛ)
		|            ТОГДА ЛОЖЬ
		|        ИНАЧЕ ИСТИНА
		|    КОНЕЦ КАК ЗаписьДополнительногоЛиста,
		|    ВЫБОР
		|        КОГДА КОНЕЦПЕРИОДА(&Период, КВАРТАЛ) = КОНЕЦПЕРИОДА(&СчетФактураДата, КВАРТАЛ)
		|            ТОГДА ДАТАВРЕМЯ(1, 1, 1)
		|        ИНАЧЕ НАЧАЛОПЕРИОДА(&СчетФактураДата, КВАРТАЛ)
		|    КОНЕЦ КАК КорректируемыйПериод,
		|    ЛОЖЬ КАК СторнирующаяЗаписьДопЛиста,
		|    ТаблицаУслуги.НомерСтроки,
		|    Реквизиты.Ссылка КАК Регистратор,
		|    """" КАК КодВидаОперации
		|ИЗ
		|    ТаблицаУслугиНДС КАК ТаблицаУслуги
		|        ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
		|        ПО ИСТИНА
		|ГДЕ
		|    ТаблицаУслуги.СуммаРубДоКорректировки - ТаблицаУслуги.СуммаРуб > 0";
	КонецЕсли;
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначенияУНФКлиентСервер.ТекстРазделителяЗапросовПакета();

	НомераТаблиц.Вставить("ТаблицаВычет", НомераТаблиц.Количество());
	Если СтруктураДополнительныеСвойства.ЕстьТовары Тогда
		ТекстЗапроса = ТекстЗапроса 
		+ "ВЫБРАТЬ
		|    &СчетФактураПриУвеличенииСтоимости КАК СчетФактура,
		|    &ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
		|    ""НДС"" КАК Содержание,
		|    ЛОЖЬ КАК Услуга,
		|    ЗНАЧЕНИЕ(Перечисление.СобытияПоНДСПокупки.ПредъявленНДСПоставщиком) КАК Событие,
		|    Реквизиты.Дата КАК ДатаСобытия,
		|    ЛОЖЬ КАК ЗаписьДополнительногоЛиста,
		|    ДАТАВРЕМЯ(1, 1, 1) КАК КорректируемыйПериод,
		|    ТаблицаТовары.Номенклатура КАК Номенклатура,
		|    ТаблицаТовары.СтавкаНДС.ПеречислениеСтавкаНДС КАК СтавкаНДС,
		|    ВЫБОР
		|        КОГДА &РасчетКорректировокСУчетомРекомендацийПоНДС
		|        И &РасчетыВВалюте
		|            ТОГДА ТаблицаТовары.СуммаБезНДСРубДоКорректировки - ТаблицаТовары.СуммаБезНДСРуб
		|        ИНАЧЕ ТаблицаТовары.СуммаРубДоКорректировки - ТаблицаТовары.СуммаРуб -
		|            (ТаблицаТовары.СуммаНДСРубДоКорректировки - ТаблицаТовары.СуммаНДСРуб)
		|    КОНЕЦ * -1 КАК СуммаБезНДС,
		|    (ТаблицаТовары.СуммаНДСРубДоКорректировки - ТаблицаТовары.СуммаНДСРуб) * -1 КАК НДС,
		|    (ТаблицаТовары.СуммаНДСВзаиморасчетовДоКорректировки - ТаблицаТовары.СуммаНДСВзаиморасчетов) * -1 КАК НДСВал,
		|    ТаблицаТовары.СуммаПерепоставкиРуб КАК СуммаПерепоставкиРуб,
		|    ТаблицаТовары.СуммаНДСПерепоставкиРуб КАК СуммаНДСПерепоставкиРуб,
		|    Реквизиты.Дата КАК Период,
		|    Реквизиты.Организация КАК Организация,
		|    Реквизиты.Контрагент КАК Поставщик,
		|    ТаблицаТовары.НомерСтроки КАК НомерСтроки,
		|    Реквизиты.Ссылка КАК Регистратор
		|ИЗ
		|    ТаблицаТоварыНДС КАК ТаблицаТовары
		|        ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаШапка КАК Реквизиты
		|        ПО ИСТИНА
		|ГДЕ
		|    ТаблицаТовары.СуммаРубДоКорректировки - ТаблицаТовары.СуммаРуб < 0
		|    ИЛИ ТаблицаТовары.СуммаПерепоставкиРуб > 0";
	КонецЕсли;
	Если СтруктураДополнительныеСвойства.ЕстьТовары И СтруктураДополнительныеСвойства.ЕстьУслуги Тогда
		ТекстЗапроса = ТекстЗапроса 
		+ "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|";
	КонецЕсли;
	Если СтруктураДополнительныеСвойства.ЕстьУслуги Тогда
		ТекстЗапроса = ТекстЗапроса 
		+ "ВЫБРАТЬ
		|    &СчетФактураПриУвеличенииСтоимости КАК СчетФактура,
		|    &ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
