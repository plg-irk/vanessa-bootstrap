	ВозвратОтгруженныхТоваров = (СтруктураДополнительныеСвойства.ПараметрыДокумента.ЭтоОтгрузка
		Или СтруктураДополнительныеСвойства.ПараметрыДокумента.ЭтоПередачаТоваров);
