Функция ПолучитьТаблицуСчетФактураВыданный(ДокументСсылка, Ошибка)

	Перем ТаблицаПоДокументамОснованиям, ТаблицаПоДокументуОснования;

	РеквизитыДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
        ДокументСсылка, "ВидОперации");

	Если РеквизитыДокумента.ВидОперации = Перечисления.ВидыОперацийСчетФактура.Продажа Тогда

		Для Каждого СтрокаТаблицы Из ДокументСсылка.ДокументыОснования Цикл
			Если ЗначениеЗаполнено(СтрокаТаблицы.ДокументОснование) Тогда
				ДокументОснованиеСсылка = СтрокаТаблицы.ДокументОснование;
                //@skip-check query-in-loop
				ТаблицаПоДокументуОснования = ПолучитьТаблицуДокументаНДС(ДокументОснованиеСсылка, Ошибка);
				Если ТаблицаПоДокументуОснования <> Неопределено Тогда
                    //@skip-check module-unused-local-variable
					Если ТаблицаПоДокументамОснованиям = Неопределено Тогда
						ТаблицаПоДокументамОснованиям = ТаблицаПоДокументуОснования.Скопировать();
					Иначе
						ОбщегоНазначенияУНФВызовСервера.ЗагрузитьВТаблицуЗначений(ТаблицаПоДокументуОснования,
							ТаблицаПоДокументамОснованиям);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;

		Возврат ТаблицаПоДокументамОснованиям;

	КонецЕсли;

	ТаблицаДокумента = Новый ТаблицаЗначений;
	ТаблицаДокумента.Колонки.Добавить("ВидЦенности");
	ТаблицаДокумента.Колонки.Добавить("СчетФактура");
	ТаблицаДокумента.Колонки.Добавить("Сумма");
	ТаблицаДокумента.Колонки.Добавить("СтавкаНДС");
	ТаблицаДокумента.Колонки.Добавить("НДС");
	ТаблицаДокумента.Колонки.Добавить("СчетУчетаНДС");
	ТаблицаДокумента.Колонки.Добавить("Событие");
	ТаблицаДокумента.Колонки.Добавить("ЭтоКомиссия", Новый ОписаниеТипов("Булево"));

	Если РеквизитыДокумента.ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда

		РеквизитыДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ДокументСсылка, "ВидОперации, СуммаДокумента, СуммаНДСДокумента, Дата, Организация");

		ТаблицаДокумента.Колонки.Добавить("Номенклатура");
		ТаблицаДокумента.Колонки.Добавить("Количество");
		ТаблицаДокумента.Колонки.Добавить("Цена");
		ТаблицаДокумента.Колонки.Добавить("СтранаПроисхождения");

		Авансы = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Авансы").Выгрузить();

		Если Не Авансы.Количество() Тогда

			СтавкаНДСОрганизации = УчетНДСВызовСервера.СтавкаНДСПоОрганизации(РеквизитыДокумента.Организация,
				РеквизитыДокумента.Дата);

			НоваяСтрока = ТаблицаДокумента.Добавить();
			НоваяСтрока.ВидЦенности  = Перечисления.ВидыЦенностей.АвансыПолученные;
			НоваяСтрока.СтавкаНДС    = СтавкаНДСОрганизации;
			НоваяСтрока.Сумма        = РеквизитыДокумента.СуммаДокумента - РеквизитыДокумента.СуммаНДСДокумента;
			НоваяСтрока.НДС          = РеквизитыДокумента.СуммаНДСДокумента;
			НоваяСтрока.Событие      = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету;
			НоваяСтрока.ЭтоКомиссия  = Истина;
			НоваяСтрока.Количество = 1;
			НоваяСтрока.Цена = НоваяСтрока.Сумма;

		Иначе

			Для Каждого СтрокаАванса Из Авансы Цикл

				НоваяСтрока = ТаблицаДокумента.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаАванса);
				НоваяСтрока.ВидЦенности  = Перечисления.ВидыЦенностей.АвансыПолученные;
				НоваяСтрока.СтавкаНДС    = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаАванса.СтавкаНДС,
					"ПеречислениеСтавкаНДС");
				;
				НоваяСтрока.Сумма        = СтрокаАванса.Сумма - СтрокаАванса.СуммаНДС;
				НоваяСтрока.НДС          = СтрокаАванса.СуммаНДС;
				НоваяСтрока.Событие      = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету;
				НоваяСтрока.ЭтоКомиссия  = Истина;
				НоваяСтрока.Количество = 1;
				НоваяСтрока.Цена = НоваяСтрока.Сумма;

				Если ЗначениеЗаполнено(НоваяСтрока.Номенклатура) Тогда
					НоваяСтрока.СтранаПроисхождения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
						НоваяСтрока.Номенклатура, "СтранаПроисхождения");
				КонецЕсли;

			КонецЦикла;

		КонецЕсли;

	КонецЕсли;

	Возврат ТаблицаДокумента;

КонецФункции

