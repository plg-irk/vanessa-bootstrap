Функция ПосредникиКорректировочныхСчетовФактур(ИсправляемыеСчетаФактуры)
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЖурналУчетаСчетовФактур.СчетФактура КАК СчетФактура,
			|	ЖурналУчетаСчетовФактур.Посредник КАК Посредник
			|ИЗ
			|	РегистрСведений.ЖурналУчетаСчетовФактур КАК ЖурналУчетаСчетовФактур
			|ГДЕ
			|	ЖурналУчетаСчетовФактур.СчетФактура В (&ИсправляемыеСчетаФактуры)";
	Запрос.УстановитьПараметр("ИсправляемыеСчетаФактуры", ИсправляемыеСчетаФактуры);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.СчетФактура, Выборка.Посредник);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

