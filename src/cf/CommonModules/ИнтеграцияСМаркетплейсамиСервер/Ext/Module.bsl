#Область ПрограммныйИнтерфейс

// Описывает структуру ошибки.
// Возвращаемое значение:
//  Структура - Структура для описания ошибки:
//  * КодОшибки - Строка - 
//  * ОписаниеОшибки - Строка -
//  * Детализация - Массив из Строка -
//  * НоменклатураНеНайдена - Массив из Структура -
//
Функция НоваяОшибка() Экспорт
    
    Результат = Новый Структура;
    Результат.Вставить( "КодОшибки", "" );
    Результат.Вставить( "ОписаниеОшибки", "" );
    Результат.Вставить( "Детализация", Новый Массив );
    Результат.Вставить( "НоменклатураНеНайдена", Новый Массив );
    
	Возврат Результат;
    
КонецФункции

// Проверка на использование интеграции с маркетплейсом Ozon.
// Возвращаемое значение:
//  Булево - Признак использования.
//
Функция ИспользуетсяИнтеграцияСМаркетплейсомOzon() Экспорт
	
	ТекстЗапроса = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ИспользуетсяИнтеграция
	|ИЗ
	|	Справочник.УчетныеЗаписиМаркетплейсов КАК УчетныеЗаписиМаркетплейсов
	|ГДЕ
	|	УчетныеЗаписиМаркетплейсов.ПометкаУдаления = ЛОЖЬ";
	Запрос = Новый Запрос(ТекстЗапроса);
	Если Запрос.Выполнить().Пустой() Тогда
		ИспользуетсяИнтеграция = Ложь;
	Иначе
		ИспользуетсяИнтеграция = Истина;
	КонецЕсли;
	
	Возврат ИспользуетсяИнтеграция;
КонецФункции

