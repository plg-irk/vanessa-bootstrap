		Элемент = Новый Структура( "Состояние1С, РезервироватьТовар",
		ЗапросВыборка.Состояние1С, ЗапросВыборка.РезервироватьТовар );
		 
		Результат.Вставить( ЗапросВыборка.СостояниеСайт, Элемент );
	КонецЦикла;
	
	Возврат Результат;
