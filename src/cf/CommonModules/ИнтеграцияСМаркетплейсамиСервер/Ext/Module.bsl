Функция ДоговорКонтрагентаПоНомеруИДатеНайти( Организация, Контрагент, НомерДоговора, ДатаДоговора ) Экспорт
    
    Результат = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
    
	ЗапросОбъект = Новый Запрос;

	ЗапросТекст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДоговорыКонтрагентов.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.ПометкаУдаления = ЛОЖЬ
	|	И ДоговорыКонтрагентов.Владелец = &Контрагент
	|	И ДоговорыКонтрагентов.Организация = ДоговорыКонтрагентов.Организация
	|	И ДоговорыКонтрагентов.ДатаДоговора = &ДатаДоговора
	|	И ДоговорыКонтрагентов.НомерДоговора = &НомерДоговора";

	ЗапросОбъект.Текст = ЗапросТекст;
	ЗапросОбъект.УстановитьПараметр( "Организация", Организация );
	ЗапросОбъект.УстановитьПараметр( "Контрагент", Контрагент );
	ЗапросОбъект.УстановитьПараметр( "НомерДоговора", НомерДоговора );
	ЗапросОбъект.УстановитьПараметр( "ДатаДоговора", ДатаДоговора );
	
	ЗапросВыборка = ЗапросОбъект.Выполнить().Выбрать();
	Если ЗапросВыборка.Следующий() Тогда
		Результат = ЗапросВыборка.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОтчетКомиссионераПоОтчетуОРеализацииТоваровЗаполнить( ОтчетОРеализацииТоваровДанные, ОбъектДляЗаполнения ) Экспорт

	Результат = Новый Структура;
    Результат.Вставить( "НоменклатураПоИдентификаторамНеСопоставлена", Неопределено );
    Результат.Вставить( "ОбъектДляЗаполненияИзменен", Истина );
    
	УчетнаяЗаписьМаркетплейса = ОтчетОРеализацииТоваровДанные.Данные.Шапка.УчетнаяЗаписьМаркетплейса;
	
	НоменклатураПоИдентификаторамНеСопоставлена =
	ОтчетОРеализацииТоваровДанные.Данные.НоменклатураПоИдентификаторамНеСопоставлена;
	Если НоменклатураПоИдентификаторамНеСопоставлена.Количество() > 0 Тогда
		
		Результат.НоменклатураПоИдентификаторамНеСопоставлена = НоменклатураПоИдентификаторамНеСопоставлена;
		
		ТекстСообщенияШаблон = 
		НСтр( "ru = 'Импорт отчета о реализации из Ozon: Не найдена номенклатура в базе 1С по данным Ozon: %1.
               |Необходимо выполнить сопоставление номенклатуры и повторить загрузку.'" );
		ТекстСообщения = СтрШаблон( ТекстСообщенияШаблон, НоменклатураПоИдентификаторамНеСопоставлена.Количество() );
		ОбщегоНазначения.СообщитьПользователю( ТекстСообщения );
		
		Если ОбменСВнешнимиСистемамиЛогирование.ЛогированиеВключено( УчетнаяЗаписьМаркетплейса ) Тогда
		
			ЛогКомментарий = ТекстСообщения + Символы.ПС + Символы.ПС
			+ НСтр( "ru = 'Таблица идентификаторов'" ) + ":" + Символы.ПС
			+ ОбменСВнешнимиСистемамиЛогирование.ОбъектПредставление( НоменклатураПоИдентификаторамНеСопоставлена );
			ОбменСВнешнимиСистемамиЛогирование.ЗаписатьВЛог( ЛогКомментарий, УчетнаяЗаписьМаркетплейса, Истина );
			
		КонецЕсли;
		
	КонецЕсли;
	
	Шапка = ОтчетОРеализацииТоваровДанные.Данные.Шапка;
	ТоварыПродажи = ОтчетОРеализацииТоваровДанные.Данные.ТоварыПродажи;
	ТоварыВозвраты = ОтчетОРеализацииТоваровДанные.Данные.ТоварыВозвраты;

	#Область Шапка

	ОбъектДляЗаполнения.Организация = Шапка.Организация;
	ОбъектДляЗаполнения.Контрагент = Шапка.Контрагент;
	ОбъектДляЗаполнения.Договор = Шапка.ДоговорКонтрагента;

	ОтчетОРеализацииТоваровЗаполнитьШапкуПоОрганизации( ОбъектДляЗаполнения, Шапка.Организация );

	ОбъектДляЗаполнения.Дата = Шапка.ДатаВходящегоДокумента;

	ОбъектДляЗаполнения.НомерВходящегоДокумента = Шапка.НомерВходящегоДокумента;
	ОбъектДляЗаполнения.ДатаВходящегоДокумента = Шапка.ДатаВходящегоДокумента;

	КомментарийШаблон = НСтр( "ru = 'Импорт из Ozon %1: %2 от %3'" );
	ОбъектДляЗаполнения.Комментарий = СтрШаблон( КомментарийШаблон, ТекущаяДатаСеанса(), 
	ОбъектДляЗаполнения.НомерВходящегоДокумента, 
	Формат( ОбъектДляЗаполнения.ДатаВходящегоДокумента, "ДФ=dd.MM.yyyy" ) )
	+ Символы.ПС + ОбъектДляЗаполнения.Комментарий;

	#КонецОбласти

	НастройкиЗаполненияНДС = НалогиУНФ.НастройкиНДСОрганизации( ОбъектДляЗаполнения.Организация, ,
	ОбъектДляЗаполнения.Дата );

	СпособРаспределенияАвто = Перечисления.СпособыЗачетаИРаспределенияПлатежей.Авто;


	// ТЧ Покупатели
	ОбъектДляЗаполнения.Покупатели.Очистить();
	ПокупателиСтрока = ОбъектДляЗаполнения.Покупатели.Добавить();
	ПокупателиСтрока.КлючСвязи = 1;
	ПокупателиСтрока.Покупатель = Шапка.Контрагент;

	#Область ТЧ_Запасы

	ОбъектДляЗаполнения.Запасы.Очистить();
	Для Каждого ТоварыПродажиСтрока Из ТоварыПродажи Цикл
		
		ЗапасыСтрока = ОбъектДляЗаполнения.Запасы.Добавить();
		
		ЗапасыСтрока.КлючСвязи = 1;
		
		ЗапасыСтрока.Номенклатура = ТоварыПродажиСтрока.Номенклатура;
		ЗапасыСтрока.Характеристика = ТоварыПродажиСтрока.Характеристика;
		
		ЗапасыСтрока.ЕдиницаИзмерения = ТоварыПродажиСтрока.ЕдиницаИзмерения;
		ЗапасыСтрока.СтавкаНДС = ТоварыПродажиСтрока.СтавкаНДС;
		
		ЗапасыСтрока.Количество = ?( ТоварыПродажиСтрока.Количество = 0, 1, ТоварыПродажиСтрока.Количество );
		ЗапасыСтрока.Сумма = ТоварыПродажиСтрока.Сумма + ТоварыПродажиСтрока.Доплата;
		ЗапасыСтрока.Цена = ЗапасыСтрока.Сумма/ЗапасыСтрока.Количество;
		
		ЗапасыСтрока.Всего = ЗапасыСтрока.Сумма;
		ЗапасыСтрока.СуммаВознаграждения = 0;
		ЗапасыСтрока.СпособРаспределения = СпособРаспределенияАвто;
		
	КонецЦикла;

	// ставка НДС
	НоменклатураВДокументахСервер.ОбновитьСтавкуНДСТабличнойЧасти( ОбъектДляЗаполнения,
	"Запасы", Истина, НастройкиЗаполненияНДС.ВидСтавкиНДС );

	#КонецОбласти

	ПокупателиСтрока.Всего = ОбъектДляЗаполнения.Запасы.Итог( "Всего" );

	// ТЧ Покупатели возвраты
	ОбъектДляЗаполнения.ПокупателиВозвраты.Очистить();
	ПокупателиВозвратыСтрока = ОбъектДляЗаполнения.ПокупателиВозвраты.Добавить();
	ПокупателиВозвратыСтрока.КлючСвязи = 1;
	ПокупателиВозвратыСтрока.Покупатель = Шапка.Контрагент;

	#Область ТЧ_ЗапасыВозвраты

	ОбъектДляЗаполнения.ЗапасыВозвраты.Очистить();
	Для Каждого ТоварыВозвратыСтрока Из ТоварыВозвраты Цикл
		
		ЗапасыВозвратыСтрока = ОбъектДляЗаполнения.ЗапасыВозвраты.Добавить();
		
		ЗапасыВозвратыСтрока.КлючСвязи = 1;
		
		ЗапасыВозвратыСтрока.Номенклатура = ТоварыВозвратыСтрока.Номенклатура;
		ЗапасыВозвратыСтрока.Характеристика = ТоварыВозвратыСтрока.Характеристика;
		
		ЗапасыВозвратыСтрока.ЕдиницаИзмерения = ТоварыВозвратыСтрока.ЕдиницаИзмерения;
		ЗапасыВозвратыСтрока.СтавкаНДС = ТоварыВозвратыСтрока.СтавкаНДС;
		
		ЗапасыВозвратыСтрока.Количество = ?( ТоварыВозвратыСтрока.Количество = 0, 1, ТоварыВозвратыСтрока.Количество );
		ЗапасыВозвратыСтрока.Сумма = ТоварыВозвратыСтрока.Сумма + ТоварыВозвратыСтрока.Доплата;
		ЗапасыВозвратыСтрока.Цена = ЗапасыВозвратыСтрока.Сумма/ЗапасыВозвратыСтрока.Количество;
		
		ЗапасыВозвратыСтрока.Всего = ЗапасыВозвратыСтрока.Сумма;
		ЗапасыВозвратыСтрока.СуммаВознаграждения = 0;
		ЗапасыВозвратыСтрока.СпособРаспределения = СпособРаспределенияАвто;
		
	КонецЦикла;

	// ставка НДС
	НоменклатураВДокументахСервер.ОбновитьСтавкуНДСТабличнойЧасти( ОбъектДляЗаполнения, 
	"ЗапасыВозвраты", Истина, НастройкиЗаполненияНДС.ВидСтавкиНДС );

	#КонецОбласти

	ПокупателиВозвратыСтрока.Всего = ОбъектДляЗаполнения.ЗапасыВозвраты.Итог( "Всего" );
	        
	Возврат Результат;
КонецФункции

Функция ОтчетОРеализацииТоваровПолучитьИОтчетКомиссионераЗаполнить( Параметры ) Экспорт

	Результат = Новый Структура;

	Если ТипЗнч( Параметры ) <> Тип( "Структура" ) Тогда
		Возврат Результат;
	КонецЕсли;

	// получить данные о продажах для заполнения объекта
	ОтчетОРеализацииТоваровДанные = ОтчетОРеализацииТоваровПолучить( Параметры );
	
	Если ЗначениеЗаполнено( ОтчетОРеализацииТоваровДанные.Ошибка.ОписаниеОшибки ) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОтчетКомиссионераПоОтчетуОРеализацииТоваровЗаполнить( ОтчетОРеализацииТоваровДанные, Параметры );
	
	Возврат Результат;
КонецФункции

#КонецОбласти
