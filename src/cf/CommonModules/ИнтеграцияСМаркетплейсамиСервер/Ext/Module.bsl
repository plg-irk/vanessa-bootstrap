Функция ОтчетОРеализацииТоваровЗаполнитьШапкуПоОрганизации( ОбъектДляЗаполнения, Организация )

	НалогиУНФ.ЗаполнитьНДСВключенВСтоимостьВДокументе( ОбъектДляЗаполнения );
	
	ЗначенияДляЗаполненияОбъекта = Новый Структура;
	//ЗначенияДляЗаполненияОбъекта.Вставить( "Номер", "" );
	
	ПодписьДокументовУНФ.ДополнитьПодписямиОрганизации( ЗначенияДляЗаполненияОбъекта, ОбъектДляЗаполнения );
	ЗаполнитьЗначенияСвойств( ОбъектДляЗаполнения, ЗначенияДляЗаполненияОбъекта );
	
	ВидСтавкиНДСПоУмолчанию = ОбщегоНазначения.ЗначениеРеквизитаОбъекта( Организация, "ВидСтавкиНДСПоУмолчанию" );
	СтавкаНДС = Справочники.СтавкиНДС.СтавкаНДС( ВидСтавкиНДСПоУмолчанию, ОбъектДляЗаполнения.Дата );
	ОбъектДляЗаполнения.СтавкаНДСВознаграждения = СтавкаНДС;
	
	Если Не ЗначениеЗаполнено( ОбъектДляЗаполнения.Договор ) Тогда
		ОбъектДляЗаполнения.Договор = 
		Справочники.ДоговорыКонтрагентов.ПоДокументуКонтрагентуОрганизацииИВидуОперации(
		ОбъектДляЗаполнения.Ссылка, ОбъектДляЗаполнения.Контрагент, ОбъектДляЗаполнения.Организация );
	КонецЕсли;
	
	Возврат Истина;
КонецФункции

Функция ОрганизацияПоИННКППНайти( ИНН, КПП = "" ) Экспорт
    
    Результат = Справочники.Организации.ПустаяСсылка();
    
	ЗапросОбъект = Новый Запрос;

	ЗапросТекст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Организации.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ИНН = &ИНН
	|	И Организации.ПометкаУдаления = ЛОЖЬ
	|	И &УсловиеКПП";

	Если ПустаяСтрока( КПП ) Тогда
		ЗапросТекст = СтрЗаменить( ЗапросТекст, "И &УсловиеКПП", "" );
	Иначе
		ЗапросОбъект.УстановитьПараметр( "КПП", КПП );
		ЗапросТекст = СтрЗаменить( ЗапросТекст, "И &УсловиеКПП", "И Организации.КПП = &КПП" );
	КонецЕсли;

	ЗапросОбъект.Текст = ЗапросТекст;
	ЗапросОбъект.УстановитьПараметр( "ИНН", ИНН );
	
	ЗапросВыборка = ЗапросОбъект.Выполнить().Выбрать();
	Если ЗапросВыборка.Следующий() Тогда
		Результат = ЗапросВыборка.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

