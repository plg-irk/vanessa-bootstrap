
#Область СлужебныйПрограммныйИнтерфейс

// см. Видеовстречи.СоздатьВидеовстречу
//
Функция СоздатьВидеовстречу(ОписаниеВидеовстречи) Экспорт
	
	Возврат ВидеовстречиВызовСервера.СоздатьВидеовстречу(ОписаниеВидеовстречи);
		
КонецФункции

// Открыть форму создания встречи.
// 
// Параметры:
//  Основание - ОпределяемыйТип.ОснованиеВидеовстречи
//  ПараметрыВыполненияКоманды - Неопределено - Параметры выполнения команды
//
Процедура ОткрытьФормуСозданияВстречи(Основание, ПараметрыВыполненияКоманды = Неопределено) Экспорт
	
	ПараметрыОткрытия = Новый Структура("Основание", Основание);
	ОткрытьФорму("Обработка.СозданиеВидеовстречи.Форма.Форма", ПараметрыОткрытия);
	
КонецПроцедуры

#КонецОбласти
