	Для НомерРяда = 1 По РеквизитыПалитры.КоличествоРядовНаСтранице Цикл
		СтрокаПлитки = СтрШаблон(СтрокаПлитки, СлужебнаяСтрокаРяда);
	КонецЦикла;
	
	Возврат СтрШаблон(СтрокаПлитки, "");
	
КонецФункции

Процедура ЗапуститьЧасы(Форма, НастройкиЧасов)
	
	Элементы = Форма.Элементы;
	ПоложениеЦентр = НСтр("ru = 'Центр'");
	ВыравниваниеАвто = НСтр("ru = 'Авто'");
	ВидимостьДекорации = Ложь;
	ВидимостьОтступа = Ложь;
	НуженРазделительКоманд = Ложь;
	
	Если Не Элементы.ПолеЧасов.Видимость = НастройкиЧасов.Использование Тогда
		Элементы.ПолеЧасов.Видимость = НастройкиЧасов.Использование;
	КонецЕсли;
	
	Если НастройкиЧасов.Использование Тогда
		
		Если Не Элементы.ПолеЧасов.Высота = НастройкиЧасов.Высота Тогда
			Элементы.ПолеЧасов.Высота = НастройкиЧасов.Высота;
		КонецЕсли;
		Если Не Элементы.ПолеЧасов.Ширина = НастройкиЧасов.Ширина Тогда
			Элементы.ПолеЧасов.Ширина = НастройкиЧасов.Ширина;
		КонецЕсли;
		ВидимостьДекорации = (НастройкиЧасов.ПоложениеЧасов = ПоложениеЦентр
			И НастройкиЧасов.ВыравниваниеПанели = ВыравниваниеАвто);
		ВидимостьОтступа = (НастройкиЧасов.ПоложениеЧасов = ПоложениеЦентр
			И Не НастройкиЧасов.ВыравниваниеПанели = ВыравниваниеАвто);
		НуженРазделительКоманд = Не (НастройкиЧасов.ПоложениеЧасов = ПоложениеЦентр
			Или НастройкиЧасов.ВыравниваниеПанели = ВыравниваниеАвто);
		
		Форма.КодЧасов = ПолучитьКодРеализацииЧасов(НастройкиЧасов);
		
	ИначеЕсли Не НастройкиЧасов.ВыравниваниеПанели = ВыравниваниеАвто Тогда
		НуженРазделительКоманд = Истина;
		Форма.КодЧасов = "";
	КонецЕсли;
	
	ЕстьТоварВКСО = (Форма.РежимКассыСамообслуживания И Не Форма.РежимРаботыСЧеком = Форма.РежимыРаботыСЧеком.ЧекПустой);
	РежимПлиткиКороткий = (Форма.РежимПлитки И Форма.ЗакрыватьПодборПриВыбореТовара);
	ИспользуетсяОтборВесовогоТовара = (Форма.РежимПлитки И Форма.ЕстьВесовойТоварВПлитке);
	ЕстьКомандыПравойЧасти = ((ЕстьТоварВКСО Или Не Форма.РежимКассыСамообслуживания) И Не РежимПлиткиКороткий);
	ВидимостьОтступаСлева = ИспользуетсяОтборВесовогоТовара Или (НуженРазделительКоманд И ЕстьКомандыПравойЧасти);
	Если Не Элементы.ДекорацияРастяжениеПослеЧасов.Видимость = ВидимостьДекорации Тогда
		Элементы.ДекорацияРастяжениеПослеЧасов.Видимость = ВидимостьДекорации;
	КонецЕсли;
	Если Не Элементы.ДекорацияОперацияОтступСправа.Видимость = ВидимостьОтступа Тогда
		Элементы.ДекорацияОперацияОтступСправа.Видимость = ВидимостьОтступа;
	КонецЕсли;
	Если Не Элементы.Декорация1.Видимость = ВидимостьОтступаСлева Тогда
		Элементы.Декорация1.Видимость = ВидимостьОтступаСлева;
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоПодтверждениеЧерезMAX(СтрокаВидаКонтроля, ИспользоватьПодтверждениеВозрастаЧерезMAX)
	
	Если НЕ ИспользоватьПодтверждениеВозрастаЧерезMAX Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПодтверждениеЧерезMAX = Ложь;
	ПараметрПодтверждениеЧерезMAX = ПредопределенноеЗначение(
		"Перечисление.ПараметрыКонтроляПродаж.ПодтверждениеЧерезMAX");
	
	Для каждого ПараметрКонтроля Из СтрокаВидаКонтроля.ПараметрыКонтроля Цикл
		Если ПараметрКонтроля.Параметр = ПараметрПодтверждениеЧерезMAX Тогда
			ПодтверждениеЧерезMAX = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПодтверждениеЧерезMAX;
	
КонецФункции

Процедура ОпределитьПозициюДобавленияОграниченияТипаПроверкаПокупателя(СтрокаОграничения,
	ЭтоПроверкаВозраста, ЗначениеВозраста, ПодтверждениеЧерезMAX,
	ПозицияДобавления, КоличествоОграничений, ИндексОграничения)
	
	// Пример сортировки:
	//  0)без параметра возраст(возраст = 0)
	//  1)проверка возраста сотрудником(возраст = 20)
	//  2)проверка возраста через MAX или сотрудника(возраст = 18)
	//  3)проверка возраста сотрудником(возраст = 18)
	//  4)проверка возраста сотрудником(возраст = 17)
	
	Если СтрокаОграничения.ВозрастКонтроля = 0 Тогда
		//без параметра возраст(возраст = 0)
		ИндексОграничения = ИндексОграничения + 1;
		ПозицияДобавления = ИндексОграничения;
	ИначеЕсли СтрокаОграничения.ВозрастКонтроля > ЗначениеВозраста Тогда
		Если Не ЭтоПроверкаВозраста Тогда
			ИндексОграничения = КоличествоОграничений;
		Иначе
			ИндексОграничения = ИндексОграничения + 1;
			ПозицияДобавления = ИндексОграничения;
		КонецЕсли;
	ИначеЕсли СтрокаОграничения.ВозрастКонтроля < ЗначениеВозраста Тогда
		ИндексОграничения = КоличествоОграничений;
	Иначе
		// Ветка условия для СтрокаОграничения.ВозрастКонтроля = ЗначениеВозраста
		Если ПодтверждениеЧерезMAX И Не СтрокаОграничения.ПодтверждениеЧерезMAX Тогда
			ИндексОграничения = КоличествоОграничений;
		Иначе
			ИндексОграничения = ИндексОграничения + 1;
			ПозицияДобавления = ИндексОграничения;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти