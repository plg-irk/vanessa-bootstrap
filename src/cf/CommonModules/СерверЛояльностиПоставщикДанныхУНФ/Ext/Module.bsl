Функция ТекстЗапросаКартЛояльностиПоНомеру()
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДисконтныеКарты.Ссылка КАК Карта,
	|	""КодКарты"" КАК ТипПоиска,
	|	ДисконтныеКарты.КартаНедействительна КАК КартаНедействительна,
	|	ДисконтныеКарты.ВладелецКарты КАК ВладелецКарты,
	|	ВидыДисконтныхКарт.ЭтоИменнаяКарта КАК ЭтоИменнаяКарта
	|ПОМЕСТИТЬ втДанныеОКартах
	|ИЗ
	|	Справочник.ДисконтныеКарты КАК ДисконтныеКарты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыДисконтныхКарт КАК ВидыДисконтныхКарт
	|		ПО ДисконтныеКарты.Владелец = ВидыДисконтныхКарт.Ссылка
	|ГДЕ
	|	НЕ ДисконтныеКарты.ПометкаУдаления
	|	И &ИдентификаторКартыКлиента В (ДисконтныеКарты.КодКартыШтрихкод, ДисконтныеКарты.КодКартыМагнитный)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ втДанныеОКартах.ВладелецКарты) КАК ВладелецКарты
	|ПОМЕСТИТЬ втДанныеВладельцах
	|ИЗ
	|	втДанныеОКартах КАК втДанныеОКартах
	|ГДЕ
	|	втДанныеОКартах.ЭтоИменнаяКарта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	втДанныеОКартах.ВладелецКарты КАК ВладелецКарты
	|ПОМЕСТИТЬ втСписокВладельцев
	|ИЗ
	|	втДанныеОКартах КАК втДанныеОКартах
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДисконтныеКарты.Ссылка КАК Карта,
	|	""КодКарты"" КАК ТипПоиска,
	|	ДисконтныеКарты.КартаНедействительна КАК КартаНедействительна,
	|	ВЫБОР
	|		КОГДА НЕ втДанныеОКартах.Карта ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК КартаПоиска
	|ПОМЕСТИТЬ КартыЛояльности
	|ИЗ
	|	втСписокВладельцев КАК втСписокВладельцев
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ДисконтныеКарты КАК ДисконтныеКарты
	|			ЛЕВОЕ СОЕДИНЕНИЕ втДанныеОКартах КАК втДанныеОКартах
	|			ПО ДисконтныеКарты.Ссылка = втДанныеОКартах.Карта
	|		ПО втСписокВладельцев.ВладелецКарты = ДисконтныеКарты.ВладелецКарты
	|		ЛЕВОЕ СОЕДИНЕНИЕ втДанныеВладельцах КАК втДанныеВладельцах
	|		ПО (ИСТИНА)
	|ГДЕ
	|	ЕСТЬNULL(втДанныеВладельцах.ВладелецКарты, 0) = 1
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втДанныеОКартах.Карта,
	|	втДанныеОКартах.ТипПоиска,
	|	втДанныеОКартах.КартаНедействительна,
	|	ИСТИНА
	|ИЗ
	|	втДанныеОКартах КАК втДанныеОКартах,
	|	втДанныеВладельцах КАК втДанныеВладельцах
	|ГДЕ
	|	ЕСТЬNULL(втДанныеВладельцах.ВладелецКарты, 0) = 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втДанныеОКартах.Карта,
	|	втДанныеОКартах.ТипПоиска,
	|	втДанныеОКартах.КартаНедействительна,
	|	ИСТИНА
	|ИЗ
	|	втДанныеОКартах КАК втДанныеОКартах,
	|	втДанныеВладельцах КАК втДанныеВладельцах
	|ГДЕ
	|	ЕСТЬNULL(втДанныеВладельцах.ВладелецКарты, 0) > 1"
	+ "
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|" + ОбщаяЧастьЗапросаКартЛояльности();
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаКартЛояльностиПоКонтактнойИнформации(СтрокаПоискаТелефона)
	
	ТекстЗапроса =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ДисконтныеКарты.Ссылка КАК Карта,
	|	""Телефон"" КАК ТипПоиска,
	|	ДисконтныеКарты.КартаНедействительна КАК КартаНедействительна,
	|	ИСТИНА КАК КартаПоиска
	|ПОМЕСТИТЬ КартыЛояльности
	|ИЗ
	|	Справочник.ДисконтныеКарты КАК ДисконтныеКарты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|		ПО ДисконтныеКарты.ВладелецКарты = КонтрагентыКонтактнаяИнформация.Ссылка
	|			И (НЕ ДисконтныеКарты.ПометкаУдаления)
	|			И (&ОбратныйНомер <> """")
	|			И (КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	|			И (НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления)
	|			И (КонтрагентыКонтактнаяИнформация.ОбратныйНомерТелефона = &ОбратныйНомер)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ДисконтныеКарты.Ссылка,
	|	""АдресЭП"",
	|	ДисконтныеКарты.КартаНедействительна,
	|	ИСТИНА
	|ИЗ
	|	Справочник.ДисконтныеКарты КАК ДисконтныеКарты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|		ПО ДисконтныеКарты.ВладелецКарты = КонтрагентыКонтактнаяИнформация.Ссылка
	|			И (НЕ ДисконтныеКарты.ПометкаУдаления)
	|			И (&АдресЭП <> """")
	|			И (КонтрагентыКонтактнаяИнформация.АдресЭП = &АдресЭП)
	|			И (НЕ КонтрагентыКонтактнаяИнформация.Ссылка.ПометкаУдаления)
	|			И (КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))"
	+ "
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|" + ОбщаяЧастьЗапросаКартЛояльности();
	
	Если ЗначениеЗаполнено(СтрокаПоискаТелефона) И Прав(СтрокаПоискаТелефона, 1) = "%" Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ОбратныйНомерТелефона = &ОбратныйНомер",
			"ОбратныйНомерТелефона ПОДОБНО &ОбратныйНомер");
	КонецЕсли;
	
	Возврат ТекстЗапроса;
	
КонецФункции

