		НоваяСтрока.ЕдиницаИзмерения = ?(ЕдиницаИзмерения.Пустая(), ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НоваяСтрока.Номенклатура, "ЕдиницаИзмерения"), ЕдиницаИзмерения);
