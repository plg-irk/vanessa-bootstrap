	Запрос.УстановитьПараметр("МаксимальныйПроцентНаценки", МаксимальныйПроцентНаценки);
	Запрос.УстановитьПараметр("ДатаСеанса", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ИспользуетсяОтбор", ИспользоватьОтборы);
	Запрос.УстановитьПараметр("ПараметрАвтоматическая", НСтр("ru = 'Автоматическая'"));
	Запрос.УстановитьПараметр("ПараметрНаДокумент", НСтр("ru = 'На документ'"));
	Запрос.УстановитьПараметр("ПараметрНаСтроку", НСтр("ru = 'На строку'"));
	Запрос.УстановитьПараметр("ПараметрРучная", НСтр("ru = 'Ручная'"));
	Запрос.УстановитьПараметр("ДопускаетсяПрименениеСкидок", ДопускаетсяПрименениеСкидок);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НоваяСтрока, "ИдентификаторСкидки") Тогда
			НоваяСтрока.ИдентификаторСкидки = Строка(Выборка.СкидкаНаценка.УникальныйИдентификатор());
		КонецЕсли;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Заполняет структуру ответа http-сервиса данными найденных карт
//
// Параметры:
//  ПараметрыМетода - Структура - структура, содержащая в себе параметры поиска карт:
//    * ИдентификаторКартыКлиента - Строка - код карты лояльности
//    * НомерТелефона - Строка - номер телефона или последняя часть номера телефона для поиска
//    * АдресЭП - Строка - адрес электронной почты владельца карты для поиска
//  СтруктураОтвета - Структура - Параметры ответа с сервера лояльности.
//
Процедура НайтиКартыЛояльности(ПараметрыМетода, СтруктураОтвета) Экспорт
	
	КартаКлиента = ПолучитьКартуПоУникальномуИдентификатору(ПараметрыМетода.УникальныйИдентификаторКарты);
	ВладелецКарты
		= ПолучитьВладельцаКартыПоУникальномуИдентификатору(ПараметрыМетода.УникальныйИдентификаторВладельцаКарты);
	Если ЗначениеЗаполнено(КартаКлиента) Тогда
		НайтиКартуЛояльностиПоСсылке(КартаКлиента, СтруктураОтвета);
	КонецЕсли;
	Если СтруктураОтвета.LoyaltyCardsList.Количество() = 0 И ЗначениеЗаполнено(ВладелецКарты) Тогда
		НайтиКартуЛояльностиПоВладельцу(ВладелецКарты, СтруктураОтвета);
	КонецЕсли;
	Если СтруктураОтвета.LoyaltyCardsList.Количество() = 0
			И ЗначениеЗаполнено(ПараметрыМетода.ИдентификаторКартыКлиента) Тогда
		НайтиКартуЛояльностиПоНомеруКарты(ПараметрыМетода.ИдентификаторКартыКлиента, СтруктураОтвета);
	КонецЕсли;
	Если СтруктураОтвета.LoyaltyCardsList.Количество() = 0
			И ЗначениеЗаполнено(ПараметрыМетода.ИдентификаторКартыКлиента) Тогда
		НайтиКартуЛояльностиПоФИО(ПараметрыМетода.ИдентификаторКартыКлиента, СтруктураОтвета);
	КонецЕсли;
	Если СтруктураОтвета.LoyaltyCardsList.Количество() = 0 Тогда
		СтрокаПоискаТелефона = ПодготовитьСтрокуПоискаПоНомеруТелефона(ПараметрыМетода.НомерТелефона);
		Если СтрокаПоискаТелефона <> "" Или ПараметрыМетода.АдресЭП <> "" Тогда
			НайтиКартыЛояльностиПоКонтактнойинформации(СтрокаПоискаТелефона, ПараметрыМетода.АдресЭП, СтруктураОтвета);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет карту лояльности клиента
//
// Параметры:
//  СтрокаУникальногоИдентификатора - Строка - уникальный идентификатор карты,
//  КартаКлиента - СправочникСсылка.ДисконтныеКарты - карта клиента
//
Процедура ПолучитьКартуКлиентаПоУникальномуИдентификатору(СтрокаУникальногоИдентификатора, КартаКлиента) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	КартаКлиента
		= Справочники.ДисконтныеКарты.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаУникальногоИдентификатора));
	
КонецПроцедуры

// Заполняет структуру ответа http-сервиса номерами и уникальным идентификатором дисконтной карты
//
// Параметры:
//  КартаКлиента - СправочникСсылка.ДисконтныеКарты - карта клиента
//  СтруктураОтвета - Структура - Параметры ответа с сервера лояльности.
//
Процедура ЗаполнитьСтруктуруОтветаНомерамиКарты(КартаКлиента, СтруктураОтвета) Экспорт

	НомераКарты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(КартаКлиента, "КодКартыШтрихкод,КодКартыМагнитный");
	
	СтруктураОтвета.CardRef = XMLСтрока(КартаКлиента);
	СтруктураОтвета.Barcode = НомераКарты.КодКартыШтрихкод;
	СтруктураОтвета.MagneticCode = НомераКарты.КодКартыМагнитный;
	
КонецПроцедуры

// Заполняет список видов карт
//
// Параметры:
//  Результат - Неопределено, ТаблицаЗначений - возвращаемое значение
//  ПараметрыРасчета - Структура - структура, содержащая в себе параметры настроек для работы с видами дисконтных карт
//
Процедура ЗаполнитьТаблицуВидовКарт(Результат, ПараметрыРасчета) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВидКарты = Константы.ВидКартыСерверЛояльности.Получить();
	Магазин = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
	Если НЕ ПараметрыРасчета = Неопределено
		И ЗначениеЗаполнено(ПараметрыРасчета.Магазин) Тогда
		Магазин = Справочники.СтруктурныеЕдиницы.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыРасчета.Магазин));
	КонецЕсли;

	Если ЗначениеЗаполнено(ВидКарты) Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтруктурныеЕдиницы.Ссылка КАК Склад,
		|	СтруктурныеЕдиницы.Родитель КАК ГруппаСкладов
		|ПОМЕСТИТЬ втСтруктурнаяЕдиница
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|ГДЕ
		|	СтруктурныеЕдиницы.Ссылка = &ТорговыйОбъект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВидыДисконтныхКарт.Ссылка КАК Ссылка,
		|	ВидыДисконтныхКарт.Наименование КАК Наименование,
		|	ВидыДисконтныхКарт.ЭтоИменнаяКарта КАК ЭтоИменнаяКарта,
		|	ВидыДисконтныхКарт.ГенерироватьНомер КАК ГенерироватьНомер,
		|	ВидыДисконтныхКарт.ПрисваиватьНомерКартыКНомеруТелефона КАК ПрисваиватьНомерКартыКНомеруТелефона
		|ПОМЕСТИТЬ втВидКарты
		|ИЗ
		|	Справочник.ВидыДисконтныхКарт КАК ВидыДисконтныхКарт
		|ГДЕ
		|	ВидыДисконтныхКарт.Ссылка = &ВидДисконтнойКарты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	втВидКарты.Ссылка КАК Ссылка,
		|	втВидКарты.Наименование КАК Наименование,
		|	втВидКарты.ЭтоИменнаяКарта КАК ЭтоИменнаяКарта,
		|	втВидКарты.ГенерироватьНомер КАК ГенерироватьНомер,
		|	втВидКарты.ПрисваиватьНомерКартыКНомеруТелефона КАК ПрисваиватьНомерКартыКНомеруТелефона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.ДлинаДиапазона, 0) КАК ДлинаДиапазона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.НачалоДиапазона, """") КАК НачалоДиапазона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.КонецДиапазона, """") КАК КонецДиапазона
		|ИЗ
		|	втВидКарты КАК втВидКарты,
		|	Справочник.ШаблоныГенерацииШтрихкодов.ТаблицаНастройкиШаблонов КАК ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСтруктурнаяЕдиница КАК втСтруктурнаяЕдиница
		|		ПО ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница = втСтруктурнаяЕдиница.Склад
		|ГДЕ
		|	НЕ ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов)
		|	И втВидКарты.ГенерироватьНомер
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	втВидКарты.Ссылка,
		|	втВидКарты.Наименование,
		|	втВидКарты.ЭтоИменнаяКарта,
		|	втВидКарты.ГенерироватьНомер,
		|	втВидКарты.ПрисваиватьНомерКартыКНомеруТелефона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.ДлинаДиапазона, 0),
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.НачалоДиапазона, """"),
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.КонецДиапазона, """")
		|ИЗ
		|	втВидКарты КАК втВидКарты,
		|	Справочник.ШаблоныГенерацииШтрихкодов.ТаблицаНастройкиШаблонов КАК ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСтруктурнаяЕдиница КАК втСтруктурнаяЕдиница
		|		ПО ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница = втСтруктурнаяЕдиница.ГруппаСкладов
		|ГДЕ
		|	ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов)
		|	И втВидКарты.ГенерироватьНомер
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	втВидКарты.Ссылка,
		|	втВидКарты.Наименование,
		|	втВидКарты.ЭтоИменнаяКарта,
		|	втВидКарты.ГенерироватьНомер,
		|	втВидКарты.ПрисваиватьНомерКартыКНомеруТелефона,
		|	0,
		|	"""",
		|	""""
		|ИЗ
		|	втВидКарты КАК втВидКарты
		|ГДЕ
		|	НЕ втВидКарты.ГенерироватьНомер";
		Запрос.УстановитьПараметр("ВидДисконтнойКарты", ВидКарты);
		Запрос.УстановитьПараметр("ТорговыйОбъект", Магазин);
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Если Выборка.Следующий() Тогда
				НоваяСтрока = Результат.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				НоваяСтрока.Идентификатор = Строка(Выборка.Ссылка.УникальныйИдентификатор());
				Если Выборка.ДлинаДиапазона > 0 Тогда
					Шаблон = НСтр("ru = '%1 - %2'");
					ПредставлениеШаблона = СтрШаблон(Шаблон, Строка(Выборка.НачалоДиапазона), Строка(Выборка.КонецДиапазона));
					НоваяСтрока.ПредставлениеШаблона = ПредставлениеШаблона;
				КонецЕсли;
			КонецЕсли;
		Иначе
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.Идентификатор		= Строка(ВидКарты.Ссылка.УникальныйИдентификатор());
			НоваяСтрока.Наименование		= ВидКарты.Наименование;
			НоваяСтрока.ЭтоИменнаяКарта		= ВидКарты.ЭтоИменнаяКарта;
		КонецЕсли;
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтруктурныеЕдиницы.Ссылка КАК Склад,
		|	СтруктурныеЕдиницы.Родитель КАК ГруппаСкладов
		|ПОМЕСТИТЬ втСтруктурнаяЕдиница
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
		|ГДЕ
		|	СтруктурныеЕдиницы.Ссылка = &ТорговыйОбъект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВидыДисконтныхКарт.Ссылка КАК Ссылка,
		|	ВидыДисконтныхКарт.Наименование КАК Наименование,
		|	ВидыДисконтныхКарт.ЭтоИменнаяКарта КАК ЭтоИменнаяКарта,
		|	ВидыДисконтныхКарт.ГенерироватьНомер КАК ГенерироватьНомер,
		|	ВидыДисконтныхКарт.ПрисваиватьНомерКартыКНомеруТелефона КАК ПрисваиватьНомерКартыКНомеруТелефона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.ДлинаДиапазона, 0) КАК ДлинаДиапазона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.НачалоДиапазона, """") КАК НачалоДиапазона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.КонецДиапазона, """") КАК КонецДиапазона
		|ИЗ
		|	Справочник.ВидыДисконтныхКарт КАК ВидыДисконтныхКарт
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШаблоныГенерацииШтрихкодов.ТаблицаНастройкиШаблонов КАК ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСтруктурнаяЕдиница КАК втСтруктурнаяЕдиница
		|			ПО ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница = втСтруктурнаяЕдиница.Склад
		|		ПО ВидыДисконтныхКарт.ШаблонГенерацииШтрихкода = ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.Ссылка
		|ГДЕ
		|	НЕ ВидыДисконтныхКарт.ПометкаУдаления
		|	И НЕ ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов)
		|	И ВидыДисконтныхКарт.ГенерироватьНомер
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВидыДисконтныхКарт.Ссылка,
		|	ВидыДисконтныхКарт.Наименование,
		|	ВидыДисконтныхКарт.ЭтоИменнаяКарта,
		|	ВидыДисконтныхКарт.ГенерироватьНомер,
		|	ВидыДисконтныхКарт.ПрисваиватьНомерКартыКНомеруТелефона,
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.ДлинаДиапазона, 0),
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.НачалоДиапазона, """"),
		|	ЕСТЬNULL(ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.КонецДиапазона, """")
		|ИЗ
		|	Справочник.ВидыДисконтныхКарт КАК ВидыДисконтныхКарт
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШаблоныГенерацииШтрихкодов.ТаблицаНастройкиШаблонов КАК ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСтруктурнаяЕдиница КАК втСтруктурнаяЕдиница
		|			ПО ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница = втСтруктурнаяЕдиница.ГруппаСкладов
		|		ПО ВидыДисконтныхКарт.ШаблонГенерацииШтрихкода = ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.Ссылка
		|ГДЕ
		|	НЕ ВидыДисконтныхКарт.ПометкаУдаления
		|	И ШаблоныГенерацииШтрихкодовТаблицаНастройкиШаблонов.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов)
		|	И ВидыДисконтныхКарт.ГенерироватьНомер
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВидыДисконтныхКарт.Ссылка,
		|	ВидыДисконтныхКарт.Наименование,
		|	ВидыДисконтныхКарт.ЭтоИменнаяКарта,
		|	ВидыДисконтныхКарт.ГенерироватьНомер,
		|	ВидыДисконтныхКарт.ПрисваиватьНомерКартыКНомеруТелефона,
		|	0,
		|	"""",
		|	""""
		|ИЗ
		|	Справочник.ВидыДисконтныхКарт КАК ВидыДисконтныхКарт
		|ГДЕ
		|	НЕ ВидыДисконтныхКарт.ПометкаУдаления
		|	И НЕ ВидыДисконтныхКарт.ГенерироватьНомер";
		
		Запрос.УстановитьПараметр("ТорговыйОбъект", Магазин);
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = Результат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.Идентификатор = Строка(Выборка.Ссылка.УникальныйИдентификатор());
			Если Выборка.ДлинаДиапазона > 0 Тогда
				Шаблон = НСтр("ru = '%1 - %2'");
				ПредставлениеШаблона = СтрШаблон(Шаблон, Строка(Выборка.НачалоДиапазона), Строка(Выборка.КонецДиапазона));
				НоваяСтрока.ПредставлениеШаблона = ПредставлениеШаблона;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Заполняет структуру ответа Сервера лояльности данными об оборотах продаж
//
// Параметры:
//  ДисконтнаяКарта - ОпределяемыйТип.КартаЛояльностиСерверЛояльности - 
//                    карта лояльности, по которой будут заполнены данные о бонусах
//  СтруктураОтвета - Структура - Параметры ответа с сервера лояльности.
//
Процедура ЗаполнитьДанныеОбОборотахПродаж(ДисконтнаяКарта, СтруктураОтвета) Экспорт
	
	ОборотыПродаж = ПолучитьОборотыПродажКлиента(ДисконтнаяКарта);
	СтруктураОтвета.SellCount = ОборотыПродаж;
	
КонецПроцедуры

// Десериализует параметры списка сотрудников, полученными в формате JSON
//
// Параметры:
//  ВходящиеДанные - Строка - содержит строковое значение тела запроса в формате JSON.
//  Результат - Структура - структура данных с параметрами расчета автоматических скидок:
//    * ВходныеПараметры				 - Структура
//    * Магазин							 - Неопределено
//
Процедура ДесериализоватьПараметрыРасчетаСписокСотрудников(ВходящиеДанные, Результат) Экспорт
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("ЕстьОшибки", Ложь);
	ПараметрыРасчета.Вставить("ОписаниеОшибки", "");
	
	Попытка
		
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(ВходящиеДанные);
		ВходящиеДанныеВJSON = ПрочитатьJSON(ЧтениеJSON, , "CurrentDate", ФорматДатыJSON.ISO);
		ЧтениеJSON.Закрыть();
		
		ВходныеПараметры = Новый Структура;
		ПараметрыРасчета.Вставить("Магазин", СерверЛояльностиПоставщикДанных.ПолучитьДесериализованноеСсылочноеЗначение(ВходящиеДанныеВJSON, "Store", "Справочники.СтруктурныеЕдиницы"));
		
	Исключение
		
		ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Ошибка преобразования тела запроса по причине: %1'"),
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ПараметрыРасчета.ЕстьОшибки = Истина;
		ПараметрыРасчета.ОписаниеОшибки = ОписаниеОшибки;
		
		ИмяСобытия = НСтр("ru = 'СерверЛояльности.ПолучитьСписокПродавцов'");
		ЗаписьЖурналаРегистрации(ИмяСобытия, , , , ОписаниеОшибки);
		
	КонецПопытки;
	
	Результат = ПараметрыРасчета;
	
КонецПроцедуры

// Заполняет список сотрудников
//
// Параметры:
//  Результат - Неопределено, ТаблицаЗначений - возвращаемое значение
//
Процедура ЗаполнитьТаблицуСотрудников(Результат) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Наименование КАК СотрудникПредставление,
	|	Сотрудники.ШтрихКод КАК КодСотрудника,
	|	Сотрудники.МагнитныйКод КАК МагнитныйКод
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.ЭтоГруппа";
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.СотрудникПредставление = Выборка.СотрудникПредставление;
			НоваяСтрока.КодСотрудника = ?(ПустаяСтрока(Выборка.КодСотрудника), Выборка.МагнитныйКод, Выборка.КодСотрудника);
			НоваяСтрока.ИдентификаторСотрудника = Строка(Выборка.Ссылка.УникальныйИдентификатор());
		КонецЦикла;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Получает данные серии по ГУИД
//
// Параметры:
//  ПараметрыМетода - Структура - структура, содержащая в себе параметры подарочного сертификата:
//   * ГУИДСерии - Строка - ГУИД серии.
//  СтруктураОтвета - Структура - структура, содержащая в себе параметры ответа:
//   * NameBatch - Строка - наименование серии.
//   * BatchUsed - Булево - Серия найдена.
//
Процедура ПолучитьДанныеСерии(ПараметрыМетода, СтруктураОтвета) Экспорт
	
	Если ТипЗнч(ПараметрыМетода) = Тип("Структура") И Не ПараметрыМетода.Свойство("ГУИДСерии") Тогда
		Возврат;
	КонецЕсли;
	
	СерияСсылка = Справочники.СерииНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(ПараметрыМетода.ГУИДСерии));
	
	Если ОбщегоНазначения.СсылкаСуществует(СерияСсылка) Тогда
		СтруктураОтвета.BatchUsed = Истина;
		СтруктураОтвета.NameBatch = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СерияСсылка,"Наименование");
	Иначе
		СтруктураОтвета.BatchUsed = Ложь;
	КонецЕсли;
КонецПроцедуры

// Десериализуются параметры серий, полученными в формате JSON
//
// Параметры:
//  ВходящиеДанные - Строка - содержит строковое значение тела запроса в формате JSON.
//  Результат - Структура - структура данных с параметрами серий:
//    * ВходныеПараметры				 - Структура
//    * Магазин							 - Неопределено
//
Процедура ДесериализоватьПараметрыСерий(ВходящиеДанные, Результат) Экспорт
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("ЕстьОшибки", Ложь);
	ПараметрыРасчета.Вставить("ОписаниеОшибки", "");
	
	Попытка
		
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(ВходящиеДанные);
		ВходящиеДанныеВJSON = ПрочитатьJSON(ЧтениеJSON, , "CurrentDate", ФорматДатыJSON.ISO);
		ЧтениеJSON.Закрыть();
		
		ВходныеПараметры = Новый Структура;
		ПараметрыРасчета.Вставить("Магазин", СерверЛояльностиПоставщикДанных.ПолучитьДесериализованноеСсылочноеЗначение(ВходящиеДанныеВJSON, "RetailStore", "Справочники.СтруктурныеЕдиницы"));
		ПараметрыРасчета.Вставить("Характеристика", СерверЛояльностиПоставщикДанных.ПолучитьДесериализованноеСсылочноеЗначение(ВходящиеДанныеВJSON, "Characteristic", "Справочники.ХарактеристикиНоменклатуры"));
		ПараметрыРасчета.Вставить("Номенклатура", СерверЛояльностиПоставщикДанных.ПолучитьДесериализованноеСсылочноеЗначение(ВходящиеДанныеВJSON, "Product", "Справочники.Номенклатура"));
		ПараметрыРасчета.Вставить("ЭтоПродажа", ВходящиеДанныеВJSON["TypeOperationSale"]);
		
	Исключение
		
		ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Ошибка преобразования тела запроса по причине: %1'"),
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ПараметрыРасчета.ЕстьОшибки = Истина;
		ПараметрыРасчета.ОписаниеОшибки = ОписаниеОшибки;
		
		ИмяСобытия = НСтр("ru = 'СерверЛояльности.ПолучитьСписокСерийПоТовару'");
		ЗаписьЖурналаРегистрации(ИмяСобытия, , , , ОписаниеОшибки);
		
	КонецПопытки;
	
	Результат = ПараметрыРасчета;
	
КонецПроцедуры

// Заполняет список серий
//
// Параметры:
//  Результат - ТаблицаЗначений - возвращаемое значение.
//  ПараметрыРасчета - Структура - параметры заполнения списка серий.
//
Процедура ЗаполнитьСписокСерий(Результат, ПараметрыРасчета) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	СтруктураСерий = Новый Структура("Номенклатура, Характеристика, Магазин, ЭтоПродажа");
	ЗаполнитьСтруктуруПараметровСерий(ПараметрыРасчета,СтруктураСерий);
	
	СтатусСерииПродан = Ложь;
	Если НЕ СтруктураСерий.ЭтоПродажа Тогда
		СтатусСерииПродан = Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка КАК Склад,
	|	СтруктурныеЕдиницы.ТипСтруктурнойЕдиницы КАК ТипСтруктурнойЕдиницы
	|ПОМЕСТИТЬ ДанныеТорговогоОбъекта
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|ГДЕ
	|	НЕ СтруктурныеЕдиницы.ПометкаУдаления
	|	И СтруктурныеЕдиницы.Ссылка = &ТорговыйОбъект
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка КАК Склад
	|ПОМЕСТИТЬ ТаблицаСклады
	|ИЗ
	|	ДанныеТорговогоОбъекта КАК ДанныеТорговогоОбъекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ПО ДанныеТорговогоОбъекта.Склад = СтруктурныеЕдиницы.Родитель
	|ГДЕ
	|	ДанныеТорговогоОбъекта.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.МагазинГруппаСкладов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СтруктурныеЕдиницы.Ссылка
	|ИЗ
	|	ДанныеТорговогоОбъекта КАК ДанныеТорговогоОбъекта
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктурныеЕдиницы КАК СтруктурныеЕдиницы
	|		ПО ДанныеТорговогоОбъекта.Склад = СтруктурныеЕдиницы.Ссылка
	|ГДЕ
	|	(ДанныеТорговогоОбъекта.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)
	|			ИЛИ ДанныеТорговогоОбъекта.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Розница))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СерииНоменклатурыОстатки.Серия КАК Серия
	|ПОМЕСТИТЬ втОстаткиСерий
	|ИЗ
	|	РегистрНакопления.СерииНоменклатуры.Остатки(
	|			&ТекущаяДата,
	|			Номенклатура = &Номенклатура
	|				И СтруктурнаяЕдиница В
	|					(ВЫБРАТЬ
	|						ТаблицаСклады.Склад КАК Склад
	|					ИЗ
	|						ТаблицаСклады КАК ТаблицаСклады)
	|				И Характеристика = &Характеристика) КАК СерииНоменклатурыОстатки
	|ГДЕ
	|	СерииНоменклатурыОстатки.КоличествоОстаток > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СерииНоменклатуры.Ссылка КАК Серия,
	|	СерииНоменклатуры.Наименование КАК Наименование
	|ИЗ
	|	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПолитикаУчетаСерий КАК втПолитикаУчетаСерий
	|			ПО Номенклатура.ПолитикаУчетаСерий = втПолитикаУчетаСерий.Ссылка
	|		ПО СерииНоменклатуры.Владелец = Номенклатура.Ссылка
	|ГДЕ
	|	НЕ СерииНоменклатуры.ПометкаУдаления
	|	И ВЫБОР
	|			КОГДА СерииНоменклатуры.ГоденДо = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ СерииНоменклатуры.ГоденДо > &ТекущаяДата
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА Номенклатура.ИспользоватьУникальныеСерии
	|				ТОГДА СерииНоменклатуры.Продан = &СтатусСерииПродан
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВЫБОР
	|			КОГДА Номенклатура.ТипНоменклатуры = &Запас
	|					И НЕ втПолитикаУчетаСерий.ТипПолитики = &ПолитикаУчетаСерий
	|				ТОГДА СерииНоменклатуры.Ссылка В
	|						(ВЫБРАТЬ
	|							втОстаткиСерий.Серия
	|						ИЗ
	|							втОстаткиСерий КАК втОстаткиСерий)
	|			ИНАЧЕ Номенклатура.Ссылка = &Номенклатура
	|		КОНЕЦ";
	Запрос.УстановитьПараметр("Номенклатура", СтруктураСерий.Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", СтруктураСерий.Характеристика);
	Запрос.УстановитьПараметр("ТорговыйОбъект", СтруктураСерий.Магазин);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("Запас", Перечисления.ТипыНоменклатуры.Запас);
	Запрос.УстановитьПараметр("СтатусСерииПродан", СтатусСерииПродан);
	Запрос.УстановитьПараметр("ПолитикаУчетаСерий", Перечисления.ТипыПолитикУказанияСерий.СправочноеУказаниеСерий);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.СерияПредставление = Выборка.Наименование;
			НоваяСтрока.ИдентификаторСерий = Строка(Выборка.Серия.УникальныйИдентификатор());
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет список скидок, применение которых зависит от вида оплаты
//
// Параметры:
//  Результат - Неопределено, ТаблицаЗначений - возвращаемое значение
//
Процедура ЗаполнитьТаблицуСкидокЗависящихОтВидаОплаты(Результат) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Результат = Неопределено Тогда
		ТипВидаОплаты = Новый ОписаниеТипов("ПеречислениеСсылка.ВидыОплатСерверЛояльности");
		ТипСкидки = Новый ОписаниеТипов("СправочникСсылка.АвтоматическиеСкидки");
		ТаблицаСкидокПоВидамОплаты = Новый ТаблицаЗначений();
		ТаблицаСкидокПоВидамОплаты.Колонки.Добавить("ВидОплаты", ТипВидаОплаты);
		ТаблицаСкидокПоВидамОплаты.Колонки.Добавить("СкидкаНаценка", ТипСкидки);
		Результат = ТаблицаСкидокПоВидамОплаты;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СправочникУсловияПредоставления.ВидОплаты КАК ВидОплаты,
	|	АвтоматическиеСкидкиУсловияПредоставления.Ссылка КАК СкидкаНаценка
	|ИЗ
	|	Справочник.УсловияПредоставленияСкидокНаценок КАК СправочникУсловияПредоставления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АвтоматическиеСкидки.УсловияПредоставления КАК АвтоматическиеСкидкиУсловияПредоставления
	|		ПО СправочникУсловияПредоставления.Ссылка = АвтоматическиеСкидкиУсловияПредоставления.УсловиеПредоставления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АвтоматическиеСкидки КАК АвтоматическиеСкидки
	|		ПО (АвтоматическиеСкидкиУсловияПредоставления.Ссылка = АвтоматическиеСкидки.Ссылка)
	|ГДЕ
	|	АвтоматическиеСкидки.Действует
	|	И СправочникУсловияПредоставления.УсловиеПредоставления = ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ЗаВидОплаты)";
	ВыборкаСкидок = Запрос.Выполнить().Выбрать();
	Пока ВыборкаСкидок.Следующий() Цикл
		НовСкидка = Результат.Добавить();
		ЗаполнитьЗначенияСвойств(НовСкидка, ВыборкаСкидок);		
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Проверяет заполненность бонусной программы в карте лояльности
//
// Параметры:
//  КартаКлиента - ОпределяемыйТип.КартаЛояльностиСерверЛояльности - 
//                    карта лояльности, по которой будут заполнены данные о бонусах.
//  ТребуетсяБлокировкаБонусов - Булево - признак необходимости блокировки бонусов
//
Процедура ПроверитьБонуснуюПрограмму(КартаКлиента, ТребуетсяБлокировкаБонусов) Экспорт
	
	ВидДисконтнойКарты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КартаКлиента, "Владелец");
	Если ЗначениеЗаполнено(ВидДисконтнойКарты) Тогда
		БонуснаяПрограмма = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДисконтнойКарты, "БонуснаяПрограмма");
		ТребуетсяБлокировкаБонусов = ЗначениеЗаполнено(БонуснаяПрограмма);
	КонецЕсли;
		
КонецПроцедуры

// Десериализует параметры запроса, полученными в формате JSON
//
// Параметры:
//  ВходящиеДанные	 - Строка	 - содержит строковое значение тела запроса в формате JSON.
//  ПараметрыРасчета		 - Структура - структура данных с десериализованными параметрами расчета автоматических скидок:
//  * ПодарочныйСертификат				- СправочникСсылка.Номенклатура
//  * НомерПодарочногоСертификата		- СправочникСсылка.СерииНоменклатуры
//  * Товары							- ТаблицаЗначений
//
Процедура ПараметрыМетодаИзЗапросаПолучитьДанныеПодарочногоСертификата(ВходящиеДанные, ПараметрыРасчета) Экспорт
	
	Попытка
		
		ЧтениеJSON = Новый ЧтениеJSON();
		ЧтениеJSON.УстановитьСтроку(ВходящиеДанные);
		ВходящиеДанныеВJSON = ПрочитатьJSON(ЧтениеJSON, , "CurrentDate", ФорматДатыJSON.ISO);
		ЧтениеJSON.Закрыть();
		ПараметрыРасчета.Вставить("ПодарочныйСертификат", Неопределено);
		ПараметрыРасчета.Вставить("СерийныйНомер", Неопределено);
		
		ВладелецСертификата = Справочники.Номенклатура.ПустаяСсылка();
		НомерПодарочногоСертификата = Справочники.СерииНоменклатуры.ПустаяСсылка();
		
		ВладелецСертификата = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанныеВJSON.GiftCardUID));
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	СерийныеНомера.Ссылка КАК СерийныйНомер,
		|	СерийныеНомера.Владелец КАК ПодарочныйСертификат
		|ИЗ
		|	Справочник.СерииНоменклатуры КАК СерийныеНомера
		|ГДЕ
		|	СерийныеНомера.Наименование = &НомерСертификата
		|	И НЕ СерийныеНомера.ПометкаУдаления
		|	И СерийныеНомера.Владелец = &ВладелецСертификата
		|	И &ИспользуетсяСерийныйНомер
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	"""",
		|	Номенклатура.Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ &ИспользуетсяСерийныйНомер
		|	И Номенклатура.Ссылка = &ВладелецСертификата
		|	И НЕ Номенклатура.ПометкаУдаления";
		
		Запрос.УстановитьПараметр("НомерСертификата", ВходящиеДанныеВJSON.GiftCardNumber);
		Запрос.УстановитьПараметр("ВладелецСертификата", ВладелецСертификата);
		Запрос.УстановитьПараметр("ИспользуетсяСерийныйНомер", НЕ ПустаяСтрока(ВходящиеДанныеВJSON.GiftCardNumber));
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			ЗаполнитьЗначенияСвойств(ПараметрыРасчета, Выборка);
		КонецЕсли;
		
		Если ПараметрыРасчета.ПодарочныйСертификат = Неопределено Тогда
			ПараметрыРасчета.ЕстьОшибки = Истина;
			ШаблонОшибки = НСтр("ru = 'Данные сертификата %1 не найдены'");
			ТекстСообщения = СтрШаблон(ШаблонОшибки, ВходящиеДанныеВJSON.GiftCardNumber);
			ПараметрыРасчета.ОписаниеОшибки = ТекстСообщения;
		Иначе
			ТаблицаТоваров = ПолучитьДесериализованнуюТаблицуТоваровПоПодарочнымСертификатам(ВходящиеДанныеВJSON);
			ПараметрыРасчета.Вставить("ТаблицаТоваров", ТаблицаТоваров);
		КонецЕсли;
		
		
	Исключение
		
		ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Ошибка преобразования тела запроса по причине: %1'"),
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ПараметрыРасчета.ЕстьОшибки = Истина;
		ПараметрыРасчета.ОписаниеОшибки = ОписаниеОшибки;
		ИмяСобытия = НСтр("ru = 'СерверЛояльности.ОбъединитьБонусныеКарты'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗаписьЖурналаРегистрации(ИмяСобытия, , , , ОписаниеОшибки);
		
	КонецПопытки;
	
КонецПроцедуры

// Производит разблокировку бонусов клиента при записи документа
//
// Параметры:
//  Источник - ДокументОбъект.ЧекККМ - документ-источник.
//  Отказ - Булево
//
Процедура РазблокироватьБонусыПодарочныеСертификатыПриЗаписи(Источник, Отказ) Экспорт
	
	Если Не Источник.Проведен Тогда
		Возврат;
	КонецЕсли;
	
	ИменаРеквизитов = Новый Структура;
	СерверЛояльностиПоставщикДанных.ЗаполнитьПустуюСтруктуруИменаРеквизитовМетаданных(ИменаРеквизитов);
	СерверЛояльностиПоставщикДанныхПереопределяемый.ЗаполнитьИменаРеквизитовПоставщикаДанных(ИменаРеквизитов);
	
	Если ИменаРеквизитов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	МетаданныеИсточника = Источник.Метаданные();
	
	Если МетаданныеИсточника.Реквизиты.Найти(ИменаРеквизитов.ИмяРеквизитаДисконтнаяКарта) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ДисконтнаяКарта = Источник[ИменаРеквизитов.ИмяРеквизитаДисконтнаяКарта];
	
	Если ЗначениеЗаполнено(ДисконтнаяКарта) Тогда
		РазблокироватьБонусы(ДисконтнаяКарта);
	КонецЕсли;
	
	Если МетаданныеИсточника.ТабличныеЧасти.Найти(ИменаРеквизитов.ИмяРеквизитаТаблицаПогашенияСертификатов) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТаблицаПогашенияСертификатов = Источник[ИменаРеквизитов.ИмяРеквизитаТаблицаПогашенияСертификатов];
	
	Для каждого СтрокаОплаты Из ТаблицаПогашенияСертификатов Цикл
		
		Если ЗначениеЗаполнено(СтрокаОплаты[ИменаРеквизитов.ИмяРеквизитаПодарочныйСертификат]) Тогда
			ДанныеСертификата = Новый Структура;
			ДанныеСертификата.Вставить("ПодарочныйСертификат", СтрокаОплаты[ИменаРеквизитов.ИмяРеквизитаПодарочныйСертификат]);
			ДанныеСертификата.Вставить("СерийныйНомер", СтрокаОплаты[ИменаРеквизитов.ИмяРеквизитаСерийныйНомер]);
			РазблокироватьПодарочныйСертификат(ДанныеСертификата);
		КонецЕсли;
		
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Выполняет корректировку регистра сведений "Бонусные баллы к списанию"
//
// Параметры:
//  Объект - ДокументОбъект.ОтчетОРозничныхПродажах
//
Процедура СкорректироватьРегистрСведенийБонусныеБаллыКСписанию(Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ОтчетОРозничныхПродажахБезналичнаяОплата.БонуснаяКарта КАК БонуснаяКарта,
	|	СУММА(ОтчетОРозничныхПродажахБезналичнаяОплата.СуммаБонусов) КАК СуммаБонусовКСписанию,
	|	СУММА(0) КАК СуммаБонусовКНачислению
	|ПОМЕСТИТЬ Вт_ТаблицаБонусов
	|ИЗ
	|	Документ.ОтчетОРозничныхПродажах.БезналичнаяОплата КАК ОтчетОРозничныхПродажахБезналичнаяОплата
	|ГДЕ
	|	ОтчетОРозничныхПродажахБезналичнаяОплата.ВидОплаты = ЗНАЧЕНИЕ(Перечисление.ВидыБезналичныхОплат.Бонусы)
	|	И ОтчетОРозничныхПродажахБезналичнаяОплата.Ссылка = &ДокументСсылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтчетОРозничныхПродажахБезналичнаяОплата.БонуснаяКарта
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОтчетОРозничныхПродажахБонусныеБаллыКНачислению.БонуснаяКарта,
	|	СУММА(0),
	|	СУММА(ОтчетОРозничныхПродажахБонусныеБаллыКНачислению.КоличествоБонусныхБаллов)
	|ИЗ
	|	Документ.ОтчетОРозничныхПродажах.БонусныеБаллыКНачислению КАК ОтчетОРозничныхПродажахБонусныеБаллыКНачислению
	|ГДЕ
	|	ОтчетОРозничныхПродажахБонусныеБаллыКНачислению.Ссылка = &ДокументСсылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ОтчетОРозничныхПродажахБонусныеБаллыКНачислению.БонуснаяКарта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Вт_ТаблицаБонусов.БонуснаяКарта КАК БонуснаяКарта,
	|	СУММА(Вт_ТаблицаБонусов.СуммаБонусовКСписанию) КАК СуммаБонусовКСписанию,
	|	СУММА(Вт_ТаблицаБонусов.СуммаБонусовКНачислению) КАК СуммаБонусовКНачислению,
	|	ЕСТЬNULL(БонусныеПрограммы.Ссылка, ЗНАЧЕНИЕ(Справочник.БонусныеПрограммы.ПустаяСсылка)) КАК БонуснаяПрограмма
	|ИЗ
	|	Вт_ТаблицаБонусов КАК Вт_ТаблицаБонусов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БонусныеПрограммы КАК БонусныеПрограммы
	|			ПРАВОЕ СОЕДИНЕНИЕ Справочник.ВидыДисконтныхКарт КАК ВидыДисконтныхКарт
	|			ПО ВидыДисконтныхКарт.БонуснаяПрограмма = БонусныеПрограммы.Ссылка
	|		ПО Вт_ТаблицаБонусов.БонуснаяКарта.Владелец = ВидыДисконтныхКарт.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Вт_ТаблицаБонусов.БонуснаяКарта,
	|	ЕСТЬNULL(БонусныеПрограммы.Ссылка, ЗНАЧЕНИЕ(Справочник.БонусныеПрограммы.ПустаяСсылка))";
	Запрос.УстановитьПараметр("ДокументСсылка", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Выборка.БонуснаяПрограмма = Справочники.БонусныеПрограммы.ПустаяСсылка() Тогда
				Продолжить;
			КонецЕсли;
			МенеджерЗаписи = РегистрыСведений.БонусныеБаллыКСписаниюИНачислению.СоздатьМенеджерЗаписи();
			
			МенеджерЗаписи.ДисконтнаяКарта = Выборка.БонуснаяКарта;
			МенеджерЗаписи.БонуснаяПрограммаЛояльности = Выборка.БонуснаяПрограмма;
			МенеджерЗаписи.Прочитать();
			
			СуммаСписанияЗапись = МенеджерЗаписи.КСписанию;
			СуммаНачисленияЗапись = МенеджерЗаписи.КНачислению;
			
			СуммаСписанияЗапись = Макс(СуммаСписанияЗапись - Выборка.СуммаБонусовКСписанию, 0);
			СуммаНачисленияЗапись = Макс(СуммаНачисленияЗапись - Выборка.СуммаБонусовКНачислению, 0);
			
			Если СуммаСписанияЗапись <= 0
				И СуммаНачисленияЗапись <= 0 Тогда
				МенеджерЗаписи.Удалить();
			Иначе
				МенеджерЗаписи.КСписанию = СуммаСписанияЗапись;
				МенеджерЗаписи.КНачислению = СуммаНачисленияЗапись;
				МенеджерЗаписи.Записать();
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Заполняет таблицу подарочных сертификатов данными по начислениям
//
// Параметры:
//  Объект							 - ДокументОбъект.ЧекККМ - документ корректировки регистров.
//  ТаблицаПодарочныхСертификатов	 - ТаблицаЗначений - Таблица списания и начисления подарочных сертификатов.
//
Процедура ЗаполнитьНачисленияПоПодарочнымСертификатам(Объект, ТаблицаПодарочныхСертификатов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЧекККМЗапасы.Номенклатура КАК ПодарочныйСертификат,
	|	ЧекККМСерииНоменклатуры.Серия КАК СерийныйНомер,
	|	ЕСТЬNULL(ЧекККМСерииНоменклатуры.Количество, ЧекККМЗапасы.Количество) КАК Количество,
	|	ЧекККМЗапасы.Цена КАК Цена
	|ИЗ
	|	Документ.ЧекККМ.Запасы КАК ЧекККМЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧекККМ.СерииНоменклатуры КАК ЧекККМСерииНоменклатуры
	|		ПО ЧекККМЗапасы.Ссылка = ЧекККМСерииНоменклатуры.Ссылка
	|			И ЧекККМЗапасы.КлючСвязи = ЧекККМСерииНоменклатуры.КлючСвязи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК втНоменклатура
	|		ПО ЧекККМЗапасы.Номенклатура = втНоменклатура.Ссылка
	|ГДЕ
	|	втНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.ПодарочныйСертификат)
	|	И ЧекККМЗапасы.Ссылка = &ДокументСсылка";
	Запрос.УстановитьПараметр("ДокументСсылка", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = ТаблицаПодарочныхСертификатов.Добавить();
			НоваяСтрока.ПодарочныйСертификат = Выборка.ПодарочныйСертификат;
			НоваяСтрока.СерийныйНомер = Выборка.СерийныйНомер;
			НоваяСтрока.КНачислению = Выборка.Количество * Выборка.Цена;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

// Устанавливает статус продан у серии подарочного сертификата
//
// Параметры:
//  ДанныеСертификата	 - Структура - данные найденного подарочный сертификат:
//  * СерийныйНомер		 - ОпределяемыйТип.СерийныйНомерСерверЛояльности
//  * ПодарочныйСертификат - ОпределяемыйТип.ПодарочныйСертификатСерверЛояльности
//  Продан				 - 	Булево - статус серийного номера подарочного сертификата.
//
Процедура УстановитьСтатусПодарочного(ДанныеСертификата, Продан) Экспорт
	
	Если Не ЗначениеЗаполнено(ДанныеСертификата.СерийныйНомер) Тогда
		Возврат;
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.СерииНоменклатуры");
		БлокировкаДанных.Заблокировать();
		
		СерияОбъект = ДанныеСертификата.СерийныйНомер.ПолучитьОбъект();
		СерияОбъект.Продан = Продан;
		СерияОбъект.Записать();
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Не удалось записать серию подарочного сертификата'",ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки);
	КонецПопытки;
	
КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает обороты продаж клиента
//
// Параметры: 
//  ДисконтнаяКарта - ОпределяемыйТип.КартаЛояльностиСерверЛояльности
//
// Возвращаемое значение:
//  Число - Оборот продаж клиента
//
Функция ПолучитьОборотыПродажКлиента(ДисконтнаяКарта)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПродажиПоДисконтнымКартамОбороты.СуммаОборот КАК СуммаОборот
	|ИЗ
	|	РегистрНакопления.ПродажиПоДисконтнымКартам.Обороты(, , , ДисконтнаяКарта = &ДисконтнаяКарта) КАК ПродажиПоДисконтнымКартамОбороты";
	Запрос.УстановитьПараметр("ДисконтнаяКарта", ДисконтнаяКарта);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.СуммаОборот;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Возвращает номер дисконтной карты
//
// Параметры:
//  ДисконтнаяКарта - ОпределяемыйТип.ДисконтнаяКартаРМК
//
// Возвращаемое значение:
//  Число
//
Функция ПолучитьНомерКарты(ДисконтнаяКарта)
	
	Если ДисконтнаяКарта.Владелец.ТипКарты = Перечисления.ТипыКарт.Штриховая Тогда
		НомерКарты = ДисконтнаяКарта.КодКартыШтрихкод;
	Иначе
		НомерКарты = ДисконтнаяКарта.КодКартыМагнитный;
	КонецЕсли;
	
	Возврат НомерКарты;
	
КонецФункции

// Возвращает аресЭП владельца карты
//
// Параметры:
//  ВладелецКарты - ОпределяемыйТип.КонтрагентСерверЛояльности
//
// Возвращаемое значение:
//  Строка
//
Функция ПолучитьАдресЭПВладельца(ВладелецКарты)
	
	АдресЭП = "";
	
	Если ВладелецКарты = Неопределено Тогда 
		Возврат АдресЭП
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВладелецКарты.АдресЭПДляПоиска) Тогда 
		АдресЭП = ВладелецКарты.АдресЭПДляПоиска;
	Иначе 
		Для Каждого СтрокаКИ Из ВладелецКарты.КонтактнаяИнформация Цикл
			Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда 
				АдресЭП = СтрокаКИ.Представление;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат АдресЭП;
	
КонецФункции

// Возвращает номер телефона владельца карты
//
// Параметры:
//  ВладелецКарты - ОпределяемыйТип.КонтрагентСерверЛояльности - владелец карты лояльности.
//
// Возвращаемое значение:
//  Строка
//
Функция ПолучитьНомерТелефонаВладельца(ВладелецКарты)
	
	НомерТелефона = "";
	
	Если ВладелецКарты = Неопределено Тогда
		Возврат НомерТелефона
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВладелецКарты.НомерТелефонаДляПоиска) Тогда 
		НомерТелефона = ВладелецКарты.НомерТелефонаДляПоиска;
	Иначе 
		Для Каждого СтрокаКИ Из ВладелецКарты.КонтактнаяИнформация Цикл
			Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда 
				НомерТелефона = СтрокаКИ.Представление;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат НомерТелефона;
	
КонецФункции

// Возвращает дату рождения владельца карты
//
// Параметры:
//  ВладелецКарты - ОпределяемыйТип.КонтрагентСерверЛояльности - владелец карты лояльности.
//
// Возвращаемое значение:
//  Дата
//
Функция ПолучитьДатуРожденияВладельца(ВладелецКарты)
	
	ДатаРождения = Дата(1,1,1);
	
	Если ВладелецКарты = Неопределено Тогда
		Возврат ДатаРождения
	КонецЕсли;
	
	ДатаРождения = ВладелецКарты.ДатаРождения;
	
	Возврат ДатаРождения;
	
КонецФункции

// Получает дисконтную карту
//
// Параметры:
//  ВходящиеДанные - Структура - структура, содержащая в себе параметры http-запроса.
//  ИмяПараметра - Строка - имя параметра, в котором содержится искомая дисконтная карта.
//  Результат - Неопределено, ОпределяемыйТип.ДисконтнаяКартаРМК - найденная дисконтная карта.
//
Процедура ПолучитьДисконтнуюКарту(ВходящиеДанные, ИмяПараметра, Результат)
	
	ДисконтнаяКарта = Справочники.ДисконтныеКарты.ПустаяСсылка();
	
	Если ТипЗнч(ВходящиеДанные) = Тип("Структура") И ВходящиеДанные.Свойство(ИмяПараметра) Тогда
		
		МассивНомеровКарт = ВходящиеДанные[ИмяПараметра];
		
		Если ЗначениеЗаполнено(МассивНомеровКарт) Тогда
			
			ПараметрыПоискаКарты = Новый Структура;
			ПараметрыПоискаКарты.Вставить("ИдентификаторКартыКлиента", МассивНомеровКарт[0]);
			ПараметрыПоискаКарты.Вставить("УникальныйИдентификаторКарты", МассивНомеровКарт[0]);
			ПараметрыПоискаКарты.Вставить("Клиент", "");
			ПараметрыПоискаКарты.Вставить("НомерТелефона", "");
			ПараметрыПоискаКарты.Вставить("АдресЭП", "");
			ПараметрыПоискаКарты.Вставить("ТребуетсяБлокировкаБонусов", Истина);
			
			НайденнаяКарта = Неопределено;
			НайтиКартуКлиента(ПараметрыПоискаКарты, НайденнаяКарта);
			Если НайденнаяКарта <> Неопределено Тогда
				ДисконтнаяКарта = НайденнаяКарта;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = ДисконтнаяКарта;
	
КонецПроцедуры 

// Ищет клиента по наименованию
// 
// Параметры:
//  ДанныеКарты - Структура - структура, содержащая данные карты лояльности:
//    * ИдентификаторКартыКлиента	 - Строка - код карты лояльности
//    * Клиент						 - Строка - ФИО владельца карты
//    * АдресЭП						 - Строка - адрес электронной почты владельца карты
//    * НомерТелефона				 - Строка - номер телефона владельца карты
//
// Возвращаемое значение:
//  Структура - результат поиска/ создания владельца карты:
//    * ВладелецКарты - ОпределяемыйТип.КонтрагентСерверЛояльности - владелец карты лояльности
//    * СтатусПолучения - Строка - возможные значения: "создан", "найден", "занят"-(найден похожий, но другой клиент)
//
Функция ПолучитьВладельцаКарты(ДанныеКарты) Экспорт
	
	РезультатФункции = Новый Структура("ВладелецКарты,СтатусПолучения", Неопределено, "");
	
	ОбратныйНомер = Справочники.Контрагенты.ПолучитьОбратныйНомерТелефонаБезКодаСтраны(ДанныеКарты.НомерТелефона);
	Запрос = Новый Запрос;
	Если ДанныеКарты.Свойство("Контрагент") И ЗначениеЗаполнено(ДанныеКарты.Контрагент) Тогда
		РезультатФункции.Вставить("ВладелецКарты", ДанныеКарты.Контрагент);
		РезультатФункции.Вставить("СтатусПолучения", "найден");
	ИначеЕсли ЗначениеЗаполнено(ОбратныйНомер) Тогда
		Запрос.Текст = ТекстЗапросаКлиентаПоОбратномуНомеруТелефона();
		Запрос.УстановитьПараметр("ОбратныйНомер", ОбратныйНомер);
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			РезультатФункции.Вставить("ВладелецКарты", Выборка.Клиент);
			РезультатФункции.Вставить("СтатусПолучения", "найден");
		КонецЕсли;
	ИначеЕсли ЗначениеЗаполнено(ДанныеКарты.АдресЭП) Тогда
		Запрос.Текст = ТекстЗапросаКлиентаСТелефономПоАдресуЭП();
		Запрос.УстановитьПараметр("АдресЭП", ДанныеКарты.АдресЭП);
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			РезультатФункции.Вставить("ВладелецКарты", Выборка.Клиент);
			Если Выборка.ОбратныйНомерТелефона = "" Тогда
				РезультатФункции.Вставить("СтатусПолучения", "найден");
			Иначе
				РезультатФункции.Вставить("СтатусПолучения", "занят");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если РезультатФункции.ВладелецКарты = Неопределено Тогда
		ВладелецКарты = СоздатьВладельцаКарты(ДанныеКарты);
		РезультатФункции.Вставить("ВладелецКарты", ВладелецКарты);
		РезультатФункции.Вставить("СтатусПолучения", "создан");
	КонецЕсли;
	
	Возврат РезультатФункции;
	
КонецФункции

Функция ПроверитьКорректностьВходящихДанных(ВходящиеДанные, ПараметрыРасчета)
	
	МассивПроверяемыхПараметров = МассивОбязательныхПараметровРасчетаСкидок();
	
	Для каждого ПроверяемыйПараметр Из МассивПроверяемыхПараметров Цикл
		Если Не ВходящиеДанные.Свойство(ПроверяемыйПараметр) Тогда 
			ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Во входящих параметрах не обнаружен параметр %1'"), ПроверяемыйПараметр);
			ПараметрыРасчета.ОписаниеОшибки = ПараметрыРасчета.ОписаниеОшибки + ОписаниеОшибки + ?(ПустаяСтрока(ПараметрыРасчета.ОписаниеОшибки), "", Символы.ПС);
			ПараметрыРасчета.ЕстьОшибки = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Не ПараметрыРасчета.ЕстьОшибки;
	
КонецФункции

Функция МассивОбязательныхПараметровРасчетаСкидок()
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить("ObjectTime");
	МассивПараметров.Добавить("LoyaltyCardsList");
	МассивПараметров.Добавить("Goods");
	МассивПараметров.Добавить("RetailStore");
	
	Возврат МассивПараметров;
	
КонецФункции

Функция ПолучитьДесериализованнуюТаблицуТоваров(ВходящиеДанные, ИмяПараметра)
	
	ОписаниеТиповЧисло = Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15,2));
	ОписаниеТиповЧислоДляКоличества = Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15,3));
	ОписаниеТиповСтрокаУИД = Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(36));
