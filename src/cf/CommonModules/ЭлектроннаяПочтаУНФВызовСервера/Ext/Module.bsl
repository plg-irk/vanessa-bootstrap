// Создание контакта на основании события.
// 
// Параметры:
//  Событие - ДокументСсылка.Событие - Событие
// 
// Возвращаемое значение:
//  Структура - Создание контакта на основании события:
//  * ПервыйУчастник - Неопределено, Структура - :
//   ** Контакт - Неопределено - 
//   ** КакСвязаться - Строка - 
//  * ВторойУчастник - Неопределено, Структура - :
//   ** Контакт - Неопределено - 
//   ** КакСвязаться - Строка - 
//  * ИсточникПривлечения - СправочникСсылка.ИсточникиПривлеченияПокупателей - 
//
Функция СозданиеКонтактаНаОснованииСобытия(Событие) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ПервыйУчастник");
	Результат.Вставить("ВторойУчастник");
	Результат.Вставить("ИсточникПривлечения", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Событие, "ИсточникПривлечения"));
	
	УчастникиСобытия = ПервыеУчастникиСобытия(Событие);
	Если УчастникиСобытия.Количество() > 0 Тогда
		Результат.ПервыйУчастник = УчастникиСобытия[0];
	КонецЕсли;
	Если УчастникиСобытия.Количество() > 1 Тогда
		Результат.ВторойУчастник = УчастникиСобытия[1];
	КонецЕсли;
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

Функция ВыгрузитьДанныеДляТехническойПоддержки(УникальныйИдентификатор, ПараметрыВыгрузки) Экспорт
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Электронная почта. Получение файлов для технической поддержки.'");
	
	ИмяМетода = "ЭлектроннаяПочтаУНФ.ВыгрузитьДанныеДляТехническойПоддержки";
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ИмяМетода, ПараметрыВыгрузки);
	
КонецФункции

