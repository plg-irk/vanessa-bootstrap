#Область ПрограммныйИнтерфейс

// Обновляет видимость и положение команд печати на форме.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения - Форма документа / Списка документов
Процедура ОбновитьСостояниеКомандПечатиПоУмолчанию(Форма) Экспорт
	
	ПечатныеФормы = Форма.СведенияОПечатныхФормах.Скопировать();
	Если ПечатныеФормы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ПерваяГруппа = Неопределено;
	ОтключитьКнопкиРекурсивно(Форма.Элементы.ПодменюПечать, ПерваяГруппа);

	Для Каждого ЭлементСпискаПечатныхФорм Из ПечатныеФормы Цикл
		ЭлементСпискаПечатныхФорм.Представление = Формат(ПечатныеФормы.Индекс(ЭлементСпискаПечатныхФорм), "ЧЦ=2; ЧВН=;");
	КонецЦикла;
	ПечатныеФормы.СортироватьПоПредставлению(НаправлениеСортировки.Убыв);
	
	Для Каждого ЭлементСпискаПечатныхФорм Из ПечатныеФормы Цикл
		Если ЭлементСпискаПечатныхФорм.Значение = "ПечатьПоУмолчаниюНастройка" Тогда
			Продолжить;
		КонецЕсли;
		
		Команда = Форма.Команды.Найти(ЭлементСпискаПечатныхФорм.Значение);
		Если Команда <> Неопределено Тогда
			Кнопка = Форма.Элементы.Найти(ЭлементСпискаПечатныхФорм.Значение);
			Если Кнопка <> Неопределено Тогда
				Кнопка.Видимость = ЭлементСпискаПечатныхФорм.Пометка;
				#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
					Форма.Элементы.Переместить(Кнопка, Кнопка.Родитель, ПерваяГруппа);
				#КонецЕсли
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ГруппаПечатьПоУмолчанию = Форма.Элементы.ПодменюПечатьПоУмолчанию;
	ГруппаПечатьПоУмолчанию.Видимость = Истина;
	КнопкаПечатьПоУмолчанию = Форма.Элементы.ПечатьПоУмолчаниюНастройка;
	КнопкаПечатьПоУмолчанию.Видимость = Истина;
	#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
		Форма.Элементы.Переместить(ГруппаПечатьПоУмолчанию, ГруппаПечатьПоУмолчанию.Родитель);
	#КонецЕсли
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОтключитьКнопкиРекурсивно(ПодменюПечать, ПерваяГруппа)
	Для Каждого ЭлементПечати Из ПодменюПечать.ПодчиненныеЭлементы Цикл
		Если ТипЗнч(ЭлементПечати) = Тип("ГруппаФормы") Тогда
			ОтключитьКнопкиРекурсивно(ЭлементПечати, ПерваяГруппа);
		Иначе
			ЭлементПечати.Видимость = Ложь;
			Если ПерваяГруппа = Неопределено Тогда
				ПерваяГруппа = ЭлементПечати.Родитель;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти