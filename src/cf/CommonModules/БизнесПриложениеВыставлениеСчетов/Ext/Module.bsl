	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ИспользоватьУпрощеннуюРаботуСПодписями", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "УпрощеннаяРаботаСоСтавкамиНДС", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ИспользоватьУпрощеннуюФормуКонтрагентов", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ИспользоватьУпрощеннуюФормуНоменклатуры", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ИспользоватьПростуюКоманднуюПанельВЗаказеПокупателя", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ИспользоватьПростуюКоманднуюПанельВОрганизациях", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ОтображатьПереходКСпискуНоменклатурыВГлавном", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ОтображатьПереходКСпискуПокупателей", Истина);
	ТарификацияБизнес.ДобавитьВозможностьВПриложение(ТаблицаВозможностей, "ФункциональнаяОпцияУчетЦенПродажи", Истина);
	
	Возврат ТаблицаВозможностей;
	
КонецФункции

Процедура УстановитьЗначенияНастроекПриложения()
	
	// Настройки необходимо выполнить только в том случае, если счета еще не выставлялись
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаказПокупателя.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказПокупателя";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	// Дата отгрузки по умолчанию будет равна дате документа
	НаборКонстант = Константы.СоздатьНабор("ВариантЗаполненияДатыОтгрузки,
		|ВидДнейРасчетаДатыОтгрузки, ПроизводственныйКалендарьРасчетаДатыОтгрузки, КоличествоДнейРасчетаДатыОтгрузки");
	
	НастройкиПоУмолчанию = Новый Структура;
	НастройкиПоУмолчанию.Вставить("ВариантЗаполненияДатыОтгрузки", Перечисления.ВариантыЗаполненияДатыОтгрузки.Прибавлять);
	НастройкиПоУмолчанию.Вставить("ВидДнейРасчетаДатыОтгрузки", Перечисления.ВидыДнейРасчетаДатыОтгрузки.Календарные);
	
	Календари = Справочники.ПроизводственныеКалендари.СписокПроизводственныхКалендарей();
	Если Календари.Количество() = 0 Тогда
		Календарь = Справочники.ПроизводственныеКалендари.ПустаяСсылка();
	Иначе
		Календарь = Календари[0];
	КонецЕсли;
	
	НастройкиПоУмолчанию.Вставить("ПроизводственныйКалендарьРасчетаДатыОтгрузки", Календарь);
	НастройкиПоУмолчанию.Вставить("КоличествоДнейРасчетаДатыОтгрузки", 0);
	
	ЗаполнитьЗначенияСвойств(НаборКонстант, НастройкиПоУмолчанию);
	НаборКонстант.Записать();
	
	// Дата оплаты по умолчанию будет равна дате документа
	НаборКонстант = Константы.СоздатьНабор("ВариантЗаполненияДатыОплаты,
		|ВидДнейРасчетаДатыОплаты, ПроизводственныйКалендарьРасчетаДатыОплаты, КоличествоДнейРасчетаДатыОплаты");
	
	НастройкиПоУмолчанию = Новый Структура;
	НастройкиПоУмолчанию.Вставить("ВариантЗаполненияДатыОплаты", Перечисления.ВариантыЗаполненияДатыОтгрузки.Прибавлять);
	НастройкиПоУмолчанию.Вставить("ВидДнейРасчетаДатыОплаты", Перечисления.ВидыДнейРасчетаДатыОтгрузки.Календарные);
	
	Календари = Справочники.ПроизводственныеКалендари.СписокПроизводственныхКалендарей();
	Если Календари.Количество() = 0 Тогда
		Календарь = Справочники.ПроизводственныеКалендари.ПустаяСсылка();
	Иначе
		Календарь = Календари[0];
	КонецЕсли;
	
	НастройкиПоУмолчанию.Вставить("ПроизводственныйКалендарьРасчетаДатыОплаты", Календарь);
	НастройкиПоУмолчанию.Вставить("КоличествоДнейРасчетаДатыОплаты", 0);
	
	ЗаполнитьЗначенияСвойств(НаборКонстант, НастройкиПоУмолчанию);
	НаборКонстант.Записать();
	
	// Выводим сумму без скидки в ПФ
	Константы.ВыводитьСуммуБезСкидки.Установить(Перечисления.ВариантыВыводаСуммыБезСкидки.Печатать);
	Константы.ПредставлениеКодовВПечатныхФормах.Установить(Перечисления.КодыНоменклатурыВДокументах.Артикул);
	Константы.ПредставлениеНомераДокументаБезПрефиксаИнформационнойБазы.Установить(Истина);
	Константы.ПредставлениеНомераДокументаБезПрефиксаОрганизации.Установить(Истина);
	Константы.ФункциональнаяОпцияКонтрольДоговоров.Установить(Перечисления.ВидыКонтроляДоговоровПриПроведении.НеКонтролировать);
	
	РегистрыСведений.СчетчикиПодсказок.ОтключитьСчетчик(Перечисления.ВидыПодсказок.РеквизитыОрганизацииДляПечати, 
														10, , Справочники.Организации.ОсновнаяОрганизация);
	
КонецПроцедуры

Процедура ВосстановитьНастройкиФормыЗаказа(Форма)
	
	ИмяКлючаОбъекта = ПолучитьКлючОбъектаЗаказ();
	
	ЭтоНовыйОбъект = Форма.Объект.Ссылка.Пустая();
	ЭтоКопирование = ЗначениеЗаполнено(Форма.Параметры.ЗначениеКопирования);
	
	Если ЭтоНовыйОбъект И НЕ ЭтоКопирование Тогда
		
		СохраненноеЗначение = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(ИмяКлючаОбъекта, ИмяКлючаОбъекта+"_НДСУпрощенно");
		Если ЗначениеЗаполнено(СохраненноеЗначение) Тогда
			Форма.НДСУпрощенно = СохраненноеЗначение;
		КонецЕсли;
		
		СохраненноеЗначение = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(ИмяКлючаОбъекта, ИмяКлючаОбъекта+"_ИспользоватьСкидки");
		Если СохраненноеЗначение  <> Неопределено Тогда
			Форма.Объект.ИспользоватьСкидкиВыставлениеСчетов = СохраненноеЗначение;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьКлючОбъектаЗаказ()
	
	Возврат "ЗаказПокупателяВыставлениеСчетов"; // Не локализуется
	
