
#Область ПрограммныйИнтерфейс

Процедура ВключитьВозможностиПриложения() Экспорт
	
	ВозможностиПодключаемогоПриложения = ФункциональныеВозможностиПриложения();
	
	Отбор = Новый Структура("ЗначениеПоУмолчанию", Истина);
	ВозможностиПриложенияВключенныеПоУмолчанию = ВозможностиПодключаемогоПриложения.НайтиСтроки(Отбор);
	
	Для каждого ВозможностьПриложения Из ВозможностиПриложенияВключенныеПоУмолчанию Цикл
		
		Попытка
			ИмяКонстанты = ВозможностьПриложения.Имя;
			Константы[ИмяКонстанты].Установить(Истина);
		Исключение
			
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			Комментарий = НСтр("ru='Ошибка попытки установки значения ""%1"" в константу ""%2"" по причине:
			|%3.'");
			Комментарий = СтрШаблон(Комментарий, Ложь, ИмяКонстанты, ТекстОшибки);
			ЗаписьЖурналаРегистрации(ТарификацияБизнес.ИмяЖР(), УровеньЖурналаРегистрации.Ошибка,,, Комментарий);
			ВызватьИсключение;
			
		КонецПопытки;
		
	КонецЦикла;
	
	Константы.ИспользоватьРаботуСПоискомКонтрагентовВСписке.Установить(Ложь);
	
	// Устанавливаем настройки ЕБВ, которые необходимы для комфортной работы с приложением
	УстановитьЗначенияНастроекПриложения();
	
КонецПроцедуры

Процедура ОтключитьВозможностиПриложения(ИсключаяВозможностиПриложений) Экспорт
	
	ОтключаемыеВозможности = ФункциональныеВозможностиПриложения();
	
	Для Каждого ОтключаемаяВозможность Из ОтключаемыеВозможности Цикл
		
		Если ИсключаяВозможностиПриложений.Найти(ОтключаемаяВозможность.Имя) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			ИмяКонстанты = ОтключаемаяВозможность.Имя;
			Константы[ИмяКонстанты].Установить(Ложь);
		Исключение
			
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			Комментарий = НСтр("ru='Ошибка попытки установки значения ""%1"" в константу ""%2"" по причине:
			|%3.'");
			Комментарий = СтрШаблон(Комментарий, Ложь, ИмяКонстанты, ТекстОшибки);
			ЗаписьЖурналаРегистрации(ТарификацияБизнес.ИмяЖР(), УровеньЖурналаРегистрации.Ошибка,,, Комментарий);
			ВызватьИсключение;
	
		КонецПопытки;
		
	КонецЦикла;
	
	// специфичная функциональность
	
КонецПроцедуры

// Процедура настраивает форму заказа покупателя для приложения "Выставление счетов"
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения	 - Форма документа "Заказ покупателя"
//
Процедура ПриСозданииНаСервереЗаказПокупателя(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	
	ИнтерфейсВыставленияСчетов = ПолучитьФункциональнуюОпцию("ИнтерфейсВыставлениеСчетов");
	
	// Специфические действия с элементами формы
	Если ИнтерфейсВыставленияСчетов Тогда
		
		// Прячем контекстные отчеты
		ПараметрыФОСвязанныхОтчетов = Новый Структура;
		ПараметрыФОСвязанныхОтчетов.Вставить("СвязанныеОтчеты", Неопределено);
		Форма.УстановитьПараметрыФункциональныхОпцийФормы(ПараметрыФОСвязанныхОтчетов);
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Страницы", "ОтображениеСтраниц", ОтображениеСтраницФормы.Нет);
		
		Для каждого Элемент Из Элементы.Запасы.ПодчиненныеЭлементы Цикл
			Элемент.ЦветФонаЗаголовка = ЦветаСтиля.ЦветФонаФормы;
			Если ТипЗнч(Элемент) = Тип("ГруппаФормы") Тогда
				Для каждого ЭлементГруппы Из Элемент.ПодчиненныеЭлементы Цикл
					ЭлементГруппы.ЦветФонаЗаголовка = ЦветаСтиля.ЦветФонаФормы;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		
		// Временный обход ошибки платформы для веб клиента
		Элементы.ЗапасыРучнаяСкидка.ЦветФонаЗаголовка = Новый Цвет();
		
		Если НЕ ЗначениеЗаполнено(Форма.Объект.Ссылка) Тогда
			Форма.АвтоЗаголовок = Ложь;
			Форма.Заголовок = НСтр("ru = 'Счет (создание)'");
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСодержимоеЗаказа", "ВертикальнаяПрокруткаПриСжатии", Истина);
		Форма.ВертикальнаяПрокрутка = ВертикальнаяПрокруткаФормы.ИспользоватьПриНеобходимости;
		
		ВосстановитьНастройкиФормыЗаказа(Форма);
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПраваяПанель", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПраваяПанельСвернуто", "Видимость", Ложь);
	
	Иначе
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПраваяПанель", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПраваяПанельСвернуто", "Видимость", Ложь);
		
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Шапка", "Видимость", НЕ ИнтерфейсВыставленияСчетов);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Подвал", "Видимость", НЕ ИнтерфейсВыставленияСчетов);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ШапкаВыставлениеСчетов", "Видимость", ИнтерфейсВыставленияСчетов);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПодвалВыставлениеСчетов", "Видимость", ИнтерфейсВыставленияСчетов);
	
	Если ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		
		// Шапка
		Элементы.ГруппаЗаголовокСчета.Ширина = 0;
		Элементы.НомерВыставлениеСчетов.ШрифтЗаголовка = Новый Шрифт;
		Элементы.НомерВыставлениеСчетов.РастягиватьПоГоризонтали = Ложь;
		
		Элементы.ДатаВыставлениеСчетов.ШрифтЗаголовка = Новый Шрифт;
		Элементы.ДатаВыставлениеСчетов.РастягиватьПоГоризонтали = Ложь;
		
		Элементы.ГруппаЛогоРеквизитыКод.Заголовок = НСтр("ru = 'Логотип, QR-код'");
		Элементы.Переместить(Элементы.РеквизитыШапкиВыставлениеСчетов, Элементы.ШапкаВыставлениеСчетов, Элементы.ГруппаЗаголовокСчета);
		
		Элементы.ДекорацияQRСБП.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
		Элементы.ДекорацияQR.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
		
		// Подвал
		Элементы.ПодвалВыставлениеСчетов.ВажностьПриОтображении = ВажностьПриОтображении.Высокая;
		Элементы.ПодвалВыставлениеСчетов.Заголовок = НСтр("ru = 'Подписи и условия'");
		Элементы.Переместить(Элементы.ГруппаИтогиВыставлениеСчетов, Элементы.СтраницаЗапасы);
		Элементы.ИтогиВыставлениеСчетов.ВажностьПриОтображении = ВажностьПриОтображении.Высокая;
		Элементы.СкидкиВыставлениеСчетов.ВажностьПриОтображении = ВажностьПриОтображении.Высокая;
		Элементы.ГруппаВсегоСуммаПрописью.Видимость = Ложь;
	
		// Правая панель
		Элементы.ГруппаЗаказИПраваяПанель.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		Элементы.ПраваяПанель.Заголовок = НСтр("ru = 'Действия с документом'");
		Элементы.ПраваяПанель.Ширина = 0;
		Элементы.ГруппаОтступ.Видимость = Ложь;
		
		// Прочее
		Элементы.ДекорацияРазделитель1.Видимость = Ложь;
		Элементы.ДекорацияРазделитель2.Видимость = Ложь;
		Элементы.ДекорацияРазделитель3.Видимость = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура настраивает форму списка заказов покупателей для приложения "Выставление счетов"
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения	 - Форма списка заказов покупателей
//
Процедура ПриСозданииНаСервереСписокЗаказПокупателя(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	
	Форма.ИнтерфейсВыставлениеСчетов = ПолучитьФункциональнуюОпцию("ИнтерфейсВыставлениеСчетов");
	Элементы.ГруппаАналитикаВыставлениеСчетов.Видимость = Форма.ИнтерфейсВыставлениеСчетов;
	Если Форма.ИнтерфейсВыставлениеСчетов Тогда
		Форма.Заголовок = НСтр("ru = 'Выставление счетов'");
		Элементы.ОтборЗавершениеЗаказа.ПодсказкаВвода = НСтр("ru = 'Завершение счета'");
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДатаОтгрузки", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ОтборСостояние", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СостояниеЗаказа", "Видимость", Ложь);
		ОбновитьАналитикуВСпискеЗаказов(Форма);
		Элементы.ЗагрузитьСтатусыОплатыВыставлениеСчетов.Видимость = ИнтеграцияСПлатежнымиСистемамиУНФ.ИнтеграцияДоступна();
	КонецЕсли;
	
КонецПроцедуры

// Процедура дополняет движения документа "Заказ покупателя" необходимыми данными для приложения "Выставление счетов"
//
// Параметры:
//  ДокументСсылкаЗаказПокупателя	 - ДокументСсылка.ЗаказПокупателя - Заказ, который проводится
//  СтруктураДополнительныеСвойства	 - Структура - Параметры проведения
//
Процедура ПриПроведенииЗаказаПокупателя(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства) Экспорт
	
	ОплаченВВыставленииСчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылкаЗаказПокупателя, "ОплаченВВыставленииСчетов");
	ОтгруженВВыставленииСчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылкаЗаказПокупателя, "ОтгруженВВыставленииСчетов");
	
	Если ОплаченВВыставленииСчетов Тогда
		
		ИсходнаяТаблица = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаОплатаСчетовИЗаказов.Скопировать();
		
		Для каждого ИсходнаяСтрока Из ИсходнаяТаблица Цикл
		
			НоваяСтрока = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаОплатаСчетовИЗаказов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсходнаяСтрока);
			НоваяСтрока.СуммаАванса = НоваяСтрока.Сумма;
			НоваяСтрока.Сумма = 0;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ОтгруженВВыставленииСчетов Тогда
		
		ИсходнаяТаблица = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаЗаказыПокупателей.Скопировать();
		
		Для каждого ИсходнаяСтрока Из ИсходнаяТаблица Цикл
		
			НоваяСтрока = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаЗаказыПокупателей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсходнаяСтрока);
			НоваяСтрока.ВидДвижения = ?(ИсходнаяСтрока.ВидДвижения = ВидДвиженияНакопления.Приход, ВидДвиженияНакопления.Расход, ВидДвиженияНакопления.Приход);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура обновляет аналитику в списке заказов покупателей
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения	 - Форма списка заказов покупателей
//
Процедура ОбновитьАналитикуВСпискеЗаказов(Форма) Экспорт
	
	ДанныеАналитики = Новый Структура;
	ДанныеАналитики.Вставить("ВсегоЗаказов", 0);
	ДанныеАналитики.Вставить("ОплаченоЗаказов", 0);
	ДанныеАналитики.Вставить("СуммаВсего", 0);
	ДанныеАналитики.Вставить("СуммаОплачено", 0);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПокупателя.Ссылка), 0) КАК ВсегоЗаказов,
		|	ЕСТЬNULL(СУММА(ВЫБОР
		|				КОГДА ЗаказПокупателя.СуммаДокумента <= ЕСТЬNULL(ФактОплатыЗаказов.СуммаАванса, 0) + ЕСТЬNULL(ФактОплатыЗаказов.СуммаОплаты, 0)
		|					ТОГДА 1
		|				ИНАЧЕ 0
		|			КОНЕЦ), 0) КАК ОплаченоЗаказов,
		|	ЕСТЬNULL(СУММА(ЗаказПокупателя.СуммаДокумента), 0) КАК СуммаВсего,
		|	ЕСТЬNULL(СУММА(ЕСТЬNULL(ФактОплатыЗаказов.СуммаАванса, 0) + ЕСТЬNULL(ФактОплатыЗаказов.СуммаОплаты, 0)), 0) КАК СуммаОплачено
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФактОплатыЗаказов КАК ФактОплатыЗаказов
		|		ПО (ФактОплатыЗаказов.СчетНаОплату = ЗаказПокупателя.Ссылка)
		|ГДЕ
		|	ЗаказПокупателя.Проведен
		|	И ЗаказПокупателя.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу)
		|	И ЗаказПокупателя.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд)
		|	И &Отборы";
	
	СтрокаОтборов = "";
	
	Если ЗначениеЗаполнено(Форма.ОтборПериод.ДатаНачала) 
		ИЛИ ЗначениеЗаполнено(Форма.ОтборПериод.ДатаОкончания) Тогда
		
		Если НЕ ЗначениеЗаполнено(Форма.ОтборПериод.ДатаОкончания) Тогда
			СтрокаОтборов = " И ЗаказПокупателя.Дата >= &ДатаНачала";
		Иначе
			СтрокаОтборов = " И ЗаказПокупателя.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
		КонецЕсли;
		
		Запрос.УстановитьПараметр("ДатаНачала", Форма.ОтборПериод.ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", Форма.ОтборПериод.ДатаОкончания);
		
	КонецЕсли;
	
	ШаблонОтбора = " И ЗаказПокупателя.ИмяПоляОтбора В (&ИмяПоляОтбора)";
	
	СписокОтборы = Новый Массив;
	СписокОтборы.Добавить("Организация");
	СписокОтборы.Добавить("Контрагент");
	СписокОтборы.Добавить("СостояниеЗаказа");
	СписокОтборы.Добавить("ВариантЗавершения");
	
	Для каждого СтрокаОтбора Из Форма.ДанныеМеток Цикл
		
		Если СписокОтборы.Найти(СтрокаОтбора.ИмяПоляОтбора) <> Неопределено Тогда
			СписокОтборы.Удалить(СписокОтборы.Найти(СтрокаОтбора.ИмяПоляОтбора));
			СтрокаОтборов = СтрокаОтборов + СтрЗаменить(ШаблонОтбора, "ИмяПоляОтбора", СтрокаОтбора.ИмяПоляОтбора);
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого СтрокаОтбора Из Форма.ДанныеМеток Цикл
		
		Если НЕ Запрос.Параметры.Свойство(СтрокаОтбора.ИмяПоляОтбора) Тогда
			 Запрос.УстановитьПараметр(СтрокаОтбора.ИмяПоляОтбора, Новый Массив);
		КонецЕсли;
		
		Запрос.Параметры[СтрокаОтбора.ИмяПоляОтбора].Добавить(СтрокаОтбора.Метка);
		
	КонецЦикла;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "И &Отборы", СтрокаОтборов);
	
	ВыборкаИтоги = Запрос.Выполнить().Выбрать();
	
	Если ВыборкаИтоги.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеАналитики, ВыборкаИтоги);
	КонецЕсли;
	
	МаксимальнаяДлинаИндикатора = 270;
	ШаблонСумма = НСтр("ru='%1 ₽'");
	ШаблонКоличество = НСтр("ru='%1 шт.'");
	
	Форма.Элементы.ДекорацияСуммаВсего.Заголовок = СтрШаблон(ШаблонСумма, ДанныеАналитики.СуммаВсего);
	Форма.Элементы.ДекорацияСуммаОплачено.Заголовок = СтрШаблон(ШаблонСумма, ДанныеАналитики.СуммаОплачено);
	Форма.Элементы.ДекорацияКоличествоВсего.Заголовок = СтрШаблон(ШаблонКоличество, ДанныеАналитики.ВсегоЗаказов);
	Форма.Элементы.ДекорацияКоличествоОплачено.Заголовок = СтрШаблон(ШаблонКоличество, ДанныеАналитики.ОплаченоЗаказов);
	
	Если ДанныеАналитики.СуммаВсего = 0 ИЛИ ДанныеАналитики.СуммаОплачено = 0 Тогда
		ДлинаИндикатораОплаты = 0;
	Иначе
		Доля = ДанныеАналитики.СуммаОплачено / ДанныеАналитики.СуммаВсего;
		ДлинаИндикатораОплаты = Цел(МаксимальнаяДлинаИндикатора * Доля);
		Если ДлинаИндикатораОплаты > МаксимальнаяДлинаИндикатора Тогда
			ДлинаИндикатораОплаты = МаксимальнаяДлинаИндикатора;
		КонецЕсли;
	КонецЕсли;
	
	ШаблонСостояниеОплатыЗаказов = ШаблонСостояниеОплатыЗаказов();
	ИмяВременногоФайлаSVG = ПолучитьИмяВременногоФайла();
	ФайлКартинки = Новый ЗаписьТекста(ИмяВременногоФайлаSVG);
	ФайлКартинки.Записать(СтрШаблон(ШаблонСостояниеОплатыЗаказов, ДлинаИндикатораОплаты));
	ФайлКартинки.Закрыть();
	ДвоичныеДанные = Новый ДвоичныеДанные(ИмяВременногоФайлаSVG);
	УдалитьФайлы(ИмяВременногоФайлаSVG);
	
	Форма.СостояниеОплатыЗаказов = ПоместитьВоВременноеХранилище(ДвоичныеДанные, Форма.УникальныйИдентификатор);
	
КонецПроцедуры

// Процедура настраивает отображения декорации QR-кода
//
// Параметры:
//  Форма	 - ФормаКлиентскогоПриложения	 - Форма документа заказ покупателя
//
Процедура НастроитьДекорациюQR(Форма) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИнтерфейсВыставлениеСчетов") Тогда
		Возврат;
	КонецЕсли;
	
	Элементы = Форма.Элементы;
	ВидКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Форма.Объект.Контрагент, "ВидКонтрагента");
	ЭтоЮрЛицо = ВидКонтрагента = Перечисления.ВидыКонтрагентов.ГосударственныйОрган
					ИЛИ ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо
					ИЛИ ВидКонтрагента = Перечисления.ВидыКонтрагентов.ИндивидуальныйПредприниматель;
					
	Если ЭтоЮрЛицо Тогда
		
		Элементы.ДекорацияQR.Видимость = Ложь;
		Элементы.ДекорацияQRСБП.Видимость = Ложь;
		
	Иначе
		
		Если ПереводыСБПc2b.ПереводыСБПДоступны() Тогда
			НастройкиПлатежныхСистем = РегистрыСведений.СоответствиеНастроекИнтеграцииРМК.НастройкиИнтеграции(Форма.Объект.Организация, Форма.Объект.СтруктурнаяЕдиницаПродажи);
			НастроенСБП = НастройкиПлатежныхСистем <> Неопределено;
		Иначе
			НастроенСБП = Ложь;
		КонецЕсли;
		
		Если НастроенСБП Тогда
			Элементы.ДекорацияQR.Видимость = Ложь;
			Элементы.ДекорацияQRСБП.Видимость = Истина;
		Иначе
			Элементы.ДекорацияQR.Видимость = Истина;
			Элементы.ДекорацияQRСБП.Видимость = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Сохраняет переданные настройки формы при их имзменении
//
// Параметры:
//  СтруктураНастроек - Структура - Настройки для сохранения.
//
Процедура СохранитьНастройкиФормы(СтруктураНастроек) Экспорт
	
	ИмяКлючаОбъекта = ПолучитьКлючОбъектаЗаказ();
	
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(ИмяКлючаОбъекта, ИмяКлючаОбъекта + СтруктураНастроек.Имя, СтруктураНастроек.Значение);
	
КонецПроцедуры

#КонецОбласти

