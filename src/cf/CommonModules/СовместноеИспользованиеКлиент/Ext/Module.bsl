#Область ПрограммныйИнтерфейс

// См. ОбщегоНазначенияКлиентПереопределяемый.ПриНачалеРаботыСистемы
//
Процедура ПриНачалеРаботыСистемы(Параметры) Экспорт
	
	#Если Не МобильныйКлиент Тогда
		Если ВнешнийСайтДоступен() Тогда
	        ОбработчикСобытия = Новый ОписаниеОповещения("ПриПолученииСообщенияОтВнешнегоСайта", СовместноеИспользованиеКлиент);
	        ОкноВнешнегоСайта.ПодключитьОбработчикСообщений(ОбработчикСобытия);
		КонецЕсли;
	#КонецЕсли
	
КонецПроцедуры

// См. обработчик ОбработкаПереходаПоНавигационнойСсылке модуля клиентского приложения.
//
Процедура ОбработкаПереходаПоНавигационнойСсылке(ДанныеПереходаПоНавигационнойСсылке, СтандартнаяОбработка) Экспорт
	
	Если Не СтандартнаяОбработка Тогда
		Возврат;
	КонецЕсли;
	
	ОтносительнаяСсылка = ДанныеПереходаПоНавигационнойСсылке.ОтносительнаяНавигационнаяСсылка;
	
	Для Каждого СоответствиеПрефикса Из СовместноеИспользованиеКлиентСервер.ПрефиксыНавигационныхСсылок() Цикл
		ПрефиксСсылки = СоответствиеПрефикса.Ключ;
		ИдентификаторПриложения = СоответствиеПрефикса.Значение;
		
		Если Не СтрНачинаетсяС(ОтносительнаяСсылка, ПрефиксСсылки) Тогда
			Продолжить;
		КонецЕсли;
		
		СтандартнаяОбработка = Ложь;
		
		НавигационнаяСсылкаДляПерехода = Сред(ОтносительнаяСсылка, СтрДлина(ПрефиксСсылки) + 1);
		
		Если ИдентификаторПриложения = СовместноеИспользованиеКлиентСервер.ИдентификаторПриложения() Тогда
			ПерейтиПоНавигационнойСсылке(НавигационнаяСсылкаДляПерехода);
		Иначе
			ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(
				НавигационнаяСсылкаДляПерехода,
				ИдентификаторПриложения);
		КонецЕсли;
		
		Прервать;
	КонецЦикла;
	
	Если СтандартнаяОбработка Тогда
		СовместноеИспользованиеКлиентПереопределяемый.ОбработкаПереходаПоНавигационнойСсылке(ДанныеПереходаПоНавигационнойСсылке, СтандартнаяОбработка);
	КонецЕсли;
	
КонецПроцедуры

// Обработчик действия, инициируемого нажатием гиперссылки или кнопки в панели отражения состояния отражения.
//
// Параметры:
//  ОписаниеКонтекста - см. СовместноеИспользованиеКлиентСервер.КонтекстОбработкиСобытия.
//  Источник - ДекорацияФормы - источник действия.
//  НавигационнаяСсылка - Строка - навигационная ссылка, по которой выполняется переход.
//  СтандартнаяОбработка - Булево - признак стандартной обработки перехода по навигационной ссылке.
//
Процедура ОбработкаНавигационнойСсылкиИнформационнойПанели(ОписаниеКонтекста, Источник, НавигационнаяСсылка, СтандартнаяОбработка) Экспорт
	
	ПараметрыСостоянияОтражения = ОписаниеКонтекста.Форма[ОписаниеКонтекста.ИмяРеквизита];
	
	ПсевдонимЭлемента = "";
	Для Каждого ЭлементСловаря Из ПараметрыСостоянияОтражения.ПсевдонимыЭлементов Цикл
		Если ЭлементСловаря.Значение = Источник.Имя Тогда
			ПсевдонимЭлемента = ЭлементСловаря.Ключ;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ОписаниеИсточника = Новый Структура;
	ОписаниеИсточника.Вставить("Псевдоним", ПсевдонимЭлемента);
	ОписаниеИсточника.Вставить("Элемент", Источник);
	
	СовместноеИспользованиеКлиентПереопределяемый.ОбработкаНавигационнойСсылкиИнформационнойПанели(
		ОписаниеКонтекста, ОписаниеИсточника, НавигационнаяСсылка, СтандартнаяОбработка);
	
КонецПроцедуры

// Открывает форму настроек отражения документов. После закрытия формы инициирует обновление
// состояния отражения документа, из которого был выполнен переход.
//
// Параметры:
//  ОписаниеКонтекста - см. СовместноеИспользованиеКлиентСервер.КонтекстОбработкиСобытия.
//  ДополнительныеПараметры - Произвольный, Неопределено - произвольные параметры, которые необходимо передать
//                            в обработчик завершения действия.
//
Процедура ПерейтиКНастройкамОтраженияИзФормыОбъекта(ОписаниеКонтекста, ДополнительныеПараметры = Неопределено) Экспорт
	
	ОткрытьФорму(
		"Обработка.ОтражениеДокументовВБухгалтерии.Форма.НастройкиРаздела",
		,
		ОписаниеКонтекста.Форма,
		,
		,
		,
		ОповещениеЗавершенияДействияИнформационнойПанели(ОписаниеКонтекста, ДополнительныеПараметры));
	
КонецПроцедуры

// Открывает форму журнала отражения документов и позиционируется на строке с документом.
// После закрытия журнала инициирует обновление состояния отражения документа, из которого был выполнен переход.
//
// Параметры:
//  ОписаниеКонтекста - см. СовместноеИспользованиеКлиентСервер.КонтекстОбработкиСобытия.
//  ДополнительныеПараметры - Произвольный, Неопределено - произвольные параметры, которые необходимо передать
//                            в обработчик завершения действия.
//
Процедура ПерейтиВЖурналОтраженияДокументовИзФормыОбъекта(ОписаниеКонтекста, ДополнительныеПараметры = Неопределено) Экспорт
	
	ОткрытьФорму("Обработка.ОтражениеДокументовВБухгалтерии.Форма.ЖурналОтраженияДокументов",
		Новый Структура("ПереходКДокументу", ОписаниеКонтекста.Объект.Ссылка),
		ОписаниеКонтекста.Форма,
		,
		,
		,
		ОповещениеЗавершенияДействияИнформационнойПанели(ОписаниеКонтекста, ДополнительныеПараметры));
	
КонецПроцедуры

// Начинает длительную операцию отражения документа в бухгалтерии.
//
// Параметры:
//  ОписаниеКонтекста - см. СовместноеИспользованиеКлиентСервер.КонтекстОбработкиСобытия.
//  ДополнительныеПараметры - Произвольный, Неопределено - произвольные параметры, которые необходимо передать
//                            в обработчик завершения действия.
//
Процедура НачатьОтражениеДокумента(ОписаниеКонтекста, ДополнительныеПараметры = Неопределено) Экспорт
	
	Оповещение = ОповещениеЗавершенияДействияИнформационнойПанели(ОписаниеКонтекста, ДополнительныеПараметры);
	
	ВыполнитьОбработкуОповещения(Оповещение, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ПерейтиПоНавигационнойСсылкеВнешнегоПриложения(НавигационнаяСсылка, ИдентификаторПриложения, ИспользоватьАльтернативнуюСсылку = Ложь) Экспорт
	
	АдресПриложения = АдресВнешнегоПриложения();
	
	Если ВнешнийСайтДоступен()
		И Не АдресПриложения.ВнешняяУчетнаяСистема Тогда
		ПерейтиПоНавигационнойСсылкеЧерезВнешнийСайт(НавигационнаяСсылка, ИдентификаторПриложения);
	Иначе
		Если Не ПустаяСтрока(АдресПриложения.АдресПриложения) Тогда
			ВнешняяСсылка = АдресПриложения.АдресПриложения;
			Если Не СтрЗаканчиваетсяНа(ВнешняяСсылка, "/") Тогда
				ВнешняяСсылка = ВнешняяСсылка + "/";
			КонецЕсли;
			
			Если ИспользоватьАльтернативнуюСсылку Тогда
				ВнешняяСсылка = ВнешняяСсылка + "#" + СовместноеИспользованиеВызовСервера.АльтернативнаяСсылкаДляПрямогоПерехода(НавигационнаяСсылка);
			Иначе
				ВнешняяСсылка = ВнешняяСсылка + "#" + НавигационнаяСсылка;
			КонецЕсли;
			
			ПерейтиПоНавигационнойСсылке(ВнешняяСсылка);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ОтправитьОповещениеВнешнемуПриложению(СвойстваОповещения, ИдентификаторПриложения, ВыполнитьПереход = Истина) Экспорт
	
	#Если Не МобильныйКлиент Тогда
		Если Не ВнешнийСайтДоступен() Тогда
			Возврат Ложь;
		КонецЕсли;
	
		Отправитель = СовместноеИспользованиеКлиентСерверПереопределяемый.ИдентификаторПриложения();
		
		ОписаниеДействия = ОписаниеДействияВоВнешнемПриложении("Оповестить");
		ОписаниеДействия.Параметры.Вставить("ИмяСобытия", СвойстваОповещения.ИмяСобытия);
		ОписаниеДействия.Параметры.Вставить("Параметры", СвойстваОповещения.Параметры);
		
		Сообщение = НовоеСообщениеВнешнемуСайту("ОтправитьСообщение", Отправитель, ИдентификаторПриложения, ОписаниеДействия);
		ОкноВнешнегоСайта.ОтправитьСообщение(Сообщение);
		
		Если ВыполнитьПереход Тогда
			Сообщение = НовоеСообщениеВнешнемуСайту("ВыполнитьПереход", Отправитель, ИдентификаторПриложения);
			ОкноВнешнегоСайта.ОтправитьСообщение(Сообщение);
		КонецЕсли;
		
		Возврат Истина;
	#КонецЕсли
	
	Возврат Ложь;
	
КонецФункции

Функция НовоеОповещениеВнешнегоПриложения(ИмяСобытия, Параметры) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяСобытия", ИмяСобытия);
	Результат.Вставить("Параметры", Параметры);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПриПолученииСообщенияОтВнешнегоСайта(Сообщение, ДополнительныеПараметры) Экспорт
	
	ОписаниеДействия = СовместноеИспользованиеВызовСервера.ОписаниеДействияОтВнешнегоПриложения(Сообщение.Данные);
	
	Если ОписаниеДействия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ОписаниеДействия.Действие = "ПерейтиПоНавигационнойСсылке" Тогда
		ПерейтиПоНавигационнойСсылке(ОписаниеДействия.ПараметрыДействия.Получить("НавигационнаяСсылка"));
	ИначеЕсли ОписаниеДействия.Действие = "Оповестить" Тогда
		Оповестить(
			ОписаниеДействия.ПараметрыДействия.Получить("ИмяСобытия"),
			ОписаниеДействия.ПараметрыДействия.Получить("Параметр"));
	КонецЕсли;
	
КонецПроцедуры

Функция ОповещениеЗавершенияДействияИнформационнойПанели(ОписаниеКонтекста, ДополнительныеПараметры)
	
	Возврат Новый ОписаниеОповещения(
		"Подключаемый_ИнформационнаяПанельСовместногоИспользованияЗавершениеДействия", ОписаниеКонтекста.Форма, ДополнительныеПараметры);
	
КонецФункции

#Область ВнешнийСайт

Функция ВнешнийСайтДоступен()
	
	#Если МобильныйКлиент Тогда
		Возврат Ложь;
	#Иначе
		Возврат ОкноВнешнегоСайта.Доступно;
	#КонецЕсли
	
КонецФункции

Процедура ПерейтиПоНавигационнойСсылкеЧерезВнешнийСайт(НавигационнаяСсылка, Получатель)
	
	#Если Не МобильныйКлиент Тогда
		Отправитель = СовместноеИспользованиеКлиентСерверПереопределяемый.ИдентификаторПриложения();
		
		ОписаниеДействия = ОписаниеДействияВоВнешнемПриложении("ПерейтиПоНавигационнойСсылке");
		ОписаниеДействия.Параметры.Вставить("НавигационнаяСсылка", НавигационнаяСсылка);
		
		Сообщение = НовоеСообщениеВнешнемуСайту("ОтправитьСообщение", Отправитель, Получатель, ОписаниеДействия);
		ОкноВнешнегоСайта.ОтправитьСообщение(Сообщение);
		
		Сообщение = НовоеСообщениеВнешнемуСайту("ВыполнитьПереход", Отправитель, Получатель);
		ОкноВнешнегоСайта.ОтправитьСообщение(Сообщение);
	#КонецЕсли
	
КонецПроцедуры

Функция НовоеСообщениеВнешнемуСайту(Действие, Отправитель, Получатель, ДополнительныеПараметры = Неопределено)
	
	ДанныеСообщения = СовместноеИспользованиеВызовСервера.ДанныеСообщенияВнешнемуСайту(Действие, Отправитель, Получатель, ДополнительныеПараметры);
	
	Возврат Новый СообщениеВнешнемуСайту(ДанныеСообщения);
	
КонецФункции

Функция ОписаниеДействияВоВнешнемПриложении(Действие)
	
	Описание = Новый Структура;
	Описание.Вставить("Действие", Действие);
	Описание.Вставить("Параметры", Новый Структура);
	
	Возврат Описание;
	
КонецФункции

#КонецОбласти

#Область ОсобенностиРеализации

Функция АдресВнешнегоПриложения()
	
	Возврат СовместноеИспользованиеВызовСервера.АдресВнешнегоПриложения();
	
КонецФункции

#КонецОбласти

#КонецОбласти