#Область ПрограммныйИнтерфейс

// Возвращает признак применения расходов на приобретение онлайн-кассы в качестве вычета на налоговый платеж
//
// Параметры:
//  Организация - СправочникСсылка.Организации
//  Период - Дата
//  ВидНалогообложения - ВидыНалоговУменьшаемыхНаРасходыККТ
//
// Возвращаемое значение:
//  Булево
//
Функция ВычетыПрименяются(Организация, Период, ВидНалогообложения) Экспорт
	
	Возврат Период >= ДатаНачалаПримененияВычета() 
			И Период <= ДатаОкончанияПримененияВычета() 
			И (ВидНалогообложения =
		ПредопределенноеЗначение("Перечисление.ВидыНалоговУменьшаемыхНаРасходыККТ.УСН"));
	
КонецФункции

Функция ДатаНачалаПримененияВычета() Экспорт
	
	Возврат Дата(2024, 1, 1);
	
КонецФункции

Функция ДатаОкончанияПримененияВычета() Экспорт
	
	Возврат Дата(2025, 12, 31, 23, 59, 59);
	
КонецФункции

#КонецОбласти