	ДанныеСмены = Новый Структура;
	ДанныеСмены.Вставить("СуммаПрихода", РезультатЗапроса[11].Выгрузить()[0].СуммаПрихода);
	ДанныеСмены.Вставить("СуммаВозвратПрихода", РезультатЗапроса[12].Выгрузить()[0].СуммаВозвратов);
	ДанныеСмены.Вставить("СуммаБезналичные", РезультатЗапроса[17].Выгрузить()[0].СуммаБезналичные);
	ДанныеСмены.Вставить("СуммаПредполата", РезультатЗапроса[18].Выгрузить()[0].СуммаПредоплата);
	ДанныеСмены.Вставить("СуммаРассрочки", РезультатЗапроса[15].Выгрузить()[0].СуммаПостоплаты);
	ДанныеСмены.Вставить("СуммаНаличными",  РезультатЗапроса[16].Выгрузить()[0].СуммаНаличными + (РезультатЗапроса[20].Выгрузить()[0].СуммаЧеков - РезультатЗапроса[19].Выгрузить()[0].СуммаБезналичныеПоЧекам - ДанныеСмены.СуммаПредполата));
	ДанныеСмены.Вставить("СуммаРасхода", РезультатЗапроса[13].Выгрузить()[0].СуммаРасхода);
	ДанныеСмены.Вставить("СуммаВозвратаРасхода", РезультатЗапроса[14].Выгрузить()[0].СуммаВозвратаРасхода);
	
	Возврат ДанныеСмены;
	
КонецФункции

Функция ЗаписатьДанныеДокументовЗаСмену(КассоваяСмена, МассивФискальныхДокументов) Экспорт
	
	ТаблицаФискальныхДокументовОФД = ТаблицаЗначенийПоЧекамОФД(МассивФискальныхДокументов);
	ДанныеФискальныхДокументовЗаСмену = ФискальныеДокументыЗаСмену(КассоваяСмена, ТаблицаФискальныхДокументовОФД);
	
	УстановитьПривилегированныйРежим(Истина); 
	НаборЗаписей = РегистрыСведений.СтатусыЧековВФНС.СоздатьНаборЗаписей();
	
	Для Каждого ФискальныйДокумент Из ДанныеФискальныхДокументовЗаСмену Цикл
		
		СтатусЧекаВФНС = СтатусЧекаВФНСПоКоду(ФискальныйДокумент.СтатусОтправкиВФНС) + "("+ ФискальныйДокумент.СтатусОтправкиВФНС + ")";
		Если ЗначениеЗаполнено(ФискальныйДокумент.ДатаЧекаОФД) Тогда
			Запись = НаборЗаписей.Добавить();
			Запись.ДокументОснование = ФискальныйДокумент.Ссылка;
			Запись.СтатусЧекаВФНС = СтатусЧекаВФНС;
			Запись.КодыОшибокФНС = ФискальныйДокумент.ОшибкиФНСПоЧеку;
		КонецЕсли;
		
	КонецЦикла;
	
	НаборЗаписей.Записать(Истина);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции

Функция СформироватьОтчетПоЧекам(Результат, КассаККМ) Экспорт
	
	СтатусКассовойСмены = КассовыеСмены.СтатусПоследнейСмены(КассаККМ.ПодключаемоеОборудование);
	Отбор = Новый Структура;
	Отбор.Вставить("НаименованиеПараметра", "РегистрационныйНомерККТ");
	ЗначениеПараметровККТ = КассаККМ.ПодключаемоеОборудование.ПараметрыРегистрации.НайтиСтроки(Отбор);
	Если ЗначениеПараметровККТ.Количество() > 0 Тогда
		РегистрационныйНомерККТ = ЗначениеПараметровККТ[0].ЗначениеПараметра;
	КонецЕсли;
	
	ТаблицаФискальныхДокументовОФД = ТаблицаЗначенийПоЧекамОФД(Результат.ДанныеПоЧекам);
	ДанныеФискальныхДокументовЗаСмену = ФискальныеДокументыЗаСмену(СтатусКассовойСмены.КассоваяСмена, ТаблицаФискальныхДокументовОФД);
	
	ОтчетЗаСмену = Новый ТабличныйДокумент;
	Макет = ЖурналыДокументов.ЧекиККМ.ПолучитьМакет("ПФ_MXL_ЧекиЗаСменуОФД");
	ОбластьОтступ = Макет.ПолучитьОбласть("Отступ");
	ОбластьРазделитель = Макет.ПолучитьОбласть("Разделитель");
	
	ОбластьОтборКасса = Макет.ПолучитьОбласть("ОтборКасса");
	ОбластьОтборКасса.Параметры.ОрганизацияПредставление = КассаККМ.Владелец.Наименование;
	ОбластьОтборКасса.Параметры.РегистрационныйНомерККТ = РегистрационныйНомерККТ;
	ОбластьОтборКасса.Параметры.НомерСмены = СтатусКассовойСмены.КассоваяСмена.НомерСменыККТ;
	ОбластьОтборКасса.Параметры.ДатаСмены = Формат(СтатусКассовойСмены.КассоваяСмена.ДатаСменыККТ, "ДЛФ=ДВ");
	ОбластьОтборКасса.Параметры.СтатусСмены = СтатусКассовойСмены.Активна;
	ОтчетЗаСмену.Вывести(ОбластьОтборКасса);
	
	ОбластьШапкаСумм = Макет.ПолучитьОбласть("ШапкаСумм");
	ОбластьШапкаСумм.Параметры.ПредставлениеВалюты = ОбщегоНазначенияРМК.ПредставлениеВалюты();
	ОтчетЗаСмену.Вывести(ОбластьШапкаСумм);
	
	ОбластьЧека = Макет.ПолучитьОбласть("СтрокаЧеков");
	ОбластьЧека.Параметры.ПараметрЧек = Нстр("ru='За смену'");
	ОбластьЧека.Параметры.СуммаПродаж = Результат.ДанныеСмены.СуммаПрихода + Результат.ДанныеСмены.СуммаВозвратаРасхода;
	ОбластьЧека.Параметры.СуммаВозвратов = Результат.ДанныеСмены.СуммаВозвратПрихода + Результат.ДанныеСмены.СуммаРасхода;
	ОбластьЧека.Параметры.СуммаВозвратовПоДаннымОФД = Результат.ДанныеСверки.СуммаВозвратаПрихода + Результат.ДанныеСверки.СуммаРасхода;
	ОбластьЧека.Параметры.СуммаПродажПоДаннымОФД = Результат.ДанныеСверки.СуммаПрихода + Результат.ДанныеСверки.СуммаВозвратаРасхода;
	Шрифт = Новый Шрифт(,10,Истина);
	ОбластьЧека.Области.СтрокаЧеков.Шрифт = Шрифт;
	ОтчетЗаСмену.Вывести(ОбластьЧека);
	ОбластьЧека.Очистить();
	
	Для Каждого ФискальныйДокумент ИЗ ДанныеФискальныхДокументовЗаСмену Цикл 
		
		ОбластьЧека = Макет.ПолучитьОбласть("СтрокаЧеков");
		Если ЗначениеЗаполнено(ФискальныйДокумент.СуммаДокумента) Тогда
			ОбластьЧека.Параметры.ПараметрЧек = ФискальныйДокумент.Ссылка;
			ОбластьЧека.Параметры.ПараметрРасшифровкиЧек = ФискальныйДокумент.Ссылка;
			Если ФискальныйДокумент.ЭтоВозврат Тогда
				ОбластьЧека.Параметры.СуммаВозвратов = ФискальныйДокумент.СуммаДокумента;
			Иначе
				ОбластьЧека.Параметры.СуммаПродаж = ФискальныйДокумент.СуммаДокумента;
			КонецЕсли;
		Иначе
			ОбластьЧека.Параметры.ПараметрЧек = ФискальныйДокумент.ДатаЧекаОФД;
			ОбластьЧека.Области.СтрокаЧеков.ЦветТекста = WebЦвета.Красный;
		КонецЕсли;
		Если ЗначениеЗаполнено(ФискальныйДокумент.СуммаДокументаОФД) Тогда
			Если ФискальныйДокумент.ЭтоВозвратОФД Тогда
				ОбластьЧека.Параметры.СуммаВозвратовПоДаннымОФД = ФискальныйДокумент.СуммаДокументаОФД;
			Иначе
				ОбластьЧека.Параметры.СуммаПродажПоДаннымОФД = ФискальныйДокумент.СуммаДокументаОФД;
			КонецЕсли;
		КонецЕсли; 
		СтатусЧекаВФНС = СтатусЧекаВФНСПоКоду(ФискальныйДокумент.СтатусОтправкиВФНС) + "("+ ФискальныйДокумент.СтатусОтправкиВФНС + ")";
		ОбластьЧека.Параметры.СтатусОтправкиВФНС = СтатусЧекаВФНС;
		ОтчетЗаСмену.Вывести(ОбластьЧека);
		ОбластьЧека.Очистить();
		
	КонецЦикла;
	
	ОтчетЗаСмену.ТолькоПросмотр = Истина;
	ОтчетЗаСмену.ОтображатьСетку = Ложь;
	
	Возврат ОтчетЗаСмену;

КонецФункции

Функция ТаблицаЗначенийПоЧекамОФД(МассивЧековОФД) Экспорт
	
	ТаблицаЗначенийПоЧекамОФД = Новый ТаблицаЗначений;
	ТаблицаЗначенийПоЧекамОФД.Колонки.Добавить("ЭтоВозврат", Новый ОписаниеТипов("Булево"));
	ТаблицаЗначенийПоЧекамОФД.Колонки.Добавить("ФискальныйНомерЧека", Новый ОписаниеТипов("Число"));
	ТаблицаЗначенийПоЧекамОФД.Колонки.Добавить("СуммаДокумента", Новый ОписаниеТипов("Число"));
	ТаблицаЗначенийПоЧекамОФД.Колонки.Добавить("ДатаЧека", Новый ОписаниеТипов("Дата"));
	ТаблицаЗначенийПоЧекамОФД.Колонки.Добавить("СтатусОтправкиВФНС", Новый ОписаниеТипов("Строка"));
	ТаблицаЗначенийПоЧекамОФД.Колонки.Добавить("ОшибкиФНСПоЧеку", Новый ОписаниеТипов("Строка"));
	
	Для Каждого ЭлементМассива Из МассивЧековОФД Цикл
		НоваяСтрока = ТаблицаЗначенийПоЧекамОФД.Добавить();
		Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
			НоваяСтрока[ЗначениеСтруктуры.Ключ] = ЗначениеСтруктуры.Значение;
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТаблицаЗначенийПоЧекамОФД; 
	
КонецФункции

Функция ФискальныеДокументыЗаСмену(КассоваяСмена, ТаблицаЧековОФД) Экспорт
	
	Запрос = Новый Запрос();
	
	Запрос.Текст = 	"ВЫБРАТЬ
	|	ТаблицаЧековОФД.ЭтоВозврат КАК ЭтоВозвратОФД,
	|	ТаблицаЧековОФД.ФискальныйНомерЧека КАК ФискальныйНомерЧека,
	|	ТаблицаЧековОФД.СуммаДокумента КАК СуммаДокументаОФД,
	|	ТаблицаЧековОФД.ДатаЧека КАК ДатаЧекаОФД,
	|	ТаблицаЧековОФД.СтатусОтправкиВФНС КАК СтатусОтправкиВФНС,
	|	ТаблицаЧековОФД.ОшибкиФНСПоЧеку КАК ОшибкиФНСПоЧеку
	|ПОМЕСТИТЬ ВременнаяТаблицаЧековОФД
	|ИЗ
	|	&ТаблицаЧековОФД КАК ТаблицаЧековОФД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка КАК Ссылка,
	|	ЧекККМ.СуммаДокумента КАК СуммаДокумента,
	|	ЛОЖЬ КАК ЭтоВозврат,
	|	ЧекККМ.НомерЧекаККМ КАК НомерЧекаККМ
	|ПОМЕСТИТЬ ТаблицаФискальныхДокументовСмены
	|ИЗ
	|	Документ.ЧекККМ КАК ЧекККМ
	|ГДЕ
	|	ЧекККМ.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМВозврат.Ссылка,
	|	ЧекККМВозврат.ЧекККМ.СуммаДокумента,
	|	ИСТИНА,
	|	ЧекККМВозврат.НомерЧекаККМ
	|ИЗ
	|	Документ.ЧекККМВозврат КАК ЧекККМВозврат
	|ГДЕ
	|	ЧекККМВозврат.ЧекККМ.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	АктВыполненныхРабот.Ссылка,
	|	АктВыполненныхРабот.СуммаДокумента,
	|	ЛОЖЬ,
	|	АктВыполненныхРабот.НомерЧекаККМ
	|ИЗ
	|	Документ.АктВыполненныхРабот КАК АктВыполненныхРабот
	|ГДЕ
	|	АктВыполненныхРабот.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОперацияПоПлатежнымКартам.Ссылка,
	|	ОперацияПоПлатежнымКартам.СуммаДокумента,
	|	ВЫБОР
	|		КОГДА ОперацияПоПлатежнымКартам.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЭквайринга.ВозвратОплатыПокупателю)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	ОперацияПоПлатежнымКартам.НомерЧекаККМ
	|ИЗ
	|	Документ.ОперацияПоПлатежнымКартам КАК ОперацияПоПлатежнымКартам
	|ГДЕ
	|	ОперацияПоПлатежнымКартам.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПередачаВА.Ссылка,
	|	ПередачаВА.СуммаДокумента,
	|	ЛОЖЬ,
	|	ПередачаВА.НомерЧекаККМ
	|ИЗ
	|	Документ.ПередачаВА КАК ПередачаВА
	|ГДЕ
	|	ПередачаВА.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПоступлениеВКассу.Ссылка,
	|	ПоступлениеВКассу.СуммаДокумента,
	|	ЛОЖЬ,
	|	ПоступлениеВКассу.НомерЧекаККМ
	|ИЗ
	|	Документ.ПоступлениеВКассу КАК ПоступлениеВКассу
	|ГДЕ
	|	ПоступлениеВКассу.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПоступлениеНаСчет.Ссылка,
	|	ПоступлениеНаСчет.СуммаДокумента,
	|	ЛОЖЬ,
	|	ПоступлениеНаСчет.НомерЧекаККМ
	|ИЗ
	|	Документ.ПоступлениеНаСчет КАК ПоступлениеНаСчет
	|ГДЕ
	|	ПоступлениеНаСчет.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриходнаяНакладная.Ссылка,
	|	ПриходнаяНакладная.СуммаДокумента,
	|	ИСТИНА,
	|	ПриходнаяНакладная.НомерЧекаККМ
	|ИЗ
	|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
	|ГДЕ
	|	ПриходнаяНакладная.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходСоСчета.Ссылка,
	|	РасходСоСчета.СуммаДокумента,
	|	ИСТИНА,
	|	РасходСоСчета.НомерЧекаККМ
	|ИЗ
	|	Документ.РасходСоСчета КАК РасходСоСчета
	|ГДЕ
	|	РасходСоСчета.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходИзКассы.Ссылка,
	|	РасходИзКассы.СуммаДокумента,
	|	ИСТИНА,
	|	РасходИзКассы.НомерЧекаККМ
	|ИЗ
	|	Документ.РасходИзКассы КАК РасходИзКассы
	|ГДЕ
	|	РасходИзКассы.НомерСменыККМ = &НомерСменыККМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка,
	|	РасходнаяНакладная.СуммаДокумента,
	|	ЛОЖЬ,
	|	РасходнаяНакладная.НомерЧекаККМ
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.НомерСменыККМ = &НомерСменыККМ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаФискальныхДокументовСмены.ЭтоВозврат КАК ЭтоВозврат,
	|	ТаблицаФискальныхДокументовСмены.СуммаДокумента КАК СуммаДокумента,
	|	ТаблицаФискальныхДокументовСмены.Ссылка КАК Ссылка,
	|	ВременнаяТаблицаЧековОФД.СтатусОтправкиВФНС КАК СтатусОтправкиВФНС,
	|	ВременнаяТаблицаЧековОФД.ЭтоВозвратОФД КАК ЭтоВозвратОФД,
	|	ВременнаяТаблицаЧековОФД.СуммаДокументаОФД КАК СуммаДокументаОФД,
	|	ВременнаяТаблицаЧековОФД.ДатаЧекаОФД КАК ДатаЧекаОФД,
	|	ВременнаяТаблицаЧековОФД.ОшибкиФНСПоЧеку КАК ОшибкиФНСПоЧеку
	|ИЗ
	|	ТаблицаФискальныхДокументовСмены КАК ТаблицаФискальныхДокументовСмены
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВременнаяТаблицаЧековОФД КАК ВременнаяТаблицаЧековОФД
	|		ПО (ВременнаяТаблицаЧековОФД.ФискальныйНомерЧека = ТаблицаФискальныхДокументовСмены.НомерЧекаККМ)";
	
	Запрос.УстановитьПараметр("ТаблицаЧековОФД", ТаблицаЧековОФД);
	Запрос.УстановитьПараметр("НомерСменыККМ", КассоваяСмена.НомерСменыККТ);
	РезультатЗапроса = Запрос.Выполнить(); 
	ФискальныеДокументыСмены = РезультатЗапроса.Выгрузить();
	
	Возврат ФискальныеДокументыСмены;
	
КонецФункции

Функция СтатусЧекаВФНСПоКоду(СтатусОтправкиВФНС) Экспорт
	
	СтатусЧекаВФНС = "Данные отсутствуют";
	
	Если СтатусОтправкиВФНС = "200" Тогда
		СтатусЧекаВФНС = "Принят";
	ИначеЕсли СтатусОтправкиВФНС = "202" Тогда
		СтатусЧекаВФНС = "Принят в мягкий карантин";
	ИначеЕсли СтатусОтправкиВФНС = "250" Тогда
		СтатусЧекаВФНС = "Принят с предупреждением";
	ИначеЕсли СтатусОтправкиВФНС = "400" Тогда
		СтатусЧекаВФНС = "Не принят";
	ИначеЕсли СтатусОтправкиВФНС = "600" Тогда
		СтатусЧекаВФНС = "Принят в жесткий карантин";
	Иначе
		СтатусЧекаВФНС = "Нет данных";
	КонецЕсли;
	
	Возврат СтатусЧекаВФНС;
	
КонецФункции

Функция СуммаПредоплатыПоДокументуРасчетов(ДокументОбъект)
	НужноАнализироватьДвижения = Ложь;
	Если ДокументОбъект.Ссылка.Метаданные().Реквизиты.Найти("СпособЗачетаПредоплаты") <> Неопределено Тогда
		НужноАнализироватьДвижения = (ДокументОбъект.СпособЗачетаПредоплаты = Перечисления.СпособыЗачетаИРаспределенияПлатежей.Авто);
	КонецЕсли;
	
	Если НужноАнализироватьДвижения Тогда
		ТаблицаПредоплата = ПолучитьТаблицаДокументаПоДвижениямПриОтгрузке(ДокументОбъект);
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументОбъект,"Предоплата") Тогда
		ПредоплатыКромеБонусов = Неопределено;
		Если ДокументОбъект.Предоплата.Количество() > 0
			И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументОбъект.Предоплата[0], "ОплатаБонусами")  Тогда
			// Оплаты бонусами уменьшают стоимость товара, их не нужно учитывать как оплату.
			ПредоплатыКромеБонусов = ДокументОбъект.Предоплата.НайтиСтроки(Новый Структура("ОплатаБонусами", Ложь));
		КонецЕсли; 
		ТаблицаПредоплата = ДокументОбъект.Предоплата.Выгрузить(ПредоплатыКромеБонусов);
	Иначе
		Возврат 0;
	КонецЕсли;
	
	// Добавим колонку оплаты сертификатом, если ее нет в документе
	Если ТаблицаПредоплата.Колонки.Найти("ОплатаСертификатом") = Неопределено Тогда
		ТаблицаПредоплата.Колонки.Добавить("ОплатаСертификатом");
		ТаблицаПредоплата.ЗаполнитьЗначения(Ложь, "ОплатаСертификатом");
	КонецЕсли;
	
	СуммаПлатежей = 0;
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.ПередачаТоваровМеждуОрганизациями") Тогда
		Контрагент = ДокументОбъект.КонтрагентПолучатель;
	Иначе
		Контрагент = ДокументОбъект.Контрагент;
	КонецЕсли;
	
	РеквизитыКонтрагента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Контрагент, "ВестиРасчетыПоДокументам");
	
	Для каждого ТекСтрока Из ТаблицаПредоплата Цикл
		Если ТекСтрока.ОплатаСертификатом Тогда
			СуммаПлатежей = СуммаПлатежей + ТекСтрока.СуммаПлатежа;
		Иначе
			Если РеквизитыКонтрагента.ВестиРасчетыПоДокументам Тогда
				Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ТекСтрока.Документ, "ВалютаДенежныхСредств") Тогда
					Валюта = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекСтрока.Документ, "ВалютаДенежныхСредств");
				ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ТекСтрока.Документ, "ВалютаДокумента") Тогда
					Валюта = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекСтрока.Документ, "ВалютаДокумента");
				КонецЕсли;
				Если Валюта <> Неопределено
					И Валюта <> УправлениеНебольшойФирмойПовтИсп.ПолучитьНациональнуюВалюту() Тогда
					ВызватьИсключение НСтр("ru='Чек не напечатан. В документе расчетов обнаружена валюта, отличная от национальной.'");
				КонецЕсли;
			КонецЕсли;
			СуммаПлатежей = СуммаПлатежей + ТекСтрока.СуммаПлатежа;
		КонецЕсли;
	КонецЦикла;
	Возврат СуммаПлатежей;
КонецФункции



#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СтруктураДляДополненияТоварами()
	
