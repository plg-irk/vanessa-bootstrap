// Возвращает массив настроек, которые необходимо хранить в разрезе по организациям.
// 
// Возвращаемое значение:
//  Массив из ПланВидовХарактеристикСсылка - Настройки по организациям
Функция НастройкиПоОрганизациям() Экспорт

	Результат = Новый Массив;
	Результат.Добавить(ПодписиИДругиеРеквизитыПечати);
	Результат.Добавить(ОрганизацияОплачиваетПеревозку);
	Результат.Добавить(ОсновнойАвтомобиль);
	Результат.Добавить(ОсновнойВодитель);
	Результат.Добавить(ОсновнойПеревозчик);
	Результат.Добавить(ПодписьСтаршегоКассира);
	Результат.Добавить(ПодписьКассира);
	Результат.Добавить(ПодписьРуководителя);
	Результат.Добавить(ПодписьГлавногоБухгалтера);
	Результат.Добавить(ПодписьБухгалтера);
	Результат.Добавить(ПодписьМол);
	Результат.Добавить(РекламныйБлокСчетаЗаказа);
	Результат.Добавить(УсловияГарантии);
	Результат.Добавить(УсловияЗаказаПокупателя);
	Результат.Добавить(УсловияСчетаЗаказа);
	Результат.Добавить(УсловияПриемки);
	Результат.Добавить(УсловияКоммерческогоПредложения);

	Возврат Результат;

КонецФункции

