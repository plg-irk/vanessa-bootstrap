// См. ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов
Процедура ПриНачальномЗаполненииЭлементов(КодыЯзыков, Элементы, ТабличныеЧасти) Экспорт

	ЗаполнитьЭлементыГруппыБыстрыеФормы(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыВидимостьКолонокВДокументах(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыВидимостьПредпросмотраВДокументах(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыДеньгиИВзаиморасчеты(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыЗагрузкаДанныхИзВнешнихИсточников(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыМобильнаяТелефония(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыНалоги(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыНастройкаСбросаКоличества(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыНастройкаЭлектроннойПочты(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыОсновныеЗначенияДляПодстановки(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыНастройкаПодбора(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыПодписиИДругиеРеквизитыПечати(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыРабочееМестоКассира(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыРедактированиеТабличныхЧастей(Элементы, КодыЯзыков);
	ЗаполнитьЭлементыГруппыЦены(Элементы, КодыЯзыков);

	ТипВариантыОбработкиКодаМаркировки = Новый ОписаниеТипов("ПеречислениеСсылка.ВариантыОбработкиКодаМаркировки");

	ДобавитьЭлемент(Элементы, КодыЯзыков, "ВариантОбработкиКодаМаркировкиВДокументахПоступления", ПустаяСсылка(),
		ТипВариантыОбработкиКодаМаркировки, "ru = 'Вариант обработки кода маркировки в документах поступления'"); // @НСтр-1

	ТипБулево = Новый ОписаниеТипов("Булево");

	ДобавитьЭлемент(Элементы, КодыЯзыков, "ВыводитьСоветОплатаСертификатомВВалюте", ПустаяСсылка(), ТипБулево,
		"ru = 'Выводить совет об оплате сертификатом в валюте'"); // @НСтр-1

	ДобавитьЭлемент(Элементы, КодыЯзыков, "НеВыводитьОтчетыПоПродажамИЦенамВКарточкеНоменклатуры", ПустаяСсылка(),
		ТипБулево, "ru = 'Не выводить отчеты по продажам и ценам в карточке номенклатуры'"); // @НСтр-1

	ДобавитьЭлемент(Элементы, КодыЯзыков, "ПредложениеИспользованияСистемыВзаимодействияДляТелефонииПоказано",
		ПустаяСсылка(), ТипБулево, "ru = 'Предложение использования системы взаимодействия для телефонии показано'"); // @НСтр-1

	ДобавитьЭлемент(Элементы, КодыЯзыков, "РежимВыполнениеЭтапов", ПустаяСсылка(), ТипБулево,
		"ru = 'Режим выполнение этапов'"); // @НСтр-1

КонецПроцедуры

