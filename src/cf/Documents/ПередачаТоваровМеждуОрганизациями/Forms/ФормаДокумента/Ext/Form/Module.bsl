КонецФункции

&НаСервере
Функция ПолучитьДанныеПриИзмененииОрганизацияПолучатель(Дата, ВалютаДокумента, ОрганизацияПолучатель, 
	ОрганизацияОтправитель)
	
	ДоговорПоУмолчанию = Справочники.ДоговорыКонтрагентов.ПоКонтрагентуПоОрганизации(ОрганизацияПолучатель,
		ОрганизацияОтправитель);
	
	СтрокаИменРеквизитовДоговора = "Наименование, ВалютаРасчетов, РасчетыВУсловныхЕдиницах, ВидЦен, ВидЦен.ЦенаВключаетНДС";
	РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДоговорПоУмолчанию, СтрокаИменРеквизитовДоговора);
	
	Результат = Новый Структура();
	
	Результат.Вставить("Контрагент",
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОрганизацияПолучатель, "КонтрагентИнтеркампани", Истина));
	Если НЕ ЗначениеЗаполнено(Результат.Контрагент) Тогда
		Результат.Контрагент = Объект.КонтрагентПолучатель;
	КонецЕсли;
	
	Результат.Вставить("Договор"				, ДоговорПоУмолчанию);
	Результат.Вставить("НаименованиеДоговора"	, РеквизитыДоговора.Наименование);
	Результат.Вставить("ВалютаРасчетов"			, РеквизитыДоговора.ВалютаРасчетов);
	Результат.Вставить("ВалютаРасчетовКурсКратность",
		РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата, Новый Структура("Валюта", РеквизитыДоговора.ВалютаРасчетов)));
			
	Результат.Вставить("РасчетыВУсловныхЕдиницах", РеквизитыДоговора.РасчетыВУсловныхЕдиницах);
	Результат.Вставить("ВидЦен"				, РеквизитыДоговора.ВидЦен);
	Результат.Вставить("СуммаВключаетНДС"		,
		?(ЗначениеЗаполнено(РеквизитыДоговора.ВидЦен), РеквизитыДоговора.ВидЦенЦенаВключаетНДС, Неопределено));
		
	Результат.Вставить("СпособЗаполненияСтавкиНДС",
		Справочники.ДоговорыКонтрагентов.СпособЗаполненияСтавкиНДСПоДоговору(ДоговорПоУмолчанию));
		
	Результат.Вставить("СпособЗачетаПредоплаты"	, ПолучитьСпособЗачетаДляДоговора(ДоговорПоУмолчанию, 
		Результат.Контрагент, Истина));
		
	Результат.Вставить("БанковскийСчетКонтрагента", Справочники.БанковскиеСчета.БанковскийСчетСубъекта(
		ОрганизацияПолучатель, Результат.ВалютаРасчетов));
		
	Результат.Вставить("БанковскийСчет"			, Справочники.БанковскиеСчета.БанковскийСчетСубъекта(
		ОрганизацияОтправитель, Результат.ВалютаРасчетов, Объект.Дата, Результат.Договор));
	
	УстановитьВидимостьДоговора();
	
	ОбновитьВидимостьИОстаткиВзаиморасчетов();
	
	Если ИспользоватьПодключаемоеОборудование Тогда
		Если ЗначениеЗаполнено(Объект.КонтрагентПолучатель) Тогда
			ДанныеКИКонтрагента = Справочники.Контрагенты.ДанныеКИКонтрагентаДляВыбораНаФорме(
				Объект.КонтрагентПолучатель, Элементы, ПоляКИДляОтправкиЧека());
		КонецЕсли;
		ЗаполнитьПоляКИДляОтправкиЧекаПоУмолчанию(ДанныеКИКонтрагента);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуРеквизитыПечати()
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("КонтекстПечати", Объект);
	ПараметрыОткрытия.Вставить("НаборОснований", НаборОснованийПечати());
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьИзмененияРеквизитовПечати", ЭтотОбъект);
	ОткрытьФорму("Обработка.РеквизитыПечати.Форма.РеквизитыПечатиПередачаТоваровМеждуОрганизациями", ПараметрыОткрытия, ЭтотОбъект, , , , ОписаниеОповещения);

КонецПроцедуры 

&НаСервереБезКонтекста
Функция ПолучитьНастройкиИзмененияКоличества()
	
	НастройкиКоличества = ДокументыУНФКлиентСервер.ПараметрыСбросаКоличества();
	ДокументыУНФ.ЗаполнитьНастройкиКоличества(НастройкиКоличества);
