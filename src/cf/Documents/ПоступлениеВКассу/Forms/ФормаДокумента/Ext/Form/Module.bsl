Процедура ЗаполнитьИнформациюПоКредитуЗаймуНаСервере()
	
	ФормыДокументовДеньги.ЗаполнитьИнформациюПоКредитуЗаймуНаСервере(ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДоговорЗаймаСотрудникуПриИзмененииНаСервере(ДоговорЗаймаСотруднику, Дата)
	
	СтруктураДанные = Новый Структура;
	
	СтруктураДанные.Вставить("ВалютаРасчетов", ДоговорЗаймаСотруднику.ВалютаРасчетов);
	СтруктураДанные.Вставить("Контрагент", ДоговорЗаймаСотруднику.Контрагент);
	СтруктураДанные.Вставить("Сотрудник", ДоговорЗаймаСотруднику.Сотрудник);
	СтруктураДанные.Вставить("ЭтоДоговорЗайма", ДоговорЗаймаСотруднику.ВидДоговора = Перечисления.ВидыДоговоровКредитаИЗайма.ДоговорЗаймаСотруднику);
	
	Возврат СтруктураДанные;
	
КонецФункции

&НаКлиенте
Процедура СотрудникПриИзменении(Элемент)
	
	СтруктураДанные = ПолучитьДанныеСотрудникПриИзменении(Объект.Подотчетник, Объект.Дата, Объект.Организация);
	Если НЕ ЗначениеЗаполнено(Объект.ПринятоОт) Тогда
		Объект.ПринятоОт = СтруктураДанные.ПодотчетникНаименование;
	КонецЕсли;
	
	Объект.ДоговорКредитаЗайма = СтруктураДанные.ДоговорКредитаЗайма;
	ОбработатьИзменениеДоговораКредитаИлиЗайма();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДанныеСотрудникПриИзменении(Сотрудник, Дата, Организация)
	
	СтруктураДанные = ПолучитьДанныеПодотчетникПриИзменении(Сотрудник);
	
	СтруктураДанные.Вставить("ДоговорКредитаЗайма", Документы.ДоговорКредитаИЗайма.ПолучитьДоговорКредитаИЗаймаПоУмолчаниюПоОрганизацииВидуДоговора(Сотрудник, Организация));
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеПодотчетникПриИзменении()

&НаКлиенте
Процедура РасчетыПрочиеКорреспонденцияПриИзменении(Элемент)
	
	Если Корреспонденция <> Объект.Корреспонденция Тогда
		УстановитьВидимостьРеквизитовВЗависимостиОтКорреспонденции(Истина);
		Объект.АналитикаПрочихДоходовИРасходов = Неопределено;
		Корреспонденция = Объект.Корреспонденция;
	КонецЕсли;
	
КонецПроцедуры

