&НаКлиенте
Процедура ПродажаВалютыРассчитатьСуммуУчета()
	
	Объект.Курс = ?(
		Объект.Курс = 0,
		1,
		Объект.Курс);
	Объект.Кратность = ?(
		Объект.Кратность = 0,
		1,
		Объект.Кратность);
	
	Объект.СуммаУчета = ВалютыУНФКлиентСервер.Пересчитать(Объект.СуммаДокумента, Объект.Курс, Объект.ПродажаВалютыКурс,
		Объект.Кратность, Объект.ПродажаВалютыКратность);
	
