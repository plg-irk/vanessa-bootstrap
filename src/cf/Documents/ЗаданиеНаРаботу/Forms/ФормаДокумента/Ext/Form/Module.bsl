	Иначе
		ДанныеСтроки = Объект.Работы[0];
	КонецЕсли;
	
	РассчитатьТрудоемкость(ДанныеСтроки);
	РассчитатьПродолжительность(ДанныеСтроки);
	РассчитатьСумму(ДанныеСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеРаботыЦена()
	
