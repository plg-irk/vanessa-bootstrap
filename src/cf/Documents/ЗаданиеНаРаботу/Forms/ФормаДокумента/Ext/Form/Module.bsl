	ОткрытьФорму("ОбщаяФорма.РедактированиеТекста", ПараметрыФормы, , , , ,
		Новый ОписаниеОповещения("РаботыКомментарийНачалоВыбораЗавершение", ЭтотОбъект,
		Новый Структура("ТекущиеДанные", ДанныеСтроки))); 
	
