
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ПереходИзОбсуждения = Ложь;
	Если Параметры.Свойство("ПереходИзОбсужденияСтатусЗадач") Тогда
		МассивЗадач = ПолучитьМассивЗадачСУчетомОграничения(Параметры);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "Ссылка", МассивЗадач, ВидСравненияКомпоновкиДанных.ВСписке,, Истина); 
		ПереходИзОбсуждения = Истина;
			
	КонецЕсли;

	Если НЕ Пользователи.ЭтоПолноправныйПользователь() И ПереходИзОбсуждения = Ложь Тогда       
		СотрудникиПользователя = РегистрыСведений.СотрудникиПользователя.ПолучитьСотрудниковПользователя();
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "Ответственный", СотрудникиПользователя, ВидСравненияКомпоновкиДанных.ВСписке,, Истина);
	КонецЕсли;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ВРег(ИмяСобытия) = ВРег("Запись_ЗадачаСотрудника") Тогда
		Элементы.Список.Обновить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиБиблиотек

// СтандартныеПодсистемы.ПодключаемыеКоманды
//@skip-check module-unused-method
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	ПодключаемыеКомандыКлиент.НачатьВыполнениеКоманды(ЭтотОбъект, Команда, Элементы.Список);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПродолжитьВыполнениеКомандыНаСервере(ПараметрыВыполнения, ДополнительныеПараметры) Экспорт
	ВыполнитьКомандуНаСервере(ПараметрыВыполнения);
КонецПроцедуры

&НаСервере
Процедура ВыполнитьКомандуНаСервере(ПараметрыВыполнения)
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, ПараметрыВыполнения, Элементы.Список);
КонецПроцедуры

//@skip-check module-unused-method
&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Элементы.Список);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

//@skip-check unknown-form-parameter-access
&НаСервере
Функция ПолучитьМассивЗадачСУчетомОграничения(Параметры)
	
	Если Параметры.ПоказательСтатусаЗадач = "Всего"	Тогда
		Возврат Справочники.ЗадачиАссистентаПоЗадачамСотрудника.ПолучитьМассивАктивныхЗадачСотрудника(	
					Параметры.СотрудникСтатусЗадач); 
	ИначеЕсли Параметры.ПоказательСтатусаЗадач = "Просроченных" Тогда
		Возврат Справочники.ЗадачиАссистентаПоЗадачамСотрудника.ПолучитьМассивПросроченныхЗадачСотрудника(	
					Параметры.СотрудникСтатусЗадач); 
	ИначеЕсли Параметры.ПоказательСтатусаЗадач = "Новых" Тогда
		Возврат Справочники.ЗадачиАссистентаПоЗадачамСотрудника.ПолучитьМассивНовыхЗадачСотрудника(	
					Параметры.СотрудникСтатусЗадач);  
	ИначеЕсли Параметры.ПоказательСтатусаЗадач = "Выполненных" Тогда
		Возврат Справочники.ЗадачиАссистентаПоЗадачамСотрудника.ПолучитьМассивВыполненныхЗадачСотрудника(	
					Параметры.СотрудникСтатусЗадач);  
	ИначеЕсли Параметры.ПоказательСтатусаЗадач = "Неоткрытых" Тогда
		Возврат Справочники.ЗадачиАссистентаПоЗадачамСотрудника.ПолучитьМассивНеоткрытыхЗадачСотрудника(	
					Параметры.СотрудникСтатусЗадач);  
	ИначеЕсли Параметры.ПоказательСтатусаЗадач = "Приближающихся" Тогда
		Возврат Справочники.ЗадачиАссистентаПоЗадачамСотрудника.ПолучитьМассивПриближающихсяЗадачСотрудника(	
					Параметры.СотрудникСтатусЗадач);  
			
	Иначе	
		Возврат Новый Массив;
	КонецЕсли;     
	
КонецФункции

#КонецОбласти

#КонецОбласти
