#Область ПрограммныйИнтерфейс

// Устанавливает отметку "Выполнена" для документов ЗадачаСотрудника
//
// Параметры:
//  МассивОбъектов - Массив из ДокументСсылка.ЗадачаСотрудника
//  ИзмененныеДокументы - Массив из ДокументСсылка.ЗадачаСотрудника
//
Процедура ЗавершитьЗадачу(МассивОбъектов, ИзмененныеДокументы) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗадачаСотрудника.Ссылка КАК Ссылка,
	|	ЗадачаСотрудника.Выполнена КАК Выполнена
	|ИЗ
	|	Документ.ЗадачаСотрудника КАК ЗадачаСотрудника
	|ГДЕ
	|	ЗадачаСотрудника.Ссылка В(&СписокЗадач)";
	
	Запрос.УстановитьПараметр("СписокЗадач", МассивОбъектов);

	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл  
		
		Если Выборка.Выполнена Тогда
			ИзмененныеДокументы.Добавить(Выборка.Ссылка);
			Продолжить;
		КонецЕсли;                               
		
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		ДокументОбъект.Выполнена = Истина;
		
		Попытка
			ДокументОбъект.Заблокировать();
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);		
		Исключение
			ТекстОшибки = СтрШаблон(нСтр("ru='Ошибка установки отметки ""Выполнена""  %1. %2'"), 
				Строка(Выборка.Ссылка), 
				ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		    ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
			Продолжить;
		КонецПопытки;
		
		ДокументОбъект.Разблокировать();
		
		ИзмененныеДокументы.Добавить(Выборка.Ссылка);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли