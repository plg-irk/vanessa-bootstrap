&НаСервере
Функция НачатьЗаполнениеЦенПоЦенамПрошлойЗакупкиНаСервере(ДополнительныеПараметры) 
	
	// параметры выполнения ДО
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);  
	   			
	Если ДополнительныеПараметры.ТЧИсточникДействияЗапасы Тогда   
		
		// запасы
		ИмяМетода 					= "ЦенообразованиеСервер.ПодготовитьТаблицуЦенПоЦенамПрошлойЗакупкиЗапасы";  	
		НаименованиеФоновогоЗадания 	= НСтр("ru = 'Приходная накладная: Заполнение цен по ценам прошлой закупки. (Запасы)'");
        	ТаблицаДанныеДляРасчета 		= Объект.Запасы.Выгрузить();
		
	ИначеЕсли ДополнительныеПараметры.ТЧИсточникДействияРасходы Тогда      
		
		// расходы
		ИмяМетода 					= "ЦенообразованиеСервер.ПодготовитьТаблицуЦенПоЦенамПрошлойЗакупкиРасходы";   	
		НаименованиеФоновогоЗадания 	= НСтр("ru = 'Приходная накладная: Заполнение цен по ценам прошлой закупки. (Расходы)'");
        	ТаблицаДанныеДляРасчета 		= Объект.Расходы.Выгрузить();
		
	КонецЕсли;
	
	ПараметрыВыполнения.ЗапуститьНеВФоне = Ложь;
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НаименованиеФоновогоЗадания;
	
	// параметры расчета
	ПараметрыРасчета = ЦенообразованиеСервер.ПодготовитьПараметрыРасчетаПоследнихЦен(Объект); 
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ИмяМетода, ТаблицаДанныеДляРасчета, ПараметрыРасчета); 
		
КонецФункции   

&НаСервереБезКонтекста
Процедура ЗаполнитьЦеныПрошлойЗакупкиПоВыделеннымСтрокам(ТЧЗаполнения, Знач МассивВыделенныхСтрок, Знач ТаблицаРезультатЦены, 
	Знач ДополнительныеПараметры)
		
	Для Каждого ТекущийЭлементМассива Из МассивВыделенныхСтрок Цикл 
						
		ИндексСтроки = ТекущийЭлементМассива.НомерСтроки - 1; 
		
		ТЧЗаполнения[ИндексСтроки].Цена 				= ТаблицаРезультатЦены[ИндексСтроки].ЦенаПрошлойЗакупки;
		ТЧЗаполнения[ИндексСтроки].ЦенаПрошлойЗакупки 	= ТаблицаРезультатЦены[ИндексСтроки].ЦенаПрошлойЗакупки;
		ТЧЗаполнения[ИндексСтроки].ПроцентИзмененияЦен 	= 0;
		ТЧЗаполнения[ИндексСтроки].ПоказателиРассчитаны = Истина;
		
	КонецЦикла;   
	
КонецПроцедуры  

&НаСервереБезКонтекста
Процедура ЗаполнитьЦеныПрошлойЗакупкиПоВсемСтрокам(ТЧЗаполнения, Знач ТаблицаРезультатЦены, Знач ДополнительныеПараметры)
		
	ТЧЗаполнения.Загрузить(ТаблицаРезультатЦены);	 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоЦенамПрошлойЗакупкиНаСервере(СтруктураРезультат, ДополнительныеПараметры)
	
	Если ДополнительныеПараметры = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ПараметрыОтборСтрок = Новый Структура("Пометка", Истина);
		
	Если ДополнительныеПараметры.ТЧИсточникДействияЗапасы Тогда 
		
		ТЧЗаполнения 			= Объект.Запасы;
		ВсегоСтрок 			= Объект.Запасы.Количество();  
		МассивВыделенныхСтрок 	= Объект.Запасы.НайтиСтроки(ПараметрыОтборСтрок);

	ИначеЕсли ДополнительныеПараметры.ТЧИсточникДействияРасходы Тогда  
		
		ТЧЗаполнения 			= Объект.Расходы;
		ВсегоСтрок 			= Объект.Расходы.Количество();  
		МассивВыделенныхСтрок 	= Объект.Расходы.НайтиСтроки(ПараметрыОтборСтрок);

	КонецЕсли;	
	
	Если ДополнительныеПараметры.Свойство("ИсточникКомандаФормы") 
		И ДополнительныеПараметры.ИсточникКомандаФормы Тогда  
		
		ЗаполнитьЦеныПрошлойЗакупкиПоВсемСтрокам(ТЧЗаполнения, СтруктураРезультат.ТаблицаРезультатЦены, ДополнительныеПараметры);
		Возврат;
		
	КонецЕсли;
	
	Если МассивВыделенныхСтрок.Количество() > 0 
		И ВсегоСтрок <> МассивВыделенныхСтрок.Количество() Тогда
				
		ЗаполнитьЦеныПрошлойЗакупкиПоВыделеннымСтрокам(ТЧЗаполнения, МассивВыделенныхСтрок, 
			СтруктураРезультат.ТаблицаРезультатЦены, ДополнительныеПараметры); 
									
	Иначе
		
		ЗаполнитьЦеныПрошлойЗакупкиПоВсемСтрокам(ТЧЗаполнения, СтруктураРезультат.ТаблицаРезультатЦены, ДополнительныеПараметры);
		
	КонецЕсли;	  

КонецПроцедуры

&НаСервере
Процедура ОбработатьРезультатЗаполненияЦенПоЦенамПрошлойЗакупкиНаСервере(АдресРезультата, ДополнительныеПараметры)
		
	СтруктураРезультат = ПолучитьИзВременногоХранилища(АдресРезультата); 
	
	Если СтруктураРезультат.ТаблицаРезультатЦены <> Неопределено 
		И ТипЗнч(СтруктураРезультат.ТаблицаРезультатЦены) = Тип("ТаблицаЗначений")
		И СтруктураРезультат.ЦеныРассчитаны Тогда 		
		   
	    ЗаполнитьПоЦенамПрошлойЗакупкиНаСервере(СтруктураРезультат, ДополнительныеПараметры);
		
	КонецЕсли;   
	
	УдалитьИзВременногоХранилища(АдресРезультата);
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриЗавершенииЗаполненияЦенПоЦенамПрошлойЗакупки(Результат, ДополнительныеПараметры) Экспорт
	
	// пользователь отменил задание.
	Если Результат = Неопределено Тогда 
		Возврат;
	КонецЕсли;

	// ошибка
	Если Результат.Статус = "Ошибка" Тогда
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	Если Результат <> Неопределено И ЭтоАдресВременногоХранилища(Результат.АдресРезультата) Тогда 
		
		// обработка результата
		ОбработатьРезультатЗаполненияЦенПоЦенамПрошлойЗакупкиНаСервере(Результат.АдресРезультата, ДополнительныеПараметры);  
		
		// обновить итоги на форме	
		ОбновитьПодвалФормы();
		
		Модифицированность = Истина;
		
	КонецЕсли;
		
КонецПроцедуры 

&НаКлиенте
Процедура ВопросЗаполнитьЦеныПоЦенамПрошлойЗакупки(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда 
		Возврат; 
	КонецЕсли;  
	
	Если Объект.Запасы.Количество() > 50 ИЛИ Объект.Расходы.Количество() > 50  Тогда  
		
		ДлительнаяОперация = НачатьЗаполнениеЦенПоЦенамПрошлойЗакупкиНаСервере(ДополнительныеПараметры);  
		
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ПриЗавершенииЗаполненияЦенПоЦенамПрошлойЗакупки", 
			ЭтотОбъект, ДополнительныеПараметры); 
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Заполнение цен по ценам прошлой закупки ...'");
		
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания); 
		ОбновитьПодвалФормы();
	Иначе
		
		 ОбновитьПоказателиТабличныхЧастейПоЦенамПрошлойЗакупки(Истина, Истина, ДополнительныеПараметры); 
		 ОбновитьПодвалФормы();
		 
	КонецЕсли;
					
КонецПроцедуры

&НаКлиенте
Процедура ЗадатьВопросОЗаполнениеЦенПоЦенамПрошлойЗакупки(ДополнительныеПараметры)
	
	ТекущаяВкладка = Элементы.Страницы.ТекущаяСтраница;
	
	ДополнительныеПараметры.Вставить("ТЧИсточникДействияРасходы"	, ТекущаяВкладка = Элементы.ГруппаРасходы);
	ДополнительныеПараметры.Вставить("ТЧИсточникДействияЗапасы"	, ТекущаяВкладка = Элементы.ГруппаЗапасы);

	Оповещение = Новый ОписаниеОповещения("ВопросЗаполнитьЦеныПоЦенамПрошлойЗакупки", ЭтотОбъект, ДополнительныеПараметры);
	ПоказатьВопрос(Оповещение, НСтр("ru = 'Цены будут заполнены по ценам прошлой закупки. Продолжить?'"), РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура ЗапасыЕдиницаПриИзмененииПродолжить(СтрокаТабличнойЧасти)    
	
	ИмяТЧЗапасы = ИмяТЧЗапасы();
	
	Если ПоказыватьКолонкуЦенаПрошлойЗакупки 
	И Объект.ВидОперации = ОбщегоНазначенияКлиент.ПредопределенныйЭлемент("Перечисление.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика") Тогда  
		
		СтруктураДанные = Новый Структура;
		СтруктураДанные.Вставить("Номенклатура"				, СтрокаТабличнойЧасти.Номенклатура);
		СтруктураДанные.Вставить("Характеристика"			, СтрокаТабличнойЧасти.Характеристика); 
		СтруктураДанные.Вставить("ЕдиницаИзмерения"			, СтрокаТабличнойЧасти.ЕдиницаИзмерения);
		СтруктураДанные.Вставить("НалогообложениеНДС"		, Объект.НалогообложениеНДС);
		СтруктураДанные.Вставить("ВидСтавкиНДСПоУмолчанию"	, ВидСтавкиНДСПоУмолчанию);
		СтруктураДанные.Вставить("Контрагент"				, Объект.Контрагент);
		СтруктураДанные.Вставить("СтруктурнаяЕдиница"		, Объект.СтруктурнаяЕдиница); 
		СтруктураДанные.Вставить("ВалютаДокумента"			, Объект.ВалютаДокумента);

		ЦенообразованиеКлиент.ДополнитьСтруктуруДаннымиЦенаПрошлойЗакупки(Объект, СтруктураДанные);  		
		СтруктураДанные = ПолучитьДанныеНоменклатуры(СтруктураДанные);
		
		Если СтруктураДанные.Свойство("ЦенаПрошлойЗакупки") Тогда    
			ЦенообразованиеКлиент.ЗаполнитьЦенуПрошлойЗакупкиВСтроке(СтрокаТабличнойЧасти, СтруктураДанные); 
			ЦенообразованиеКлиент.РассчитатьОтклонениеЦенВСтроке(ЭтотОбъект, ИмяТЧЗапасы, СтрокаТабличнойЧасти);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

// ЦенаПрошлойЗакупки

&НаСервере
Процедура ОбновитьПоказателиТабличныхЧастейПоЦенамПрошлойЗакупки(ОбновитьВсеСтроки = Ложь, ЗаполнитьЦенуПоПрошлой = Ложь, 
	ДополнительныеПараметры = Неопределено)
	
	Если ДополнительныеПараметры = Неопределено Тогда  
		
		ОбновитьПоказателиТЧЗапасы(ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой); 
		ОбновитьПоказателиТЧРасходы(ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой);  
		
	ИначеЕсли ДополнительныеПараметры.Свойство("ТЧИсточникДействияЗапасы") 
			И ДополнительныеПараметры.ТЧИсточникДействияЗапасы Тогда  
		
		ОбновитьПоказателиТЧЗапасы(ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой, "Запасы", ДополнительныеПараметры);
		
	ИначеЕсли ДополнительныеПараметры.Свойство("ТЧИсточникДействияРасходы") 
			И ДополнительныеПараметры.ТЧИсточникДействияРасходы Тогда

		ОбновитьПоказателиТЧРасходы(ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой, "Расходы", ДополнительныеПараметры); 
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбработатьРезультатЗапросаОбновитьПоказателиЦенПрошлойЗакупки(Объект, ИмяТабличнойЧасти, Выборка, 
		ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой, ДополнительныеПараметры = Неопределено)
	
	РежимИзменитьСтроки = Ложь;
	Если ДополнительныеПараметры <> Неопределено 
		И ДополнительныеПараметры.Свойство("ИзменитьСтроки") 
		И ДополнительныеПараметры.ИзменитьСтроки Тогда  	
		РежимИзменитьСтроки = Истина;
	КонецЕсли;
		
	ПараметрыРасчетаВСтроке = Новый Структура;
	ПараметрыРасчетаВСтроке.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС); 

	Пока Выборка.Следующий() Цикл 
		
		СтрокаТЧ = Объект[ИмяТабличнойЧасти][Выборка.НомерСтроки - 1]; 	
		Если СтрокаТЧ <> Неопределено Тогда 
			
			Если НЕ ОбновитьВсеСтроки И СтрокаТЧ.ПоказателиРассчитаны Тогда
				Продолжить;
			КонецЕсли; 
			
			Если РежимИзменитьСтроки И НЕ СтрокаТЧ.Пометка Тогда
				Продолжить;
			КонецЕсли;
			
			ТребуетсяУчестьНДС = Ложь;
			Если Объект.НалогообложениеНДС <> Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
				Если Выборка.СуммаВключаетНДС <> Объект.СуммаВключаетНДС Тогда
					ТребуетсяУчестьНДС = Истина;
				КонецЕсли; 
			КонецЕсли;
			
			ЦенаПрошлойЗакупки 		= Выборка.ЦенаПрошлойЗакупки;  
			ОтношениеЦенВПроцентах 	= Выборка.ОтношениеЦенВПроцентах; 
			
			// если есть разница в учете ндс в текущем документе и прошлом.
			Если ТребуетсяУчестьНДС Тогда 
				
				ЦенаПрошлойЗакупки = ПересчитатьЦенуСУчетомНалогообложенияНДС(ЦенаПрошлойЗакупки, СтрокаТЧ.СтавкаНДС,  
					Объект.СуммаВключаетНДС, Выборка.СуммаВключаетНДС); 
					
				ОтношениеЦенВПроцентах = 0;
				Если ЦенаПрошлойЗакупки > 0 И СтрокаТЧ.Цена > 0 Тогда
					ОтношениеЦенВПроцентах = (ЦенаПрошлойЗакупки / СтрокаТЧ.Цена - 1) * 100; 
				КонецЕсли;
				
			КонецЕсли;
				
			СтрокаТЧ.ПоказателиРассчитаны 	= Истина;   		
			СтрокаТЧ.ЦенаПрошлойЗакупки 	= ЦенаПрошлойЗакупки;
			СтрокаТЧ.ПроцентИзмененияЦен 	= ОтношениеЦенВПроцентах;
			
			Если ЗаполнитьЦенуПоПрошлой Тогда
				
				СтрокаТЧ.Цена 				= ЦенаПрошлойЗакупки;
				СтрокаТЧ.Сумма 				= СтрокаТЧ.Цена * СтрокаТЧ.Количество;
				СтрокаТЧ.ПроцентИзмененияЦен 	= 0;
				
				ТабличныеЧастиУНФКлиентСервер.РассчитатьСуммуНДСИВсего(СтрокаТЧ, ПараметрыРасчетаВСтроке);
			
			КонецЕсли;
			
		КонецЕсли;  
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ОбновитьПоказателиТЧЗапасы(ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой, ИмяТабличнойЧасти = "Запасы", 
		ДополнительныеПараметры = Неопределено)  
		
	Если Объект[ИмяТабличнойЧасти].Количество() = 0 Тогда		
		Возврат;		
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) ИЛИ НЕ ЗначениеЗаполнено(Объект.Контрагент) 
		ИЛИ НЕ ЗначениеЗаполнено(Объект.Договор) Тогда
		Возврат;
	КонецЕсли;  
	
	Если ОбновитьВсеСтроки Тогда
		ЦенообразованиеСервер.ОбнулитьРасчетныеПоказателиПрошлыхЦен(Объект[ИмяТабличнойЧасти], 
			"ЦенаПрошлойЗакупки", ДополнительныеПараметры);
	КонецЕсли;
	
	Запрос = Новый Запрос;         
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаТоваровОбъекта.НомерСтроки КАК НомерСтроки,
	|	ТаблицаТоваровОбъекта.Номенклатура КАК Номенклатура,
	|	ТаблицаТоваровОбъекта.Характеристика КАК Характеристика,
	|	ТаблицаТоваровОбъекта.Цена КАК Цена,
	|	ВЫРАЗИТЬ(ТаблицаТоваровОбъекта.ЕдиницаИзмерения КАК Справочник.ЕдиницыИзмерения) КАК Упаковка
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&ТаблицаТоваровОбъекта КАК ТаблицаТоваровОбъекта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ РАЗРЕШЕННЫЕ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Характеристика КАК Характеристика,
	|	МАКСИМУМ(ПрошлыеЗакупки.ДатаПрошлойЗакупки) КАК ДатаПрошлойЗакупки,
	|	МАКСИМУМ(ПрошлыеЗакупки.СуммаВключаетНДС) КАК СуммаВключаетНДС
	|ПОМЕСТИТЬ ВТ_ТаблицаСтрокЗакупки
	|ИЗ
	|	ВТ_Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПоступлениеТоваровТовары.Номенклатура КАК Номенклатура,
	|			ПоступлениеТоваровТовары.Характеристика КАК Характеристика,
	|			ПоступлениеТоваровТовары.Ссылка.Дата КАК ДатаПрошлойЗакупки,
	|			ПоступлениеТоваровТовары.Ссылка.ВалютаДокумента КАК ВалютаДокумента,
	|			ПоступлениеТоваровТовары.Ссылка.Кратность КАК Кратность,
	|			ПоступлениеТоваровТовары.Ссылка.Курс КАК Курс,
	|			ПоступлениеТоваровТовары.Ссылка.СуммаВключаетНДС КАК СуммаВключаетНДС
	|		ИЗ
	|			Документ.ПриходнаяНакладная.Запасы КАК ПоступлениеТоваровТовары
	|		ГДЕ
	|			ПоступлениеТоваровТовары.Ссылка.Дата <= &Период
	|			И ПоступлениеТоваровТовары.Ссылка <> &Ссылка
	|			И ПоступлениеТоваровТовары.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			И ПоступлениеТоваровТовары.Ссылка.Контрагент = &Поставщик
	|			И ПоступлениеТоваровТовары.Ссылка.Проведен
	|			И ПоступлениеТоваровТовары.Ссылка.ВалютаДокумента = &ВалютаДокумента) КАК ПрошлыеЗакупки
	|		ПО Товары.Номенклатура = ПрошлыеЗакупки.Номенклатура
	|			И Товары.Характеристика = ПрошлыеЗакупки.Характеристика
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура,
	|	Товары.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ТаблицаСтрокЗакупкиСДатами.Номенклатура КАК Номенклатура,
	|	ТаблицаСтрокЗакупкиСДатами.Характеристика КАК Характеристика,
	|	МАКСИМУМ(ТаблицаСтрокЗакупкиСЦенами.Цена) КАК Цена,
	|	ТаблицаСтрокЗакупкиСДатами.СуммаВключаетНДС КАК СуммаВключаетНДС
	|ПОМЕСТИТЬ ВТ_ПрошлыеЗакупки
	|ИЗ
	|	ВТ_ТаблицаСтрокЗакупки КАК ТаблицаСтрокЗакупкиСДатами
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПоступлениеТоваровТовары.Номенклатура КАК Номенклатура,
	|			ПоступлениеТоваровТовары.Характеристика КАК Характеристика,
	|			ПоступлениеТоваров.Дата КАК ДатаПрошлойЗакупки,
	|			ПоступлениеТоваровТовары.Цена / ВЫБОР
	|				КОГДА ПоступлениеТоваровТовары.ЕдиницаИзмерения ССЫЛКА Справочник.ЕдиницыИзмерения
	|					ТОГДА ЕСТЬNULL(ПоступлениеТоваровТовары.ЕдиницаИзмерения.Коэффициент, 1)
	|				КОГДА ПоступлениеТоваровТовары.ЕдиницаИзмерения ССЫЛКА Справочник.КлассификаторЕдиницИзмерения
	|					ТОГДА 1
	|				ИНАЧЕ 1
	|			КОНЕЦ КАК Цена
	|		ИЗ
	|			Документ.ПриходнаяНакладная.Запасы КАК ПоступлениеТоваровТовары
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная КАК ПоступлениеТоваров
	|				ПО ПоступлениеТоваровТовары.Ссылка = ПоступлениеТоваров.Ссылка
	|		ГДЕ
	|			ПоступлениеТоваров.Дата < &Период
	|			И ПоступлениеТоваровТовары.Ссылка <> &Ссылка
	|			И ПоступлениеТоваров.Проведен
	|			И ПоступлениеТоваровТовары.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			И ПоступлениеТоваровТовары.Ссылка.Контрагент = &Поставщик) КАК ТаблицаСтрокЗакупкиСЦенами
	|		ПО ТаблицаСтрокЗакупкиСДатами.Номенклатура = ТаблицаСтрокЗакупкиСЦенами.Номенклатура
	|			И ТаблицаСтрокЗакупкиСДатами.Характеристика = ТаблицаСтрокЗакупкиСЦенами.Характеристика
	|			И ТаблицаСтрокЗакупкиСДатами.ДатаПрошлойЗакупки = ТаблицаСтрокЗакупкиСЦенами.ДатаПрошлойЗакупки
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаСтрокЗакупкиСДатами.Номенклатура,
	|	ТаблицаСтрокЗакупкиСДатами.Характеристика,
	|	ТаблицаСтрокЗакупкиСДатами.СуммаВключаетНДС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	ИСТИНА КАК ПоказателиРассчитаны,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ЦеныПрошлыхЗакупок.Цена, 0) > 0
	|				И Товары.Цена > 0
	|			ТОГДА (Товары.Цена / (ВЫБОР
	|					КОГДА Товары.Упаковка <> ЗНАЧЕНИЕ(Справочник.ЕдиницыИзмерения.ПустаяСсылка)
	|						ТОГДА Товары.Упаковка.Коэффициент
	|					ИНАЧЕ 1
	|				КОНЕЦ * ЕСТЬNULL(ЦеныПрошлыхЗакупок.Цена, 0)) - 1) * 100
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОтношениеЦенВПроцентах,
	|	ВЫБОР
	|		КОГДА Товары.Упаковка <> ЗНАЧЕНИЕ(Справочник.ЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА Товары.Упаковка.Коэффициент
	|		ИНАЧЕ 1
	|	КОНЕЦ * ЕСТЬNULL(ЦеныПрошлыхЗакупок.Цена, 0) КАК ЦенаПрошлойЗакупки,
	|	ЕСТЬNULL(ЦеныПрошлыхЗакупок.СуммаВключаетНДС, ЛОЖЬ) КАК СуммаВключаетНДС
	|ИЗ
	|	ВТ_Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПрошлыеЗакупки.Номенклатура КАК Номенклатура,
	|			ПрошлыеЗакупки.Характеристика КАК Характеристика,
	|			ПрошлыеЗакупки.Цена КАК Цена,
	|			ПрошлыеЗакупки.СуммаВключаетНДС КАК СуммаВключаетНДС
	|		ИЗ
	|			ВТ_ПрошлыеЗакупки КАК ПрошлыеЗакупки) КАК ЦеныПрошлыхЗакупок
	|		ПО Товары.Номенклатура = ЦеныПрошлыхЗакупок.Номенклатура
	|			И Товары.Характеристика = ЦеныПрошлыхЗакупок.Характеристика";
	
	ТаблицаТоваровОбъекта = Объект[ИмяТабличнойЧасти].Выгрузить(, "Номенклатура, Характеристика, НомерСтроки, Цена, ЕдиницаИзмерения, ПоказателиРассчитаны"); 
	
	Если ОбновитьВсеСтроки Тогда
		ТаблицаТоваровОбъекта.ЗаполнитьЗначения(Ложь, "ПоказателиРассчитаны"); 
	КонецЕсли;     
	
	Запрос.УстановитьПараметр("ТаблицаТоваровОбъекта", ТаблицаТоваровОбъекта);
	Запрос.УстановитьПараметр("Ссылка"				, Объект.Ссылка);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Поставщик"			, Объект.Контрагент); 
	Запрос.УстановитьПараметр("ВалютаДокумента"		, Объект.ВалютаДокумента); 
		
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	Иначе
		Запрос.УстановитьПараметр("Период", Объект.Дата);
	КонецЕсли;
		
	Если НЕ Запрос.Выполнить().Пустой() Тогда  
		
		Выборка = Запрос.Выполнить().Выбрать(); 
		
		ОбработатьРезультатЗапросаОбновитьПоказателиЦенПрошлойЗакупки(Объект, ИмяТабличнойЧасти, Выборка, 
			ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой, ДополнительныеПараметры);  
		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ОбновитьПоказателиТЧРасходы(ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой, ИмяТабличнойЧасти = "Расходы", 
		ДополнительныеПараметры = Неопределено)  
		
	Если Объект[ИмяТабличнойЧасти].Количество() = 0 Тогда		
		Возврат;	
	КонецЕсли;
		
	Если НЕ ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) ИЛИ НЕ ЗначениеЗаполнено(Объект.Контрагент)
		ИЛИ НЕ ЗначениеЗаполнено(Объект.Договор) Тогда
		Возврат;
	КонецЕсли;  
	
	Если ОбновитьВсеСтроки Тогда
		ЦенообразованиеСервер.ОбнулитьРасчетныеПоказателиПрошлыхЦен(Объект[ИмяТабличнойЧасти],
			"ЦенаПрошлойЗакупки", ДополнительныеПараметры);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаТоваровОбъекта.НомерСтроки КАК НомерСтроки,
	|	ТаблицаТоваровОбъекта.Номенклатура КАК Номенклатура,
	|	ТаблицаТоваровОбъекта.Цена КАК Цена,
	|	ВЫРАЗИТЬ(ТаблицаТоваровОбъекта.ЕдиницаИзмерения КАК Справочник.ЕдиницыИзмерения) КАК Упаковка
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&ТаблицаТоваровОбъекта КАК ТаблицаТоваровОбъекта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Товары.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ПрошлыеЗакупки.ДатаПрошлойЗакупки) КАК ДатаПрошлойЗакупки,
	|	МАКСИМУМ(ПрошлыеЗакупки.СуммаВключаетНДС) КАК СуммаВключаетНДС
	|ПОМЕСТИТЬ ВТ_ТаблицаСтрокЗакупки
	|ИЗ
	|	ВТ_Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПоступлениеТоваровТовары.Номенклатура КАК Номенклатура,
	|			ПоступлениеТоваровТовары.Ссылка.Дата КАК ДатаПрошлойЗакупки,
	|			ПоступлениеТоваровТовары.Ссылка.СуммаВключаетНДС КАК СуммаВключаетНДС
	|		ИЗ
	|			Документ.ПриходнаяНакладная.Расходы КАК ПоступлениеТоваровТовары
	|		ГДЕ
	|			ПоступлениеТоваровТовары.Ссылка.Дата <= &Период
	|			И ПоступлениеТоваровТовары.Ссылка <> &Ссылка
	|			И ПоступлениеТоваровТовары.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			И ПоступлениеТоваровТовары.Ссылка.Контрагент = &Поставщик
	|			И ПоступлениеТоваровТовары.Ссылка.Проведен
	|			И ПоступлениеТоваровТовары.Ссылка.ВалютаДокумента = &ВалютаДокумента) КАК ПрошлыеЗакупки
	|		ПО Товары.Номенклатура = ПрошлыеЗакупки.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСтрокЗакупкиСДатами.Номенклатура КАК Номенклатура,
	|	МАКСИМУМ(ТаблицаСтрокЗакупкиСЦенами.Цена) КАК Цена,
	|	ТаблицаСтрокЗакупкиСДатами.СуммаВключаетНДС КАК СуммаВключаетНДС
	|ПОМЕСТИТЬ ВТ_ПрошлыеЗакупки
	|ИЗ
	|	ВТ_ТаблицаСтрокЗакупки КАК ТаблицаСтрокЗакупкиСДатами
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПоступлениеТоваровТовары.Номенклатура КАК Номенклатура,
	|			ПоступлениеТоваров.Дата КАК ДатаПрошлойЗакупки,
	|			ПоступлениеТоваровТовары.Цена / ВЫБОР
	|				КОГДА ПоступлениеТоваровТовары.ЕдиницаИзмерения ССЫЛКА Справочник.ЕдиницыИзмерения
	|					ТОГДА ЕСТЬNULL(ПоступлениеТоваровТовары.ЕдиницаИзмерения.Коэффициент, 1)
	|				КОГДА ПоступлениеТоваровТовары.ЕдиницаИзмерения ССЫЛКА Справочник.КлассификаторЕдиницИзмерения
	|					ТОГДА 1
	|				ИНАЧЕ 1
	|			КОНЕЦ КАК Цена
	|		ИЗ
	|			Документ.ПриходнаяНакладная.Расходы КАК ПоступлениеТоваровТовары
	|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная КАК ПоступлениеТоваров
	|				ПО ПоступлениеТоваровТовары.Ссылка = ПоступлениеТоваров.Ссылка
	|		ГДЕ
	|			ПоступлениеТоваров.Дата < &Период
	|			И ПоступлениеТоваровТовары.Ссылка <> &Ссылка
	|			И ПоступлениеТоваров.Проведен
	|			И ПоступлениеТоваровТовары.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|			И ПоступлениеТоваровТовары.Ссылка.Контрагент = &Поставщик) КАК ТаблицаСтрокЗакупкиСЦенами
	|		ПО ТаблицаСтрокЗакупкиСДатами.Номенклатура = ТаблицаСтрокЗакупкиСЦенами.Номенклатура
	|			И ТаблицаСтрокЗакупкиСДатами.ДатаПрошлойЗакупки = ТаблицаСтрокЗакупкиСЦенами.ДатаПрошлойЗакупки
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаСтрокЗакупкиСДатами.Номенклатура,
	|	ТаблицаСтрокЗакупкиСДатами.СуммаВключаетНДС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	ИСТИНА КАК ПоказателиРассчитаны,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ЦеныПрошлыхЗакупок.Цена, 0) > 0
	|				И Товары.Цена > 0
	|			ТОГДА (Товары.Цена / (ВЫБОР
	|					КОГДА Товары.Упаковка <> ЗНАЧЕНИЕ(Справочник.ЕдиницыИзмерения.ПустаяСсылка)
	|						ТОГДА Товары.Упаковка.Коэффициент
	|					ИНАЧЕ 1
	|				КОНЕЦ * ЕСТЬNULL(ЦеныПрошлыхЗакупок.Цена, 0)) - 1) * 100
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОтношениеЦенВПроцентах,
	|	ВЫБОР
	|		КОГДА Товары.Упаковка <> ЗНАЧЕНИЕ(Справочник.ЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА Товары.Упаковка.Коэффициент
	|		ИНАЧЕ 1
	|	КОНЕЦ * ЕСТЬNULL(ЦеныПрошлыхЗакупок.Цена, 0) КАК ЦенаПрошлойЗакупки,
	|	ЕСТЬNULL(ЦеныПрошлыхЗакупок.СуммаВключаетНДС, ЛОЖЬ) КАК СуммаВключаетНДС
	|ИЗ
	|	ВТ_Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПрошлыеЗакупки.Номенклатура КАК Номенклатура,
	|			ПрошлыеЗакупки.Цена КАК Цена,
	|			ПрошлыеЗакупки.СуммаВключаетНДС КАК СуммаВключаетНДС
	|		ИЗ
	|			ВТ_ПрошлыеЗакупки КАК ПрошлыеЗакупки) КАК ЦеныПрошлыхЗакупок
	|		ПО Товары.Номенклатура = ЦеныПрошлыхЗакупок.Номенклатура";
	
	ТаблицаТоваровОбъекта = Объект[ИмяТабличнойЧасти].Выгрузить(, "Номенклатура, НомерСтроки, Цена, ЕдиницаИзмерения, ПоказателиРассчитаны"); 
	
	Если ОбновитьВсеСтроки Тогда
		ТаблицаТоваровОбъекта.ЗаполнитьЗначения(Ложь, "ПоказателиРассчитаны");
	КонецЕсли;     
	
	Запрос.УстановитьПараметр("ТаблицаТоваровОбъекта", ТаблицаТоваровОбъекта);
	Запрос.УстановитьПараметр("Ссылка"					, Объект.Ссылка);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница"	, Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Поставщик"				, Объект.Контрагент);
	Запрос.УстановитьПараметр("ВалютаДокумента"		, Объект.ВалютаДокумента);
	Запрос.УстановитьПараметр("СтавкаНДС"				, Перечисления.СтавкиНДС.БезНДС);
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Запрос.УстановитьПараметр("Период", ТекущаяДатаСеанса());
	Иначе
		Запрос.УстановитьПараметр("Период", Объект.Дата);
	КонецЕсли;
	
	Если НЕ Запрос.Выполнить().Пустой() Тогда
		
		Выборка = Запрос.Выполнить().Выбрать(); 
		
		ОбработатьРезультатЗапросаОбновитьПоказателиЦенПрошлойЗакупки(Объект, ИмяТабличнойЧасти, Выборка, 
			ОбновитьВсеСтроки, ЗаполнитьЦенуПоПрошлой, ДополнительныеПараметры);  
		
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПересчитатьЦенуСУчетомНалогообложенияНДС(ЦенаПрошлойЗакупки, СтавкаНДС, 
СуммаВключаетНДСТекущийДокумент, СуммаВключаетНДСПрошлыйДокумент) 
	
	ЦенаСУчетомНДС = ЦенаПрошлойЗакупки;  
	
	Если СуммаВключаетНДСТекущийДокумент И СуммаВключаетНДСПрошлыйДокумент Тогда
		Возврат ЦенаСУчетомНДС;
	КонецЕсли;
	
	Если НЕ СуммаВключаетНДСТекущийДокумент И НЕ СуммаВключаетНДСПрошлыйДокумент Тогда
		Возврат ЦенаСУчетомНДС;
	КонецЕсли;
	
	ЗначениеСтавкиНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтавкаНДС);
	
	Если СуммаВключаетНДСТекущийДокумент Тогда	
		ЦенаСУчетомНДС = (ЦенаПрошлойЗакупки * (100 + ЗначениеСтавкиНДС)) / 100;	
	Иначе	
		ЦенаСУчетомНДС = (ЦенаПрошлойЗакупки * 100) / (100 + ЗначениеСтавкиНДС);	
	КонецЕсли;

		
	Возврат ЦенаСУчетомНДС;
	
КонецФункции

// Конец ЦенаПрошлойЗакупки

&НаСервере
Процедура ЗаполнитьНоменклатуруПоставщикаПоНоменклатуреСервере()
	
	НоменклатураВДокументахСервер.ЗаполнитьТабличнуюЧастьНоменклатуройПоставщикаПоНоменклатуре(Объект);
	
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьЦенуПоступленияПоТипуЦен() 
	
	СтруктураДанных = Новый Структура;
	ТабличнаяЧастьДокумента = Новый Массив;

	СтруктураДанных.Вставить("Дата",				Объект.Дата);
	СтруктураДанных.Вставить("Организация",			Компания);
	СтруктураДанных.Вставить("ЭтоНовыйОбъект", 		НЕ ЗначениеЗаполнено(Объект.Ссылка));
	ДоговорКомиссииВидЦен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ДоговорКомиссии, "ВидЦен");
	СтруктураДанных.Вставить("ВидЦен",				ДоговорКомиссииВидЦен);
	СтруктураДанных.Вставить("ВалютаДокумента",		Объект.ВалютаДокумента);
	СтруктураДанных.Вставить("СуммаВключаетНДС",	Объект.СуммаВключаетНДС);
	
	Для каждого СтрокаТЧ Из Объект.Запасы Цикл
		
		Если ТипЗнч(СтрокаТЧ.Номенклатура) <> Тип("СправочникСсылка.Номенклатура")
			Или Не ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТабличнойЧасти = Новый Структура;
		СтрокаТабличнойЧасти.Вставить("Номенклатура", СтрокаТЧ.Номенклатура);
		СтрокаТабличнойЧасти.Вставить("Характеристика", СтрокаТЧ.Характеристика);
		СтрокаТабличнойЧасти.Вставить("ЕдиницаИзмерения", СтрокаТЧ.ЕдиницаИзмерения);
		СтрокаТабличнойЧасти.Вставить("СтавкаНДС", СтрокаТЧ.СтавкаНДС);
		
		// МинимальныеЦены
		ПрименитьОбщийВидЦен = Ложь;
		ЦенообразованиеКлиентСервер.ДополнитьСтруктуруДанныхНоменклатурыПолямиЦенообразования(Объект, СтрокаТЧ,
			СтрокаТабличнойЧасти, Истина, ПрименитьОбщийВидЦен);
		// Конец МинимальныеЦены
		
		СтрокаТабличнойЧасти.Вставить("Цена", 0);
		
		Если СтрокаТЧ.Свойство("МинимальнаяЦена") Тогда
			СтрокаТабличнойЧасти.Вставить("МинимальнаяЦена", 0);
		КонецЕсли;
		
		ТабличнаяЧастьДокумента.Добавить(СтрокаТабличнойЧасти);
		
	КонецЦикла;
		
	ЦенообразованиеСервер.ПолучитьЦеныТабличнойЧастиПоВидуЦен(СтруктураДанных, ТабличнаяЧастьДокумента);
	
	СтруктураПоиска = Новый Структура;
	
	Для каждого СтрокаТЧ Из ТабличнаяЧастьДокумента Цикл

		СтруктураПоиска.Вставить("Номенклатура", СтрокаТЧ.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", СтрокаТЧ.Характеристика);
		СтруктураПоиска.Вставить("ЕдиницаИзмерения", СтрокаТЧ.ЕдиницаИзмерения);
		СтруктураПоиска.Вставить("СтавкаНДС", СтрокаТЧ.СтавкаНДС);
		
		РезультатПоиска = Объект.Запасы.НайтиСтроки(СтруктураПоиска);
		
		Для каждого СтрокаРезультат Из РезультатПоиска Цикл
			
			СтрокаРезультат.ЦенаПередачи = СтрокаТЧ.Цена;
			
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры // ПерезаполнитьЦеныТабличнойЧастиПоВидуЦен()

&НаКлиенте
Процедура РассчитатьСуммыПередачи(СтрокаТабличнойЧасти = Неопределено) 
	
	Если Не Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВыкупленныеКомиссионеромТовары") Тогда
		Возврат
	КонецЕсли;
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда 
		СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	КонецЕсли;
	
	// Сумма передачи.
	СтрокаТабличнойЧасти.СуммаПередачи = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.ЦенаПередачи;
	
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
	
	// Сумма НДС передачи.
	СтрокаТабличнойЧасти.СуммаНДСПередачи = ?(Объект.СуммаВключаетНДС,
												СтрокаТабличнойЧасти.СуммаПередачи - (СтрокаТабличнойЧасти.СуммаПередачи) / ((СтавкаНДС + 100) / 100),
												СтрокаТабличнойЧасти.СуммаПередачи * СтавкаНДС / 100);
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросОчиститьЗапасыИЗаполнитьПоОрдерам(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда 
		Возврат 
	КонецЕсли;
	
	Объект.Запасы.Очистить();
	Объект.СведенияПрослеживаемости.Очистить();
	Объект.СерииНоменклатуры.Очистить();
	Объект.АкцизныеМарки.Очистить();
	
	Если Объект.ПоложениеДокументаПоступления = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке")
		И Не ЗначениеЗаполнено(Объект.ДокументПоступления) Тогда
		Объект.ПоложениеДокументаПоступления = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти");
		ПриИзмененииВидаУчетаСклада(Истина);
	КонецЕсли;
		
	ИдентификаторыНовыхСтрок = Новый Массив;
	ЗагрузитьПоОстаткамНаСервере(ИдентификаторыНовыхСтрок);
	
	Для Каждого СтрокаТабличнойЧасти Из Объект.Запасы Цикл
		РассчитатьСуммуВСтрокеТабличнойЧасти("Запасы", СтрокаТабличнойЧасти);
	КонецЦикла;
	
	Если Объект.Запасы.Количество() Тогда
		Модифицированность = Истина;
		ОбновитьПодвалФормы();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПоОстаткамНаСервере(ИдентификаторыНовыхСтрок)
	
	ДополнительныеПараметры = Новый Структура("ПоложениеСклада, ПоложениеДокументаПоступления", Объект.ПоложениеСклада,
		Объект.ПоложениеДокументаПоступления);
	ЗапасыКПоступлению = СкладскойУчетСервер.ПолучитьТаблицуОстатковПоПриходнымОрдерам(Объект, ДополнительныеПараметры);
	ПараметрыПолученияЗапасовИзХранилища = НовыеПараметрыПолученияЗапасовИзХранилища(ЗапасыКПоступлению, "Запасы");
	ПараметрыПолученияЗапасовИзХранилища.ИдентификаторыНовыхСтрок = ИдентификаторыНовыхСтрок;
	ПараметрыПолученияЗапасовИзХранилища.ЗаполнениеПоОстаткам = Истина;
	ПолучитьЗапасыИзХранилища(ПараметрыПолученияЗапасовИзХранилища);
	СерииНоменклатурыУНФ.УдалитьСерииНоменклатурыВТабличнойЧастиВЗависимостиОтПолитики(Объект);
	ЗаполнитьПризнакиИспользованияХарактеристик();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПриходныеОрдераПоНоменклатуреСервер()
	
	ДополнительныеПараметры = Новый Структура("ПоложениеСклада, ПоложениеДокументаПоступления", Объект.ПоложениеСклада, Объект.ПоложениеДокументаПоступления);
	СкладскойУчетСервер.РаспределитьНоменклатуруПоОрдерам(ЭтотОбъект, ДополнительныеПараметры, "Запасы");
	СерииНоменклатурыУНФ.УдалитьСерииНоменклатурыВТабличнойЧастиВЗависимостиОтПолитики(Объект);
	
	Модифицированность = Истина;
	
	ЗаполнитьПризнакиИспользованияХарактеристик();
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииВидаУчетаСклада(ШапкаТабличнаяЧасть = Ложь)
	
	Если Объект.ПоложениеСклада = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке Тогда
		
		Если ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
			Если Не ЗначениеЗаполнено(Объект.ПоложениеДокументаПоступления) Или Объект.ПоложениеДокументаПоступления = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке Тогда
				Элементы.ГруппаДокументПоступления.Видимость = УчетОстатковПоСкладскимОрдерам;
				Элементы.ЗапасыДокументПоступления.Видимость = Ложь;
				Элементы.ЗаполнитьПриходныеОрдераПоНоменклатуре.Видимость = Ложь;
				
				Если ШапкаТабличнаяЧасть Тогда
					
					Если ЗначениеЗаполнено(Объект.ДокументПоступления) Тогда
						ДокументПоступленияВСтроке = Объект.ДокументПоступления;
					Иначе
						ДокументПоступленияВСтроке = Неопределено;
					КонецЕсли;
					
					Для Каждого СтрокаЗапасов Из Объект.Запасы Цикл
						СтрокаЗапасов.ДокументПоступления = ДокументПоступленияВСтроке;
					КонецЦикла;
					
				КонецЕсли;
				
			Иначе
				Элементы.ЗапасыДокументПоступления.Видимость = УчетОстатковПоСкладскимОрдерам;
				Элементы.ГруппаДокументПоступления.Видимость = Ложь;
				Элементы.ЗаполнитьПриходныеОрдераПоНоменклатуре.Видимость = УчетОстатковПоСкладскимОрдерам;
				
				Если ШапкаТабличнаяЧасть Тогда
					Объект.ДокументПоступления = Неопределено;
				КонецЕсли;
				
			КонецЕсли;
		Иначе
			Элементы.ГруппаДокументПоступления.Видимость = Ложь;
			Элементы.ЗапасыДокументПоступления.Видимость = Ложь;
			
			Если ШапкаТабличнаяЧасть Тогда
				Для Каждого СтрокаЗапасов Из Объект.Запасы Цикл
					СтрокаЗапасов.ДокументПоступления = Неопределено;
				КонецЦикла;
				Объект.ДокументПоступления = Неопределено;
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		Если ШапкаТабличнаяЧасть Тогда
			
			Объект.ПоложениеДокументаПоступления = Перечисления.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти;
			Объект.ДокументПоступления = Неопределено;
			
			Для Каждого СтрокаЗапасов Из Объект.Запасы Цикл
				СтрокаЗапасов.ДокументПоступления = Неопределено;
			КонецЦикла;
			
		КонецЕсли;
		
		Элементы.ГруппаДокументПоступления.Видимость = Ложь;
		Элементы.ЗапасыДокументПоступления.Видимость = СкладскойУчетСервер.ПоказыватьКолонкуДокументПоступления(ЭтотОбъект);
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЗаполнениеПоОрдерамНеВозможно()
	
	Отказ = Ложь;
	
	Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
		ТекстСообщения = НСтр("ru = 'Поле ""Организация"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "Объект.Организация", , Отказ);
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		ТекстСообщения = НСтр("ru = 'Поле ""Контрагент"" не заполнено'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "Объект.Контрагент", , Отказ);
	КонецЕсли;
	
	Если Объект.ПоложениеСклада = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке") Тогда
		
		Если Не ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
			ТекстСообщения = НСтр("ru = 'Поле ""Склад"" не заполнено'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "Объект.СтруктурнаяЕдиница", , Отказ);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Отказ;
	
КонецФункции

&НаКлиенте
Процедура УстановитьВидимостьКолонкиДокументаПоступления(Элемент, ПослеУдаления = Ложь)
	
	Если Элемент = Неопределено ИЛИ (ПослеУдаления Или (Не Элемент.ТекущийЭлемент = Неопределено 
		И (Элемент.ТекущийЭлемент.Имя = "ЗапасыНоменклатура" Или Элемент.ТекущийЭлемент.Имя = "ЗапасыСтруктурнаяЕдиница"))) Тогда
		
		Если Объект.ПоложениеСклада = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти") Тогда
			
			ПараметрыПоиска = Новый Структура("УказыватьДокументПоступления", Истина);
			
			НайденныеСтроки = Объект.Запасы.НайтиСтроки(ПараметрыПоиска);
			Элементы.ЗапасыДокументПоступления.Видимость = НайденныеСтроки.Количество();
			Элементы.ЗаполнитьПриходныеОрдераПоНоменклатуре.Видимость = Элементы.ЗапасыДокументПоступления.Видимость;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция УчетОстатковВРазрезеСкладскихОрдеров(СтруктурнаяЕдиница = Неопределено)
	
	Если НЕ СтруктурнаяЕдиница = Неопределено Тогда
		Возврат СкладскойУчетСервер.УчетОстатковВРазрезеСкладскихОрдеров(СтруктурнаяЕдиница);
	КонецЕсли;
	
	Если Объект.ПоложениеСклада = Перечисления.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти Тогда
			МассивКонтроля = СкладскойУчетСервер.МассивКонтроляПоЗапасамКПоступлениюПоСкладскимОрдерам(Объект.Запасы.Выгрузить(,"СтруктурнаяЕдиница"));
			Возврат МассивКонтроля.Количество();
	КонецЕсли;
	
	Возврат СкладскойУчетСервер.УчетОстатковВРазрезеСкладскихОрдеров(Объект.СтруктурнаяЕдиница);
	
КонецФункции

&НаСервере
Процедура ОбработатьСчетФактурыПослеЗаписиНаСервере()
	
	Если Не Объект.ЭтоУниверсальныйДокумент Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Объект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Объект.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика
		И Не Объект.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя 
		И Не Объект.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВыкупленныеКомиссионеромТовары Тогда
		Возврат;
	КонецЕсли;
	
	Если (ЗначениеЗаполнено(Объект.НомерВходящегоДокумента) И ЗначениеЗаполнено(Объект.ДатаВходящегоДокумента))
		Или Объект.ПокупателюВыставляетсяКорректировочныйСчетФактура Тогда
		
		СчетФактураСсылка = СчетаФактурыУНФ.ПолучитьПодчиненныйСчетФактуру(Объект.Ссылка, Истина, Объект.ПокупателюВыставляетсяКорректировочныйСчетФактура);
		
		Если СчетФактураСсылка = Неопределено Тогда
			
			СчетФактураСоздана = Ложь;
			Если Объект.ПокупателюВыставляетсяКорректировочныйСчетФактура Тогда
				
				ОшибкаПроверки = Ложь;
				
				Если Не ЗначениеЗаполнено(Объект.ДокументОснование)
					Или Не ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
					
					ОбщегоНазначения.СообщитьПользователю(НСтр("ru ='Корректировочный счет-фактура не создан. Необходимо выбрать документ основание ""Расходная накладная"".'"));
					ОшибкаПроверки = Истина;
				КонецЕсли;
				
				НайденныйСчетФактура = СчетаФактурыУНФВызовСервера.ПолучитьПодчиненныйСчетФактуру(Объект.ДокументОснование);
				Если ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") И Не ЗначениеЗаполнено(НайденныйСчетФактура) Тогда
					ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Для ввода корректировочной счет-фактуры у документа основания должна быть введена счет-фактура.'"));
					ОшибкаПроверки = Истина;
				КонецЕсли;
				
				Если Не ОшибкаПроверки Тогда
					ПараметрыСчетФактуры = СчетаФактурыУНФВызовСервера.СоздатьСчетФактуру(Объект.Ссылка, Объект.Дата);
					СчетФактураСоздана = Истина;
				КонецЕсли;
				
			Иначе
				
				ПараметрыСчетФактуры = СчетаФактурыУНФ.СоздатьСчетФактуру(Объект.Ссылка, Объект.ДатаВходящегоДокумента, Объект.НомерВходящегоДокумента);
				СчетФактураСоздана = Истина;
				
			КонецЕсли;
			
			Если СчетФактураСоздана Тогда
				КэшЗначений.Вставить("СчетФактураСсылка", ?(ТипЗнч(ПараметрыСчетФактуры) = Тип("Структура"), ПараметрыСчетФактуры.Ссылка, Неопределено));
				
				Элементы.СчетФактураНадпись.Заголовок = РаботаСФормойДокументаКлиентСервер.СформироватьНадписьСчетФактура(КэшЗначений.СчетФактураСсылка, Истина,
				, Объект.ЭтоУниверсальныйДокумент, Объект.ПокупателюВыставляетсяКорректировочныйСчетФактура);
			КонецЕсли;
			
		Иначе
			
			Если ТипЗнч(СчетФактураСсылка) = Тип("Структура") Тогда
				КэшЗначений.Вставить("СчетФактураСсылка", СчетФактураСсылка.Ссылка);
			ИначеЕсли ТипЗнч(СчетФактураСсылка) = Тип("ДокументСсылка.СчетФактураПолученный") Или ТипЗнч(СчетФактураСсылка) = Тип("ДокументСсылка.СчетФактура") Тогда
				КэшЗначений.Вставить("СчетФактураСсылка", СчетФактураСсылка);
			Иначе
				КэшЗначений.Вставить("СчетФактураСсылка", Неопределено);
			КонецЕсли;
			
			Элементы.СчетФактураНадпись.Заголовок = РаботаСФормойДокументаКлиентСервер.СформироватьНадписьСчетФактура(КэшЗначений.СчетФактураСсылка, Истина,
			, Объект.ЭтоУниверсальныйДокумент, Объект.ПокупателюВыставляетсяКорректировочныйСчетФактура);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидОперацииВозврата()
	
	ВидОперацииВозврата = "";
	
	Если НЕ Параметры.Свойство("ВидОперации", ВидОперацииВозврата) Тогда
		Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя");
		Возврат;
	КонецЕсли;
	
	Если ВидОперацииВозврата = "ВозвратОтКомиссионера" Тогда
		Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтКомиссионера");
	ИначеЕсли ВидОперацииВозврата = "ВозвратОтПереработчика" Тогда
		Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПереработчика");
	ИначеЕсли ВидОперацииВозврата = "ВозвратСОтветХранения" Тогда
		Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратСОтветХранения");
	Иначе
		Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПризнакиИспользованияСерийПриИзмененииКлючевыхРеквизитов()
	ДополнительныеСвойства = Новый Структура("ИзменениеКлючевыхРеквизитов", Истина);
	СерииНоменклатурыУНФ.ЗаполнитьПризнакиИспользованияСерий(Объект, ДополнительныеСвойства);
КонецПроцедуры

