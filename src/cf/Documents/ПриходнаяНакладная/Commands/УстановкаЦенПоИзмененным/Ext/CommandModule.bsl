
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если ТипЗнч(ПараметрКоманды) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			
		ДанныеЗаполнения = Новый Структура;
		ДанныеЗаполнения.Вставить("ДокументОснование", ПараметрКоманды);
		ДанныеЗаполнения.Вставить("ОтображатьНаценку", Истина); 
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Основание", ДанныеЗаполнения);
		ПараметрыФормы.Вставить("ЗаполнениеПоИзменениямЦенПоставщика", Истина);
		
		ОткрытьФорму("Документ.УстановкаЦенНоменклатуры.ФормаОбъекта", ПараметрыФормы, 
			ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, 
				ПараметрыВыполненияКоманды.Окно, ПараметрыВыполненияКоманды.НавигационнаяСсылка);
			
	КонецЕсли;
	
КонецПроцедуры    

#КонецОбласти  



