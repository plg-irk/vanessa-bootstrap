&НаСервере
Процедура Подключаемый_ОтборПриИзмененииНаСервере(ЭлементИмя, ЭлементРодительИмя)
	
	РаботаСОтборами.Подключаемый_ОтборПриИзменении(ЭтотОбъект, ЭлементИмя, ЭлементРодительИмя);
	
КонецПроцедуры

// @skip-warning
&НаКлиенте
Процедура Подключаемый_ОтборОчистка(Элемент)
	
	Подключаемый_ОтборОчисткаНаСервере(Элемент.Имя, Элемент.Родитель.Имя)
	
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ОтборОчисткаНаСервере(ЭлементИмя, ЭлементРодительИмя)
	
	РаботаСОтборами.Подключаемый_ОтборОчистка(ЭтотОбъект, ЭлементИмя);

КонецПроцедуры

&НаКлиенте
Процедура СброситьВсеОтборы(Команда)
	РаботаСОтборамиКлиент.СброситьОтборПоПериоду(ЭтотОбъект, "Список", "Дата");
	СброситьВсеМеткиОтбораНаСервере();
КонецПроцедуры

&НаСервере
Процедура СброситьВсеМеткиОтбораНаСервере()
	РаботаСОтборами.УдалитьМеткиОтбораСервер(ЭтотОбъект, Список);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбработкаЗаписиРассылки(ИмяСобытия)
	
	Если ИмяСобытия <> "Запись_МассоваяРассылка" Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.Список.Обновить();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтправкиРассылок(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия <> "МассовыеРассылки_Отправить" Тогда
		Возврат;
	КонецЕсли;
	
	Если Параметр.КоличествоОтправленныхРассылок = 1 Тогда
		
		ЗаголовокОповещения = НСтр("ru = 'Отправлена 1 рассылка'");
		
	Иначе
		
		Шаблон = НСтр("ru = ';%1 рассылка;;%1 рассылки;%1 рассылок;%1 рассылка'");
		КоличествоРассылокСОписанием = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
		Шаблон, Параметр.КоличествоОтправленныхРассылок);
		ЗаголовокОповещения = СтрШаблон(НСтр("ru = 'Отправлено %1'"), КоличествоРассылокСОписанием);
		
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаОповещенияПослеОтправкиРассылок", ЭтотОбъект);
	
	Если Параметр.Состояние = ПредопределенноеЗначение("Перечисление.СостоянияОтправкиРассылки.ОшибкаОтправки") Тогда
		
		Пояснение = НСтр("ru = 'При отправке рассылок происходили ошибки'");
		Картинка = БиблиотекаКартинок.Ошибка32;
		
	ИначеЕсли Параметр.Состояние =
		ПредопределенноеЗначение("Перечисление.СостоянияОтправкиРассылки.ОтправленоЧастично") Тогда
		
		Пояснение = НСтр("ru = 'При отправке рассылок происходили ошибки'");
		Картинка = БиблиотекаКартинок.Предупреждение32;
		
	Иначе
		
		Пояснение = НСтр("ru = 'Список рассылок'");
		Картинка = БиблиотекаКартинок.ПолучитьОтправитьПочту;
		
	КонецЕсли;
	
	ПоказатьОповещениеПользователя(
	ЗаголовокОповещения,
	ОписаниеОповещения,
	Пояснение,
	Картинка);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещенияПослеОтправкиРассылок(ДополнительныеПараметры) Экспорт
	
	Элементы.Список.Обновить();
	ОткрытьФорму("Документ.МассоваяРассылка.ФормаСписка");
	
КонецПроцедуры

&НаСервере
Процедура НастроитьРежимВыбораФормы()
	
	Элементы.Список.РежимВыбора = Параметры.РежимВыбора;
	Элементы.Список.МножественныйВыбор = ?(Параметры.ЗакрыватьПриВыборе = Неопределено, Ложь, Не Параметры.ЗакрыватьПриВыборе);
	Если Параметры.РежимВыбора Тогда
		КлючНазначенияИспользования = КлючНазначенияИспользования + "ВыборПодбор";
		РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
	Иначе
		КлючНазначенияИспользования = КлючНазначенияИспользования + "Список";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьЭлементыФормыПриСоздании()
	
	Элементы.КомандыСоздатьПодменю.Видимость = ИспользоватьМассовыеРассылкиИнтеграция;
	Элементы.ПредставлениеСервиса.Видимость = ИспользоватьМассовыеРассылкиИнтеграция;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаСоздать", "Видимость", НЕ ИспользоватьМассовыеРассылкиИнтеграция);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаОтборСервисРассылки", "Видимость", ИспользоватьМассовыеРассылкиИнтеграция);
	
	Если Не ИспользоватьМассовыеРассылкиИнтеграция Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ПравоДоступа("Редактирование", Метаданные.Документы.МассоваяРассылка) Тогда
		Элементы.СоздатьРассылкуСервиса.Видимость = Ложь;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ОткрытьОчередьРассылок", "Видимость", ЕстьРассылкиУНФ());
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КонтекстноеМенюОткрытьОчередьРассылок", "Видимость", ЕстьРассылкиУНФ());
	
	ПредставлениеСервиса = МассовыеРассылкиИнтеграция.ПредставлениеСервиса(СервисМассовойРассылки);
	Элементы.СоздатьРассылкуСервиса.Заголовок = СтрШаблон(НСтр("ru='Рассылка %1'"), ПредставлениеСервиса);
	
КонецПроцедуры

&НаСервере
Функция ЕстьРассылкиУНФ()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	МассоваяРассылка.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.МассоваяРассылка КАК МассоваяРассылка
	|ГДЕ
	|	МассоваяРассылка.СервисМассовойРассылки = ЗНАЧЕНИЕ(Перечисление.СервисыМассовыхРассылок.ПустаяСсылка)";
	
	Результат = Запрос.Выполнить();
	
	Возврат Не Результат.Пустой();
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция КодСобственнаяРассылка()
	
	Возврат "УНФ";
	
КонецФункции

&НаСервере
Процедура ЗаполнитьЗначенияОтборов()
	
	Элементы.ОтборСервисРассылки.СписокВыбора.Очистить();
	Элементы.ОтборСервисРассылки.СписокВыбора.Добавить(КодСобственнаяРассылка(), НСтр("ru='1С:УНФ'"));
	Элементы.ОтборСервисРассылки.СписокВыбора.Добавить(СервисМассовойРассылки);
	
КонецПроцедуры

