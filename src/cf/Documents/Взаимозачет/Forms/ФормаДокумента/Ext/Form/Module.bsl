&НаКлиенте
Процедура ПодборРасчетовСПрочимиКонтрагентами(Команда)
	
	ТекКонтрагент = ?(Объект.ВидПрочегоВзаимозачета = ПредопределенноеЗначение("Перечисление.ВидыПрочегоВзаимозачета.ДолгПрочегоКонтрагентаИДолгПередПоставщиком"), Объект.КонтрагентИсточник, Объект.Контрагент);
	Если НЕ ЗначениеЗаполнено(ТекКонтрагент) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для использования подбора необходимо заполнить контрагента'"));
		Возврат;
	КонецЕсли;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийВзаимозачет.КорректировкаДолгаПрочегоКонтрагента") Тогда
		АдресТЧВХранилище = ПоместитьПрочиеРасчетыВХранилище();
	Иначе
		Если Объект.ВидПрочегоВзаимозачета = ПредопределенноеЗначение("Перечисление.ВидыПрочегоВзаимозачета.ДолгПокупателяИДолгПрочемуКонтрагенту") Тогда
			АдресТЧВХранилище = ПоместитьКредиторВХранилище();
		Иначе
			АдресТЧВХранилище = ПоместитьДебиторВХранилище();
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыПодбора = Новый Структура;
	ПараметрыПодбора.Вставить("АдресДебиторВХранилище", АдресТЧВХранилище);
	ПараметрыПодбора.Вставить("Компания", Компания);
	ПараметрыПодбора.Вставить("Дата", Объект.Дата);
	ПараметрыПодбора.Вставить("Контрагент", ТекКонтрагент);
	ПараметрыПодбора.Вставить("Ссылка", Объект.Ссылка);
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийВзаимозачет.КорректировкаДолгаПрочегоКонтрагента") Тогда
		ПараметрыПодбора.Вставить("СчетУчета", Неопределено);
	Иначе
		ПараметрыПодбора.Вставить("СчетУчета", Объект.КорреспонденцияПрочиеРасчеты);
	КонецЕсли;
	ПараметрыПодбора.Вставить("ВидПрочегоВзаимозачета", Объект.ВидПрочегоВзаимозачета);
	
	ОткрытьФорму("ОбщаяФорма.ФормаПодбораПрочихДолгов", ПараметрыПодбора, , , , ,
		Новый ОписаниеОповещения("ПодборРасчетовСПрочимиКонтрагентамиЗавершение", ЭтотОбъект,
		Новый Структура("АдресДебиторВХранилище", АдресТЧВХранилище)));
	
КонецПроцедуры

&НаКлиенте
Процедура ПодборРасчетовСПрочимиКонтрагентамиЗавершение(Результат1, ДополнительныеПараметры) Экспорт
	
	АдресДебиторВХранилище = ДополнительныеПараметры.АдресДебиторВХранилище;
	
	Результат = Результат1;
	Если Результат = КодВозвратаДиалога.OK Тогда
		Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийВзаимозачет.КорректировкаДолгаПрочегоКонтрагента") Тогда
			ПолучитьПрочиеРасчетыИзХранилища(АдресДебиторВХранилище);
		Иначе
			Если Объект.ВидПрочегоВзаимозачета = ПредопределенноеЗначение("Перечисление.ВидыПрочегоВзаимозачета.ДолгПокупателяИДолгПрочемуКонтрагенту") Тогда
				ПолучитьКредиторИзХранилища(АдресДебиторВХранилище);
			Иначе
				ПолучитьДебиторИзХранилища(АдресДебиторВХранилище);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик команды ЗаполнитьРасчетыСКонтрагентом.
//
&НаКлиенте
Процедура ЗаполнитьРасчетыСКонтрагентом(Команда)
	
	ИмяТекущейСтраницы = Элементы.Страницы.ТекущаяСтраница.Имя;
	
	ЗадаватьВопрос =
		ИмяТекущейСтраницы = "РасчетыСДебитором" И Объект.Дебитор.Количество() > 0
		Или ИмяТекущейСтраницы = "РасчетыСКредитором" И Объект.Кредитор.Количество() > 0
		Или ИмяТекущейСтраницы = "РасчетыСПрочимКонтрагентом" И Объект.ПрочиеРасчеты.Количество() > 0;
	
	Если ЗадаватьВопрос Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ЗаполнитьРасчетыСКонтрагентомЗавершение", ЭтотОбъект), 
			НСтр("ru='Табличная часть будет полностью перезаполнена. Продолжить?'"),
			РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗаполнитьРасчетыСКонтрагентомНаСервере();
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРасчетыСКонтрагентомЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Ответ = Результат;
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	Объект.Кредитор.Очистить();
	
	ЗаполнитьРасчетыСКонтрагентомНаСервере();
		
КонецПроцедуры // ЗаполнитьРасчетыСКонтрагентом()

&НаСервере
Процедура ЗаполнитьРасчетыСКонтрагентомНаСервере()
	
	Документ = РеквизитФормыВЗначение("Объект");
	Документ.ЗаполнитьРасчетыСКонтрагентом(Элементы.Страницы.ТекущаяСтраница.Имя);
	ЗначениеВРеквизитФормы(Документ, "Объект");
	Модифицированность = Истина;
	
КонецПроцедуры // ЗаполнитьРасчетыСКонтрагентомНаСервере()

