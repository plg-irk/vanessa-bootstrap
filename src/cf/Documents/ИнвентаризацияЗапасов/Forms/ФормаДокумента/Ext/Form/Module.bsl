&НаКлиенте
Процедура ОткрытьФормуНастройки(ПередаватьВидДокумента)

	// 1. Формируем структуру параметров для заполнения формы "Настройка документа".
	ПараметрыФормы = Новый Структура;
		
	СтруктураДоступности = Новый Структура("ПоложениеЯчейки", Ложь);
	
	Если Элементы.Ячейка.Видимость Или Элементы.ЗапасыЯчейка.Видимость Тогда
		ПараметрыФормы.Вставить("ПоложениеЯчейки", Объект.ПоложениеЯчейки);
		СтруктураДоступности.ПоложениеЯчейки = Истина;
	Иначе
		ПараметрыФормы.Вставить("ПоложениеЯчейки", Объект.ПоложениеЯчейки);
	КонецЕсли;
		
	Если ПередаватьВидДокумента Тогда
		ПараметрыФормы.Вставить("ВидДокумента", НСтр("ru = 'Инвентаризация запасов'"));
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.ШапкаТабличнаяЧасть", ПараметрыФормы, , , , ,
		Новый ОписаниеОповещения("ШапкаТабличнаяЧастьЗавершение", ЭтотОбъект));

	КонецПроцедуры

&НаКлиенте

&НаКлиенте
Процедура ШапкаТабличнаяЧастьЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	СтруктураНастройкаДокумента = Результат;

	Если ТипЗнч(СтруктураНастройкаДокумента) = Тип("Структура") И СтруктураНастройкаДокумента.БылиВнесеныИзменения Тогда

		ОбновитьФорму = Ложь;				
	
		Если Результат.Свойство("ПоложениеЯчейки")
		И Объект.ПоложениеЯчейки <> Результат.ПоложениеЯчейки Тогда
		Объект.ПоложениеЯчейки = Результат.ПоложениеЯчейки;
		
		Если Объект.ПоложениеЯчейки = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти") Тогда
			Для Каждого СтрокаТабличнойЧасти Из Объект.Запасы Цикл
				СтрокаТабличнойЧасти.Ячейка = Объект.Ячейка;
			КонецЦикла;
		Иначе
			Если Объект.Запасы.Количество() Тогда
				Объект.Ячейка = Объект.Запасы[0].Ячейка;
			КонецЕсли;
		КонецЕсли;
		
		КонецЕсли;
		
		УстановитьВидимостьЯчейки(ЭтотОбъект, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьЯчейки(Форма, ШапкаТабличнаяЧасть = Ложь) 
	
	Объект = Форма.Объект;
	ЭлементыФормы = Форма.Элементы;
	УчетПоЯчейкам = Форма.УчетПоЯчейкам;
		
	Если НЕ УчетПоЯчейкам Тогда
		ЭлементыФормы.Ячейка.Видимость = Ложь;
		ЭлементыФормы.ЗапасыЯчейка.Видимость = Ложь;
		ЭлементыФормы.СтруктурнаяЕдиница.АвтоМаксимальнаяШирина = Истина;
		Возврат;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Объект.СтруктурнаяЕдиница) Тогда
		
		Если Не ЗначениеЗаполнено(Объект.ПоложениеЯчейки) 
			Или Объект.ПоложениеЯчейки = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке") Тогда
			ЭлементыФормы.Ячейка.Видимость = Истина;
			ЭлементыФормы.ЗапасыЯчейка.Видимость = Ложь;
		
			Если ШапкаТабличнаяЧасть Тогда
				
				Если ЗначениеЗаполнено(Объект.Ячейка) Тогда
					ЯчейкаВСтроке = Объект.Ячейка;
				Иначе
					ЯчейкаВСтроке = Неопределено;
				КонецЕсли;
				
				Для Каждого СтрокаЗапасов Из Объект.Запасы Цикл
					СтрокаЗапасов.Ячейка = ЯчейкаВСтроке;
				КонецЦикла;
				
			КонецЕсли;
			
		Иначе
			ЭлементыФормы.ЗапасыЯчейка.Видимость = Истина;
			ЭлементыФормы.Ячейка.Видимость = Ложь;
			
			Если ШапкаТабличнаяЧасть Тогда
				Объект.Ячейка = Неопределено;
			КонецЕсли;
			
		КонецЕсли;
	Иначе
		ЭлементыФормы.ЗапасыЯчейка.Видимость = Ложь;
		ЭлементыФормы.Ячейка.Видимость = Истина;
		
		Если ШапкаТабличнаяЧасть Тогда
			Для Каждого СтрокаЗапасов Из Объект.Запасы Цикл
				СтрокаЗапасов.Ячейка = Неопределено;
			КонецЦикла;
			Объект.Ячейка = Неопределено;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура СкопироватьНастройкиВремениДокументаИсточника(ДокументИсточник)
	
	ДатаВремяОснования = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументИсточник, "Дата");
	
	Если ДатаВремяОснования = НачалоДня(ДатаВремяОснования) Тогда
		ВариантЗаполненияДатыИнвентаризации = "НаУтро";
	ИначеЕсли ДатаВремяОснования = КонецДня(ДатаВремяОснования) Тогда
		ВариантЗаполненияДатыИнвентаризации = "НаВечер";
	Иначе
		ВариантЗаполненияДатыИнвентаризации = "НаВремя";
	КонецЕсли;
	
	Если ВариантЗаполненияДатыИнвентаризации = "НаУтро" Тогда
		Элементы.ДекорацияВремяИнвентаризации.Заголовок = НСтр("ru = 'на утро'");
	ИначеЕсли ВариантЗаполненияДатыИнвентаризации = "НаВечер" Тогда
		Элементы.ДекорацияВремяИнвентаризации.Заголовок = НСтр("ru = 'на вечер'");
	Иначе
		Элементы.ДекорацияВремяИнвентаризации.Заголовок = НСтр("ru = 'на время'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗначениеПараметров(Настройки)
	
	Параметр = Настройки.ПараметрыДанных.Элементы.Найти("Организация");
	Если Не Параметр = Неопределено Тогда
		Параметр.Значение = Компания;
	КонецЕсли;
	
	Параметр = Настройки.ПараметрыДанных.Элементы.Найти("СтруктурнаяЕдиница");
	Если Не Параметр = Неопределено Тогда
		Параметр.Значение = Объект.СтруктурнаяЕдиница;
	КонецЕсли;
	
//	Параметр = НастройкаКомпановкиДанных.Настройки.ПараметрыДанных.Элементы.Найти("УчетПоЯчейкам");
// 	Если Не Параметр = Неопределено Тогда
		Если Объект.ПоложениеЯчейки = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке Тогда
//		Параметр.Значение = УчетПоЯчейкам;

		Параметр = НастройкаКомпановкиДанных.Настройки.ПараметрыДанных.Элементы.Найти("Ячейка");
			Если Не Параметр = Неопределено Тогда
				
				Параметр.Использование = ЗначениеЗаполнено(Объект.Ячейка);
				Параметр.Значение = Объект.Ячейка;
			КонецЕсли;
		Для Каждого Элемент из НастройкаКомпановкиДанных.Настройки.Выбор.Элементы Цикл
