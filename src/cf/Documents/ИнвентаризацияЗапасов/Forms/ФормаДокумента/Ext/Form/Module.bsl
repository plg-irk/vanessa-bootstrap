		Иначе
//		
		Параметр = НастройкаКомпановкиДанных.Настройки.ПараметрыДанных.Элементы.Найти("Ячейка");
			Если Не Параметр = Неопределено Тогда
				Параметр.Использование = Ложь;
				Параметр.Значение = Справочники.Ячейки.ПустаяСсылка();
			КонецЕсли;
		Для Каждого Элемент из НастройкаКомпановкиДанных.Настройки.Выбор.Элементы Цикл
