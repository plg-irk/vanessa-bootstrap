#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ДанныеЗаполнения = СформироватьЛанныеЗаполнения(ПараметрКоманды);
	МассивДанных = ДанныеЗаполнения.МассивДанных;
	ПредставлениеРазличия = ДанныеЗаполнения.ПредставленияРазличияКлючевычРеквизитов;
	
	Если МассивДанных.Количество() = 1 Тогда
		
		ПараметрыФормы = Новый Структура("Основание", МассивДанных[0]);
		ОткрытьФорму("Документ.ЗаказНаПеремещение.Форма.ФормаДокумента", 
			ПараметрыФормы, 
			ПараметрыВыполненияКоманды.Источник, 
			ПараметрыВыполненияКоманды.Уникальность, 
			ПараметрыВыполненияКоманды.Окно, 
			ПараметрыВыполненияКоманды.НавигационнаяСсылка);
		
	ИначеЕсли МассивДанных.Количество() > 1 Тогда
		
		Если ПараметрКоманды.Количество() = 1 Тогда
			ТекстСообщения = НСтр("ru = 'В табличной части документа указаны разные склады. Сформировать несколько заказов на перемещение?'");
		Иначе
			ТекстСообщения = НСтр("ru = 'В выбранных документах отличаются ключевые реквизиты (%1). Сформировать несколько заказов на перемещение?'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, ПредставлениеРазличия);
		КонецЕсли;
		
		ДополнительныеПараметры = Новый Структура("МассивДанных", МассивДанных);
		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьЗаказыНаПеремещения", ЭтотОбъект, ДополнительныеПараметры);
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстСообщения, РежимДиалогаВопрос.ДаНет);
		
	Иначе
		
		ТекстСообщения = НСтр("ru = 'Нет данных для формирования заказов на перемещение'");
		ПоказатьПредупреждение(, ТекстСообщения);
			
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция СформироватьЛанныеЗаполнения(МассивОснований)
	Возврат Документы.ЗаказНаПроизводство.СформироватьДанныеЗаполнения(МассивОснований);
КонецФункции

&НаКлиенте
Процедура СоздатьЗаказыНаПеремещения(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	МассивДанных = ДополнительныеПараметры.МассивДанных;
	СозданныеДокументы = СформироватьИЗаписатьЗаказыНаПеремещение(МассивДанных);
	Текст = НСтр("ru='Создание:'");
	
	Для Каждого СтрокаДокумент Из СозданныеДокументы Цикл
		ПоказатьОповещениеПользователя(Текст, ПолучитьНавигационнуюСсылку(СтрокаДокумент), СтрокаДокумент, БиблиотекаКартинок.Информация32);
	КонецЦикла;
	
	ОткрытьФорму("Документ.ЗаказНаПеремещение.ФормаСписка");
	
КонецПроцедуры

&НаСервере
Функция СформироватьИЗаписатьЗаказыНаПеремещение(МассивДанных)
	
	СозданныеДокументы = Новый Массив();
	
	Для Каждого СтрокаОснование Из МассивДанных Цикл
		
		НовыйДокумент = Документы.ЗаказНаПеремещение.СоздатьДокумент();
		НовыйДокумент.Дата = ТекущаяДатаСеанса();
		НовыйДокумент.Заполнить(СтрокаОснование);
		НовыйДокумент.Записать();
		СозданныеДокументы.Добавить(НовыйДокумент.Ссылка);
		
	КонецЦикла;
	
	Возврат СозданныеДокументы;
	
КонецФункции

#КонецОбласти



