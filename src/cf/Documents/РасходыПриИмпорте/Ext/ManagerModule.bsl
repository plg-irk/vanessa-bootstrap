	Запрос.Текст = КурсовыеРазницыУНФ.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыСПрочимиКонтрагентами(Запрос.МенеджерВременныхТаблиц, Ложь, НомерЗапроса);
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПрочимиКонтрагентами", МассивРезультатов[НомерЗапроса].Выгрузить());
	
КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаДоходыИРасходы(ДокументСсылкаДополнительныеРасходы, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК НомерСтроки,
	|	ТаблицаДокумента.Дата КАК Период,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	НЕОПРЕДЕЛЕНО КАК СтруктурнаяЕдиница,
	|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее) КАК НаправлениеДеятельности,
	|	НЕОПРЕДЕЛЕНО КАК ЗаказПокупателя,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.СуммаКурсовойРазницы > 0
	|			ТОГДА &ОтрицательнаяКурсоваяРазницаСчетУчета
	|		ИНАЧЕ &ПоложительнаяКурсоваяРазницаСчетУчета
	|	КОНЕЦ КАК СчетУчета,
	|	ТаблицаДокумента.Валюта КАК Аналитика,
	|	&КурсоваяРазница КАК СодержаниеПроводки,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.СуммаКурсовойРазницы > 0
	|			ТОГДА 0
	|		ИНАЧЕ -ТаблицаДокумента.СуммаКурсовойРазницы
	|	КОНЕЦ КАК СуммаДоходов,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.СуммаКурсовойРазницы > 0
	|			ТОГДА ТаблицаДокумента.СуммаКурсовойРазницы
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СуммаРасходов,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.СуммаКурсовойРазницы > 0
	|			ТОГДА ТаблицаДокумента.СуммаКурсовойРазницы
	|		ИНАЧЕ -ТаблицаДокумента.СуммаКурсовойРазницы
	|	КОНЕЦ КАК Сумма
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТаблицаКурсовыхРазницРасчетыСПоставщиками.Дата КАК Дата,
	|		ТаблицаКурсовыхРазницРасчетыСПоставщиками.Организация КАК Организация,
	|		ТаблицаКурсовыхРазницРасчетыСПоставщиками.Валюта КАК Валюта,
	|		СУММА(ТаблицаКурсовыхРазницРасчетыСПоставщиками.СуммаКурсовойРазницы) КАК СуммаКурсовойРазницы
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ТаблицаДокумента.Дата КАК Дата,
	|			ТаблицаДокумента.Организация КАК Организация,
	|			ТаблицаДокумента.Валюта КАК Валюта,
	|			ТаблицаДокумента.СуммаКурсовойРазницы КАК СуммаКурсовойРазницы
	|		ИЗ
	|			ВременнаяТаблицаКурсовыхРазницРасчетыСПрочимиКонтрагентами КАК ТаблицаДокумента
	|		ГДЕ
	|			ТаблицаДокумента.ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Долг)
	|		
	|		ОБЪЕДИНИТЬ ВСЕ
	|		
	|		ВЫБРАТЬ
	|			ТаблицаДокумента.Дата,
	|			ТаблицаДокумента.Организация,
	|			ТаблицаДокумента.Валюта,
	|			ТаблицаДокумента.СуммаКурсовойРазницы
	|		ИЗ
	|			ВременнаяТаблицаКурсовыхРазницРасчетыСПрочимиКонтрагентами КАК ТаблицаДокумента
	|		ГДЕ
	|			ТаблицаДокумента.ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс)) КАК ТаблицаКурсовыхРазницРасчетыСПоставщиками
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ТаблицаКурсовыхРазницРасчетыСПоставщиками.Дата,
	|		ТаблицаКурсовыхРазницРасчетыСПоставщиками.Организация,
	|		ТаблицаКурсовыхРазницРасчетыСПоставщиками.Валюта
	|	
	|	ИМЕЮЩИЕ
	|		(СУММА(ТаблицаКурсовыхРазницРасчетыСПоставщиками.СуммаКурсовойРазницы) >= 0.005
	|			ИЛИ СУММА(ТаблицаКурсовыхРазницРасчетыСПоставщиками.СуммаКурсовойРазницы) <= -0.005)) КАК ТаблицаДокумента
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаТаможенныйШтраф.НомерСтроки,
	|	ТаблицаТаможенныйШтраф.Период,
	|	ТаблицаТаможенныйШтраф.Организация,
	|	НЕОПРЕДЕЛЕНО,
	|	ТаблицаТаможенныйШтраф.НаправлениеДеятельности,
	|	НЕОПРЕДЕЛЕНО,
	|	ТаблицаТаможенныйШтраф.СчетУчета,
	|	ТаблицаТаможенныйШтраф.АналитикаДоходовИРасходов,
	|	&ОтражениеРасходов,
	|	0,
	|	ТаблицаТаможенныйШтраф.СуммаШтраф,
	|	ТаблицаТаможенныйШтраф.СуммаШтраф
	|ИЗ
	|	ВременнаяТаблицаРасходы КАК ТаблицаТаможенныйШтраф
	|ГДЕ
	|	ТаблицаТаможенныйШтраф.СуммаШтраф > 0";
	
	Запрос.УстановитьПараметр("ПоложительнаяКурсоваяРазницаСчетУчета", ПланыСчетов.Управленческий.ПрочиеДоходы);
	Запрос.УстановитьПараметр("ОтрицательнаяКурсоваяРазницаСчетУчета", ПланыСчетов.Управленческий.ПрочиеРасходы);
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ru = 'Курсовая разница'"));
	Запрос.УстановитьПараметр("ОтражениеРасходов", НСтр("ru = 'Отражение расходов'"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДоходыИРасходы", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаДоходыИРасходы()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
// Параметры:
// 	ДокументСсылкаРасходыПриИмпорте - ДокументСсылка.РасходыПриИмпорте
// 	СтруктураДополнительныеСвойства - Структура - 
// 		см. ПроведениеДокументовУНФ.ИнициализироватьДополнительныеСвойстваДляПроведения, ДополнительныеСвойства
//
Процедура СформироватьТаблицаЖурналУчетаСчетовФактур(ДокументСсылкаРасходыПриИмпорте, СтруктураДополнительныеСвойства)

	Организация = СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности;
	Период = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
	ВалютаРеглУчета = СтруктураДополнительныеСвойства.НациональнаяВалюта;
	
	ТаблицаЗаписи = Новый ТаблицаЗначений;
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЖурналУчетаСчетовФактур", ТаблицаЗаписи);
	 
	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(Организация, Период);
	Если НЕ ПлательщикНДС
		И НЕ УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(Организация, Период) Тогда
		Возврат;
	КонецЕсли;
	
	НДСВключенВСтоимость = НЕ ПлательщикНДС И НЕ УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(Организация, Период);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаРасходыПриИмпорте);
	Запрос.УстановитьПараметр("ВалютаРеглУчета", ВалютаРеглУчета);
	Запрос.УстановитьПараметр("НДСВключенВСтоимость", НДСВключенВСтоимость);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасходыПриИмпорте.Ссылка КАК Ссылка,
	|	РасходыПриИмпорте.Дата КАК Период,
	|	РасходыПриИмпорте.ВалютаДокумента КАК ВалютаДокумента,
	|	РасходыПриИмпорте.Курс КАК КурсДокумента,
	|	РасходыПриИмпорте.Кратность КАК КратностьДокумента,
	|	РасходыПриИмпорте.НомерГТД КАК НомерГТД,
	|	РасходыПриИмпорте.Организация КАК Организация,
	|	РасходыПриИмпорте.Контрагент КАК Контрагент,
	|	РасходыПриИмпорте.ТаможенныйСбор КАК ТаможенныйСбор,
	|	&НДСВключенВСтоимость КАК НДСВключенВСтоимость
	|ПОМЕСТИТЬ Реквизиты
	|ИЗ
	|	Документ.РасходыПриИмпорте КАК РасходыПриИмпорте
	|ГДЕ
	|	РасходыПриИмпорте.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	Реквизиты.Период КАК Период,
	|	Реквизиты.ВалютаДокумента КАК ВалютаДокумента,
	|	Реквизиты.КурсДокумента КАК КурсДокумента,
	|	Реквизиты.КратностьДокумента КАК КратностьДокумента,
	|	Реквизиты.НомерГТД КАК НомерГТД,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.Контрагент КАК Контрагент,
	|	Реквизиты.ТаможенныйСбор КАК ТаможенныйСбор
	|ИЗ
	|	Реквизиты КАК Реквизиты";
	
	Реквизиты = Запрос.Выполнить().Выбрать();
	Если НЕ Реквизиты.Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеГТД = Справочники.НомераГТД.ДанныеНомераГТД(Реквизиты.НомерГТД);
	Если ЗначениеЗаполнено(ДанныеГТД.ДатаПринятия) Тогда
		ДатаСчетаФактуры = ДанныеГТД.ДатаПринятия;
	Иначе
		ДатаСчетаФактуры = Реквизиты.Период;
	КонецЕсли;
	Запрос.УстановитьПараметр("ДатаСчетаФактуры", ДатаСчетаФактуры);
	
	Если Реквизиты.ВалютаДокумента = ВалютаРеглУчета Тогда
		КоэффициентТаможеннаяСтоимостьРуб = 1;
	Иначе
		КоэффициентТаможеннаяСтоимостьРуб = Реквизиты.КурсДокумента / Реквизиты.КратностьДокумента;
	КонецЕсли;
	Запрос.УстановитьПараметр("КоэффициентТаможеннаяСтоимостьРуб", КоэффициентТаможеннаяСтоимостьРуб);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасходыПриИмпортеЗапасы.Ссылка КАК Ссылка,
	|	РасходыПриИмпортеЗапасы.НомерСтроки КАК НомерСтроки,
	|	РасходыПриИмпортеЗапасы.Номенклатура КАК Номенклатура,
	|	РасходыПриИмпортеЗапасы.Характеристика КАК Характеристика,
	|	РасходыПриИмпортеЗапасы.Партия КАК Партия,
	|	РасходыПриИмпортеЗапасы.Количество КАК Количество,
	|	РасходыПриИмпортеЗапасы.ФактурнаяСтоимость КАК ФактурнаяСтоимостьПоДокументу,
	|	РасходыПриИмпортеЗапасы.СуммаПошлины КАК СуммаПошлины,
	|	РасходыПриИмпортеЗапасы.СуммаНДС КАК СуммаНДС,
	|	РасходыПриИмпортеЗапасы.ДокументПартии КАК ДокументПартии,
	|	РасходыПриИмпортеЗапасы.СтранаПроисхождения КАК СтранаПроисхождения,
	|	РасходыПриИмпортеЗапасы.НомерРаздела КАК НомерРаздела
	|ПОМЕСТИТЬ ТоварыДокумента
	|ИЗ
	|	Документ.РасходыПриИмпорте.Запасы КАК РасходыПриИмпортеЗапасы
	|ГДЕ
	|	РасходыПриИмпортеЗапасы.Ссылка = &Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерРаздела
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасходыПриИмпортеРазделы.Ссылка КАК Ссылка,
	|	РасходыПриИмпортеРазделы.НомерСтроки КАК НомерСтроки,
	|	РасходыПриИмпортеРазделы.ТаможеннаяСтоимость КАК ТаможеннаяСтоимость,
	|	РасходыПриИмпортеРазделы.СтавкаПошлины КАК СтавкаПошлины,
	|	РасходыПриИмпортеРазделы.СуммаПошлины КАК СуммаПошлины,
	|	ЛОЖЬ КАК НДСВВалюте,
	|	РасходыПриИмпортеРазделы.СтавкаНДС КАК СтавкаНДС,
	|	РасходыПриИмпортеРазделы.СуммаНДС КАК СуммаНДС,
	|	РасходыПриИмпортеРазделы.НомерСтроки КАК НомерРаздела
	|ПОМЕСТИТЬ РазделыДокумента
	|ИЗ
	|	Документ.РасходыПриИмпорте.Разделы КАК РасходыПриИмпортеРазделы
	|ГДЕ
	|	РасходыПриИмпортеРазделы.Ссылка = &Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) КАК Посредник,
	|	ПриходнаяНакладная.Контрагент КАК Поставщик
	|ПОМЕСТИТЬ ТаблицаПоставщик
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
	|		ПО ТоварыДокумента.ДокументПартии = ПриходнаяНакладная.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РазделыДокумента КАК РазделыДокумента
	|		ПО ТоварыДокумента.НомерРаздела = РазделыДокумента.НомерСтроки
	|ГДЕ
	|	НЕ РазделыДокумента.НДСВВалюте
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыДокумента.Номенклатура КАК Номенклатура,
	|	ТоварыДокумента.Характеристика КАК Характеристика,
	|	ТоварыДокумента.Партия КАК Партия,
	|	СУММА(ТоварыДокумента.Количество) КАК Количество,
	|	СУММА(ТоварыДокумента.ФактурнаяСтоимостьПоДокументу) КАК ФактурнаяСтоимостьПоДокументу,
	|	ТоварыДокумента.ДокументПартии КАК ДокументПартии,
	|	СУММА(ВЫБОР
	|			КОГДА Реквизиты.НДСВключенВСтоимость
	|				ТОГДА ВЫРАЗИТЬ(ТоварыДокумента.СуммаНДС + ТоварыДокумента.СуммаПошлины КАК ЧИСЛО(15, 2))
	|			ИНАЧЕ ТоварыДокумента.СуммаПошлины
	|		КОНЕЦ) КАК НДСИПошлины
	|ПОМЕСТИТЬ ТоварыПартии
	|ИЗ
	|	ТоварыДокумента КАК ТоварыДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Реквизиты КАК Реквизиты
	|		ПО (ИСТИНА)
	|СГРУППИРОВАТЬ ПО
	|	ТоварыДокумента.ДокументПартии,
	|	ТоварыДокумента.Номенклатура,
	|	ТоварыДокумента.Характеристика,
	|	ТоварыДокумента.Партия
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументПартии,
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыПартии.Номенклатура КАК Номенклатура,
	|	ТоварыПартии.Характеристика КАК Характеристика,
	|	ТоварыПартии.Партия КАК Партия,
	|	ТоварыПартии.ДокументПартии КАК ДокументПартии,
	|	СУММА(ТоварыПартии.ФактурнаяСтоимостьПоДокументу) КАК ФактурнаяСтоимостьПоДокументу
	|ПОМЕСТИТЬ ФактурнаяСтоимостьПредварительная
	|ИЗ
	|	ТоварыПартии КАК ТоварыПартии
	|ГДЕ
	|	ТоварыПартии.ДокументПартии > ЗНАЧЕНИЕ(Документ.ПриходнаяНакладная.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыПартии.Номенклатура,
