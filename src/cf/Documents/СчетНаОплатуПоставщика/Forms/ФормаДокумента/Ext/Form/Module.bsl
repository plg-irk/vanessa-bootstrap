	Если Контрагент <> Объект.Контрагент Тогда
		
		ОбработатьИзменениеКонтрагента();
		
	Иначе
		
		Объект.Договор = Договор; // Восстанавливаем автоматически очищенный договор.
		
	КонецЕсли;
	
