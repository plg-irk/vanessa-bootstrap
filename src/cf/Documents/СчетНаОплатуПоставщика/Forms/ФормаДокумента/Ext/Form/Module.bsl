	КонецЕсли;
	
	ПараметрыОбъекта = Новый Структура("ВидОперации", "СчетНаОплатуПоставщика");
	БыстрыеФормыУНФКлиент.ОткрытьБыструюФормуКонтрагента(Элемент, ВыбранноеЗначение, СтандартнаяОбработка, ПараметрыОбъекта);
	
КонецПроцедуры

