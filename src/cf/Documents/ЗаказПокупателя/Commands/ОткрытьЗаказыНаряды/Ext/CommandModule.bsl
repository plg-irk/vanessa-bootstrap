
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если ПараметрыВыполненияКоманды.Окно = Неопределено Тогда
		Источник = Неопределено;
		Уникальность = "ЗаказНаряд";
	Иначе
		Источник = ПараметрыВыполненияКоманды.Источник;
		Уникальность = ПараметрыВыполненияКоманды.Уникальность;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("ЗаказНаряд", Истина);
	Если ПараметрыВыполненияКоманды.Параметры <> Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ПараметрыФормы, ПараметрыВыполненияКоманды.Параметры);
	КонецЕсли;
	
	ОткрытьФорму("Документ.ЗаказПокупателя.ФормаСписка",
	ПараметрыФормы,
	Источник,
	Уникальность,
	ПараметрыВыполненияКоманды.Окно,
	ПараметрыВыполненияКоманды.НавигационнаяСсылка);
	
КонецПроцедуры

#КонецОбласти 

