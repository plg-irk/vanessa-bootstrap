#Область ТабличнаяЧастьПредоплата

&НаКлиенте
Процедура РедактироватьЗачетПредоплатыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	АдресПредоплатаВХранилище = ДополнительныеПараметры.АдресПредоплатаВХранилище;
	
	КодВозврата = Результат;
	Если КодВозврата = КодВозвратаДиалога.OK Тогда
		ПолучитьПредоплатаИзХранилища(АдресПредоплатаВХранилище);
	КонецЕсли;
	
КонецПроцедуры // РедактироватьЗачетПредоплаты()

&НаСервере
Процедура ПолучитьПредоплатаИзХранилища(АдресПредоплатаВХранилище)
	
	ТаблицаДляЗагрузки = ПолучитьИзВременногоХранилища(АдресПредоплатаВХранилище);
	РасчетыРаботаСФормамиВызовСервера.ВыполнитьКонтрольСуммыОплатыВТаблице(ЭтотОбъект, ИтогВсего, ТаблицаДляЗагрузки);
	Объект.Предоплата.Загрузить(ТаблицаДляЗагрузки);
	
	Элементы.ГруппаПредоплата.Заголовок = РаботаСФормойДокументаКлиентСервер.ПолучитьЗаголовокОплаты(Объект.СпособЗачетаПредоплаты, Объект.Предоплата);
	
КонецПроцедуры // ПолучитьПредоплатаИзХранилища()


#КонецОбласти

#Область АссистентУправления

&НаКлиенте
Процедура ВыполнитьДействиеСообщенияАссистента(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> АссистентУправленияКлиентСервер.КодДействияСообщенияВыполнитьДействие() Тогда
		Возврат;
	КонецЕсли;
	
	Действие = Неопределено;
	
	Если Не ТипЗнч(ДополнительныеПараметры) = Тип("Структура") И НЕ ТипЗнч(ДополнительныеПараметры) = Тип("ФиксированнаяСтруктура") Тогда
		Возврат;
	КонецЕсли;                                          
	
	Если ДополнительныеПараметры.Свойство("ДанныеСообщения") И 
		(ТипЗнч(ДополнительныеПараметры.ДанныеСообщения) = Тип("Структура") ИЛИ 
		ТипЗнч(ДополнительныеПараметры.ДанныеСообщения) = Тип("ФиксированнаяСтруктура")) Тогда
		
		Если НЕ ДополнительныеПараметры.ДанныеСообщения.Свойство("Действие", Действие) Тогда
			Возврат;
		КонецЕсли;
		
		Если Действие = "ИзменитьСостояние"  И ДополнительныеПараметры.ДанныеСообщения.Свойство("СостояниеЗаказа") Тогда
			
			Если Объект.СостояниеЗаказа <> ДополнительныеПараметры.ДанныеСообщения.СостояниеЗаказа Тогда
				
				ЗаблокироватьДанныеФормыДляРедактирования();
				
				Объект.СостояниеЗаказа = ДополнительныеПараметры.ДанныеСообщения.СостояниеЗаказа;
				Модифицированность = Истина;
				ОбработатьИзменениеСостоянияЗаказа();
				Записать();
				
			КонецЕсли;
			
		КонецЕсли;  
	ИначеЕсли ДополнительныеПараметры.Свойство("Данные") И ТипЗнч(ДополнительныеПараметры.Данные) = Тип("ХранилищеЗначения") Тогда
		
		ДанныеСообщенияКОтправке =  ПолучитьДанныеИзХранилища(ДополнительныеПараметры.Данные);
		Если Не ТипЗнч(ДанныеСообщенияКОтправке) = Тип("Структура") И НЕ ТипЗнч(ДанныеСообщенияКОтправке) = Тип("ФиксированнаяСтруктура") Тогда
			Возврат;
		КонецЕсли;                                          
		
		Если НЕ ДанныеСообщенияКОтправке.Свойство("Действие", Действие) Тогда
			Возврат;
		КонецЕсли;
		
		Действие = ДанныеСообщенияКОтправке.Действие;		
		Если Действие = "СоздатьОтправитьЭлектронноеПисьмо" Тогда
			ОтправитьОтложенноеПисьмо(ДанныеСообщенияКОтправке);
		КонецЕсли;
	КонецЕсли;
	
	ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОписаниеОповещения);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДанныеИзХранилища(Знач Хранилище)  
	
	ВложенноеЗначение = Хранилище.Получить();
	Если ТипЗнч(ВложенноеЗначение) = Тип("ХранилищеЗначения") Тогда
		ВложенноеЗначение = ВложенноеЗначение.Получить();	
	КонецЕсли;            
	
	Возврат ВложенноеЗначение;
	
КонецФункции   

&НаСервереБезКонтекста
Процедура ОтправитьОтложенноеПисьмо(ДанныеСообщенияКОтправке)
	
	Если Не ТипЗнч(ДанныеСообщенияКОтправке) = Тип("Структура") И НЕ ТипЗнч(ДанныеСообщенияКОтправке) = Тип("ФиксированнаяСтруктура") Тогда
		Возврат;
	КонецЕсли;                                          

	Если НЕ ДанныеСообщенияКОтправке.Свойство("ДополнительныеПараметрыИсходные") Тогда
		Возврат;
	КонецЕсли;      
	
	Если НЕ ДанныеСообщенияКОтправке.Свойство("Событие") Тогда
		Возврат;
	КонецЕсли;     
	
	Если НЕ ДанныеСообщенияКОтправке.Свойство("Предмет") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ДанныеСообщенияКОтправке.Свойство("Задача") Тогда
		Возврат;
	КонецЕсли;
	
	Предмет = ДанныеСообщенияКОтправке.Предмет;
	
	ДополнительныеПараметрыИсходные = ДанныеСообщенияКОтправке.ДополнительныеПараметрыИсходные; 
	Если Не ТипЗнч(ДополнительныеПараметрыИсходные) = Тип("Структура") И НЕ ТипЗнч(ДополнительныеПараметрыИсходные) = Тип("ФиксированнаяСтруктура") Тогда
		Возврат;
	КонецЕсли;  
	
	Если НЕ ДополнительныеПараметрыИсходные.Свойство("ДополнительныеПараметрыСобытия") Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметрыСобытия = ДополнительныеПараметрыИсходные.ДополнительныеПараметрыСобытия;
	ДополнительныеПараметрыСобытия.Вставить("ПовторныйВызов", Истина);
	
	АссистентУправления.ПриСрабатыванииСобытия(Предмет, ДанныеСообщенияКОтправке.Событие, Неопределено, ДополнительныеПараметрыСобытия);   
	АссистентУправления.ВыполнитьДействияЗадачи(Неопределено, "ИзменениеСостоянияЗаказаПокупателя", Предмет, ДанныеСообщенияКОтправке.Задача, ДополнительныеПараметрыСобытия);	
	ОбсужденияУНФ.ЗаписатьОтложенныеСообщенияВСистемуВзаимодействияСейчас(Предмет, АссистентУправления.ПользовательАссистент());	
	
КонецПроцедуры	        

#КонецОбласти

