&НаСервере
Функция ОбработатьРезультатИзмененияДанныхПоЗаявкам(РезультатИзменения)
	
	Результат = Новый Структура;
	Результат.Вставить("ДанныеКонтрагента", Неопределено);
	Результат.Вставить("КонтрагентИзменен", РезультатИзменения.КонтрагентИзменен);
	Результат.Вставить("ЛидИзменен", РезультатИзменения.ЛидИзменен);
	Результат.Вставить("ПереводЗаказаВЗаявку", РезультатИзменения.ПереводЗаказаВЗаявку);
	Результат.Вставить("ВидОперацииИзменен", РезультатИзменения.ВидОперацииИзменен);
	
	Если РезультатИзменения.КонтрагентИзменен Тогда
		ДанныеКонтрагента = КонтрагентПриИзмененииНаСервере();
		Результат.Вставить("ДанныеКонтрагента", ДанныеКонтрагента);
	КонецЕсли;
	
	Если Результат.ВидОперацииИзменен Тогда
		ОбновитьИнтерфейсПриИзмененииВидаОперацииПоЗаявкам();
		ПредыдущийВидОперации = Объект.ВидОперации;
	КонецЕсли;
	
	Если Результат.ЛидИзменен Тогда
		СвязанныйКонтрагентСЛидом = Справочники.Лиды.СвязанныйКонтрагент(Объект.Лид);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОбновитьИнтерфейсПриИзмененииВидаОперацииПоЗаявкам()
	
	НастроитьЭлементыПоСервисуДоставки();
	НастроитьЭлементыЯндексДоставки();
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект); // для обновления команд печати
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Функция ОбработкаОповещенияПриЗаписиВидаЗаказаПоЗаявкам(Параметр)
	
	Контрагент = Объект.Контрагент;
	
	ПараметрыОбработки = ПараметрыОбработкиОповещенияПриЗаписиВидаЗаказаПоЗаявкам(Параметр);
	Ответ = РаботаСЗаявками.ОбработкаОповещенияПриЗаписиВидаЗаказа(ПараметрыОбработки);
	
	Возврат ОбработатьРезультатИзмененияДанныхПоЗаявкам(Ответ);
	
КонецФункции

&НаСервере
Функция ПараметрыОбработкиОповещенияПриЗаписиВидаЗаказаПоЗаявкам(Параметр)
	
	ПараметрыИзмененияВидаОперации = ПараметрыИзмененияВидаОперацииПоЗаявкам();
	ПараметрыИзмененияВидаОперации.ИспользоватьЗаявки = Истина;
	ПараметрыИзмененияВидаОперации.ИзменятьВид = Ложь;
	
	Результат = Новый Структура;
	Результат.Вставить("Объект", Объект);
	Результат.Вставить("Ссылка", Параметр);
	Результат.Вставить("ПараметрыИзмененияВидаОперации", ПараметрыИзмененияВидаОперации);
	Результат.Вставить("ПараметрыИзмененияСостоянияЗаказа", ПараметрыИзмененияСостоянияЗаказаПоЗаявкам());
	Результат.Вставить("ПараметрыУстановкиСпискаВыбораВидаОперации", ПараметрыУстановкиСпискаВыбораВидаОперации());
	
	Возврат Результат;
	
КонецФункции

