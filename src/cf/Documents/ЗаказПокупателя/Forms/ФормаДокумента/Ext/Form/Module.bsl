Процедура ПодписьБухгалтераПодвалОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		
		Если ВыбранноеЗначение.Свойство("БыстроеСоздание") Тогда
			БыстрыеФормыУНФКлиент.ОткрытьБыструюФормуПодписи(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СчетЗавершенПриИзменении(Элемент)
	
	Модифицированность = Истина;
	
	Если СчетЗавершен Тогда
		Объект.СостояниеЗаказа = ПредопределенноеЗначение("Справочник.СостоянияЗаказовПокупателей.Завершен");
		ОбработатьИзменениеСостоянияЗаказа();
		СтатистикаПоПоказателямКлиентСервер.ДобавитьСобытие("Данные.ЗаказПокупателя.ФлажокЗавершен"); 
	Иначе
		Объект.СостояниеЗаказа = ПолучитьСостояниеЗаказаПокупателя(Объект.ВидЗаказа);
		ОбработатьИзменениеСостоянияЗаказа();
	КонецЕсли;
	
КонецПроцедуры

