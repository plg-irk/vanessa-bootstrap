		Если Объект.Предоплата.Количество() > 0 Тогда
			ЗадатьВопросОбОчисткеПредоплаты();
		Иначе
			ОбработатьИзменениеДоговора();
		КонецЕсли;
		
	КонецЕсли;
	
	СтатистикаИспользованияФормКлиент.ПриИнтерактивномДействии(ЭтотОбъект, Элемент, "ПриИзменении");
	
	// Калькуляция
