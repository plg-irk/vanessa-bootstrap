	Модифицированность = Истина;
	
	СохранитьЗначениеНастройки("_НДСУпрощенно", НДСУпрощенно);
	
	НДСУпрощенноПриИзмененииНаСервере();
	
	Если СуммаВключаетНДСДоИзменения <> Объект.СуммаВключаетНДС Тогда
		ЦенообразованиеКлиент.ПересчитаемСуммуТабличнойЧастиПоФлагуСуммаВключаетНДС(ЭтотОбъект, "Запасы");
	КонецЕсли;
	
	ОбновитьИтогиКлиент();
	
