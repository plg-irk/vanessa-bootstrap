	Иначе
		ШаблонЗаголовкаЗакрывающегоДокумента = НСтр("ru = 'Накладная №%1 от %2'");
	КонецЕсли;
	
	Возврат СтрШаблон(ШаблонЗаголовкаЗакрывающегоДокумента, НомерЗакрывающегоДокумента, Формат(ДатаЗакрывающегоДокумента, НСтр("ru = 'ДФ=dd.MM.yy;'")));
	
