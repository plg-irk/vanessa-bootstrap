#Область ВыставлениеСчетов

&НаКлиенте 
Процедура ДобавитьИзменитьПодписьЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(ДополнительныеПараметры) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьИзображенияФаксимиле();
	
	Если ЗначениеЗаполнено(Объект.ПодписьРуководителя) Тогда
		ОбновитьПодписьОрганизации(Объект.Организация, ДополнительныеПараметры.ИмяРеквизита, Объект[ДополнительныеПараметры.ИмяРеквизита]);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИконкиОтгрузкиОплаты()
	
	Если НЕ ИнтерфейсВыставлениеСчетов Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяДатаДляСравнения = ОбщегоНазначенияКлиент.ДатаСеанса();
	
	Если Объект.ОтгруженВВыставленииСчетов Тогда
		Элементы.ДекорацияОтгружен.Видимость = Истина;
		Элементы.ДекорацияОтгрузкаСегодня.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаПросрочена.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаНеПросрочена.Видимость = Ложь;
	ИначеЕсли НачалоДня(Объект.ДатаОтгрузки) = НачалоДня(ТекущаяДатаДляСравнения) Тогда
		Элементы.ДекорацияОтгружен.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаСегодня.Видимость = Истина;
		Элементы.ДекорацияОтгрузкаПросрочена.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаНеПросрочена.Видимость = Ложь;
	ИначеЕсли НачалоДня(Объект.ДатаОтгрузки) < НачалоДня(ТекущаяДатаДляСравнения) Тогда
		Элементы.ДекорацияОтгружен.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаСегодня.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаПросрочена.Видимость = Истина;
		Элементы.ДекорацияОтгрузкаНеПросрочена.Видимость = Ложь;
	Иначе
		Элементы.ДекорацияОтгружен.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаСегодня.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаПросрочена.Видимость = Ложь;
		Элементы.ДекорацияОтгрузкаНеПросрочена.Видимость = Истина;
	КонецЕсли;
	
	Если Объект.ОплаченВВыставленииСчетов Тогда
		Элементы.ДекорацияОплачен.Видимость = Истина;
		Элементы.ДекорацияОплатаСегодня.Видимость = Ложь;
		Элементы.ДекорацияОплатаПросрочена.Видимость = Ложь;
		Элементы.ДекорацияОплатаНеПросрочена.Видимость = Ложь;
	ИначеЕсли НачалоДня(Объект.ОплатаДо) = НачалоДня(ТекущаяДатаДляСравнения) Тогда
		Элементы.ДекорацияОплачен.Видимость = Ложь;
		Элементы.ДекорацияОплатаСегодня.Видимость = Истина;
		Элементы.ДекорацияОплатаПросрочена.Видимость = Ложь;
		Элементы.ДекорацияОплатаНеПросрочена.Видимость = Ложь;
	ИначеЕсли НачалоДня(Объект.ОплатаДо) < НачалоДня(ТекущаяДатаДляСравнения) Тогда
		Элементы.ДекорацияОплачен.Видимость = Ложь;
		Элементы.ДекорацияОплатаСегодня.Видимость = Ложь;
		Элементы.ДекорацияОплатаПросрочена.Видимость = Истина;
		Элементы.ДекорацияОплатаНеПросрочена.Видимость = Ложь;
	Иначе
		Элементы.ДекорацияОплачен.Видимость = Ложь;
		Элементы.ДекорацияОплатаСегодня.Видимость = Ложь;
		Элементы.ДекорацияОплатаПросрочена.Видимость = Ложь;
		Элементы.ДекорацияОплатаНеПросрочена.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

