&НаКлиенте
Процедура ПечатьПоУмолчаниюНастройка(Команда)
	ПечатьДокументовУНФКлиент.ОткрытьФормуНастройкиПечатныхФормПоУмолчанию(ЭтотОбъект);
КонецПроцедуры
#КонецОбласти

&НаКлиенте
Процедура ОнлайнЗаказыВыставлениеСчетов(Команда)
	
	ТекущаяСтрока = Элементы.Список.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОнлайнЗаказыКлиент.Подключаемый_ОткрытьФормуURLЗаказа(ТекущаяСтрока, Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьПоШаблону(Команда)
	
	ЗаполнениеОбъектовУНФКлиент.ПоказатьВыборШаблонаДляСозданияДокументаИзСписка(
	"Документ.ЗаказПокупателя",
	Список.КомпоновщикНастроек.Настройки.Отбор.Элементы,
	Элементы.Список.ТекущаяСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьШаблоныПечатиДоговоровКонтрагентов(Команда)
	
	ШаблоныПечатиОфисныхДокументовКлиент.ОткрытьШаблоныПечатиОфисныхДокументов(
	ПредопределенноеЗначение("Перечисление.НазначенияШаблоновПечатиОфисныхДокументов.ДоговорКонтрагентаЗаказ"));
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьШаблоныПечатиКоммерческихПредложений(Команда)
	
	ШаблоныПечатиОфисныхДокументовКлиент.ОткрытьШаблоныПечатиОфисныхДокументов(
	ПредопределенноеЗначение("Перечисление.НазначенияШаблоновПечатиОфисныхДокументов.КоммерческоеПредложение"));
	
КонецПроцедуры

&НаКлиенте
Процедура ПоискПоШтрихкоду(Команда)
	
	ТекШтрихкод = "";
	
	ОбработкаЗавершения = Новый ОписаниеОповещения("ПоискПоШтрихкодуЗавершение", ЭтотОбъект,
		Новый Структура("ТекШтрихкод", ТекШтрихкод));
	
	#Если МобильныйКлиент Тогда
		ОткрытьФорму("ОбщаяФорма.ФормаПоискаПоШтрихкоду", , , , , , ОбработкаЗавершения);
	#Иначе
		ПоказатьВводЗначения(ОбработкаЗавершения, ТекШтрихкод, НСтр("ru = 'Введите штрихкод'"));
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ПереключитьВидимостьПредпросмотра(Команда)
	
	ПанельПредпросмотраРазвернута = НЕ ПанельПредпросмотраРазвернута;
	
	ОбработатьПанельПредпросмотра();
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаФормы(Команда)
	
	ОткрытьФормуНастройки(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьСчетPDF(Команда)
	
	ТекущаяСтрока = Элементы.Список.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФайла = ИмяФайлаПечатнойФормыОбъекта(ТекущаяСтрока);
	
	ДиалогВыбораФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	ДиалогВыбораФайла.ПолноеИмяФайла = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(ИмяФайла);
	ДиалогВыбораФайла.Фильтр = Строка(ПредопределенноеЗначение("Перечисление.ФорматыСохраненияОтчетов.PDF")) + " (*.pdf)|*.pdf"; 
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("ТипФайла", ТипФайлаТабличногоДокумента.PDF);
	ПараметрыОповещения.Вставить("Ссылка", ТекущаяСтрока);
	ПараметрыОповещения.Вставить("ПолноеИмяФайла", ДиалогВыбораФайла.ПолноеИмяФайла + ".pdf");
	ОписаниеОповещения = Новый ОписаниеОповещения("ПродолжитьСохранениеВФайл", ЭтотОбъект, ПараметрыОповещения);
	ФайловаяСистемаКлиент.ПоказатьДиалогВыбора(ОписаниеОповещения, ДиалогВыбораФайла);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСчетПоПочте(Команда)
	
	ТекущаяСтрока = Элементы.Список.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИдентификаторыПечатныхФорм", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("СчетНаОплату"));
	ДополнительныеПараметры.Вставить("НастройкиФорматаВложений", УправлениеПечатьюКлиент.НастройкиСохранения());
	ДополнительныеПараметры.НастройкиФорматаВложений.ФорматыСохранения.Добавить(Строка(ТипФайлаТабличногоДокумента.PDF));
	ДополнительныеПараметры.НастройкиФорматаВложений.ПодписьИПечать = НастройкаПользователяЗаполнятьФаксимиле();
	
	ПараметрыВыполненияКоманды = ПодключаемыеКомандыКлиент.ПараметрыВыполненияКоманды();
	ПараметрыВыполненияКоманды.Форма = ЭтотОбъект;
	ПараметрыВыполненияКоманды.ОписаниеКоманды = Новый Структура;
	ПараметрыВыполненияКоманды.ОписаниеКоманды.Вставить("ДополнительныеПараметры", ДополнительныеПараметры);
	
	ЭлектроннаяПочтаУНФКлиент.ОтправитьПечатныеФормыПоПочте(ТекущаяСтрока, ПараметрыВыполненияКоманды);
	
КонецПроцедуры

&НаКлиенте
Процедура НапечататьСчет(Команда)
	
	Если Элементы.Список.ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати("Документ.ЗаказПокупателя",
													"СчетНаОплату",
													Элементы.Список.ВыделенныеСтроки,
													ЭтотОбъект);
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПоделитьсяДокументомShareВыставлениеСчетов(Команда)
	
	ТекущаяСтрока = Элементы.Список.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИнтеграцияShareКлиент.ПоделитьсяДокументом(ТекущаяСтрока, Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСтатусыОплатыВыставлениеСчетов(Команда)
	
	ИнтеграцияСПлатежнымиСистемамиУНФКлиент.ЗагрузитьСтатусыОплатыИзФормыСписка(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьОтборы(Команда)
	
	ИмяРеквизитаСписка = "Список";
	ИмяТЧДанныеМеток = "ДанныеМеток";
	ИмяТЧДанныеОтборов = "ДанныеОтборов";
	ИмяГруппыОтборов = "ГруппаОтборы";
	ИмяПредопределенныеОтборыПоУмолчанию = "ПредопределенныеОтборыПоУмолчанию";
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяРеквизитаСписка", ИмяРеквизитаСписка);
	ДополнительныеПараметры.Вставить("ИмяТЧДанныеМеток", ИмяТЧДанныеМеток);
	ДополнительныеПараметры.Вставить("ИмяТЧДанныеОтборов", ИмяТЧДанныеОтборов);
	ДополнительныеПараметры.Вставить("ИмяГруппыОтборов", ИмяГруппыОтборов);
	ДополнительныеПараметры.Вставить("ИмяПредопределенныеОтборыПоУмолчанию", ИмяПредопределенныеОтборыПоУмолчанию);
	
	РаботаСОтборамиКлиент.НастроитьОтборыНажатие(ЭтотОбъект, ПараметрыОткрытияФормыСНастройкамиОтборов(ДополнительныеПараметры), ДополнительныеПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьВсеОтборы(Команда)
	РаботаСОтборамиКлиент.СброситьОтборПоПериоду(ЭтотОбъект, "Список", "Дата");
	СброситьВсеМеткиОтбораНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьСостояниеЗаказа(Команда)
	
	Если Команда.Имя = "СостояниеЗавершенУспешно" Тогда
		ВидЗаказа = Неопределено;
	Иначе
		ИндексСостояния = Число(Сред(Команда.Имя,11,СтрДлина(Команда.Имя)));
		ВидЗаказа = СостоянияЗаказовПокупателей[ИндексСостояния].Вид;
	КонецЕсли;
	
	ИмяКоманды = Команда.Имя;
	Заказы = Элементы.Список.ВыделенныеСтроки;
	УстановитьСостояниеЗаказа(ИмяКоманды, Заказы, ВидЗаказа);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьЗаказы(Команда)
	
	Оповещение = Новый ОписаниеОповещения("УстановитьСостояниеОтменен", ЭтотОбъект);
	ОткрытьФорму("Документ.ЗаказПокупателя.Форма.ФормаОтменыЗаказа", , ЭтотОбъект, , , , Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередатьВЯндексДоставку(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Заказы", Элементы.Список.ВыделенныеСтроки);
	
	ОткрытьФорму("РегистрСведений.ЯндексДоставка.Форма.ПередатьЗаказы", ПараметрыФормы);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Заявки

&НаСервере
Процедура УстановитьОтборПоВидуОперации()
	
	ВидыОперацийЗаказПокупателя = Новый СписокЗначений;
	ВидыОперацийЗаказПокупателя.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу);
	ВидыОперацийЗаказПокупателя.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПереработку);
	
	Если ИспользоватьЗаявки Тогда
		ВидыОперацийЗаказПокупателя.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
	Список, "ВидОперации", ВидыОперацийЗаказПокупателя, ВидСравненияКомпоновкиДанных.ВСписке);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьОчищениеМеткиУФильтровПоЗаявкам()
	
	Элементы.ГруппаОтборКонтрагент.Доступность = (Элементы.ГруппаОтборЛид.ПодчиненныеЭлементы.Количество() <= 1);
	Элементы.ГруппаОтборЛид.Доступность = (Элементы.ГруппаОтборКонтрагент.ПодчиненныеЭлементы.Количество() <= 1);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсПоЗаявкам()
	
	Элементы.Контрагент.Видимость = Не ИспользоватьЗаявки;
	
	Элементы.ГруппаКонтрагентИлиЛид.Видимость = ИспользоватьЗаявки;
	Элементы.ГруппаОтборЛид.Видимость = ИспользоватьЗаявки;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ИзменитьЗапросПоПравам()
	
	ЛидыДоступны = РаботаСЛидами.ЛидыДоступны();
	Если ЛидыДоступны Тогда
		
		Список.ТекстЗапроса = СтрЗаменить(
		Список.ТекстЗапроса,
		"-1 КАК ИндексИконкиКонтрагентаИлиЛида",
		"ВЫБОР
		|КОГДА ДокументЗаказПокупателя.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|		И ДокументЗаказПокупателя.Лид = ЗНАЧЕНИЕ(Справочник.Лиды.ПустаяСсылка)
		|	ТОГДА -1
		|КОГДА ДокументЗаказПокупателя.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) Или Не &ЛидыДоступны
		|	ТОГДА ВЫБОР
		|			КОГДА ДокументЗаказПокупателя.Контрагент.ВидКонтрагента = ЗНАЧЕНИЕ(Перечисление.ВидыКонтрагентов.ИндивидуальныйПредприниматель)
		|					ИЛИ ДокументЗаказПокупателя.Контрагент.ВидКонтрагента = ЗНАЧЕНИЕ(Перечисление.ВидыКонтрагентов.ФизическоеЛицо)
		|				ТОГДА ВЫБОР
		|						КОГДА ДокументЗаказПокупателя.Контрагент.ПометкаУдаления
		|							ТОГДА 3
		|						ИНАЧЕ 1
		|					КОНЕЦ
		|			ИНАЧЕ ВЫБОР
		|					КОГДА ДокументЗаказПокупателя.Контрагент.ПометкаУдаления
		|						ТОГДА 2
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		КОНЕЦ
		|ИНАЧЕ ВЫБОР
		|		КОГДА ДокументЗаказПокупателя.Лид.Вид = ЗНАЧЕНИЕ(Перечисление.ВидыЛидов.ПовторноеОбращение)
		|			ТОГДА ВЫБОР
		|					КОГДА ДокументЗаказПокупателя.Лид.ПометкаУдаления
		|						ТОГДА 7
		|					ИНАЧЕ 5
		|				КОНЕЦ
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ДокументЗаказПокупателя.Лид.ПометкаУдаления
		|					ТОГДА 6
		|				ИНАЧЕ 4
		|			КОНЕЦ
		|	КОНЕЦ
		|КОНЕЦ КАК ИндексИконкиКонтрагентаИлиЛида");
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборПоПараметрам(Параметры)
	
	Если Параметры.Свойство("Лид") Тогда
		СброситьВсеМеткиОтбораНаСервере();
		//@skip-check unknown-form-parameter-access
		УстановитьМеткуИОтборСписка("КонтрагентИлиЛид", Элементы.ГруппаОтборЛид.Имя, Параметры.Лид);
		КонтекстноеОткрытие = Истина;
	КонецЕсли;
	
	Если Параметры.Свойство("Состояния") Тогда
		
		Если Параметры.Свойство("ВидЗаказа") Тогда
			//@skip-check unknown-form-parameter-access
			УстановитьМеткуИОтборСписка("ВидЗаказа", Элементы.ГруппаОтборВидЗаказа.Имя, Параметры.ВидЗаказа);
		КонецЕсли;
		
		//@skip-check unknown-form-parameter-access
		Для Каждого Состояние Из Параметры.Состояния Цикл
			УстановитьМеткуИОтборСписка("СостояниеЗаказа", Элементы.ГруппаОтборСостояние.Имя, Состояние);
		КонецЦикла;
		
		Если Параметры.Свойство("ВидОперации") Тогда
			
			//@skip-check unknown-form-parameter-access
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "ВидОперации", Параметры.ВидОперации, ВидСравненияКомпоновкиДанных.Равно);
			
		КонецЕсли;
		
		КонтекстноеОткрытие = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ВидЗаказаВОтбореНаКлиенте()
	
	НайденныеСтроки = ДанныеМеток.НайтиСтроки(Новый Структура("ИмяПоляОтбора", "ВидЗаказа"));
	Если НайденныеСтроки.Количество() = 1 И ТипЗнч(НайденныеСтроки[0].Метка) = Тип("СправочникСсылка.ВидыЗаказовПокупателей") Тогда
		Возврат НайденныеСтроки[0].Метка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Процедура УстановитьОтборТекущиеДела()
	
	Если НЕ Параметры.Свойство("ТекущиеДела") Тогда
		Возврат;
	КонецЕсли;
	
	АвтоЗаголовок = Ложь;
	Заголовок = НСтр("ru='Заказы покупателей'");
	
	СотрудникиПользователя = РегистрыСведений.СотрудникиПользователя.ПолучитьСотрудниковПользователя();
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Проведен", Истина);
	
	УстановитьМеткуИОтборСписка(
		"ВариантЗавершения",
		Элементы.ОтборЗавершениеЗаказа.Родитель.Имя,
		ПредопределенноеЗначение("Перечисление.ВариантыЗавершенияЗаказа.ПустаяСсылка"), // В текущих делах все заказы Не завершенные
		Элементы.ОтборЗавершениеЗаказа.СписокВыбора.НайтиПоЗначению("ПустаяСсылка").Представление);
	
	РаботаСОтборами.ПрикрепитьМеткиОтбораИзМассива(ЭтотОбъект, "Ответственный", "ГруппаОтборОтветственный", СотрудникиПользователя);
	РаботаСОтборами.УстановитьОтборСписка(ЭтотОбъект, Список, "Ответственный");
	
	Если Параметры.Свойство("ПросроченоВыполнение") Тогда
		
		Заголовок = Заголовок + ": " + НСтр("ru='просрочено выполнение'");
		Список.УстановитьОбязательноеИспользование("ПросроченоВыполнение", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "ПросроченоВыполнение", Истина);
		
	ИначеЕсли Параметры.Свойство("ПросроченаОплата") Тогда
		
		Заголовок = Заголовок + ": " + НСтр("ru='просрочена оплата'");
		Список.УстановитьОбязательноеИспользование("ПросроченаОплата", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "ПросроченаОплата", Истина);
		
	ИначеЕсли Параметры.Свойство("НаСегодня") Тогда
		
		Заголовок = Заголовок + ": " + НСтр("ru='на сегодня'");
		Список.УстановитьОбязательноеИспользование("НаСегодня", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "НаСегодня", Истина);
		
	ИначеЕсли Параметры.Свойство("НеЗавершенные") Тогда
		
		Заголовок = Заголовок + ": " + НСтр("ru='не завершенные'");
		
	КонецЕсли;
	
	ПредставлениеПериода = РаботаСОтборамиКлиентСервер.ОбновитьПредставлениеПериода(ОтборПериод);
	РаботаСОтборами.ОбновитьЭлементыМеток(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьСохранениеВФайл(ВыбранныеФайлы, ПараметрыОповещения) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ВыбранныеФайлы) = Тип("Массив") Тогда
		Если ВыбранныеФайлы.Количество() > 0 Тогда
			ПолноеИмяФайла = ВыбранныеФайлы[0];
		Иначе
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ВыбранныеФайлы) = Тип("Строка") Тогда
		ПолноеИмяФайла = ВыбранныеФайлы
	КонецЕсли;
	
	Файл = ФайлСчетаНаОплату(ПараметрыОповещения.Ссылка, ПараметрыОповещения.ТипФайла);
	
	Если ПолноеИмяФайла = "" Тогда
		
		Если Файл <> Неопределено Тогда
			ПолноеИмяФайла = ПараметрыОповещения.ПолноеИмяФайла;
			АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(Файл, УникальныйИдентификатор);
			
			ПараметрыСохранения = ФайловаяСистемаКлиент.ПараметрыСохраненияФайлов();
			ПараметрыСохранения.Интерактивно = Истина;
			ПараметрыСохранения.Диалог.Фильтр = Строка(ПредопределенноеЗначение("Перечисление.ФорматыСохраненияОтчетов.PDF")) + " (*.pdf)|*.pdf";
			ФайловаяСистемаКлиент.СохранитьФайл(Неопределено, АдресВоВременномХранилище, ПолноеИмяФайла, ПараметрыСохранения);
		
		КонецЕсли;
		
	Иначе
		
		Если Файл <> Неопределено Тогда
			Файл.НачатьЗапись(Новый ОписаниеОповещения("ПослеСохраненияФайла", ЭтотОбъект), ПолноеИмяФайла);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

