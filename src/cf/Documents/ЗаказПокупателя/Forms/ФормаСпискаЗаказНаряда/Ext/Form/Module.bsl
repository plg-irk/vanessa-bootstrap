#Область Отборы

&НаСервере
Процедура УстановитьМеткуИОтборСписка(ИмяПоляОтбораСписка, ГруппаРодительМетки, ВыбранноеЗначение, ПредставлениеЗначения="")
	
	Если ГруппаРодительМетки = "ГруппаОтборОплата" Тогда
		ПредставлениеЗначения = РаботаСОтборами.СформироватьПредставлениеМеткиОплата(ВыбранноеЗначение);
		Если ИмяПоляОтбораСписка = "НомерКартинкиОплаты" Тогда
			ВыбранноеЗначение = РаботаСОтборами.НомерКартинкиПоСтатусуОплаты(ВыбранноеЗначение);
		КонецЕсли;
	ИначеЕсли ПредставлениеЗначения="" Тогда
		ПредставлениеЗначения=Строка(ВыбранноеЗначение);
	КонецЕсли;
	
	Если ИмяПоляОтбораСписка = "КонтрагентИлиЛид" Тогда
		Если ГруппаРодительМетки = Элементы.ГруппаОтборЛид.Имя Тогда
			Элементы.ГруппаОтборКонтрагент.Доступность = Ложь;
		Иначе
			Элементы.ГруппаОтборЛид.Доступность = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяПоляОтбораСписка = "КонтрагентИлиЛид" И ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Лиды") Тогда
		ИмяОтбора = Элементы.ОтборЛид.Имя;
	Иначе
		ИмяОтбора = "";
	КонецЕсли;
	
	РаботаСОтборами.ПрикрепитьМеткуОтбора(ЭтотОбъект, ИмяПоляОтбораСписка, ГруппаРодительМетки, ВыбранноеЗначение, ПредставлениеЗначения);
	РаботаСОтборами.УстановитьОтборСписка(ЭтотОбъект, Список, ИмяПоляОтбораСписка, , , , ИмяОтбора);
	
КонецПроцедуры

//@skip-check module-unused-method
&НаКлиенте
Процедура Подключаемый_МеткаОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки,
	СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;

	МеткаИД = Сред(Элемент.Имя, СтрДлина("Метка_") + 1);
	УдалитьМеткуОтбора(МеткаИД);
	
	ТребуетсяОбновитьДанныеВыбораСостояния = Истина;

КонецПроцедуры

&НаСервере
Процедура УдалитьМеткуОтбора(МеткаИД)

	ЧисловойИдентификаторМетки = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(МеткаИД);
	СтрокаМеток = ДанныеМеток.НайтиПоИдентификатору(ЧисловойИдентификаторМетки);
	Если СтрокаМеток <> Неопределено И СтрокаМеток.ИмяПоляОтбора = "ВидЗаказа" Тогда
		ТребуетсяОбновитьДанныеВыбораСостояния = Истина;
	КонецЕсли;

	РаботаСОтборами.УдалитьМеткуОтбораСервер(ЭтотОбъект, Список, МеткаИД);
	
	Если ИспользоватьЗаявки Тогда
		ОбработатьОчищениеМеткиУФильтровПоЗаявкам();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура СохранитьНастройки()
	
	УжеИспользоватьЗаявки = РаботаСЗаявками.ЗаявкиИспользуются(, Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд);
	Если ИспользоватьЗаявки = УжеИспользоватьЗаявки Тогда
		РаботаСОтборами.СохранитьНастройкиОтборов(ЭтотОбъект);
	КонецЕсли;
	
	Если ПоказыватьПредпросмотрЗаказНарядов И НЕ ЭтоМобильныйКлиент Тогда
		КлючОбъекта = СтрЗаменить(ИмяФормы, ".", "");
		ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(КлючОбъекта, 
			"ПанельПредпросмотраРазвернута", ПанельПредпросмотраРазвернута);
	КонецЕсли;
	
КонецПроцедуры

