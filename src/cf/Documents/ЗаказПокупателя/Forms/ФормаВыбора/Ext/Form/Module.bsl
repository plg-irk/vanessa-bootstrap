
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Список.Параметры.УстановитьЗначениеПараметра("АктуальнаяДатаСеанса", НачалоДня(ТекущаяДатаСеанса()));
	
	//@skip-check unknown-form-parameter-access
	Если Параметры.Отбор.Свойство("Договор")
		И Параметры.Свойство("ДоговорКомиссии") И ЗначениеЗаполнено(Параметры.ДоговорКомиссии) Тогда
		Параметры.Отбор.Договор = Параметры.ДоговорКомиссии;
	КонецЕсли;
	
	Если Параметры.Свойство("СчетЗатрат") Тогда
		
		//@skip-check unknown-form-parameter-access
		Если ЗначениеЗаполнено(Параметры.СчетЗатрат) Тогда
			
			Если Параметры.СчетЗатрат.ТипСчета <> Перечисления.ТипыСчетов.Расходы
				И Параметры.СчетЗатрат.ТипСчета <> Перечисления.ТипыСчетов.Доходы
				И Параметры.СчетЗатрат.ТипСчета <> Перечисления.ТипыСчетов.НезавершенноеПроизводство
				И Параметры.СчетЗатрат.ТипСчета <> Перечисления.ТипыСчетов.КосвенныеЗатраты Тогда
				
				ОбщегоНазначения.СообщитьПользователю(НСтр(
					"ru = 'Для данного типа счета заказ покупателя не указывается.'"), , , , Отказ);
				
			КонецЕсли;
			
		Иначе
			
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не выбран счет.'"), , , , Отказ);
			
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьОтборПоВидуОперации();
	СохранитьГлобальныеНастройки(Параметры);
	ОбновитьИнтерфейсПоЗаявкам();
	ИзменитьЗапросПоПравам();
	УстановитьПараметрыСписка();
	
	Если Параметры.Свойство("ВозможнаПечатьЗаказаИзРМК") Тогда
		Элементы.ФормаПечатьЗаказаИзРМК.Видимость = Истина;
	КонецЕсли;
	
	СостоянияЗаказов.УстановитьУсловноеОформлениеОтмененногоЗаказа(
		Список.КомпоновщикНастроек.Настройки.УсловноеОформление);
	
	УстановитьУсловноеОформлениеПоЦветамСостоянийСервер();
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
		"ФормаДокументПриходнаяНакладнаяСоздатьНаОсновании", 
		"Заголовок",
		НСтр("ru = 'Возврат от покупателя'"));
		
	// МобильноеПриложение
	Если МобильноеПриложениеВызовСервера.НужноОграничитьФункциональность() Тогда
		Элементы.ФормаОбщаяКомандаСтруктураПодчиненности.Видимость = Ложь;
		Элементы.ГруппаГлобальныеКомандыЗаказПокупателя.Видимость = Ложь;
	КонецЕсли;
	// Конец МобильноеПриложение
	
	ДинамическиеСпискиУНФ.ОтображатьТолькоВремяДляТекущейДаты(Список);
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если (ЭтоЗаказНаряд И ИмяСобытия = "Запись_СостоянияЗаказНарядов")
		Или (Не ЭтоЗаказНаряд И ИмяСобытия = "Запись_СостоянияЗаказовПокупателей") Тогда
		
		УстановитьУсловноеОформлениеПоЦветамСостоянийСервер();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПечатьЗаказаИзРМК(Команда)
	
	СтруктураВыбора = Новый Структура;
	СтруктураВыбора.Вставить("ДокументЗаказ", Элементы.Список.ТекущиеДанные.Ссылка);
	СтруктураВыбора.Вставить("ПечатьЗаказа", Истина);
	Закрыть(СтруктураВыбора);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбновлениеИнтерфейса

&НаСервере
Процедура ОбновитьИнтерфейсПоЗаявкам()
	
	Элементы.Контрагент.Видимость = Не ИспользоватьЗаявки;
	Элементы.ГруппаКонтрагентИлиЛид.Видимость = ИспользоватьЗаявки;
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьЗапросПоПравам()
	
	ЛидыДоступны = РаботаСЛидами.ЛидыДоступны();
	Если ЛидыДоступны Тогда
		
		Список.ТекстЗапроса = СтрЗаменить(
		Список.ТекстЗапроса,
		"-1 КАК ИндексИконкиКонтрагентаИлиЛида",
		"ВЫБОР
		|КОГДА ДокументЗаказПокупателя.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|		И ДокументЗаказПокупателя.Лид = ЗНАЧЕНИЕ(Справочник.Лиды.ПустаяСсылка)
		|	ТОГДА -1
		|КОГДА ДокументЗаказПокупателя.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) Или Не &ЛидыДоступны
		|	ТОГДА ВЫБОР
		|			КОГДА ДокументЗаказПокупателя.Контрагент.ВидКонтрагента = ЗНАЧЕНИЕ(Перечисление.ВидыКонтрагентов.ИндивидуальныйПредприниматель)
		|					ИЛИ ДокументЗаказПокупателя.Контрагент.ВидКонтрагента = ЗНАЧЕНИЕ(Перечисление.ВидыКонтрагентов.ФизическоеЛицо)
		|				ТОГДА ВЫБОР
		|						КОГДА ДокументЗаказПокупателя.Контрагент.ПометкаУдаления
		|							ТОГДА 3
		|						ИНАЧЕ 1
		|					КОНЕЦ
		|			ИНАЧЕ ВЫБОР
		|					КОГДА ДокументЗаказПокупателя.Контрагент.ПометкаУдаления
		|						ТОГДА 2
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		КОНЕЦ
		|ИНАЧЕ ВЫБОР
		|		КОГДА ДокументЗаказПокупателя.Лид.Вид = ЗНАЧЕНИЕ(Перечисление.ВидыЛидов.ПовторноеОбращение)
		|			ТОГДА ВЫБОР
		|					КОГДА ДокументЗаказПокупателя.Лид.ПометкаУдаления
		|						ТОГДА 7
		|					ИНАЧЕ 5
		|				КОНЕЦ
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ДокументЗаказПокупателя.Лид.ПометкаУдаления
		|					ТОГДА 6
		|				ИНАЧЕ 4
		|			КОНЕЦ
		|	КОНЕЦ
		|КОНЕЦ КАК ИндексИконкиКонтрагентаИлиЛида");
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыСписка()
	
	Список.Параметры.УстановитьЗначениеПараметра("ЛидыДоступны", ЛидыДоступны);
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура УстановитьОтборПоВидуОперации()
	
	//@skip-check unknown-form-parameter-access
	Если Параметры.Свойство("ВыбиратьЗаказНаряд") И Параметры.ВыбиратьЗаказНаряд Тогда
		
		Параметры.Отбор.Вставить("ВидОперации", Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд);
		АвтоЗаголовок = Ложь;
		Заголовок = НСтр("ru = 'Заказ-наряды'");
		ЭтоЗаказНаряд = Истина;
		
	КонецЕсли;
	
	//@skip-check unknown-form-parameter-access
	Если Параметры.Свойство("ВыбиратьЗаказПокупателя") И Параметры.ВыбиратьЗаказПокупателя Тогда
		
		Параметры.Отбор.Вставить("ВидОперации", Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу);
		АвтоЗаголовок = Ложь;
		Заголовок = НСтр("ru = 'Заказы покупателей'");
		
	КонецЕсли;
	
	Если Параметры.Свойство("ВидыОпераций") Тогда
		
		//@skip-check unknown-form-parameter-access
		Если Параметры.ВидыОпераций[0] = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд Тогда
			
			АвтоЗаголовок = Ложь;
			Заголовок = НСтр("ru = 'Заказ-наряды'");
			ЭтоЗаказНаряд = Истина;
			
		КонецЕсли;
		
		Если Не Параметры.Свойство("ОтображатьЗаявки") Тогда
			
			//@skip-check unknown-form-parameter-access
			ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(
			Параметры.ВидыОпераций, Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу);
			//@skip-check unknown-form-parameter-access
			ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(
			Параметры.ВидыОпераций, Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд);
			
		КонецЕсли;
		
		//@skip-check unknown-form-parameter-access
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		Список, "ВидОперации", Параметры.ВидыОпераций, ВидСравненияКомпоновкиДанных.ВСписке);
		
	ИначеЕсли Не Параметры.Свойство("ОтображатьЗаявки") Тогда
		
		НеиспользуемыеВидыОпераций = Новый Массив;
		НеиспользуемыеВидыОпераций.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаНаПродажу);
		НеиспользуемыеВидыОпераций.Добавить(Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд);
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		Список, "ВидОперации", НеиспользуемыеВидыОпераций, ВидСравненияКомпоновкиДанных.НеВСписке);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьГлобальныеНастройки(Параметры)
	
	ИспользоватьЗаявки = Параметры.Свойство("ОтображатьЗаявки") И РаботаСЗаявками.ЗаявкиИспользуются();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеПоЦветамСостоянийСервер()
	
	СостоянияЗаказов.УстановитьУсловноеОформлениеПоЦветамСостояний(
		Список.КомпоновщикНастроек.Настройки.УсловноеОформление,
		?(ЭтоЗаказНаряд, Метаданные.Справочники.СостоянияЗаказНарядов.ПолноеИмя(),
			Метаданные.Справочники.СостоянияЗаказовПокупателей.ПолноеИмя()));
	
КонецПроцедуры

#КонецОбласти
