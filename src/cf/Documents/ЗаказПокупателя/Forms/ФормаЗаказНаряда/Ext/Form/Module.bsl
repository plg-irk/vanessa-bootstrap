&НаСервере
Функция ПараметрыОтображенияЭлементовПоЗаявкам()
	
	Если ПараметрыРасчетовСКонтрагентом = Неопределено Тогда
		ВестиРасчетыПоДоговорам = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Контрагент, "ВестиРасчетыПоДоговорам");
	Иначе
		ВестиРасчетыПоДоговорам = ПараметрыРасчетовСКонтрагентом.ВестиРасчетыПоДоговорам;
	КонецЕсли;
	
	ПередаваемыеЭлементы = Новый Структура;
	ПередаваемыеЭлементы.Вставить("Лид", Элементы.Лид);
	ПередаваемыеЭлементы.Вставить("Контрагент", Элементы.ЗНКонтрагент);
	ПередаваемыеЭлементы.Вставить("КонтрагентИнформация", Элементы.ГруппаКонтрагент);
	ПередаваемыеЭлементы.Вставить("ЗаполнитьПокупателяПоЛиду", Элементы.ЗаполнитьПокупателяПоЛиду);
	ПередаваемыеЭлементы.Вставить("СоздатьКонтрагентаПоЛиду", Элементы.СоздатьКонтрагентаПоЛиду);
	ПередаваемыеЭлементы.Вставить("Договор", Элементы.ЗНДоговор);
	ПередаваемыеЭлементы.Вставить("ОстатокВзаиморасчетов", Элементы.ОстатокВзаиморасчетов);
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользоватьЗаявки", ИспользоватьЗаявки Или ОбработкаОповещенияПоЗаявкам);
	Результат.Вставить("МожноИспользоватьЗавершенногоЛида", МожноИспользоватьЗавершенногоЛида);
	Результат.Вставить("СвязанныйКонтрагентСЛидом", СвязанныйКонтрагентСЛидом);
	Результат.Вставить("ВестиРасчетыПоДоговорам", ВестиРасчетыПоДоговорам);
	Результат.Вставить("Элементы", ПередаваемыеЭлементы);
	Результат.Вставить("Объект", Объект);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ДействияПослеЧтенияОбъектаПоЗаявкам()
	
	Если ЗначениеЗаполнено(Объект.Лид) Тогда
		СвязанныйКонтрагентСЛидом = Справочники.Лиды.СвязанныйКонтрагент(Объект.Лид);
	Иначе
		СвязанныйКонтрагентСЛидом = Неопределено;
	КонецЕсли;
	
	ОбновитьОтображениеЭлементовПоЗаявкам();
	
