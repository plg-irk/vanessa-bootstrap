	// Конец Калькуляция
	
	// Прослеживаемость
	Если СтрокаТабличнойЧасти <> Неопределено Тогда
		УдалитьСвязанныеЗаписи(СтрокаТабличнойЧасти);
	КонецЕсли;
	ОчиститьРНПТРаботПослеИзмененияРНПТМатериалов();
	// Конец Прослеживаемость
	
КонецПроцедуры

