	СтруктураДанные.Вставить("ИспользоватьПартии", 			СтрокаТабличнойЧасти.ИспользоватьПартии);
	СтруктураДанные.Вставить("СтранаПроисхождения",			СтрокаТабличнойЧасти.СтранаПроисхождения);
