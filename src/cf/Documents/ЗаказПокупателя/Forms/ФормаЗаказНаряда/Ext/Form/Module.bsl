	// Калькуляция
	ОчиститьКалькуляцию();
	// Конец Калькуляция
	
	// Прослеживаемость
	УдалитьСвязанныеЗаписи(СтрокаТабличнойЧасти);
	ОчиститьРНПТРаботПослеИзмененияРНПТМатериалов();
