// Формирует таблицу значений, содержащую данные для проведения по регистру СерииНоменклатурыГарантии.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаСерииНоменклатурыЗаказПокупателя(ДокументСсылкаРасходнаяНакладная, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	// Оприходование подарочных сертификатов при полном погашении, с целью повторной продажи этого сертификата.
	ВыполнятьДвиженияПоСертификатам = Истина;	
	ТекстЗапросаСертификаты = "
	|ВЫБРАТЬ
	|	ТаблицаСертификаты.ВидДвижения КАК ВидДвижения,
	|	ЗНАЧЕНИЕ(Перечисление.ОперацииСерийНоменклатуры.Приход) КАК Операция,
	|	ТаблицаСертификаты.Период КАК Период,
	|	ТаблицаСертификаты.Период КАК ДатаСобытия,
	|	ТаблицаСертификаты.Серия КАК Серия,
	|	Истина КАК ОстаткиСерийНоменклатуры,
	|	ТаблицаСертификаты.Организация КАК Организация,
	|	ТаблицаСертификаты.Номенклатура КАК Номенклатура,
	|	ТаблицаСертификаты.Характеристика КАК Характеристика,
	|	ТаблицаСертификаты.Партия КАК Партия,
	|	ТаблицаСертификаты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаСертификаты.Контрагент КАК Контрагент,
	|	ТаблицаСертификаты.Ячейка КАК Ячейка,
	|	ТаблицаСертификаты.ОрдерныйСклад КАК ОрдерныйСклад,
	|	1 КАК Количество
	|ИЗ
	|	ВложенныйЗапросСертификаты КАК ТаблицаСертификаты";
	ТекстЗапросаСертификаты = СтрЗаменить(ТекстЗапросаСертификаты, "ВложенныйЗапросСертификаты", "(" 
		+ РаботаСПодарочнымиСертификатами.ТекстЗапросаДвиженийЗапасыОприходованиеДляПовторнойПродажи(ВыполнятьДвиженияПоСертификатам) + ")");

	Запрос.Текст = ТекстЗапросаСертификаты;
	ТаблицаОприходованиеПодарочныхСертификатов = Запрос.Выполнить().Выгрузить();
	// Конец Оприходование подарочных сертификатов
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДвиженияСерииНоменклатуры", ТаблицаОприходованиеПодарочныхСертификатов);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСерииНоменклатурыГарантии", Новый ТаблицаЗначений);
	
	ПараметрыОтбора = Новый Структура("ОстаткиСерийНоменклатуры", Истина);
	ОстаткиСерийНоменклатурыСтроки = ТаблицаОприходованиеПодарочныхСертификатов.НайтиСтроки(ПараметрыОтбора);
	ТаблицаСерииНоменклатуры = ТаблицаОприходованиеПодарочныхСертификатов.Скопировать(ОстаткиСерийНоменклатурыСтроки);
		
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСерииНоменклатуры", ТаблицаСерииНоменклатуры);
	
КонецПроцедуры // СформироватьТаблицаСерииНоменклатуры()

