	|	ЗапасыКРасходуСоСкладовОстатки.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы КАК ТипСтруктурнойЕдиницы,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ЗапасыКРасходуСоСкладовОстатки.Номенклатура.ЕдиницаИзмерения) КАК ЕдиницаИзмеренияПредставление,
	|	ЕСТЬNULL(ДвиженияЗапасыКРасходуСоСкладовИзменение.КоличествоИзменение, 0) + ЕСТЬNULL(ЗапасыКРасходуСоСкладовОстатки.КоличествоОстаток, 0) КАК ОстатокЗапасыНаСкладах,
	|	ЕСТЬNULL(ЗапасыКРасходуСоСкладовОстатки.КоличествоОстаток, 0) КАК КоличествоОстатокЗапасыНаСкладах
	|ИЗ
	|	ДвиженияЗапасыКРасходуСоСкладовИзменение КАК ДвиженияЗапасыКРасходуСоСкладовИзменение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыКРасходуСоСкладов.Остатки(
	|				&МоментКонтроля,
	|				(Организация, СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия, ДокументОснование, Ячейка) В
	|					(ВЫБРАТЬ
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение.Организация КАК Организация,
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение.Номенклатура КАК Номенклатура,
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение.Характеристика КАК Характеристика,
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение.Партия КАК Партия,
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение.ДокументОснование КАК ДокументОснование,
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение.Ячейка КАК Ячейка
	|					ИЗ
	|						ДвиженияЗапасыКРасходуСоСкладовИзменение КАК ДвиженияЗапасыКРасходуСоСкладовИзменение)) КАК ЗапасыКРасходуСоСкладовОстатки
	|		ПО ДвиженияЗапасыКРасходуСоСкладовИзменение.Организация = ЗапасыКРасходуСоСкладовОстатки.Организация
	|			И ДвиженияЗапасыКРасходуСоСкладовИзменение.СтруктурнаяЕдиница = ЗапасыКРасходуСоСкладовОстатки.СтруктурнаяЕдиница
	|			И ДвиженияЗапасыКРасходуСоСкладовИзменение.Номенклатура = ЗапасыКРасходуСоСкладовОстатки.Номенклатура
	|			И ДвиженияЗапасыКРасходуСоСкладовИзменение.Характеристика = ЗапасыКРасходуСоСкладовОстатки.Характеристика
	|			И ДвиженияЗапасыКРасходуСоСкладовИзменение.Партия = ЗапасыКРасходуСоСкладовОстатки.Партия
	|			И ДвиженияЗапасыКРасходуСоСкладовИзменение.ДокументОснование = ЗапасыКРасходуСоСкладовОстатки.ДокументОснование
	|			И (ВЫБОР
	|				КОГДА ЗапасыКРасходуСоСкладовОстатки.СтруктурнаяЕдиница.УчетОстатковПоЯчейкам
	|					ТОГДА ДвиженияЗапасыКРасходуСоСкладовИзменение.Ячейка = ЗапасыКРасходуСоСкладовОстатки.Ячейка
	|				ИНАЧЕ ЛОЖЬ
	|			КОНЕЦ)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ЗапасыКРасходуСоСкладовОстатки.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоСкладскимОрдерам)
	|				ТОГДА ЕСТЬNULL(ЗапасыКРасходуСоСкладовОстатки.КоличествоОстаток, 0) > 0
	|			КОГДА ЗапасыКРасходуСоСкладовОстатки.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоПрочимДокументам)
	|				ТОГДА ЕСТЬNULL(ЗапасыКРасходуСоСкладовОстатки.КоличествоОстаток, 0) < 0
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И ДвиженияЗапасыКРасходуСоСкладовИзменение.СтруктурнаяЕдиница В(&МассивКонтроляПоЗапасамКОтгрузкеПоСкладскимОрдерам)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Функция СформироватьТекстЗапросаСерииНоменклатурыКРасходу()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ДвиженияСерииНоменклатурыКРасходуИзменение.НомерСтроки КАК НомерСтроки,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.ДокументОснование) КАК ДокументПредставление,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.Организация) КАК ОрганизацияПредставление,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиницаПредставление,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.Номенклатура) КАК НоменклатураПредставление,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.Характеристика) КАК ХарактеристикаПредставление,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.Партия) КАК ПартияПредставление,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.Серия) КАК СерияПредставление,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДвиженияСерииНоменклатурыКРасходуИзменение.ДокументОснование) КАК ДокументОснованиеПредставление,
	|	СерииНоменклатурыКРасходуОстатки.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы КАК ТипСтруктурнойЕдиницы,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СерииНоменклатурыКРасходуОстатки.Номенклатура.ЕдиницаИзмерения) КАК ЕдиницаИзмеренияПредставление,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ДвиженияСерииНоменклатурыКРасходуИзменение.КоличествоИзменение, 0) + ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0) < 0
	|			ТОГДА -(ЕСТЬNULL(ДвиженияСерииНоменклатурыКРасходуИзменение.КоличествоИзменение, 0) + ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0))
	|		ИНАЧЕ ЕСТЬNULL(ДвиженияСерииНоменклатурыКРасходуИзменение.КоличествоИзменение, 0) + ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0)
	|	КОНЕЦ КАК ОстатокЗапасыНаСкладах,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0) < 0
	|			ТОГДА -ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0)
	|		ИНАЧЕ ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0)
	|	КОНЕЦ КАК КоличествоОстатокЗапасыНаСкладах
	|ИЗ
	|	ДвиженияСерииНоменклатурыКРасходуИзменение КАК ДвиженияСерииНоменклатурыКРасходуИзменение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СерииНоменклатурыКРасходу.Остатки(
	|				&МоментКонтроля,
	|				(Организация, СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия, ДокументОснование, Серия) В
	|					(ВЫБРАТЬ
	|						ДвиженияСерииНоменклатурыКРасходуИзменение.Организация КАК Организация,
	|						ДвиженияСерииНоменклатурыКРасходуИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|						ДвиженияСерииНоменклатурыКРасходуИзменение.Номенклатура КАК Номенклатура,
	|						ДвиженияСерииНоменклатурыКРасходуИзменение.Характеристика КАК Характеристика,
	|						ДвиженияСерииНоменклатурыКРасходуИзменение.Партия КАК Партия,
	|						ДвиженияСерииНоменклатурыКРасходуИзменение.ДокументОснование КАК ДокументОснование,
	|						ДвиженияСерииНоменклатурыКРасходуИзменение.Серия КАК Серия
	|					ИЗ
	|						ДвиженияСерииНоменклатурыКРасходуИзменение КАК ДвиженияСерииНоменклатурыКРасходуИзменение)) КАК СерииНоменклатурыКРасходуОстатки
	|		ПО ДвиженияСерииНоменклатурыКРасходуИзменение.Организация = СерииНоменклатурыКРасходуОстатки.Организация
	|			И ДвиженияСерииНоменклатурыКРасходуИзменение.СтруктурнаяЕдиница = СерииНоменклатурыКРасходуОстатки.СтруктурнаяЕдиница
	|			И ДвиженияСерииНоменклатурыКРасходуИзменение.Номенклатура = СерииНоменклатурыКРасходуОстатки.Номенклатура
	|			И ДвиженияСерииНоменклатурыКРасходуИзменение.Характеристика = СерииНоменклатурыКРасходуОстатки.Характеристика
	|			И ДвиженияСерииНоменклатурыКРасходуИзменение.Партия = СерииНоменклатурыКРасходуОстатки.Партия
	|			И ДвиженияСерииНоменклатурыКРасходуИзменение.ДокументОснование = СерииНоменклатурыКРасходуОстатки.ДокументОснование
	|			И ДвиженияСерииНоменклатурыКРасходуИзменение.Серия = СерииНоменклатурыКРасходуОстатки.Серия
	|ГДЕ
	|	ВЫБОР
	|			КОГДА СерииНоменклатурыКРасходуОстатки.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоСкладскимОрдерам)
	|				ТОГДА ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0) > 0
	|			КОГДА СерииНоменклатурыКРасходуОстатки.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоПрочимДокументам)
	|				ТОГДА ЕСТЬNULL(СерииНоменклатурыКРасходуОстатки.КоличествоОстаток, 0) < 0
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И ДвиженияСерииНоменклатурыКРасходуИзменение.СтруктурнаяЕдиница В(&МассивКонтроляПоЗапасамКОтгрузкеПоСкладскимОрдерам)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

Функция СформироватьТекстЗапросаРезервыТоваровОрганизаций()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ДвиженияРезервыТоваровОрганизацийИзменение.НомерСтроки КАК НомерСтроки,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.Организация КАК ОрганизацияПредставление,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиницаПредставление,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.Номенклатура КАК НоменклатураПредставление,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.Характеристика КАК ХарактеристикаПредставление,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.Партия КАК ПартияПредставление,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.Ячейка КАК ЯчейкаПредставление,
	|	ЗапасыОстатки.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы КАК ТипСтруктурнойЕдиницы,
	|	ЗапасыОстатки.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияПредставление,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.КоличествоПередЗаписью + ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
	|	ДвиженияРезервыТоваровОрганизацийИзменение.КоличествоИзменение +
	|		ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) + ЕСТЬNULL(РезервыТоваровОрганизацийОстатки.КоличествоОстаток,
	|		0) КАК КоличествоОстатокЗапасыНаСкладах,
	|	ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) + ЕСТЬNULL(РезервыТоваровОрганизацийОстатки.КоличествоОстаток,
	|		0) КАК ОстатокЗапасыНаСкладах
	|ИЗ
	|	ДвиженияРезервыТоваровОрганизацийИзменение КАК ДвиженияРезервыТоваровОрганизацийИзменение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(&МоментКонтроля, Организация В (&МассивОрганизаций)
	|		И (СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия) В
	|			(ВЫБРАТЬ
	|				ДвиженияЗапасыИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|				ДвиженияЗапасыИзменение.Номенклатура КАК Номенклатура,
	|				ДвиженияЗапасыИзменение.Характеристика КАК Характеристика,
	|				ДвиженияЗапасыИзменение.Партия КАК Партия
	|			ИЗ
	|				ДвиженияЗапасыИзменение КАК ДвиженияЗапасыИзменение)) КАК ЗапасыОстатки
	|		ПО ДвиженияРезервыТоваровОрганизацийИзменение.СтруктурнаяЕдиница = ЗапасыОстатки.СтруктурнаяЕдиница
	|		И ДвиженияРезервыТоваровОрганизацийИзменение.Номенклатура = ЗапасыОстатки.Номенклатура
	|		И ДвиженияРезервыТоваровОрганизацийИзменение.Характеристика = ЗапасыОстатки.Характеристика
	|		И ДвиженияРезервыТоваровОрганизацийИзменение.Партия = ЗапасыОстатки.Партия
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервыТоваровОрганизаций.Остатки(&МоментКонтроля, Организация В
	|		(&МассивОрганизаций)
	|		И (СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия) В
	|			(ВЫБРАТЬ
	|				ДвиженияРезервыТоваровОрганизацийИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|				ДвиженияРезервыТоваровОрганизацийИзменение.Номенклатура КАК Номенклатура,
	|				ДвиженияРезервыТоваровОрганизацийИзменение.Характеристика КАК Характеристика,
	|				ДвиженияРезервыТоваровОрганизацийИзменение.Партия КАК Партия
	|			ИЗ
	|				ДвиженияРезервыТоваровОрганизацийИзменение КАК ДвиженияРезервыТоваровОрганизацийИзменение)) КАК РезервыТоваровОрганизацийОстатки
	|		ПО (&ПередачаТоваровМеждуОрганизациями)
	|		И ДвиженияРезервыТоваровОрганизацийИзменение.СтруктурнаяЕдиница = РезервыТоваровОрганизацийОстатки.СтруктурнаяЕдиница
	|		И ДвиженияРезервыТоваровОрганизацийИзменение.Номенклатура = РезервыТоваровОрганизацийОстатки.Номенклатура
	|		И ДвиженияРезервыТоваровОрганизацийИзменение.Характеристика = РезервыТоваровОрганизацийОстатки.Характеристика
	|		И ДвиженияРезервыТоваровОрганизацийИзменение.Партия = РезервыТоваровОрганизацийОстатки.Партия
	|ГДЕ
	|	ДвиженияРезервыТоваровОрганизацийИзменение.Организация В (&МассивОрганизаций)
	|	И ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) + ЕСТЬNULL(РезервыТоваровОрганизацийОстатки.КоличествоОстаток,
	|		0) + ДвиженияРезервыТоваровОрганизацийИзменение.КоличествоИзменение < 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Возврат ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	
КонецФункции

