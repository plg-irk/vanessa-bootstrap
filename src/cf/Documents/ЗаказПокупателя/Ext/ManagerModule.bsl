	|	ТаблицаСертификаты.Партия КАК Партия,
	|	ТаблицаСертификаты.ФиксированнаяСтоимость КАК ФиксированнаяСтоимость,
	|	ТаблицаСертификаты.ВидДвиженияУправленческий КАК ВидДвиженияУправленческий,
	|	ТаблицаСертификаты.СтранаПроисхождения КАК СтранаПроисхождения,
	|	ТаблицаСертификаты.НомерГТД КАК НомерГТД,
	|	ТаблицаСертификаты.СодержаниеПроводки КАК СодержаниеПроводки,
	|	Количество(Различные ТаблицаСертификаты.Серия) КАК Количество,
	|	СУММА(ТаблицаСертификаты.Сумма) КАК Сумма,
	|	СУММА(ТаблицаСертификаты.СуммаБезНДС) КАК СуммаБезНДС
	|ИЗ
	|	ВложенныйЗапросСертификаты КАК ТаблицаСертификаты
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаСертификаты.ВидДвижения,
	|	ТаблицаСертификаты.Период,
	|	ТаблицаСертификаты.Организация,
	|	ТаблицаСертификаты.СтруктурнаяЕдиница,
	|	ТаблицаСертификаты.СчетУчета,
	|	ТаблицаСертификаты.Номенклатура,
	|	ТаблицаСертификаты.Характеристика,
	|	ТаблицаСертификаты.Партия,
	|	ТаблицаСертификаты.ФиксированнаяСтоимость,
	|	ТаблицаСертификаты.ВидДвиженияУправленческий,
	|	ТаблицаСертификаты.СтранаПроисхождения,
	|	ТаблицаСертификаты.НомерГТД,
	|	ТаблицаСертификаты.СодержаниеПроводки";
	ВыполнятьДвиженияПоСертификатам = Истина;	
	ТекстЗапросаСертификаты = СтрЗаменить(ТекстЗапросаСертификаты, "ВложенныйЗапросСертификаты", "(" 
		+ РаботаСПодарочнымиСертификатами.ТекстЗапросаДвиженийЗапасыОприходованиеДляПовторнойПродажи(ВыполнятьДвиженияПоСертификатам) + ")");
	Запрос.Текст = ТекстЗапросаСертификаты;
	ТаблицаОприходованиеПодарочныхСертификатов = Запрос.Выполнить().Выгрузить();
	Если ТаблицаОприходованиеПодарочныхСертификатов.Количество() > 0 Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаОприходованиеПодарочныхСертификатов, ВременнаяТаблицаЗапасы);
	КонецЕсли;

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаЗапасы = ВременнаяТаблицаЗапасы;
	
