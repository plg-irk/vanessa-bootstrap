// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыПоНалогам(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.Финиш КАК Период,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ЗНАЧЕНИЕ(Справочник.ВидыНалогов.НДС) КАК ВидНалога,
	|	ТаблицаДокумента.СуммаНДС КАК Сумма,
	|	&НачислениеНДСПродажи КАК СодержаниеПроводки
	|ИЗ
	|	ВременнаяТаблицаРаботы КАК ТаблицаДокумента,
	|	ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
	|ГДЕ
	|	ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА
	|	И ВременнаяТаблицаШапка.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)
	|	И ТаблицаДокумента.СуммаНДС <> 0
	|	И НЕ ТаблицаДокумента.НДСВключатьВСтоимость
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаДокумента.Финиш,
	|	ТаблицаДокумента.Организация,
	|	ЗНАЧЕНИЕ(Справочник.ВидыНалогов.НДС),
	|	ТаблицаДокумента.СуммаНДС,
	|	&НачислениеНДСПродажи
	|ИЗ
	|	ВременнаяТаблицаТовары КАК ТаблицаДокумента,
	|	ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
	|ГДЕ
	|	ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА
	|	И ВременнаяТаблицаШапка.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)
	|	И ТаблицаДокумента.СуммаНДС <> 0
	|	И НЕ ТаблицаДокумента.НДСВключатьВСтоимость";
	
	Запрос.УстановитьПараметр("НачислениеНДСПродажи", СодержанияПроводок.НачислениеНДСПродажи());
	РезультатЗапроса = Запрос.Выполнить();
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоНалогам", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаЗапасы()

#Область Промокоды

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаПромокодыЗаказНаряд(ДокументСсылкаЧекККМ, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаШапка.Дата КАК Период,
	|	Промокоды.Промокод КАК Промокод,
	|	Промокоды.УсловиеПредоставленияСкидки КАК УсловиеПредоставленияСкидки,
	|	Промокоды.ДействуетС КАК ДействуетС,
	|	Промокоды.ДействуетДо КАК ДействуетДо,
	|	Промокоды.Конечный КАК Конечный
	|ИЗ
	|	ВременнаяТаблицаПромокоды КАК Промокоды,
	|	ВременнаяТаблицаШапка КАК ТаблицаШапка
	|ГДЕ
	|	Промокоды.ЭтоАктивацияПромокода";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПромокоды", РезультатЗапроса.Выгрузить());
		
КонецПроцедуры // СформироватьТаблицаЗапасы()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаПрименениеПромокодовЗаказНаряд(ДокументСсылкаЧекККМ, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПараметрыУсловий.Ссылка КАК УсловиеПредоставленияСкидки,
	|	СкидкиНаценки.СкидкаНаценка КАК СкидкаНаценка,
	|	СУММА(СкидкиНаценки.Сумма) КАК Сумма
	|ПОМЕСТИТЬ втСуммыСработавшихУсловий 
	|ИЗ
	|	ВременнаяТаблицаАвтоСкидкиНаценки КАК СкидкиНаценки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.АвтоматическиеСкидки.УсловияПредоставления КАК УсловияСкидок
	|		ПО (УсловияСкидок.Ссылка = СкидкиНаценки.СкидкаНаценка)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УсловияПредоставленияСкидокНаценок КАК ПараметрыУсловий
	|		ПО (ПараметрыУсловий.Ссылка = УсловияСкидок.УсловиеПредоставления)
	|			И (ПараметрыУсловий.УсловиеПредоставления = ЗНАЧЕНИЕ(Перечисление.УсловияПредоставленияСкидокНаценок.ЗаПромокод))
	|
	|СГРУППИРОВАТЬ ПО
	|	СкидкиНаценки.СкидкаНаценка,
	|	ПараметрыУсловий.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаШапка.Дата КАК Период,
	|	ТаблицаПромокоды.Промокод КАК Промокод,
	|	ПримененныеСкидки.СкидкаНаценка КАК СкидкаНаценка,
	|	1 КАК Количество,
	|	ПримененныеСкидки.Сумма КАК СуммаСкидки
	|ИЗ
	|	ВременнаяТаблицаПромокоды КАК ТаблицаПромокоды
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втСуммыСработавшихУсловий КАК ПримененныеСкидки
	|		ПО ТаблицаПромокоды.УсловиеПредоставленияСкидки = ПримененныеСкидки.УсловиеПредоставленияСкидки,
	|	ВременнаяТаблицаШапка КАК ТаблицаШапка
	|ГДЕ
	|	НЕ ТаблицаПромокоды.ЭтоАктивацияПромокода";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПрименениеПромокодов", РезультатЗапроса.Выгрузить());

КонецПроцедуры

Процедура СформироватьТаблицаДоступностьПромокодовЗаказНаряд(ДокументСсылкаЧекККМ, СтруктураДополнительныеСвойства)
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаШапка.Дата КАК Период,
	|	ТаблицаПромокоды.Промокод КАК Промокод,
	|	1 КАК Доступно
	|ИЗ
	|	ВременнаяТаблицаПромокоды КАК ТаблицаПромокоды,
	|	ВременнаяТаблицаШапка КАК ТаблицаШапка
	|ГДЕ
	|	НЕ ТаблицаПромокоды.ЭтоАктивацияПромокода
	|	И ТаблицаПромокоды.Конечный
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаШапка.Дата,
	|	ТаблицаПромокоды.Промокод,
	|	ТаблицаПромокоды.Доступно
	|ИЗ
	|	ВременнаяТаблицаПромокоды КАК ТаблицаПромокоды,
	|	ВременнаяТаблицаШапка КАК ТаблицаШапка
	|ГДЕ
	|	ТаблицаПромокоды.ЭтоАктивацияПромокода
	|	И ТаблицаПромокоды.Конечный";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДоступностьПромокодов", РезультатЗапроса.Выгрузить());
		
КонецПроцедуры // СформироватьТаблицаЗапасы()

#КонецОбласти

// Формирует таблицу значений, содержащую данные для проведения по регистрам ПартииТоваровУСН и ОписаниеОперацииКУДиР.
//  Таблицы значений сохраняет в свойствах структуры "СтруктураДополнительныеСвойства".
//
// Параметры:
//  ДокументСсылкаЗаказПокупателя - ДокументСсылка.ЗаказПокупателя - документ-источник движений
//  СтруктураДополнительныеСвойства	 - Структура - свойство объекта ДополнительныеСвойства
//
Процедура СформироватьТаблицаПартииТоваровУСН(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства) Экспорт
	
	ОрганизацияПартий = СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности;
	
	ТаблицыДвижений = УчетПартийУСН.ТаблицыДвиженийПоПартиямУСН(ОрганизацияПартий,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);
		
	ТаблицаПартииТоваров = ТаблицыДвижений.ТаблицаПартииТоваровУСН;
	ТаблицаОписаниеОперации = ТаблицыДвижений.ТаблицаОписаниеОперацииКУДиР;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПартииТоваровУСН", ТаблицаПартииТоваров);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаОписаниеОперацииКУДиР", ТаблицаОписаниеОперации);
	
	Если НЕ ТаблицыДвижений.ПроводитьПоПартиямУСН Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ СтруктураДополнительныеСвойства.ДляПроведения.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерВТ = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаЗаказПокупателя);
	Запрос.УстановитьПараметр("Период", СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Запрос.УстановитьПараметр("Организация", ОрганизацияПартий);
	Запрос.УстановитьПараметр("МоментВремени", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени);
		
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказНаряд.Ссылка КАК Ссылка,
	               |	ЗаказНаряд.Дата КАК Период,
	               |	ЗаказНаряд.Финиш КАК Финиш,
	               |	ЗаказНаряд.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	ЗаказНаряд.Контрагент КАК Контрагент,
	               |	ЗаказНаряд.Контрагент.Наименование КАК КонтрагентНаименование,
	               |	ЗаказНаряд.Контрагент.НаименованиеПолное КАК ЮридическоеНаименованиеКонтрагента
	               |ПОМЕСТИТЬ ТаблицаДокумента
	               |ИЗ
	               |	Документ.ЗаказПокупателя КАК ЗаказНаряд
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыЗаказНарядов.ПорядокСостояний КАК ВидыЗаказНарядовПорядокСостояний
	               |		ПО (ЗаказНаряд.Ссылка = &Ссылка)
	               |			И (ЗаказНаряд.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен))
	               |			И ЗаказНаряд.ВидЗаказа = ВидыЗаказНарядовПорядокСостояний.Ссылка
	               |			И ЗаказНаряд.СостояниеЗаказа = ВидыЗаказНарядовПорядокСостояний.Состояние
	               |			И (ВидыЗаказНарядовПорядокСостояний.НомерСтроки >= ВЫРАЗИТЬ(ЗаказНаряд.ВидЗаказа КАК Справочник.ВидыЗаказНарядов).НомерСостоянияВыполнения)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаДокумента.Финиш КАК Период,
	               |	ТаблицаДокумента.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	ЗаказПокупателяЗапасы.Номенклатура КАК Номенклатура,
	               |	ЗаказПокупателяЗапасы.Количество * ЕСТЬNULL(ЕдиницыИзмерения.Коэффициент, 1) КАК Количество,
	               |	ТаблицаДокумента.Контрагент КАК Контрагент,
	               |	ТаблицаДокумента.КонтрагентНаименование КАК КонтрагентНаименование,
	               |	ТаблицаДокумента.ЮридическоеНаименованиеКонтрагента КАК ЮридическоеНаименованиеКонтрагента
	               |ИЗ
	               |	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	               |		ПО ЗаказПокупателяЗапасы.ЕдиницаИзмерения = ЕдиницыИзмерения.Ссылка
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаДокумента КАК ТаблицаДокумента
	               |		ПО ЗаказПокупателяЗапасы.Ссылка = ТаблицаДокумента.Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТаблицаДокумента.Финиш,
	               |	ТаблицаДокумента.УчитыватьВНУ,
	               |	ЗаказПокупателяМатериалы.Номенклатура,
	               |	ЗаказПокупателяМатериалы.Количество * ЕСТЬNULL(ЕдиницыИзмерения.Коэффициент, 1),
	               |	ТаблицаДокумента.Контрагент,
	               |	ТаблицаДокумента.КонтрагентНаименование,
	               |	ТаблицаДокумента.ЮридическоеНаименованиеКонтрагента
	               |ИЗ
	               |	Документ.ЗаказПокупателя.Материалы КАК ЗаказПокупателяМатериалы
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	               |		ПО ЗаказПокупателяМатериалы.ЕдиницаИзмерения = ЕдиницыИзмерения.Ссылка
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаДокумента КАК ТаблицаДокумента
	               |		ПО ЗаказПокупателяМатериалы.Ссылка = ТаблицаДокумента.Ссылка";
	
	ТаблицаЗапасы = Запрос.Выполнить().Выгрузить();
	СписокТоваров = ТаблицаЗапасы.ВыгрузитьКолонку("Номенклатура");
	Запрос.УстановитьПараметр("Номенклатура", СписокТоваров);
	Запрос.Текст = УчетПартийУСН.ТекстЗапросаПартииДляСписания(Истина);
	ПартииСписать = Запрос.Выполнить().Выбрать();
	
	УчетПартийУСН.ЗаполнитьДвиженияСписаниеПартий(ДокументСсылкаЗаказПокупателя, ПартииСписать, ТаблицаЗапасы, ТаблицаПартииТоваров);
	
	Если ТаблицаПартииТоваров.Найти(Истина, "ОтражатьВКУДиР") <> Неопределено Тогда
		СтрокаОписание = ТаблицаОписаниеОперации.Добавить();
		СтрокаОписание.Период = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
		СтрокаОписание.Организация = ОрганизацияПартий;
		СтрокаОписание.ДатаПервичногоДокумента = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
		СтрокаОписание.НомерПервичногоДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(СтруктураДополнительныеСвойства.ДляПроведения.Номер, Истина, Истина);
		
		ТекстПокупатель = "";
		Если ТаблицаЗапасы.Количество() > 0 Тогда
			ТекстПокупатель = ?(ПустаяСтрока(ТаблицаЗапасы[0].ЮридическоеНаименованиеКонтрагента),
					ТаблицаЗапасы[0].НаименованиеКонтрагента,
					ТаблицаЗапасы[0].ЮридическоеНаименованиеКонтрагента);
		КонецЕсли;
		СтрокаОписание.Содержание = УчетПартийУСНКлиентСервер.СодержаниеПродажаТоваров(ТекстПокупатель);
	КонецЕсли;
	
КонецПроцедуры // СформироватьТаблицаПартииТоваровУСН()

#КонецОбласти  

#Область СозданиеНаОсновании

// СтандартныеПодсистемы.ПодключаемыеКоманды


// Определяет список команд создания на основании.
//
// Параметры:
//  КомандыСозданияНаОсновании - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.КомандыСозданияНаОсновании
//  Параметры - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.Параметры
//
Процедура ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры) Экспорт

	Если НЕ ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ПодключаемыеКоманды") Тогда
		Возврат;
	КонецЕсли;  

	//@skip-check module-unused-local-variable
	СтруктураПодменюВажное = Новый Структура("Подменю, Важность", "ПодменюСоздатьНаОснованииПереопределен", "Важное");
	СтруктураПодменюОбычное = Новый Структура("Подменю, Важность", "ПодменюСоздатьНаОснованииПереопределен", "Обычное");
	СтруктураПодменюСмТакже = Новый Структура("Подменю, Важность", "ПодменюСоздатьНаОснованииПереопределен", "СмТакже");   
	
	ОбъектМетаданных = "Документ.СчетНаОплату"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.СчетНаОплату.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументСчетНаОплатуСоздатьНаОсновании");	  
 	КонецЕсли;
	
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям("Документ.ПоступлениеВКассу") 
		ИЛИ ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям("Документ.ПоступлениеНаСчет") Тогда
		ДобавитьКомандуДокументЗаказПокупателяВвестиФактическийПлатеж(КомандыСозданияНаОсновании, СтруктураПодменюОбычное);  
  	КонецЕсли;

	ОбъектМетаданных = "Документ.ПоступлениеВКассу"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ПоступлениеВКассу.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументПоступлениеВКассуСоздатьНаОсновании");	
  	КонецЕсли;

	ОбъектМетаданных = "Документ.ПоступлениеНаСчет"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ПоступлениеНаСчет.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументПоступлениеНаСчетСоздатьНаОсновании");	
	КонецЕсли;   
	
	ОбъектМетаданных = "Документ.ОперацияПоПлатежнымКартам"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ОперацияПоПлатежнымКартам.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		СтруктураПодменюОбычноеОплатаКартой = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураПодменюОбычное);
		СтруктураПодменюОбычноеОплатаКартой.Вставить("Представление", НСтр("ru='Оплата картой'"));

		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычноеОплатаКартой, ОбъектМетаданных, "ФормаДокументОперацияПоПлатежнымКартамОплатаПлатежнойКартой");	
	КонецЕсли;   

	ОбъектМетаданных = "Документ.РасходныйОрдер"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.РасходныйОрдер.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументРасходныйОрдерСоздатьНаОсновании");	   
 	КонецЕсли;

	ОбъектМетаданных = "Документ.ЧекККМ"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ЧекККМ.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументЗаказПокупателяСоздатьЧекККМ");	   
 	КонецЕсли;

	ОбъектМетаданных = "Документ.РасходнаяНакладная"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		 Документы.РасходнаяНакладная.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		 ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументРасходнаяНакладнаяСоздатьНаОсновании");	
 	КонецЕсли;
	    
	ОбъектМетаданных = "Документ.АктВыполненныхРабот"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		 Документы.АктВыполненныхРабот.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);
		 ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументАктВыполненныхРаботСоздатьНаОсновании");	   
 	КонецЕсли;
	
	ОбъектМетаданных = "Документ.ПриходнаяНакладная"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ПриходнаяНакладная.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		СтруктураПодменюОбычноеВозвратОтПокупателя = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураПодменюОбычное);
		СтруктураПодменюОбычноеВозвратОтПокупателя.Вставить("Представление", НСтр("ru='Возврат от покупателя'"));
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычноеВозвратОтПокупателя, ОбъектМетаданных, "ФормаДокументПриходнаяНакладнаяСоздатьНаОсновании");	
		
		ДобавитьКомандуДокументПриходнаяНакладнаяПриемВПереработку(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
	КонецЕсли;
	
	ОбъектМетаданных = "Документ.ЗаказПоставщику"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		
		Документы.ЗаказПоставщику.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументЗаказПоставщикуСоздатьНаОсновании");	
		
		Обработки.РасчетПотребностей.ДобавитьКомандуЗаказыПоставщикам(КомандыСозданияНаОсновании, СтруктураПодменюОбычное);
		
		ДобавитьКомандуДокументЗаказПоставщикуПоКалькуляции(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
		
	КонецЕсли;

	ОбъектМетаданных = "Обработка.ТорговыеПредложения"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		ДобавитьКомандуДокументЗаказыПоставщикамБизнесСеть(КомандыСозданияНаОсновании, СтруктураПодменюОбычное);       
 	КонецЕсли;
	
	ОбъектМетаданных = "Документ.СборкаЗапасов"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.СборкаЗапасов.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		СтруктураПодменюОбычноеПроизводство = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураПодменюОбычное);
		СтруктураПодменюОбычноеПроизводство.Вставить("Представление", НСтр("ru='Производство'"));
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычноеПроизводство, ОбъектМетаданных, "ФормаДокументСборкаЗапасовСоздатьНаОсновании");	
		
		ДобавитьКомандуДокументСборкаЗапасовЧастичныйВыпуск(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
	КонецЕсли;


	ОбъектМетаданных = "Документ.ЗаказНаПроизводство"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ЗаказНаПроизводство.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументЗаказНаПроизводствоСоздатьНаОсновании");	
		ДобавитьКомандуДокументЗаказНаПроизводствоИерархический(КомандыСозданияНаОсновании, СтруктураПодменюОбычное);
	КонецЕсли; 
	
 	ОбъектМетаданных = "Документ.ПередачаТоваровМеждуОрганизациями"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ПередачаТоваровМеждуОрганизациями.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументПередачаТоваровМеждуОрганизациямиСоздатьНаОсновании");	
 	КонецЕсли;

	ОбъектМетаданных = "Документ.ЗаказНаПеремещение"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ЗаказНаПеремещение.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументЗаказНаПеремещениеСоздатьНаОсновании");	
 	КонецЕсли;

	ОбъектМетаданных = "Документ.ПеремещениеЗапасов"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ПеремещениеЗапасов.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументПеремещениеЗапасовСоздатьНаОсновании");	
 	КонецЕсли;
	
	ОбъектМетаданных = "Документ.РезервированиеЗапасов"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.РезервированиеЗапасов.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		СтруктураПодменюРезервирование = ОбщегоНазначения.СкопироватьРекурсивно(СтруктураПодменюОбычное);
		СтруктураПодменюРезервирование.Вставить("Представление", НСтр("ru='Резервирование (зарезервировать)'"));
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюРезервирование, ОбъектМетаданных, "ФормаДокументЗаказПокупателяРезервированиеСоздатьНаОсновании");	
		
		ДобавитьКомандуДокументРезервированиеСнятьРезерв(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
	КонецЕсли;
	
	ОбъектМетаданных = "Документ.ЗаданиеНаРаботу"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		ДобавитьКомандуДокументЗаданиеНаРаботуКоманда(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
 	КонецЕсли;

	ОбъектМетаданных = "Документ.ОтчетОПереработке"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ОтчетОПереработке.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументОтчетОПереработкеСоздатьНаОсновании");	
  	КонецЕсли;

	ОбъектМетаданных = "Документ.СдельныйНаряд"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.СдельныйНаряд.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументСдельныйНарядСоздатьНаОсновании");	
  	КонецЕсли;

	ОбъектМетаданных = "Документ.РаспределениеЗатрат"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.РаспределениеЗатрат.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументРаспределениеЗатратСоздатьНаОсновании");	
	КонецЕсли;   
	
	ОбъектМетаданных = "Документ.ПоступлениеДСПлан"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ПоступлениеДСПлан.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументПоступлениеДСПланСоздатьНаОсновании");	
 	КонецЕсли;

	ОбъектМетаданных = "Документ.ОтчетКомиссионераОСписании"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ОтчетКомиссионераОСписании.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументОтчетКомиссионераОСписанииСоздатьНаОсновании");	
 	КонецЕсли;

	ОбъектМетаданных = "Документ.ПереоценкаТоваровНаКомиссии"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ПереоценкаТоваровНаКомиссии.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументПереоценкаТоваровНаКомиссииСоздатьНаОсновании");	
 	КонецЕсли;

	ОбъектМетаданных = "Документ.КомплектацияЗапасов"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		ДобавитьКомандуКомплектация(КомандыСозданияНаОсновании, СтруктураПодменюОбычное);       
	КонецЕсли; 
	
	Если ПолучитьФункциональнуюОпцию( "ИспользоватьСервис1СДоставка" ) Тогда
 		ДобавитьКомандуЗаказНаДоставкуВ1СДоставка(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
 	КонецЕсли;
 	
 	Если ПолучитьФункциональнуюОпцию( "ИспользоватьСервис1СКурьер" ) Тогда
		ДобавитьКомандуЗаказНаДоставкуВ1СКурьер(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию( "ИспользоватьСервис1СКурьерика" ) Тогда	
		ДобавитьКомандуЗаказНаДоставкуВ1СКурьерика(КомандыСозданияНаОсновании, СтруктураПодменюОбычное); 
	КонецЕсли;

	ОбъектМетаданных = "Документ.АктОРасхожденияхПолученный"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.АктОРасхожденияхПолученный.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументАктОРасхожденияхПолученныйСоздатьНаОсновании");	
	КонецЕсли;
	
	РазделениеВключено = ОбщегоНазначения.РазделениеВключено();
	Если РазделениеВключено И ПолучитьФункциональнуюОпцию("ИспользоватьАвтоматическоеВыставлениеСчетовДляОплатыСервиса") Тогда 
		ДобавитьКомандуСоздатьПодпискуНаТариф(КомандыСозданияНаОсновании, СтруктураПодменюОбычное);                        
	КонецЕсли;
	
	ОбъектМетаданных = "Документ.Событие"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.Событие.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументСобытиеСоздатьНаОсновании");	
  	КонецЕсли;

	ОбъектМетаданных = "Документ.ЗакрытиеПланируемыхОплат"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.ЗакрытиеПланируемыхОплат.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных, "ФормаДокументЗакрытиеПлатежногоКалендаряСоздатьНаОсновании");	
	КонецЕсли;
	
	ОбъектМетаданных = "Документ.РасходыПредпринимателя"; 
	Если ОбщегоНазначения.ОбъектМетаданныхДоступенПоФункциональнымОпциям(ОбъектМетаданных) Тогда
		Документы.РасходыПредпринимателя.ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры);  
		ИзменитьСведенияПоследнейКоманды(КомандыСозданияНаОсновании, СтруктураПодменюОбычное, ОбъектМетаданных,
			"ФормаДокументРасходыПредпринимателяСоздатьНаОсновании");	
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьДополнительныеОбработкиСозданияСвязанныхОбъектов") Тогда
		ДобавитьКомандуСозданиеСвязанныхОбъектов(КомандыСозданияНаОсновании, СтруктураПодменюОбычное);       
  	КонецЕсли;

	Если НЕ Параметры.Свойство("ПоУмолчанию") Тогда  
		ТекущийПользователь = Пользователи.ТекущийПользователь();   
		НастройкиПользователя = РегистрыСведений.НастройкиВводаНаОсновании.НастройкиПользователя(ТекущийПользователь, ПолноеИмяОбъекта());    
		МассивУдаляемыхКоманд = Новый Массив;
		Для Каждого 	Команда Из КомандыСозданияНаОсновании Цикл 
			КомандаВНастройках = НастройкиПользователя.Найти(Команда.Представление, "Наименование");   
			Если КомандаВНастройках = Неопределено Тогда      
				МассивУдаляемыхКоманд.Добавить(Команда);
			ИначеЕсли НЕ КомандаВНастройках.Пометка Тогда      
				МассивУдаляемыхКоманд.Добавить(Команда);
			Иначе
				Команда.Порядок = НастройкиПользователя.Индекс(КомандаВНастройках) + 1; 
			КонецЕсли;
		КонецЦикла;
		Для Каждого 	Команда Из МассивУдаляемыхКоманд Цикл 
			КомандыСозданияНаОсновании.Удалить(Команда);     
		КонецЦикла;    
		
		ДобавитьКомандуНастройки(КомандыСозданияНаОсновании, СтруктураПодменюСмТакже);    
		
		Если НЕ Параметры.ЭтоФормаОбъекта Тогда      
			КопияТаблицы = КомандыСозданияНаОсновании.Скопировать();
			Для Каждого КомандаКопии Из КопияТаблицы Цикл    
				НоваяКоманда = КомандыСозданияНаОсновании.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяКоманда, КомандаКопии);
				НоваяКоманда.Подменю = "СписокКонтекстноеМенюСоздатьНаОснованииПереопределен"
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;  
	
КонецПроцедуры

// Для использования в процедуре ДобавитьКомандыСозданияНаОсновании других модулей менеджеров объектов.
// Добавляет в список команд создания на основании этот объект.
//
// Параметры:
//  КомандыСозданияНаОсновании - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.КомандыСозданияНаОсновании
//
// Возвращаемое значение:
//  СтрокаТаблицыЗначений, Неопределено - описание добавленной команды.
//
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ПодключаемыеКоманды") Тогда
		МодульСозданиеНаОсновании = ОбщегоНазначения.ОбщийМодуль("СозданиеНаОсновании");
		КомандаСозданияНаОсновании = МодульСозданиеНаОсновании.ДобавитьКомандуСозданияНаОсновании(КомандыСозданияНаОсновании, Метаданные.Документы.ЗаказПокупателя);
		Возврат КомандаСозданияНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Добавляет в список команду настройки
//
// Параметры:
//  КомандыСозданияНаОсновании - см. СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании.КомандыСозданияНаОсновании
//  Параметры - Структура - дополнительные параметры команды.
//
// Возвращаемое значение:
//  СтрокаТаблицыЗначений, Неопределено - описание добавленной команды.
//
Функция ДобавитьКомандуНастройки(КомандыСозданияНаОсновании, Параметры)
	
	МодульСозданиеНаОсновании = ОбщегоНазначения.ОбщийМодуль("СозданиеНаОсновании");
	КомандаСозданияНаОсновании = МодульСозданиеНаОсновании.ДобавитьКомандуСозданияНаОсновании(
		КомандыСозданияНаОсновании, Метаданные.Документы.ЗаказПокупателя);
	Если КомандаСозданияНаОсновании <> Неопределено Тогда
		КомандаСозданияНаОсновании.Обработчик = "СозданиеНаОснованииКлиент.ОткрытьФормуНастройкиПунктовСозданияНаОсновании";
		КомандаСозданияНаОсновании.ДополнительныеПараметры.Вставить("ПолноеИмяОбъекта", ПолноеИмяОбъекта());
		
		КомандаСозданияНаОсновании.Представление = РегистрыСведений.НастройкиВводаНаОсновании.НаименованиеПунктаНастроек();
		КомандаСозданияНаОсновании.Порядок = 90;   
		
		ЗаполнитьЗначенияСвойств(КомандаСозданияНаОсновании, Параметры);
		Возврат КомандаСозданияНаОсновании;
 	КонецЕсли;
	
КонецФункции

