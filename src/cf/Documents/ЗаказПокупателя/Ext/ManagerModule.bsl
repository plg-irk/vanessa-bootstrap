Процедура СформироватьТаблицаСерииНоменклатурыЗаказНаряд(ДокументСсылка, СтруктураДополнительныеСвойства)
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СНОбщаяТаблица.Период КАК Период,
	|	СНОбщаяТаблица.ВидДвижения КАК ВидДвижения,
	|	СНОбщаяТаблица.ДатаСобытия КАК ДатаСобытия,
	|	СНОбщаяТаблица.Операция КАК Операция,
	|	СНОбщаяТаблица.Серия КАК Серия,
	|	СНОбщаяТаблица.Организация КАК Организация,
	|	СНОбщаяТаблица.Номенклатура КАК Номенклатура,
	|	СНОбщаяТаблица.Характеристика КАК Характеристика,
	|	СНОбщаяТаблица.Партия КАК Партия,
	|	СНОбщаяТаблица.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СНОбщаяТаблица.Ячейка КАК Ячейка,
	|	СУММА(СНОбщаяТаблица.Количество) КАК Количество,
	|	СНОбщаяТаблица.ОстаткиСерийНоменклатуры КАК ОстаткиСерийНоменклатуры
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВременнаяТаблицаЗапасы.Период КАК Период,
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|		ВременнаяТаблицаЗапасы.Период КАК ДатаСобытия,
	|		ЗНАЧЕНИЕ(Перечисление.ОперацииСерийНоменклатуры.Расход) КАК Операция,
	|		СерииНоменклатуры.Серия КАК Серия,
	|		СерииНоменклатуры.ОстаткиСерийНоменклатуры КАК ОстаткиСерийНоменклатуры,
	|		ВременнаяТаблицаЗапасы.Организация КАК Организация,
	|		ВременнаяТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|		ВременнаяТаблицаЗапасы.Характеристика КАК Характеристика,
	|		ВременнаяТаблицаЗапасы.Партия КАК Партия,
	|		ВЫРАЗИТЬ(ВременнаяТаблицаЗапасы.СтруктурнаяЕдиница КАК Справочник.СтруктурныеЕдиницы) КАК СтруктурнаяЕдиница,
	|		ВременнаяТаблицаЗапасы.Ячейка КАК Ячейка,
	|		СерииНоменклатуры.Количество КАК Количество
	|	ИЗ
	|		ВременнаяТаблицаТовары КАК ВременнаяТаблицаЗапасы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаСерииНоменклатуры КАК СерииНоменклатуры
	|			ПО ВременнаяТаблицаЗапасы.КлючСвязи = СерииНоменклатуры.КлючСвязи,
	|		ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
	|	ГДЕ
	|		ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА
	|		И ВременнаяТаблицаШапка.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВременнаяТаблицаМатериалы.Период,
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|		ВременнаяТаблицаМатериалы.Период,
	|		ЗНАЧЕНИЕ(Перечисление.ОперацииСерийНоменклатуры.Расход),
	|		СерииНоменклатуры.Серия,
	|		СерииНоменклатуры.ОстаткиСерийНоменклатуры,
	|		ВременнаяТаблицаМатериалы.Организация,
	|		ВременнаяТаблицаМатериалы.Номенклатура,
	|		ВременнаяТаблицаМатериалы.Характеристика,
	|		ВременнаяТаблицаМатериалы.Партия,
	|		ВЫРАЗИТЬ(ВременнаяТаблицаМатериалы.СтруктурнаяЕдиницаЗапасов КАК Справочник.СтруктурныеЕдиницы),
	|		ВременнаяТаблицаМатериалы.Ячейка,
	|		СерииНоменклатуры.Количество
	|	ИЗ
	|		ВременнаяТаблицаМатериалы КАК ВременнаяТаблицаМатериалы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаСерииНоменклатурыМатериалы КАК СерииНоменклатуры
	|			ПО ВременнаяТаблицаМатериалы.КлючСвязиСерииНоменклатуры = СерииНоменклатуры.КлючСвязи,
	|		ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
	|	ГДЕ
	|		ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА
	|		И ВременнаяТаблицаШапка.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)) КАК СНОбщаяТаблица
	|ГДЕ
	|	НЕ(СНОбщаяТаблица.СтруктурнаяЕдиница.ОрдерныйСклад
	|				И СНОбщаяТаблица.СтруктурнаяЕдиница.ИспользоватьОрдернуюСхемуПриОтгрузке
	|				И (СНОбщаяТаблица.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоПрочимДокументам)
	|					ИЛИ СНОбщаяТаблица.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.ПоСкладуВЦелом)))
	|
	|СГРУППИРОВАТЬ ПО
	|	СНОбщаяТаблица.Период,
	|	СНОбщаяТаблица.ДатаСобытия,
	|	СНОбщаяТаблица.Операция,
	|	СНОбщаяТаблица.Серия,
	|	СНОбщаяТаблица.Организация,
	|	СНОбщаяТаблица.Номенклатура,
	|	СНОбщаяТаблица.Характеристика,
	|	СНОбщаяТаблица.Партия,
	|	СНОбщаяТаблица.СтруктурнаяЕдиница,
	|	СНОбщаяТаблица.Ячейка,
	|	СНОбщаяТаблица.ВидДвижения,
	|	СНОбщаяТаблица.ОстаткиСерийНоменклатуры";
	
	ТаблицаДвиженияСерииНоменклатуры = Запрос.Выполнить().Выгрузить();
	
	// Оприходование подарочных сертификатов при полном погашении, с целью повторной продажи этого сертификата.
	ВыполнятьДвиженияПоСертификатам = Истина;	
	ТекстЗапросаСертификаты = "
	|ВЫБРАТЬ
	|	ТаблицаСертификаты.ВидДвижения КАК ВидДвижения,
	|	ЗНАЧЕНИЕ(Перечисление.ОперацииСерийНоменклатуры.Приход) КАК Операция,
	|	ТаблицаСертификаты.Период КАК Период,
	|	ТаблицаСертификаты.Период КАК ДатаСобытия,
	|	ТаблицаСертификаты.Серия КАК Серия,
	|	Истина КАК ОстаткиСерийНоменклатуры,
	|	ТаблицаСертификаты.Организация КАК Организация,
	|	ТаблицаСертификаты.Номенклатура КАК Номенклатура,
	|	ТаблицаСертификаты.Характеристика КАК Характеристика,
	|	ТаблицаСертификаты.Партия КАК Партия,
	|	ТаблицаСертификаты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаСертификаты.Контрагент КАК Контрагент,
	|	ТаблицаСертификаты.Ячейка КАК Ячейка,
	|	ТаблицаСертификаты.ОрдерныйСклад КАК ОрдерныйСклад,
	|	1 КАК Количество
	|ИЗ
	|	ВложенныйЗапросСертификаты КАК ТаблицаСертификаты";
	ТекстЗапросаСертификаты = СтрЗаменить(ТекстЗапросаСертификаты, "ВложенныйЗапросСертификаты", "(" 
		+ РаботаСПодарочнымиСертификатами.ТекстЗапросаДвиженийЗапасыОприходованиеДляПовторнойПродажи(ВыполнятьДвиженияПоСертификатам) + ")");

	Запрос.Текст = ТекстЗапросаСертификаты;
	ТаблицаОприходованиеПодарочныхСертификатов = Запрос.Выполнить().Выгрузить();
	Если ТаблицаОприходованиеПодарочныхСертификатов.Количество() > 0 Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаОприходованиеПодарочныхСертификатов, ТаблицаДвиженияСерииНоменклатуры);
	КонецЕсли;	
	// Конец Оприходование подарочных сертификатов

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДвиженияСерииНоменклатуры", ТаблицаДвиженияСерииНоменклатуры);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСерииНоменклатурыГарантии", Новый ТаблицаЗначений);
	
	ПараметрыОтбора = Новый Структура("ОстаткиСерийНоменклатуры", Истина);
	ОстаткиСерийНоменклатурыСтроки = ТаблицаДвиженияСерииНоменклатуры.НайтиСтроки(ПараметрыОтбора);
	ТаблицаСерииНоменклатуры = ТаблицаДвиженияСерииНоменклатуры.Скопировать(ОстаткиСерийНоменклатурыСтроки);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСерииНоменклатуры", ТаблицаСерииНоменклатуры);
	
КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру СерииНоменклатурыКРасходу.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаСерииНоменклатурыКРасходуЗаказНаряд(ДокументСсылка, СтруктураДополнительныеСвойства)
	
	Если ДокументСсылка.СерииНоменклатуры.Количество() = 0 Тогда
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСерииНоменклатурыКРасходу", Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СНОбщаяТаблица.Период КАК Период,
	|	СНОбщаяТаблица.ВидДвижения КАК ВидДвижения,
	|	СНОбщаяТаблица.ДатаСобытия КАК ДатаСобытия,
	|	СНОбщаяТаблица.Операция КАК Операция,
	|	СНОбщаяТаблица.Серия КАК Серия,
	|	СНОбщаяТаблица.Организация КАК Организация,
	|	СНОбщаяТаблица.Номенклатура КАК Номенклатура,
	|	СНОбщаяТаблица.Характеристика КАК Характеристика,
	|	СНОбщаяТаблица.Партия КАК Партия,
	|	СНОбщаяТаблица.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СНОбщаяТаблица.Ячейка КАК Ячейка,
	|	СУММА(СНОбщаяТаблица.Количество) КАК Количество,
	|	СНОбщаяТаблица.ОстаткиСерийНоменклатуры КАК ОстаткиСерийНоменклатуры,
	|	СНОбщаяТаблица.ДокументОснование КАК ДокументОснование
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВременнаяТаблицаЗапасы.Период КАК Период,
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|		ВременнаяТаблицаЗапасы.Период КАК ДатаСобытия,
	|		ЗНАЧЕНИЕ(Перечисление.ОперацииСерийНоменклатуры.Расход) КАК Операция,
	|		СерииНоменклатуры.Серия КАК Серия,
	|		СерииНоменклатуры.ОстаткиСерийНоменклатуры КАК ОстаткиСерийНоменклатуры,
	|		ВременнаяТаблицаЗапасы.Организация КАК Организация,
	|		ВременнаяТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|		ВременнаяТаблицаЗапасы.Характеристика КАК Характеристика,
	|		ВременнаяТаблицаЗапасы.Партия КАК Партия,
	|		ВЫРАЗИТЬ(ВременнаяТаблицаЗапасы.СтруктурнаяЕдиница КАК Справочник.СтруктурныеЕдиницы) КАК СтруктурнаяЕдиница,
	|		ВременнаяТаблицаЗапасы.ЯчейкаКРасходу КАК Ячейка,
	|		ВременнаяТаблицаЗапасы.ДокументПоступления КАК ДокументОснование,
	|		СерииНоменклатуры.Количество КАК Количество
	|	ИЗ
	|		ВременнаяТаблицаТовары КАК ВременнаяТаблицаЗапасы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаСерииНоменклатуры КАК СерииНоменклатуры
	|			ПО ВременнаяТаблицаЗапасы.КлючСвязи = СерииНоменклатуры.КлючСвязи,
	|		ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
	|	ГДЕ
	|		ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА
	|		И ВременнаяТаблицаШапка.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ВременнаяТаблицаМатериалы.Период,
	|		ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|		ВременнаяТаблицаМатериалы.Период,
	|		ЗНАЧЕНИЕ(Перечисление.ОперацииСерийНоменклатуры.Расход),
	|		СерииНоменклатуры.Серия,
	|		СерииНоменклатуры.ОстаткиСерийНоменклатуры,
	|		ВременнаяТаблицаМатериалы.Организация,
	|		ВременнаяТаблицаМатериалы.Номенклатура,
	|		ВременнаяТаблицаМатериалы.Характеристика,
	|		ВременнаяТаблицаМатериалы.Партия,
	|		ВЫРАЗИТЬ(ВременнаяТаблицаМатериалы.СтруктурнаяЕдиницаЗапасов КАК Справочник.СтруктурныеЕдиницы),
	|		ВременнаяТаблицаМатериалы.ЯчейкаКРасходу,
	|		ВременнаяТаблицаМатериалы.ДокументПоступления,
	|		СерииНоменклатуры.Количество
	|	ИЗ
	|		ВременнаяТаблицаМатериалы КАК ВременнаяТаблицаМатериалы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаСерииНоменклатурыМатериалы КАК СерииНоменклатуры
	|			ПО ВременнаяТаблицаМатериалы.КлючСвязиСерииНоменклатуры = СерииНоменклатуры.КлючСвязи,
	|		ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка
	|	ГДЕ
	|		ВременнаяТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда = ИСТИНА
	|		И ВременнаяТаблицаШапка.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)) КАК СНОбщаяТаблица
	|ГДЕ
	|	СНОбщаяТаблица.СтруктурнаяЕдиница.ОрдерныйСклад
	|			И СНОбщаяТаблица.СтруктурнаяЕдиница.ИспользоватьОрдернуюСхемуПриОтгрузке
	|
	|СГРУППИРОВАТЬ ПО
	|	СНОбщаяТаблица.Период,
	|	СНОбщаяТаблица.ДатаСобытия,
	|	СНОбщаяТаблица.Операция,
	|	СНОбщаяТаблица.Серия,
	|	СНОбщаяТаблица.Организация,
	|	СНОбщаяТаблица.Номенклатура,
	|	СНОбщаяТаблица.Характеристика,
	|	СНОбщаяТаблица.Партия,
	|	СНОбщаяТаблица.СтруктурнаяЕдиница,
	|	СНОбщаяТаблица.Ячейка,
	|	СНОбщаяТаблица.ВидДвижения,
	|	СНОбщаяТаблица.ОстаткиСерийНоменклатуры,
	|	СНОбщаяТаблица.ДокументОснование";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	ПараметрыОтбора = Новый Структура("ОстаткиСерийНоменклатуры", Истина);
	ОстаткиСерийНоменклатурыСтроки = РезультатЗапроса.НайтиСтроки(ПараметрыОтбора);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСерииНоменклатурыКРасходу", РезультатЗапроса.Скопировать(ОстаткиСерийНоменклатурыСтроки));
	
КонецПроцедуры

Процедура СформироватьТаблицаПодарочныеСертификатыЗаказНаряд(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		
	ВыполнятьДвиженияПоСертификатам = Истина;	
	Запрос.Текст = РаботаСПодарочнымиСертификатами.ТекстЗапросаДвиженийПодарочныхСертификатов(ВыполнятьДвиженияПоСертификатам); 
	Результат = Запрос.Выполнить().Выгрузить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПодарочныеСертификаты", Результат);
	
КонецПроцедуры

Процедура СформироватьТаблицаОплатаПодарочнымиСертификатамиЗаказНаряд(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	ВыполнятьДвиженияПоСертификатам = Истина;	
	Запрос.Текст = РаботаСПодарочнымиСертификатами.ТекстЗапросаДвиженийОплатыПодарочнымиСертификатами(ВыполнятьДвиженияПоСертификатам);
	Результат = Запрос.Выполнить().Выгрузить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаОплатаПодарочнымиСертификатами", Результат);
	
КонецПроцедуры

Процедура СформироватьТаблицаРезервыТоваровОрганизацийЗаказНаряд(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства)
	
	Если Не ПолучитьФункциональнуюОпцию("ПередачаТоваровМеждуОрганизациями") Тогда
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРезервыТоваровОрганизаций", Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаСерииНоменклатуры.КлючСвязи КАК КлючСвязи,
	|	СУММА(ТаблицаСерииНоменклатуры.Количество) КАК Количество
	|ПОМЕСТИТЬ СерииСвернуто
	|ИЗ
	|	ВременнаяТаблицаСерииНоменклатуры КАК ТаблицаСерииНоменклатуры
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаСерииНоменклатуры.КлючСвязи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСерииНоменклатуры.КлючСвязи КАК КлючСвязи,
	|	СУММА(ТаблицаСерииНоменклатуры.Количество) КАК Количество
	|ПОМЕСТИТЬ СерииМатериалыСвернуто
	|ИЗ
	|	ВременнаяТаблицаСерииНоменклатурыМатериалы КАК ТаблицаСерииНоменклатуры
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаСерииНоменклатуры.КлючСвязи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаТовары.НомерСтроки КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаТовары.Финиш КАК Период,
	|	ТаблицаТовары.Организация КАК Организация,
	|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ТаблицаТовары.Характеристика КАК Характеристика,
	|	ТаблицаТовары.Партия КАК Партия,
	|	ТаблицаТовары.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаТовары.ОрдерныйСклад КАК ОрдерныйСклад,
	|	ТаблицаШапка.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ТаблицаТовары.Ячейка КАК Ячейка,
	|	ТаблицаТовары.НомерГТД КАК НомерГТД,
	|	ТаблицаТовары.СтранаПроисхождения КАК СтранаПроисхождения,
	|	ТаблицаСерииНоменклатуры.Серия КАК Серия,
	|	ТаблицаСерииНоменклатуры.ОстаткиСерийНоменклатуры КАК СерияСОстатком,
	|	ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка) КАК ЗаказРезерваСписание,
	|	ТаблицаСерииНоменклатуры.Количество КАК Количество
	|ПОМЕСТИТЬ ЗапасыДляРезервовТоваровОрганизаций
	|ИЗ
	|	ВременнаяТаблицаТовары КАК ТаблицаТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаСерииНоменклатуры КАК ТаблицаСерииНоменклатуры
	|		ПО ТаблицаТовары.КлючСвязи = ТаблицаСерииНоменклатуры.КлючСвязи,
	|	ВременнаяТаблицаШапка КАК ТаблицаШапка
	|ГДЕ
	|	ТаблицаТовары.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	|	И (ТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда
	|			ИЛИ ТаблицаТовары.Резерв > 0)
	|	И НЕ ТаблицаСерииНоменклатуры.Серия ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаТовары.НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	ТаблицаТовары.Финиш,
	|	ТаблицаТовары.Организация,
	|	ТаблицаТовары.Номенклатура,
	|	ТаблицаТовары.Характеристика,
	|	ТаблицаТовары.Партия,
	|	ТаблицаТовары.СтруктурнаяЕдиница,
	|	ТаблицаТовары.ОрдерныйСклад,
	|	ТаблицаШапка.ХозяйственнаяОперация,
	|	ТаблицаТовары.Ячейка,
	|	ТаблицаТовары.НомерГТД,
	|	ТаблицаТовары.СтранаПроисхождения,
	|	ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка),
	|	ЛОЖЬ,
	|	ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка),
	|	ВЫБОР
	|		КОГДА ТаблицаШапка.ЭтоСостояниеВыполненияЗаказНаряда
	|			ТОГДА ТаблицаТовары.Количество - ЕСТЬNULL(СерииСвернуто.Количество, 0)
