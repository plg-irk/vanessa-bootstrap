#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка.ЗаписиУСН
//  ДополнительныеСвойства - Структура 
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылка, ДополнительныеСвойства) Экспорт
	
	ДанныеПроведения = ДополнительныеСвойства.ДляПроведения;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	&Период КАК Период,
	|	&Организация КАК Организация,
	|	ЗаписиУСНЗаписиКУДиР.ДоходВсего КАК ДоходВсего,
	|	ЗаписиУСНЗаписиКУДиР.ДоходБаза КАК ДоходБаза,
	|	ЗаписиУСНЗаписиКУДиР.РасходВсего КАК РасходВсего,
	|	ЗаписиУСНЗаписиКУДиР.РасходБаза КАК РасходБаза,
	|	ЗаписиУСНЗаписиКУДиР.НДС КАК НДС,
	|	ЗаписиУСНЗаписиКУДиР.Содержание КАК Содержание,
	|	ЗаписиУСНЗаписиКУДиР.ПервичныйДокумент КАК ПервичныйДокумент,
	|	ЗаписиУСНЗаписиКУДиР.ДатаПервичногоДокумента КАК ДатаПервичногоДокумента,
	|	ЗаписиУСНЗаписиКУДиР.НомерПервичногоДокумента КАК НомерПервичногоДокумента,
	|	ЗаписиУСНЗаписиКУДиР.Ссылка.ВидЗаписей КАК ВидЗаписи,
	|	ЗаписиУСНЗаписиКУДиР.НомерСтроки КАК НомерСтрокиДокумента,
	|	ЗаписиУСНЗаписиКУДиР.ВзносыПодлежащиеУплате КАК ВзносыПодлежащиеУплате,
	|	ЗаписиУСНЗаписиКУДиР.ВидВзносаПодлежащегоУплате КАК ВидВзносаПодлежащегоУплате
	|ИЗ
	|	Документ.ЗаписиУСН.ЗаписиКУДиР КАК ЗаписиУСНЗаписиКУДиР
	|ГДЕ
	|	ЗаписиУСНЗаписиКУДиР.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаписиУСНГрафикПоОС.ПериодПризнания КАК Период,
	|	&Организация КАК Организация,
	|	ЗаписиУСНГрафикПоОС.ОсновноеСредство КАК ОсновноеСредство,
	|	ЗаписиУСНГрафикПоОС.Сумма КАК Сумма
	|ИЗ
	|	Документ.ЗаписиУСН.ГрафикПоОС КАК ЗаписиУСНГрафикПоОС
	|ГДЕ
	|	ЗаписиУСНГрафикПоОС.Ссылка = &Ссылка");
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеПроведения.Ссылка);
	Запрос.УстановитьПараметр("Период", ДанныеПроведения.Дата);
	Запрос.УстановитьПараметр("Организация", ДанныеПроведения.ОрганизацияДляРегОтчетности);
	
	Результат = Запрос.ВыполнитьПакет();
	
	ДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаКнигаУчетаДоходовИРасходов", Результат[0].Выгрузить());
	ДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаГрафикПризнанияРасходовНаОСиНМА",
		Результат[1].Выгрузить());
	
КонецПроцедуры

// Возвращает текстовое представление документа в виде
//
// Параметры:
//  ДокументСсылка - ДокументСсылка.ЗаписиУСН
//  
// Возвращаемое значение: 
//  - Строка - представление документа
//
Функция ОписаниеДокумента(ДокументСсылка) Экспорт
	
	ОписаниеДокумента = Новый Структура("Наименование");
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		РеквизитыДокумента    = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументСсылка,
			"Номер, Дата, Ссылка");
		
		НаименованиеДокумента = ДокументСсылка.Метаданные().Синоним;
		НомерДокумента        = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(РеквизитыДокумента.Номер, Истина, Истина);
		ДатаДокумента         = Формат(РеквизитыДокумента.Дата,"ДЛФ=D");
		Статус                = ИнтерфейсыВзаимодействияБРО.ПредставлениеСостоянияДокумента(РеквизитыДокумента.Ссылка);
		
		ШаблонПредставления = НСтр("ru = '%1 %2 от %3 (%4)'");
		
		ОписаниеДокумента.Наименование = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонПредставления,
			НаименованиеДокумента, НомерДокумента, ДатаДокумента, Статус);
	КонецЕсли;
	
	Возврат ОписаниеДокумента;
	
КонецФункции

// Возвращает список месяцев, в течение которых из доходов и/или расходов для КУДиР нужно исключать сумму НДС
//
// Параметры:
//  Организация - СправочникСсылка.Организации
//  ДатаНачала - Дата
//  ДатаОкончания - Дата
//  
// Возвращаемое значение: 
//  - Структура:
//     * МесяцыДоходыБезНДС - Массив из Дата
//     * МесяцыРасходыБезНДС - Массив из Дата
//
Функция МесяцыИсключенияНДСИзДоходовРасходов(Организация, ДатаНачала, ДатаОкончания) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("МесяцыДоходыБезНДС", Новый Массив);
	Результат.Вставить("МесяцыРасходыБезНДС", Новый Массив);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	РегламентированнаяОтчетностьУСН.ПолучитьВТПериодыСтавокНДСНаУСН(Запрос.МенеджерВременныхТаблиц, Организация,
		ДатаНачала, ДатаОкончания);
		
	Запрос.Текст = "ВЫБРАТЬ
	|	ВТПериодыСтавокНДСНаУСН.ПериодНачало КАК ПериодНачало,
	|	ВТПериодыСтавокНДСНаУСН.ПериодОкончание КАК ПериодОкончание,
	|	ВТПериодыСтавокНДСНаУСН.НДСИсключитьДоходы КАК НДСИсключитьДоходы,
	|	ВТПериодыСтавокНДСНаУСН.НДСИсключитьРасходы КАК НДСИсключитьРасходы
	|ИЗ
	|	ВТПериодыСтавокНДСНаУСН КАК ВТПериодыСтавокНДСНаУСН";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Месяц = НачалоМесяца(Выборка.ПериодНачало);
		Пока Месяц < Выборка.ПериодОкончание Цикл
			
			Если Выборка.НДСИсключитьДоходы Тогда
				Результат.МесяцыДоходыБезНДС.Добавить(Месяц);
			КонецЕсли;
			
			Если Выборка.НДСИсключитьРасходы Тогда
				Результат.МесяцыРасходыБезНДС.Добавить(Месяц);
			КонецЕсли;
			
			Месяц = ДобавитьМесяц(Месяц, 1);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

#КонецЕсли
