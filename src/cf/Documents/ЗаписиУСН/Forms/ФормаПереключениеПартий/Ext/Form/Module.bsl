
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.ВызваноПриОткрытии Тогда
		Элементы.ГруппаОтключитьПредупреждение.Видимость = Истина;
		Элементы.ДекорацияПредложение.Видимость = Истина;
	КонецЕсли;
	
	СпособУчетаПартийТоваров = УчетПартийУСН.ТекущийРегистрУчетаПартийТоваров();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Отмена(Команда)
	Если БольшеНеПоказывать Тогда
		Результат = Новый Структура;
		Результат.Вставить("ОтключитьПредупреждение", БольшеНеПоказывать);
	Иначе
		Результат = Неопределено;
	КонецЕсли;
	Закрыть(Результат);
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	
	Результат = Новый Структура;
	Результат.Вставить("ОтключитьПредупреждение", БольшеНеПоказывать);
	Результат.Вставить("ИзмененРегистрПартий", ИзменитьРегистрУчетаПартий(СпособУчетаПартийТоваров));
	
	Закрыть(Результат);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ИзменитьРегистрУчетаПартий(НовыйРегистр)
	
	ТекущийРегистр = УчетПартийУСН.ТекущийРегистрУчетаПартийТоваров();
	Если ТекущийРегистр = НовыйРегистр Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УчетПартийУСН.УстановитьРегистрУчетаПартийТоваров(НовыйРегистр);
	Возврат Истина;
	
КонецФункции

#КонецОбласти