#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Дата = КонецКвартала(ТекущаяДатаСеанса());
		Объект.ВидЗаписей = Перечисления.ВидыЗаписейФормированийКУДиР.РучныеЗаписи;
		ДокументыЗаПериод = Параметры.ДокументыЗаПериод;
		Если ЗначениеЗаполнено(Параметры.Организация) Тогда
			Объект.Организация = Параметры.Организация;
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ВидЗаписей = Перечисления.ВидыЗаписейФормированийКУДиР.РучныеЗаписи Тогда
		Элементы.ГруппаПредупреждения.Видимость = Ложь;
	Иначе
		ТолькоПросмотр = Истина;
	КонецЕсли;
	НомерСтроки = Параметры.НомерСтроки;
	Если Объект.ЗаписиКУДиР.Количество() > 0 Тогда
		РабочаяСтрока = Объект.ЗаписиКУДиР[НомерСтроки-1];
		ДоходыВсего = РабочаяСтрока.ДоходВсего;
		Доходы = РабочаяСтрока.ДоходБаза;
		ДоходыНДС = РабочаяСтрока.ДоходВсего - РабочаяСтрока.ДоходБаза;
		РасходыВсего = РабочаяСтрока.РасходБаза + РабочаяСтрока.НДС;
		Расходы = РабочаяСтрока.РасходБаза;
		РасходыНДС = РабочаяСтрока.НДС;
		ДатаПервичногоДокумента = РабочаяСтрока.ДатаПервичногоДокумента;
		НомерПервичногоДокумента = РабочаяСтрока.НомерПервичногоДокумента;
		Содержание = РабочаяСтрока.Содержание;
		ПервичныйДокумент = РабочаяСтрока.ПервичныйДокумент;
	КонецЕсли;
	
	ТекущийМесяц = ?(ЗначениеЗаполнено(ДатаПервичногоДокумента),
		НачалоМесяца(ДатаПервичногоДокумента), НачалоМесяца(Объект.Дата));
	ОбновитьМесяцыБезНДС();
	
	Элементы.ПервичныйДокумент.Видимость = ЗначениеЗаполнено(ПервичныйДокумент);
	
	УстановитьВидимостьИДоступностьЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	Если Объект.ВидЗаписей = Перечисления.ВидыЗаписейФормированийКУДиР.РучныеЗаписи Тогда
		ПроверяемыеРеквизиты.Добавить("НомерПервичногоДокумента");
		ПроверяемыеРеквизиты.Добавить("ДатаПервичногоДокумента");
		ПроверяемыеРеквизиты.Добавить("Содержание");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Если Объект.Ссылка.Пустая() Тогда
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	РабочаяСтрока = Неопределено;
	Если ТекущийОбъект.ВидЗаписей = Перечисления.ВидыЗаписейФормированийКУДиР.РучныеЗаписи Тогда
		// сохраняем ручные данные первой строки
		ТекущийОбъект.Дата = КонецКвартала(ДатаПервичногоДокумента);
		ТекущийОбъект.ЗаписиКУДиР.Очистить();
		РабочаяСтрока = ТекущийОбъект.ЗаписиКУДиР.Добавить();
	Иначе
		Если ТекущийОбъект.ЗаписиКУДиР.Количество() > 0 Тогда
			РабочаяСтрока = ТекущийОбъект.ЗаписиКУДиР[НомерСтроки-1];
		КонецЕсли;
	КонецЕсли;
	
	Если РабочаяСтрока <> Неопределено Тогда
		РабочаяСтрока.ДоходВсего = ДоходыВсего;
		РабочаяСтрока.ДоходБаза = Доходы;
		РабочаяСтрока.РасходВсего = РасходыВсего;
		РабочаяСтрока.РасходБаза = Расходы;
		РабочаяСтрока.НДС = РасходыНДС;
		РабочаяСтрока.ДатаПервичногоДокумента = ДатаПервичногоДокумента;
		РабочаяСтрока.НомерПервичногоДокумента = НомерПервичногоДокумента;
		РабочаяСтрока.Содержание = Содержание;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ОбновитьНастройкиНалогообложенияНДС();
КонецПроцедуры

&НаКлиенте
Процедура ДатаПервичногоДокументаПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(ДатаПервичногоДокумента) Тогда
		НовыйМесяц = НачалоМесяца(ДатаПервичногоДокумента);
	Иначе
		НовыйМесяц = НачалоМесяца(ОбщегоНазначенияКлиент.ДатаСеанса());
	КонецЕсли;
	
	Если НовыйМесяц <> ТекущийМесяц Тогда
		ТекущийМесяц = НовыйМесяц;
		ОбновитьНастройкиНалогообложенияНДС();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДоходыПриИзменении(Элемент)
	ОбновитьДоходыВсего();
КонецПроцедуры

&НаКлиенте
Процедура ДоходыНДСПриИзменении(Элемент)
	ОбновитьДоходыВсего();
КонецПроцедуры

&НаКлиенте
Процедура РасходыПриИзменении(Элемент)
	ОбновитьРасходыВсего();
КонецПроцедуры

&НаКлиенте
Процедура РасходыНДСПриИзменении(Элемент)
	ОбновитьРасходыВсего();
КонецПроцедуры

&НаКлиенте
Процедура ПервичныйДокументНажатие(Элемент, СтандартнаяОбработка)

	Если ЗначениеЗаполнено(ПервичныйДокумент) Тогда
		СтандартнаяОбработка = Ложь;
		ПоказатьЗначение( , ПервичныйДокумент);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВключитьФормуДляРедактирования(Команда)
	
	ТолькоПросмотр = Ложь;
	Элементы.ГруппаПредупреждения.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЗапись(Команда)
	
	Если НомерСтроки <> 0 Тогда
		УдалитьЗаписьСервер();
		Оповестить("ИзмененыЗаписиКУДИР");
	КонецЕсли;
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьДоходыВсего()
	ДоходыВсего = Доходы + ДоходыНДС;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРасходыВсего()
	РасходыВсего = Расходы + РасходыНДС;
КонецПроцедуры
	
&НаСервере
Процедура УстановитьВидимостьИДоступностьЭлементов() 
	
	Элементы.ГруппаРежимы.ТекущаяСтраница = Элементы.ГруппаРучная;
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		Элементы.ДоходыВсего.Видимость = ЗначениеЗаполнено(ДоходыВсего) ИЛИ ЗначениеЗаполнено(Доходы);
		Элементы.РасходыВсего.Видимость = ЗначениеЗаполнено(РасходыВсего) ИЛИ ЗначениеЗаполнено(Расходы);
	КонецЕсли;
	
	УстановитьОформлениеПолейНДС();
КонецПроцедуры

&НаСервере
Процедура УстановитьОформлениеПолейНДС()
	
	Если МесяцыДоходыБезНДС.Количество() = 0 И МесяцыРасходыБезНДС.Количество() = 0 Тогда
		Элементы.ДоходыНДС.Видимость = Ложь;
		ДоходыНДС = 0;
		Возврат;
	КонецЕсли;
	
	Элементы.ДоходыНДС.Видимость = Элементы.ДоходыВсего.Видимость;
	Элементы.ДоходыНДС.ТолькоПросмотр = Элементы.Доходы.ТолькоПросмотр;
	
	Если Элементы.РасходыВсего.Видимость Тогда
		Элементы.РасходыНДС.Видимость = Истина;
		НачалоТекущегоМесяца = НачалоМесяца(ДатаПервичногоДокумента);
		Если МесяцыРасходыБезНДС.НайтиПоЗначению(НачалоТекущегоМесяца) = Неопределено Тогда
			Элементы.РасходыНДС.ЦветФона = Элементы.Расходы.ЦветФона;
		Иначе
			Элементы.РасходыНДС.ЦветФона = Элементы.РасходыВсего.ЦветФона;
		КонецЕсли;
	Иначе
		Элементы.РасходыНДС.Видимость = Ложь;
	КонецЕсли;
	Элементы.РасходыНДС.ТолькоПросмотр = Элементы.Расходы.ТолькоПросмотр;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьЗаписьСервер()
	
	РабочаяСтрока = Объект.ЗаписиКУДиР[НомерСтроки - 1];
	Объект.ЗаписиКУДиР.Удалить(РабочаяСтрока);
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьНастройкиНалогообложенияНДС()
	
	ОбновитьМесяцыБезНДС();
	УстановитьОформлениеПолейНДС();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьМесяцыБезНДС()
	
	МесяцыДоходыБезНДС.Очистить();
	МесяцыРасходыБезНДС.Очистить();

	МесяцыИсключенияНДС = Документы.ЗаписиУСН.МесяцыИсключенияНДСИзДоходовРасходов(Объект.Организация,
		НачалоГода(ТекущийМесяц), КонецГода(ТекущийМесяц));

	МесяцыДоходыБезНДС.ЗагрузитьЗначения(МесяцыИсключенияНДС.МесяцыДоходыБезНДС);
	МесяцыРасходыБезНДС.ЗагрузитьЗначения(МесяцыИсключенияНДС.МесяцыРасходыБезНДС);
	
КонецПроцедуры

#КонецОбласти
