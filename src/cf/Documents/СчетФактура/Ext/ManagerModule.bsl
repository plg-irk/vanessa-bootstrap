	Реквизиты = Запрос.Выполнить().Выбрать();
	Если НЕ Реквизиты.Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	НомерСчетаФактуры = ПредставлениеНомераСчетаФактуры(Реквизиты);
	Запрос.УстановитьПараметр("НомерСчетаФактуры", НомерСчетаФактуры);
	Запрос.УстановитьПараметр("ПостфиксДляНомера", "");
	
	КодВидаОперации = Реквизиты.КодВидаОперации;
	КодВидаОперацииПоУмолчанию = "01";
	
	Если НЕ ЗначениеЗаполнено(КодВидаОперации) Тогда
		КодВидаОперации = КодВидаОперацииПоУмолчанию;
	КонецЕсли;
	
	ОперацииОбновитьКод = Новый Массив;
	ОперацииОбновитьКод.Добавить(Перечисления.ВидыОперацийСчетФактура.Аванс);
	ОперацииОбновитьКод.Добавить(Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса);
	ОперацииОбновитьКод.Добавить(Перечисления.ВидыОперацийСчетФактура.НаАвансКомитента);
	ОперацииОбновитьКод.Добавить(Перечисления.ВидыОперацийСчетФактура.СуммовыеРазницы);
	Если КодВидаОперации = КодВидаОперацииПоУмолчанию
		И ОперацииОбновитьКод.Найти(Реквизиты.ВидСчетаФактуры) <> Неопределено Тогда
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("Дата", Реквизиты.Дата);
		СтруктураПараметров.Вставить("ВидОперации", Реквизиты.ВидСчетаФактуры);
		СтруктураПараметров.Вставить("Исправление", Реквизиты.Исправление);
		СтруктураПараметров.Вставить("Контрагент", Реквизиты.Контрагент);
