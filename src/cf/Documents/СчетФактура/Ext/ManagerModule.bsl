		СтруктураПараметров.Вставить("Продавец", Справочники.Контрагенты.ПустаяСсылка());
		
		ЗапросДокументыОснования = Новый Запрос;
		ЗапросДокументыОснования.УстановитьПараметр("СсылкаНаДокумент", ДокументСсылкаСчетФактура);
		ЗапросДокументыОснования.Текст =
		"ВЫБРАТЬ
		|	СчетФактураДокументыОснования.ДокументОснование
		|ИЗ
		|	Документ.СчетФактура.ДокументыОснования КАК СчетФактураДокументыОснования
		|ГДЕ
		|	СчетФактураДокументыОснования.Ссылка = &СсылкаНаДокумент";

		ТаблицаОснований = ЗапросДокументыОснования.Выполнить().Выгрузить();
			
		Если ТаблицаОснований.Количество() > 0 Тогда
			СтруктураПараметров.Вставить("ДокументыОснования", ТаблицаОснований);
			КодВидаОперации = ПолучитьКодВидаОперации(СтруктураПараметров);
		КонецЕсли;
	КонецЕсли;
	Запрос.УстановитьПараметр("КодВидаОперации", КодВидаОперации);
		
