	|    ВТ_КурсыДокОсн.КурсУпрВал,
	|    ВТ_КурсыДокОсн.КратностьРегВал";

	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	Возврат ТекстЗапроса;

КонецФункции // ИнициализироватьДанныеДокумента()
