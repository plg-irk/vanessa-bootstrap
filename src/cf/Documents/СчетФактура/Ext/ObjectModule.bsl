		|ГДЕ
		|	ПлатежныйДокументРасшифровкаПлатежа.Ссылка = &СсылкаНаДокумент";
		
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеВКассу") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ПоступлениеВКассу");		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ПоступлениеНаСчет");
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ОперацияПоПлатежнымКартам");
	КонецЕсли;
	ТаблицаРасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
	
	СтавкаБезНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();

	Для Каждого СтрокаРасшифровки Из ТаблицаРасшифровкаПлатежа Цикл

		Если Не СтрокаРасшифровки.ПризнакАванса Или СтрокаРасшифровки.СтавкаНДС = СтавкаБезНДС Тогда

			Продолжить;

		КонецЕсли;

		СтавкуНДСРасчетная = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСРасчетная(СтрокаРасшифровки.СтавкаНДС);

        Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса И Авансы.Количество() > 0 Тогда
			КорректируемыйСчетФактура =  Авансы[0].КорректируемыйСчетФактура;
			Авансы.Очистить();
		КонецЕсли;

		Если Авансы.Количество() > 0 И Авансы[0].СтавкаНДС = СтавкуНДСРасчетная Тогда
			СтрокаДатаНомерДокументовОплаты = Авансы[0];
			СтрокаДатаНомерДокументовОплаты.Сумма = СтрокаДатаНомерДокументовОплаты.Сумма
				+ (СтрокаРасшифровки.СуммаПлатежа);
			СтрокаДатаНомерДокументовОплаты.СуммаНДС = СтрокаДатаНомерДокументовОплаты.СуммаНДС
				+ СтрокаРасшифровки.СуммаНДС;
		Иначе
				СтрокаДатаНомерДокументовОплаты = Авансы.Добавить();
				СтрокаДатаНомерДокументовОплаты.Содержание = НСтр("ru ='Предварительная оплата'");
				СтрокаДатаНомерДокументовОплаты.Сумма = СтрокаРасшифровки.СуммаПлатежа;
				СтрокаДатаНомерДокументовОплаты.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСРасчетная(
				СтрокаРасшифровки.СтавкаНДС);
				СтрокаДатаНомерДокументовОплаты.СуммаНДС = СтрокаРасшифровки.СуммаНДС;
				СтрокаДатаНомерДокументовОплаты.ДокументОснование = ДанныеЗаполнения;
				Если ОбщегоНазначения.ЕстьРеквизитОбъекта("НомерВходящегоДокумента", ДанныеЗаполнения.Метаданные()) Тогда
					СтрокаДатаНомерДокументовОплаты.НомерПлатежноРасчетногоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
					ДанныеЗаполнения, "НомерВходящегоДокумента");
					СтрокаДатаНомерДокументовОплаты.ДатаПлатежноРасчетногоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
					ДанныеЗаполнения, "ДатаВходящегоДокумента");
				КонецЕсли;
				
				Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса Тогда

				Если ЗначениеЗаполнено(КорректируемыйСчетФактура) Тогда
					СтрокаДатаНомерДокументовОплаты.КорректируемыйСчетФактура = КорректируемыйСчетФактура;
					
					ДанныеСтроки = Новый Структура;
					ДанныеСтроки.Вставить("КорректируемыйСчетФактура");
					ДанныеСтроки.Вставить("Сумма");
					ДанныеСтроки.Вставить("СтавкаНДС");
					ДанныеСтроки.Вставить("СуммаНДС");
					ДанныеСтроки.Вставить("Дата");

					ЗаполнитьЗначенияСвойств(ДанныеСтроки, СтрокаДатаНомерДокументовОплаты);
					ЗаполнитьЗначенияСвойств(ДанныеСтроки, ЭтотОбъект, "Дата");
					ПараметрыДоплаты = Документы.СчетФактура.ПараметрыДоплатыКАвансу(ДанныеСтроки);
					ЗаполнитьЗначенияСвойств(СтрокаДатаНомерДокументовОплаты, ПараметрыДоплаты);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	ДатаНомерДокументовОплаты.Очистить();

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеВКассу") Тогда

		СтрокаДатаНомерДокументовОплаты = ДатаНомерДокументовОплаты.Добавить();
		СтрокаДатаНомерДокументовОплаты.ДатаПлатежноРасчетногоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "Дата");
		СтрокаДатаНомерДокументовОплаты.НомерПлатежноРасчетногоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "Номер");

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда

		СтрокаДатаНомерДокументовОплаты = ДатаНомерДокументовОплаты.Добавить();
		СтрокаДатаНомерДокументовОплаты.ДатаПлатежноРасчетногоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "ДатаВходящегоДокумента");
		СтрокаДатаНомерДокументовОплаты.НомерПлатежноРасчетногоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "НомерВходящегоДокумента");

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьСведения(ДанныеЗаполнения, СведенияДокументовОснований, СуммыДокументовОснований)

	ТипыДокументовРеализаций = Новый Массив;
	ТипыДокументовРеализаций.Добавить(Тип("ДокументСсылка.АктВыполненныхРабот"));
	ТипыДокументовРеализаций.Добавить(Тип("ДокументСсылка.ЗаказПокупателя"));
	ТипыДокументовРеализаций.Добавить(Тип("ДокументСсылка.РасходнаяНакладная"));
	ТипыДокументовРеализаций.Добавить(Тип("ДокументСсылка.КорректировкаРеализации"));
	ТипыДокументовРеализаций.Добавить(Тип("ДокументСсылка.ОтчетКомиссионера"));

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаРеализации") 
		И ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда

		ЗаполнитьСведенияШапкиПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований);
		ЗаполнитьСуммуДокументаАвансПоКорректировке(ДанныеЗаполнения, СуммыДокументовОснований);
		ЗаполнитьДатаНомерДокументовОплатыПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований);
    
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетКомиссионера")
		И (ВидОперации = Перечисления.ВидыОперацийСчетФактура.СводнаяСправка
		ИЛИ ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка) Тогда
		
		// см. ЗаполнитьПоПокупателямОтчетаКомиссионера
        ЗаполнитьСведенияШапкиПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований);
		
		Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.СводнаяСправка Тогда
			ЗаполнитьПоПокупателямОтчетаКомиссионераСводнаяСправка(ДанныеЗаполнения, СведенияДокументовОснований,
				СуммыДокументовОснований);
		ИначеЕсли
		ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка Тогда
			ЗаполнитьПоПокупателямОтчетаКомиссионераСводнаяСправкаКорректировка(ДанныеЗаполнения,
				СведенияДокументовОснований, СуммыДокументовОснований);
		КонецЕсли;
	ИначеЕсли ТипыДокументовРеализаций.Найти(ТипЗнч(ДанныеЗаполнения)) <> Неопределено Тогда

		ЗаполнитьСведенияШапкиПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований);
		ЗаполнитьСуммуДокументаПоРеализации(ДанныеЗаполнения, СуммыДокументовОснований);
		ЗаполнитьДатаНомерДокументовОплатыПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований);

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетКомитенту") Тогда

		ЗаполнитьСведенияШапкиПоОтчетуКомитента(ДанныеЗаполнения, СведенияДокументовОснований);
		ЗаполнитьСуммуДокументаПоОтчетуКомитента(ДанныеЗаполнения, СведенияДокументовОснований,
			СуммыДокументовОснований);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда

		Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.СводнаяСправка Тогда
			ЗаполнитьПоОтчетОРозничныхПродажахСводнаяСправка(ДанныеЗаполнения, СведенияДокументовОснований,
				СуммыДокументовОснований);
		ИначеЕсли ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка Тогда
			ЗаполнитьПоОтчетОРозничныхПродажахСводнаяСправкаКорректировка(ДанныеЗаполнения, СведенияДокументовОснований,
				СуммыДокументовОснований);
		ИначеЕсли ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда		
				
		КонецЕсли;

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетОПереработке") Тогда

		ЗаполнитьСведенияШапкиПоПереработке(ДанныеЗаполнения, СведенияДокументовОснований);
		ЗаполнитьСуммуДокументаПоПереработке(ДанныеЗаполнения, СведенияДокументовОснований, СуммыДокументовОснований);

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриемИПередачаВРемонт") Тогда

		ЗаполнитьСведенияШапкиПоРемонту(ДанныеЗаполнения, СведенияДокументовОснований);
		ЗаполнитьСуммуДокументаПоРемонту(ДанныеЗаполнения, СведенияДокументовОснований, СуммыДокументовОснований);

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеВКассу") Или ТипЗнч(ДанныеЗаполнения) = Тип(
		"ДокументСсылка.ПоступлениеНаСчет") Или ТипЗнч(ДанныеЗаполнения) = Тип(
		"ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда

		ЗаполнитьСведенияШапкиПоАвансу(ДанныеЗаполнения, СведенияДокументовОснований);

		Если СведенияДокументовОснований.ВидОперации <> Перечисления.ВидыОперацийСчетФактура.СуммовыеРазницы Тогда

			ЗаполнитьСуммуДокументаПоАвансу(ДанныеЗаполнения, СуммыДокументовОснований);
			ЗаполнитьРасшифровкуАванса(ДанныеЗаполнения, СуммыДокументовОснований);

		КонецЕсли;

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ДокументРасчетовСКонтрагентом") Тогда

		ЗаполнитьСведенияШапкиПоАвансу(ДанныеЗаполнения, СведенияДокументовОснований);

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями") Тогда

		ЗаполнитьСведенияШапкиПоПередачеТоваровМеждуОрганизациями(ДанныеЗаполнения, СведенияДокументовОснований);
		ЗаполнитьСуммуДокументаПоРеализации(ДанныеЗаполнения, СуммыДокументовОснований);
		ЗаполнитьДатаНомерДокументовОплатыПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований);

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриходнаяНакладная") 
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ДанныеЗаполнения, "ПокупателюВыставляетсяКорректировочныйСчетФактура") = Истина Тогда
		ЗаполнитьСведенияШапкиПоПоступлению(ДанныеЗаполнения, СведенияДокументовОснований);
		ЗаполнитьСуммуДокументаПоРеализации(ДанныеЗаполнения, СуммыДокументовОснований);
	КонецЕсли;

КонецПроцедуры

Процедура ВыполнитьОбработкуЗаполнения()

	СуммыДокументовОснований = СуммыДокументовОснований();

	Если ДокументыОснования.Количество() < 1 Тогда

		ЗаполнитьЗначенияСвойств(ЭтотОбъект, СуммыДокументовОснований);
		Возврат;

	КонецЕсли;

	СведенияДокументовОснований = Новый Структура();
	СведенияДокументовОснований.Вставить("Организация");
	СведенияДокументовОснований.Вставить("Контрагент");
	СведенияДокументовОснований.Вставить("Договор");
	СведенияДокументовОснований.Вставить("ВалютаДокумента");
	СведенияДокументовОснований.Вставить("Кратность");
	СведенияДокументовОснований.Вставить("Курс");
	СведенияДокументовОснований.Вставить("ОснованиеПечати");
	СведенияДокументовОснований.Вставить("ПодписьРуководителя");
	СведенияДокументовОснований.Вставить("ПодписьГлавногоБухгалтера");
	СведенияДокументовОснований.Вставить("ПодписьКладовщика");
	СведенияДокументовОснований.Вставить("ХозяйственнаяОперация");
	СведенияДокументовОснований.Вставить("ЭтоВозврат");												  

	Если Ссылка.Пустая() Тогда
		СведенияДокументовОснований.Вставить("Автор");
	КонецЕсли;
	СведенияДокументовОснований.Вставить("ЕстьПрослеживаемыеТовары", Ложь);

	УдалитьЗапасы.Очистить();
	
	Если Не ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса Тогда
		Авансы.Очистить();
	КонецЕсли;

	Если Не ДанныеОбОплатеИзмененыВручную Тогда
		ДатаНомерДокументовОплаты.Очистить();
	КонецЕсли;

	Если Не ДополнительныеСвойства.Свойство("ЭтоСинхронизация") Или ДополнительныеСвойства.ЭтоСинхронизация = Ложь Тогда

		ПервыйДокументОснование = ДокументыОснования[0].ДокументОснование;
		Если ТипЗнч(ПервыйДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
			Дата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПервыйДокументОснование, "Финиш");
		Иначе
			Дата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПервыйДокументОснование, "Дата");
		КонецЕсли;

	КонецЕсли;

	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.СводнаяСправка Или ВидОперации
		= Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка Тогда
		СуммаДокумента = 0;
		СуммаНДСДокумента = 0;
	КонецЕсли;

	ЕстьДокументРасчетовСКонтрагентом = Ложь;

	Для Каждого СтрокаТаблицы Из ДокументыОснования Цикл

		ЗаполнитьСведения(СтрокаТаблицы.ДокументОснование, СведенияДокументовОснований, СуммыДокументовОснований);

		Если (ТипЗнч(СтрокаТаблицы.ДокументОснование) = Тип("ДокументСсылка.КорректировкаРеализации") И Не ВидОперации
			= Перечисления.ВидыОперацийСчетФактура.Аванс) Или (ТипЗнч(СтрокаТаблицы.ДокументОснование) = Тип(
			"ДокументСсылка.ПриходнаяНакладная")
			И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТаблицы.ДокументОснование,
			"ПокупателюВыставляетсяКорректировочныйСчетФактура")) Тогда

			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СведенияДокументовОснований,
				"НомерИсходногоДокумента, ДатаИсходногоДокумента, УчитыватьИсправлениеИсходногоДокумента, НомерИсправленияИсходногоДокумента, ДатаИсправленияИсходногоДокумента");

		КонецЕсли;

		ЕстьДокументРасчетовСКонтрагентом = ?(Не ЕстьДокументРасчетовСКонтрагентом, ТипЗнч(
			СтрокаТаблицы.ДокументОснование) = Тип("ДокументСсылка.ДокументРасчетовСКонтрагентом"),
			ЕстьДокументРасчетовСКонтрагентом);

	КонецЦикла;

	Если Не ЗначениеЗаполнено(СведенияДокументовОснований.ЭтоВозврат) Тогда

		СведенияДокументовОснований.ЭтоВозврат = Перечисления.ДаНет.Нет;

	КонецЕсли;

	Если Ссылка.Пустая() Тогда
		СведенияДокументовОснований.Автор = Пользователи.АвторизованныйПользователь();
	КонецЕсли;

	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СведенияДокументовОснований);

	Если ЕстьДокументРасчетовСКонтрагентом И СуммыДокументовОснований.СуммаДокумента = 0 Тогда
		СуммыДокументовОснований.СуммаДокумента = СуммаДокумента;
		СуммыДокументовОснований.СуммаНДСДокумента = СуммаНДСДокумента;
	КонецЕсли;

	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СуммыДокументовОснований);

	КодВидаОперацииОснованияУменьшение = "";
	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.Корректировка Тогда
		ВерсияКодовВидовОпераций = УчетНДСКлиентСервер.ВерсияКодовВидовОпераций(Дата);
		Если ВерсияКодовВидовОпераций > 1 Тогда
			Если КодВидаОперацииОснованияУменьшение <> "" Тогда
				КодВидаОперацииНаУменьшение = КодВидаОперацииОснованияУменьшение;
			Иначе
				Если ЗначениеЗаполнено(Договор) И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор,
					"УчетАгентскогоНДСПокупателем") Тогда
					КодВидаОперацииНаУменьшение = "34";
				Иначе
					КодВидаОперацииНаУменьшение = "18";
				КонецЕсли;
			КонецЕсли;
		Иначе
			КодВидаОперацииНаУменьшение = "";
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура ДозаполнитьРеквизитыСводныхСправок()

	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка Тогда
		НомерДата = Документы.СчетФактура.ДатаНомерДляПечати(ИсправляемыйСчетФактура);
		Если ЗначениеЗаполнено(НомерДата.Номер) Тогда
			НомерИсходногоДокумента = НомерДата.Номер;
			ДатаИсходногоДокумента = НомерДата.Дата;
		Иначе
			РеквизитыДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ИсправляемыйСчетФактура, "Номер, Дата");
			НомерИсходногоДокумента = РеквизитыДокумента.Номер;
			ДатаИсходногоДокумента = РеквизитыДокумента.Дата;
		КонецЕсли;		
	КонецЕсли;

КонецПроцедуры

// Суммы документов оснований.
// 
// Возвращаемое значение:
//  Структура:
// * СуммаДокумента - Число 
// * СуммаУвеличение - Число 
// * СуммаУменьшение - Число 
// * СуммаНДСДокумента - Число 
// * СуммаНДСУвеличение - Число 
// * СуммаНДСУменьшение - Число 
// * СуммаДокументаКомиссия - Число 
// * СуммаНДСДокументаКомиссия - Число
// * СуммаУвеличениеКомиссия - Число
// * СуммаУменьшениеКомиссия - Число 
// * СуммаНДСУвеличениеКомиссия - Число 
// * СуммаНДСУменьшениеКомиссия - Число 
Функция СуммыДокументовОснований()
	
	Результат = Новый Структура;
	Результат.Вставить("СуммаДокумента", 0);
	Результат.Вставить("СуммаУвеличение", 0);
	Результат.Вставить("СуммаУменьшение", 0);
	Результат.Вставить("СуммаНДСДокумента", 0);
	Результат.Вставить("СуммаНДСУвеличение", 0);
	Результат.Вставить("СуммаНДСУменьшение", 0);
	Результат.Вставить("СуммаДокументаКомиссия", 0);
	Результат.Вставить("СуммаНДСДокументаКомиссия", 0);
	Результат.Вставить("СуммаУвеличениеКомиссия", 0);
	Результат.Вставить("СуммаУменьшениеКомиссия", 0);
	Результат.Вставить("СуммаНДСУвеличениеКомиссия", 0);
	Результат.Вставить("СуммаНДСУменьшениеКомиссия", 0);
	
	Возврат Результат;
	
КонецФункции

