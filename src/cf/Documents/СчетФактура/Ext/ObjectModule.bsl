Процедура ЗаполнитьСуммыОтчетКомиссионераКорректировка(ДокументОснование)
	
	СуммыДокументов = СуммыДокументовОснований();
	ТекстЗапроса = ТекстЗапросаСуммыОтчетКомиссионераКорректировка();
	ЗаполнитьСуммыДокументов(ТекстЗапроса, ДокументОснование, СуммыДокументов);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СуммыДокументов);
	
КонецПроцедуры

Функция ТекстЗапросаСуммыОтчетКомиссионераКорректировка()
	
	Текст = "ВЫБРАТЬ
	|	ОтчетКомиссионера.Ссылка КАК Ссылка,
	|	ОтчетКомиссионера.СуммаВключаетНДС КАК СуммаВключаетНДС
	|ПОМЕСТИТЬ ВТДокументыВозврата
	|ИЗ
	|	Документ.ОтчетКомиссионера КАК ОтчетКомиссионера
	|ГДЕ
	|	ОтчетКомиссионера.Ссылка В (&Ссылка)
	|	И ОтчетКомиссионера.НаВозвратыВыставляетсяКорректировочныйСчетФактура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТДокументыВозврата.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ВТДокументыВозврата.СуммаВключаетНДС
	|			ТОГДА ЗапасыВозвраты.Сумма - ЗапасыВозвраты.СуммаНДС
	|		ИНАЧЕ ЗапасыВозвраты.Сумма
	|	КОНЕЦ КАК СуммаУменьшение,
	|	ЗапасыВозвраты.СуммаНДС КАК СуммаНДСУменьшение
	|ПОМЕСТИТЬ ВТСуммыДокумента
	|ИЗ
	|	Документ.ОтчетКомиссионера.ЗапасыВозвраты КАК ЗапасыВозвраты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыВозврата КАК ВТДокументыВозврата
	|		ПО ЗапасыВозвраты.Ссылка = ВТДокументыВозврата.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтчетКомиссионера.ПокупателиВозвраты КАК ПокупателиВозвраты
	|		ПО ЗапасыВозвраты.Ссылка = ПокупателиВозвраты.Ссылка
	|		И ЗапасыВозвраты.КлючСвязи = ПокупателиВозвраты.КлючСвязи
	|		И ПокупателиВозвраты.ВыставленСФ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТДокументыВозврата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСуммыДокумента.Ссылка КАК ДокументСсылка,
	|	СУММА(ВТСуммыДокумента.СуммаУменьшение) КАК СуммаДокумента,
	|	СУММА(ВТСуммыДокумента.СуммаНДСУменьшение) КАК СуммаНДСДокумента,
	|	СУММА(ВТСуммыДокумента.СуммаУменьшение) КАК СуммаУменьшение,
	|	СУММА(ВТСуммыДокумента.СуммаНДСУменьшение) КАК СуммаНДСУменьшение
	|ИЗ
	|	ВТСуммыДокумента КАК ВТСуммыДокумента
	|СГРУППИРОВАТЬ ПО
	|	ВТСуммыДокумента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыДокумента";
	
	Возврат Текст;
	
КонецФункции

#КонецОбласти

#Область ОтчетОРозничныхПродажах

Процедура ЗаполнитьПоОтчетОРозничныхПродажахСводнаяСправкаКорректировка(СтруктураЗаполнения,
	СведенияДокументовОснований, СуммыДокументовОснований) Экспорт
	
	// Заполнение шапки.
	ДанныеЗаполнения	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураЗаполнения, "Ссылка");;

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ВалютаДокумента", Истина);

	Курс = 1;
	Кратность = 1;
	
	//

	Если ВалютаДокумента <> Константы.НациональнаяВалюта.Получить() Тогда

		ВалютаКурсКратность = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ДанныеЗаполнения, "ВалютаДокумента"), Дата);
		ДанныеКурса = Новый Структура("Курс, Кратность", ВалютаКурсКратность.Курс, ВалютаКурсКратность.Кратность);

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеКурса, "Курс");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеКурса, "Кратность");

	КонецЕсли;

	Если ДокументыОснования.Найти(ДанныеЗаполнения, "ДокументОснование") = Неопределено Тогда

		НоваяСтрока = ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ДанныеЗаполнения;

	КонецЕсли;

	Если ЗначениеЗаполнено(Организация) Тогда

		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Организация,
			"ПодписьРуководителя, ПодписьГлавногоБухгалтера");
		ДанныеПодписей = Новый Структура("ПодписьРуководителя, ПодписьГлавногоБухгалтера",
			ЗначенияРеквизитов.ПодписьРуководителя, ЗначенияРеквизитов.ПодписьГлавногоБухгалтера);

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеПодписей, "ПодписьРуководителя");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеПодписей, "ПодписьГлавногоБухгалтера");

	КонецЕсли;
    
    Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", СтруктураЗаполнения);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОтчетОРозничныхПродажахЗапасы.СтавкаНДС КАК СтавкаНДС,
	|	ОтчетОРозничныхПродажахЗапасы.Сумма КАК Сумма,
	|	ОтчетОРозничныхПродажахЗапасы.СуммаНДС КАК СуммаНДС,
	|	ОтчетОРозничныхПродажахЗапасы.СтавкаНДС.Ставка КАК СтавкаНДССтавка,
	|	ОтчетОРозничныхПродажахЗапасы.Возврат КАК Возврат
	|ИЗ
	|	Документ.ОтчетОРозничныхПродажах.Запасы КАК ОтчетОРозничныхПродажахЗапасы
	|ГДЕ
	|	ОтчетОРозничныхПродажахЗапасы.Ссылка = &СсылкаНаДокумент";

	РезультатПоиска = Запрос.Выполнить().Выгрузить();

	Для Каждого СтрокаТабличнойЧасти Из РезультатПоиска Цикл

		Если СтрокаТабличнойЧасти.Возврат = 0 Тогда
			Продолжить;
		КонецЕсли;

		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "СуммаВключаетНДС") Тогда
			СуммаБезНДС = Окр(СтрокаТабличнойЧасти.Сумма / ((СтрокаТабличнойЧасти.СтавкаНДССтавка + 100) / 100), 2);
		Иначе
			СуммаБезНДС = СтрокаТабличнойЧасти.Сумма;
		КонецЕсли;

		СуммаДокумента = СуммаДокумента + (-СуммаБезНДС);
		СуммаНДСДокумента = СуммаНДСДокумента + (-СтрокаТабличнойЧасти.СуммаНДС);

	КонецЦикла;

	СуммыДокументовОснований.СуммаДокумента = СуммаДокумента;
	СуммыДокументовОснований.СуммаНДСДокумента = СуммаНДСДокумента;
	СуммыДокументовОснований.СуммаУменьшение = СуммаДокумента;
	СуммыДокументовОснований.СуммаНДСУменьшение = СуммаНДСДокумента;

КонецПроцедуры

Процедура ЗаполнитьПоОтчетОРозничныхПродажахСводнаяСправка(СтруктураЗаполнения, СведенияДокументовОснований,
