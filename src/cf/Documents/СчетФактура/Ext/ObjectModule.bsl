Процедура ЗаполнитьСведенияШапкиПоАвансу(ДанныеЗаполнения, СведенияДокументовОснований)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", ДанныеЗаполнения);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПлатежныйДокументРасшифровкаПлатежа.Договор КАК Договор
		|ИЗ
		|	Документ.%ТипДокумента%.РасшифровкаПлатежа КАК ПлатежныйДокументРасшифровкаПлатежа
		|ГДЕ
		|	ПлатежныйДокументРасшифровкаПлатежа.Ссылка = &СсылкаНаДокумент";
	
	ВидОперацииСчетФактуры = Перечисления.ВидыОперацийСчетФактура[?(ДополнительныеСвойства.Свойство(
		"ЭтоСуммоваяРазница"), "СуммовыеРазницы", "Аванс")];
	
	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.НаАвансКомитента 
		И ВидОперацииСчетФактуры = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда
		СведенияДокументовОснований.Вставить("ВидОперации", Перечисления.ВидыОперацийСчетФактура.НаАвансКомитента);
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса 
		И ВидОперацииСчетФактуры = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда	
	    СведенияДокументовОснований.Вставить("ВидОперации", Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса);
	Иначе
		СведенияДокументовОснований.Вставить("ВидОперации", ВидОперацииСчетФактуры);
	КонецЕсли;

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Контрагент", Истина);

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ДокументРасчетовСКонтрагентом") Тогда
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, "ДоговорКонтрагента, ВалютаДокумента");
		СведенияДокументовОснований.Договор = ЗначенияРеквизитов.ДоговорКонтрагента;
		СведенияДокументовОснований.ВалютаДокумента = ЗначенияРеквизитов.ВалютаДокумента;
		Возврат;
	КонецЕсли
	;

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеВКассу") Тогда

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьРуководителя");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьГлавногоБухгалтера");

		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ПоступлениеВКассу");	
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеНаСчет") Или ТипЗнч(ДанныеЗаполнения) = Тип(
		"ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда

			
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ДанныеЗаполнения, "Организация"), "ПодписьРуководителя");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ДанныеЗаполнения, "Организация"), "ПодписьГлавногоБухгалтера");

		ТипДокумента = ?(ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеНаСчет"), "ПоступлениеНаСчет",
		"ОперацияПоПлатежнымКартам");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", ТипДокумента);
	КонецЕсли;

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ХозяйственнаяОперация");
    
    ТаблицаРасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
    
	Если ТаблицаРасшифровкаПлатежа.Количество() > 0 Тогда

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ТаблицаРасшифровкаПлатежа[0], "Договор", Истина);

	КонецЕсли;

	Если СведенияДокументовОснований.ВидОперации = Перечисления.ВидыОперацийСчетФактура.СуммовыеРазницы Тогда

		СведенияДокументовОснований.Вставить("ВалютаДокумента", Константы.НациональнаяВалюта.Получить());
		СведенияДокументовОснований.Вставить("СтавкаНДССуммовойРазницы",
			УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС(18));

	ИначеЕсли СведенияДокументовОснований.Свойство("ВалютаДокумента") И ЗначениеЗаполнено(
		СведенияДокументовОснований.ВалютаДокумента) И СведенияДокументовОснований.ВалютаДокумента
		<> ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "ВалютаДенежныхСредств") Тогда

		ВызватьИсключение СтрШаблон(НСтр("ru ='Ввод счета-фактуры по различающимся значениям запрещен (%1).'"), НСтр(
			"ru ='Валюта документа'"));

	Иначе

		СведенияДокументовОснований.Вставить("ВалютаДокумента", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ДанныеЗаполнения, "ВалютаДенежныхСредств"));
		Если ПолучитьФункциональнуюОпцию("УчетВалютныхОпераций") Тогда

			Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "ВалютаДенежныхСредств")
				<> Константы.НациональнаяВалюта.Получить() Тогда

				СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата, Новый Структура("Валюта",
					ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "ВалютаДенежныхСредств")));
				СведенияДокументовОснований.Вставить("Курс", СтруктураПоВалюте.Курс);
				СведенияДокументовОснований.Вставить("Кратность", СтруктураПоВалюте.Кратность);

			КонецЕсли;

		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьСуммуДокументаПоАвансу(ДанныеЗаполнения, СуммыДокументовОснований)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", ДанныеЗаполнения);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПлатежныйДокументРасшифровкаПлатежа.ПризнакАванса,
		|	ПлатежныйДокументРасшифровкаПлатежа.СтавкаНДС,
		|	ПлатежныйДокументРасшифровкаПлатежа.СуммаНДС,
		|	ПлатежныйДокументРасшифровкаПлатежа.СуммаПлатежа
		|ИЗ
		|	Документ.%ТипДокумента%.РасшифровкаПлатежа КАК ПлатежныйДокументРасшифровкаПлатежа
		|ГДЕ
		|	ПлатежныйДокументРасшифровкаПлатежа.Ссылка = &СсылкаНаДокумент";
		
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеВКассу") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ПоступлениеВКассу");		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ПоступлениеНаСчет");
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ОперацияПоПлатежнымКартам");
	КонецЕсли;
	ТаблицаРасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();	
		
	СтавкаБезНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();

	СуммаНДСДокументаОснования = 0;
	СуммаДокументаОснования = 0;
	Для Каждого СтрокаРасшифровки Из ТаблицаРасшифровкаПлатежа Цикл

		Если Не СтрокаРасшифровки.ПризнакАванса Или СтрокаРасшифровки.СтавкаНДС = СтавкаБезНДС Тогда

			Продолжить;

		КонецЕсли;

		СуммаНДСДокументаОснования = СуммаНДСДокументаОснования + СтрокаРасшифровки.СуммаНДС;
		СуммаДокументаОснования = СуммаДокументаОснования + (СтрокаРасшифровки.СуммаПлатежа
			- СтрокаРасшифровки.СуммаНДС);

	КонецЦикла;

	СуммыДокументовОснований.СуммаДокумента = СуммыДокументовОснований.СуммаДокумента + СуммаДокументаОснования;
	СуммыДокументовОснований.СуммаНДСДокумента = СуммыДокументовОснований.СуммаНДСДокумента + СуммаНДСДокументаОснования;

КонецПроцедуры

Процедура ЗаполнитьСуммуДокументаАвансПоКорректировке(ДанныеЗаполнения, СуммыДокументовОснований)

	Авансы.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", ДанныеЗаполнения);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КорректировкаРеализацииЗапасы.СуммаДоИзменения,
		|	КорректировкаРеализацииЗапасы.Сумма,
		|	КорректировкаРеализацииЗапасы.СуммаНДС,
		|	КорректировкаРеализацииЗапасы.СуммаНДСДоИзменения
		|ИЗ
		|	Документ.КорректировкаРеализации.Запасы КАК КорректировкаРеализацииЗапасы
		|ГДЕ
		|	КорректировкаРеализацииЗапасы.Ссылка = &СсылкаНаДокумент";

	Запасы = Запрос.Выполнить().Выгрузить();

	СуммаДокументаОснования = Запасы.Итог("СуммаДоИзменения") - Запасы.Итог("Сумма");
	СуммаНДСДокументаОснования = Запасы.Итог("СуммаНДСДоИзменения") - Запасы.Итог("СуммаНДС");
	Если СуммаДокументаОснования < 0 Тогда
		СуммаДокументаОснования = 0;
		СуммаНДСДокументаОснования = 0;
	Иначе

		РеквизитыДокументы = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения,
			"Организация, Дата, СуммаВключаетНДС");

		СтавкаНДСАвансыПеречисление = УчетНДСВызовСервера.РасчетнаяСтавкаНДСОрганизации(РеквизитыДокументы.Организация,
			РеквизитыДокументы.Дата);
		СтавкаНДСАвансы = Справочники.СтавкиНДС.СтавкаНДСПоПеречислениюСтавкиНДС(СтавкаНДСАвансыПеречисление);

		СтрокаАванса = Авансы.Добавить();
		СтрокаАванса.Содержание = НСтр("ru ='Предварительная оплата'");
		СтрокаАванса.СтавкаНДС = СтавкаНДСАвансы;
		СтрокаАванса.СуммаНДС = УчетНДСКлиентСервер.РассчитатьСуммуНДС(
        СуммаДокументаОснования, РеквизитыДокументы.СуммаВключаетНДС, УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(
            СтавкаНДСАвансыПеречисление));
		СуммаНДСДокументаОснования = СтрокаАванса.СуммаНДС;

		Если РеквизитыДокументы.СуммаВключаетНДС Тогда
			СтрокаАванса.Сумма = СуммаДокументаОснования;
			СуммаДокументаОснования = СуммаДокументаОснования - СуммаНДСДокументаОснования;
		Иначе
			СтрокаАванса.Сумма = СуммаДокументаОснования + СуммаНДСДокументаОснования;
		КонецЕсли;

	КонецЕсли;
	СуммыДокументовОснований.СуммаДокумента = СуммыДокументовОснований.СуммаДокумента + СуммаДокументаОснования;
	СуммыДокументовОснований.СуммаНДСДокумента = СуммыДокументовОснований.СуммаНДСДокумента + СуммаНДСДокументаОснования;

КонецПроцедуры

Процедура ЗаполнитьРасшифровкуАванса(ДанныеЗаполнения, СуммыДокументовОснований)

