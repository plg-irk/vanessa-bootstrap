    // Заполнение шапки.
	ДанныеЗаполнения    = СтруктураЗаполнения.Ссылка;

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ВалютаДокумента", Истина);

	Курс = 1;
	Кратность = 1;
    
    //

	Если ВалютаДокумента <> Константы.НациональнаяВалюта.Получить() Тогда

		ВалютаКурсКратность = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ДанныеЗаполнения.ВалютаДокумента, Дата);
		ДанныеКурса = Новый Структура("Курс, Кратность", ВалютаКурсКратность.Курс, ВалютаКурсКратность.Кратность);

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеКурса, "Курс");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеКурса, "Кратность");

	КонецЕсли;

	Если ДокументыОснования.Найти(ДанныеЗаполнения, "ДокументОснование") = Неопределено Тогда

		НоваяСтрока = ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ДанныеЗаполнения;

	КонецЕсли;

	Если ЗначениеЗаполнено(Организация) Тогда

		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Организация,
			"ПодписьРуководителя, ПодписьГлавногоБухгалтера");
		ДанныеПодписей = Новый Структура("ПодписьРуководителя, ПодписьГлавногоБухгалтера",
			ЗначенияРеквизитов.ПодписьРуководителя, ЗначенияРеквизитов.ПодписьГлавногоБухгалтера);

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеПодписей, "ПодписьРуководителя");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеПодписей, "ПодписьГлавногоБухгалтера");

	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", СтруктураЗаполнения);
	Запрос.Текст =
	"ВЫБРАТЬ
	|    ОтчетОРозничныхПродажахЗапасы.СтавкаНДС,
	|    ОтчетОРозничныхПродажахЗапасы.Сумма,
	|    ОтчетОРозничныхПродажахЗапасы.СуммаНДС,
	|    ОтчетОРозничныхПродажахЗапасы.СтавкаНДС.Ставка,
	|    ОтчетОРозничныхПродажахЗапасы.Возврат
	|ИЗ
	|    Документ.ОтчетОРозничныхПродажах.Запасы КАК ОтчетОРозничныхПродажахЗапасы
	|ГДЕ
	|    ОтчетОРозничныхПродажахЗапасы.Ссылка = &СсылкаНаДокумент";

	ТаблицаЗапасы = Запрос.Выполнить().Выгрузить();

	СтруктураПоиска = Новый Структура("Возврат", 0);
	РезультатПоиска = ТаблицаЗапасы.НайтиСтроки(СтруктураПоиска);

	Для Каждого СтрокаТабличнойЧасти Из РезультатПоиска Цикл
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "СуммаВключаетНДС") Тогда
			СуммаБезНДС = Окр(СтрокаТабличнойЧасти.Сумма / ((СтрокаТабличнойЧасти.СтавкаНДССтавка + 100) / 100), 2);
		Иначе
			СуммаБезНДС = СтрокаТабличнойЧасти.Сумма;
		КонецЕсли;

		СуммаДокумента = СуммаДокумента + СуммаБезНДС;
		СуммаНДСДокумента = СуммаНДСДокумента + СтрокаТабличнойЧасти.СуммаНДС;

	КонецЦикла;

	СуммыДокументовОснований.СуммаДокумента = СуммаДокумента;
	СуммыДокументовОснований.СуммаНДСДокумента = СуммаНДСДокумента;

КонецПроцедуры

