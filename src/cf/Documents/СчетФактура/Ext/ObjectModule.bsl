	СуммаНДСДокументаОснования = ТаблицаПродукция.Итог("СуммаНДС");

	ДобавитьЗначенияДокументаВИтоговыеСуммы(ДанныеЗаполнения, СуммыДокументовОснований, СуммаДокументаОснования,
		СуммаНДСДокументаОснования);

