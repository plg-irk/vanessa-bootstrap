#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Процедура - обработчик события ПриКопировании объекта.
//
Процедура ПриКопировании(ОбъектКопирования)

	ВызватьИсключение НСтр("ru ='Для документа счет-фактура копирование не предусмотрено'");

КонецПроцедуры // ПриКопировании()

// Процедура - обработчик события ОбработкаЗаполнения объекта.
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)

	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") И Не ДанныеЗаполнения.Свойство("Ссылка") Тогда

		ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ЭтотОбъект, ДанныеЗаполнения);

		ДозаполнитьРеквизитыСводныхСправок();

	ИначеЕсли ЗначениеЗаполнено(ДанныеЗаполнения) Или (ТипЗнч(ДанныеЗаполнения) = Тип("ТаблицаЗначений")) Тогда

		ЗаполнитьДокументыОснования(ДанныеЗаполнения);
		ВыполнитьОбработкуЗаполнения();
		ДозаполнитьРеквизитыСводныхСправок();
//		ЗаполнитьТаблицуАвансы();

	Иначе

		Организация = Справочники.Организации.ОрганизацияПоУмолчанию();

	КонецЕсли;

	Если ЭтоВозврат <> Перечисления.ДаНет.Да Тогда

		ЭтоВозврат = Перечисления.ДаНет.Нет;

	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(КодВидаОперации) Тогда
		КодВидаОперации = Документы.СчетФактура.ПолучитьКодВидаОперации(ЭтотОбъект);
	КонецЕсли;
	
	Если НЕ ВидОперации = Перечисления.ВидыОперацийСчетФактура.СводнаяСправка
		И НЕ ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка
		И НЕ ЗначениеЗаполнено(ДатаВыставления) Тогда
		ВыставленСтатус = 2;
		ДатаВыставления = ?(Не ЗначениеЗаполнено(Дата), ТекущаяДатаСеанса(), Дата);
	КонецЕсли;
	
КонецПроцедуры // ОбработкаЗаполнения()

// Процедура - обработчик события ОбработкаПроверкиЗаполнения объекта.
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)

	Если Исправление Тогда

		ПроверяемыеРеквизиты.Добавить("НомерИсправления");
		ПроверяемыеРеквизиты.Добавить("ДатаИсправления");

	КонецЕсли;

	Если ДокументыОснования.Количество() < 1 Тогда

		НеобходимоЗаполнитьДокументы = НСтр(
			"ru = 'Необходимо заполнить документы, которые являются основаниями счета-фактуры.'");
		ОбщегоНазначения.СообщитьПользователю(НеобходимоЗаполнитьДокументы, ЭтотОбъект, , , Отказ);

	Иначе

		Для Каждого СтрокаТаблицы Из ДокументыОснования Цикл

			ДокументОснование = СтрокаТаблицы.ДокументОснование;

			Если ЗначениеЗаполнено(ДокументОснование) И Не ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование,
				"Проведен") Тогда

				ДокументОснованиеНеПроведен = СтрШаблон(НСтр(
					"ru = 'Документ-основание %1 № %2 от %3 не проведен. Проведение счет фактуры невозможно.'"), ТипЗнч(
					ДокументОснование), ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование, "Номер"), Формат(
					ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументОснование, "Дата"), "ДЛФ=D;"));
				ОбщегоНазначения.СообщитьПользователю(ДокументОснованиеНеПроведен, ЭтотОбъект, , , Отказ);

			КонецЕсли;

		КонецЦикла;

	КонецЕсли;

	ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизитДоговор(ПроверяемыеРеквизиты, ЭтотОбъект);

	Если ТребуетсяОтразитьСуммыДокументаВНациональнойВалюте() Тогда

		Если ДокументыОснования.Количество() = 1 И Не ЗначениеЗаполнено(ДокументыОснования[0].ДокументОснование) Тогда

			НеВыбранДокументОснование = НСтр("ru = 'Не выбран документ-основание.'");
			ОбщегоНазначения.СообщитьПользователю(НеВыбранДокументОснование, ЭтотОбъект, , , Отказ);

		КонецЕсли;

	КонецЕсли;

	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировкаАванса Тогда

		ИмяСписка = НСтр("ru = 'Расшифровка аванса'");
		Для Каждого СтрокаАвансы Из Авансы Цикл

			ИндексСтроки = Формат(СтрокаАвансы.НомерСтроки - 1, "ЧН=0; ЧГ=");
			Если СтрокаАвансы.СуммаДоКорректировки > СтрокаАвансы.Сумма Тогда

				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Корректность", НСтр(
					"ru = 'Сумма'"), СтрокаАвансы.НомерСтроки, ИмяСписка);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, СтрШаблон("Авансы[%1].Сумма",
					ИндексСтроки), "Объект", Отказ);

			КонецЕсли;

			Если СтрокаАвансы.СуммаНДСДоКорректировки > СтрокаАвансы.СуммаНДС Тогда

				ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Корректность", НСтр(
					"ru = 'Сумма НДС'"), СтрокаАвансы.НомерСтроки, ИмяСписка);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, СтрШаблон("Авансы[%1].СуммаНДС",
					ИндексСтроки), "Объект", Отказ);

			КонецЕсли;

		КонецЦикла;

	Иначе

		ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Авансы.КорректируемыйСчетФактура");
		ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Авансы.СуммаДоКорректировки");
		ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Авансы.СтавкаНДСДоКорректировки");
		ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Авансы.СуммаНДСДоКорректировки");

	КонецЕсли;

	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.СводнаяСправка Или ВидОперации
		= Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка Тогда
		ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Контрагент");
		ЗаполнениеОбъектовУНФ.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "Договор");
	КонецЕсли;

	ИменаТабличныхЧастей = Новый Массив;
	ИменаТабличныхЧастей.Добавить("УдалитьЗапасы");

	ГрузовыеТаможенныеДекларацииСервер.ПриОбработкеПроверкиЗаполнения(Отказ, ЭтотОбъект, ИменаТабличныхЧастей);

КонецПроцедуры // ОбработкаПроверкиЗаполнения()

// Процедура - обработчик события ПередЗаписью объекта.
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если ОбменДаннымиСобытияУНФ.ПропуститьДозаполнениеДокумента(ЭтотОбъект, РежимЗаписи) Тогда
		Возврат;
	КонецЕсли;
	
	ТипыРеализации = Новый Массив;
	ТипыРеализации.Добавить(Тип("ДокументСсылка.ЗаказПокупателя"));
	ТипыРеализации.Добавить(Тип("ДокументСсылка.КорректировкаРеализации"));
	ТипыРеализации.Добавить(Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями"));
	ТипыРеализации.Добавить(Тип("ДокументСсылка.ПриходнаяНакладная"));
	ТипыРеализации.Добавить(Тип("ДокументСсылка.РасходнаяНакладная"));
	ТипыРеализации.Добавить(Тип("ДокументСсылка.ОтчетКомиссионера"));
	МассивОснованийРеализации = Новый Массив;
	 
	// Проверка на уникальность счета-фактуры
	Для Каждого СтрокаОснование Из ДокументыОснования Цикл
		
		Если ТипыРеализации.Найти(ТипЗнч(СтрокаОснование.ДокументОснование)) <> Неопределено Тогда 
			МассивОснованийРеализации.Добавить(СтрокаОснование.ДокументОснование);
		КонецЕсли;
		
		Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка Или (ТипЗнч(СтрокаОснование.ДокументОснование)
			= Тип("ДокументСсылка.КорректировкаРеализации") И ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс) Тогда
			Продолжить;
		КонецЕсли;

		ДокументОснование = СтрокаОснование.ДокументОснование;
		Если ЗначениеЗаполнено(ДокументОснование) И Не ТипЗнч(ДокументОснование) = Тип(
			"ДокументСсылка.ОтчетКомиссионера") И Не ТипЗнч(ДокументОснование) = Тип(
			"ДокументСсылка.ПодтверждениеНулевойСтавкиНДС") Тогда

			НайденныйСчетФактура = СчетаФактурыУНФ.ПолучитьПодчиненныйСчетФактуру(ДокументОснование);
			Если ЗначениеЗаполнено(НайденныйСчетФактура) И НайденныйСчетФактура.Ссылка <> Ссылка Тогда
				ТекстСообщения = СтрШаблон(НСтр("ru = 'Для документа ""%1"" 
												|уже введен счет-фактура ""%2"". 
												|Запись еще одного документа ""счет-фактура"" не допускается.'"),
					ДокументОснование, НайденныйСчетФактура.Ссылка);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "ДокументОснование", , Отказ);
			КонецЕсли;

		КонецЕсли;

		Если ЗначениеЗаполнено(ДокументОснование) И ТипЗнч(ДокументОснование) = Тип(
			"ДокументСсылка.ПередачаТоваровМеждуОрганизациями") Тогда

			Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
				НовыйСтатус = Перечисления.СтатусыСчетаФактуры.Проведен;
			Иначе
				НовыйСтатус = Перечисления.СтатусыСчетаФактуры.НеПроведен;
			КонецЕсли;

			Если ЗначениеЗаполнено(НомерНаПечать) Тогда
				НомерДляРегистра = НомерНаПечать;
			Иначе
				Если ЭтоНовый() И Не ЗначениеЗаполнено(Номер) Тогда
					УстановитьНовыйНомер();
				КонецЕсли;
				НомерДляРегистра = РаботаСФормойДокументаКлиентСервер.ПолучитьКороткийНомерДокумента(Номер);
			КонецЕсли;

			РегистрыСведений.СтатусыДокументов.УстановитьСтатусСчетаФактурыДокумента(ДокументОснование,
				НомерДляРегистра, НовыйСтатус);

		КонецЕсли;

	КонецЦикла;
	
    //НДС
	Если ДокументыОснования.Количество() > 0 Тогда
		ДокументОснование = ДокументыОснования[0].ДокументОснование;
	Иначе
		ДокументОснование = Неопределено;
	КонецЕсли;

	Если ДополнительныеСвойства.Свойство("ГрупповоеПерепроведение") И ДополнительныеСвойства.ГрупповоеПерепроведение Тогда

		Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс И УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(Организация, Дата)
			И (Авансы.Количество() = 1 Или Авансы.Количество() = 0) Тогда
			СуммыДокументовОснований = Новый Структура;

			СуммыДокументовОснований.Вставить("СуммаДокумента", 0);
			СуммыДокументовОснований.Вставить("СуммаНДСДокумента", 0);
			Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда

            Авансы.Очистить();
				ЗаполнитьСуммуДокументаАвансПоКорректировке(ДокументОснование, СуммыДокументовОснований);

			ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ПоступлениеВКассу") Или ТипЗнч(ДокументОснование)
				= Тип("ДокументСсылка.ПоступлениеНаСчет") Или ТипЗнч(ДокументОснование) = Тип(
				"ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда
				Авансы.Очистить();
				ЗаполнитьСуммуДокументаПоАвансу(ДокументОснование, СуммыДокументовОснований);
				ЗаполнитьРасшифровкуАванса(ДокументОснование, СуммыДокументовОснований);
			КонецЕсли;
			
			Если СуммаНДСДокумента <> СуммыДокументовОснований.СуммаНДСДокумента
			ИЛИ СуммаДокумента <> СуммыДокументовОснований.СуммаДокумента Тогда
	
			    ЗаполнитьЗначенияСвойств(ЭтотОбъект, СуммыДокументовОснований);
			КонецЕсли;
			
		КонецЕсли;
		
		КодВидаОперацииОснованияУменьшение = "";
		Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.Корректировка Тогда
			ВерсияКодовВидовОпераций = УчетНДСКлиентСервер.ВерсияКодовВидовОпераций(Дата);
			Если ВерсияКодовВидовОпераций > 1 Тогда
				Если КодВидаОперацииОснованияУменьшение <> "" Тогда
					КодВидаОперацииНаУменьшение = КодВидаОперацииОснованияУменьшение;
				Иначе
					Если ЗначениеЗаполнено(Договор) И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор,
						"УчетАгентскогоНДСПокупателем") Тогда
						КодВидаОперацииНаУменьшение = "34";
					Иначе
						КодВидаОперацииНаУменьшение = "18";
					КонецЕсли;
				КонецЕсли;
			Иначе
				КодВидаОперацииНаУменьшение = "";
			КонецЕсли;
		КонецЕсли;

	КонецЕсли;
	//НДС

	ЗаполнениеОбъектовУНФ.ЗаполнитьДоговорПоУмолчанию(ЭтотОбъект);
	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.Продажа
		ИЛИ ВидОперации = Перечисления.ВидыОперацийСчетФактура.Корректировка Тогда
		ОбновитьСуммыДокумента(МассивОснованийРеализации);
	
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка Тогда
		
		Если СуммаДокумента <> 0 И СуммаУменьшение = 0 Тогда
			СуммаУменьшение = СуммаДокумента;
			СуммаНДСУменьшение = СуммаНДСДокумента;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ИсправляемыйСчетФактура) Тогда
			РеквизитыИсправляемого = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ИсправляемыйСчетФактура, "Номер, Дата");
			Если РеквизитыИсправляемого.Номер = НомерИсходногоДокумента Тогда
				ДозаполнитьРеквизитыСводныхСправок();
			КонецЕсли;
		КонецЕсли;		
	КонецЕсли;

КонецПроцедуры // ПередЗаписью()

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    	
	// Инициализация дополнительных свойств для проведения документа.
	ПроведениеДокументовУНФ.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
	ДополнительныеСвойства.Вставить("НеобходимоОтразитьСчетФактуройЗапасыВРазрезеГТД",
		ТребуетсяОтразитьСчетФактуройЗапасыВРазрезеГТД());
	ДополнительныеСвойства.Вставить("ТребуетсяОтразитьСуммыДокументаВНациональнойВалюте",
		ТребуетсяОтразитьСуммыДокументаВНациональнойВалюте());
	
	// Взаиморасчеты
	РасчетыПроведениеДокументов.ИнициализироватьДополнительныеСвойстваДляПроведения(ЭтотОбъект, ДополнительныеСвойства,
		Отказ, Ложь);
	
	// Инициализация данных документа.
	Документы.СчетФактура.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства);
	
	// Подготовка наборов записей.
	ПроведениеДокументовУНФ.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
	
	// Отражение в разделах учета.
	ТаблицыДляДвижений = ДополнительныеСвойства.ТаблицыДляДвижений;
	ПроведениеДокументовУНФ.ОтразитьДвижения("ЗапасыВРазрезеГТД", ТаблицыДляДвижений, Движения, Отказ);
	
	// Суммы документов регламентированный учет
	ПроведениеДокументовУНФ.ОтразитьДвижения("СуммыДокументовРегламентированныйУчет", ТаблицыДляДвижений, Движения,
		Отказ);
    
    // НДС
	ПроведениеДокументовУНФ.ОтразитьДвижения("НДСЗаписиКнигиПродаж", ТаблицыДляДвижений, Движения, Отказ);
	ПроведениеДокументовУНФ.ОтразитьДвижения("НДСАвансыПолученные", ТаблицыДляДвижений, Движения, Отказ);
	ПроведениеДокументовУНФ.ОтразитьДвижения("ЖурналУчетаСчетовФактур", ТаблицыДляДвижений, Движения, Отказ); 
    // НДС
	
	// Запись наборов записей.
	ПроведениеДокументовУНФ.ЗаписатьНаборыЗаписей(ЭтотОбъект);
	
	// Контроль
	Документы.СчетФактура.ВыполнитьКонтроль(Ссылка, ДополнительныеСвойства, Отказ);

	ПроведениеДокументовУНФ.ЗакрытьМенеджерВременныхТаблиц(ЭтотОбъект);

КонецПроцедуры

// Процедура - обработчик события ОбработкаУдаленияПроведения объекта.
//
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	// Инициализация дополнительных свойств для удаления проведения документа
	ПроведениеДокументовУНФ.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
	
	// Подготовка наборов записей.
	ПроведениеДокументовУНФ.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
	
	// Запись наборов записей.
	ПроведениеДокументовУНФ.ЗаписатьНаборыЗаписей(ЭтотОбъект);
	
	// Контроль
	Документы.СчетФактура.ВыполнитьКонтроль(Ссылка, ДополнительныеСвойства, Отказ, Истина);

КонецПроцедуры // ОбработкаУдаленияПроведения()

Процедура ПриЗаписи(Отказ)

	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если Не (ПолучитьФункциональнуюОпцию("ПередачаТоваровНаКомиссию") Или ПолучитьФункциональнуюОпцию(
		"ПриемТоваровНаКомиссию") Или ПолучитьФункциональнуюОпцию("ИспользуетсяОСНО")) Тогда

		УстановитьПривилегированныйРежим(Истина);
		Константы.ФункциональнаяОпцияИспользоватьСчетаФактурыИсходящие.Установить(Истина);
		УстановитьПривилегированныйРежим(Ложь);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТребуетсяОтразитьСчетФактуройЗапасыВРазрезеГТД()

	Возврат ГрузовыеТаможенныеДекларацииСервер.НеобходимоОтразитьСчетФактуройЗапасыВРазрезеГТД(Ссылка);

КонецФункции

Функция ТребуетсяОтразитьСуммыДокументаВНациональнойВалюте()

	Если УдалитьЗапасы.Количество() < 1 Тогда

		Возврат Ложь;

	КонецЕсли;

	Возврат (ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийСчетФактура.Продажа") Или ВидОперации
		= ПредопределенноеЗначение("Перечисление.ВидыОперацийСчетФактура.Корректировка"))
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "РасчетыВУсловныхЕдиницах") И ВалютаДокумента
		<> Константы.НациональнаяВалюта.Получить() И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВалютаРасчетов")
		<> Константы.НациональнаяВалюта.Получить();

КонецФункции

Процедура ОбновитьСуммыДокумента(ДокументыОснования)

	// Реквизиты СуммаДокумента и СуммаНДСДокумента не заполняем: нужно обновить новые реквизиты сумм,
	// которые могут быть незаполнены
	СуммыДокументов = СуммыДокументовОснований();
	СуммыДокументов.Удалить("СуммаДокумента");
	СуммыДокументов.Удалить("СуммаНДСДокумента");
	
	Для Каждого Элемент Из СуммыДокументов Цикл
		Если ЭтотОбъект[Элемент.Ключ] <> 0 Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;

	// 	Обрабатываем только корректировочные документы и документы, содержащие товары на комиссии
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументыОснования", ДокументыОснования);
	Запрос.Текст = "ВЫБРАТЬ
	|	Запасы.Регистратор КАК Ссылка
	|ПОМЕСТИТЬ ВТРегистраторы
	|ИЗ
	|	РегистрНакопления.Запасы КАК Запасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПартииНоменклатуры КАК ПартииНоменклатуры
	|		ПО Запасы.Партия = ПартииНоменклатуры.Ссылка
	|		И ПартииНоменклатуры.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.ТоварыНаКомиссии)
	|		И Запасы.Регистратор В (&ДокументыОснования)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КорректировкаРеализации.Ссылка
	|ИЗ
	|	Документ.КорректировкаРеализации КАК КорректировкаРеализации
	|ГДЕ
	|	КорректировкаРеализации.Ссылка В (&ДокументыОснования)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриходнаяНакладная.Ссылка
	|ИЗ
	|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
	|ГДЕ
	|	ПриходнаяНакладная.Ссылка В (&ДокументыОснования)
	|	И ПриходнаяНакладная.ПокупателюВыставляетсяКорректировочныйСчетФактура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОтчетКомиссионера.Ссылка
	|ИЗ
	|	Документ.ОтчетКомиссионера КАК ОтчетКомиссионера
	|ГДЕ
	|	ОтчетКомиссионера.Ссылка В (&ДокументыОснования)
	|	И ОтчетКомиссионера.НаВозвратыВыставляетсяКорректировочныйСчетФактура
	|	И ОтчетКомиссионера.СуммаДокументаВозврат > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТРегистраторы.Ссылка,
	|	ТИПЗНАЧЕНИЯ(ВТРегистраторы.Ссылка) КАК ТипСсылки
	|ИЗ
	|	ВТРегистраторы КАК ВТРегистраторы";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ДокументыПоТипам = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		СписокДокументов = ДокументыПоТипам.Получить(Выборка.ТипСсылки);
		Если СписокДокументов = Неопределено Тогда
			СписокДокументов = Новый Массив;
			ДокументыПоТипам.Вставить(Выборка.ТипСсылки, СписокДокументов);
		КонецЕсли; 
		СписокДокументов.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Заказы = ДокументыПоТипам.Получить(Тип("ДокументСсылка.ЗаказПокупателя"));
	Если Заказы <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапросаСуммыЗаказПокупателя();
		ЗаполнитьСуммыДокументов(ТекстЗапроса, Заказы, СуммыДокументов);
	КонецЕсли;

	Корректировки = ДокументыПоТипам.Получить(Тип("ДокументСсылка.КорректировкаРеализации"));
	Если Корректировки <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапросаСуммыКорректировкаРеализации();
		ЗаполнитьСуммыДокументов(ТекстЗапроса, Корректировки, СуммыДокументов);
	КонецЕсли;

	ВозвратыПокупателя = ДокументыПоТипам.Получить(Тип("ДокументСсылка.ПриходнаяНакладная"));
	Если ВозвратыПокупателя <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапросаСуммыПриходнаяНакладная();
		ЗаполнитьСуммыДокументов(ТекстЗапроса, ВозвратыПокупателя, СуммыДокументов);
	КонецЕсли;

	Передачи = ДокументыПоТипам.Получить(Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями"));
	Если Передачи <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапросаСуммДокумента(ТипЗнч(ДокументыОснования), "Запасы", Истина);
		ЗаполнитьСуммыДокументов(ТекстЗапроса, Передачи, СуммыДокументов);
	КонецЕсли;

	РасходныеНакладные = ДокументыПоТипам.Получить(Тип("ДокументСсылка.РасходнаяНакладная"));
	Если РасходныеНакладные <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапросаСуммыРасходнаяНакладная();
		ЗаполнитьСуммыДокументов(ТекстЗапроса, РасходныеНакладные, СуммыДокументов);
	КонецЕсли;
	
	ОтчетыКомиссионеров = ДокументыПоТипам.Получить(Тип("ДокументСсылка.ОтчетКомиссионера"));
	Если ОтчетыКомиссионеров <> Неопределено Тогда
		ТекстЗапроса = ТекстЗапросаСуммыОтчетКомиссионераКорректировка();
		ЗаполнитьСуммыДокументов(ТекстЗапроса, ОтчетыКомиссионеров, СуммыДокументов);
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СуммыДокументов);
	
КонецПроцедуры

Функция СовместнаяРеализацияСобственныхИКомиссионныхТоваров(СсылкаНаДокумент)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", СсылкаНаДокумент);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РасходнаяНакладнаяЗапасы.Ссылка КАК Ссылка,
	|	1 КАК ИндексЗапасов
	|ПОМЕСТИТЬ Итог
	|ИЗ
	|	Документ.РасходнаяНакладная.Запасы КАК РасходнаяНакладнаяЗапасы
	|ГДЕ
	|	РасходнаяНакладнаяЗапасы.Ссылка = &Ссылка
	|	И (РасходнаяНакладнаяЗапасы.Партия = ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
	|			ИЛИ РасходнаяНакладнаяЗапасы.Партия.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы))
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	РасходнаяНакладнаяЗапасы.Ссылка,
	|	1
	|ИЗ
	|	Документ.РасходнаяНакладная.Запасы КАК РасходнаяНакладнаяЗапасы
	|ГДЕ
	|	РасходнаяНакладнаяЗапасы.Ссылка = &Ссылка
	|	И РасходнаяНакладнаяЗапасы.Партия.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.ТоварыНаКомиссии)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итог.Ссылка КАК Ссылка,
	|	Итог.ИндексЗапасов КАК ИндексЗапасов
	|ИЗ
	|	Итог КАК Итог
	|
	|СГРУППИРОВАТЬ ПО
	|	Итог.Ссылка,
	|	Итог.ИндексЗапасов
	|
	|ИМЕЮЩИЕ
	|	СУММА(Итог.ИндексЗапасов) = 2";
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

#Область ПроцедурыЗаполненияДокумента

Процедура ПроверитьДокументыОснованияСчетФактуры()
	
	Для Каждого ТекСтрока из ДокументыОснования Цикл

		Если ТипЗнч(ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.КорректировкаРеализации")
		И НЕ ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда

			РеквизитыОснования = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТекСтрока.ДокументОснование,
				"ДокументОснование, ВидОперации");

			Если ТипЗнч(РеквизитыОснования.ДокументОснование) = Тип("ДокументСсылка.АктОРасхожденияхПолученный") Тогда
				РеквизитыАктаОРасхождениях = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
					РеквизитыОснования.ДокументОснование, "ДокументОснование");
				РеквизитыОснования.ДокументОснование = РеквизитыАктаОРасхождениях.ДокументОснование;
			КонецЕсли;

			Если СчетаФактурыУНФ.ПолучитьПодчиненныйСчетФактуру(РеквизитыОснования.ДокументОснование) = Неопределено Тогда

				ШаблонТекст = НСтр(
					"ru = 'Перед добавлением %1 счета-фактуры создайте счет-фактуру у исправляемого документа'");

				ЭтоИсправление = (РеквизитыОснования.ВидОперации
					= Перечисления.ВидыОперацийИсправленияПоступленияРеализации.ИсправлениеОшибки);
				ОписаниеВидаОперации = ?(ЭтоИсправление, НСтр("ru = 'исправления'"), НСтр("ru = 'корректировочного'"));

				ВызватьИсключение СтрШаблон(ШаблонТекст, ОписаниеВидаОперации);

			КонецЕсли;

		КонецЕсли;

		Если ТипЗнч(ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ПоступлениеВКассу") Или ТипЗнч(
			ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ПоступлениеНаСчет") Или ТипЗнч(
			ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда

			Если Не Документы.СчетФактура.ТребуетсяВводитьСчетФактуруНаАванс(ТекСтрока.ДокументОснование) Тогда
				ТекстИсключения = НСтр("ru = 'Для операции, которая выбрана в документе %1,
									   |создание счета-фактуры не требуется.'");

				ВызватьИсключение СтрШаблон(ТекстИсключения, СокрЛП(ТекСтрока.ДокументОснование));
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("СсылкаНаДокумент", ТекСтрока.ДокументОснование);
			Запрос.Текст =
			"ВЫБРАТЬ
			|	ПлатежныйДокументРасшифровкаПлатежа.Договор КАК Договор,
			|  ПризнакАванса КАК ПризнакАванса
			|ИЗ
			|	Документ.%ТипДокумента%.РасшифровкаПлатежа КАК ПлатежныйДокументРасшифровкаПлатежа
			|ГДЕ
			|	ПлатежныйДокументРасшифровкаПлатежа.Ссылка = &СсылкаНаДокумент";

			Если ТипЗнч(ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ПоступлениеВКассу") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ПоступлениеВКассу");
			ИначеЕсли ТипЗнч(ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ПоступлениеНаСчет");
			ИначеЕсли ТипЗнч(ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента%", "ОперацияПоПлатежнымКартам");
			КонецЕсли;
			ТаблицаРасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
	
			ПараметрыОтбора = Новый Структура("ПризнакАванса", Истина);
			
			НайденныеСтроки = ТаблицаРасшифровкаПлатежа.НайтиСтроки(ПараметрыОтбора);
			Если НайденныеСтроки.Количество() < 1 Тогда

				ТекстИсключения = НСтр("ru = 'В документе %1 нет авансовых данных.
									   |Создание счета-фактуры не требуется.'");

				ВызватьИсключение СтрШаблон(ТекстИсключения, СокрЛП(ТекСтрока.ДокументОснование));

			КонецЕсли;

			Если ДополнительныеСвойства.Свойство("ЭтоСуммоваяРазница") Тогда

				ОтсутствуетДоговорУЕ = Истина;
				Для Каждого СтрокаРасшифровки Из ТаблицаРасшифровкаПлатежа Цикл

					ДоговорКонтрагента = СтрокаРасшифровки.Договор; //СправочникСсылка.ДоговорыКонтрагентов
					Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДоговорКонтрагента,
						"РасчетыВУсловныхЕдиницах") Тогда

						ОтсутствуетДоговорУЕ = Ложь;
						Прервать;

					КонецЕсли;

				КонецЦикла;

				Если ОтсутствуетДоговорУЕ Тогда

					ТекстИсключения = НСтр("ru = 'Счет-фактура с видом операции Суммовые разницы формируется по договорам в У.Е.
										   |В документе %1 отсутствуют договоры в условных единицах.'");

					ВызватьИсключение СтрШаблон(ТекстИсключения, СокрЛП(ТекСтрока.ДокументОснование));

				КонецЕсли;

			КонецЕсли;

		КонецЕсли;

		НеСправка = Не ВидОперации = Перечисления.ВидыОперацийСчетФактура.КорректировочнаяСправка И Не ВидОперации
			= Перечисления.ВидыОперацийСчетФактура.СводнаяСправка;
			
		НеКорректировкаНаАванс = Не (ТипЗнч(ТекСтрока.ДокументОснование) = Тип(
			"ДокументСсылка.КорректировкаРеализации") И ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс);
		
		НеОтчетКомиссионераНаАванс = Не (ТипЗнч(ТекСтрока.ДокументОснование) = Тип(
			"ДокументСсылка.ОтчетКомиссионера") И ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс);
		
		Если НеСправка И НеКорректировкаНаАванс И НеОтчетКомиссионераНаАванс Тогда

			НайденныйСчетФактура = СчетаФактурыУНФ.ПолучитьПодчиненныйСчетФактуру(ТекСтрока.ДокументОснование);
			Если ЗначениеЗаполнено(НайденныйСчетФактура) И НайденныйСчетФактура.Ссылка <> Ссылка Тогда

				ШаблонТекст = НСтр("ru = 'Для документа ""%1"" 
								   |уже введен счет-фактура ""%2"".
								   |Запись еще одного документа ""Счет-фактура"" не допускается!'");

				ВызватьИсключение СтрШаблон(ШаблонТекст, ТекСтрока.ДокументОснование, НайденныйСчетФактура.Ссылка);

			КонецЕсли;

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Добавить строку документа основания.
// 
// Параметры:
//  СсылкаНаДокументОснование - ДокументСсылка
//  НаименованиеДокументаОтгрузки - Строка
Процедура ДобавитьСтрокуДокументаОснования(СсылкаНаДокументОснование, НаименованиеДокументаОтгрузки = "")

	Если Не ОбщегоНазначения.ЗначениеСсылочногоТипа(СсылкаНаДокументОснование) Тогда

		ВызватьИсключение СтрШаблон(НСтр("ru ='Документ-основание должен быть ссылочного типа'"),
			СсылкаНаДокументОснование);

	КонецЕсли;
	
	КонтролироватьУникальностьСчетФактуры = Не (ТипЗнч(СсылкаНаДокументОснование) = Тип(
		"ДокументСсылка.ДокументРасчетовСКонтрагентом") Или (ТипЗнч(СсылкаНаДокументОснование) = Тип(
		"ДокументСсылка.КорректировкаРеализации") И ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс));

	ЭтоСинхронизация = ДополнительныеСвойства.Свойство("ЭтоСинхронизация");
	Если Не ЭтоСинхронизация И КонтролироватьУникальностьСчетФактуры
		И СсылкаНаДокументОснование.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда

		ВызватьИсключение СтрШаблон(НСтр("ru ='Для документа %1 ввод счета-фактуры не требуется'"),
			СсылкаНаДокументОснование);

	КонецЕсли;

	Если ДокументыОснования.Найти(СсылкаНаДокументОснование, "ДокументОснование") = Неопределено Тогда

		НоваяСтрока 							  = ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование			  = СсылкаНаДокументОснование;
		НоваяСтрока.НаименованиеДокументаОтгрузки = НаименованиеДокументаОтгрузки;

	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьДокументыОснования(ДанныеЗаполнения)

	ДокументыОснования.Очистить();
	Если ОбщегоНазначения.ЗначениеСсылочногоТипа(ДанныеЗаполнения) Тогда

		ДобавитьСтрокуДокументаОснования(ДанныеЗаполнения);

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ТаблицаЗначений") Тогда

		ЕстьНаименованиеДокумента = (ДанныеЗаполнения.Колонки.Найти("НаименованиеДокументаОтгрузки") <> Неопределено);
		Для Каждого СтрокаТаблицы Из ДанныеЗаполнения Цикл

			ДобавитьСтрокуДокументаОснования(СтрокаТаблицы.ДокументОснование, ?(ЕстьНаименованиеДокумента,
				СтрокаТаблицы.НаименованиеДокументаОтгрузки, ""));

		КонецЦикла;

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда

		Если ДанныеЗаполнения.Свойство("Ссылка") Тогда

			ДобавитьСтрокуДокументаОснования(ДанныеЗаполнения.Ссылка);

		КонецЕсли;

		Если ДанныеЗаполнения.Свойство("ЭтоСуммоваяРазница") Тогда

			ДополнительныеСвойства.Вставить("ЭтоСуммоваяРазница", ДанныеЗаполнения.ЭтоСуммоваяРазница);

		КонецЕсли;

	КонецЕсли;

	ПроверитьДокументыОснованияСчетФактуры();

КонецПроцедуры

Процедура ЗаполнитьЗначениеСПроверкой(Приемник, Источник, ИмяРеквизита, ЗапретитьРазличия = Ложь)

	Если ТипЗнч(Источник) = Тип("ДокументСсылка.АктВыполненныхРабот") И ИмяРеквизита = "ПодписьКладовщика" Тогда

		Возврат;

	КонецЕсли;

	Если ЗапретитьРазличия И ЗначениеЗаполнено(Приемник[ИмяРеквизита]) Тогда

		Если Приемник[ИмяРеквизита] <> Источник[ИмяРеквизита] Тогда

			ВызватьИсключение СтрШаблон(НСтр("ru ='Ввод счета-фактуры по различающимся значениям запрещен (%1).'"),
				ИмяРеквизита);

		КонецЕсли;

		Приемник[ИмяРеквизита] = Источник[ИмяРеквизита];

	Иначе

		Приемник[ИмяРеквизита] = Источник[ИмяРеквизита];

	КонецЕсли;

КонецПроцедуры

Процедура ДобавитьЗначенияДокументаВИтоговыеСуммы(ДанныеЗаполнения, СуммыДокументовОснований, СуммаДокументаОснования,
	СуммаНДСДокументаОснования)

	СуммыДокументовОснований.СуммаДокумента = СуммыДокументовОснований.СуммаДокумента + СуммаДокументаОснования;
	СуммыДокументовОснований.СуммаНДСДокумента = СуммыДокументовОснований.СуммаНДСДокумента + СуммаНДСДокументаОснования;

	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "СуммаВключаетНДС") Тогда

		СуммыДокументовОснований.СуммаДокумента = СуммыДокументовОснований.СуммаДокумента - СуммаНДСДокументаОснования;

	КонецЕсли;

КонецПроцедуры

Процедура ДобавитьСуммыДокументаВИтоговыеСуммы(ИтоговыеСуммы, СуммыДокумента)

	Для Каждого Элемент Из СуммыДокумента Цикл
		Если ЗначениеЗаполнено(Элемент.Значение) Тогда
			ИтоговыеСуммы[Элемент.Ключ] = ИтоговыеСуммы[Элемент.Ключ] + Элемент.Значение;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#Область Реализация

Процедура ЗаполнитьСведенияШапкиПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований)

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Контрагент", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Договор", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ВалютаДокумента", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Кратность");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Курс");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ХозяйственнаяОперация");
	
	Если НЕ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетКомиссионера") Тогда
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьРуководителя");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьГлавногоБухгалтера");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьКладовщика");
	КонецЕсли;

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ОснованиеПечати");

		ВидОперацийВозвратов = Новый Массив;
		ВидОперацийВозвратов.Добавить(Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратПоставщику);
		ВидОперацийВозвратов.Добавить(Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратКомитенту);
		ВидОперацийВозвратов.Добавить(Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратИзПереработки);
		ВидОперацийВозвратов.Добавить(Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратСОтветХранения);

		Если СведенияДокументовОснований.ЭтоВозврат <> Перечисления.ДаНет.Да Тогда

			СведенияДокументовОснований.ЭтоВозврат = ?(ВидОперацийВозвратов.Найти(
				ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "ВидОперации"))
				= Неопределено, Перечисления.ДаНет.Нет, Перечисления.ДаНет.Да);

		КонецЕсли;
		
		// Прослеживаемость
		//@skip-check reading-attribute-from-database
		ЕстьПрослеживаемыеТовары = ДанныеЗаполнения.Запасы.Итог("ПрослеживаемыйТовар") > 0;
		СведенияДокументовОснований.ЕстьПрослеживаемыеТовары = Макс(
			СведенияДокументовОснований.ЕстьПрослеживаемыеТовары, ЕстьПрослеживаемыеТовары);
		// Конец Прослеживаемость
		
		Если СовместнаяРеализацияСобственныхИКомиссионныхТоваров(ДанныеЗаполнения) Тогда
			КодВидаОперации = "15";
		Иначе
			КодВидаОперации = "";
		КонецЕсли;

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда

		ДокументРеализацииСсылка = Документы.КорректировкаРеализации.ПолучитьИсправляемыйДокументРеализации(
			ДанныеЗаполнения, Истина);
		Если Не ПустаяСтрока(ДокументРеализацииСсылка.ОснованиеПечати) Тогда

			СведенияДокументовОснований.ОснованиеПечати = ДокументРеализацииСсылка.ОснованиеПечати;

		КонецЕсли;

		СведенияДокументовОснований.Вставить("ИсправляемыйСчетФактура", Неопределено);
		СведенияДокументовОснований.Вставить("ВидОперации", Неопределено);
		СведенияДокументовОснований.Вставить("НомерИсходногоДокумента", Неопределено);
		СведенияДокументовОснований.Вставить("ДатаИсходногоДокумента", Неопределено);
		СведенияДокументовОснований.Вставить("НомерИсправляемогоКорректировочногоДокумента", Неопределено);
		СведенияДокументовОснований.Вставить("ДатаИсправляемогоКорректировочногоДокумента", Неопределено);
		СведенияДокументовОснований.Вставить("НомерИсправления", Неопределено);
		СведенияДокументовОснований.Вставить("Исправление", Неопределено);
		СведенияДокументовОснований.Вставить("УчитыватьИсправлениеИсходногоДокумента", Неопределено);
		СведенияДокументовОснований.Вставить("НомерИсправленияИсходногоДокумента", Неопределено);
		СведенияДокументовОснований.Вставить("ДатаИсправленияИсходногоДокумента", Неопределено);

		Если Не ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс Тогда
			
			РеквизитыКорректировки = Документы.СчетФактура.ПолучитьПараметрыЗаполненияКорректировочногоСчетаФактуры(
			ДанныеЗаполнения);
			
			Для Каждого ЭлементСтруктуры Из РеквизитыКорректировки Цикл
				
				Если СведенияДокументовОснований.Свойство(ЭлементСтруктуры.Ключ) Тогда
					
					СведенияДокументовОснований[ЭлементСтруктуры.Ключ] = ЭлементСтруктуры.Значение;
					
				КонецЕсли;
				
			КонецЦикла;
		Иначе
			СведенияДокументовОснований.ВидОперации = Перечисления.ВидыОперацийСчетФактура.Аванс;
		КонецЕсли;
		
	ИначеЕсли НЕ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетКомиссионера") Тогда

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ОснованиеПечати");

	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьДатаНомерДокументовОплатыПоРеализации(ДанныеЗаполнения, СведенияДокументовОснований)

	ВерсияПостановленияНДС1137 = УчетНДСПереопределяемый.ВерсияПостановленияНДС1137(Дата);

	Если ВерсияПостановленияНДС1137 >= 8 Тогда
		ТекДатаНомерДокументовОплаты = Документы.СчетФактура.ПолучитьДатаНомерДокументовОплаты(ДанныеЗаполнения);
	Иначе
		ТекДатаНомерДокументовОплаты = Документы.СчетФактура.АрхивныеАлгоритмыПолучитьДатаНомерДокументовОплаты(
			ДанныеЗаполнения);
	КонецЕсли;

	Если ТекДатаНомерДокументовОплаты <> Неопределено Тогда
		ДатаНомерДокументовОплаты.Загрузить(ТекДатаНомерДокументовОплаты);
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьСуммыДокументов(ТекстЗапроса, СписокДокументов, СуммыДокументовОснований)
	
	Если НЕ ЗначениеЗаполнено(ТекстЗапроса) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СписокДокументов)
		ИЛИ ТипЗнч(СписокДокументов) = Тип("Массив") И СписокДокументов.Количество() = 0 Тогда
			Возврат;
	КонецЕсли;
	
	СуммыДокументаПустые = СуммыДокументовОснований();
	СуммыДокумента = Новый Структура;
	Для Каждого Элемент Из СуммыДокументовОснований Цикл
		СуммыДокумента.Вставить(Элемент.Ключ);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", СписокДокументов);
	Запрос.Текст = ТекстЗапроса;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СуммыДокумента, СуммыДокументаПустые);
		ЗаполнитьЗначенияСвойств(СуммыДокумента, Выборка);
		ДобавитьСуммыДокументаВИтоговыеСуммы(СуммыДокументовОснований, СуммыДокумента);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСуммуДокументаПоРеализации(ДанныеЗаполнения, СуммыДокументовОснований)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда

		ТекстЗапроса = ТекстЗапросаСуммыРасходнаяНакладная();

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
		
		ТекстЗапроса = ТекстЗапросаСуммыКорректировкаРеализации();
		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда

		ТекстЗапроса = ТекстЗапросаСуммДокумента(ТипЗнч(ДанныеЗаполнения), "РаботыИУслуги", Ложь);
		
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями") Тогда

		ТекстЗапроса = ТекстЗапросаСуммДокумента(ТипЗнч(ДанныеЗаполнения), "Запасы", Истина);

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда

		ТекстЗапроса = ТекстЗапросаСуммыЗаказПокупателя();
		// Суммы доставки - доставка в ЗН не автоматизирована.

	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда

		ТекстЗапроса = ТекстЗапросаСуммыПриходнаяНакладная();
	
	Иначе
		
		ТекстЗапроса = "";
	КонецЕсли;

	ЗаполнитьСуммыДокументов(ТекстЗапроса, ДанныеЗаполнения, СуммыДокументовОснований);

КонецПроцедуры

Функция ТекстЗапросаСуммДокумента(ТипДокумента, ИмяТаблицы, ЕстьПартии)
	
	ТекстЗапроса = "ВЫБРАТЬ
	|	Реквизиты.Ссылка КАК Ссылка,
	|	ТаблицаДокумента.Сумма КАК Сумма,
	|	ТаблицаДокумента.СуммаНДС КАК СуммаНДС,
	|	ЛОЖЬ КАК ЭтоКомиссия
	|ПОМЕСТИТЬ ВТСуммыДокумента
	|ИЗ
	|	ТабличнаяЧасть КАК ТаблицаДокумента
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ КАК Реквизиты
	|		ПО ТаблицаДокумента.Ссылка = Реквизиты.Ссылка
	|		И Реквизиты.Ссылка В (&Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСуммыДокумента.Ссылка КАК ДокументСсылка,
	|	СУММА(ВТСуммыДокумента.Сумма) КАК СуммаДокумента,
	|	СУММА(ВТСуммыДокумента.СуммаНДС) КАК СуммаНДСДокумента,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.Сумма
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаДокументаКомиссия,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.СуммаНДС
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаНДСДокументаКомиссия
	|ИЗ
	|	ВТСуммыДокумента КАК ВТСуммыДокумента
	|СГРУППИРОВАТЬ ПО
	|	ВТСуммыДокумента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыДокумента";
	
	СхемаЗапроса = Новый СхемаЗапроса();
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	Документ = Метаданные.НайтиПоТипу(ТипДокумента);
	
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0];
	Выбор = ЗапросВыбора.Операторы[0];

	ИндексТаблицы = -1;
	ПсевдонимТаблица = "ТаблицаДокумента";
	ПсевдонимРеквизиты = "Реквизиты";
	Для Индекс = 0 По Выбор.Источники.Количество() - 1 Цикл
		
		Псевдоним = Выбор.Источники[Индекс].Источник.Псевдоним;
		Если Псевдоним = ПсевдонимТаблица Тогда
			ИмяТаблицыЗапроса = СтрШаблон("%1.%2", Документ.ПолноеИмя(), ИмяТаблицы);
			ИндексТаблицы = Индекс;
		ИначеЕсли Псевдоним = ПсевдонимРеквизиты Тогда
			ИмяТаблицыЗапроса = Документ.ПолноеИмя();
		Иначе
			Продолжить;
		КонецЕсли;
		
		Таблица = ЗапросВыбора.ДоступныеТаблицы.Найти(ИмяТаблицыЗапроса);
		Выбор.Источники.Заменить(Индекс, Таблица);
		Выбор.Источники[Индекс].Источник.Псевдоним = Псевдоним;
		
	КонецЦикла;
		
	Если Документ.Реквизиты.Найти("СуммаВключаетНДС") <> Неопределено Тогда
		Выбор.ВыбираемыеПоля[1] =  Новый ВыражениеСхемыЗапроса(
			"ВЫБОР
			|	КОГДА Реквизиты.СуммаВключаетНДС ТОГДА
			|		ТаблицаДокумента.Сумма - ТаблицаДокумента.СуммаНДС
			|	ИНАЧЕ ТаблицаДокумента.Сумма
			|КОНЕЦ");
	КонецЕсли;

	Если ЕстьПартии Тогда
		ИсточникПартии = Выбор.Источники.Добавить("Справочник.ПартииНоменклатуры", "ПартииНоменклатуры");
		Выбор.Источники[ИндексТаблицы].Соединения.Добавить(ИсточникПартии,
			"ТаблицаДокумента.Партия = ПартииНоменклатуры.Ссылка
			|И ПартииНоменклатуры.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.ТоварыНаКомиссии)");
		Выбор.ВыбираемыеПоля[3] = Новый ВыражениеСхемыЗапроса("НЕ ПартииНоменклатуры.Статус ЕСТЬ NULL");
	КонецЕсли;
	
	Возврат СхемаЗапроса.ПолучитьТекстЗапроса();
	
КонецФункции

Функция ТекстЗапросаСуммыРасходнаяНакладная()
	
	Текст = "ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА РасходнаяНакладная.СуммаВключаетНДС
	|			ТОГДА РасходнаяНакладнаяЗапасы.Сумма - РасходнаяНакладнаяЗапасы.СуммаНДС
	|		ИНАЧЕ РасходнаяНакладнаяЗапасы.Сумма
	|	КОНЕЦ КАК Сумма,
	|	РасходнаяНакладнаяЗапасы.СуммаНДС КАК СуммаНДС,
	|	НЕ ПартииНоменклатуры.Статус ЕСТЬ NULL КАК ЭтоКомиссия
	|ПОМЕСТИТЬ ВТСуммыДокумента
	|ИЗ
	|	Документ.РасходнаяНакладная.Запасы КАК РасходнаяНакладнаяЗапасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО РасходнаяНакладнаяЗапасы.Ссылка = РасходнаяНакладная.Ссылка
	|		И РасходнаяНакладная.Ссылка В (&Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПартииНоменклатуры КАК ПартииНоменклатуры
	|		ПО РасходнаяНакладнаяЗапасы.Партия = ПартииНоменклатуры.Ссылка
	|		И ПартииНоменклатуры.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.ТоварыНаКомиссии)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходнаяНакладная.Ссылка,
	|	ВЫБОР
	|		КОГДА РасходнаяНакладная.СуммаВключаетНДС
	|			ТОГДА РасходнаяНакладная.СтоимостьДоставки - РасходнаяНакладная.СуммаНДСДоставки
	|		ИНАЧЕ РасходнаяНакладная.СтоимостьДоставки
	|	КОНЕЦ,
	|	РасходнаяНакладная.СуммаНДСДоставки,
	|	ЛОЖЬ
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.Ссылка В (&Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСуммыДокумента.Ссылка КАК ДокументСсылка,
	|	СУММА(ВТСуммыДокумента.Сумма) КАК СуммаДокумента,
	|	СУММА(ВТСуммыДокумента.СуммаНДС) КАК СуммаНДСДокумента,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.Сумма
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаДокументаКомиссия,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.СуммаНДС
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаНДСДокументаКомиссия
	|ИЗ
	|	ВТСуммыДокумента КАК ВТСуммыДокумента
	|СГРУППИРОВАТЬ ПО
	|	ВТСуммыДокумента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыДокумента";
	
	Возврат Текст;
	
КонецФункции

