Функция ТекстЗапросаСуммыЗаказПокупателя()
	
	Текст = "ВЫБРАТЬ
	|	ЗаказПокупателя.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ЗаказПокупателя.СуммаВключаетНДС
	|			ТОГДА ЗаказПокупателяЗапасы.Сумма - ЗаказПокупателяЗапасы.СуммаНДС
	|		ИНАЧЕ ЗаказПокупателяЗапасы.Сумма
	|	КОНЕЦ КАК Сумма,
	|	ЗаказПокупателяЗапасы.СуммаНДС КАК СуммаНДС,
	|	НЕ ПартииНоменклатуры.Статус ЕСТЬ NULL КАК ЭтоКомиссия
	|ПОМЕСТИТЬ ВТСуммыДокумента
	|ИЗ
	|	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|		ПО ЗаказПокупателяЗапасы.Ссылка = ЗаказПокупателя.Ссылка
	|		И ЗаказПокупателя.Ссылка В (&Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПартииНоменклатуры КАК ПартииНоменклатуры
	|		ПО ЗаказПокупателяЗапасы.Партия = ПартииНоменклатуры.Ссылка
	|		И ПартииНоменклатуры.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.ТоварыНаКомиссии)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказПокупателя.Ссылка,
	|	ВЫБОР
	|		КОГДА ЗаказПокупателя.СуммаВключаетНДС
	|			ТОГДА ЗаказПокупателяРаботы.Сумма - ЗаказПокупателяРаботы.СуммаНДС
	|		ИНАЧЕ ЗаказПокупателяРаботы.Сумма
	|	КОНЕЦ,
	|	ЗаказПокупателяРаботы.СуммаНДС,
	|	ЛОЖЬ
	|ИЗ
	|	Документ.ЗаказПокупателя.Работы КАК ЗаказПокупателяРаботы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|		ПО ЗаказПокупателяРаботы.Ссылка = ЗаказПокупателя.Ссылка
	|		И ЗаказПокупателя.Ссылка В (&Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСуммыДокумента.Ссылка КАК ДокументСсылка,
	|	СУММА(ВТСуммыДокумента.Сумма) КАК СуммаДокумента,
	|	СУММА(ВТСуммыДокумента.СуммаНДС) КАК СуммаНДСДокумента,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.Сумма
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаДокументаКомиссия,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.СуммаНДС
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаНДСДокументаКомиссия
	|ИЗ
	|	ВТСуммыДокумента КАК ВТСуммыДокумента
	|СГРУППИРОВАТЬ ПО
	|	ВТСуммыДокумента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыДокумента";
	
	Возврат Текст;	
КонецФункции

Функция ТекстЗапросаСуммыПриходнаяНакладная()
	
	Текст = "ВЫБРАТЬ
	|	ПриходнаяНакладная.Ссылка КАК Ссылка,
	|	ПриходнаяНакладная.СуммаВключаетНДС КАК СуммаВключаетНДС,
	|	ПриходнаяНакладная.ДокументОснование КАК ДокументОснование
	|ПОМЕСТИТЬ ВТДокументыВозврата
	|ИЗ
	|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
	|ГДЕ
	|	ПриходнаяНакладная.Ссылка В (&Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТДокументыВозврата.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ВТДокументыВозврата.СуммаВключаетНДС
	|			ТОГДА ПриходнаяНакладнаяЗапасы.Сумма - ПриходнаяНакладнаяЗапасы.СуммаНДС
	|		ИНАЧЕ ПриходнаяНакладнаяЗапасы.Сумма
	|	КОНЕЦ КАК СуммаУменьшение,
	|	ПриходнаяНакладнаяЗапасы.СуммаНДС КАК СуммаНДСУменьшение,
	|	НЕ ПартииНоменклатуры.Статус ЕСТЬ NULL КАК ЭтоКомиссия
	|ПОМЕСТИТЬ ВТСуммыДокумента
	|ИЗ
	|	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыВозврата КАК ВТДокументыВозврата
	|		ПО ПриходнаяНакладнаяЗапасы.Ссылка = ВТДокументыВозврата.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПартииНоменклатуры КАК ПартииНоменклатуры
	|		ПО ПриходнаяНакладнаяЗапасы.Партия = ПартииНоменклатуры.Ссылка
	|		И ПартииНоменклатуры.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.ТоварыНаКомиссии)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТДокументыВозврата.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА РасходнаяНакладная.СуммаВключаетНДС
	|			ТОГДА РасходнаяНакладнаяЗапасы.Сумма - РасходнаяНакладнаяЗапасы.СуммаНДС
	|		ИНАЧЕ РасходнаяНакладнаяЗапасы.Сумма
	|	КОНЕЦ КАК СуммаДо,
	|	РасходнаяНакладнаяЗапасы.СуммаНДС КАК СуммаНДСДо,
	|	НЕ ПартииНоменклатуры.Статус ЕСТЬ NULL КАК ЭтоКомиссия
	|ПОМЕСТИТЬ ВТСуммыДо
	|ИЗ
	|	Документ.РасходнаяНакладная.Запасы КАК РасходнаяНакладнаяЗапасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|		ПО РасходнаяНакладнаяЗапасы.Ссылка = РасходнаяНакладная.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТДокументыВозврата КАК ВТДокументыВозврата
	|		ПО РасходнаяНакладная.Ссылка = ВТДокументыВозврата.ДокументОснование
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПартииНоменклатуры КАК ПартииНоменклатуры
	|		ПО РасходнаяНакладнаяЗапасы.Партия = ПартииНоменклатуры.Ссылка
	|		И ПартииНоменклатуры.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.ТоварыНаКомиссии)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТДокументыВозврата;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСуммыДокумента.Ссылка КАК Ссылка,
	|	СУММА(ВТСуммыДокумента.СуммаУменьшение) КАК СуммаУменьшение,
	|	СУММА(ВТСуммыДокумента.СуммаНДСУменьшение) КАК СуммаНДСУменьшение,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.СуммаУменьшение
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаУменьшениеКомиссия,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДокумента.ЭтоКомиссия
	|			ТОГДА ВТСуммыДокумента.СуммаНДСУменьшение
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаНДСУменьшениеКомиссия
	|ПОМЕСТИТЬ ВТСуммыКомиссия
	|ИЗ
	|	ВТСуммыДокумента КАК ВТСуммыДокумента
	|СГРУППИРОВАТЬ ПО
	|	ВТСуммыДокумента.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСуммыДо.Ссылка КАК Ссылка,
	|	СУММА(ВТСуммыДо.СуммаДо) КАК СуммаДо,
	|	СУММА(ВТСуммыДо.СуммаНДСДо) КАК СуммаНДСДо,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДо.ЭтоКомиссия
	|			ТОГДА ВТСуммыДо.СуммаДо
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаДоКомиссия,
	|	СУММА(ВЫБОР
	|		КОГДА ВТСуммыДо.ЭтоКомиссия
	|			ТОГДА ВТСуммыДо.СуммаНДСДо
	|		ИНАЧЕ 0
	|	КОНЕЦ) КАК СуммаНДСДоКомиссия
	|ПОМЕСТИТЬ ВТСуммыДоКомиссия
	|ИЗ
	|	ВТСуммыДо КАК ВТСуммыДо
	|СГРУППИРОВАТЬ ПО
	|	ВТСуммыДо.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыДокумента;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыДо;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСуммыКомиссия.Ссылка КАК ДокументСсылка,
	|	ВЫБОР
	|		КОГДА ВТСуммыДоКомиссия.СуммаДо ЕСТЬ NULL
	|			ТОГДА ВТСуммыКомиссия.СуммаУменьшение
	|		ИНАЧЕ ВТСуммыДоКомиссия.СуммаДо - ВТСуммыКомиссия.СуммаУменьшение
	|	КОНЕЦ КАК СуммаДокумента,
	|	ВЫБОР
	|		КОГДА ВТСуммыДоКомиссия.СуммаДо ЕСТЬ NULL
	|			ТОГДА ВТСуммыКомиссия.СуммаНДСУменьшение
	|		ИНАЧЕ ВТСуммыДоКомиссия.СуммаНДСДо - ВТСуммыКомиссия.СуммаНДСУменьшение
	|	КОНЕЦ КАК СуммаНДСДокумента,
	|	ВТСуммыКомиссия.СуммаУменьшение,
	|	ВТСуммыКомиссия.СуммаНДСУменьшение,
	|	ВТСуммыКомиссия.СуммаУменьшениеКомиссия,
	|	ВТСуммыКомиссия.СуммаНДСУменьшениеКомиссия,
	|	ВЫБОР
	|		КОГДА ВТСуммыДоКомиссия.СуммаДо ЕСТЬ NULL
	|			ТОГДА ВТСуммыКомиссия.СуммаУменьшениеКомиссия
	|		ИНАЧЕ ВТСуммыДоКомиссия.СуммаДоКомиссия - ВТСуммыКомиссия.СуммаУменьшениеКомиссия
	|	КОНЕЦ КАК СуммаДокументаКомиссия,
	|	ВЫБОР
	|		КОГДА ВТСуммыДоКомиссия.СуммаДо ЕСТЬ NULL
	|			ТОГДА ВТСуммыКомиссия.СуммаНДСУменьшениеКомиссия
	|		ИНАЧЕ ВТСуммыДоКомиссия.СуммаНДСДоКомиссия - ВТСуммыКомиссия.СуммаНДСУменьшениеКомиссия
	|	КОНЕЦ КАК СуммаНДСКомиссия
	|ИЗ
	|	ВТСуммыКомиссия КАК ВТСуммыКомиссия
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыДоКомиссия КАК ВТСуммыДоКомиссия
	|		ПО ВТСуммыКомиссия.Ссылка = ВТСуммыДоКомиссия.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыДоКомиссия;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСуммыКомиссия";
	
	Возврат Текст;
КонецФункции

#КонецОбласти

#Область Поступление
Процедура ЗаполнитьСведенияШапкиПоПоступлению(ДанныеЗаполнения, СведенияДокументовОснований)

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Контрагент", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Договор", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ВалютаДокумента", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Кратность");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Курс");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьКладовщика");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ХозяйственнаяОперация");

	ДокументРеализацииСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "ДокументОснование");
	Если Не ПустаяСтрока(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ДокументРеализацииСсылка, "ОснованиеПечати")) Тогда

		СведенияДокументовОснований.ОснованиеПечати = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ДокументРеализацииСсылка, "ОснованиеПечати");

	КонецЕсли;

	СведенияДокументовОснований.Вставить("ИсправляемыйСчетФактура", Неопределено);
	СведенияДокументовОснований.Вставить("ВидОперации", Неопределено);
	СведенияДокументовОснований.Вставить("НомерИсходногоДокумента", Неопределено);
	СведенияДокументовОснований.Вставить("ДатаИсходногоДокумента", Неопределено);
	СведенияДокументовОснований.Вставить("НомерИсправляемогоКорректировочногоДокумента", Неопределено);
	СведенияДокументовОснований.Вставить("ДатаИсправляемогоКорректировочногоДокумента", Неопределено);
	СведенияДокументовОснований.Вставить("НомерИсправления", Неопределено);
	СведенияДокументовОснований.Вставить("Исправление", Неопределено);
	СведенияДокументовОснований.Вставить("УчитыватьИсправлениеИсходногоДокумента", Неопределено);
	СведенияДокументовОснований.Вставить("НомерИсправленияИсходногоДокумента", Неопределено);
	СведенияДокументовОснований.Вставить("ДатаИсправленияИсходногоДокумента", Неопределено);

	РеквизитыКорректировки = Документы.СчетФактура.ПолучитьПараметрыЗаполненияКорректировочногоСчетаФактурыВозвратОтПокупателя(
		ДанныеЗаполнения);
	Для Каждого ЭлементСтруктуры Из РеквизитыКорректировки Цикл

		Если СведенияДокументовОснований.Свойство(ЭлементСтруктуры.Ключ) Тогда

			СведенияДокументовОснований[ЭлементСтруктуры.Ключ] = ЭлементСтруктуры.Значение;

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьСведенияШапкиПоПередачеТоваровМеждуОрганизациями(ДанныеЗаполнения, СведенияДокументовОснований)

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	СведенияДокументовОснований.Контрагент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения,
		"КонтрагентПолучатель");
	СведенияДокументовОснований.Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "Договор");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ВалютаДокумента", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Кратность");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Курс");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьРуководителя");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьГлавногоБухгалтера");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьКладовщика");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ХозяйственнаяОперация");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ОснованиеПечати");

КонецПроцедуры

#Область ОтчетКомитенту

Процедура ЗаполнитьСведенияШапкиПоОтчетуКомитента(ДанныеЗаполнения, СведенияДокументовОснований)

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Контрагент", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Договор", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ВалютаДокумента", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Кратность");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Курс");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ОснованиеПечати");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ПодписьРуководителя");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
		ДанныеЗаполнения, "Организация"), "ПодписьГлавногоБухгалтера");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ХозяйственнаяОперация");

КонецПроцедуры

Процедура ЗаполнитьСуммуДокументаПоОтчетуКомитента(ДанныеЗаполнения, СведенияДокументовОснований,
	СуммыДокументовОснований)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", ДанныеЗаполнения);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОтчетКомитентуЗапасы.СуммаВознаграждения,
		|	ОтчетКомитентуЗапасы.СуммаНДСВознаграждения
		|ИЗ
		|	Документ.ОтчетКомитенту.Запасы КАК ОтчетКомитентуЗапасы
		|ГДЕ
		|	ОтчетКомитентуЗапасы.Ссылка = &СсылкаНаДокумент";
		
	ТаблицаЗапасы = Запрос.Выполнить().Выгрузить();
	
	СуммыДокументовОснований.СуммаДокумента = ТаблицаЗапасы.Итог("СуммаВознаграждения");
	СуммыДокументовОснований.СуммаНДСДокумента = ТаблицаЗапасы.Итог("СуммаНДСВознаграждения");
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "СуммаВключаетНДС") Тогда

		СуммыДокументовОснований.СуммаДокумента = СуммыДокументовОснований.СуммаДокумента
			- СуммыДокументовОснований.СуммаНДСДокумента;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОтчетКомиссионера

// Поддержка механизма заполнения сводных счетов-фактур на основании отчетов комиссионеров
//

Процедура ЗаполнитьПоПокупателямОтчетаКомиссионера(СтруктураЗаполнения) Экспорт
	
	// Заполнение шапки.
	ДанныеЗаполнения	= СтруктураЗаполнения.Ссылка;
	Дата				= СтруктураЗаполнения.Дата;
	ВидОперации			= Перечисления.ВидыОперацийСчетФактура.Продажа;
	Организация			= СтруктураЗаполнения.Организация;
	Контрагент			= СтруктураЗаполнения.Покупатель;
	Договор				= Справочники.ДоговорыКонтрагентов.ДоговорПоУмолчанию(СтруктураЗаполнения.Покупатель);
	СводныйКомиссионный = СтруктураЗаполнения.СводныйКомиссионный;
	ВалютаДокумента		= СтруктураЗаполнения.ВалютаДокумента;
	СуммаВключаетНДС	= СтруктураЗаполнения.СуммаВключаетНДС; // переменная
	Курс				= СтруктураЗаполнения.Курс;
	Кратность			= СтруктураЗаполнения.Кратность;

	Если СтруктураЗаполнения.Свойство("Корректировочный") Тогда
		Корректировочный	= СтруктураЗаполнения.Корректировочный;
		Если Корректировочный Тогда
			ВидОперации = Перечисления.ВидыОперацийСчетФактура.Корректировка;
		КонецЕсли;
	КонецЕсли;
	//

	Если ВалютаДокумента <> Константы.НациональнаяВалюта.Получить() Тогда

		ВалютаКурсКратность = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор,
			"ВалютаРасчетов"), Дата);
		Курс = ВалютаКурсКратность.Курс;
		Кратность = ВалютаКурсКратность.Кратность;

	КонецЕсли;

	СтрокаДокументаОснования = ДокументыОснования.Найти(ДанныеЗаполнения, "ДокументОснование");
	
	Если СтрокаДокументаОснования = Неопределено Тогда

		СтрокаДокументаОснования = ДокументыОснования.Добавить();
		СтрокаДокументаОснования.ДокументОснование = ДанныеЗаполнения;
		
	КонецЕсли;

	Если ЗначениеЗаполнено(Организация) Тогда

		ПодписьРуководителя = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ПодписьРуководителя");
		ПодписьГлавногоБухгалтера = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ПодписьГлавногоБухгалтера");

	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(КодВидаОперации) Тогда
		КодВидаОперации = ?(СводныйКомиссионный, "27", "01");
	КонецЕсли;
	
	// Прослеживаемость
	Для Каждого СтрокаЗапасы Из СтруктураЗаполнения.Запасы Цикл
		Если СтрокаЗапасы.ПрослеживаемыйТовар Тогда
			ЕстьПрослеживаемыеТовары = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	// Конец Прослеживаемость

	Если ВидОперации = Перечисления.ВидыОперацийСчетФактура.Корректировка Тогда
		Если НЕ ЗначениеЗаполнено(КодВидаОперацииНаУменьшение) Тогда
			КодВидаОперацииНаУменьшение = ?(СводныйКорректировочный, "01", "18");
		КонецЕсли;
		
		НомерИсходногоДокумента = СтруктураЗаполнения.НомерИсходногоДокумента;
		ДатаИсходногоДокумента = СтруктураЗаполнения.ДатаИсходногоДокумента;
		СтрокаДокументаОснования.НомерИсходногоДокумента = СтруктураЗаполнения.НомерИсходногоДокумента;
		СтрокаДокументаОснования.ДатаИсходногоДокумента = СтруктураЗаполнения.ДатаИсходногоДокумента;
		ЗаполнитьСуммыОтчетКомиссионераКорректировка(ДанныеЗаполнения);
	Иначе
		ЗаполнитьТабличнуюЧастьПоОтчетуКомиссионера(СтруктураЗаполнения, СуммаВключаетНДС);
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьТабличнуюЧастьПоОтчетуКомиссионера(СтруктураЗаполнения, СуммаВключаетНДС) Экспорт

	ФорматСчетФактуры = ?(УдалитьЗапасы.Количество() > 0, "1.6.11", "1.6.12");

	Если ФорматСчетФактуры = "1.6.11" Тогда

		УдалитьЗапасы.Очистить();

	КонецЕсли;

	СуммаДокумента = 0;
	СуммаНДСДокумента = 0;

	РезультатПоиска = СтруктураЗаполнения.Запасы;
	Для Каждого СтрокаТабличнойЧасти Из РезультатПоиска Цикл

		Если ФорматСчетФактуры = "1.6.11" Тогда

			НоваяСтрока = УдалитьЗапасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТабличнойЧасти);

			Если НоваяСтрока.Количество = 0 Тогда
				НоваяСтрока.Цена = 0;
			ИначеЕсли СуммаВключаетНДС Тогда
				НоваяСтрока.Цена = НоваяСтрока.Сумма / ((ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
					НоваяСтрока.СтавкаНДС, "Ставка") + 100) / 100) / НоваяСтрока.Количество;
			Иначе
				НоваяСтрока.Цена = НоваяСтрока.Сумма / НоваяСтрока.Количество;
			КонецЕсли;

		КонецЕсли;

		Если СуммаВключаетНДС Тогда

			СуммаБезНДС = Окр(СтрокаТабличнойЧасти.Сумма / ((СтрокаТабличнойЧасти.СтавкаНДС.Ставка + 100) / 100), 2);

		Иначе

			СуммаБезНДС = СтрокаТабличнойЧасти.Сумма;

		КонецЕсли;

		Если ФорматСчетФактуры = "1.6.11" Тогда

			НоваяСтрока.Сумма = СуммаБезНДС;

		КонецЕсли;

		СуммаДокумента = СуммаДокумента + СуммаБезНДС;
		СуммаНДСДокумента = СуммаНДСДокумента + СтрокаТабличнойЧасти.СуммаНДС;

	КонецЦикла;

КонецПроцедуры

Процедура ЗаполнитьПоПокупателямОтчетаКомиссионераСводнаяСправка(СтруктураЗаполнения, СведенияДокументовОснований,
	СуммыДокументовОснований) Экспорт
	
	// Заполнение шапки.
	ДанныеЗаполнения	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураЗаполнения, "Ссылка");

	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Организация", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "ВалютаДокумента", Истина);
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Курс");
	ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеЗаполнения, "Кратность");
		
	//

	Если ВалютаДокумента <> Константы.НациональнаяВалюта.Получить() Тогда

		ДоговорВалютаРасчетов = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВалютаРасчетов");

		ВалютаКурсКратность = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ДоговорВалютаРасчетов, Дата);
		ДанныеКурса = Новый Структура("Курс, Кратность", ВалютаКурсКратность.Курс, ВалютаКурсКратность.Кратность);

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеКурса, "Курс");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеКурса, "Кратность");

	КонецЕсли;

	Если ДокументыОснования.Найти(ДанныеЗаполнения, "ДокументОснование") = Неопределено Тогда

		НоваяСтрока = ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ДанныеЗаполнения;

	КонецЕсли;

	Если ЗначениеЗаполнено(Организация) Тогда

		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Организация,
			"ПодписьРуководителя, ПодписьГлавногоБухгалтера");
		ДанныеПодписей = Новый Структура("ПодписьРуководителя, ПодписьГлавногоБухгалтера",
			ЗначенияРеквизитов.ПодписьРуководителя, ЗначенияРеквизитов.ПодписьГлавногоБухгалтера);

		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеПодписей, "ПодписьРуководителя");
		ЗаполнитьЗначениеСПроверкой(СведенияДокументовОснований, ДанныеПодписей, "ПодписьГлавногоБухгалтера");

	КонецЕсли;
    
    Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", СтруктураЗаполнения);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОтчетКомиссионераЗапасы.СтавкаНДС,
	|	ОтчетКомиссионераЗапасы.Сумма,
	|	ОтчетКомиссионераЗапасы.СуммаНДС,
	|	ОтчетКомиссионераЗапасы.СтавкаНДС.Ставка
	|ИЗ
	|	Документ.ОтчетКомиссионера.Запасы КАК ОтчетКомиссионераЗапасы
	|ГДЕ
	|	ОтчетКомиссионераЗапасы.Ссылка = &СсылкаНаДокумент";

	РезультатПоиска = Запрос.Выполнить().Выгрузить();

	Для Каждого СтрокаТабличнойЧасти Из РезультатПоиска Цикл
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЗаполнения, "СуммаВключаетНДС") Тогда
			СуммаБезНДС = Окр(СтрокаТабличнойЧасти.Сумма / ((СтрокаТабличнойЧасти.СтавкаНДССтавка + 100) / 100), 2);
		Иначе
			СуммаБезНДС = СтрокаТабличнойЧасти.Сумма;
		КонецЕсли;

		СуммаДокумента = СуммаДокумента + СуммаБезНДС;
		СуммаНДСДокумента = СуммаНДСДокумента + СтрокаТабличнойЧасти.СуммаНДС;

	КонецЦикла;

	СуммыДокументовОснований.СуммаДокумента = СуммаДокумента;
	СуммыДокументовОснований.СуммаНДСДокумента = СуммаНДСДокумента;

КонецПроцедуры

