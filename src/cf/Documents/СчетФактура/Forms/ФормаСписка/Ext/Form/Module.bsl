&НаКлиенте
Процедура ПослеВыбораСводнойСправки(Результат, Параметры) Экспорт
	
	Если Результат = Неопределено Тогда 
		Возврат
	КонецЕсли;
	
	СтруктураПараметров = ПолучитьСтруктуруПараметровФормы(ПредопределенноеЗначение("Перечисление.ВидыОперацийСчетФактура.КорректировочнаяСправка"), Результат);
	ОткрытьФорму("Документ.СчетФактура.Форма.ФормаДокумента",СтруктураПараметров, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСтруктуруПараметровФормы(ВидСчетаФактуры, ИсправляемыйСчетФактура = Неопределено)
	
	СтруктураПараметров = Новый Структура;
	
	ОтборПоОрганизации = ВернутьПолеПользовательскогоОтбораКомпоновки(ЭтотОбъект,, "Организация");
	
	ЗначенияЗаполнения = Новый Структура();
	
	Если ОтборПоОрганизации <> Неопределено Тогда
		ЗначенияЗаполнения.Вставить("Организация", ОтборПоОрганизации);
	КонецЕсли;
	
	ЗначенияЗаполнения.Вставить("ВидОперации", ВидСчетаФактуры);
	ЗначенияЗаполнения.Вставить("ИсправляемыйСчетФактура", ИсправляемыйСчетФактура);
	
	СтруктураПараметров.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	Возврат СтруктураПараметров;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВернутьПолеПользовательскогоОтбораКомпоновки(Форма, Знач ИмяПоля, Настройки = Неопределено)
	
	Если Настройки = Неопределено Тогда
		Настройки = Форма.Список.КомпоновщикНастроек.ПользовательскиеНастройки;
	КонецЕсли;
	
	ЗначениеПоляОтбора = Неопределено;
	ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ИмяПоля);
	Для каждого ЭлементОтбора Из Форма.Список.Отбор.Элементы Цикл
		Если ЭлементОтбора.ЛевоеЗначение = ЛевоеЗначение И ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СписокЗначений")
			И ЭлементОтбора.ПравоеЗначение.Количество() Тогда
			ЗначениеПоляОтбора = ЭлементОтбора.ПравоеЗначение[ЭлементОтбора.ПравоеЗначение.Количество() - 1].Значение;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЗначениеПоляОтбора;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьНастройкиДинамическогоСписка(Знач ИмяТаблицы, Знач ИмяКоманды)
	
	Если ПустаяСтрока(Заголовок) Тогда
		ЗаголовокФормы = НСтр("ru = 'Счет-фактура'");
	Иначе
		ЗаголовокФормы = Заголовок;
	КонецЕсли;
	
	ПараметрыОтчета = Отчеты.РеестрДокументов.ПараметрыОтчета();
	ПараметрыОтчета.ЗаголовокФормы = ЗаголовокФормы;
	ПараметрыОтчета.ИмяТаблицы = ИмяТаблицы;
	ПараметрыОтчета.ИмяКоманды = ИмяКоманды;
	ПараметрыОтчета.ЗаменяемыеЗаголовкиПолей = ЗаголовкиПолейДляРеестраДокументов();
	ПараметрыОтчета.ЗаменяемыеПоляВыбора = СписокПолейДляЗамены();
	
	Отчеты.РеестрДокументов.НастройкиДинамическогоСписка(ЭтотОбъект, ПараметрыОтчета);
	
КонецПроцедуры

&НаСервере
Функция ЗаголовкиПолейДляРеестраДокументов()
	
	ЗаголовокКонтрагента = Элементы.Контрагент.Заголовок;
	ЗаголовкиПолей = Новый Структура();
	ЗаголовкиПолей.Вставить("Контрагент", ЗаголовокКонтрагента);
	Возврат ЗаголовкиПолей;
	
КонецФункции

&НаСервере
Функция СписокПолейДляЗамены()
	
	СписокПолей = Новый Структура();
	СписокПолей.Вставить("Дата", "ДатаДокумента");
	
	Возврат СписокПолей;
	
КонецФункции

