// Формирует строку содержащую текст запроса.
// Возвращаемое значение:
//   Строка
Функция ПолучитьТекстЗапросаИнициализироватьДанныеДокумента() Экспорт
	
	ТекстЗапроса = "ВЫБРАТЬ
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Ссылка КАК Ссылка,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.ПометкаУдаления КАК ПометкаУдаления,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Номер КАК Номер,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.ДатаРегистрации КАК Дата,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Проведен КАК Проведен,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.УменьшаемыйНалог КАК УменьшаемыйНалог,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Организация КАК Организация,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Модель КАК Модель,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.ЗаводскойНомер КАК ЗаводскойНомер,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.ДатаРегистрации КАК ДатаРегистрации,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.РегистрационныйНомер КАК РегистрационныйНомер,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.СуммаДокумента КАК СуммаДокумента,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Комментарий КАК Комментарий,
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Ответственный КАК Ответственный
	|ПОМЕСТИТЬ ВременнаяТаблицаШапка
	|ИЗ
	|	Документ.РасходыНаОнлайнКассыУменьшающиеНалоги КАК РасходыНаОнлайнКассыУменьшающиеНалоги
	|ГДЕ
	|	РасходыНаОнлайнКассыУменьшающиеНалоги.Ссылка = &Ссылка";
	Возврат ТекстЗапроса;
	
КонецФункции

// Формирует структуру значений, содержащую данные по регистрации кассы для вычета.
// Возвращаемое значение:
//   Структура:
//   	* ДокументРасхода				- Неопределено
//   	* ДатаРегистрации				- Дата
//   	* СуммаДокумента				- Число
//   	* РегистрационныйНомер			- Строка
//   	* ЗаводскойНомер				- Строка
//   	* Модель						- Строка
//   	* РегистрацияВНалоговомОргане	- Неопределено
//   	* Организация					- Неопределено
//   	* УменьшаемыйНалог				- Число
Функция НовыйИнформацияПоДокументуРасходов() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ДокументРасхода", 				Неопределено);
	Результат.Вставить("ДатаРегистрации", 				Дата(1,1,1));
	Результат.Вставить("СуммаДокумента", 				0);
	Результат.Вставить("РегистрационныйНомер", 			""); 
	Результат.Вставить("ЗаводскойНомер", 				""); 
	Результат.Вставить("Модель", 						""); 
    Результат.Вставить("РегистрацияВНалоговомОргане",	Неопределено);
	Результат.Вставить("Организация", 					Неопределено);
	Результат.Вставить("УменьшаемыйНалог", 				0);
	
	Возврат Результат;
	
КонецФункции

