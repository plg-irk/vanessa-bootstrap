Функция ПолучитьАктуальныйДокументРасходов(Организация, Дата) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.Ссылка КАК ДокументРасхода,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.ДатаРегистрации КАК ДатаРегистрации,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.СуммаДокумента КАК СуммаДокумента,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.РегистрационныйНомер КАК РегистрационныйНомер,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.ЗаводскойНомер КАК ЗаводскойНомер,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.Модель КАК Модель,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.Организация КАК Организация,
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.УменьшаемыйНалог КАК УменьшаемыйНалог
		|ИЗ
		|	Документ.РасходыНаОнлайнКассыУменьшающиеНалоги КАК РасходыНаОнлайнКассыУменьшающиеНалоги
		|ГДЕ
		|	РасходыНаОнлайнКассыУменьшающиеНалоги.Проведен
		|	И РасходыНаОнлайнКассыУменьшающиеНалоги.Организация = &Организация
		|	И РасходыНаОнлайнКассыУменьшающиеНалоги.ДатаРегистрации <= &Дата";
	
	Запрос.УстановитьПараметр("Дата", 			Дата);
	Запрос.УстановитьПараметр("Организация", 	Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	СтруктураВозврата = НовыйИнформацияПоДокументуРасходов();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СтруктураВозврата, Выборка);	
	КонецЦикла;
	
	Возврат СтруктураВозврата;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасходыНаОнлайнКассыУменьшающиеНалоги(ДокументСсылка, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("РасходНаОнлайнКассыУменьшающиеНалоги", НСтр("ru='Расход на онлайн кассы уменьшающие налоги'")); 
	Запрос.УстановитьПараметр("СистемаНалогообложения", Перечисления.ВидыНалоговУменьшаемыхНаРасходыККТ.УСН);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК НомерСтроки,
	|	ВЫРАЗИТЬ(&РасходНаОнлайнКассыУменьшающиеНалоги КАК СТРОКА(100)) КАК СодержаниеПроводки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ВременнаяТаблицаШапка.Дата КАК Дата,
	|	ВременнаяТаблицаШапка.Дата КАК Период,
	|	ВременнаяТаблицаШапка.Организация КАК Организация,
	|	ВременнаяТаблицаШапка.СуммаДокумента КАК Сумма,
	|	ВременнаяТаблицаШапка.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане,
	|	ВременнаяТаблицаШапка.Ссылка КАК ДокументРасхода,
	|	&СистемаНалогообложения КАК СистемаНалогообложения
	|ИЗ
	|	ВременнаяТаблицаШапка КАК ВременнаяТаблицаШапка";
	
	Запрос.Выполнить();
	
	НомерЗапроса = 0;
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасходыНаОнлайнКассыУменьшающиеНалоги", МассивРезультатов[НомерЗапроса].Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаДенежныеСредства()

