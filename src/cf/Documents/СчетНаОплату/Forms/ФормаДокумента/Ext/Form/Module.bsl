#Область ПлатежныйКалендарь

&НаКлиенте
Процедура ОбработатьИзменениеПлатежныйКалендарьПроцентОплаты()
	
	Если Элементы.РедактироватьСписком.Пометка Тогда
		ТекущаяСтрока = Элементы.СписокПлатежныйКалендарь.ТекущиеДанные;
	Иначе
		ТекущаяСтрока = Объект.ПлатежныйКалендарь[0];
	КонецЕсли;
	ПроцентОплатыИтог = Объект.ПлатежныйКалендарь.Итог("ПроцентОплаты");
	
	Если ПроцентОплатыИтог > 100 Тогда
		ТекущаяСтрока.ПроцентОплаты = ТекущаяСтрока.ПроцентОплаты - (ПроцентОплатыИтог - 100);
	КонецЕсли;
	
	ТекущаяСтрока.СуммаОплаты = Окр((Объект.Запасы.Итог("Всего") + СтоимостьДоставкиСНДС) * ТекущаяСтрока.ПроцентОплаты
		/ 100, 2, 1);
	ТекущаяСтрока.СуммаНДСОплаты = Окр((Объект.Запасы.Итог("СуммаНДС") + Объект.СуммаНДСДоставки)
		* ТекущаяСтрока.ПроцентОплаты / 100, 2, 1);
	
	Если Объект.ПлатежныйКалендарь.Итог("ПроцентОплаты") = 100
		И Объект.ПлатежныйКалендарь.Итог("СуммаОплаты") <> ИтогВсего Тогда
		ОбработатьИтогиПлатежныйКалендарь();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеПлатежныйКалендарьСуммаОплаты()
	Если Элементы.РедактироватьСписком.Пометка Тогда
		ТекущаяСтрока = Элементы.СписокПлатежныйКалендарь.ТекущиеДанные;
	Иначе
		ТекущаяСтрока = Объект.ПлатежныйКалендарь[0];
	КонецЕсли;
	ЗапасыИтог = Объект.Запасы.Итог("Всего") + СтоимостьДоставкиСНДС;
	ПлатежныйКалендарьИтог = Объект.ПлатежныйКалендарь.Итог("СуммаОплаты");

	Если ПлатежныйКалендарьИтог > ЗапасыИтог Тогда
		ТекущаяСтрока.СуммаОплаты = ТекущаяСтрока.СуммаОплаты - (ПлатежныйКалендарьИтог - ЗапасыИтог);
	КонецЕсли;

	ТекущаяСтрока.ПроцентОплаты = ?(ЗапасыИтог = 0, 0, Окр(ТекущаяСтрока.СуммаОплаты / ЗапасыИтог * 100, 2, 1));
	ТекущаяСтрока.СуммаНДСОплаты = Окр(Объект.Запасы.Итог("СуммаНДС") * ТекущаяСтрока.ПроцентОплаты / 100, 2, 1);

	Если Объект.ПлатежныйКалендарь.Итог("ПроцентОплаты") = 100
		И Объект.ПлатежныйКалендарь.Итог("СуммаОплаты") <> ИтогВсего Тогда
		ОбработатьИтогиПлатежныйКалендарь();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеПлатежныйКалендарьСуммаНДСОплаты()
	Если Элементы.РедактироватьСписком.Пометка Тогда
		ТекущаяСтрока = Элементы.СписокПлатежныйКалендарь.ТекущиеДанные;
	Иначе
		ТекущаяСтрока = Объект.ПлатежныйКалендарь[0];
	КонецЕсли;
	
	ЗапасыИтог = Объект.Запасы.Итог("СуммаНДС");
	ПлатежныйКалендарьИтог = Объект.ПлатежныйКалендарь.Итог("СуммаНДСОплаты");
	
	Если ПлатежныйКалендарьИтог > ЗапасыИтог Тогда
		ТекущаяСтрока.СуммаНДСОплаты = ТекущаяСтрока.СуммаНДСОплаты - (ПлатежныйКалендарьИтог - ЗапасыИтог);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбработатьИтогиПлатежныйКалендарь()
	
	ТаблицаРаспределения = Объект.ПлатежныйКалендарь.Выгрузить();
	РасчетыПроведениеДокументов.РаспределитьСуммуПоКолонкеТаблицы(ИтогВсего, ТаблицаРаспределения, "СуммаОплаты",
		"ПроцентОплаты");
	Объект.ПлатежныйКалендарь.Загрузить(ТаблицаРаспределения);
	
КонецПроцедуры

#КонецОбласти

#Область РаспределениеКорректировкиСуммы

&НаСервереБезКонтекста
Функция ПолучитьНастройкиИзмененияСумм()
	
	НастройкиСумм = ДокументыУНФКлиентСервер.ПараметрыИзмененияСуммыДокумента();
	ДокументыУНФ.ЗаполнитьНастройкиИзмененияСуммыДокумента(НастройкиСумм);
	Возврат НастройкиСумм;
	
КонецФункции

&НаКлиенте
Процедура НастройкаРаспределенияКорректировкиСуммыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	НастройкиКорректировкиСуммы = ПолучитьНастройкиИзмененияСумм();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НастройкиКорректировкиСуммы);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеИзмененияИтогоВсего(Результат, ДополнительныеПараметры)Экспорт
	РаспределятьКакСкидку = Ложь;
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("КорректировкаСуммыЗаСчетРучнойСкидки") Тогда
			РаспределятьКакСкидку = Результат.КорректировкаСуммыЗаСчетРучнойСкидки;
		КонецЕсли;
		Если Результат.Свойство("ЗапрашиватьВариантКорректировкиСуммы") Тогда
			ЗапрашиватьРаспределение = Результат.ЗапрашиватьВариантКорректировкиСуммы;
			Если Не ЗапрашиватьРаспределение Тогда
				КорректировкаСуммыЗаСчетРучнойСкидки = РаспределятьКакСкидку;
			КонецЕсли;				
		КонецЕсли;
	КонецЕсли;
	
	ПродолжитьИзменениеИтогВсего(РаспределятьКакСкидку);	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьИзменениеИтогВсего(КорректировкаЗаСчетСкидки = Ложь)
	СтарыйИтогВсего = Объект.Запасы.Итог("Всего");
	ИзменениеСуммыВсего = СтарыйИтогВсего - ИтогВсего;
	Если КорректировкаЗаСчетСкидки Тогда
		СкидкаСумма = СкидкаСумма + ИзменениеСуммыВсего;
		ОбработатьИзменениеСкидкаСумма();
	Иначе
		// Сумма распределяется за счет изменения цены, так работает этот вариант обработки
		ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение(
			"Перечисление.ДействияГрупповогоИзмененияСтрок.РаспределитьСуммуПоСуммам");
		ЗапасыИзменениеСтрокЗначение = - ИзменениеСуммыВсего;		
		Для Каждого ИзменяемаяСтрока Из Объект.Запасы Цикл
			ИзменяемаяСтрока.Пометка = Истина;
		КонецЦикла;
		ОбработатьТаблицу(Ложь);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзменениеСкидкаСумма()
	
	ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение(
		"Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьСкидкуСуммой");
	ЗапасыИзменениеСтрокОбъектИзмененийРеквизит = "Сумма";
	ЗапасыИзменениеСтрокЗначение = СкидкаСумма;
	Модифицированность = Истина;
	
	СтруктураОповещения = Новый Структура;
	СтруктураОповещения.Вставить("СуммаДоРасчета", СкидкаСумма);
	
	ОбработатьТаблицу();
	
	СтруктураОповещения.Вставить("СуммаПослеРасчета", СкидкаСумма);
	
	ЦенообразованиеКлиент.ПоказатьОповещениеПользователяОКорректировкеЦены(СтруктураОповещения);
	
КонецПроцедуры

// Производит пересчет связанных реквизитов в строках таблицы после из группового изменения.
&НаКлиенте
Процедура ОбработатьТаблицу(ЗаСчетСкидки = Неопределено)
		
	// Наборы
	Если ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УдалитьСтроки") Тогда
		
		ИзменяемыеСтроки = Объект.Запасы.НайтиСтроки(Новый Структура("Пометка", Истина));

		Если ИзменяемыеСтроки.Количество() = Объект.Запасы.Количество() Тогда
			// Если выделены все строки - проверки удаления наборов не выполняются
			Объект.ДобавленныеНаборы.Очистить();
		Иначе
			Для каждого Строка Из ИзменяемыеСтроки Цикл
				Если ЗначениеЗаполнено(Строка.НоменклатураНабора) Тогда
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = НСтр("ru = 'Действие недоступно для наборов.'");
					Сообщение.Поле = "Объект.Запасы";
					Сообщение.Сообщить();
					Возврат;
				КонецЕсли; 
			КонецЦикла; 
		КонецЕсли; 
	КонецЕсли; 
	// Конец Наборы
	
	ЗадаватьВопросРаспределенияКорректировки = Ложь;
	Если ЗаСчетСкидки = Неопределено 
		И ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.РаспределитьСуммуПоСуммам")
		ИЛИ ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ОкруглитьСуммы") Тогда
		ЗадаватьВопросРаспределенияКорректировки = ЗапрашиватьРаспределение;
	КонецЕсли;
	Если ЗадаватьВопросРаспределенияКорректировки Тогда
		ДопПараметр = Новый Структура();
		Оповещение = Новый ОписаниеОповещения("ПослеВыбораВариантаРаспределенияСуммы", ЭтотОбъект, ДопПараметр);
		ОткрытьФорму("ОбщаяФорма.ПодтверждениеРаспределенияКорректировкиСуммы", , , , , , Оповещение);
	Иначе
		ПродолжитьОбработкуТаблицы(?(ЗаСчетСкидки = Неопределено, КорректировкаСуммыЗаСчетРучнойСкидки, ЗаСчетСкидки));
	КонецЕсли;
Конецпроцедуры

&НаКлиенте
Процедура ПослеВыбораВариантаРаспределенияСуммы(Результат, ДополнительныеПараметры) Экспорт

	РаспределятьКакСкидку = Ложь;
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("КорректировкаСуммыЗаСчетРучнойСкидки") Тогда
			РаспределятьКакСкидку = Результат.КорректировкаСуммыЗаСчетРучнойСкидки;
		КонецЕсли;
		Если Результат.Свойство("ЗапрашиватьВариантКорректировкиСуммы") Тогда
			ЗапрашиватьРаспределение = Результат.ЗапрашиватьВариантКорректировкиСуммы;
			Если Не ЗапрашиватьРаспределение Тогда
				КорректировкаСуммыЗаСчетРучнойСкидки = РаспределятьКакСкидку;
			КонецЕсли;				
		КонецЕсли;
	КонецЕсли;
	ПродолжитьОбработкуТаблицы(РаспределятьКакСкидку);
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьОбработкуТаблицы(РаспределятьКакСкидку = Неопределено)

	ОбработатьТаблицуНаСервере();
	
	ИзменяемыеСтроки = Объект.Запасы.НайтиСтроки(Новый Структура("Пометка", Истина));
	Для каждого Строка Из ИзменяемыеСтроки Цикл
		
		Если ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ИзменитьЦеныНаПроцент")
			ИЛИ ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ОкруглитьЦены")
			ИЛИ ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьПроцентСкидкиНаценки")
			ИЛИ ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьЦеныПоВиду")
			ИЛИ ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ДобавитьИзДокумента") Тогда
			
			РассчитатьСуммуВСтрокеТабличнойЧасти(Строка);
			
		ИначеЕсли ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьСкидкуСуммой") Тогда
			
			ТабличныеЧастиУНФКлиент.РассчитатьСуммуНДСИВсего(Строка, Новый Структура("СуммаВключаетНДС",Объект.СуммаВключаетНДС));
			
			// Ручные скидки
			СкидкиНаценкиКлиентСервер.РассчитатьСуммуИПроцентСкидки(ЭтотОбъект, "Запасы");
			// Конец Ручные скидки
			
			// АвтоматическиеСкидки.
			СброситьФлагСкидкиРассчитаныКлиент("РассчитатьСуммуВСтрокеТабличнойЧасти");
			
			//Строка.ПроцентАвтоматическойСкидки = 0;
			//Строка.СуммаАвтоматическойСкидки = 0;
			// Конец АвтоматическиеСкидки		
			
		ИначеЕсли ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ОкруглитьСуммы") Тогда
			
			// Цена.
			НоваяСуммаДоСкидок = Строка.Сумма + Строка.СуммаСкидкиНаценки + Строка.СуммаАвтоматическойСкидки;
			ПараметрыПересчетаСуммы = Новый Структура();
			ЗаСчетСкидки = ?(РаспределятьКакСкидку = Неопределено, КорректировкаСуммыЗаСчетРучнойСкидки, РаспределятьКакСкидку);
			Если ЗаСчетСкидки Тогда
				СтараяСуммаДоСкидок = Строка.Цена * Строка.Количество;
				КорректировкаРучнойСкидки = НоваяСуммаДоСкидок - СтараяСуммаДоСкидок;
				Строка.СуммаСкидкиНаценки = Строка.СуммаСкидкиНаценки + КорректировкаРучнойСкидки;
				ПараметрыПересчетаСуммы.Вставить("РассчитатьЦену", Ложь);
				ПараметрыПересчетаСуммы.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", Истина);
			ИначеЕсли Строка.Количество <> 0 Тогда
				ПараметрыПересчетаСуммы.Вставить("РассчитатьЦену", Истина);
				ПараметрыПересчетаСуммы.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", Ложь);
			КонецЕсли;			
			РассчитатьСуммуВСтрокеТабличнойЧасти(Строка, ПараметрыПересчетаСуммы);
			
			// Платежный календарь.
			ПересчитатьПлатежныйКалендарь();

			// АвтоматическиеСкидки.
			СброситьФлагСкидкиРассчитаныКлиент("РассчитатьСуммуВСтрокеТабличнойЧасти", "Сумма");
			// Конец АвтоматическиеСкидки
			
		ИначеЕсли ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьСтавкуНДС") Тогда
			
			ТабличныеЧастиУНФКлиент.РассчитатьСуммуНДСИВсего(Строка, Новый Структура("СуммаВключаетНДС",Объект.СуммаВключаетНДС));
			
		ИначеЕсли ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.РаспределитьСуммуПоКоличеству")
			ИЛИ ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.РаспределитьСуммуПоСуммам") Тогда
			
			ПараметрыПересчетаСуммы = Новый Структура();
			НоваяСуммаДоСкидок = Строка.Сумма + Строка.СуммаСкидкиНаценки + Строка.СуммаАвтоматическойСкидки;
			Если ЗапасыИзменениеСтрокЗначение <> Неопределено
				И Число(ЗапасыИзменениеСтрокЗначение ) < 0 Тогда
				// Постобработка не требуется, для скидки запускался алгоритм, 
				// который анализирует минимальные цены, скидки и согласованно изменяет сумму с остальными данными строки 
				ПараметрыПересчетаСуммы.Вставить("РассчитатьСуммуСкидки", Истина);
			ИначеЕсли РаспределятьКакСкидку Тогда
				СтараяСуммаДоСкидок = Строка.Цена * Строка.Количество;
				КорректировкаРучнойСкидки = СтараяСуммаДоСкидок - НоваяСуммаДоСкидок;
				Строка.СуммаСкидкиНаценки = Макс(Строка.СуммаСкидкиНаценки + КорректировкаРучнойСкидки, 0);
				ПараметрыПересчетаСуммы.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", Истина);
				ПараметрыПересчетаСуммы.Вставить("РассчитатьЦену", Ложь);
			ИначеЕсли Строка.Количество <> 0 Тогда
				//Строка.Цена = НоваяСуммаДоСкидок / Строка.Количество;
				ПараметрыПересчетаСуммы.Вставить("РассчитатьЦену", Истина);
				ПараметрыПересчетаСуммы.Вставить("КорректировкаСуммыЗаСчетРучнойСкидки", Ложь);
			КонецЕсли;
			РассчитатьСуммуВСтрокеТабличнойЧасти(Строка, ПараметрыПересчетаСуммы);			
			
			// АвтоматическиеСкидки.
			СброситьФлагСкидкиРассчитаныКлиент("РассчитатьСуммуВСтрокеТабличнойЧасти");
			// Конец АвтоматическиеСкидки
			
		ИначеЕсли ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьЗаказПокупателя") Тогда
			
			// АвтоматическиеСкидки
			Если СброситьФлагСкидкиРассчитаныКлиент("ЗапасыЗаказПокупателяПриИзменении") Тогда
				РассчитатьСуммуВСтрокеТабличнойЧасти(Строка, Новый Структура("СброситьФлагСкидкиРассчитаны", Ложь));
			КонецЕсли;
			// Конец АвтоматическиеСкидки
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьПроцентСкидкиНаценки")
		ИЛИ ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьСкидкуСуммой") Тогда
		
		ГрупповоеИзменениеСтрокКлиент.ОчиститьДействиеЗначение(ЗапасыИзменениеСтрокДействие, ЗапасыИзменениеСтрокЗначение);
	КонецЕсли;
	
	ОбновитьПодвалФормы();
	ПересчитатьПлатежныйКалендарь();
	
