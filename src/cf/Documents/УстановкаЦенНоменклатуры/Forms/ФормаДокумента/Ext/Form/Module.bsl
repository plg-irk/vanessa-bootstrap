#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОстаткиИРезервы(Команда) 
	
	РежимОстаткиИРезервы = Не РежимОстаткиИРезервы;
	Элементы.ОстаткиИРезервы.Пометка = Не Элементы.ОстаткиИРезервы.Пометка;
		
	ОбновитьОтображениеКолонокВРазрезеЗапасов();
		
	Если РежимОстаткиИРезервы Тогда			
		ВыполнитьСценарийЗаполненияЗначенияОстатковТЧНоменклатура();		
	КонецЕсли;   
	
КонецПроцедуры 

&НаКлиенте
Процедура ПечатнаяФормаУстановкаЦен(Команда)
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Печать возможна только для записанного документа'"));
		Возврат;
	КонецЕсли;
	
	ТабличныйДокумент = ПечатнаяФормаУстановкаЦенНаСервере();
	ТабличныйДокумент.ОтображатьСетку 		= Ложь; 
	ТабличныйДокумент.ОтображатьГруппировки = Истина;
	ТабличныйДокумент.ОтображатьЗаголовки 	= Ложь;
	ТабличныйДокумент.Показать();
	
КонецПроцедуры

&НаКлиенте
Процедура ВывестиСписок(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ИменаКолонокПоУмолчанию", ПолучитьЗначенияИменВсехКолонок());
	
	ОповещениеПриЗавершениеВыбораКолонок = Новый ОписаниеОповещения("ОбработчикОповещенияВыбратьКолонкиЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Документ.УстановкаЦенНоменклатуры.Форма.ФормаВыборКолонок", ПараметрыОткрытия, ЭтотОбъект, , , ,
		ОповещениеПриЗавершениеВыбораКолонок, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЦенуХарактеристик(Команда) 
	
	ИдентификаторыЦен = Новый Структура;
	Если Элементы.ТЧНоменклатура.ВыделенныеСтроки.Количество() > 0 Тогда 
		
		ВыбранныеСтроки = Элементы.ТЧНоменклатура.ВыделенныеСтроки;
		ЭлементКоллекции = ТЧНоменклатура.НайтиПоИдентификатору(ВыбранныеСтроки[0]); 
		
		Для Каждого ТекИдентификатор Из КэшЗначений.ЗначенияИдентификаторовВидовЦен Цикл
			ИмяКолонкиЦенаНовая = "ТЧНоменклатура" + ТекИдентификатор.Значение + "_ЦенаНовая";
			Если ЭлементКоллекции[ИмяКолонкиЦенаНовая] > 0 Тогда 
				ИдентификаторыЦен.Вставить(ТекИдентификатор.Значение, ЭлементКоллекции[ИмяКолонкиЦенаНовая]);
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("КэшЗначений"		, КэшЗначений);
	ПараметрыОткрытия.Вставить("ВидРасчета"		, "УстановитьЦену");
	ПараметрыОткрытия.Вставить("ДатаДокумента"	, Объект.Дата);  
	
	Если ИдентификаторыЦен.Количество() > 0 Тогда
		ПараметрыОткрытия.Вставить("ИдентификаторыЦен", ИдентификаторыЦен) ; 
	КонецЕсли;

	Если ТипЗнч(ТекущийЭлемент) = Тип("ТаблицаФормы") И ТипЗнч(Элементы[ТекущийЭлемент.Имя].ТекущийЭлемент) = Тип(
		"ПолеФормы") Тогда

		ПараметрыОткрытия.Вставить("ТекущаяКолонка", Элементы[ТекущийЭлемент.Имя].ТекущийЭлемент.Имя);

	КонецЕсли;
	
	ПараметрыОповещения = СтруктураОбязательныхПараметровОбработкиХарактеристик("ТЧХарактеристики");
		
	ОбработкаОписание = Новый ОписаниеОповещения("РассчитатьНовыеЦеныПоУказаннымУсловиям", ЭтотОбъект, ПараметрыОповещения); 
	
	ОткрытьФорму("Документ.УстановкаЦенНоменклатуры.Форма.ФормаИзмененияЦен", ПараметрыОткрытия, ЭтотОбъект, , , ,
		ОбработкаОписание); 
		
	Модифицированность = Истина;

КонецПроцедуры


// ОбработчикиСортировки
&НаКлиенте
Процедура СортироватьПоВозрастанию(Команда)
	
	Если Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Номенклатура Тогда
		ТЧНоменклатура.Сортировать("Номенклатура Возр");
	ИначеЕсли Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Характеристики Тогда
		ТЧХарактеристики.Сортировать("Характеристика Возр");
	КонецЕсли;
	Модифицированность = Истина;
	
КонецПроцедуры

