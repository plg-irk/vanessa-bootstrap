&НаКлиентеНаСервереБезКонтекста
Функция СтруктураОбязательныхПараметровОбработкиХарактеристик(ИмяТаблицаИсточник)
	
	ПараметрыОповещения = Новый Структура;  
	ПараметрыОповещения.Вставить("ОбластьПримененияПоУмолчанию"		, 0);
	ПараметрыОповещения.Вставить("ИмяТаблицаИсточник"					, ИмяТаблицаИсточник); 
