&НаСервере
Функция ПараметрыПолученияЦен(ИдентификаторВидаЦен) 
	
	СтруктураДанных = Новый Структура;  
	СтруктураДанных.Вставить("ВалютаДокумента"		, Неопределено);
	СтруктураДанных.Вставить("Номенклатура"			, Неопределено);
	СтруктураДанных.Вставить("ЕдиницаИзмерения"		, Неопределено); 	
	СтруктураДанных.Вставить("Характеристика"		, Неопределено);
	СтруктураДанных.Вставить("ВидЦен"				, Неопределено);
	СтруктураДанных.Вставить("ДатаОбработки"			, Объект.Дата);
	СтруктураДанных.Вставить("Коэффициент"			, 1); 
	СтруктураДанных.Вставить("ЭтоНовыйОбъект"		, Параметры.Ключ.Пустая()); 
	СтруктураДанных.Вставить("ИдентификаторВидаЦен"	, ИдентификаторВидаЦен);
	СтруктураДанных.Вставить("ДокументУстановкаЦен"	, Параметры.Ключ);
	
	Возврат СтруктураДанных;
	
КонецФункции

&НаСервере
Процедура ОбработатьМассивСтрок_ОтразитьЦеныВВыбраннойУпаковке(Знач МассивСтрок, Знач ИдентификаторВидаЦен, Знач ПересчетНовойЦены) 
	
	ИмяТабличнойЧасти = "ТЧНоменклатура";
	ШаблонПараметров = "%1%2";
	
	Идентификатор = СтрШаблон(ШаблонПараметров, ИмяТабличнойЧасти, ИдентификаторВидаЦен);
	
	ИмяКолонки_ЦенаДо 			= СтрШаблон(ШаблонПараметров, Идентификатор, "_ЦенаДо");
	ИмяКолонки_ЦенаНовая 			= СтрШаблон(ШаблонПараметров, Идентификатор, "_ЦенаНовая");
	ИмяКолонки_ВалютаНовая 		= СтрШаблон(ШаблонПараметров, Идентификатор, "_ВалютаНовая");
	ИмяКолонки_ЕдиницаИзмерения 	= СтрШаблон(ШаблонПараметров, Идентификатор, "_ЕдИзм");
	
	ДополнительныеПараметры = ПараметрыПолученияЦен(ИдентификаторВидаЦен);
	
	Для Каждого ИдентификаторТекущейСтроки Из МассивСтрок Цикл
				
		ДанныеТекущейСтроки = ЭтотОбъект[ИмяТабличнойЧасти].НайтиПоИдентификатору(ИдентификаторТекущейСтроки); 
		
		Если ДанныеТекущейСтроки <> Неопределено Тогда
			
			// заполним недостающие параметры
			ДополнительныеПараметры.ВалютаДокумента 	= ДанныеТекущейСтроки[ИмяКолонки_ВалютаНовая];
			ДополнительныеПараметры.Номенклатура 		= ДанныеТекущейСтроки["Номенклатура"]; 
			ДополнительныеПараметры.ЕдиницаИзмерения 	= ДанныеТекущейСтроки[ИмяКолонки_ЕдиницаИзмерения]; 
			
			Если НЕ ЗначениеЗаполнено(ДополнительныеПараметры.Номенклатура) Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеТекущейСтроки[ИмяКолонки_ЦенаДо] = ЦенообразованиеСервер.ПолучитьЦенуНоменклатурыПоВидуЦен(
				ДополнительныеПараметры);
			
			Если ПересчетНовойЦены Тогда
				ДанныеТекущейСтроки[ИмяКолонки_ЦенаНовая] = ДанныеТекущейСтроки[ИмяКолонки_ЦенаДо]; 
			КонецЕсли;     
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтразитьЦены(МассивИдентификаторовСтрок, ИдентификаторВидаЦен, ИдентификаторТаблицыТЧНоменклатура, ПересчетНовойЦены) 
	
	// заполним цены согласно упаковкам
	ОбработатьМассивСтрок_ОтразитьЦеныВВыбраннойУпаковке(МассивИдентификаторовСтрок, 
		ИдентификаторВидаЦен, ПересчетНовойЦены); 
			
	// пересчет цен
	Если МассивИдентификаторовСтрок.Количество() > 0 Тогда
		ЗаполнитьЕдиницыИзмеренияИПересчитатьЦеныХарактеристикНоменклатурыПоМассивуСтрок(МассивИдентификаторовСтрок); 	
	КонецЕсли;

	// обработка дополнительных показателей
	Для Каждого СтрокаКоллекции ИЗ ТЧНоменклатура Цикл
				
		ПересчитатьПроцентИзменения(СтрокаКоллекции, ИдентификаторТаблицыТЧНоменклатура); 
		
		ОтразитьИзменениеНовойЦены(СтрокаКоллекции, ИдентификаторВидаЦен, "ТЧНоменклатура"); 
		
	КонецЦикла; 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЕдиницыИзмеренияИЦены()  
		
	Для Каждого ЭлементСоответствия Из КэшЗначений.ЗначенияИдентификаторовВидовЦен Цикл 
		
		ИдентификаторТаблицыТЧНоменклатура 	= СтрШаблон("%1%2", "ТЧНоменклатура", ЭлементСоответствия.Значение); 
		ИдентификаторВидаЦен 				= ЭлементСоответствия.Значение;
		
		ИдентификаторыТЧНоменклатура = Новый Массив;
		
		Для Каждого СтрокаКоллекции Из ТЧНоменклатура Цикл
			
			ИдентификаторыТЧНоменклатура.Добавить(СтрокаКоллекции.ПолучитьИдентификатор());
						
		КонецЦикла;   
		
		// перед заполнением цен соберем идентификаторы строк в массив
		Если ИдентификаторыТЧНоменклатура.Количество() > 0 Тогда
			ОтразитьЦены(ИдентификаторыТЧНоменклатура, ИдентификаторВидаЦен, ИдентификаторТаблицыТЧНоменклатура, Ложь);
		КонецЕсли;
		
		Если Объект.ПоказыватьХарактеристики Тогда
			
			ИмяТабличнойЧасти = "ТЧХарактеристики";
			ИдентификаторыТЧХарактеристики = Новый Массив;
			
			ИдентификаторТаблицыТЧХарактеристики = СтрШаблон("%1%2", ИмяТабличнойЧасти, ЭлементСоответствия.Значение);
			Для Каждого СтрокаКоллекции Из ТЧХарактеристики Цикл
								
				ИдентификаторыТЧХарактеристики.Добавить(СтрокаКоллекции.ПолучитьИдентификатор()); 
				
				// пересчет дельты
				Если СтрокаКоллекции.Свойство(ИмяТабличнойЧасти + ИдентификаторВидаЦен + "_Дельта") 
					И СтрокаКоллекции.Свойство(ИмяТабличнойЧасти + ИдентификаторВидаЦен + "_ЦенаНовая") 
					И СтрокаКоллекции.Свойство(ИмяТабличнойЧасти + ИдентификаторВидаЦен + "_ЦенаДо") Тогда			
					ПересчитатьДельтуВПолеНаКлиенте(СтрокаКоллекции, ИмяТабличнойЧасти + ИдентификаторВидаЦен);					
				КонецЕсли;

			КонецЦикла; 
			
			// Пересчет зависимых цен
			Если ИдентификаторыТЧХарактеристики.Количество() > 0 Тогда 
				ОбработатьМассивЗависимыхСтрок(ИдентификаторыТЧХарактеристики, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
			КонецЕсли;
			
			// пересчет % изменения
			Для Каждого СтрокаКоллекции Из ТЧХарактеристики Цикл
				
				ПересчитатьПроцентИзменения(СтрокаКоллекции, ИдентификаторТаблицыТЧХарактеристики);
								
			КонецЦикла; 
			
		КонецЕсли;
		
	КонецЦикла;  
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьПроцентИзменения(ДанныеТекущейСтроки, Идентификатор)
	
	ИмяПоляПроцентИзменения 	= Идентификатор + "_ПроцентИзменения";
	ИмяПоляЦенаНовая 			= Идентификатор + "_ЦенаНовая"; 
	ИмяПоляЦенаДо 			= Идентификатор + "_ЦенаДо";   
	ИмяПоляВалютаДо 			= Идентификатор + "_ВалютаДо";
	ИмяПоляВалютаНовая 		= Идентификатор + "_ВалютаНовая"; 
	
	// значения 
	Цена_До 					= ДанныеТекущейСтроки[ИмяПоляЦенаДо]; 
	Цена_Новая 				= ДанныеТекущейСтроки[ИмяПоляЦенаНовая];
	Валюта_До 				= ДанныеТекущейСтроки[ИмяПоляВалютаДо];
	Валюта_Новая 				= ДанныеТекущейСтроки[ИмяПоляВалютаНовая];
	
	Если Валюта_До <> Валюта_Новая Тогда
		
		ЦенаДоВНовойВалюте = ПересчитатьЦенуИзВалютыВВалюту(Цена_До, Валюта_До, Валюта_Новая, КэшЗначений.КурсыВалютДокумента); 
			
		Если ЦенаДоВНовойВалюте > 0 Тогда 
			
			ИзменениеЦены = Цена_Новая - ЦенаДоВНовойВалюте;
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = ИзменениеЦены / ЦенаДоВНовойВалюте * 100;			
		Иначе
					
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = 0;			
		КонецЕсли; 

	Иначе
		
		Если Цена_До > 0 Тогда 
			
			ИзменениеЦены = Цена_Новая - Цена_До;
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = ИзменениеЦены / Цена_До * 100;			
		Иначе
					
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = 0;			
		КонецЕсли;     
		
	КонецЕсли;

КонецПроцедуры 

&НаКлиенте
Процедура ПересчитатьПроцентНаценки(ДанныеТекущейСтроки, Идентификатор, ИмяТабличнойЧасти)
	
	ИдентификаторВидЦен = СтрЗаменить(Идентификатор, ИмяТабличнойЧасти, "");
	ИдентификаторБазовыйВидЦен = КэшЗначений.ЗначенияЗависимыхИдентификаторов.Получить(ИдентификаторВидЦен);
		
	Если ПустаяСтрока(ИдентификаторБазовыйВидЦен) Тогда 
		Возврат;
	КонецЕсли;
	
	ИмяПоляЦенаНоваяБазовыйВидЦен 		= ИмяТабличнойЧасти + ИдентификаторБазовыйВидЦен + "_ЦенаНовая";
	ИмяПоляЦенаНоваяТекущийВидЦен 		= Идентификатор + "_ЦенаНовая";
	ИмяПоляПроцентНаценкиТекущийВидЦен 	= Идентификатор + "_ПроцентНаценки";
	
	Если ДанныеТекущейСтроки[ИмяПоляЦенаНоваяТекущийВидЦен] > 0
		И ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен] > 0 Тогда 
			
		ДанныеТекущейСтроки[ИмяПоляПроцентНаценкиТекущийВидЦен] = Окр((ДанныеТекущейСтроки[ИмяПоляЦенаНоваяТекущийВидЦен] 
			/ ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен] - 1) * 100, 1);			
	Иначе
				
		ДанныеТекущейСтроки[ИмяПоляПроцентНаценкиТекущийВидЦен] = 0;			
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ПересчитатьЦенуПоПроцентуНаценки(ДанныеТекущейСтроки, Идентификатор, ИмяТабличнойЧасти)
	  
	ИдентификаторВидаЦен = СтрЗаменить(Идентификатор, ИмяТабличнойЧасти, ""); 
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторВидаЦен) Тогда   
		Возврат;
	КонецЕсли;
	
	ИдентификаторБазовыйВидЦен = КэшЗначений.ЗначенияЗависимыхИдентификаторов.Получить(ИдентификаторВидаЦен);
	
	ИмяПоляЦенаНоваяТекущийВидЦен = Идентификатор + "_ЦенаНовая";
	ИмяПоляПроцентНаценкиТекущийВидЦен = Идентификатор + "_ПроцентНаценки";
	
	Если ПустаяСтрока(ИдентификаторБазовыйВидЦен) Тогда 
		Возврат;
	КонецЕсли;
	
	ИмяПоляЦенаНоваяБазовыйВидЦен = ИмяТабличнойЧасти + ИдентификаторБазовыйВидЦен + "_ЦенаНовая";
	
	РасчетнаяЦена = ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен] 
		+ (ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен] * ДанныеТекущейСтроки[ИмяПоляПроцентНаценкиТекущийВидЦен]
			/ 100);   
				
	ДанныеВидаЦен = ПолучитьДанныеВидаЦенПоИдентификатору(ИдентификаторВидаЦен);	
	РезультатОкругления = ЦенообразованиеКлиентСервер.ОкруглитьЦену(РасчетнаяЦена, 
		ДанныеВидаЦен.ПорядокОкругления, ДанныеВидаЦен.ОкруглятьВБольшуюСторону);
	
	ДанныеТекущейСтроки[ИмяПоляЦенаНоваяТекущийВидЦен] = РезультатОкругления;  
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьЦену_ПроцентИзмененияПриИзменении(ДанныеТекущейСтроки, Идентификатор, ИмяТабличнойЧасти)
	
	ИмяПоляЦенаДо = Идентификатор + "_ЦенаДо";
	ИмяПоляЦенаНовая = Идентификатор + "_ЦенаНовая";
	ИмяПоляЦенуИзменили = Идентификатор + "_ЦенуИзменили";
	ИмяПоляПроцентИзменения = Идентификатор + "_ПроцентИзменения";

	Если ДанныеТекущейСтроки[ИмяПоляЦенаДо] > 0 Тогда 
		
		ДанныеТекущейСтроки[ИмяПоляЦенуИзменили] = Истина;  
		
		ДанныеТекущейСтроки[ИмяПоляЦенаНовая] = ДанныеТекущейСтроки[ИмяПоляЦенаДо] 
			+ (ДанныеТекущейСтроки[ИмяПоляЦенаДо] / 100 
				* ДанныеТекущейСтроки[ИмяПоляПроцентИзменения]); 
	Иначе
			
		ДанныеТекущейСтроки[ИмяПоляЦенаНовая] = 0;
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти

// Конец ПересчетДополнителныхПоказателей

&НаКлиенте
Процедура ПроверитьЕдиницыИзмеренияВТЧХарактеристики(ИдентификаторВидаЦен)
		
	ОшибкаЗаполнения = Ложь; 
	ПредставлениеКолонки = "_ЕдИзм"; 
	
	ИмяКолонки_ЕдИзм = СтрШаблон("%1%2", ИдентификаторВидаЦен, ПредставлениеКолонки);
	
	ТекущийТипДанных = ТипЗнч(ТЧХарактеристики[0][ИмяКолонки_ЕдИзм]);
	Для Каждого СтрокаТЧ Из ТЧХарактеристики Цикл  
		
		НовыйТипДанных = ТипЗнч(СтрокаТЧ[ИмяКолонки_ЕдИзм]);

		Если НовыйТипДанных <> ТекущийТипДанных Тогда 
			
			ОшибкаЗаполнения = Истина;
			Прервать; 
			
		КонецЕсли;
			
	КонецЦикла;
	
	Если ОшибкаЗаполнения Тогда 
		
		ТекущиеДанныеТЧНоменклатура = Элементы.ТЧНоменклатура.ТекущиеДанные; 
		
		Если ТекущиеДанныеТЧНоменклатура <> Неопределено Тогда 
			
			ИмяКолонки_ЕдИзмНоменклатура = СтрШаблон("%1%2", СтрЗаменить(ИдентификаторВидаЦен, 
				"ТЧХарактеристики", "ТЧНоменклатура"), ПредставлениеКолонки);
			
			ЕдиницаИзмеренияНоменклатуры = ТекущиеДанныеТЧНоменклатура[ИмяКолонки_ЕдИзмНоменклатура];
			КлючСвязи = ТекущиеДанныеТЧНоменклатура["КлючСвязи"];
			
			ИдентификаторВидаЦен = СтрЗаменить(СтрЗаменить(ИдентификаторВидаЦен, "ТЧХарактеристики", ""), ПредставлениеКолонки, "");
			ОтразитьЕдиницуИзмеренийВХарактеристиках(ИдентификаторВидаЦен, ЕдиницаИзмеренияНоменклатуры, КлючСвязи);
	        	
			ТекстСообщения = НСтр("ru='Единицы измерения могут быть изменены в таблице товаров и услуг.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЕдиницыИзмеренияИПересчитатьЦеныНоменклатуры(ТаблицаНоменклатуры, ПерезаполнятьЕдиницыИзмерения)  
	
	МассивНоменклатуры = ТаблицаНоменклатуры.ВыгрузитьКолонку("Номенклатура");
	МассивВидовЦен = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ТекущиеВидыЦен.ВыгрузитьЗначения());	 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
		|	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			,
		|			ВидЦен В (&МассивВидовЦен)
		|				И Номенклатура В (&МассивТоваров)
		|				И Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК ЦеныНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("МассивВидовЦен", МассивВидовЦен);
	Запрос.УстановитьПараметр("МассивТоваров", МассивНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		
		ТаблицаПоследнихЦенПоВидамЦен = РезультатЗапроса.Выгрузить();	
		
		ПараметрыПоиска = Новый Структура;
		
		Для Каждого ЭлементСоответствия Из КэшЗначений.ЗначенияИдентификаторовВидовЦен Цикл 
			
			ИдентификаторФормул = ЭлементСоответствия.Значение;
			ВидЦены 			= ЭлементСоответствия.Ключ;
			
			ИмяКолонкиНоменклатура_ЕдИзм 	= СтрШаблон("%1%2%3", "ТЧНоменклатура", ИдентификаторФормул, "_ЕдИзм");
			ИмяКолонкиНоменклатура_ЦенаДо	= СтрШаблон("%1%2%3", "ТЧНоменклатура", ИдентификаторФормул, "_ЦенаДо"); 
			ИмяКолонкиНоменклатура_ЦенаНовая = СтрШаблон("%1%2%3", "ТЧНоменклатура", ИдентификаторФормул, "_ЦенаНовая");  
			
			Для Каждого СтрокаКоллекции Из ТЧНоменклатура Цикл  
				
				ПараметрыПоиска.Вставить("Номенклатура"	, СтрокаКоллекции.Номенклатура); 
				ПараметрыПоиска.Вставить("ВидЦен", ВидЦены); 
				
				НайденныеСтроки = ТаблицаПоследнихЦенПоВидамЦен.НайтиСтроки(ПараметрыПоиска);
				Для Каждого СтрокаТаблицыРегистра Из НайденныеСтроки Цикл 
					
					ЕдиницаДокумента = СтрокаКоллекции[ИмяКолонкиНоменклатура_ЕдИзм];
					
					Если НЕ ЗначениеЗаполнено(ЕдиницаДокумента)
						ИЛИ НЕ ЗначениеЗаполнено(СтрокаТаблицыРегистра.ЕдиницаИзмерения) Тогда
						Продолжить;
					КонецЕсли;

					Если СтрокаТаблицыРегистра.ЕдиницаИзмерения <> ЕдиницаДокумента Тогда
																		
						УпаковкаВРегистреЦен = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(
							СтрокаТаблицыРегистра.ЕдиницаИзмерения, "Коэффициент"); 
							
						УпаковкаВДокументе = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(
							ЕдиницаДокумента, "Коэффициент");
			
						Если УпаковкаВРегистреЦен Тогда
								
							КоэффициентЕдиницыВРегистре = ?(ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(
								СтрокаТаблицыРегистра.ЕдиницаИзмерения, "Коэффициент"), 
								СтрокаТаблицыРегистра.ЕдиницаИзмерения.Коэффициент, 1);

							СтрокаКоллекции[ИмяКолонкиНоменклатура_ЦенаДо] = Окр(СтрокаТаблицыРегистра.Цена 
								/ ?(КоэффициентЕдиницыВРегистре = 0, 1, КоэффициентЕдиницыВРегистре), 2);
						КонецЕсли; 
						
						Если УпаковкаВДокументе Тогда  
							
							КоэффициентЕдиницыВРегистре = ?(ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(
								СтрокаТаблицыРегистра.ЕдиницаИзмерения, "Коэффициент"), 
								СтрокаТаблицыРегистра.ЕдиницаИзмерения.Коэффициент, 1);

							СтрокаКоллекции[ИмяКолонкиНоменклатура_ЦенаДо] = Окр(СтрокаТаблицыРегистра.Цена 
								* ?(ЕдиницаДокумента.Коэффициент = 0, 1, КоэффициентЕдиницыВРегистре), 2); 
								
						КонецЕсли;
												
					КонецЕсли;   
					
					Если СтрокаТаблицыРегистра.ВидЦен = ВидЦены 
						И НЕ ЗначениеЗаполнено(СтрокаКоллекции[ИмяКолонкиНоменклатура_ЦенаНовая]) Тогда
						
						СтрокаКоллекции[ИмяКолонкиНоменклатура_ЦенаНовая] = СтрокаТаблицыРегистра.Цена;
						
						УстановитьЗначенияЗависимыхЦенПоСтроке(СтрокаКоллекции.ПолучитьИдентификатор(), 
							ИдентификаторФормул, "ТЧНоменклатура");
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЦикла;

		КонецЦикла;
	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЕдиницыИзмеренияИПересчитатьЦеныХарактеристикНоменклатурыПоМассивуСтрок(МассивИдентификаторовСтрок)  
		
	Для Каждого ИдентификаторТекущейСтроки Из МассивИдентификаторовСтрок Цикл 
		
		ДанныеТекущейСтроки = ЭтотОбъект["ТЧНоменклатура"].НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
		Номенклатура = ДанныеТекущейСтроки.Номенклатура;
		
		ЗаполнитьЕдиницыИзмеренияИПересчитатьЦеныХарактеристикНоменклатуры(Номенклатура, Истина);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЕдиницыИзмеренияИПересчитатьЦеныХарактеристикНоменклатуры(Знач Номенклатура, Знач ПерезаполнятьЕдиницыИзмерения)  
		
	ПараметрыПоиск = Новый Структура("Номенклатура", Номенклатура);   
	
	СтрокНоменклатуры 	= ТЧНоменклатура.НайтиСтроки(ПараметрыПоиск); 
	СтрокиХарактеристик = ТЧХарактеристики.НайтиСтроки(ПараметрыПоиск); 
	ИмяТЧНоменклатура 	= "ТЧНоменклатура";
	ИмяТЧХарактеристики = "ТЧХарактеристики";
	ШаблонСтроки 		= "%1%2%3";  
	
	Для Каждого ЭлементСоответствия Из КэшЗначений.ЗначенияИдентификаторовВидовЦен Цикл 
		
		ИдентификаторФормул = ЭлементСоответствия.Значение;
		ВидЦены = ЭлементСоответствия.Ключ;
			
		ИмяКолонкиНоменклатура_ЕдИзм 		= СтрШаблон(ШаблонСтроки, ИмяТЧНоменклатура,   ИдентификаторФормул, "_ЕдИзм");
		ИмяКолонкиНоменклатура_ЦенаДо 		= СтрШаблон(ШаблонСтроки, ИмяТЧНоменклатура,   ИдентификаторФормул, "_ЦенаДо"); 	
		ИмяКолонкиХарактеристики_ЕдИзм 		= СтрШаблон(ШаблонСтроки, ИмяТЧХарактеристики, ИдентификаторФормул, "_ЕдИзм");
		ИмяКолонкиХарактеристики_ЦенаДо 	= СтрШаблон(ШаблонСтроки, ИмяТЧХарактеристики, ИдентификаторФормул, "_ЦенаДо");
		ИмяКолонкиХарактеристики_ЦенаНовая 	= СтрШаблон(ШаблонСтроки, ИмяТЧХарактеристики, ИдентификаторФормул, "_ЦенаНовая");
		
		Для Каждого ЭлементМассива Из СтрокиХарактеристик Цикл 
			
			Номенклатура_ЕдИзм = СтрокНоменклатуры[0][ИмяКолонкиНоменклатура_ЕдИзм];  	
			Характеристика_ЕдИзм_До = ЭлементМассива[ИмяКолонкиХарактеристики_ЕдИзм];
			
			// заполнить единицу измерения характеристики по номенклатуре
			Если ПерезаполнятьЕдиницыИзмерения Тогда
				
				ЭлементМассива[ИмяКолонкиХарактеристики_ЕдИзм] = Номенклатура_ЕдИзм; 
				
			КонецЕсли;  
			
			Характеристика_ЕдИзм_После = ЭлементМассива[ИмяКолонкиХарактеристики_ЕдИзм];	
			ЕдиницаИзменена = Характеристика_ЕдИзм_После <> Характеристика_ЕдИзм_До;
			
			Если ЕдиницаИзменена Тогда 
				// пересчитать цену характеристики 
				Номенклатура_ЦенаДо = СтрокНоменклатуры[0][ИмяКолонкиНоменклатура_ЦенаДо]; 
				Характеристика_ЦенаДо = ЭлементМассива[ИмяКолонкиХарактеристики_ЦенаДо];
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Характеристика_ЦенаДо) ИЛИ ЗначениеЗаполнено(Номенклатура_ЦенаДо) Тогда
				
				ЭлементМассива[ИмяКолонкиХарактеристики_ЦенаДо] = ПересчитатьЦенуПоКоэффициентуУпаковки(ВидЦены,
					Номенклатура_ЕдИзм, Характеристика_ЕдИзм_До, Характеристика_ЕдИзм_После,  
						Номенклатура_ЦенаДо, Характеристика_ЦенаДо);  
										
			КонецЕсли; 
			
			Если ЕдиницаИзменена Тогда  
				
				ЦенаХарактеристикиНовая = ЭлементМассива[ИмяКолонкиХарактеристики_ЦенаНовая]; 
				
				Если НЕ ЗначениеЗаполнено(ЦенаХарактеристикиНовая)  Тогда 
					
					ЭлементМассива[ИмяКолонкиХарактеристики_ЦенаНовая] = ЭлементМассива[ИмяКолонкиХарактеристики_ЦенаДо]; 
					
				ИначеЕсли ЗначениеЗаполнено(ЦенаХарактеристикиНовая) Тогда
					
					ЭлементМассива[ИмяКолонкиХарактеристики_ЦенаНовая] = ПересчитатьЦенуПоКоэффициентуУпаковки(ВидЦены,
						Номенклатура_ЕдИзм, Характеристика_ЕдИзм_До, Характеристика_ЕдИзм_После,  
							Номенклатура_ЦенаДо, ЦенаХарактеристикиНовая); 
						
				КонецЕсли;   
				
				УстановитьЗначенияЗависимыхЦенПоСтроке(ЭлементМассива.ПолучитьИдентификатор(), 
					ИдентификаторФормул, "ТЧХарактеристики");

			КонецЕсли;
		
		КонецЦикла; 
	КонецЦикла
	
КонецПроцедуры

&НаКлиенте
Процедура ОтразитьЦеныВВыбраннойУпаковкеТЧНоменклатура(ДанныеТекущейСтроки, ИдентификаторВидаЦен, 
		ПересчетНовойЦены = Ложь) 
		
	Идентификатор = СтрШаблон("%1%2", "ТЧНоменклатура", ИдентификаторВидаЦен);
	
	ИмяКолонки_ЦенаДо 			= СтрШаблон("%1%2", Идентификатор, "_ЦенаДо");
	ИмяКолонки_ЦенаНовая 			= СтрШаблон("%1%2", Идентификатор, "_ЦенаНовая");
	ИмяКолонки_ВалютаНовая 		= СтрШаблон("%1%2", Идентификатор, "_ВалютаНовая");
	ИмяКолонки_ЕдиницаИзмерения 	= СтрШаблон("%1%2", Идентификатор, "_ЕдИзм");
	
	СтруктураДанных = Новый Структура; 
	СтруктураДанных.Вставить("ВалютаДокумента"		, ДанныеТекущейСтроки[ИмяКолонки_ВалютаНовая]);
	СтруктураДанных.Вставить("Номенклатура"			, ДанныеТекущейСтроки["Номенклатура"]); 
	СтруктураДанных.Вставить("ЕдиницаИзмерения"		, ДанныеТекущейСтроки[ИмяКолонки_ЕдиницаИзмерения]);
	СтруктураДанных.Вставить("Характеристика"		, Неопределено);
	СтруктураДанных.Вставить("ВидЦен"				, Неопределено);
	СтруктураДанных.Вставить("ДатаОбработки"			, Объект.Дата);
	СтруктураДанных.Вставить("Коэффициент"			, 1); 
	СтруктураДанных.Вставить("ЭтоНовыйОбъект"		, Параметры.Ключ.Пустая()); 
	СтруктураДанных.Вставить("ИдентификаторВидаЦен"	, ИдентификаторВидаЦен);
	СтруктураДанных.Вставить("ДокументУстановкаЦен"	, Параметры.Ключ);
	
	ДанныеТекущейСтроки[ИмяКолонки_ЦенаДо] = ЦенообразованиеСервер.ПолучитьЦенуНоменклатурыПоВидуЦен(СтруктураДанных);
	
	Если ПересчетНовойЦены Тогда
		ДанныеТекущейСтроки[ИмяКолонки_ЦенаНовая] = ДанныеТекущейСтроки[ИмяКолонки_ЦенаДо]; 
	КонецЕсли;
	
КонецПроцедуры  

&НаСервере
Функция ПересчитатьЦенуПоКоэффициентуУпаковки(ВидЦены, ЕдиницаИзмеренияНоменклатуры, 
		ЕдиницаИзмеренияХарактеристики_До, ЕдиницаИзмеренияХарактеристики_После, 
		Номенклатура_ЦенаДо, Характеристика_ЦенаДо)
	
	Коэффициент = 1; 
	НоваяЦена = 0;
	Цена = ?(ЗначениеЗаполнено(Характеристика_ЦенаДо), Характеристика_ЦенаДо, Номенклатура_ЦенаДо); 
	УпаковкаХарактеристикиИзменена = ЕдиницаИзмеренияХарактеристики_До <> ЕдиницаИзмеренияХарактеристики_После; 
	
	ИмяТипаСправочникЕдиницыИзмерения = "СправочникСсылка.ЕдиницыИзмерения";
	ИмяТипаСправочникКлассификаторЕдиницИзмерения = "СправочникСсылка.КлассификаторЕдиницИзмерения";
	
	// в номенклатуре выбрана упаковка, а в характеристике - классификатор, пересчет из упаковок в штуки.
	Если ТипЗнч(ЕдиницаИзмеренияНоменклатуры) = Тип(ИмяТипаСправочникЕдиницыИзмерения) 
		И ТипЗнч(ЕдиницаИзмеренияХарактеристики_После) = Тип("СправочникСсылка.КлассификаторЕдиницИзмерения") Тогда
		
		Коэффициент = ?(ЕдиницаИзмеренияНоменклатуры.Коэффициент = 0, 1, 
			ЕдиницаИзмеренияНоменклатуры.Коэффициент);  
			
		НоваяЦена = Цена / Коэффициент;
		
	// в характеристике выбрана упаковка, а в номенклатуре - классификатор, пересчет из штук в упаковки.
	ИначеЕсли ТипЗнч(ЕдиницаИзмеренияХарактеристики_После) = Тип(ИмяТипаСправочникЕдиницыИзмерения)
		И ТипЗнч(ЕдиницаИзмеренияНоменклатуры) = Тип(ИмяТипаСправочникКлассификаторЕдиницИзмерения) Тогда 
		
		Коэффициент = ?(ЕдиницаИзмеренияХарактеристики_После.Коэффициент = 0, 1, 
			ЕдиницаИзмеренияХарактеристики_После.Коэффициент);
			
		НоваяЦена = Цена * Коэффициент;  
		
	// везде упаковки.
	ИначеЕсли ТипЗнч(ЕдиницаИзмеренияНоменклатуры) = Тип(ИмяТипаСправочникЕдиницыИзмерения) 
		И ТипЗнч(ЕдиницаИзмеренияХарактеристики_После) = Тип(ИмяТипаСправочникЕдиницыИзмерения) Тогда   
			
		НоваяЦена = Цена;  
		
		Если УпаковкаХарактеристикиИзменена И Характеристика_ЦенаДо <> 0 Тогда  
			
			ОбработкаСравненияЕдиницХарактеристик_ЕдиницаДо_ЕдиницаПосле(
				ЕдиницаИзмеренияХарактеристики_До, ЕдиницаИзмеренияХарактеристики_После, 
				Характеристика_ЦенаДо, НоваяЦена);  
				
		КонецЕсли;
	// везде классификатор	
	ИначеЕсли ТипЗнч(ЕдиницаИзмеренияНоменклатуры) = Тип(ИмяТипаСправочникКлассификаторЕдиницИзмерения) 
		И ТипЗнч(ЕдиницаИзмеренияХарактеристики_После) = Тип(ИмяТипаСправочникКлассификаторЕдиницИзмерения) Тогда   
		
		НоваяЦена = Номенклатура_ЦенаДо;  
		 
		ОбработкаСравненияЕдиницХарактеристик_ЕдиницаДо_ЕдиницаПосле(
			ЕдиницаИзмеренияХарактеристики_До, ЕдиницаИзмеренияХарактеристики_После, 
			Характеристика_ЦенаДо, НоваяЦена);
			
	КонецЕсли;
	
	//@skip-check bsl-legacy-check-string-literal
	ПорядокОкругления = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидЦены, "ПорядокОкругления");	// АПК:1036 проверка орфографии не требуется.
	СтандартныйПорядокОкругления = Перечисления.ПорядкиОкругления.Окр0_01;      
	
	Если ПорядокОкругления <> СтандартныйПорядокОкругления Тогда
		НоваяЦена = ЦенообразованиеСервер.ОкруглитьЦенуПоВидуЦен(НоваяЦена, ВидЦены);  
	КонецЕсли; 

	Возврат НоваяЦена;   
	
КонецФункции  

&НаСервереБезКонтекста
Процедура ОбработкаСравненияЕдиницХарактеристик_ЕдиницаДо_ЕдиницаПосле(
	ЕдиницаИзмеренияХарактеристики_До, ЕдиницаИзмеренияХарактеристики_После, 
	Характеристика_ЦенаДо, НоваяЦена);  
	
	Если ЕдиницаИзмеренияХарактеристики_До <> ЕдиницаИзмеренияХарактеристики_После Тогда 
		
		Если ТипЗнч(ЕдиницаИзмеренияХарактеристики_До) = Тип("СправочникСсылка.ЕдиницыИзмерения")
			И ТипЗнч(ЕдиницаИзмеренияХарактеристики_После) = Тип("СправочникСсылка.КлассификаторЕдиницИзмерения") Тогда 
			
			КоэффициентДо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЕдиницаИзмеренияХарактеристики_До, "Коэффициент");	
			НоваяЦена = Характеристика_ЦенаДо / ?(КоэффициентДо = 0, 1, КоэффициентДо);	
			
		ИначеЕсли ТипЗнч(ЕдиницаИзмеренияХарактеристики_После) = Тип("СправочникСсылка.ЕдиницыИзмерения")
			И ТипЗнч(ЕдиницаИзмеренияХарактеристики_До) = Тип("СправочникСсылка.КлассификаторЕдиницИзмерения") Тогда
			
			КоэффициентПосле 	= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЕдиницаИзмеренияХарактеристики_После, "Коэффициент");
			НоваяЦена = Характеристика_ЦенаДо * ?(КоэффициентПосле = 0, 1, КоэффициентПосле);
			
		КонецЕсли;  
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СортироватьПоАртикулуНаСервере(ПризнакСортировки)    
	
	ИмяКолонки 	= "Артикул";
	
	Если Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Номенклатура Тогда
		ТаблицаСортировки 	= ТЧНоменклатура.Выгрузить();
		ВладелецАртикула 	= "Номенклатура";
	ИначеЕсли Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Характеристики Тогда
        ТаблицаСортировки 	= ТЧХарактеристики.Выгрузить();
		ВладелецАртикула 	= "Характеристика";
	КонецЕсли; 
	
	ТаблицаСортировки.Колонки.Добавить(ИмяКолонки, Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(50)));
	
	Для Каждого СтрокаТаблицы Из ТаблицаСортировки Цикл
		СтрокаТаблицы[ИмяКолонки] = СтрокаТаблицы[ВладелецАртикула][ИмяКолонки];
	КонецЦикла;
	
	ТаблицаСортировки.Сортировать(ИмяКолонки + " " + ПризнакСортировки);
	ТаблицаСортировки.Колонки.Удалить(ИмяКолонки);
	
	Если Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Номенклатура Тогда
		
		ТЧНоменклатура.Очистить();
		ТЧНоменклатура.Загрузить(ТаблицаСортировки);
		
	ИначеЕсли Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Характеристики Тогда
		
		ТЧХарактеристики.Очистить();
		ТЧХарактеристики.Загрузить(ТаблицаСортировки);
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОповещенияВыбратьКолонкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено И Результат.Свойство("ВыбранныеКолонки") 
		И ЗначениеЗаполнено(Результат.ВыбранныеКолонки) Тогда
		
		// вывести список в табличный документ
		ТабличныйДокумент = ВывестиСписокНаСеврере(Результат.ВыбранныеКолонки); 
    		ТабличныйДокумент.Показать();
	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПечатнаяФормаУстановкаЦенНаСервере()
	
	МассивОбъектов = Новый Массив;  
	МассивОбъектов.Добавить(Объект.Ссылка);
	
	ОбъектыПечати = Новый СписокЗначений;
	ОбъектыПечати.ЗагрузитьЗначения(МассивОбъектов);
	
	Возврат Документы.УстановкаЦенНоменклатуры.ПечатнаяФормаУстановкаЦен(МассивОбъектов, ОбъектыПечати);
	
КонецФункции

&НаКлиенте
Функция СформироватьМассивСтрокХарактеристикПоВладельцу(СтрокаВладелец) 
	
	НайденныеСтрокиРезультат = Новый Массив;
	
	ПараметрыОтбор = Новый Структура;
	ПараметрыОтбор.Вставить("КлючСвязи", СтрокаВладелец.КлючСвязи);
	
	НайденныеСтрокиПоОтбору = ТЧХарактеристики.НайтиСтроки(ПараметрыОтбор); 
	Для Каждого ЭлементМассива Из НайденныеСтрокиПоОтбору Цикл   
		ТекИдентификатор = ЭлементМассива.ПолучитьИдентификатор();
		НайденныеСтрокиРезультат.Добавить(ТЧХарактеристики.Индекс(ТЧХарактеристики.НайтиПоИдентификатору(ТекИдентификатор)));	
	КонецЦикла;
	
	Возврат НайденныеСтрокиРезультат;
	
КонецФункции

&НаКлиенте
Процедура СкрытьОтобразитьКолонкиДополнительныхПоказателей(ИмяТабличнойЧасти)
		
	ИдентификаторыЗависимыхВидовЦен = КэшЗначений.ЗначенияЗависимыхИдентификаторов; 
	
	ИмяРеквизитаПроцентНаценки = "_ПроцентНаценки";
	
	Для Каждого ТекущийИдентификатор Из ИдентификаторыЗависимыхВидовЦен Цикл
			  	
		ПолноеИмяРеквизитаПроцентНаценки = СтрШаблон("%1%2%3", 
			ИмяТабличнойЧасти, ТекущийИдентификатор.Ключ, ИмяРеквизитаПроцентНаценки); 	

		ЭлементСуществует = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Элементы, 
			ПолноеИмяРеквизитаПроцентНаценки);	
			
		Если ЭлементСуществует Тогда  	
			Элементы[ПолноеИмяРеквизитаПроцентНаценки].Видимость = Объект.ОтображатьНаценку; 
		КонецЕсли;
		
	КонецЦикла;  
		
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтраницуТовары_ПервоеПереключениеНаОсновании()
	
	Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаТовары; 
	
	КэшЗначений.НовыеВидыЦен.Очистить();
	КэшЗначений.ПервоеПереключениеНаОсновании = Ложь;
	
	Если Объект.Запасы.Количество() = 0 Тогда                     
		
		ТекстСообщения = НСтр("ru = 'Нет данных для заполнения документа'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли;
	
КонецПроцедуры   

&НаСервере
Процедура ОбработатьЗаполнениеПоИзменившимсяЦенамПоставщика()
	
	МассивИменТабличныхЧастей = ПолучитьМассивИменТЧДляИзменения();
	
	ИзменитьСоставРеквизитовИЭлементовТабличнойЧасти(МассивИменТабличныхЧастей); 
	
	ЗаполнитьКэшЗначенийВидамиЦен(КэшЗначений);  
	
	// заполнить таблицу запасы номенклатурой с изменившейся ценой поставщика
	ЗаполнитьПоИзменившимсяЦенамПоставщика(); 

КонецПроцедуры 

&НаСервереБезКонтекста
Функция ПолучитьМассивВидовЦенДляЗаполненияПоДокументуОснования() 
	
	МассивВидовЦен = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВидыЦен.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВтВидыЦен
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	НЕ ВидыЦен.ПометкаУдаления
	|	И НЕ ВидыЦен.Недействителен
	|	И ВидыЦен.ЗаполнятьИзОснования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СвязиВидовЦенСлужебный.ВидЦенРасчетный КАК ВидЦен
	|ИЗ
	|	ВтВидыЦен КАК ВтВидыЦен
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СвязиВидовЦенСлужебный КАК СвязиВидовЦенСлужебный
	|		ПО ВтВидыЦен.Ссылка = СвязиВидовЦенСлужебный.ВидЦенБазовый
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВтВидыЦен.Ссылка
	|ИЗ
	|	ВтВидыЦен КАК ВтВидыЦен";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		МассивВидовЦен = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ВидЦен");	
	КонецЕсли;
	
	Возврат МассивВидовЦен;
	
КонецФункции


// ОбработчикиСортировкиСлужебные
&НаКлиенте
Процедура ОбработатьСортировкаПроцентИзменения(ПризнакСортировки)				  
	
	ПараметрыОповещения = Новый Структура; 
	ПараметрыОповещения.Вставить("ПризнакСортировки", ПризнакСортировки);
	
	ОбработкаОписание = Новый ОписаниеОповещения("СортироватьНоменклатуруПроцентИзменения", ЭтотОбъект, ПараметрыОповещения);   
	
	ПараметрыОткрытия = Новый Структура;  
	ПараметрыОткрытия.Вставить("ВыбранныеВидыЦен", КэшЗначений.ВыбранныеВидыЦен);

	ОткрытьФорму("Документ.УстановкаЦенНоменклатуры.Форма.ФормаСортировки", ПараметрыОткрытия, 
		ЭтотОбъект, , , , ОбработкаОписание); 
		
	Модифицированность = Истина; 	
			
КонецПроцедуры

 &НаКлиенте
Процедура СортироватьНоменклатуруПроцентИзменения(Результат, ДополнительныеПараметры) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") И Результат.ВыборПроизведен Тогда
		СортировкаПроцентИзмененияНаСервере(Результат, ДополнительныеПараметры); 
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура СортировкаПроцентИзмененияНаСервере(Результат, ДополнительныеПараметры)
	
	ПризнакСортировки 	= ?(ДополнительныеПараметры.Свойство("ПризнакСортировки"), ДополнительныеПараметры.ПризнакСортировки, "");
	ИдентификаторВидаЦен 	= ?(Результат.Свойство("ИдентификаторВидаЦен"), Результат.ИдентификаторВидаЦен, ""); 
	
	Если НЕ ЗначениеЗаполнено(ПризнакСортировки) Тогда
		Возврат;
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторВидаЦен) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКолонки 	= "ПроцентИзменения"; 
	
	Если Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Номенклатура Тогда
		ТаблицаСортировки = ТЧНоменклатура.Выгрузить();  
		ИмяТаблицы = "ТЧНоменклатура";
	ИначеЕсли Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Характеристики Тогда
        ТаблицаСортировки = ТЧХарактеристики.Выгрузить();
		ИмяТаблицы = "ТЧХарактеристики";
	КонецЕсли; 
	
	ТаблицаСортировки.Колонки.Добавить(ИмяКолонки, Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(50))); 
	
	Для Каждого СтрокаТаблицы Из ТаблицаСортировки Цикл 
		СтрокаТаблицы[ИмяКолонки] = СтрокаТаблицы[ИмяТаблицы + ИдентификаторВидаЦен + "_" + ИмяКолонки];  
	КонецЦикла;
	
	ТаблицаСортировки.Сортировать(ИмяКолонки + " " + ПризнакСортировки);
	ТаблицаСортировки.Колонки.Удалить(ИмяКолонки);
	
	Если Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Номенклатура Тогда
		
		ТЧНоменклатура.Очистить();
		ТЧНоменклатура.Загрузить(ТаблицаСортировки); 
		
	ИначеЕсли Элементы.СтраницыПредварительныйРезультат.ТекущаяСтраница = Элементы.СтраницаПР_Характеристики Тогда 
		
		ТЧХарактеристики.Очистить();
		ТЧХарактеристики.Загрузить(ТаблицаСортировки); 
		
	КонецЕсли; 

КонецПроцедуры  

// Конец ОбработчикиСортировкиСлужебные

&НаСервереБезКонтекста
Функция ПолучитьДанныеВидаЦенПоИдентификатору(ИдентификаторВидаЦен) 
	
	ДанныеВидаЦен = Новый Структура; 
	ДанныеВидаЦен.Вставить("ПорядокОкругления"		, Перечисления.ПорядкиОкругления.ПустаяСсылка());
	ДанныеВидаЦен.Вставить("ОкруглятьВБольшуюСторону"	, Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыЦен.ПорядокОкругления КАК ПорядокОкругления,
	|	ВидыЦен.ОкруглятьВБольшуюСторону КАК ОкруглятьВБольшуюСторону
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	НЕ ВидыЦен.ПометкаУдаления
	|	И НЕ ВидыЦен.Недействителен
	|	И ВидыЦен.ИдентификаторФормул = &ИдентификаторФормул";
	
	Запрос.УстановитьПараметр("ИдентификаторФормул", ИдентификаторВидаЦен);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать(); 
		ВыборкаДетальныеЗаписи.Следующий();
		
		ЗаполнитьЗначенияСвойств(ДанныеВидаЦен, ВыборкаДетальныеЗаписи);
				
	КонецЕсли;

	Возврат ДанныеВидаЦен;
	
КонецФункции

&НаКлиенте
Процедура УстановитьДоступностьКолонкиЦенаНовая() 
	
	Если КэшЗначений.ЗначенияИдентификаторовВидовЦен = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ШаблонИмени = "ТЧНоменклатура%1_ЦенаНовая";
	Для Каждого ЭлементВидЦен Из КэшЗначений.ЗначенияИдентификаторовВидовЦен Цикл  
		
		ИдентификаторВидаЦен = ЭлементВидЦен.Значение;  
		
		Если НЕ ЗначениеЗаполнено(ИдентификаторВидаЦен) Тогда 
			Продолжить;
		КонецЕсли;     
		
		ИмяЭлемента = СтрШаблон(ШаблонИмени, ИдентификаторВидаЦен);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяЭлемента, "Доступность", Истина);  
		
	КонецЦикла;
	
КонецПроцедуры

#Область ВывестиСписок

&НаСервере
Функция ВывестиСписокНаСеврере(ВыбранныеКолонки)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	ТаблицаДанныеФормыНоменклатура = ТЧНоменклатура.Выгрузить();  
	КоллекцияКолонокНоменклатура = ТаблицаДанныеФормыНоменклатура.Колонки; 

	Если ТаблицаДанныеФормыНоменклатура.Количество() = 0 Тогда
		Возврат ТабличныйДокумент;
	КонецЕсли; 	 		  	
		
	ТаблицаДанныеФормыХарактеристики = ТЧХарактеристики.Выгрузить();  
	КоллекцияКолонокХарактеристик = ТаблицаДанныеФормыХарактеристики.Колонки; 
	
	ИспользоватьХарактеристики = ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики") 
			И Объект.ПоказыватьХарактеристики И ТаблицаДанныеФормыХарактеристики.Количество() > 0;
			
	Если ТаблицаДанныеФормыХарактеристики.Количество() = 0 И ИспользоватьХарактеристики Тогда 	
		Возврат ТабличныйДокумент;	
	КонецЕсли; 	 
	
 	СчетчикКолонок = КоллекцияКолонокНоменклатура.Количество() - 1;
	Пока СчетчикКолонок <> 0 Цикл  
		
		ТекущаяКолонка = КоллекцияКолонокНоменклатура[СчетчикКолонок];
		ИмяКолонки = СтрЗаменить(ТекущаяКолонка.Имя, "ТЧНоменклатура", "");  
		
		Если ИмяКолонки <> "Номенклатура" 
			И ИмяКолонки <> "Характеристика" Тогда
			
			Если ВыбранныеКолонки.Получить(ИмяКолонки) = Неопределено Тогда 
				
				КоллекцияКолонокНоменклатура.Удалить(ТекущаяКолонка);
				
			ИначеЕсли ВыбранныеКолонки.Получить(ИмяКолонки) <> Неопределено
				И ВыбранныеКолонки[ИмяКолонки] = Ложь Тогда
				
				КоллекцияКолонокНоменклатура.Удалить(ТекущаяКолонка); 
				
			КонецЕсли; 
			
		КонецЕсли;
		
		СчетчикКолонок = СчетчикКолонок - 1;
		
	КонецЦикла;   
	
	СчетчикКолонок = КоллекцияКолонокХарактеристик.Количество() - 1;
	Пока СчетчикКолонок <> 0 Цикл  
		
		ТекущаяКолонка = КоллекцияКолонокХарактеристик[СчетчикКолонок];
		ИмяКолонки = СтрЗаменить(ТекущаяКолонка.Имя, "ТЧХарактеристики", "");  
		
		Если ИмяКолонки <> "Номенклатура" 
			И ИмяКолонки <> "Характеристика" Тогда
			
			Если ВыбранныеКолонки.Получить(ИмяКолонки) = Неопределено Тогда 
				
				КоллекцияКолонокХарактеристик.Удалить(ТекущаяКолонка);
				
			ИначеЕсли ВыбранныеКолонки.Получить(ИмяКолонки) <> Неопределено
				И ВыбранныеКолонки[ИмяКолонки] = Ложь Тогда
				
				КоллекцияКолонокХарактеристик.Удалить(ТекущаяКолонка); 
				
			КонецЕсли; 
			
		КонецЕсли;
		
		СчетчикКолонок = СчетчикКолонок - 1;
		
	КонецЦикла;
	
	Если ТаблицаДанныеФормыНоменклатура.Количество() > 0  Тогда
				
		КоличествоКолонок = КоллекцияКолонокНоменклатура.Количество() + ?(ИспользоватьХарактеристики, 1, 0);
		
		// вывести заголовки таблицы 	
		ВывестиЗаголовкиВТабличныйДокумент(ТабличныйДокумент, 
			ТаблицаДанныеФормыНоменклатура, КоличествоКолонок, ИспользоватьХарактеристики);
				
		// вывести строки таблицы
		ВывестиСтрокиВТабличныйДокумент(ТабличныйДокумент, 
			ТаблицаДанныеФормыНоменклатура, ТаблицаДанныеФормыХарактеристики, ИспользоватьХарактеристики);
		
		// оформление таблицы
		УстановитьПараметрыОформленияТабличногоДокумента(ТабличныйДокумент, КоличествоКолонок, ИспользоватьХарактеристики);
		
	КонецЕсли;
	
	Возврат ТабличныйДокумент; 
		
КонецФункции

&НаСервереБезКонтекста
Функция СформироватьИмяКолонкиТабличногоДокумента(Знач ИмяКолонки)
	
	Результат = СтрЗаменить(ИмяКолонки, "ТЧНоменклатура"	, "");
	Результат = СтрЗаменить(Результат, "_ЦенаДо"			, "_Цена старая");
	Результат = СтрЗаменить(Результат, "_ЦенаНовая"		, "_Цена новая");
	Результат = СтрЗаменить(Результат, "_"				, Символы.ПС);

	Если Результат = "Номенклатура" ИЛИ Результат = "Характеристика" Тогда
		Результат = СтрШаблон("%1%2%3", Результат, Символы.ПС, " ");	
	КонецЕсли;

	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ВывестиЗаголовкиВТабличныйДокумент(ТабличныйДокумент, ТаблицаДанные, КоличествоКолонок, ИспользоватьХарактеристики) 
			
	Если ИспользоватьХарактеристики Тогда
		ТаблицаДанные.Колонки.Вставить(1, "Характеристика");	
	КонецЕсли;
	
	ОбластьВыводаЗаголовок = ТабличныйДокумент.ПолучитьОбласть(1, 1, 1, КоличествоКолонок);

	// 1. Заполнить заголовки колонок  
	СчетчикСтроки = 1;  	
	СчетчикКолонок = 1; 	
	Для Каждого ТекКолонка Из ТаблицаДанные.Колонки Цикл  
		
		ИмяКолонки = СформироватьИмяКолонкиТабличногоДокумента(ТекКолонка.Имя);
			
		ОбластьЗаполнения = ОбластьВыводаЗаголовок.Область(СчетчикСтроки, СчетчикКолонок, СчетчикСтроки, СчетчикКолонок);
		ОбластьЗаполнения.Текст 		= ИмяКолонки;
		ОбластьЗаполнения.Заполнение 	= ТипЗаполненияОбластиТабличногоДокумента.Текст; 
						
		СчетчикКолонок = СчетчикКолонок + 1; 
		
	КонецЦикла;	  
				
	ТабличныйДокумент.Вывести(ОбластьВыводаЗаголовок); 
	
КонецПроцедуры  

&НаСервереБезКонтекста
Процедура ВывестиСтрокиВТабличныйДокумент(ТабличныйДокумент, ТаблицаДанныеНоменклатура, ТаблицаДанныеХарактеристики, 
	ИспользоватьХарактеристикиВДокументе) 
	
	Если ТаблицаДанныеХарактеристики.Количество() > 5000 Тогда   
		ТаблицаДанныеХарактеристики.Индексы.Добавить("Номенклатура");	
	КонецЕсли;
	
	ЗначенияРеквизитовНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
		ТаблицаДанныеНоменклатура.ВыгрузитьКолонку("Номенклатура"), "ИспользоватьХарактеристики");
	
	СчетчикСтроки = 2;  		
	Для Каждого СтрокаТЗНоменклатура Из ТаблицаДанныеНоменклатура Цикл
		
		ИспользоватьХарактеристикиВСтроке = Ложь; 
		
		ЗначенияРеквизитовТекущейНоменклатуры = ЗначенияРеквизитовНоменклатуры.Получить(СтрокаТЗНоменклатура.Номенклатура);
		Если ЗначенияРеквизитовТекущейНоменклатуры <> Неопределено Тогда	
			ИспользоватьХарактеристикиВСтроке = ЗначенияРеквизитовТекущейНоменклатуры["ИспользоватьХарактеристики"];
		КонецЕсли;
		
		Если ИспользоватьХарактеристикиВДокументе И ИспользоватьХарактеристикиВСтроке Тогда 
			
			// строка с характеристиками
			ПараметрыОтбор = Новый Структура("Номенклатура", СтрокаТЗНоменклатура.Номенклатура);  
			НайденныеСтроки = ТаблицаДанныеХарактеристики.НайтиСтроки(ПараметрыОтбор);   
			
			Для Каждого СтрокаКоллекции Из НайденныеСтроки Цикл 
				
				// заполним текущую строку
				СчетчикКолонок = 1; 	 	
				Для Каждого ТекКолонка Из ТаблицаДанныеХарактеристики.Колонки Цикл  		
					
					ИмяКолонки = ТекКолонка.Имя;  
					
					ОбластьЯчейка = ТабличныйДокумент.Область(СчетчикСтроки, СчетчикКолонок, СчетчикСтроки, СчетчикКолонок);
					ОбластьЯчейка.Заполнение	= ТипЗаполненияОбластиТабличногоДокумента.Текст;    
					ОбластьЯчейка.Текст		= СтрокаКоллекции[ИмяКолонки];
					
					СчетчикКолонок = СчетчикКолонок + 1;  
					
				КонецЦикла;  
				
				СчетчикСтроки = СчетчикСтроки + 1;

			КонецЦикла;
			
		Иначе
			
			// строка без характеристик
			СчетчикКолонок = 1; 	 	
			Для Каждого ТекКолонка Из ТаблицаДанныеНоменклатура.Колонки Цикл  		
				
				ИмяКолонки = ТекКолонка.Имя;  
				
				ОбластьЯчейка = ТабличныйДокумент.Область(СчетчикСтроки, СчетчикКолонок, СчетчикСтроки, СчетчикКолонок);
				ОбластьЯчейка.Заполнение 	= ТипЗаполненияОбластиТабличногоДокумента.Текст;    
				ОбластьЯчейка.Текст 		= СтрокаТЗНоменклатура[ИмяКолонки];
				
				СчетчикКолонок = СчетчикКолонок + 1;  
				
			КонецЦикла;	
			
			СчетчикСтроки = СчетчикСтроки + 1;

		КонецЕсли; 
						
	КонецЦикла;  
	 	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьПараметрыОформленияТабличногоДокумента(ТабличныйДокумент, КоличествоКолонок, ИспользоватьХарактеристики)
	
	ТабличныйДокумент.ОтображатьЗаголовки 	= Истина;
	ТабличныйДокумент.ОтображатьСетку 		= Истина;
	ТабличныйДокумент.ОриентацияСтраницы 	= ОриентацияСтраницы.Ландшафт;
	
	ПараметрыОформления = ПараметрыОформленияТабличногоДокументаПоУмолчанию();

	// оформление заголовка
	Адрес = СтрШаблон("R1C1:R1C%1", XMLСтрока(КоличествоКолонок)); 	
	ОбластьЗаголовок 			= ТабличныйДокумент.Область(Адрес);	
	ОбластьЗаголовок.ЦветФона 	= ПараметрыОформления.ЦветФонаЗаголовкаТабличногоДокумента; 
	ОбластьЗаголовок.Шрифт 	= ПараметрыОформления.ШрифтЗаголовкаТабличногоДокумента;
	
	// ширина номенклатуры 
	Адрес = СтрШаблон("R1C1:R%1C1", XMLСтрока(ТабличныйДокумент.ВысотаТаблицы)); 
	ОбластьКолонкаНоменклатура = ТабличныйДокумент.Область(Адрес);
	УстановитьШиринуКолонки(ОбластьКолонкаНоменклатура, "Номенклатура"); 
	
	// ширина колонок по видам цен
	СчетчикКолонок = 1;
	Пока СчетчикКолонок <= ТабличныйДокумент.ШиринаТаблицы Цикл 
		
		ЗаголовокКолонки = ТабличныйДокумент.Область(1, СчетчикКолонок, 1, СчетчикКолонок); 
		
		Адрес = "R" + XMLСтрока(1) + "C" + XMLСтрока(СчетчикКолонок) + ":" +
								  "R" + XMLСтрока(ТабличныйДокумент.ВысотаТаблицы) + "C" + XMLСтрока(СчетчикКолонок); 
		
		АдресОбластьКолонка = ТабличныйДокумент.Область(Адрес);
		УстановитьШиринуКолонки(АдресОбластьКолонка, ЗаголовокКолонки); 
		
		СчетчикКолонок = СчетчикКолонок + 1;
	КонецЦикла;
	
КонецПроцедуры 

&НаСервереБезКонтекста
Функция ПараметрыОформленияТабличногоДокументаПоУмолчанию()

	ЭлементыСтиля = Метаданные.ЭлементыСтиля;
	
	// элементы стиля
	ПараметрыОформления = Новый Структура; 
	ПараметрыОформления.Вставить("ЦветФонаЗаголовкаТабличногоДокумента"	, ЭлементыСтиля.ЦветФонаЗаголовкаТабДокУЦ.Значение);
	ПараметрыОформления.Вставить("ШрифтЗаголовкаТабличногоДокумента"	, ЭлементыСтиля.ШрифтЗаголовкаТабДокУЦ.Значение);
	
	Возврат ПараметрыОформления;
	
КонецФункции 

&НаСервереБезКонтекста
Процедура УстановитьШиринуКолонки(ОбластьЗаполнения, ИмяКолонки) 
	
	Если ИмяКолонки = "Номенклатура" ИЛИ ИмяКолонки = "Характеристика" Тогда
		
		ОбластьЗаполнения.ШиринаКолонки = 30; 
						
	Иначе
		
		ОбластьЗаполнения.ШиринаКолонки = 22;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьЗначенияИменВсехКолонок() 
	
	МассивКолонок = Новый Массив;
	
	ТаблицаЗначений = ТЧНоменклатура.Выгрузить();
	Для Каждого ТекКолонка Из ТаблицаЗначений.Колонки Цикл 
		
		Если ТекКолонка.Имя = "Номенклатура" ИЛИ ТекКолонка.Имя = "Характеристика" Тогда 
			Продолжить;
		КонецЕсли;
		
		Если СтрНайти(ТекКолонка.Имя, "ТЧНоменклатура") = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		Если СтрНайти(ТекКолонка.Имя, "_ЦенаДо") = 0 И СтрНайти(ТекКолонка.Имя, "_ЦенаНовая") = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		МассивКолонок.Добавить(ТекКолонка.Имя);	
			
	КонецЦикла;
	
	Возврат МассивКолонок;
	
КонецФункции

#КонецОбласти

#Область СортировкаКолонок

&НаКлиенте
Процедура ПриСменеСтраницыТекущаяСтраницаВидыЦен()
	
 	УстановитьДоступностьЭлементовСтраницыВидыЦен(); 
	
КонецПроцедуры  

&НаКлиенте
Процедура ПриСменеСтраницыТекущаяСтраницаТовары()  
	
	Отказ = Ложь;
	
	КэшЗначений.ОтображатьНаценку = Объект.ОтображатьНаценку;
	
	ЗаполнитьКэшЗначенийВидамиЦен(КэшЗначений);
	
	Если ВидыЦенВыбраны() Тогда
		
		МассивИменТабличныхЧастей = ПолучитьМассивИменТЧДляИзменения();
		ИзменитьСоставРеквизитовИЭлементовТабличнойЧасти(МассивИменТабличныхЧастей); 
		
	Иначе
		
		ТекстСообщения = НСтр("ru = 'Необходимо указать виды цен, для которых планируется установка новых цен.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "ВидыЦен", , Отказ);
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаВидыЦен;
		Возврат;
		
	КонецЕсли;
	
	Отказ = Не ЦенообразованиеКлиент.ЗаполненыОбязательныеПараметрыСхемКомпоновкиДанных(ЭтотОбъект);
	
	Если Отказ Тогда
		
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаВидыЦен;
		
	Иначе
		
		ИзменитьВидимостьЭлементовТабличныхЧастей();
		
		// Заполнить по основанию
		Если НЕ КэшЗначений.ЗаполнениеПоИзменениямЦенПоставщика
			И ЗначениеЗаполнено(Объект.ДокументОснование) 
			И ТЧНоменклатура.Количество() = 0 
			И КэшЗначений.ПервоеПереключениеНаОсновании Тогда
			
			ЗаполнитьПоОснованиюЗавершение(КодВозвратаДиалога.Да, Неопределено);  
			
			КэшЗначений.ПервоеПереключениеНаОсновании = Ложь;
			
			Если КэшЗначений.Свойство("ТребуетсяПересчетСтарыхЦен") И КэшЗначений.ТребуетсяПересчетСтарыхЦен Тогда
				ОбработатьЕдиницыИзмеренияИЦены();
			КонецЕсли;
			
		КонецЕсли; 
		
		// Заполнить по основанию (изменения цен поставщика)
		Если КэшЗначений.ЗаполнениеПоИзменениямЦенПоставщика 
			И КэшЗначений.ПервоеПереключениеНаОсновании
			И ЗначениеЗаполнено(Объект.ДокументОснование) Тогда
			
			ЗаполнитьПоОснованиюЗавершение_ИзмененияЦенПоставщика(КодВозвратаДиалога.Да, Неопределено);	
			
			КэшЗначений.ПервоеПереключениеНаОсновании = Ложь;	
			
			Если КэшЗначений.ТребуетсяПересчетСтарыхЦен Тогда		
				ОбработатьЕдиницыИзмеренияИЦены(); 
			КонецЕсли;
			
		КонецЕсли;
		
		Если КэшЗначений.Свойство("ЗаполнитьЗапасыПоОчередиРасчета") ИЛИ КэшЗначений.Свойство("ЗаполнитьЗапасыПоВсейНоменклатуре")
			И КэшЗначений.ТекущаяСтраницаИмя <> "СтраницаТовары" Тогда
			
			ЗаполнитьНовыеВидыЦенВТабличныхЧастях();
			
		Иначе
			
			// при первом открытие не должны пересчитаться цены
			Если КэшЗначений.НовыеВидыЦен.Количество() <> 0 И ТЧНоменклатура.Количество() <> 0
				И (НЕ КэшЗначений.ПервоеОткрытиеДокумента И КэшЗначений.ТекущаяСтраницаИмя <> "СтраницаТовары") Тогда
					
				ЗаполнитьНовыеВидыЦенВТабличныхЧастях();
				
			КонецЕсли;

		КонецЕсли;
		
	КонецЕсли;
	
	СортироватьКолонкиВидовЦенНаФорме();
	
	ИзменитьЭлементыФормыПоВыбраннымВидамЦен();

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИдентификаторыВидовЦен(КэшЗначений)
	
	ЗначенияИдентификаторовВидовЦен = Новый Соответствие;
	ЗначенияЗависимыхИдентификаторов = Новый Соответствие;
	
	Если ЗначениеЗаполнено(КэшЗначений.ВыбранныеВидыЦен) Тогда  
		
		МассивВсехВидовЦен = Новый Массив;
		ЗаполнитьМассивВсехВидовЦенРекурсивно(МассивВсехВидовЦен, КэшЗначений.ВыбранныеВидыЦен);
		
		Если МассивВсехВидовЦен.Количество() <> 0 Тогда
			
			ДанныеИдентификаторов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивВсехВидовЦен, "ИдентификаторФормул");
			
			Для Каждого БазовыйВидЦен Из КэшЗначений.ВыбранныеВидыЦен Цикл 
				
				ТекущийВидЦен = БазовыйВидЦен.Ключ;
				ЗависимыеВидыЦен = БазовыйВидЦен.Значение;
				
				ЗначенияИдентификаторовВидовЦен.Вставить(ТекущийВидЦен, ДанныеИдентификаторов[ТекущийВидЦен].ИдентификаторФормул);
				
				Если НЕ ЗначениеЗаполнено(ЗависимыеВидыЦен) Тогда
					Продолжить;
				КонецЕсли;
				
				ЗаполнитьЗависимыеИдентификаторыРекурсивно(ДанныеИдентификаторов, ТекущийВидЦен, ЗависимыеВидыЦен, 
					ЗначенияИдентификаторовВидовЦен, ЗначенияЗависимыхИдентификаторов);
				
			КонецЦикла; 
			
		КонецЕсли;
	КонецЕсли;
	
	КэшЗначений.Вставить("ЗначенияИдентификаторовВидовЦен", ЗначенияИдентификаторовВидовЦен); 
	КэшЗначений.Вставить("ЗначенияЗависимыхИдентификаторов", ЗначенияЗависимыхИдентификаторов);
	
КонецПроцедуры   

&НаСервереБезКонтекста
Процедура ЗаполнитьМассивВсехВидовЦенРекурсивно(МассивВидовЦен, ВыбранныеВидыЦен) 
	
	Для Каждого ЭлементСоответствия Из ВыбранныеВидыЦен Цикл 
		
		ТекущийВидЦен = ЭлементСоответствия.Ключ;
		ЗависимыеВидыЦен = ЭлементСоответствия.Значение;
		
		МассивВидовЦен.Добавить(ТекущийВидЦен); 
		
		Если ЗначениеЗаполнено(ЗависимыеВидыЦен) Тогда 
			ЗаполнитьМассивВсехВидовЦенРекурсивно(МассивВидовЦен, ЗависимыеВидыЦен);
		КонецЕсли; 
		
	КонецЦикла;

КонецПроцедуры  

&НаСервереБезКонтекста
Процедура ЗаполнитьЗависимыеИдентификаторыРекурсивно(ДанныеИдентификаторов, БазовыйВидЦен, ПодчиненныеВидыЦен,
		ЗначенияИдентификаторовВидовЦен, ЗначенияЗависимыхИдентификаторов) 
	
	Для Каждого ЭлементСоответствия Из ПодчиненныеВидыЦен Цикл 
		
		ТекущийВидЦен = ЭлементСоответствия.Ключ; 
		ЗависимыеВидыЦен = ЭлементСоответствия.Значение;
		
		ЗависимыйИдентификаторФормул = ДанныеИдентификаторов[ТекущийВидЦен].ИдентификаторФормул;
		БазовыйИдентификаторФормул = ДанныеИдентификаторов[БазовыйВидЦен].ИдентификаторФормул;
		
		ЗначенияЗависимыхИдентификаторов.Вставить(ЗависимыйИдентификаторФормул, БазовыйИдентификаторФормул); 
		ЗначенияИдентификаторовВидовЦен.Вставить(ТекущийВидЦен, ЗависимыйИдентификаторФормул);

		Если ТипЗнч(ЗависимыеВидыЦен) = Тип("Соответствие") 
			И ЗначениеЗаполнено(ЗависимыеВидыЦен) Тогда  
			
			ЗаполнитьЗависимыеИдентификаторыРекурсивно(ДанныеИдентификаторов, ТекущийВидЦен, ЗависимыеВидыЦен,
				ЗначенияИдентификаторовВидовЦен, ЗначенияЗависимыхИдентификаторов);  
							
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СортироватьКолонкиВидовЦенНаФорме()

	МассивСортировки = ПолучитьМассивСортировкиКолонок(КэшЗначений.ВыбранныеВидыЦен);

	Для Каждого ТекущаяКолонка Из МассивСортировки Цикл

		Если Элементы.Найти("ТЧНоменклатура" + ТекущаяКолонка) = Неопределено Тогда

			Продолжить;

		КонецЕсли;

		Элементы.Переместить(Элементы["ТЧНоменклатура" + ТекущаяКолонка], Элементы.ТЧНоменклатура); 
		
		Если ФОИспользоватьХарактеристики И Объект.ПоказыватьХарактеристики Тогда
			Элементы.Переместить(Элементы["ТЧХарактеристики" + ТекущаяКолонка], Элементы.ТЧХарактеристики);
		КонецЕсли; 
		
	КонецЦикла;

	Элементы.Переместить(Элементы.ТЧНоменклатураПустаяКолонка, Элементы.ТЧНоменклатура);  
	
	Если ФОИспользоватьХарактеристики И Объект.ПоказыватьХарактеристики Тогда 
		Элементы.Переместить(Элементы.ТЧХарактеристикиПустаяКолонка, Элементы.ТЧХарактеристики);  
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыСортировкиКолонок(Результат, ДополнительныеПараметры) Экспорт

	Если Результат <> Неопределено Тогда

		СортироватьКолонкиВидовЦенНаФорме();

	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьМассивСортировкиКолонок(ВыбранныеВидыЦен)

	МаксимальныйПорядок = Справочники.ВидыЦен.ПолучитьМаксимальныйПорядокКолонок();

	Если МаксимальныйПорядок = 0 Тогда

		Возврат ПолучитьСортированныйМассивКолонокВидовЦенПоУмолчанию(ВыбранныеВидыЦен);

	Иначе

		Таблица = Справочники.ВидыЦен.ПолучитьСортированнуюТаблицуВидовЦен();
		Возврат Таблица.ВыгрузитьКолонку("ИдентификаторФормул");

	КонецЕсли;

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСортированныйМассивКолонокВидовЦенПоУмолчанию(ВыбранныеВидыЦен)

	РезультатСсылки = Новый Массив;
	СортироватьВыбранныеВидыЦенПоУмолчанию(ВыбранныеВидыЦен, РезультатСсылки);
	Результат = Новый Массив;
	Для Каждого ВидЦеныСсылка Из РезультатСсылки Цикл

		Результат.Добавить(ВидЦеныСсылка.ИдентификаторФормул);

	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ОбновитьВидимостьКомандСортировкиАртикула()
				
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СортироватьПоВозрастаниюАртикул", 
		"Видимость", Элементы.ТЧНоменклатураНоменклатураАртикул.Видимость);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СортироватьПоУбываниюАртикул", 
		"Видимость", Элементы.ТЧНоменклатураНоменклатураАртикул.Видимость);   
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СортироватьПоВозрастаниюАртикулХарактеристики", 
		"Видимость", Элементы.ТЧХарактеристикиХарактеристикаАртикул.Видимость);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СортироватьПоУбываниюАртикулХарактеристики", 
		"Видимость", Элементы.ТЧХарактеристикиХарактеристикаАртикул.Видимость);  
	
КонецПроцедуры 

