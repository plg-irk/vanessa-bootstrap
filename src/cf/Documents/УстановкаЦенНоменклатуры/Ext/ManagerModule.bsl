	ПолеДельтаКартинка = ПолеДельтаКартинка + ", "
		+ "
		|	ВЫБОР КОГДА
		|		ВЫБОР КОГДА ISNULL(" + ШаблонИмяТаблицыЗапроса + ".Цена, 0) = 0
		|			ТОГДА 0 
		|			ИНАЧЕ ISNULL(" + ШаблонИмяТаблицыЗапроса + ".Цена, 0) 
