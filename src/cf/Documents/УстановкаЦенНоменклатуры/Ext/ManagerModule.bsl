	|	ВТ_ДанныеДокумент.СтавкаНДС КАК СтавкаНДС,
	|	ВТ_ДанныеДокумент.Дата КАК Дата,
	|	ВТ_ДанныеДокумент.Курс КАК КурсДокумента,
	|	ВТ_ДанныеДокумент.Кратность КАК КратностьДокумента,
