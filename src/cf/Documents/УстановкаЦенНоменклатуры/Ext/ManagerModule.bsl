Процедура ТекстПоляВалютаВидимостьОсновная(СтруктураОбщихПараметровПолей, ПолеВалютаВидимость)
	
	ИмяТабличнойЧасти = СтруктураОбщихПараметровПолей.ИмяТабличнойЧасти;
	ИдентификаторФормул = СтруктураОбщихПараметровПолей.ИдентификаторФормул;
	ШаблонИмяТаблицыЗапросаРегистр = СтруктураОбщихПараметровПолей.ШаблонИмяТаблицыЗапросаРегистр;
	РазделительПолейЗапроса = СтруктураОбщихПараметровПолей.РазделительПолейЗапроса;
	ШаблонИмяТаблицыЗапроса = СтруктураОбщихПараметровПолей.ШаблонИмяТаблицыЗапроса;
	
	ИмяПоляВалютаВидимость = ИмяТабличнойЧасти + ИдентификаторФормул + "_ВалютаВидимость";
	ПолеВалютаВидимость = ПолеВалютаВидимость
		+ ?(ПустаяСтрока(ПолеВалютаВидимость), "", ", ") + Символы.ПС
		+ СтрШаблон(РазделительПолейЗапроса, "ВалютаВидимость")
		+"	ВЫБОР КОГДА НЕ ВЫРАЗИТЬ(&_ШаблонИмяВидаЦен КАК Справочник.ВидыЦен).НесколькоВалютДляЦен
		|		ТОГДА
		|			ВЫБОР КОГДА " + ШаблонИмяТаблицыЗапроса + ".ВалютаСтарая <> ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)
		|				ТОГДА " + ШаблонИмяТаблицыЗапроса + ".ВалютаСтарая
		|				ИНАЧЕ 
		|					ВЫБОР КОГДА ISNULL(" + ШаблонИмяТаблицыЗапросаРегистр + ".ВалютаЦены, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) 
		|						ТОГДА " + ШаблонИмяТаблицыЗапросаРегистр + ".ВалютаЦены
		|						ИНАЧЕ " + ШаблонИмяТаблицыЗапросаРегистр + ".ВидЦен.ВалютаЦены
		|					КОНЕЦ
		|			КОНЕЦ
		|			<>
		|			ВЫРАЗИТЬ(&_ШаблонИмяВидаЦен КАК Справочник.ВидыЦен).ВалютаЦены
		|	ИНАЧЕ
		|		ИСТИНА 
		|	КОНЕЦ КАК " + ИмяПоляВалютаВидимость;
			
КонецПроцедуры

Процедура ТекстПоляВалютаВидимостьЗависимая(СтруктураОбщихПараметровПолей, ПолеВалютаВидимость)
	
	ИмяТабличнойЧасти = СтруктураОбщихПараметровПолей.ИмяТабличнойЧасти;
	ШаблонИмяТаблицыЗапросаРегистр = СтруктураОбщихПараметровПолей.ШаблонИмяТаблицыЗапросаРегистр;
	ШаблонИмяТаблицыЗапроса = СтруктураОбщихПараметровПолей.ШаблонИмяТаблицыЗапроса;
	
	ИмяПоляВалютаВидимость = ИмяТабличнойЧасти + ШаблонИмяТаблицыЗапроса + "_ВалютаВидимость";
	ПолеВалютаВидимость = ПолеВалютаВидимость + ", "
		+"	
		|	ВЫБОР КОГДА НЕ ВЫРАЗИТЬ(&_ШаблонИмяВидаЦен КАК Справочник.ВидыЦен).НесколькоВалютДляЦен
		|		ТОГДА
		|			ВЫБОР КОГДА " + ШаблонИмяТаблицыЗапроса + ".ВалютаСтарая <> ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)
		|				ТОГДА " + ШаблонИмяТаблицыЗапроса + ".ВалютаСтарая
		|				ИНАЧЕ 
		|					ВЫБОР КОГДА ISNULL(" + ШаблонИмяТаблицыЗапросаРегистр + ".ВалютаЦены, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) 
		|						ТОГДА " + ШаблонИмяТаблицыЗапросаРегистр + ".ВалютаЦены
		|						ИНАЧЕ " + ШаблонИмяТаблицыЗапросаРегистр + ".ВидЦен.ВалютаЦены
		|					КОНЕЦ
		|			КОНЕЦ
		|			<>
		|			ВЫРАЗИТЬ(&_ШаблонИмяВидаЦен КАК Справочник.ВидыЦен).ВалютаЦены
		|	ИНАЧЕ
		|		ИСТИНА 
		|	КОНЕЦ КАК " + ИмяПоляВалютаВидимость;
			
КонецПроцедуры

Функция ТекстЗапросаКолонокТекущихЦен()
	
	Текст = 
	"ВЫБРАТЬ
	|	ТаблицаИсточник.Номенклатура КАК Номенклатура,
	|	ТаблицаИсточник.Характеристика КАК Характеристика,
	|	ТаблицаИсточник.ЕдиницаИзмерения КАК ЕдиницаИзмеренияШаблон,
	|	ТаблицаИсточник.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ТаблицаИсточник.ЦенаНоваяШаблон КАК ЦенаНоваяШаблон,
	|	ТаблицаИсточник.КлючСвязи КАК КлючСвязи,
	|	ТаблицаИсточник.Валюта КАК Валюта,
	|	АВТОНОМЕРЗАПИСИ() КАК НомерСтроки
	|ПОМЕСТИТЬ ТаблицаИсточник
	|ИЗ
	|	&ТаблицаИсточник КАК ТаблицаИсточник
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаЦен.Номенклатура КАК Номенклатура,
	|	ТаблицаЦен.Характеристика КАК Характеристика,
	|	ТаблицаЦен.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ТаблицаЦен.Цена КАК Цена,
	|	ТаблицаЦен.ЦенаСтарая КАК ЦенаСтарая,
	|	ТаблицаЦен.ВидЦены КАК ВидЦены,
	|	ТаблицаЦен.Валюта КАК Валюта,
	|	ТаблицаЦен.ВалютаСтарая КАК ВалютаСтарая
	|ПОМЕСТИТЬ ТаблицаЦен
	|ИЗ
	|	&ТаблицаЦен КАК ТаблицаЦен
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(Штрихкоды.Штрихкод) КАК Штрихкод,
	|	Штрихкоды.Номенклатура,
	|	Штрихкоды.Характеристика
	|ПОМЕСТИТЬ Штрихкоды
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
	|ГДЕ
	|	(Штрихкоды.Номенклатура, Штрихкоды.Характеристика) В
	|		(ВЫБРАТЬ
	|			Т.Номенклатура,
	|			Т.Характеристика
	|		ИЗ
	|			ТаблицаИсточник КАК Т)
	|	И НЕ Штрихкоды.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|СГРУППИРОВАТЬ ПО
	|	Штрихкоды.Номенклатура,
	|	Штрихкоды.Характеристика
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦеныПоВыбраннымТипамЦен.Период КАК Период,
	|	ЦеныПоВыбраннымТипамЦен.ВидЦен КАК ВидЦен,
	|	ЦеныПоВыбраннымТипамЦен.Номенклатура КАК Номенклатура,
	|	ЦеныПоВыбраннымТипамЦен.Характеристика КАК Характеристика,
	|	ЦеныПоВыбраннымТипамЦен.Цена КАК Цена,
	|	ЦеныПоВыбраннымТипамЦен.Актуальность КАК Актуальность,
	|	ЦеныПоВыбраннымТипамЦен.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЦеныПоВыбраннымТипамЦен.ВалютаЦены КАК ВалютаЦены,
	|	ЦеныПоВыбраннымТипамЦен.ВключаяХарактеристики КАК ВключаяХарактеристики,
	|	ЦеныПоВыбраннымТипамЦен.Автор КАК Автор,
	|	ЦеныПоВыбраннымТипамЦен.ДокументУстановки КАК ДокументУстановки
	|ПОМЕСТИТЬ ЦеныПоВыбраннымТипамЦен
	|ИЗ
	|	&ЦеныПоВыбраннымТипамЦен КАК ЦеныПоВыбраннымТипамЦен
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаИсточник.Номенклатура КАК Номенклатура,
	|	ВЫРАЗИТЬ(ТаблицаИсточник.Номенклатура КАК Справочник.Номенклатура).ТипНоменклатуры КАК ТипНоменклатуры,
	|	ТаблицаИсточник.Номенклатура.ЭтоНабор КАК ЭтоНабор,
	|	ТаблицаИсточник.Номенклатура.ИспользоватьХарактеристики КАК ИспользоватьХарактеристики,
	|	ТаблицаИсточник.Номенклатура.ПроверятьЗаполнениеХарактеристики КАК ПроверятьЗаполнениеХарактеристики,
	|	ТаблицаИсточник.Номенклатура.ПометкаУдаления КАК ПометкаУдаления,
	|	ТаблицаИсточник.Характеристика КАК Характеристика,
	|	ТаблицаИсточник.ЦенаНоваяШаблон КАК ЦенаНоваяШаблон,
	|	ТаблицаИсточник.ЕдиницаИзмеренияШаблон КАК ЕдиницаИзмеренияШаблон,
	|	ТаблицаИсточник.КлючСвязи КАК КлючСвязи,
	|	ТаблицаИсточник.НомерСтроки КАК НомерСтроки,
	|	ISNULL(Штрихкоды.Штрихкод, """") КАК ХарактеристикаШтрихкод,
	|	&ПолеИменаКолонокЦенуИзменили,
	|	&ПолеИменаКолонокТекущихЦен,
	|	&ПолеИменаКолонокНовыхЦен,
	|	&ПолеИменаКолонокЕдиницИзмерения,
	|	&ПолеИменаКолонокДельта,
	|	&ПолеИменаКолонокВалюта,
	|	&ПолеИменаКолонокТекущаяВалюта,
	|	&ПолеИменаКолонокДельтаВалюта,
	|	&ПолеИменаКолонокВидимостьВалюта,
	|	&ПолеИменаКолонокДельтаКартинка
	|ПОМЕСТИТЬ ТаблицаДокумента
	|ИЗ
	|	ТаблицаИсточник КАК ТаблицаИсточник
	|	ЛЕВОЕ СОЕДИНЕНИЕ Штрихкоды КАК Штрихкоды
	|		ПО ТаблицаИсточник.Номенклатура = Штрихкоды.Номенклатура
	|		И ТаблицаИсточник.Характеристика = Штрихкоды.Характеристика";
	
	Возврат Текст;
	
КонецФункции

Процедура ПересчитатьВалютнуюДельту(ТаблицаИсточникСЦеной, Знач ПараметрыКопирования, Знач ТаблицаИменКолонок)

	Если Не ПараметрыКопирования.ФОУчетВалютныхОпераций Тогда
		Возврат;
	КонецЕсли;
	
	КурсыВалютДокумента = ПараметрыКопирования.КурсыВалютДокумента;	
	Для Каждого Запись Из ТаблицаИсточникСЦеной Цикл
		Для Каждого СтрокаИмен Из ТаблицаИменКолонок Цикл
			Если ЗначениеЗаполнено(Запись[СтрокаИмен.ВалютаДо]) 
				И Запись[СтрокаИмен.ВалютаНовая] <> Запись[СтрокаИмен.ВалютаДо] Тогда
				
				ПараметрыТекущегоКурса = КурсыВалютДокумента.Получить(Запись[СтрокаИмен.ВалютаДо]);
				ПараметрыНовогоКурса = КурсыВалютДокумента.Получить(Запись[СтрокаИмен.ВалютаНовая]);
				
				ЦенаДоВНовойВалюте = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(Запись[СтрокаИмен.ЦенаДо],
					ПараметрыТекущегоКурса, ПараметрыНовогоКурса); 
					
				Запись[СтрокаИмен.Дельта] = Запись[СтрокаИмен.ЦенаНовая] - ЦенаДоВНовойВалюте;
				
				Если Запись[СтрокаИмен.Дельта] < 0 Тогда
					Запись[СтрокаИмен.ДельтаКартинка] = 1;
				ИначеЕсли Запись[СтрокаИмен.Дельта] > 0 Тогда
					Запись[СтрокаИмен.ДельтаКартинка] = 0;
				Иначе
					Запись[СтрокаИмен.ДельтаКартинка] = -1;
				КонецЕсли;
				 
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьКолонкиПодчиненногоВидаЦенВТекстЗапроса(ПараметрыПроцедуры)
	
	ПолеДельта = ПараметрыПроцедуры.ПолеДельта;
	ПолеЕдиницИзмерения = ПараметрыПроцедуры.ПолеЕдиницИзмерения;
	ПолеНовыхЦен = ПараметрыПроцедуры.ПолеНовыхЦен;
	ПолеТекущихЦен = ПараметрыПроцедуры.ПолеТекущихЦен;
	ПолеЦенуИзменили = ПараметрыПроцедуры.ПолеЦенуИзменили;
	ПолеНоваяВалюта = ПараметрыПроцедуры.ПолеНоваяВалюта;
	ПолеДельтаВалюта = ПараметрыПроцедуры.ПолеДельтаВалюта;
	ПолеТекущаяВалюта = ПараметрыПроцедуры.ПолеТекущаяВалюта;
	ПолеВалютаВидимость = ПараметрыПроцедуры.ПолеВалютаВидимость;
	ПолеДельтаКартинка = ПараметрыПроцедуры.ПолеДельтаКартинка;
	
	Запрос = ПараметрыПроцедуры.Запрос;
	ИмяТабличнойЧасти = ПараметрыПроцедуры.ИмяТабличнойЧасти;
	ПодчиненныеВидыЦен = ПараметрыПроцедуры.ПодчиненныеВидыЦен;
	ДобавляемыйВидЦен = ПараметрыПроцедуры.ПодчиненныйВидЦен;	
	ШаблонТекстаЗапросаВидЦен = ПараметрыПроцедуры.ШаблонТекстаЗапросаВидЦен;
	ШаблонТекстаЗапросаВидЦенРегистр = ПараметрыПроцедуры.ШаблонТекстаЗапросаВидЦенРегистр;
	
	Если ПодчиненныеВидыЦен.Найти(ДобавляемыйВидЦен.Ключ) = Неопределено Тогда
		
		ШаблонИмяТаблицыЗапроса = ДобавляемыйВидЦен.Ключ.ИдентификаторФормул;
		ШаблонИмяТаблицыЗапросаРегистр = ДобавляемыйВидЦен.Ключ.ИдентификаторФормул + "Регистр";
		
		СтруктураОбщихПараметровПолей = Новый Структура;
		СтруктураОбщихПараметровПолей.Вставить("ИмяТабличнойЧасти", ИмяТабличнойЧасти);
		СтруктураОбщихПараметровПолей.Вставить("ШаблонИмяТаблицыЗапросаРегистр", ШаблонИмяТаблицыЗапросаРегистр);
		СтруктураОбщихПараметровПолей.Вставить("ШаблонИмяТаблицыЗапроса", ШаблонИмяТаблицыЗапроса);
		
		ТекстПоляЦенаДоЗависимая(СтруктураОбщихПараметровПолей, ПолеТекущихЦен);
		
		ТекстПоляТекущаяВалютаЗависимая(СтруктураОбщихПараметровПолей, ПолеТекущаяВалюта);
				
		ТекстПоляДельтаЗависимая(СтруктураОбщихПараметровПолей, ПолеДельта);
			
		ТекстПоляДельтаВалютаЗависимая(СтруктураОбщихПараметровПолей, ПолеДельтаВалюта);
		
		ТекстПоляЦенаНоваяЗависимая(СтруктураОбщихПараметровПолей, ПолеНовыхЦен);
		
		ТекстПоляВалютаНоваяЗависимая(СтруктураОбщихПараметровПолей, ПолеНоваяВалюта);
		
		ТекстПоляЕдиницаИзмененияЗависимая(СтруктураОбщихПараметровПолей, ПолеЕдиницИзмерения);
		
		ТекстПоляЦенуИзменилиЗависимая(СтруктураОбщихПараметровПолей, ПолеЦенуИзменили);
		
		ТекстПоляВалютаВидимостьЗависимая(СтруктураОбщихПараметровПолей, ПолеВалютаВидимость);
		
		ТекстПоляДельтаКартинкаЗависимая(СтруктураОбщихПараметровПолей, ПолеДельтаКартинка);
		
		ТекстЗапросаЛевоеСоединение = СтрЗаменить(ШаблонТекстаЗапросаВидЦен, "_ШаблонИмяТаблицыЗапроса",
			ШаблонИмяТаблицыЗапроса);
		ТекстЗапросаЛевоеСоединение = СтрЗаменить(ТекстЗапросаЛевоеСоединение, "_ШаблонИмяВидаЦен",
			ШаблонИмяТаблицыЗапроса);

		ТекстЗапросаЛевоеСоединениеРегистр = СтрЗаменить(ШаблонТекстаЗапросаВидЦенРегистр, "_ШаблонИмяТаблицыЗапроса",
			ШаблонИмяТаблицыЗапроса);
		ТекстЗапросаЛевоеСоединениеРегистр = СтрЗаменить(ТекстЗапросаЛевоеСоединениеРегистр, "_ШаблонИмяВидаЦен",
			ШаблонИмяТаблицыЗапроса);
		
		ПолеВалютаВидимость = СтрЗаменить(ПолеВалютаВидимость, "_ШаблонИмяВидаЦен", ШаблонИмяТаблицыЗапроса);
		ПолеНоваяВалюта = СтрЗаменить(ПолеНоваяВалюта, "_ШаблонИмяВидаЦен", ШаблонИмяТаблицыЗапроса);
		
		Запрос.Текст = Запрос.Текст + ТекстЗапросаЛевоеСоединение + ТекстЗапросаЛевоеСоединениеРегистр;
		Запрос.УстановитьПараметр(ШаблонИмяТаблицыЗапроса, ДобавляемыйВидЦен.Ключ);
		Запрос.УстановитьПараметр(ШаблонИмяТаблицыЗапросаРегистр, ДобавляемыйВидЦен.Ключ);
		
		ПодчиненныеВидыЦен.Добавить(ДобавляемыйВидЦен.Ключ);
		
		ПараметрыПроцедуры.ПолеДельта = ПолеДельта;
		ПараметрыПроцедуры.ПолеЕдиницИзмерения = ПолеЕдиницИзмерения;
		ПараметрыПроцедуры.ПолеНовыхЦен = ПолеНовыхЦен;
		ПараметрыПроцедуры.ПолеТекущихЦен = ПолеТекущихЦен;
		ПараметрыПроцедуры.ПолеЦенуИзменили = ПолеЦенуИзменили;
		ПараметрыПроцедуры.ПолеНоваяВалюта = ПолеНоваяВалюта;
		ПараметрыПроцедуры.ПолеДельтаВалюта = ПолеДельтаВалюта;
		ПараметрыПроцедуры.ПолеТекущаяВалюта = ПолеТекущаяВалюта;
		ПараметрыПроцедуры.ПолеВалютаВидимость = ПолеВалютаВидимость;
		ПараметрыПроцедуры.ПолеДельтаКартинка = ПолеДельтаКартинка;
		
	КонецЕсли;
	
	Для каждого ПодчиненныйВидЦен Из ДобавляемыйВидЦен.Значение Цикл
		
		ПараметрыПроцедуры.Вставить("ПодчиненныйВидЦен", ПодчиненныйВидЦен);
		ДобавитьКолонкиПодчиненногоВидаЦенВТекстЗапроса(ПараметрыПроцедуры);
	
	КонецЦикла;

КонецПроцедуры

Функция СформироватьМассивВидовЦенИзКоллекции(КолекцияЗависимыеВидыЦен)
	
	МассивВидовЦен = Новый Массив; 
	
	Для Каждого СтрокаКоллекции Из КолекцияЗависимыеВидыЦен Цикл
		МассивВидовЦен.Добавить(СтрокаКоллекции.Ключ);
	КонецЦикла;
	
	Возврат МассивВидовЦен; 
	
КонецФункции

Процедура ПересчитатьПроцентИзменения(ДанныеТекущейСтроки, Идентификатор, Период = Неопределено)
	
	ИмяПоляПроцентИзменения 	= Идентификатор + "_ПроцентИзменения";
	ИмяПоляЦенаНовая 			= Идентификатор + "_ЦенаНовая"; 
	ИмяПоляЦенаДо 			= Идентификатор + "_ЦенаДо";
	ИмяПоляВалютаДо 			= Идентификатор + "_ВалютаДо";
	ИмяПоляВалютаНовая 		= Идентификатор + "_ВалютаНовая"; 
	
	Цена_До 					= ДанныеТекущейСтроки[ИмяПоляЦенаДо]; 
	Цена_Новая 				= ДанныеТекущейСтроки[ИмяПоляЦенаНовая];
	Валюта_До 				= ДанныеТекущейСтроки[ИмяПоляВалютаДо];
	Валюта_Новая 				= ДанныеТекущейСтроки[ИмяПоляВалютаНовая];
	
	Если Валюта_До <> Валюта_Новая Тогда
		
		ЦенаДоВНовойВалюте = ПересчитатьЦенуИзВалютыВВалюту(Цена_До, Валюта_До, Валюта_Новая, 
			?(Период = Неопределено, ТекущаяДатаСеанса(), Период)); 
			
		Если ЦенаДоВНовойВалюте > 0 Тогда 
			
			ИзменениеЦены = Цена_Новая - ЦенаДоВНовойВалюте;
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = ИзменениеЦены / ЦенаДоВНовойВалюте * 100;			
		Иначе
					
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = 0;			
		КонецЕсли; 

	Иначе
		
		Если Цена_До > 0 Тогда 
			
			ИзменениеЦены = Цена_Новая - Цена_До;
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = ИзменениеЦены / Цена_До * 100;			
		Иначе
					
			ДанныеТекущейСтроки[ИмяПоляПроцентИзменения] = 0;			
		КонецЕсли;     
		
	КонецЕсли;
	
КонецПроцедуры  

Процедура ПересчитатьПроцентНаценки(ДанныеТекущейСтроки, Идентификатор, 
		ЗначенияЗависимыхИдентификаторов, ИмяТабличнойЧасти)
	
	ИдентификаторВидЦен = СтрЗаменить(Идентификатор, ИмяТабличнойЧасти, "");
	ИдентификаторБазовыйВидЦен = ЗначенияЗависимыхИдентификаторов.Получить(ИдентификаторВидЦен);
		
	Если ПустаяСтрока(ИдентификаторБазовыйВидЦен) Тогда 
		Возврат;
	КонецЕсли;
	
	ИмяПоляЦенаНоваяБазовыйВидЦен = ИмяТабличнойЧасти + ИдентификаторБазовыйВидЦен + "_ЦенаНовая";
	ИмяПоляЦенаНоваяЗависимыйВидЦен = Идентификатор + "_ЦенаНовая"; 
	ИмяПоляПроцентНаценкиЗависимыйВидЦен = Идентификатор + "_ПроцентНаценки";
		
	Если ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен] > 0 
		И ДанныеТекущейСтроки[ИмяПоляЦенаНоваяЗависимыйВидЦен] > 0 Тогда
		
		НовыйПроцентНаценки = ВычислитьПроцентНаценкиНаБазовыйВидЦенПоФормуле(
			ДанныеТекущейСтроки[ИмяПоляЦенаНоваяЗависимыйВидЦен], ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен]);
			
	Иначе
		НовыйПроцентНаценки = 0;
	КонецЕсли; 
	
	ДанныеТекущейСтроки[ИмяПоляПроцентНаценкиЗависимыйВидЦен] = НовыйПроцентНаценки;
	
КонецПроцедуры 

Процедура ПересчитатьПроцентНаценкиПоВидуЦен(ДанныеТекущейСтроки, Знач ИдентификаторВидаЦен, Знач ЗначенияРеквизитовВидовЦенОснования, 
		Знач ЗначенияЗависимыхИдентификаторов, Знач ИмяТабличнойЧасти, Знач ДатаСреза)
				
	ИмяПоляЦенаНоваяБазовыйВидЦен = СтрШаблон("%1%2_ЦенаНовая", ИмяТабличнойЧасти, ИдентификаторВидаЦен);
	
	Для Каждого ТекЭлемент Из ЗначенияЗависимыхИдентификаторов Цикл 
		
		ЗависимыйИдентификатор = ТекЭлемент.Ключ;
		
		ИмяПоляЦенаНоваяЗависимыйВидЦен 		= СтрШаблон("%1%2_ЦенаНовая", ИмяТабличнойЧасти, ЗависимыйИдентификатор);
		ИмяПоляПроцентНаценкиЗависимыйВидЦен 	= СтрШаблон("%1%2_ПроцентНаценки", ИмяТабличнойЧасти, ЗависимыйИдентификатор);
		
		Если ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен] > 0 
			И ДанныеТекущейСтроки[ИмяПоляЦенаНоваяЗависимыйВидЦен] > 0 Тогда
			
			НовыйПроцентНаценки = ВычислитьПроцентНаценкиНаБазовыйВидЦенПоФормуле(
			ДанныеТекущейСтроки[ИмяПоляЦенаНоваяЗависимыйВидЦен], ДанныеТекущейСтроки[ИмяПоляЦенаНоваяБазовыйВидЦен]);
			
		Иначе
			НовыйПроцентНаценки = 0;
		КонецЕсли; 
		
		ДанныеТекущейСтроки[ИмяПоляПроцентНаценкиЗависимыйВидЦен] = НовыйПроцентНаценки;
		ЗаполнитьПоказательПроцентИзмененияЦены(ДанныеТекущейСтроки, ИмяТабличнойЧасти, ЗависимыйИдентификатор, ДатаСреза);
		
	КонецЦикла;
		
КонецПроцедуры 

Функция ПолучитьПризнакДинамическийПоВидуЦен(ВидЦен) 
	
	ПризнакДинамический = Ложь;
	Если ВидЦен.ТипВидаЦен = Перечисления.ТипыВидовЦен.ДинамическийПроцент
		ИЛИ ВидЦен.ТипВидаЦен = Перечисления.ТипыВидовЦен.ДинамическийФормула Тогда 
		
		ПризнакДинамический = Истина;
	КонецЕсли;
	
	Возврат ПризнакДинамический;
	
КонецФункции

Процедура ЗаполнитьПоказательПроцентИзмененияЦены(СтрокаПриемник, ИмяТабличнойЧасти, ИдентификаторВидаЦен, ДатаСреза) 
	
	// имена колонок
	ИмяКолонкиЦенаДо 			= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторВидаЦен, "_ЦенаДо"); 
	ИмяКолонкиЦенаНовая 		= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторВидаЦен, "_ЦенаНовая");
	ИмяКолонкиПроцентИзменения = СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторВидаЦен, "_ПроцентИзменения");  
	ПолеВалютаДо 				= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторВидаЦен, "_ВалютаДо");
	ПолеВалютаНовая 			= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторВидаЦен, "_ВалютаНовая"); 
	
	// значения 
	Цена_До 		= СтрокаПриемник[ИмяКолонкиЦенаДо];
	Цена_Новая 	= СтрокаПриемник[ИмяКолонкиЦенаНовая];
	Валюта_До 	= СтрокаПриемник[ПолеВалютаДо];
	Валюта_Новая 	= СтрокаПриемник[ПолеВалютаНовая];
	
	Если Валюта_До <> Валюта_Новая Тогда

		ЦенаДоВНовойВалюте = ПересчитатьЦенуИзВалютыВВалюту(Цена_До, Валюта_До, Валюта_Новая, ДатаСреза);  
			
		Если ЦенаДоВНовойВалюте > 0 Тогда
			
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = (Цена_Новая - ЦенаДоВНовойВалюте) / ЦенаДоВНовойВалюте * 100;  
			
			Если Цена_Новая = 0 Тогда 
				СтрокаПриемник[ИмяКолонкиПроцентИзменения] = -100;
			КонецЕсли;
		Иначе
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = 0;
		КонецЕсли;  
		
	Иначе

		Если Цена_До > 0 Тогда
			
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = (Цена_Новая - Цена_До) / Цена_До * 100;  
			
			Если Цена_Новая = 0 Тогда 
				СтрокаПриемник[ИмяКолонкиПроцентИзменения] = -100;
			КонецЕсли;
		Иначе
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = 0;
		КонецЕсли;  

	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьЦеновуюГруппуНоменклатурыВТекущейСтроке(ЗначенияРеквизитовЦеновыхГрупп, СтрокаПриемник)
	
	ЦеноваяГруппа = Справочники.ЦеновыеГруппы.ПустаяСсылка();
	
	ДанныеТовара = ЗначенияРеквизитовЦеновыхГрупп.Получить(СтрокаПриемник.Номенклатура); 
	Если ДанныеТовара <> Неопределено Тогда
		ЦеноваяГруппа = ДанныеТовара.ЦеноваяГруппа;
	КонецЕсли;
	
	Возврат ЦеноваяГруппа;
	
КонецФункции

Функция ПолучитьПроцентНаценкиНаБазовыйВидЦенВСтроке_ДинамическийПроцент(ТекущийВидЦен, ЦеноваяГруппа, НайденныеСтроки,
		ИспользоватьРежимПодбора, ПроцентНаценки, ЦенаНоваяТекущийВидЦен, ЦенаНоваяБазовыйВидЦен, ЭтоНовыйДокумент)
	
	РезультатПроцентНаценки = 0;
	
	Если НЕ ЭтоНовыйДокумент Тогда 
 
		РезультатПроцентНаценки = ВычислитьПроцентНаценкиНаБазовыйВидЦенПоФормуле(
			ЦенаНоваяТекущийВидЦен, ЦенаНоваяБазовыйВидЦен);
			
		Возврат РезультатПроцентНаценки;
	КонецЕсли;

	Если ИспользоватьРежимПодбора Тогда 
		РезультатПроцентНаценки = ВычислитьПроцентНаценкиНаБазовыйВидЦенПоФормуле(
			ЦенаНоваяТекущийВидЦен, ЦенаНоваяБазовыйВидЦен);  
			
		Возврат РезультатПроцентНаценки;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЦеноваяГруппа) Тогда 
		
		РезультатПроцентНаценки = ПроцентНаценки; 
		
	ИначеЕсли ЗначениеЗаполнено(ЦеноваяГруппа)
		И ТекущийВидЦен.ЦеновыеГруппы.Количество() = 0 Тогда
		
		РезультатПроцентНаценки = ПроцентНаценки; 
		
	ИначеЕсли ЗначениеЗаполнено(ЦеноваяГруппа) 
		И НайденныеСтроки.Количество() = 0 Тогда
		
		РезультатПроцентНаценки = ПроцентНаценки;
		
	ИначеЕсли ЗначениеЗаполнено(ЦеноваяГруппа) 
		И НайденныеСтроки.Количество() <> 0 Тогда
		
		РезультатПроцентНаценки = НайденныеСтроки[0].Процент; 		
	Иначе
		
		РезультатПроцентНаценки = ВычислитьПроцентНаценкиНаБазовыйВидЦенПоФормуле(
			ЦенаНоваяТекущийВидЦен, ЦенаНоваяБазовыйВидЦен);		
	КонецЕсли; 
	
	Возврат РезультатПроцентНаценки;
	
КонецФункции

Функция ВычислитьПроцентНаценкиНаБазовыйВидЦенПоФормуле(ЦенаНоваяТекущийВидЦен, ЦенаНоваяБазовыйВидЦен)
	
	РезультатПроцентНаценки = 0; 
	
	Если ЦенаНоваяБазовыйВидЦен <> 0 Тогда
		РезультатПроцентНаценки = Окр((ЦенаНоваяТекущийВидЦен / ЦенаНоваяБазовыйВидЦен - 1) * 100, 1);   
	КонецЕсли;
	
	Возврат РезультатПроцентНаценки;
	
КонецФункции

Процедура ЗаполнитьПоказателиИзмененияИНаценкиЗависимыхЦен(СтрокаПриемник, ИмяТабличнойЧасти, 
		ИспользоватьРежимПодбора, ТекущийВидЦен, ИдентификаторБазовыйВидЦен, ПересчетНаценки, 
		ЭтоНовыйДокумент, ЗначенияРеквизитовЦеновыхГрупп, ЗначенияРеквизитовЗависимыхВидовЦен, ДатаСреза) 
	 	
	ДанныеРеквизитовТекущийВидЦен = ЗначенияРеквизитовЗависимыхВидовЦен.Получить(ТекущийВидЦен);
	
	ИдентификаторТекущийВидЦен = ДанныеРеквизитовТекущийВидЦен.ИдентификаторФормул;
	ПроцентНаценки = ?(ДанныеРеквизитовТекущийВидЦен.Процент <> Неопределено, ДанныеРеквизитовТекущийВидЦен.Процент, 0); 
		
	Если НЕ ЗначениеЗаполнено(ИдентификаторТекущийВидЦен) Тогда
		Возврат;
	КонецЕсли;
	
	ЦеноваяГруппа = ПолучитьЦеновуюГруппуНоменклатурыВТекущейСтроке(ЗначенияРеквизитовЦеновыхГрупп, СтрокаПриемник);
	
	// имена колонок
	ИмяКолонкиПроцентИзменения 		= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторТекущийВидЦен, "_ПроцентИзменения");   		
	ИмяКолонкиПроцентНаценки			= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторТекущийВидЦен, "_ПроцентНаценки");  
	
	ИмяКолонкиЦенаНовая_БазовыйВидЦен 	= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторБазовыйВидЦен, "_ЦенаНовая");
	ИмяКолонкиЦенаДо_БазовыйВидЦен 		= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторБазовыйВидЦен, "_ЦенаДо"); 
	
	ИмяКолонкиЦенаНовая_ТекущийВидЦен 	= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторТекущийВидЦен, "_ЦенаНовая");
	ИмяКолонкиЦенаДо_ТекущийВидЦен 		= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторТекущийВидЦен, "_ЦенаДо");   
	
	// колонки валюта
	ПолеВалютаДо 						= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторТекущийВидЦен, "_ВалютаДо");
	ПолеВалютаНовая 					= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, ИдентификаторТекущийВидЦен, "_ВалютаНовая"); 
	
	// значения цены в базовом виде цен
	ЗначениеЦенаДо_БазовыйВидЦен 		= СтрокаПриемник[ИмяКолонкиЦенаДо_БазовыйВидЦен];
	ЗначениеЦенаНовая_БазовыйВидЦен 	= СтрокаПриемник[ИмяКолонкиЦенаНовая_БазовыйВидЦен];  
	
	// значения цены в текущем(зависимом) виде цен
	ЗначениеЦенаДо_ТекущийВидЦен 		= СтрокаПриемник[ИмяКолонкиЦенаДо_ТекущийВидЦен];
	ЗначениеЦенаНовая_ТекущийВидЦен 	= СтрокаПриемник[ИмяКолонкиЦенаНовая_ТекущийВидЦен]; 
	
	// значения валюты
	Валюта_До 		= СтрокаПриемник[ПолеВалютаДо];
	Валюта_Новая 		= СтрокаПриемник[ПолеВалютаНовая];
    Цена_До 			= СтрокаПриемник[ИмяКолонкиЦенаДо_ТекущийВидЦен];
	Цена_Новая 		= СтрокаПриемник[ИмяКолонкиЦенаНовая_ТекущийВидЦен];
	
	// % изменения  	
	Если Валюта_До <> Валюта_Новая Тогда
		
		ЦенаДоВНовойВалюте = ПересчитатьЦенуИзВалютыВВалюту(Цена_До, Валюта_До, Валюта_Новая, ДатаСреза);  
			
		Если ЦенаДоВНовойВалюте > 0  Тогда
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = (Цена_Новая - ЦенаДоВНовойВалюте) / ЦенаДоВНовойВалюте * 100;  
		Иначе 
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = 0;
		КонецЕсли; 
		
	Иначе  
		
		Если Цена_До > 0  Тогда
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = (Цена_Новая - Цена_До) / Цена_До * 100;  
		Иначе 
			СтрокаПриемник[ИмяКолонкиПроцентИзменения] = 0;
		КонецЕсли;     
		
	КонецЕсли;
	
	// % наценки    
	Если ПересчетНаценки Тогда 
		
		НайденныеСтроки = ТекущийВидЦен.ЦеновыеГруппы.НайтиСтроки(Новый Структура("ЦеноваяГруппа", ЦеноваяГруппа));
		
		Если ТекущийВидЦен.ТипВидаЦен = Перечисления.ТипыВидовЦен.ДинамическийПроцент Тогда
			
			РезультатПроцентНаценки = ПолучитьПроцентНаценкиНаБазовыйВидЦенВСтроке_ДинамическийПроцент(ТекущийВидЦен, 
				ЦеноваяГруппа, НайденныеСтроки, ИспользоватьРежимПодбора, ПроцентНаценки, 
					ЗначениеЦенаНовая_ТекущийВидЦен, ЗначениеЦенаНовая_БазовыйВидЦен, ЭтоНовыйДокумент); 
					
			
		ИначеЕсли ТекущийВидЦен.ТипВидаЦен = Перечисления.ТипыВидовЦен.ДинамическийФормула Тогда
			
			Если ЗначениеЦенаНовая_БазовыйВидЦен > 0 Тогда
									
				РезультатПроцентНаценки = ВычислитьПроцентНаценкиНаБазовыйВидЦенПоФормуле(
					ЗначениеЦенаНовая_ТекущийВидЦен, ЗначениеЦенаНовая_БазовыйВидЦен);
					
			Иначе
				РезультатПроцентНаценки = 0;
			КонецЕсли; 
			
		КонецЕсли;
	
		Если РезультатПроцентНаценки <> Неопределено Тогда
			СтрокаПриемник[ИмяКолонкиПроцентНаценки] = РезультатПроцентНаценки;
		Иначе
			СтрокаПриемник[ИмяКолонкиПроцентНаценки] = 0;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция СодержитЗависимыеВидЦен(Знач ИдентификаторВидаЦен, Знач ЗначенияЗависимыхИдентификаторов)
	
	Результат = Ложь;
	
	Для Каждого ТекЭлемент Из ЗначенияЗависимыхИдентификаторов Цикл
		
		Если ИдентификаторВидаЦен = ТекЭлемент.Значение Тогда 
			Результат = Истина;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура КопироватьДобавлениемСтрокТаблицЗначений(ТаблицаИсточник, ТаблицаПриемник, ПараметрыКопирования) Экспорт 
	
	Перем ИмяТабличнойЧасти, ВыбранныеВидыЦен, ЗаполнитьТекущиеЦены, ИменаКолонокКопирования, 
		ИменаКолонокИсключений, МаксимальныйКлючСвязи, МаксимальныйКлючСвязиПослеДобавления, 
		ПоДокументу, ИспользоватьРежимПодбора;
	
	ЗначенияИдентификаторовВидовЦен = ?(ПараметрыКопирования.Свойство("ЗначенияИдентификаторовВидовЦен"), 
		ПараметрыКопирования.ЗначенияИдентификаторовВидовЦен, Неопределено);
		
	Если ТипЗнч(ТаблицаИсточник) = Тип("ТаблицаЗначений")
		И ТипЗнч(ТаблицаПриемник) = Тип("ТаблицаЗначений") Тогда
		
		ТаблицаКопирования 	= ТаблицаИсточник.Скопировать();
		ТекДатаСеанса 		= ТекущаяДатаСеанса();
		
		ПараметрыКопирования.Свойство("МаксимальныйКлючСвязи", МаксимальныйКлючСвязи);
		ПараметрыКопирования.Свойство("МаксимальныйКлючСвязиПослеДобавления", МаксимальныйКлючСвязиПослеДобавления);	
		ПараметрыКопирования.Свойство("ИменаКолонокКопирования", ИменаКолонокКопирования);
		ПараметрыКопирования.Свойство("ИменаКолонокИсключений", ИменаКолонокИсключений);
		
		Если НЕ ЗначениеЗаполнено(ПараметрыКопирования.Период) Тогда
			ПараметрыКопирования.Период = ТекДатаСеанса;	
		КонецЕсли;
		
		// локальные переменные   
		ВалютаПоУмолчанию		= Константы.ВалютаУчета.Получить(); 	
		ВалютаОснования 		= ?(ПараметрыКопирования.Свойство("ВалютаОснования")	, ПараметрыКопирования.ВалютаОснования, Неопределено); 
		ДатаДокумента 		= ?(ПараметрыКопирования.Свойство("ДатаДокумента")	, ПараметрыКопирования.ДатаДокумента, ТекДатаСеанса);
		ДатаСреза 			= ?(ПараметрыКопирования.Период <> Дата(1, 1, 1)		, ПараметрыКопирования.Период, ТекДатаСеанса);      	  																   
		ПоДокументу 			= ?(ПараметрыКопирования.Свойство("ПоДокументу")		, ПараметрыКопирования.ПоДокументу, Ложь);  
		ДокументОснование 	= ?(ПараметрыКопирования.Свойство("ДокументОснование"), ПараметрыКопирования.ДокументОснование, Неопределено); 
		ВклПроцентНаценки 	= ?(ПараметрыКопирования.Свойство("ОтображатьПроцентНаценки"), ПараметрыКопирования.ОтображатьПроцентНаценки, Ложь); 
		ЗначенияЗависимыхИдентификаторов = ?(ПараметрыКопирования.Свойство("ЗначенияЗависимыхИдентификаторов"), ПараметрыКопирования.ЗначенияЗависимыхИдентификаторов, Неопределено);
		
		МассивВидовЦенИзОснования 	= ?(ПараметрыКопирования.Свойство("МассивВидовЦенЗаполнятьИзОснования"), 
			ПараметрыКопирования.МассивВидовЦенЗаполнятьИзОснования, Неопределено); 			 
		// локальные переменные

		ВалютаПоУмолчанию = Константы.ВалютаУчета.Получить(); 
		
		// параметры пересчета
		ПараметрыПересчета = Новый Структура;
		ПараметрыПересчета.Вставить("ВалютаПоУмолчанию"	, ВалютаПоУмолчанию);
		ПараметрыПересчета.Вставить("ДатаСреза"			, ДатаСреза);   
		
		ИменаРеквизитов = "ТипВидаЦен, ИдентификаторФормул, ВалютаЦены, ЗаполнятьИзОснования, НесколькоВалютДляЦен, ЦенаВключаетНДС";	
		ЗначенияРеквизитовВидовЦен = Неопределено;
		
		МассивВыбранныхВидовЦен = СформироватьМассивВидовЦенИзКоллекции(ПараметрыКопирования.ВыбранныеВидыЦен);		
		Если МассивВыбранныхВидовЦен <> Неопределено Тогда 	
			ЗначенияРеквизитовВидовЦен = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивВыбранныхВидовЦен, ИменаРеквизитов); 	
		КонецЕсли;  
		 
		ЗначенияРеквизитовВидовЦенОснования = Неопределено;    	
		Если МассивВидовЦенИзОснования <> Неопределено Тогда 		
			ЗначенияРеквизитовВидовЦенОснования = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивВидовЦенИзОснования, ИменаРеквизитов); 		
		КонецЕсли;  
		   	
		ПараметрыПересчета.Вставить("ЗначенияРеквизитовВидовЦен", ЗначенияРеквизитовВидовЦен);
		ПараметрыПересчета.Вставить("ЗначенияРеквизитовВидовЦенОснования", ЗначенияРеквизитовВидовЦенОснования);
		// параметры пересчета
		
		ТаблицаЦенАвансовый = Неопределено;
		Если ПараметрыКопирования.Свойство("ДокументОснование") 
			И ЗначениеЗаполнено(ДокументОснование) 
			И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АвансовыйОтчет") Тогда
			
			ТаблицаЦенАвансовый = ТаблицаЦенПоАвансовомуОтчету(ДокументОснование, МассивВидовЦенИзОснования); 
		
		КонецЕсли;
		
		ЕстьПолеИндексКартинки = ТаблицаПриемник.Колонки.Найти("ИндексКартинки") <> Неопределено;
		ЕстьПолеЛупа = ТаблицаПриемник.Колонки.Найти("Лупа") <> Неопределено;
		
		ПараметрыКопирования.Свойство("ЗаполнитьТекущиеЦены", ЗаполнитьТекущиеЦены);
		ЗаполнитьТекущиеЦены = ?(ЗаполнитьТекущиеЦены = Неопределено, Ложь, ЗаполнитьТекущиеЦены);
		
		ТаблицаЦен = ?(ПараметрыКопирования.Свойство("ТаблицаЦен"), ПараметрыКопирования.ТаблицаЦен, Неопределено);
		
		Если ПараметрыКопирования.Свойство("ЗаполнятьНаОснованиеПрихода")
			И ПараметрыКопирования.ЗаполнятьНаОснованиеПрихода Тогда 
			
			Если ТаблицаЦен <> Неопределено Тогда 
				
				МассивВидовЦен = ТаблицаЦен.ВыгрузитьКолонку("ВидЦены");
				ЗначенияПравилОкругления = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивВидовЦен, "ПорядокОкругления");
				СтандартныйПорядокОкругления = Перечисления.ПорядкиОкругления.Окр0_01;
				
				Для Каждого ТекСтрока Из ТаблицаЦен Цикл
					
					ПравилоОкругления = ЗначенияПравилОкругления.Получить(ТекСтрока.ВидЦены);
					Если ПравилоОкругления <> Неопределено Тогда
						Если ПравилоОкругления.ПорядокОкругления <> СтандартныйПорядокОкругления Тогда
							ТекСтрока.Цена = ЦенообразованиеСервер.ОкруглитьЦенуПоВидуЦен(ТекСтрока.Цена, ТекСтрока.ВидЦены);
						КонецЕсли; 
					КонецЕсли;
				КонецЦикла; 
			КонецЕсли;    
			
		КонецЕсли;

		Если ЗаполнитьТекущиеЦены Тогда
			
			ПараметрыКопирования.Свойство("ИмяТабличнойЧасти", ИмяТабличнойЧасти);
			ПараметрыКопирования.Свойство("ВыбранныеВидыЦен", ВыбранныеВидыЦен);
			
			ДобавитьИЗаполнитьКолонкиТекущихЦен(ВыбранныеВидыЦен, ИмяТабличнойЧасти, ТаблицаИсточник,
				ТаблицаКопирования, ТаблицаЦен, ПараметрыКопирования);
			
		КонецЕсли;
		
		Если ПараметрыКопирования.Свойство("РежимПодбор")
			И ПараметрыКопирования.РежимПодбор 
			И ПараметрыКопирования.ЭтоНовый Тогда 
			
			ИспользоватьРежимПодбора = Истина; 
		Иначе
			ИспользоватьРежимПодбора = Ложь;
		КонецЕсли;
		
		МассивНоменклатуры = ОбщегоНазначенияПереопределяемый.УдалитьПовторяющиесяЭлементыМассива(
			ТаблицаКопирования.ВыгрузитьКолонку("Номенклатура")); 
			
		ЗначенияРеквизитовЦеновыхГрупп = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивНоменклатуры, "ЦеноваяГруппа");
		
		ЗаполнениеИзПодменюЗаполнить = ПараметрыКопирования.Свойство("ЗаполнениеИзПодменюЗаполнить") 
			И ЗначениеЗаполнено(ПараметрыКопирования.ЗаполнениеИзПодменюЗаполнить);
		
		РежимПодбор = ПараметрыКопирования.Свойство("РежимПодбор") И ПараметрыКопирования.РежимПодбор;
		ЦеныПоВыбраннымТипамЦен = Неопределено;
		Если РежимПодбор Тогда
			
			Если ПараметрыКопирования.ЭтоНовый Тогда
				ПериодСреза = ТекДатаСеанса;
			Иначе
				ПериодСреза = ПараметрыКопирования.Период; 
			КонецЕсли;
			
			ЦеныПоВыбраннымТипамЦен = ПолучитьЦеныПоВидамЦен(ТаблицаЦен, ПараметрыКопирования, ПериодСреза, 
				ВыбранныеВидыЦен, МассивНоменклатуры);  
				
			Если ЦеныПоВыбраннымТипамЦен.Количество() > 5000 Тогда 
				ЦеныПоВыбраннымТипамЦен.Индексы.Добавить("Номенклатура, Характеристика, ВидЦен");		
			КонецЕсли; 
				
		КонецЕсли;
		
		ТипВидаЦенПроизвольныйЗапрос 	= Перечисления.ТипыВидовЦен.ПроизвольныйЗапрос;
		ТипВидаЦенРасширение 			= Перечисления.ТипыВидовЦен.Расширение;
		ПустаяНоменклатура			= Справочники.Номенклатура.ПустаяСсылка();
		ПустаяХарактеристика			= Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
		ПустойВидЦен 					= Справочники.ВидыЦен.ПустаяСсылка();
		
		ПараметрыОтборНоменклатура = Новый Структура(); 
		ПараметрыОтборНоменклатура.Вставить("Номенклатура"	, ПустаяНоменклатура);						
		ПараметрыОтборНоменклатура.Вставить("ВидЦены"		, Справочники.ВидыЦен.ПустаяСсылка()); 
		
		ПараметрыОтборЦен = Новый Структура;
		ПараметрыОтборЦен.Вставить("Номенклатура"	, ПустаяНоменклатура);
		ПараметрыОтборЦен.Вставить("Характеристика"	, ПустаяХарактеристика);
		
		ПараметрыОтборМВалюта = Новый Структура;
		ПараметрыОтборМВалюта.Вставить("Номенклатура"		, ПустаяНоменклатура); 
		ПараметрыОтборМВалюта.Вставить("Характеристика"		, ПустаяХарактеристика);
		ПараметрыОтборМВалюта.Вставить("ВидЦены"				, ПустойВидЦен); 
		
		Для Каждого СтрокаИсточник Из ТаблицаКопирования Цикл
			
			Если НЕ ПоДокументу
				И ЦенообразованиеСерверПовтИсп.НоменклатураЗапрещенаКУстановкеЦены(СтрокаИсточник.Номенклатура) Тогда
				
				ТекстСообщения = СтрШаблон(
					НСтр("ru = 'Номенклатура %1 является сертификатом. Невозможно добавить в документ.'"),
					СтрокаИсточник.Номенклатура);
					
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);		
				Продолжить;
				
			КонецЕсли;
			
			НоваяСтрока = ТаблицаПриемник.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточник, ИменаКолонокКопирования, ИменаКолонокИсключений);
			
			ПараметрыОтборЦен.Номенклатура = СтрокаИсточник.Номенклатура;
			ПараметрыОтборЦен.Характеристика = СтрокаИсточник.Характеристика;
			
			Если ПараметрыКопирования.Свойство("ВыбранныеВидыЦен") Тогда
				
				КоллекцияВидовЦен = ПараметрыКопирования.ВыбранныеВидыЦен;
				
				Для Каждого СтрокаВидыЦен Из КоллекцияВидовЦен Цикл 
					
					ТекущийВидЦен = СтрокаВидыЦен.Ключ;  
					КолекцияЗависимыеВидыЦен = СтрокаВидыЦен.Значение;  
					
					Если ЗначенияРеквизитовВидовЦен <> Неопределено 
						И ЗначенияРеквизитовВидовЦен[ТекущийВидЦен] <> Неопределено Тогда
							
						ИдентификаторВидаЦен = ЗначенияРеквизитовВидовЦен[ТекущийВидЦен]["ИдентификаторФормул"];					// АПК:1036 проверка орфографии не требуется.
										
					ИначеЕсли ЗначенияИдентификаторовВидовЦен <> Неопределено
						И ЗначенияИдентификаторовВидовЦен[ТекущийВидЦен] <> Неопределено Тогда
							
						ИдентификаторВидаЦен = ЗначенияИдентификаторовВидовЦен[ТекущийВидЦен]["ИдентификаторФормул"];
						
					Иначе
						
						//@skip-check bsl-legacy-check-string-literal
						ИдентификаторВидаЦен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
								ТекущийВидЦен, "ИдентификаторФормул");														// АПК:1036 проверка орфографии не требуется.			
					КонецЕсли;
					
					Если НЕ ЗначениеЗаполнено(ИдентификаторВидаЦен) Тогда
						Продолжить;
					КонецЕсли;
					
					Если НЕ ПараметрыКопирования.ЭтоНовый И ВклПроцентНаценки
						И ИдентификаторВидаЦен <> Неопределено И ЗначенияРеквизитовВидовЦенОснования <> Неопределено
						И СодержитЗависимыеВидЦен(ИдентификаторВидаЦен, ЗначенияЗависимыхИдентификаторов) Тогда 
						
						ПересчитатьПроцентНаценкиПоВидуЦен(НоваяСтрока, ИдентификаторВидаЦен, ЗначенияРеквизитовВидовЦенОснования, 
							ЗначенияЗависимыхИдентификаторов, ИмяТабличнойЧасти, ДатаСреза); 
							
					КонецЕсли;
					
					ЗаполнитьПоказательПроцентИзмененияЦены(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, 
						КонецДня(ДатаСреза));
						
					Если НЕ ПараметрыКопирования.ЭтоНовый Тогда
						Продолжить;
					КонецЕсли;
					
					ИмяКолонки_ЦенаНовая 	= СтрШаблон("%1%2_ЦенаНовая"	, ИмяТабличнойЧасти, ИдентификаторВидаЦен);
					ИмяКолонки_ЦенаДо 	= СтрШаблон("%1%2_ЦенаДо"		, ИмяТабличнойЧасти, ИдентификаторВидаЦен);
					ИмяКолонки_ВалютаНовая	= СтрШаблон("%1%2_ВалютаНовая"	, ИмяТабличнойЧасти, ИдентификаторВидаЦен);
					ИмяКолонки_ВалютаДо 	= СтрШаблон("%1%2_ВалютаДо"	, ИмяТабличнойЧасти, ИдентификаторВидаЦен);   					
					ИмяКолонки_Дельта 	= СтрШаблон("%1%2_Дельта"		, ИмяТабличнойЧасти, ИдентификаторВидаЦен);
					
					Если ЗначенияРеквизитовВидовЦен <> Неопределено 
						И ЗначенияРеквизитовВидовЦен.Получить(ТекущийВидЦен) <> Неопределено Тогда
						
						ДанныеРеквизитовВидаЦен = ЗначенияРеквизитовВидовЦен[ТекущийВидЦен];
								
					Иначе 
								
						ДанныеРеквизитовВидаЦен = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ТекущийВидЦен, ИменаРеквизитов);
						
					КонецЕсли;	
					
					Если ДанныеРеквизитовВидаЦен = Неопределено Тогда
						Продолжить;
					КонецЕсли;
							  
					ВидЦенЗаполнятьИзОснования 	= ДанныеРеквизитовВидаЦен["ЗаполнятьИзОснования"]; 							// АПК:1036 проверка орфографии не требуется.									
					ВалютаЦены 					= ДанныеРеквизитовВидаЦен["ВалютаЦены"];										// АПК:1036 проверка орфографии не требуется.					
					НесколькоВалютДляЦен 			= ДанныеРеквизитовВидаЦен["НесколькоВалютДляЦен"]; 							// АПК:1036 проверка орфографии не требуется.			
					ТипВидаЦен 					= ДанныеРеквизитовВидаЦен["ТипВидаЦен"]; 									// АПК:1036 проверка орфографии не требуется.						 
					
					КурсКратностьВалютаЦены = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаЦены, ДатаДокумента);
					
					ЦенаВключаетНДС = Ложь; 	
					Если ЗначенияРеквизитовВидовЦен <> Неопределено 
						И ЗначенияРеквизитовВидовЦен[ТекущийВидЦен] <> Неопределено Тогда
						ЦенаВключаетНДС = ЗначенияРеквизитовВидовЦен[ТекущийВидЦен]["ЦенаВключаетНДС"]; 
					КонецЕсли;
						
					Если (ТипВидаЦен = ТипВидаЦенПроизвольныйЗапрос ИЛИ ТипВидаЦен = ТипВидаЦенРасширение)
						И НЕ ВидЦенЗаполнятьИзОснования Тогда				
						Продолжить;		
					КонецЕсли;
							 
					// мультивалютные цены не пересчитываются при вводе на основание
					Если НесколькоВалютДляЦен И ЗначениеЗаполнено(ДокументОснование) Тогда   
						
						Если ЗначениеЗаполнено(ВалютаОснования) Тогда
							НоваяСтрока[ИмяКолонки_ВалютаНовая] = ВалютаОснования;
						КонецЕсли;
						
						ПараметрыОтборМВалюта.Номенклатура 			= СтрокаИсточник.Номенклатура;
						ПараметрыОтборМВалюта.Характеристика 		= СтрокаИсточник.Характеристика;
						ПараметрыОтборМВалюта.ВидЦены 				= ТекущийВидЦен; 
						Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(
							ТаблицаЦен[0], "НесколькоВалютДляЦен") Тогда 
								
							ПараметрыОтборМВалюта.Вставить("НесколькоВалютДляЦен", НесколькоВалютДляЦен); 
						КонецЕсли;


						Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АвансовыйОтчет") Тогда
							МассивНайденныеСтроки = ТаблицаЦенАвансовый.НайтиСтроки(ПараметрыОтборМВалюта);  
						ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
                            	МассивНайденныеСтроки = ТаблицаЦен.НайтиСтроки(ПараметрыОтборМВалюта); 
						Иначе 
							Продолжить;
						КонецЕсли;
											
						// перезаполним с учетом ндс
						Если МассивНайденныеСтроки.Количество() <> 0 Тогда
							
							ПерваяСтрока = МассивНайденныеСтроки[0];
							Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ПерваяСтрока, "Всего") 
								И МассивНайденныеСтроки.Количество() > 0 И ЦенаВключаетНДС 
								И НоваяСтрока[ИмяКолонки_ЦенаНовая] <> МассивНайденныеСтроки[0].Всего Тогда
							
								НоваяСтрока[ИмяКолонки_ЦенаНовая] = МассивНайденныеСтроки[0].Всего;
								НоваяСтрока[ИмяКолонки_ВалютаНовая] = МассивНайденныеСтроки[0].Валюта;

							КонецЕсли;
						
							ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаДокумента));
							ЗаполнитьПоказательПроцентИзмененияЦены(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаСреза)); 
						КонецЕсли;
						
						Продолжить;
						
					КонецЕсли;
							 
					// Заполнение происходит не из подменю "заполнить"
					Если НЕ ЗаполнениеИзПодменюЗаполнить Тогда
						 
						Если РежимПодбор И ЦеныПоВыбраннымТипамЦен <> Неопределено Тогда      
		 					
		    					ПараметрыОтборЦен.Вставить("ВидЦен"	, ТекущийВидЦен);			
		    					МассивСтрок = ЦеныПоВыбраннымТипамЦен.НайтиСтроки(ПараметрыОтборЦен);  		
		    					Если МассивСтрок.Количество() > 0 Тогда 
		    						
		    						НоваяСтрока[ИмяКолонки_ЦенаНовая] = МассивСтрок[0].Цена; 
		    						НоваяСтрока[ИмяКолонки_ВалютаНовая] = МассивСтрок[0].ВалютаЦены;
		    						
		    						Если ПараметрыКопирования.Свойство("ЗначенияЗависимыхИдентификаторов")
		    							И ЗначениеЗаполнено(ПараметрыКопирования.ЗначенияЗависимыхИдентификаторов) Тогда
		    								
		    							ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования,
		    									ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
		    									
		    						КонецЕсли;
		    								
		    						Если НЕ ЗначениеЗаполнено(НоваяСтрока[ИмяКолонки_ЦенаДо]) Тогда
		    							НоваяСтрока[ИмяКолонки_Дельта] = 0;	
		    						КонецЕсли;
		    						
		    					Иначе 
		    						
		    						НоваяСтрока[ИмяКолонки_ЦенаНовая] = 0;
		    						
		    						Если ПараметрыКопирования.Свойство("ЗначенияЗависимыхИдентификаторов") 
		    							И ЗначениеЗаполнено(ПараметрыКопирования.ЗначенияЗависимыхИдентификаторов) Тогда  
		    								
		    							ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования,
		    									ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
		    									
		    						КонецЕсли;
		
		    						Если НЕ ЗначениеЗаполнено(НоваяСтрока[ИмяКолонки_ЦенаДо]) Тогда
		    							НоваяСтрока[ИмяКолонки_Дельта] = 0;	
		    						КонецЕсли;
		    				
		    					КонецЕсли;
	    					
	    					КонецЕсли;
						
						// для вида цен с флагом "заполнять из документа основания" оставляем цену из документа основания.
						Если ВидЦенЗаполнятьИзОснования
							И ПараметрыКопирования.Свойство("ЗаполнятьНаОснованиеПрихода") 
							И ПараметрыКопирования.ЗаполнятьНаОснованиеПрихода
							И ЗначениеЗаполнено(ДокументОснование)
							И ПараметрыКопирования.ЭтоНовый Тогда  
							
							ПараметрыОтборНоменклатура.Номенклатура = НоваяСтрока.Номенклатура;						
							ПараметрыОтборНоменклатура.ВидЦены 		= ТекущийВидЦен;  
							
							Если ЗначениеЗаполнено(СтрокаИсточник.Характеристика) Тогда
								ПараметрыОтборНоменклатура.Вставить("Характеристика", НоваяСтрока.Характеристика);  
							КонецЕсли;  
							
							Если НесколькоВалютДляЦен И ВалютаОснования <> Неопределено Тогда 
								ПараметрыОтборНоменклатура.Вставить("Валюта", ВалютаОснования);
							Иначе 
								ПараметрыОтборНоменклатура.Вставить("Валюта", ВалютаЦены);
							КонецЕсли;

							РезультатСтроки = ТаблицаЦен.НайтиСтроки(ПараметрыОтборНоменклатура);
							Если РезультатСтроки.Количество() > 0 Тогда 
								
								НайденнаяСтрока = РезультатСтроки[0];
								
								Если ЦенаВключаетНДС Тогда
									ЦенаОкр = ЦенообразованиеСервер.ОкруглитьЦенуПоВидуЦен(НайденнаяСтрока.Всего, ТекущийВидЦен);
									НоваяСтрока[ИмяКолонки_ЦенаНовая] 	= ЦенаОкр; 
								Иначе
									ЦенаОкр = ЦенообразованиеСервер.ОкруглитьЦенуПоВидуЦен(НайденнаяСтрока.Цена, ТекущийВидЦен);
									НоваяСтрока[ИмяКолонки_ЦенаНовая] 	= ЦенаОкр; 
								КонецЕсли;
																	
								НоваяСтрока[ИмяКолонки_ВалютаНовая] = НайденнаяСтрока.Валюта; 
								
								ДатаТекущегоДокумента = ?(
									ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НайденнаяСтрока, "ДатаДокумента"), 
										НайденнаяСтрока.ДатаДокумента, ДатаДокумента);
										
								ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаТекущегоДокумента));
															
								Если ЗначениеЗаполнено(КолекцияЗависимыеВидыЦен) Тогда
									
									ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования, 
										ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
									
								КонецЕсли; 
								
							КонецЕсли;
							
						ИначеЕсли ВидЦенЗаполнятьИзОснования 
							И ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АвансовыйОтчет") Тогда
																										
							Если ТаблицаЦенАвансовый <> Неопределено Тогда
								
								ПараметрыОтборНоменклатура.Номенклатура = НоваяСтрока.Номенклатура;			
								ПараметрыОтборНоменклатура.ВидЦены 		= ТекущийВидЦен;

								Если ЗначениеЗаполнено(СтрокаИсточник.Характеристика) Тогда
									ПараметрыОтборНоменклатура.Вставить("Характеристика", НоваяСтрока.Характеристика);
								КонецЕсли;  
								
								Если НесколькоВалютДляЦен И ВалютаОснования <> Неопределено Тогда 
									ПараметрыОтборНоменклатура.Вставить("Валюта", ВалютаОснования);
								Иначе 
									ПараметрыОтборНоменклатура.Вставить("Валюта", ВалютаЦены);
								КонецЕсли;
									
								РезультатСтроки = ТаблицаЦенАвансовый.НайтиСтроки(ПараметрыОтборНоменклатура);
								Если РезультатСтроки.Количество() > 0 Тогда
									
									НайденнаяСтрока = РезультатСтроки[0];
									
									Если ЦенаВключаетНДС Тогда
										НоваяСтрока[ИмяКолонки_ЦенаНовая] = НайденнаяСтрока.Всего; 
									Иначе
										НоваяСтрока[ИмяКолонки_ЦенаНовая] = НайденнаяСтрока.Цена; 
									КонецЕсли;	
																	
									НоваяСтрока[ИмяКолонки_ВалютаНовая] = НайденнаяСтрока.Валюта; 
									
									ДатаТекущегоДокумента = ?(
									ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НайденнаяСтрока, "ДатаДокумента"), 
										НайденнаяСтрока.ДатаДокумента, ДатаДокумента);
									
									ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, 
										КонецДня(ДатаТекущегоДокумента));
									
									Если ЗначениеЗаполнено(КолекцияЗависимыеВидыЦен) Тогда
										
										ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования, 
											ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
										
									КонецЕсли; 
									
								ИначеЕсли НЕ НесколькоВалютДляЦен И РезультатСтроки.Количество() = 0 Тогда 
									
									ПараметрыОтборНоменклатура.Вставить("Валюта", ВалютаОснования);
									РезультатСтроки = ТаблицаЦенАвансовый.НайтиСтроки(ПараметрыОтборНоменклатура);
									НайденнаяСтрока = РезультатСтроки[0];
									
									КурсВалютаЦены = 1; 
									КратностьВалютаЦены = 1;  
									Если ЗначениеЗаполнено(КурсКратностьВалютаЦены) Тогда
										КурсВалютаЦены = КурсКратностьВалютаЦены.Курс;
										КратностьВалютаЦены = КурсКратностьВалютаЦены.Кратность;
									КонецЕсли;
																		
									Если ЦенаВключаетНДС Тогда
										РезультатКонвертации = (НайденнаяСтрока.Всего * НайденнаяСтрока.КурсДокумента / НайденнаяСтрока.КратностьДокумента) 
											/ КурсВалютаЦены * КратностьВалютаЦены;  
									Иначе
										РезультатКонвертации = (НайденнаяСтрока.Цена * НайденнаяСтрока.КурсДокумента / НайденнаяСтрока.КратностьДокумента) 
											/ КурсВалютаЦены * КратностьВалютаЦены; 
									КонецЕсли;	
									
									НоваяСтрока[ИмяКолонки_ЦенаНовая] = Окр(РезультатКонвертации, 2);
									НоваяСтрока[ИмяКолонки_ВалютаНовая] = ВалютаЦены;
									
									
									ДатаТекущегоДокумента = ?(
										ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НайденнаяСтрока, "ДатаДокумента"), 
										НайденнаяСтрока.ДатаДокумента, ДатаДокумента);
									
									ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаТекущегоДокумента));
									
									// Зависимые цены по строке
									Если ЗначениеЗаполнено(КолекцияЗависимыеВидыЦен) Тогда
										
										ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования, 
											ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
										
									КонецЕсли;
									
								КонецЕсли;

								
							КонецЕсли;
						
						Иначе 
							
							Если ПараметрыКопирования.Свойство("ЗаполнятьНаОснованиеПрихода") 
								И ПараметрыКопирования.ЗаполнятьНаОснованиеПрихода 
								И ПараметрыКопирования.ПересчитыватьЦены Тогда
								
								НоваяСтрока[ИмяКолонки_ЦенаНовая] 	= НоваяСтрока[ИмяКолонки_ЦенаДо]; 
								НоваяСтрока[ИмяКолонки_ВалютаНовая] = НоваяСтрока[ИмяКолонки_ВалютаДо];
								
								ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаДокумента));
								
								Если ЗначениеЗаполнено(КолекцияЗависимыеВидыЦен) Тогда
									
									ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования, 
										ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
		
								КонецЕсли;
								
							КонецЕсли;
						КонецЕсли;
					
					КонецЕсли; 
					
					ЗаполнитьПоказательПроцентИзмененияЦены(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаСреза)); 
								
					Если ЗначениеЗаполнено(КолекцияЗависимыеВидыЦен) Тогда 
						
						МассивЗависимыхВидовЦен = СформироватьМассивВидовЦенИзКоллекции(КолекцияЗависимыеВидыЦен);
						ЗначенияРеквизитовЗависимыхВидовЦен = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивЗависимыхВидовЦен, 
							"Процент, ИдентификаторФормул");
						
						ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования, 
										ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);
						
						Для Каждого СтрокаЗависимыхВидовЦен Из КолекцияЗависимыеВидыЦен Цикл
							
							ЗависимыйВидЦен = СтрокаЗависимыхВидовЦен.Ключ; 
							
							ЗначенияРеквизитовЗависимыйВидЦен = ЗначенияРеквизитовЗависимыхВидовЦен[ЗависимыйВидЦен];
							Если ЗначенияРеквизитовЗависимыйВидЦен = Неопределено Тогда
								Продолжить;
							КонецЕсли;
							
							ИмяПроверяемогоСвойства = СтрШаблон("%1%2_ПроцентНаценки", ИмяТабличнойЧасти, 
								ЗначенияРеквизитовЗависимыйВидЦен["ИдентификаторФормул"]); 	
							ЕстьКолонкаПроцентНаценки = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(НоваяСтрока, 
								ИмяПроверяемогоСвойства);
							
							ДинамическийВидЦен = ПолучитьПризнакДинамическийПоВидуЦен(ЗависимыйВидЦен);								
							ПересчетНаценки = ДинамическийВидЦен И ПараметрыКопирования.ОтображатьНаценку И ЕстьКолонкаПроцентНаценки;

							ЗаполнитьПоказателиИзмененияИНаценкиЗависимыхЦен(НоваяСтрока, ИмяТабличнойЧасти, ИспользоватьРежимПодбора, 
								ЗависимыйВидЦен, ИдентификаторВидаЦен, ПересчетНаценки, ПараметрыКопирования.ЭтоНовый, 
									ЗначенияРеквизитовЦеновыхГрупп, ЗначенияРеквизитовЗависимыхВидовЦен, ДатаСреза); 
							
							ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаДокумента)); 
							 			
						КонецЦикла;
								
					КонецЕсли;  
					
					// пересчет валютной			
					Если НЕ НесколькоВалютДляЦен И ВалютаОснования <> ВалютаПоУмолчанию	
						И ПараметрыКопирования.ЭтоНовый 
						И ПараметрыКопирования.Свойство("ДокументОснование")
						И ТипЗнч(ПараметрыКопирования.ДокументОснование) = Тип("ДокументСсылка.ПриходнаяНакладная")
						И ЗначениеЗаполнено(ПараметрыКопирования.ДокументОснование) Тогда
							
						
						ПараметрыПересчета.Вставить("ТекущийВидЦен"				, ТекущийВидЦен);
						ПараметрыПересчета.Вставить("ИдентификаторВидаЦен"		, ИдентификаторВидаЦен);  
						ПараметрыПересчета.Вставить("КолекцияЗависимыеВидыЦен"	, КолекцияЗависимыеВидыЦен);
								
						ПересчетВалютыВРублиПоВидуЦен(НоваяСтрока, ТаблицаЦен, ИмяТабличнойЧасти, ТаблицаПриемник, 
							ПараметрыКопирования, ПараметрыПересчета);
							
					КонецЕсли;
							
				КонецЦикла;	  
			КонецЕсли;
			
			// процент наценки
			Если ВклПроцентНаценки 
				И ИдентификаторВидаЦен <> Неопределено И ЗначенияРеквизитовВидовЦенОснования <> Неопределено
				И СодержитЗависимыеВидЦен(ИдентификаторВидаЦен, ЗначенияЗависимыхИдентификаторов) Тогда
				
				ПересчитатьПроцентНаценкиПоВидуЦен(НоваяСтрока, ИдентификаторВидаЦен, ЗначенияРеквизитовВидовЦенОснования,
					ЗначенияЗависимыхИдентификаторов, ИмяТабличнойЧасти, ДатаСреза);

			КонецЕсли;
			
			НоваяСтрока.ПроверятьЗаполнениеХарактеристики = НоваяСтрока.Номенклатура.ПроверятьЗаполнениеХарактеристики;
			НоваяСтрока.ИспользоватьХарактеристики = НоваяСтрока.Номенклатура.ИспользоватьХарактеристики;
			
			Если ЕстьПолеЛупа Тогда
				НоваяСтрока.Лупа = ?(НоваяСтрока.ИспользоватьХарактеристики, 0, -1);
			КонецЕсли;
			НоваяСтрока.КлючСвязи = МаксимальныйКлючСвязи + СтрокаИсточник.КлючСвязи;
			МаксимальныйКлючСвязиПослеДобавления = МАКС(МаксимальныйКлючСвязиПослеДобавления, МаксимальныйКлючСвязи
				+ СтрокаИсточник.КлючСвязи);
			
			Если ЕстьПолеИндексКартинки Тогда
				
				Если ЗаполнитьТекущиеЦены Тогда
					
					НоваяСтрока.ИндексКартинки =
						?(СтрокаИсточник.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Запас, 2, 0)
						+ ?(СтрокаИсточник.ИспользоватьХарактеристики, 1, 0)
						+ ?(СтрокаИсточник.ПометкаУдаления, 4, 0)
						+ ?(СтрокаИсточник.ЭтоНабор, 8, 0);	
						
				Иначе
					
					НоваяСтрока.ИндексКартинки =
						?(СтрокаИсточник.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Запас, 2, 0)
						+ ?(СтрокаИсточник.Номенклатура.ИспользоватьХарактеристики, 1, 0)
						+ ?(СтрокаИсточник.Номенклатура.ПометкаУдаления, 4, 0)
						+ ?(СтрокаИсточник.Номенклатура.ЭтоНабор, 8, 0);
						
				КонецЕсли;
					
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ПараметрыКопирования.МаксимальныйКлючСвязиПослеДобавления = МаксимальныйКлючСвязиПослеДобавления;
	
КонецПроцедуры

Процедура ПересчетВалютыВРублиПоВидуЦен(НоваяСтрока, ТаблицаЦен, ИмяТабличнойЧасти, ТаблицаПриемник, 
		ПараметрыКопирования, ПараметрыПересчета)
	
	Если ТаблицаЦен.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВалютаПоУмолчанию 					= ПараметрыПересчета.ВалютаПоУмолчанию;
	ТекущийВидЦен 						= ПараметрыПересчета.ТекущийВидЦен;
	ИдентификаторВидаЦен 					= ПараметрыПересчета.ИдентификаторВидаЦен;
	ДатаСреза							= ПараметрыПересчета.ДатаСреза;
	КолекцияЗависимыеВидыЦен 				= ПараметрыПересчета.КолекцияЗависимыеВидыЦен;
	ЗначенияРеквизитовВидовЦен				= ПараметрыПересчета.ЗначенияРеквизитовВидовЦен;
	ЗначенияРеквизитовВидовЦенОснования 	= ПараметрыПересчета.ЗначенияРеквизитовВидовЦенОснования;
	 
	ИмяКолонки_ЦенаНовая 		= СтрШаблон("%1%2_ЦенаНовая", ИмяТабличнойЧасти, ИдентификаторВидаЦен);
	ИмяКолонки_ВалютаНовая 	= СтрШаблон("%1%2_ВалютаНовая", ИмяТабличнойЧасти, ИдентификаторВидаЦен);
	ИмяКолонки_ВалютаДельта 	= СтрШаблон("%1%2_ВалютаДельта", ИмяТабличнойЧасти, ИдентификаторВидаЦен);
	
	Если ИмяТабличнойЧасти = "ТЧНоменклатура" Тогда
		
		ПараметрыСтрокПересчет = Новый Структура; 
		ПараметрыСтрокПересчет.Вставить("Номенклатура"			, НоваяСтрока.Номенклатура);
		ПараметрыСтрокПересчет.Вставить("ВидЦены"				, ТекущийВидЦен);
		ПараметрыСтрокПересчет.Вставить("НесколькоВалютДляЦен"	, Ложь);
		
	Иначе   
		
		ПараметрыСтрокПересчет = Новый Структура; 
		ПараметрыСтрокПересчет.Вставить("Номенклатура"			, НоваяСтрока.Номенклатура);
		ПараметрыСтрокПересчет.Вставить("Характеристика"			, НоваяСтрока.Характеристика);
		ПараметрыСтрокПересчет.Вставить("ВидЦены"				, ТекущийВидЦен);
		ПараметрыСтрокПересчет.Вставить("НесколькоВалютДляЦен"	, Ложь);
		
	КонецЕсли;    
	
	СуществуетКолонкаНесколькоВалют = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ТаблицаЦен[0], "НесколькоВалютДляЦен");
	Если НЕ СуществуетКолонкаНесколькоВалют Тогда 
		ТаблицаЦен.Колонки.Добавить("НесколькоВалютДляЦен");
		ЗначенияРеквизитовВидовЦен = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(ТаблицаЦен.ВыгрузитьКолонку("ВидЦены"), "НесколькоВалютДляЦен"); 	
		Если ЗначенияРеквизитовВидовЦен <> Неопределено Тогда
			Для Каждого СтрокаТЗ Из ТаблицаЦен Цикл 
				СтрокаТЗ.НесколькоВалютДляЦен = ЗначенияРеквизитовВидовЦен[СтрокаТЗ.ВидЦены]["НесколькоВалютДляЦен"]; 
			КонецЦикла;
		КонецЕсли;		
	КонецЕсли;
	
	НайденныеСтрокиДляПересчета  = ТаблицаЦен.НайтиСтроки(ПараметрыСтрокПересчет);                                               
	Если НайденныеСтрокиДляПересчета.Количество() > 0 Тогда
		
		ПерваяСтрока = НайденныеСтрокиДляПересчета[0];
		
		НоваяСтрока[ИмяКолонки_ЦенаНовая] = ПерваяСтрока.Цена;
		
		НоваяСтрока[ИмяКолонки_ВалютаНовая] = ВалютаПоУмолчанию; 
		НоваяСтрока[ИмяКолонки_ВалютаДельта] = ВалютаПоУмолчанию;
		
		ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаСреза));
		
		Если ЗначениеЗаполнено(КолекцияЗависимыеВидыЦен) Тогда  
			
			Для Каждого ЭлементКоллекции Из КолекцияЗависимыеВидыЦен Цикл 
				
				ЗависимыйВидЦен = ЭлементКоллекции.Ключ;
				
				Если ЗначенияРеквизитовВидовЦен <> Неопределено 
					И ЗначенияРеквизитовВидовЦен[ЗависимыйВидЦен] <> Неопределено Тогда  
						 
					ИдентификаторФормул = ЗначенияРеквизитовВидовЦен[ЗависимыйВидЦен]["ИдентификаторФормул"];
					
				ИначеЕсли ЗначенияРеквизитовВидовЦенОснования <> Неопределено 
					И ЗначенияРеквизитовВидовЦенОснования[ЗависимыйВидЦен] <> Неопределено Тогда
						
				 	ИдентификаторФормул = ЗначенияРеквизитовВидовЦенОснования[ЗависимыйВидЦен]["ИдентификаторФормул"];
				 	
				Иначе
					//@skip-check bsl-legacy-check-string-literal
					ИдентификаторФормул = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗависимыйВидЦен, "ИдентификаторФормул"); 
				КонецЕсли;
				
				ИмяКолонки_ВалютаНовая = СтрШаблон("%1%2_ВалютаНовая", ИмяТабличнойЧасти, ИдентификаторФормул);  
				ИмяКолонки_ВалютаДельта = СтрШаблон("%1%2_ВалютаДельта", ИмяТабличнойЧасти, ИдентификаторФормул); 
				
				Если НоваяСтрока[ИмяКолонки_ВалютаНовая] <> ВалютаПоУмолчанию Тогда
					
					НоваяСтрока[ИмяКолонки_ВалютаНовая] = ВалютаПоУмолчанию; 
					НоваяСтрока[ИмяКолонки_ВалютаДельта] = ВалютаПоУмолчанию; 
					
				КонецЕсли;
				
			КонецЦикла;
			
			// пересчет зависимых цен
			ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(НоваяСтрока, ТаблицаПриемник, ПараметрыКопирования, 
				ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти);  
				
			// пересчет дельты
			Для Каждого ЭлементКоллекции Из КолекцияЗависимыеВидыЦен Цикл  
				
				ЗависимыйВидЦен = ЭлементКоллекции.Ключ;
				
				Если ЗначенияРеквизитовВидовЦен <> Неопределено 
					И ЗначенияРеквизитовВидовЦен[ЗависимыйВидЦен] <> Неопределено Тогда   
						
					ИдентификаторФормул = ЗначенияРеквизитовВидовЦен[ЗависимыйВидЦен]["ИдентификаторФормул"];
					
				ИначеЕсли ЗначенияРеквизитовВидовЦенОснования <> Неопределено 
					И ЗначенияРеквизитовВидовЦенОснования[ЗависимыйВидЦен] <> Неопределено Тогда
						
				 	ИдентификаторФормул = ЗначенияРеквизитовВидовЦенОснования[ЗависимыйВидЦен]["ИдентификаторФормул"];
				
				Иначе
					//@skip-check bsl-legacy-check-string-literal
					ИдентификаторФормул = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗависимыйВидЦен, "ИдентификаторФормул"); 
				КонецЕсли;   
				
				ПересчитатьДельту(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаСреза));
				ЗаполнитьПоказательПроцентИзмененияЦены(НоваяСтрока, ИмяТабличнойЧасти, ИдентификаторВидаЦен, КонецДня(ДатаСреза)); 	
			КонецЦикла; 
			
		КонецЕсли;
		
	КонецЕсли;  

КонецПроцедуры

Функция ПересчитатьЦенуИзВалютыВВалюту(Знач Цена, ИсходнаяВалюта, НоваяВалюта, ДатаСреза) Экспорт
	
	Отбор = Новый Структура;  
	
	// Текущий курс
	Отбор.Вставить("Валюта", ИсходнаяВалюта);
	ПараметрыТекущегоКурса =  РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДатаСреза, Отбор); 
	ПараметрыТекущегоКурса.Вставить("Валюта", ИсходнаяВалюта);

	// Новый курс
	Отбор.Вставить("Валюта", НоваяВалюта);
	ПараметрыНовогоКурса = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДатаСреза, Отбор);   
	ПараметрыНовогоКурса.Вставить("Валюта", НоваяВалюта);
	
	Если ПараметрыТекущегоКурса <> Неопределено И ПараметрыНовогоКурса <> Неопределено Тогда
		Возврат РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(Цена, ПараметрыТекущегоКурса, ПараметрыНовогоКурса);
	Иначе
		Возврат Цена;
	КонецЕсли;

КонецФункции

Процедура ПересчитатьДельту(ДанныеТекущейСтроки, ИмяТабличнойЧасти, Идентификатор, ДатаСреза)

	ПолеДельта 			= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, Идентификатор, "_Дельта");
	ПолеВалютаДельта 		= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, Идентификатор, "_ВалютаДельта");
	ПолеДельтаКартинка 	= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, Идентификатор, "_ДельтаКартинка"); 
	ПолеЦенаНовая 		= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, Идентификатор, "_ЦенаНовая"); 
	ПолеЦенаДо 			= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, Идентификатор, "_ЦенаДо");
	ПолеВалютаДо 			= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, Идентификатор, "_ВалютаДо");
	ПолеВалютаНовая 		= СтрШаблон("%1%2%3", ИмяТабличнойЧасти, Идентификатор, "_ВалютаНовая"); 
	
	ВалютаДо 	= ДанныеТекущейСтроки[ПолеВалютаДо];
	ВалютаНовая = ДанныеТекущейСтроки[ПолеВалютаНовая];

	Если ДанныеТекущейСтроки[ПолеВалютаДо] <> ДанныеТекущейСтроки[ПолеВалютаНовая] Тогда

		ЦенаДоВНовойВалюте = ПересчитатьЦенуИзВалютыВВалюту(ДанныеТекущейСтроки[ПолеЦенаДо], ВалютаДо, ВалютаНовая, ДатаСреза);  
		
		Если ЦенаДоВНовойВалюте <> 0 Тогда 
			
			ДанныеТекущейСтроки[ПолеВалютаДельта] 	= ДанныеТекущейСтроки[ПолеВалютаНовая];  
			ДанныеТекущейСтроки[ПолеДельта] 		= ДанныеТекущейСтроки[ПолеЦенаНовая] - ЦенаДоВНовойВалюте; 

		Иначе 
			
			ДанныеТекущейСтроки[ПолеДельта] 		= ДанныеТекущейСтроки[ПолеЦенаНовая]; 
			ДанныеТекущейСтроки[ПолеВалютаДельта] 	= ДанныеТекущейСтроки[ПолеВалютаНовая];

		КонецЕсли;

	Иначе

		ДанныеТекущейСтроки[ПолеДельта] = ДанныеТекущейСтроки[ПолеЦенаНовая] - ДанныеТекущейСтроки[ПолеЦенаДо];

	КонецЕсли;
	
	Если ДанныеТекущейСтроки[ПолеДельта] > 0 Тогда
		ДанныеТекущейСтроки[ПолеДельтаКартинка] = 0;
	ИначеЕсли ДанныеТекущейСтроки[ПолеДельта] < 0 Тогда
		ДанныеТекущейСтроки[ПолеДельтаКартинка] = 1;
	Иначе
		ДанныеТекущейСтроки[ПолеДельтаКартинка] = -1;
	КонецЕсли;

КонецПроцедуры

Процедура ПересчитатьИЗаполнитьЗависимыеЦеныПоСтроке(ТекущаяСтрока, ТаблицаПриемник, ПараметрыКопирования, 
	ДатаСреза, ИдентификаторВидаЦен, ИмяТабличнойЧасти)
	
	// 1. подготовим параметры для пересчета 
	ТаблицаРасчета = ПолучитьПустуюТаблицуДляРасчетаЗависимыхЦен();  
	
	//@skip-check bsl-legacy-check-string-literal
	ТаблицаИсточникСЦеной = ТаблицаПриемник.Скопировать(
		Новый Структура("Номенклатура", ТекущаяСтрока["Номенклатура"]));
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НовыеВидыЦен"				, Новый Массив);
	СтруктураПараметров.Вставить("Период"					, ДатаСреза);
	СтруктураПараметров.Вставить("КэшФормул"					, Новый Структура);
	СтруктураПараметров.Вставить("ИдентификаторИсключение"	, ИдентификаторВидаЦен);
	
	ЗаполнитьТаблицуДляРасчетаЗависимыхПоТаблицеБазовых(ТаблицаРасчета, ПараметрыКопирования.ВыбранныеВидыЦен, 
		ИмяТабличнойЧасти, ТаблицаИсточникСЦеной, СтруктураПараметров);
	
	ПараметрыРасчета = Новый Структура; 
	ПараметрыРасчета.Вставить("Период"					, ДатаСреза); 
	ПараметрыРасчета.Вставить("ТаблицаРасчета"			, ТаблицаРасчета); 
	ПараметрыРасчета.Вставить("Автор"					, ПараметрыКопирования.Автор); 
	ПараметрыРасчета.Вставить("ВключаяХарактеристики"		, Истина); 
	ПараметрыРасчета.Вставить("КурсыВалютДокумента"		, ПараметрыКопирования.КурсыВалютДокумента);
	
	// 2. пересчет зависимых цен
	ТаблицаРезультат = РассчитатьЗависимыеЦеныПоБазовой(ПараметрыРасчета);  
	
	Если ТаблицаРезультат.Количество() > 0 Тогда
		
		МассивЗависимыхВидовЦен = ТаблицаРезультат.ВыгрузитьКолонку("ВидЦенРасчетный");
		ИдентификаторыЗависимыхВидовЦен = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
			МассивЗависимыхВидовЦен, "ИдентификаторФормул");
		
		// 3. перезаполнить зависимые цены.  	
		Для Каждого СтрокаРезультат Из ТаблицаРезультат Цикл			
			
			ИдентификаторФормул = ИдентификаторыЗависимыхВидовЦен[СтрокаРезультат.ВидЦенРасчетный].ИдентификаторФормул;
			ИмяПоляЦенаНовая 	= СтрШаблон("%1%2_ЦенаНовая", ИмяТабличнойЧасти, ИдентификаторФормул);  						
			
			ТекущаяСтрока[ИмяПоляЦенаНовая] = СтрокаРезультат.ЗначениеЦеныРасчетной;
			
		КонецЦикла;  
		
	КонецЕсли;

КонецПроцедуры

Функция СтруктуруДереваЗначенийВТаблицуЗначений(ДеревоЗначений)
	
	Результат = Новый ТаблицаЗначений;
	
	Для Каждого Колонка Из ДеревоЗначений.Колонки Цикл
		
		Результат.Колонки.Добавить(Колонка.Имя, Колонка.ТипЗначения);
		
	КонецЦикла;
	
	Результат.Колонки.Добавить("КлючСвязи", Новый ОписаниеТипов("Число"));
	
	Возврат Результат;
КонецФункции

Функция РазобратьДеревоНоменклатуры(ДеревоНоменклатуры, ПоказыватьНедействительныеХарактеристики = Ложь, Запасы = Неопределено) Экспорт
	
	ТаблицаНоменклатуры = СтруктуруДереваЗначенийВТаблицуЗначений(ДеревоНоменклатуры);
	ТаблицаХарактеристик = СтруктуруДереваЗначенийВТаблицуЗначений(ДеревоНоменклатуры);
	
	ДобавитьОбязательныеКолонкиПриРазбореДереваНоменклатуры(ТаблицаНоменклатуры, ТаблицаХарактеристик);
	
	ИспользоватьХарактеристики = ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики");
	
	Если Запасы <> Неопределено Тогда 
		Если ИспользоватьХарактеристики И Запасы.Количество() > 5000 Тогда
			Запасы.Индексы.Добавить("Номенклатура, Характеристика");  
		КонецЕсли;
	КонецЕсли;  
	
	ЛокальныйКлючСвязи = 0;
	
	Для Каждого СтрокаДереваНоменклатура Из ДеревоНоменклатуры.Строки Цикл
		
		Если НЕ ЗначениеЗаполнено(СтрокаДереваНоменклатура.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		
		ЛокальныйКлючСвязи = ЛокальныйКлючСвязи + 1;
		
		НоваяСтрокаНоменклатура = ТаблицаНоменклатуры.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаНоменклатура, СтрокаДереваНоменклатура);
		
		Если НоваяСтрокаНоменклатура.Характеристика = Неопределено Тогда
			НоваяСтрокаНоменклатура.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
		КонецЕсли;		
		НоваяСтрокаНоменклатура.КлючСвязи = ЛокальныйКлючСвязи;
		
		Если ИспользоватьХарактеристики Тогда
			
			Для Каждого СтрокаДереваХарактеристика Из СтрокаДереваНоменклатура.Строки Цикл
				
				Если НЕ ЗначениеЗаполнено(СтрокаДереваХарактеристика.Характеристика) Тогда
					Продолжить;
				КонецЕсли;
				
				Если ИспользоватьХарактеристики
					И НЕ ПоказыватьНедействительныеХарактеристики
					И СтрокаДереваХарактеристика.ХарактеристикаНедействителен Тогда
					
					Продолжить;
					
				КонецЕсли;
				
				Если Запасы <> Неопределено Тогда  
					
					СтруктураПоиска = Новый Структура;
					СтруктураПоиска.Вставить("Номенклатура", СтрокаДереваНоменклатура.Номенклатура);
					СтруктураПоиска.Вставить("Характеристика", СтрокаДереваХарактеристика.Характеристика);
	
					Если Запасы.НайтиСтроки(СтруктураПоиска).Количество() = 0 Тогда
						Продолжить;
					КонецЕсли;
					
				КонецЕсли;
				
				НоваяСтрокаХарактеристика = ТаблицаХарактеристик.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаХарактеристика, СтрокаДереваХарактеристика);
				НоваяСтрокаХарактеристика.КлючСвязи = ЛокальныйКлючСвязи;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Новый Структура("ТаблицаНоменклатуры, ТаблицаХарактеристик", ТаблицаНоменклатуры, ТаблицаХарактеристик);
	
КонецФункции

Функция РазобратьМассивНоменклатуры(МассивНоменклатуры, УстанавливатьХарактеристикамБезЦен,
	ПоказыватьНедействительныеХарактеристики = Ложь, МассивХарактеристик = Неопределено) Экспорт
	
	ДеревоНоменклатуры = Новый ДеревоЗначений;
	
	// 1. Получим СКД
	СхемаКомпоновкиДанных = ПолучитьМакет("ПоНоменклатуре");
	
	// 2. создаем настройки для схемы 
	НастройкиКомпоновкиДанных = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики") Тогда
		
		НастройкиКомпоновкиДанных.Структура[0].Структура[0].Использование = Ложь;
		
	КонецЕсли;

	МассивСсылок = МассивНоменклатуры;
	Если МассивНоменклатуры.Количество() > 0 Тогда 
		
		Если ТипЗнч(МассивНоменклатуры[0]) = Тип("Структура") Тогда	
			
			МассивСсылок = Новый Массив;
			Для Каждого ЭлементМассива Из МассивНоменклатуры Цикл
				МассивСсылок.Добавить(ЭлементМассива.Номенклатура);
			КонецЦикла; 	

		КонецЕсли; 
		
	КонецЕсли;

	// 2.1 установим значения параметров
	ПараметрКД = СхемаКомпоновкиДанных.Параметры.Найти("МассивНоменклатуры");
	ПараметрКД.Значение = МассивСсылок;
	
	// 3. готовим макет 
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновкиДанных, , , Тип(
		"ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	// 4. исполняем макет 
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(Макет);
	ПроцессорКомпоновки.Сбросить();
	
	// 5. выводим результат 
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ДеревоНоменклатуры);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	СтруктураТаблицДанных = РазобратьДеревоНоменклатуры(ДеревоНоменклатуры, ПоказыватьНедействительныеХарактеристики);
	АдресВременногоХранилища = ПоместитьВоВременноеХранилище(СтруктураТаблицДанных);
	
	Возврат АдресВременногоХранилища;
	
КонецФункции

Функция РазобратьМассивНоменклатурыИХарактеристикПоДокументу(Запасы, УстанавливатьХарактеристикамБезЦен,
	ПоказыватьНедействительныеХарактеристики = Ложь) Экспорт
	
	ДеревоНоменклатуры = Новый ДеревоЗначений;	
	СхемаКомпоновкиДанных = ПолучитьМакет("ПоДокументу");
	
	НастройкиКомпоновкиДанных = СхемаКомпоновкиДанных.НастройкиПоУмолчанию; 	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики") Тогда  		
		НастройкиКомпоновкиДанных.Структура[0].Структура[0].Использование = Ложь;   		
	КонецЕсли;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Запасы", Запасы);
	Запрос.Текст =
	"ВЫБРАТЬ 
	|	* 
	|ПОМЕСТИТЬ Запасы
	|ИЗ &Запасы КАК Запасы";
	Запрос.Выполнить();
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновкиДанных, , , Тип(
		"ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(Макет, , , , , МенеджерВременныхТаблиц);
	ПроцессорКомпоновки.Сбросить();
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ДеревоНоменклатуры);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	ТаблицаЦен = Новый ТаблицаЗначений;	
	СхемаКомпоновкиДанных = ПолучитьМакет("ЦеныПоДокументу");
	
	НастройкиКомпоновкиДанных = СхемаКомпоновкиДанных.НастройкиПоУмолчанию; 	
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновкиДанных, , , Тип(
		"ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(Макет, , , , , МенеджерВременныхТаблиц);
	ПроцессорКомпоновки.Сбросить();
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаЦен);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	СтруктураТаблицДанных = РазобратьДеревоНоменклатуры(ДеревоНоменклатуры, ПоказыватьНедействительныеХарактеристики);
	СтруктураТаблицДанных.Вставить("ТаблицаЦен", ТаблицаЦен);
	АдресВременногоХранилища = ПоместитьВоВременноеХранилище(СтруктураТаблицДанных);
	
	Возврат АдресВременногоХранилища;
	
КонецФункции

// Заполнить запасы по виду цен.
// 
// Параметры:
//  МассивВидовЦен - Массив - массив видов цен
//  ПоказыватьХарактеристики - Булево - Показывать характеристики
//  ПериодЗаписи - Неопределено - Период записи
// 
// Возвращаемое значение:
//  Неопределено, ТаблицаЗначений - Заполнить запасы по виду цен
//  
//@skip-check doc-comment-collection-item-type
Функция ЗаполнитьЗапасыПоВидуЦен(Знач МассивВидовЦен, Знач ПоказыватьХарактеристики, ПериодЗаписи = Неопределено) Экспорт 	
	
	Если ПериодЗаписи = Неопределено Тогда
		ПериодЗаписи = ТекущаяДатаСеанса();
	КонецЕсли;    
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦены,
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	|	ЦеныНоменклатурыСрезПоследних.Актуальность КАК Актуальность,
	|	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЦеныНоменклатурыСрезПоследних.ВалютаЦены КАК ВалютаЦены,
	|	ЦеныНоменклатурыСрезПоследних.Период КАК Период
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Период, ВидЦен В (&МассивВидовЦен)) КАК ЦеныНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", КонецДня(ПериодЗаписи));
	Запрос.УстановитьПараметр("МассивВидовЦен", МассивВидовЦен);  
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ЗаписиРегистраЗаПериод = Неопределено;
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		ЗаписиРегистраЗаПериод = РезультатЗапроса.Выгрузить(); 
		
		ЦенообразованиеСервер.ИзменитьЦенуВТаблицеПоПорогамСрабатывания(ЗаписиРегистраЗаПериод, МассивВидовЦен, ПериодЗаписи);
						
	КонецЕсли;
	
	Возврат ЗаписиРегистраЗаПериод;
	
КонецФункции 

// Заполнить запасы по очереди расчета.
// 
// Параметры:
//  ВидЦеныРасчетный - СправочникСсылка.ВидыЦен - Вид цены расчетный
//  ПоказыватьХарактеристики - Булево - Показывать характеристики
//  ПериодЗаписи - Неопределено, Дата - Период записи
// 
// Возвращаемое значение:
//  Неопределено, ТаблицаЗначений - Заполнить запасы по очереди расчета
Функция ЗаполнитьЗапасыПоОчередиРасчета(Знач ВидЦеныРасчетный, Знач ПоказыватьХарактеристики, ПериодЗаписи = Неопределено) Экспорт 	
	
	Если ПериодЗаписи = Неопределено Тогда
		ПериодЗаписи = ПолучитьМаксимальныйПериодЗаписиИзОчереди(ВидЦеныРасчетный);
	КонецЕсли;
	
	Если ПериодЗаписи = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запасы = Новый ТаблицаЗначений; 
	Запасы.Колонки.Добавить("Номенклатура");
	Запасы.Колонки.Добавить("Характеристика");
	Запасы.Колонки.Добавить("ЕдиницаИзмерения");
	Запасы.Колонки.Добавить("ВидЦены");
	Запасы.Колонки.Добавить("Цена");
	Запасы.Колонки.Добавить("ЦенаСтарая"); 
	Запасы.Колонки.Добавить("Валюта");
	Запасы.Колонки.Добавить("ВалютаСтарая");
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("ПериодЗаписи"				, ПериодЗаписи);
	ПараметрыРасчета.Вставить("ВидЦенРасчетный"			, ВидЦеныРасчетный);
	ПараметрыРасчета.Вставить("НомерОчередиЦен"			, 0);
	ПараметрыРасчета.Вставить("УникальныйИдентификатор"	, Новый УникальныйИдентификатор());
	ПараметрыРасчета.Вставить("АдресВХранилище"			, Неопределено);
	ПараметрыРасчета.Вставить("ПересчетЗаТекущийПериод"	, Ложь);     
	ПараметрыРасчета.Вставить("ЗнакСравненияПериода"		, 1);  // 0 - равно, 1 - меньши или равно. 
	
	ВалютаЦены = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыРасчета.ВидЦенРасчетный, "ВалютаЦены");	
	КурсВалюты = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаЦены, ПараметрыРасчета.ПериодЗаписи);
	
	ПараметрыРасчета.Вставить("ВидЦенРасчетныйКурс"		, ?(ЗначениеЗаполнено(КурсВалюты.Курс), КурсВалюты.Курс, 1));
	ПараметрыРасчета.Вставить("ВидЦенРасчетныйКратность"	, ?(ЗначениеЗаполнено(КурсВалюты.Кратность), КурсВалюты.Кратность, 1));
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период"					, ПараметрыРасчета.ПериодЗаписи);
	Запрос.УстановитьПараметр("ВидЦенРасчетный"			, ПараметрыРасчета.ВидЦенРасчетный);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОчередьЦен.ПериодЗаписи КАК ПериодЗаписи,
	|	ОчередьЦен.НомерОчередиЦен КАК НомерОчередиЦен,
	|	ОчередьЦен.ВидЦенРасчетный КАК ВидЦенРасчетный
	|ИЗ
	|	РегистрСведений.ОчередьРасчетаЦен КАК ОчередьЦен
	|ГДЕ
	|	ОчередьЦен.ПериодЗаписи <= &Период
	|	И ОчередьЦен.ВидЦенРасчетный = &ВидЦенРасчетный
	|	И НЕ ОчередьЦен.ПересчетВыполнен
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПериодЗаписи,
	|	НомерОчередиЦен";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТаблицаЗаполнения = Запасы.СкопироватьКолонки();
	
	КолонкиГруппировок = "Номенклатура, Характеристика, ЕдиницаИзмерения, ВидЦены, Цена, ЦенаСтарая";  
	
	Пока Выборка.Следующий() Цикл
		
		ПараметрыРасчета.НомерОчередиЦен = Выборка.НомерОчередиЦен;
		
		ЦеныРассчитаны	= Ложь;
		ОписаниеОшибки	= "";
		
		ТекущийТипВидаЦен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидЦеныРасчетный, "ТипВидаЦен");

		Если ТекущийТипВидаЦен = Перечисления.ТипыВидовЦен.ДинамическийПроцент Тогда
			
			ЦенообразованиеСервер.РасчетДинамическихЦенНаПроцент(ПараметрыРасчета, ЦеныРассчитаны, ОписаниеОшибки, Ложь);
			
		ИначеЕсли ТекущийТипВидаЦен = Перечисления.ТипыВидовЦен.ДинамическийФормула Тогда
			
			ЦенообразованиеСервер.РасчетДинамическихЦенПоФормуле(ПараметрыРасчета, ЦеныРассчитаны, ОписаниеОшибки, Ложь);
			
		КонецЕсли;
		
		Если ЦеныРассчитаны Тогда
									
			ЗаписиРегистраЗаПериод = ПолучитьИзВременногоХранилища(ПараметрыРасчета.АдресВХранилище); 
			
			МассивВидовЦен = Новый Массив;
			МассивВидовЦен.Добавить(Выборка.ВидЦенРасчетный);                                     
			ЦенообразованиеСервер.ИзменитьЦенуВТаблицеПоПорогамСрабатывания(ЗаписиРегистраЗаПериод, МассивВидовЦен, Выборка.ПериодЗаписи);
			
			Для Каждого СтрокаТаблицы Из ЗаписиРегистраЗаПериод Цикл
						
				НоваяСтрока = ТаблицаЗаполнения.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);   
				
				НоваяСтрока.ВидЦены = ВидЦеныРасчетный;
				НоваяСтрока.Цена = СтрокаТаблицы.Цена;   
				
				Если НЕ ПоказыватьХарактеристики Тогда
					ПоказыватьХарактеристики = ЗначениеЗаполнено(НоваяСтрока.Характеристика);
				КонецЕсли;				
				
			КонецЦикла; 
			
			ТаблицаЗаполнения.Свернуть(КолонкиГруппировок); 
			
		КонецЕсли
		
	КонецЦикла; 
		
	Возврат ТаблицаЗаполнения;
	
КонецФункции

Функция ПолучитьМаксимальныйПериодЗаписиИзОчереди(ВидЦенРасчетный)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1
	               |	РС.ПериодЗаписи КАК ПериодЗаписи
	               |ИЗ
	               |	РегистрСведений.ОчередьРасчетаЦен КАК РС
	               |ГДЕ
	               |	РС.ВидЦенРасчетный = &ВидЦенРасчетный
	               |	И РС.ВидЦенРасчетный.КоличествоПопытокСлужебный < 2
	               |	И НЕ РС.ВидЦенРасчетный.РассчитыватьАвтоматически
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	РС.ПериодЗаписи УБЫВ";
	
	Запрос.УстановитьПараметр("ВидЦенРасчетный", ВидЦенРасчетный);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ПериодЗаписи;
	Иначе
		Возврат Неопределено;
	КонецЕсли;	
	
КонецФункции

Процедура ЗаполнитьЦеныРасширенийПоДаннымИБ(Знач ПоказыватьНедействительныеХарактеристики, Знач СтруктураПараметров,
	Знач ТаблицаНоменклатуры, Знач УстанавливатьХарактеристикамБезЦен)

	АдресХранилища = РазобратьМассивНоменклатурыИХарактеристикПоДокументу(ТаблицаНоменклатуры,
		УстанавливатьХарактеристикамБезЦен, ПоказыватьНедействительныеХарактеристики);

	СтруктураЦен = ПолучитьИзВременногоХранилища(АдресХранилища);
	ТаблицаРасчетныхЦенНоменклатуры = ПолучитьТаблицуРасчетныхЦенРасширения(СтруктураЦен.ТаблицаНоменклатуры,
		СтруктураПараметров.ВыбранныеВидыЦен);
	ТаблицаРасчетныхЦенХарактеристик = ПолучитьТаблицуРасчетныхЦенРасширения(СтруктураЦен.ТаблицаХарактеристик,
		СтруктураПараметров.ВыбранныеВидыЦен);

	УстановитьЦеныВТаблицыФормыПослеРасчета(СтруктураПараметров, СтруктураЦен, ТаблицаРасчетныхЦенНоменклатуры,
		ТаблицаРасчетныхЦенХарактеристик, Перечисления.ТипыВидовЦен.Расширение);

КонецПроцедуры

Процедура УстановитьЦеныВТаблицыФормыПослеРасчета(Знач СтруктураПараметров, Знач СтруктураЦен,
	Знач ТаблицаРасчетныхЦенНоменклатуры, Знач ТаблицаРасчетныхЦенХарактеристик, Знач ТипВидаЦен)
	
	Перем ДополнительноеПоле, ЗначениеЦены, ИмяТабличнойЧасти, МассивПолей, ОтборНаФорме, 
		ОтборРасчетныхЦен, ПолеДельта, ПолеЕдиницаИзмерения, ПолеЦенаНовая, ПолеЦенаСтарая, 
		СтрокаТабличнойЧасти, СтрокаЦен, Строки, СтрокиРасчетныхЦен, СтруктураТабличныхЧастей, 
		ТаблицаРасчетныхЦен, ТабличнаяЧасть;
	
	СтруктураТабличныхЧастей = Новый Структура;
	СтруктураТабличныхЧастей.Вставить("ТЧНоменклатура", Новый Структура("ТаблицаРасчетныхЦен, МассивПолей",
		ТаблицаРасчетныхЦенНоменклатуры, Новый Массив));
	
	МассивПолей = Новый Массив;
	МассивПолей.Добавить("Характеристика");
	СтруктураТабличныхЧастей.Вставить("ТЧХарактеристики", Новый Структура("ТаблицаРасчетныхЦен, МассивПолей",
		ТаблицаРасчетныхЦенХарактеристик, МассивПолей));
	
	Для Каждого ТабличнаяЧасть Из СтруктураТабличныхЧастей Цикл
		
		ИмяТабличнойЧасти = ТабличнаяЧасть.Ключ;
		ТаблицаРасчетныхЦен = ТабличнаяЧасть.Значение.ТаблицаРасчетныхЦен;
		
		Для каждого СтрокаЦен Из СтруктураЦен.ТаблицаЦен Цикл
			
			Если СтрокаЦен.ВидЦены.ТипВидаЦен <> ТипВидаЦен Тогда
				Продолжить;
			КонецЕсли;
			
			ПолеЕдиницаИзмерения = ИмяТабличнойЧасти + СтрокаЦен.ВидЦены.ИдентификаторФормул + "_ЕдИзм";
			ПолеЦенаНовая = ИмяТабличнойЧасти + СтрокаЦен.ВидЦены.ИдентификаторФормул + "_ЦенаНовая";
			ПолеЦенаСтарая = ИмяТабличнойЧасти + СтрокаЦен.ВидЦены.ИдентификаторФормул + "_ЦенаДо";
			ПолеДельта = ИмяТабличнойЧасти + СтрокаЦен.ВидЦены.ИдентификаторФормул + "_Дельта";
			ПолеВалютаНовая = ИмяТабличнойЧасти + СтрокаЦен.ВидЦены.ИдентификаторФормул + "_ВалютаНовая";
			ПолеДельтаКартинка = ИмяТабличнойЧасти + СтрокаЦен.ВидЦены.ИдентификаторФормул + "_ДельтаКартинка";
			
			ЗначениеЦены = 0;
			
			ОтборНаФорме = Новый Структура;
			ОтборНаФорме.Вставить("Номенклатура", СтрокаЦен.Номенклатура);
			ОтборНаФорме.Вставить(ПолеЕдиницаИзмерения, СтрокаЦен.ЕдиницаИзмерения);
			
			Для каждого ДополнительноеПоле Из ТабличнаяЧасть.Значение.МассивПолей Цикл
				ОтборНаФорме.Вставить(ДополнительноеПоле, СтрокаЦен[ДополнительноеПоле]);
			КонецЦикла;
			
			Если СтруктураПараметров[ИмяТабличнойЧасти].Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Строки = СтруктураПараметров[ИмяТабличнойЧасти].НайтиСтроки(ОтборНаФорме);
			Для Каждого СтрокаТабличнойЧасти Из Строки Цикл
				
				ВалютаЦены = СтрокаТабличнойЧасти[ПолеВалютаНовая];
				
				ОтборРасчетныхЦен = Новый Структура;
				ОтборРасчетныхЦен.Вставить("Номенклатура", СтрокаЦен.Номенклатура);
				ОтборРасчетныхЦен.Вставить("ВидЦены", СтрокаЦен.ВидЦены);
				
				Для Каждого ДополнительноеПоле Из ТабличнаяЧасть.Значение.МассивПолей Цикл
					ОтборРасчетныхЦен.Вставить(ДополнительноеПоле, СтрокаЦен[ДополнительноеПоле]);
				КонецЦикла;
				
				СтрокиРасчетныхЦен = ТаблицаРасчетныхЦен.НайтиСтроки(ОтборРасчетныхЦен);
				Если СтрокиРасчетныхЦен.Количество() > 0 Тогда
					ЗначениеЦены = СтрокиРасчетныхЦен[0].Цена;
					ВалютаЦены = СтрокиРасчетныхЦен[0].Валюта;
				КонецЕсли;
				
				СтрокаТабличнойЧасти[ПолеЦенаНовая] = ЗначениеЦены;
				СтрокаТабличнойЧасти[ПолеВалютаНовая] = ВалютаЦены;
				СтрокаТабличнойЧасти[ПолеДельта] 	= ЗначениеЦены - СтрокаТабличнойЧасти[ПолеЦенаСтарая];
				Если СтрокаТабличнойЧасти[ПолеДельта] < 0 Тогда
					СтрокаТабличнойЧасти[ПолеДельтаКартинка] = 1;
				ИначеЕсли СтрокаТабличнойЧасти[ПолеДельта] > 0 Тогда
					СтрокаТабличнойЧасти[ПолеДельтаКартинка] = 0;
				Иначе
					СтрокаТабличнойЧасти[ПолеДельтаКартинка] = -1;
				КонецЕсли;
				
				Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти[ПолеЕдиницаИзмерения]) Тогда
					
					СтрокаТабличнойЧасти[ПолеЕдиницаИзмерения] 	= СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ЗаписьНовыхЦен

Процедура ОпределитьЗаписываемыеЦеныКоллекцииНоменклатуры(КоллекцияНоменклатуры, МассивВидовЦен, ПараметрыКоллекции)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КоллекцияНоменклатуры", КоллекцияНоменклатуры);
	Запрос.УстановитьПараметр("ПериодЗаписи", ПараметрыКоллекции.ПериодЗаписи);
	Запрос.УстановитьПараметр("МассивВидовЦен", МассивВидовЦен);
	Запрос.УстановитьПараметр("ДокументУстановки", ПараметрыКоллекции.ДокументУстановки);
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	РСЦены.Период КАК Период,
	|	РСЦены.ВидЦен КАК ВидЦен,
	|	РСЦены.ВалютаЦены КАК ВалютаЦены,
	|	РСЦены.Номенклатура КАК Номенклатура,
	|	РСЦены.Характеристика КАК Характеристика,
	|	РСЦены.Цена КАК Цена,
	|	РСЦены.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	РСЦены.Актуальность КАК Актуальность,
	|	РСЦены.Автор КАК Автор,
	|	РСЦены.ДокументУстановки КАК ДокументУстановки
	|ПОМЕСТИТЬ ТекущиеЗаписиРегистраЦен
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры КАК РСЦены
	|ГДЕ
	|	РСЦены.Период = &ПериодЗаписи
	|	И РСЦены.ВидЦен В(&МассивВидовЦен)
	|	И РСЦены.Цена <> 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидЦен,
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КоллекцияНоменклатуры.Период КАК Период,
	|	КоллекцияНоменклатуры.ВидЦен КАК ВидЦен,
	|	КоллекцияНоменклатуры.ВалютаЦены КАК ВалютаЦены,
	|	КоллекцияНоменклатуры.Номенклатура КАК Номенклатура,
	|	КоллекцияНоменклатуры.Характеристика КАК Характеристика,
	|	КоллекцияНоменклатуры.Цена КАК Цена,
	|	КоллекцияНоменклатуры.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	КоллекцияНоменклатуры.Актуальность КАК Актуальность,
	|	КоллекцияНоменклатуры.Автор КАК Автор,
	|	&ДокументУстановки КАК ДокументУстановки
	|ПОМЕСТИТЬ КоллекцияНоменклатуры
	|ИЗ
	|	&КоллекцияНоменклатуры КАК КоллекцияНоменклатуры
	|ГДЕ
	|	КоллекцияНоменклатуры.Цена <> 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидЦен,
	|	Номенклатура,
	|	Характеристика
	|;/////////////////////////////////////////////////////////////////////";
	
	ТекстЗапросаТекущиеЦены = 
	"
	|// Если по ключевым полям в регистре уже имеется запись, то оставляем ее
	|// 
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ТекущиеЗаписиРегистраЦен.Период, КоллекцияНоменклатуры.Период) КАК Период
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.Актуальность, КоллекцияНоменклатуры.Актуальность) КАК Актуальность
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.ВидЦен, КоллекцияНоменклатуры.ВидЦен) КАК ВидЦен
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.ВалютаЦены, КоллекцияНоменклатуры.ВалютаЦены) КАК ВалютаЦены
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.Номенклатура, КоллекцияНоменклатуры.Номенклатура) КАК Номенклатура
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.Характеристика, КоллекцияНоменклатуры.Характеристика) КАК Характеристика
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.Цена, КоллекцияНоменклатуры.Цена) КАК Цена
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.ЕдиницаИзмерения, КоллекцияНоменклатуры.ЕдиницаИзмерения) КАК ЕдиницаИзмерения
	|	,ЕстьNULL(ТекущиеЗаписиРегистраЦен.Автор, КоллекцияНоменклатуры.Автор) КАК Автор
	|	,ЕстьNULL(КоллекцияНоменклатуры.ДокументУстановки, Значение(Документ.УстановкаЦенНоменклатуры.ПустаяСсылка)) КАК ДокументУстановки
	|ИЗ ТекущиеЗаписиРегистраЦен КАК ТекущиеЗаписиРегистраЦен
	|	ПОЛНОЕ СОЕДИНЕНИЕ КоллекцияНоменклатуры КАК КоллекцияНоменклатуры
	|		ПО ТекущиеЗаписиРегистраЦен.ВидЦен = КоллекцияНоменклатуры.ВидЦен 
	|			И ТекущиеЗаписиРегистраЦен.Номенклатура = КоллекцияНоменклатуры.Номенклатура 
	|			И ТекущиеЗаписиРегистраЦен.Характеристика = КоллекцияНоменклатуры.Характеристика";
	
	ТекстЗапросаНовыеЦены = 
	"
	|// Записываем новые данные в любом случае и добавляем существующие только тогда, когда в таблице нет записей с такими ключами
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(КоллекцияНоменклатуры.Период, ТекущиеЗаписиРегистраЦен.Период) КАК Период
	|	,ЕстьNULL(КоллекцияНоменклатуры.Актуальность, ТекущиеЗаписиРегистраЦен.Актуальность) КАК Актуальность
	|	,ЕстьNULL(КоллекцияНоменклатуры.ВидЦен, ТекущиеЗаписиРегистраЦен.ВидЦен) КАК ВидЦен
	|	,ЕстьNULL(КоллекцияНоменклатуры.ВалютаЦены, ТекущиеЗаписиРегистраЦен.ВалютаЦены) КАК ВалютаЦены
	|	,ЕстьNULL(КоллекцияНоменклатуры.Номенклатура, ТекущиеЗаписиРегистраЦен.Номенклатура) КАК Номенклатура
	|	,ЕстьNULL(КоллекцияНоменклатуры.Характеристика, ТекущиеЗаписиРегистраЦен.Характеристика) КАК Характеристика
	|	,ЕстьNULL(КоллекцияНоменклатуры.Цена, ТекущиеЗаписиРегистраЦен.Цена) КАК Цена
	|	,Выбор КОГДА КоллекцияНоменклатуры.Цена = ТекущиеЗаписиРегистраЦен.Цена
	|		ТОГДА ЕСТЬNULL(ТекущиеЗаписиРегистраЦен.ЕдиницаИзмерения, КоллекцияНоменклатуры.ЕдиницаИзмерения)
	|		ИНАЧЕ ЕСТЬNULL(КоллекцияНоменклатуры.ЕдиницаИзмерения, ТекущиеЗаписиРегистраЦен.ЕдиницаИзмерения) КОНЕЦ КАК ЕдиницаИзмерения
	|	,Выбор КОГДА КоллекцияНоменклатуры.Цена = ТекущиеЗаписиРегистраЦен.Цена
	|		ТОГДА ЕСТЬNULL(ТекущиеЗаписиРегистраЦен.Автор, КоллекцияНоменклатуры.Автор)
	|		ИНАЧЕ ЕСТЬNULL(КоллекцияНоменклатуры.Автор, ТекущиеЗаписиРегистраЦен.Автор) КОНЕЦ КАК Автор
	|	,ЕстьNULL(КоллекцияНоменклатуры.ДокументУстановки, ЕСТЬNULL(ТекущиеЗаписиРегистраЦен.ДокументУстановки, Значение(Документ.УстановкаЦенНоменклатуры.ПустаяСсылка))) КАК ДокументУстановки
	|ИЗ ТекущиеЗаписиРегистраЦен КАК ТекущиеЗаписиРегистраЦен
	|	ПОЛНОЕ СОЕДИНЕНИЕ КоллекцияНоменклатуры КАК КоллекцияНоменклатуры
	|		ПО ТекущиеЗаписиРегистраЦен.ВидЦен = КоллекцияНоменклатуры.ВидЦен 
	|			И ТекущиеЗаписиРегистраЦен.Номенклатура = КоллекцияНоменклатуры.Номенклатура 
	|			И ТекущиеЗаписиРегистраЦен.Характеристика = КоллекцияНоменклатуры.Характеристика";
	
	Запрос.Текст = ТекстЗапроса + ?(ПараметрыКоллекции.ЗаписыватьНовыеЦеныПоверхУстановленных, ТекстЗапросаНовыеЦены,
		ТекстЗапросаТекущиеЦены);
	
	КоллекцияНоменклатуры = Запрос.Выполнить().Выгрузить();
	
КонецПроцедуры

Процедура ДобавитьСтрокуДанныхВКоллекцию(КоллекцияНоменклатуры, МассивВидовЦен, СтрокаДереваДанныхНоменклатура, ПараметрыКоллекции)
	
	Если МассивВидовЦен.Найти(СтрокаДереваДанныхНоменклатура.ВидЦены) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаДереваДанныхНоменклатура.Цена = 0 Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока 						= КоллекцияНоменклатуры.Добавить();
	НоваяСтрока.Период					= ПараметрыКоллекции.ПериодЗаписи;
	НоваяСтрока.ВидЦен					= СтрокаДереваДанныхНоменклатура.ВидЦены;
	НоваяСтрока.Номенклатура			= СтрокаДереваДанныхНоменклатура.Номенклатура;
	НоваяСтрока.ДокументУстановки		= ПараметрыКоллекции.ДокументУстановки;
	НоваяСтрока.ВалютаЦены				= СтрокаДереваДанныхНоменклатура.Валюта;
	
	Если ПараметрыКоллекции.ЕстьКолонкаХарактеристика Тогда
		НоваяСтрока.Характеристика		= СтрокаДереваДанныхНоменклатура.Характеристика;
	КонецЕсли;
	
	НоваяСтрока.Цена					= СтрокаДереваДанныхНоменклатура.Цена;
	НоваяСтрока.ЕдиницаИзмерения		= СтрокаДереваДанныхНоменклатура.ЕдиницаИзмерения;
	НоваяСтрока.Актуальность			= Истина;
	НоваяСтрока.Автор					= ПараметрыКоллекции.АвторизированныйПользователь;
	НоваяСтрока.УстанавливатьХарактеристикамБезЦен	= ПараметрыКоллекции.УстанавливатьХарактеристикамБезЦен;
	
