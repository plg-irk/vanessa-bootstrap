		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	АвансовыйОтчетЗапасы.Номенклатура КАК Номенклатура,
		               |	АвансовыйОтчетЗапасы.Характеристика КАК Характеристика,
