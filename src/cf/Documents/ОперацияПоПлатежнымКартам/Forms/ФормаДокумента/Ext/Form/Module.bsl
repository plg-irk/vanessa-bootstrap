&НаСервереБезКонтекста
Функция ПолучитьСпособОплатыСБП(ДокументОснование)
	
	Перем ТекстОшибки;
	
	Если ЗначениеЗаполнено(ДокументОснование) Тогда
	
		НастройкаСБП = ИнтеграцияСПлатежнымиСистемамиУНФ.ПолучитьНастройкиДокументаДляОплатыСБП(
			ДокументОснование, 
			ТекстОшибки);
			
		Если Не ЗначениеЗаполнено(ТекстОшибки) Тогда
			
			НастройкиИнтеграции = ИнтеграцияСПлатежнымиСистемамиУНФ.НастройкиИнтеграции(
				НастройкаСБП.Организация, 
				НастройкаСБП.ТорговыйОбъект);
			
			Если ЗначениеЗаполнено(НастройкиИнтеграции)
				И НастройкиИнтеграции.Количество() = 1 Тогда
				
				СпособОплатыСБП = НастройкиИнтеграции[0].СпособОплаты;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕСли;	
	
	Возврат СпособОплатыСБП;
	
КонецФункции

