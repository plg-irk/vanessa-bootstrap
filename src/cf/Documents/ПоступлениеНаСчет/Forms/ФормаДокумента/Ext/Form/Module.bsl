&НаСервереБезКонтекста
Функция ПолучитьКурсВалютыНаСервере(ВалютаДоговор, ДатаКурса)
	
	Если ТипЗнч(ВалютаДоговор) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		Валюта = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВалютаДоговор, "ВалютаРасчетов");
	Иначе
		Валюта = ВалютаДоговор;
	КонецЕсли;
	
	Возврат РаботаСКурсамиВалют.ПолучитьКурсВалюты(Валюта, ДатаКурса);
	
КонецФункции

#КонецОбласти

#Область ПродажаВалюты

&НаКлиенте
Процедура ОбработатьИзменениеПродажаВалютыКурсКратность()
	ПродажаВалютыРассчитатьСуммуУчета();
	ОбновитьОтображениеЭлементовПродажаВалюты();
КонецПроцедуры

&НаСервере
Процедура ОбновитьОтображениеЭлементовПродажаВалюты()
	
	ФормыДокументовДеньги.ОбновитьОтображениеЭлементовПродажаВалюты(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура КурсПродажаВалютыОбработкаВыбораЗавершение(ДатаКурса, ДополнительныеПараметры) Экспорт
	
	Если ДатаКурса <> Неопределено Тогда
		КурсНаДату = ПолучитьКурсВалютыНаСервере(Объект.ПродажаВалютыВалюта, ДатаКурса);
		Объект.ПродажаВалютыКурс = КурсНаДату.Курс;
		Объект.ПродажаВалютыКратность = КурсНаДату.Кратность;
		ОбработатьИзменениеПродажаВалютыКурсКратность();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПродажаВалютыРассчитатьСуммуУчета()
	
	Объект.Курс = ?(
		Объект.Курс = 0,
		1,
		Объект.Курс);
	Объект.Кратность = ?(
		Объект.Кратность = 0,
		1,
		Объект.Кратность);
	
	Объект.СуммаУчета = ВалютыУНФКлиентСервер.Пересчитать(Объект.СуммаДокумента, Объект.Курс, Объект.ПродажаВалютыКурс,
		Объект.Кратность, Объект.ПродажаВалютыКратность);
	
КонецПроцедуры

