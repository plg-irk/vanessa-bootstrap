&НаСервереБезКонтекста
Функция ПроверитьЗаполнениеРеквизитовОрганизацииДляРасчетаВзносов(Организация, ДатаАнализа, ТекстВопроса,
	РассчитыватьБезВзносов, Расшифровка)

	УчетНалогов = ПолучитьФункциональнуюОпцию("ВестиУчетНалогаНаДоходыИВзносов");
	Если Не УчетНалогов Тогда
		РассчитыватьБезВзносов = Истина;
		Возврат Истина;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Организации.ИспользуетсяОтчетность,
	|	Организации.ТарифНаТравматизм,
	|	ТарифыСтраховыхВзносов.ВидТарифа
	|ИЗ
	|	Справочник.Организации КАК Организации
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрименяемыеТарифыСтраховыхВзносовУНФ.СрезПоследних(&ДатаАнализа, ) КАК ТарифыСтраховыхВзносов
	|		ПО (ТарифыСтраховыхВзносов.ГоловнаяОрганизация = &Организация)
	|ГДЕ
	|	Организации.Ссылка = &Организация";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ДатаАнализа", ДатаАнализа);

	Расшифровка = Новый Структура;
	Расшифровка.Вставить("ТипРасшифровки", "Объектная");
	Расшифровка.Вставить("ЗначениеРасшифровки", Организация);
	ПоляСОшибками = Новый Соответствие;

	СистемаНалогообложения = РегистрыСведений.СистемыНалогообложенияОрганизаций.ОпределитьСистемуНалогообложенияОрганизации(
	Организация, ТекущаяДатаСеанса());

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если Не Выборка.ИспользуетсяОтчетность Тогда
			РассчитыватьБезВзносов = Истина;
			Возврат Истина;
		Иначе
			ЗаполненТарифНаТравматизм = Выборка.ТарифНаТравматизм > 0 Или (СистемаНалогообложения.ПрименяетсяАУСН
				И РегистрыСведений.РазмерФиксированныхВзносовОтНесчастныхСлучаевАУСН.РазмерФиксированныхВзносовОтНесчастныхСлучаевЗаполнен());

			ЗаполненТарифСтраховыхВзносов = ЗначениеЗаполнено(Выборка.ВидТарифа);
			Если Не ЗаполненТарифНаТравматизм И Не ЗаполненТарифСтраховыхВзносов Тогда
				ТекстВопроса = НСтр(
					"ru = 'В организации не заполнены тариф на травматизм и тариф страховых взносов. Заполнить?'");
				ПоляСОшибками.Вставить("КлючТарифаСтраховыхВзносов.ВидТарифа", НСтр(
					"ru='Не указан тариф страховых взносов'"));
				ПоляСОшибками.Вставить("Объект.ТарифНаТравматизм", НСтр("ru='Не указан тариф на травматизм'"));
				Расшифровка.Вставить("ПараметрыРасшифровки", ПоляСОшибками);

				Возврат Ложь;
			ИначеЕсли Не ЗаполненТарифНаТравматизм Тогда
				ТекстВопроса = НСтр("ru = 'В организации не заполнены тариф на травматизм. Заполнить?'");
				ПоляСОшибками.Вставить("Объект.ТарифНаТравматизм", НСтр("ru='Не указан тариф на травматизм'"));
				Расшифровка.Вставить("ПараметрыРасшифровки", ПоляСОшибками);

				Возврат Ложь;
			ИначеЕсли Не ЗаполненТарифСтраховыхВзносов Тогда
				ТекстВопроса = НСтр("ru = 'В организации не заполнены тариф страховых взносов. Заполнить?'");
				ПоляСОшибками.Вставить("КлючТарифаСтраховыхВзносов.ВидТарифа", НСтр(
					"ru='Не указан тариф страховых взносов'"));
				Расшифровка.Вставить("ПараметрыРасшифровки", ПоляСОшибками);

				Возврат Ложь;
			Иначе
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;

	Иначе
		Возврат Истина;
	КонецЕсли;

КонецФункции

&НаСервереБезКонтекста
Процедура ПолучитьСчетЗатратВзноса(СтруктураПараметров)

	ЗарплатаИПерсоналСлужебный.ПолучитьСчетЗатратВидаНачисления(СтруктураПараметров);
	СтруктураПараметров.СчетЗатрат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
		СтруктураПараметров.ВидНачисленияУдержания, "СчетЗатрат");

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТипСчетаЗатрат(Строка, ТипыСчетовЗатрат)
	
	Если НЕ ЗначениеЗаполнено(Строка.СчетЗатрат) Тогда
		Возврат;
	КонецЕсли;
	
	ТипСчета = ТипыСчетовЗатрат.Получить(Строка.СчетЗатрат);
	Если ТипСчета = Неопределено Тогда
		ТипСчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.СчетЗатрат, "ТипСчета");
		Если ТипСчета = Неопределено Тогда
			ТипСчета = Перечисления.ТипыСчетов.ПустаяСсылка();
		КонецЕсли;
		ТипыСчетовЗатрат.Вставить(Строка.СчетЗатрат, ТипСчета);
	КонецЕсли;
	Строка.ТипСчета = ТипСчета;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораМенюРасшифровки(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт

	Если ВыбранныйЭлемент <> Неопределено И ВыбранныйЭлемент.Значение = "РасшифроватьЗначение" Тогда

		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("Организация", Объект.Организация);
		СтруктураПараметров.Вставить("Сотрудник", ДополнительныеПараметры.Сотрудник);

		Период = Новый СтандартныйПериод;
		Период.ДатаНачала = НачалоМесяца(Объект.ПериодРегистрации);
		Период.ДатаОкончания = КонецМесяца(Объект.ПериодРегистрации);

		СтруктураПараметров.Вставить("Период", Период);
		СтруктураПараметров.Вставить("ДатаПолученияПравил", КонецМесяца(Объект.ПериодРегистрации));

		ПараметрыФормыОтчетаРасшифровки = Новый Структура;
		ПараметрыФормыОтчетаРасшифровки.Вставить("СформироватьПриОткрытии", Истина);
		ПараметрыФормыОтчетаРасшифровки.Вставить("Отбор", СтруктураПараметров);

		ОткрытьФорму("Отчет.РасшифровкаНачисленийПремийПродавцам.Форма", ПараметрыФормыОтчетаРасшифровки, ЭтотОбъект);

	КонецЕсли;

КонецПроцедуры

