	ДанныеСтроки.Вставить("Договор");
	
	ВыплатыКонтрагентПриИзмененииНаСервере(ДанныеСтроки);
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, ДанныеСтроки);
	
