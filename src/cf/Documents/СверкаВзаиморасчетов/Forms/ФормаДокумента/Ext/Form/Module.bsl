&НаКлиенте
Процедура ЗаполнитьОстаткамиНаКлиенте()
	
	ВызватьПроцедуруЗаполненияТабличнойЧасти = Истина;
	
	Если НЕ ЗначениеЗаполнено(Объект.КонецПериода) Тогда
		
		ТекстСообщения	= НСтр("ru = 'Неверно заполнена дата окончания периода.'");
		ПолеСообщения	= "Объект.КонецПериода";
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , ПолеСообщения);
		
		ВызватьПроцедуруЗаполненияТабличнойЧасти = Ложь;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Контрагент) Тогда
		
		ТекстСообщения	= НСтр("ru = 'Не заполнен контрагент.'");
		ПолеСообщения	= "Объект.Контрагент";
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , ПолеСообщения);
		
		ВызватьПроцедуруЗаполненияТабличнойЧасти = Ложь;
		
	КонецЕсли;
	
	Если ВызватьПроцедуруЗаполненияТабличнойЧасти Тогда
		
		Если Объект.ДанныеОрганизации.Количество() > 0 Тогда
			
			ТестВопроса	= НСтр("ru = 'Табличная часть будет очищена и заполнена повторно. Продолжить?'");
			ОписаниеОповещения = Новый ОписаниеОповещения("ОбработчикПослеВопросаООчистке", ЭтотОбъект, "ДанныеОрганизации");
			ПоказатьВопрос(ОписаниеОповещения, ТестВопроса, РежимДиалогаВопрос.ДаНет, 0);
			
		Иначе
			
			ЗаполнитьПоОстаткам();
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРеквизитыПечати()

	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьИзмененияРеквизитовПечати", ЭтотОбъект);
	ОткрытьФорму("Обработка.РеквизитыПечати.Форма.РеквизитыПечатиСверкаВзаиморасчетов", 
		Новый Структура("КонтекстПечати", Объект), ЭтотОбъект, , , , ОписаниеОповещения);
		
КонецПроцедуры 

&НаКлиентеНаСервереБезКонтекста
Процедура ПересчитатьОстатки(Форма)

	Объект = Форма.Объект;
	
	Форма.ОстатокНаНачало = - Объект.СальдоНачалоПериода;
	
	Форма.ОстатокНаКонец = Форма.ОстатокНаНачало
		+ Объект.ДанныеОрганизации.Итог("СуммаДолгКонтрагента")
		- Объект.ДанныеОрганизации.Итог("СуммаДолгОрганизации");
		
	Если Форма.ОстатокНаНачало > 0 Тогда
		Форма.ОстатокНаНачалоПояснение = НСтр("ru='(долг контрагента)'");
	ИначеЕсли Форма.ОстатокНаНачало < 0 Тогда 
		Форма.ОстатокНаНачалоПояснение = НСтр("ru='(долг организации)'");
	Иначе 
		Форма.ОстатокНаНачалоПояснение = "";
	КонецЕсли;
		
	Если Форма.ОстатокНаКонец > 0 Тогда
		Форма.ОстатокНаКонецПояснение = НСтр("ru='(долг контрагента)'");
	ИначеЕсли Форма.ОстатокНаКонец < 0 Тогда 
		Форма.ОстатокНаКонецПояснение = НСтр("ru='(долг организации)'");
	Иначе 
		Форма.ОстатокНаКонецПояснение = "";
	КонецЕсли;
	
	Форма.ОстатокНаНачалоКонтрагент = - Форма.ОстатокНаНачало;

	Форма.ОстатокНаКонецКонтрагент = Форма.ОстатокНаНачалоКонтрагент
		+ Объект.ДанныеКонтрагента.Итог("СуммаДолгКонтрагента")
		- Объект.ДанныеКонтрагента.Итог("СуммаДолгОрганизации");
		
	Если Форма.ОстатокНаНачалоКонтрагент < 0 Тогда
		Форма.ОстатокНаНачалоКонтрагентПояснение = НСтр("ru='(долг контрагента)'");
	ИначеЕсли Форма.ОстатокНаНачалоКонтрагент > 0 Тогда 
		Форма.ОстатокНаНачалоКонтрагентПояснение = НСтр("ru='(долг организации)'");
	Иначе 
		Форма.ОстатокНаНачалоКонтрагентПояснение = "";
	КонецЕсли;
		
	Если Форма.ОстатокНаКонецКонтрагент < 0 Тогда
		Форма.ОстатокНаКонецКонтрагентПояснение = НСтр("ru='(долг контрагента)'");
	ИначеЕсли Форма.ОстатокНаКонецКонтрагент > 0 Тогда 
		Форма.ОстатокНаКонецКонтрагентПояснение = НСтр("ru='(долг организации)'");
	Иначе 
		Форма.ОстатокНаКонецКонтрагентПояснение = "";
	КонецЕсли;
	
	Форма.Расхождение = Форма.ОстатокНаКонец + Форма.ОстатокНаКонецКонтрагент;
	Форма.РасхождениеКонтрагент = - Форма.Расхождение;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьЭлементовПоНастройкеПользователя(Форма)
	
	Элементы = Форма.Элементы;
	
	// Видимость колонок, настроенная пользователем
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеОрганизацииРасчетныйДокумент",
		"Видимость", Форма.ПоказыватьКолонкуРасчетныйДокументВСверкеВзаиморасчетов);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеКонтрагентаРасчетныйДокумент",
		"Видимость", Форма.ПоказыватьКолонкуРасчетныйДокументВСверкеВзаиморасчетов);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеОрганизацииВалютаПоДокументу",
		"Видимость", Форма.ПоказыватьКолонкуВалютаВСверкеВзаиморасчетов);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеКонтрагентаВалютаПоДокументу",
		"Видимость", Форма.ПоказыватьКолонкуВалютаВСверкеВзаиморасчетов);

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуНастройки(ПередаватьВидДокумента)
	
	СтруктураПараметров = Новый Структура;
	
	Если ПередаватьВидДокумента Тогда
		СтруктураПараметров.Вставить("ВидДокумента", НСтр("ru = 'сверки взаиморасчетов'"));
	КонецЕсли;
	
	СтруктураПараметров.Вставить("ПоказыватьКолонкуРасчетныйДокументВСверкеВзаиморасчетов",
		ПоказыватьКолонкуРасчетныйДокументВСверкеВзаиморасчетов); 
	СтруктураПараметров.Вставить("ПоказыватьКолонкуВалютаВСверкеВзаиморасчетов",
		ПоказыватьКолонкуВалютаВСверкеВзаиморасчетов);
	СтруктураПараметров.Вставить("ТолькоПросмотр", ТолькоПросмотр);

	ШапкаТабличнаяЧастьЗавершение = Новый ОписаниеОповещения("ШапкаТабличнаяЧастьЗавершение", ЭтотОбъект);
			
	ОткрытьФорму("ОбщаяФорма.ШапкаТабличнаяЧасть", СтруктураПараметров, , , , , ШапкаТабличнаяЧастьЗавершение);

КонецПроцедуры

&НаКлиенте
Процедура ШапкаТабличнаяЧастьЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.БылиВнесеныИзменения Тогда
		
		ОбновитьФорму = Ложь;
		Если Результат.Свойство("ПоказыватьКолонкуРасчетныйДокументВСверкеВзаиморасчетов") Тогда
			ПоказыватьКолонкуРасчетныйДокументВСверкеВзаиморасчетов = 
				Результат.ПоказыватьКолонкуРасчетныйДокументВСверкеВзаиморасчетов;
			ОбновитьФорму = Истина;
		КонецЕсли;		
		
		Если Результат.Свойство("ПоказыватьКолонкуВалютаВСверкеВзаиморасчетов") Тогда
			ПоказыватьКолонкуВалютаВСверкеВзаиморасчетов = Результат.ПоказыватьКолонкуВалютаВСверкеВзаиморасчетов;
			ОбновитьФорму = Истина;
		КонецЕсли;

		Если ОбновитьФорму Тогда
			УстановитьВидимостьЭлементовПоНастройкеПользователя(ЭтотОбъект);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_НажатиеДекорацияИнформацияНовоеФаксимилеЗакрыть(Элемент)
	
