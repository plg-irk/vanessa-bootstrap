		ТекстСообщения = НСтр("ru = 'Табличная часть взаиморасчетов по данным контрагента пуста.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
		
	КонецЕсли;
	
	ЗаполнитьДатыВСведенияхКонтрагентаИзРасчетныхДокументов();
	
