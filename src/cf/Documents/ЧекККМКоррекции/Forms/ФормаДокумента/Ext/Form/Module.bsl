&НаСервереБезКонтекста
Функция РеквизитыПредметаРасчета(Знач НаименованиеПредметаРасчета, Знач Организация,
	Знач НастройкиНДСПоУмолчанию, Знач ДатаОбработки = Неопределено)
	
	СтруктураРеквизитов = Новый Структура;
	СтруктураРеквизитов.Вставить("ЕдиницаИзмерения");
	СтруктураРеквизитов.Вставить("ВидСтавкиНДС");
	
	НастройкиНДС = НастройкиНДСПустые();	
	Если НастройкиНДСПоУмолчанию = Неопределено Тогда
		НДСОрганизации = НалогиУНФ.НастройкиНДСОрганизации(Организация, , ДатаОбработки);
		НастройкиНДС.НалогообложениеНДС = НДСОрганизации.ТипНалогообложения;
		НастройкиНДС.ВидСтавкиПоУмолчанию = НДСОрганизации.ВидСтавкиНДС;
	Иначе
		ЗаполнитьЗначенияСвойств(НастройкиНДС, НастройкиНДСПоУмолчанию);
	КонецЕсли;
	РеквизитыредметаРасчета = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(НаименованиеПредметаРасчета, СтруктураРеквизитов);
	
	ПараметрыНДСНоменклатуры = НоменклатураВДокументахСервер.ПараметрыОпределенияСтавкиНДС();
	ПараметрыНДСНоменклатуры.Организация = Организация;
	ПараметрыНДСНоменклатуры.ДатаОбработки = ?(ЗначениеЗаполнено(ДатаОбработки), ДатаОбработки, ТекущаяДатаСеанса());
	ПараметрыНДСНоменклатуры.НалогообложениеНДС = НастройкиНДС.НалогообложениеНДС;
	ПараметрыНДСНоменклатуры.ВидСтавкиНДСПоУмолчанию = НастройкиНДС.ВидСтавкиПоУмолчанию;
	ПараметрыНДСНоменклатуры.Номенклатура = НаименованиеПредметаРасчета;
	ПараметрыНДСНоменклатуры.НоменклатураВидСтавкиНДС = РеквизитыредметаРасчета.ВидСтавкиНДС;
	ДанныеНДС = НоменклатураВДокументахСервер.ДанныеНДССтрокиНоменклатуры(ПараметрыНДСНоменклатуры);
	СтруктураРеквизитов.Вставить("СтавкаНДС", ДанныеНДС.СтавкаНДС);
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НастройкиНДСПустые()
	
	Возврат Новый Структура("НалогообложениеНДС, ВидСтавкиПоУмолчанию");
		
КонецФункции
 
&НаСервере
Функция НастройкиНалогообложенияНДС()
	
	НастройкиНДС = НастройкиНДСПустые();
	
	Если Объект.СистемаНалогообложения = Перечисления.ТипыСистемНалогообложенияККТ.ЕНВД
		ИЛИ Объект.СистемаНалогообложения = Перечисления.ТипыСистемНалогообложенияККТ.Патент Тогда
		НастройкиНДС.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
		НастройкиНДС.ВидСтавкиПоУмолчанию = Перечисления.ВидыСтавокНДС.БезНДС;
	Иначе
		ПоУмолчанию = НалогиУНФ.НастройкиНДСОрганизации(Объект.Организация, Объект.СтруктурнаяЕдиница, Объект.Дата);
		НастройкиНДС.НалогообложениеНДС = ПоУмолчанию.ТипНалогообложения;
		НастройкиНДС.ВидСтавкиПоУмолчанию = ПоУмолчанию.ВидСтавкиНДС;
	КонецЕсли;
	
	Возврат НастройкиНДС;
КонецФункции

&НаКлиенте
Процедура ОбновитьНастройкиНДС()
	
	Если ТипЗнч(НастройкиНДСПоУмолчанию) = Тип("Структура") Тогда
		СтарыеНастройки = Новый ФиксированнаяСтруктура(НастройкиНДСПоУмолчанию);
	Иначе
		СтарыеНастройки = Неопределено;
	КонецЕсли;
	
	НастройкиНДСПоУмолчанию = НастройкиНалогообложенияНДС();
	
	Если СтарыеНастройки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьОтличия = Ложь;
	Для Каждого Элемент Из НастройкиНДСПоУмолчанию Цикл
		Если Элемент.Значение <> СтарыеНастройки[Элемент.Ключ] Тогда
			ЕстьОтличия = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьОтличия И Объект.ПозицииЧека.Количество() > 0 Тогда
		ТекстВопроса = НСтр("ru = 'Перезаполнить ставку НДС во всех строках?'");
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("СтарыеНастройкиНДС", СтарыеНастройки);
		ОповещениеОтвет = Новый ОписаниеОповещения("ОбновитьНастройкиНДСЗавершение", ЭтотОбъект, ДопПараметры);
		ПоказатьВопрос(ОповещениеОтвет, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНастройкиНДСЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = Неопределено ИЛИ РезультатВопроса = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьСтавкуНДСПозицийЧека(ДополнительныеПараметры.СтарыеНастройкиНДС);
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтавкуНДСПозицийЧека(Знач ПредыдущиеНастройкиНДС = Неопределено)
	
	СтавкиНДСБезИзменений = Новый Массив;
	СтавкиНДСБезИзменений.Добавить(УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль());
	Если ПредыдущиеНастройкиНДС <> Неопределено
		И ПредыдущиеНастройкиНДС.НалогообложениеНДС <> Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
			СтавкиНДСБезИзменений.Добавить(УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС());
	КонецЕсли;
	
	ПараметрыОпределенияНДС = НоменклатураВДокументахСервер.ПараметрыОпределенияСтавкиНДС();
	ПараметрыОпределенияНДС.ДатаОбработки = Объект.Дата;
	ПараметрыОпределенияНДС.НалогообложениеНДС = НастройкиНДСПоУмолчанию.НалогообложениеНДС;
	ПараметрыОпределенияНДС.ВидСтавкиНДСПоУмолчанию = НастройкиНДСПоУмолчанию.ВидСтавкиПоУмолчанию;
	СтавкаНДСПоУмолчанию = Справочники.СтавкиНДС.СтавкаНДС(НастройкиНДСПоУмолчанию.ВидСтавкиПоУмолчанию, Объект.Дата);
	Для Каждого Строка Из Объект.ПозицииЧека Цикл
		
		Если СтавкиНДСБезИзменений.Найти(Строка.СтавкаНДС) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(Строка.НаименованиеПредметаРасчета) = Тип("СправочникСсылка.Номенклатура") Тогда
			ПараметрыОпределенияНДС.Номенклатура = Строка.НаименованиеПредметаРасчета;
			ДанныеНДС = НоменклатураВДокументахСервер.ДанныеНДССтрокиНоменклатуры(ПараметрыОпределенияНДС);
			СтавкаНДС = ДанныеНДС.СтавкаНДС;
		Иначе
			СтавкаНДС = СтавкаНДСПоУмолчанию;
		КонецЕсли;
		
		Если Строка.СтавкаНДС <> СтавкаНДС Тогда
			Строка.СтавкаНДС = СтавкаНДС;
			ЗначениеСтавкиНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(Строка.СтавкаНДС);
			Строка.СуммаНДС = УчетНДСКлиентСервер.РассчитатьСуммуНДС(Строка.СуммаСоСкидками, Истина, ЗначениеСтавкиНДС);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
