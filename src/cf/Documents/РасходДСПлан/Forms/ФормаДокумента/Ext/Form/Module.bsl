		ПараметрВыбора = Новый Массив;
		ПараметрВыбора.Добавить(Новый ПараметрВыбора("Отбор.ЮридическоеФизическоеЛицо",
			Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо));		
