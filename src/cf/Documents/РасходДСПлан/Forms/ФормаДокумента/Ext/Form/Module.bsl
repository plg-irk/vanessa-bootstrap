&НаСервере
Процедура УстановитьОтборВидаНалога(ПриСозданииНаСервере = Ложь)
	
	Если ПриСозданииНаСервере Тогда
		ПлательщикЕНП = РегламентированнаяОтчетностьУСН.ПлательщикЕНП(Объект.Организация, ТекущаяДатаСеанса());
	Иначе
		ПлательщикЕНП = РегламентированнаяОтчетностьУСН.ПлательщикЕНП(Объект.Организация, Объект.Дата);
	КонецЕсли;
	
	НовыеПараметры = Новый Массив;
	НовыеПараметры.Добавить(Новый ПараметрВыбора("Отбор.ПрименяетсяОсобыйПорядокУплатыНалога", ПлательщикЕНП));
	Элементы.Налог.ПараметрыВыбора = Новый ФиксированныйМассив(НовыеПараметры);
	
КонецПроцедуры

// Заполняет реквизиты платежа в бюджет по умолчанию.
//
&НаКлиенте
Процедура ЗаполнитьРеквизитыПлатежаВБюджетПоУмолчанию()
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходДСПлан.Налоги") Тогда
		Если ЗначениеЗаполнено(Объект.Налог)
			И Объект.Налог = ПредопределенноеЗначение("Справочник.ВидыНалогов.ЕдиныйНалоговыйПлатеж") Тогда
				
			ДанныеДляЗаполненияПоЕНП = ДанныеДляЗаполненияПоЕНП(Объект.Налог, Объект.Организация, Объект.Дата);
			Получатель = ДанныеДляЗаполненияПоЕНП.АдминистраторНалогаОрганизации;
			Если ЗначениеЗаполнено(Получатель) И Объект.Контрагент <> Получатель Тогда
					
				Объект.Контрагент = Получатель;
				Объект.СчетКонтрагента = ДанныеДляЗаполненияПоЕНП.ЕдиныйБанковскийСчетГосударственногоОргана;
				ПриИзмененииКонтрагента();
					
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеДляЗаполненияПоЕНП(Налог, Организация, Дата)
	
	СтруктураДляВозврата = Новый Структура();
	СтруктураДляВозврата.Вставить("АдминистраторНалогаОрганизации", ДанныеГосударственныхОрганов.АдминистраторНалогаОрганизации(Налог, Организация, Дата));
	СтруктураДляВозврата.Вставить("ЕдиныйБанковскийСчетГосударственногоОргана",
	ЕдиныйНалоговыйСчет.ЕдиныйБанковскийСчетГосударственногоОргана(СтруктураДляВозврата.АдминистраторНалогаОрганизации));
	
	Возврат СтруктураДляВозврата;
	
КонецФункции

// Процедура устанавливает статью в форме документа в зависимости от вида операции
//
&НаСервере
Процедура УстановитьСтатьюДДСВЗависимостиОтВидаОперации() 
	
	СтатьяДДСПоУмолчаниюКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Контрагент, 
																				"СтатьяДДСПоУмолчанию");
	Если НЕ Объект.Контрагент.Пустая() И НЕ СтатьяДДСПоУмолчаниюКонтрагента.Пустая() Тогда
		Объект.СтатьяДвиженияДенежныхСредств = СтатьяДДСПоУмолчаниюКонтрагента;
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.Покупателю Тогда
		Объект.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ОплатаОтПокупателей;
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.Поставщику Тогда
		Объект.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ОплатаПоставщикам;
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.ЛичныеСредстваПредпринимателя Тогда
		Объект.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ЛичныеСредстваПредпринимателя;
	Иначе
		Объект.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.Прочее;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЛичныеСредстваПредпринимателяОчиститьОрганизацию()
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.ЛичныеСредстваПредпринимателя Тогда
		Если Справочники.Организации.ЭтоЮрЛицо(Объект.Организация) Тогда
			Объект.Организация = Справочники.Организации.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВидОперацииПриИзмененииФрагментНаСервере()
	
	ОчиститьРеквизитыНеОтносящиесяКОперации();
	УстановитьВидимостьЭлементовВЗависимостиОтВидаОперации(); 
	УстановитьСтатьюДДСВЗависимостиОтВидаОперации();
	УстановитьОтборВидаНалога();
	ЛичныеСредстваПредпринимателяОчиститьОрганизацию();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПоФизЛицуНаСервере(ПриИзменении = Ложь)
	
	Если Объект.ВидОперации <> Перечисления.ВидыОперацийРасходДСПлан.ЗарплатаСотруднику
		 И Объект.ВидОперации <> Перечисления.ВидыОперацийРасходДСПлан.Подотчетнику Тогда
		
		Физлицо = Справочники.ФизическиеЛица.ПустаяСсылка();
		Возврат;
		
	КонецЕсли;
	
	Если ПриИзменении Тогда
		
		СтруктураДанные = ДанныеКонтрагентаДляИзменения(Объект.Подотчетник, Объект.ВалютаДокумента, Объект.ВидОперации);
		
		Объект.СчетКонтрагента 	= СтруктураДанные.СчетКонтрагента;
		
	КонецЕсли;
	
	Физлицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Подотчетник, "Физлицо");
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЭлементовВЗависимостиОтВидаОперации()
	
	СброситьВидимостьЭлементовФормы();
	
	Если ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.ПустаяСсылка() Тогда
		
		Элементы.Контрагент.Видимость = Истина;
		Элементы.Контрагент.Заголовок = НСтр("ru='Контрагент'");
		Элементы.СчетКонтрагента.Видимость = Истина;
	
	КонецЕсли;
	
	Если ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.Поставщику Тогда

		Элементы.Контрагент.Видимость = Истина;
		Элементы.Контрагент.Заголовок = НСтр("ru='Поставщик'");
		Элементы.СчетКонтрагента.Видимость = Истина;
		
	КонецЕсли;
	
	Если ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.Покупателю Тогда
			
		Элементы.Контрагент.Видимость = Истина;
		Элементы.Контрагент.Заголовок = НСтр("ru='Покупатель'");
		Элементы.СчетКонтрагента.Видимость = Истина;
	
	КонецЕсли;
	
	Если ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.ПрочиеРасчеты Тогда

		Элементы.Корреспонденция.Видимость = Истина;
		Элементы.Контрагент.Видимость = Истина;
		Элементы.Контрагент.Заголовок = НСтр("ru='Контрагент'");
			
	КонецЕсли;
	
	Если ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.Прочее Тогда
	
		Элементы.Корреспонденция.Видимость = Истина;
		Элементы.Контрагент.Видимость = Истина;
		Элементы.Контрагент.Заголовок =  НСтр("ru='Получатель'");
			
	КонецЕсли;

		
	Если ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.Подотчетнику Тогда
		
		Элементы.Договор.Видимость = Ложь;
		Элементы.Подотчетник.Видимость = Истина;
		Элементы.Подотчетник.Заголовок = НСтр("ru='Подотчетник'");
					
	КонецЕсли;
	
	Если  ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.ЗарплатаСотруднику Тогда
		
		Элементы.Договор.Видимость = Ложь;
		Элементы.Подотчетник.Видимость = Истина;
		Элементы.Подотчетник.Заголовок = НСтр("ru='Сотрудник'");
		Элементы.ПериодРегистрации.Видимость = Истина;
				
	КонецЕсли;
	
	Если ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.Зарплата Тогда
				
		Элементы.Контрагент.Видимость = Истина;
		Элементы.Контрагент.Заголовок =  НСтр("ru='Получатель'");
		Элементы.Ведомость.Видимость = Истина;

	КонецЕсли;
			
	Если  ВидОперации = Перечисления.ВидыОперацийРасходДСПлан.НаРасходы Тогда
		
		Элементы.Корреспонденция.Заголовок = НСтр("ru='Статья расходов'");
