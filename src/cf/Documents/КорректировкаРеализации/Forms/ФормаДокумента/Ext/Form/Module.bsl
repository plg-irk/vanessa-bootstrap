		Возврат
	КонецЕсли;
	
	
	ПараметрыПоиска = Новый Структура("УказыватьДокументПоступления", Истина);
	
	НайденныеСтроки = Форма.Объект.Запасы.НайтиСтроки(ПараметрыПоиска);
	Форма.Элементы.ЗапасыДокументПоступления.Видимость = НайденныеСтроки.Количество();
	
