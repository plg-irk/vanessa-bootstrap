		ТекстЗаголовкаАвансы = СтрШаблон(НСтр("ru = 'Расшифровка аванса (%1)'"), Объект.Авансы.Количество());
	Иначе
		ТекстЗаголовкаАвансы = НСтр("ru = 'Расшифровка аванса'");
