
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КэшЗначений = Новый Структура("Ссылка, АдресРасшифровкиПокупателей, МассивДокументовОснований");
	
	ЗаполнитьЗначенияСвойств(КэшЗначений, Параметры);
	ЗаполнитьЗначенияСвойств(Объект, Параметры);
	
	Объект.СчетаФактурыВыданныеПокупателям.Загрузить(ПолучитьИзВременногоХранилища(КэшЗначений.АдресРасшифровкиПокупателей));
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСчетаФактурыВыданныеПокупателям

&НаКлиенте
Процедура СчетаФактурыВыданныеПокупателямСчетФактураПриИзменении(Элемент)
	
	ДанныеТекущейСтроки = Элементы.СчетаФактурыВыданныеПокупателям.ТекущиеДанные;
	Если ДанныеТекущейСтроки = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ДанныеДокумента = ДанныеДокументаТабличнойЧасти(ДанныеТекущейСтроки.СчетФактура);
	ЗаполнитьЗначенияСвойств(ДанныеТекущейСтроки, ДанныеДокумента);
	
	ДанныеТекущейСтроки.Сумма	= ДанныеДокумента.СуммаДокумента;
	ДанныеТекущейСтроки.НДС		= ДанныеДокумента.СуммаНДСДокумента;
	
КонецПроцедуры

&НаКлиенте
Процедура СчетаФактурыВыданныеПокупателямПриИзменении(Элемент)
	
	ОбновитьИтогиДокумента();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	ЗаписатьВХранилищеПокупателейКомиссионногоТовара();
	
	КэшЗначений.Вставить("СуммаДокумента",		Объект.СуммаДокумента);
	КэшЗначений.Вставить("СуммаНДСДокумента",	Объект.СуммаНДСДокумента);
	КэшЗначений.Вставить("ВыполненаКоманда",	КодВозвратаДиалога.OK);
	
	Закрыть(КэшЗначений);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаписатьВХранилищеПокупателейКомиссионногоТовара()
	
	ПоместитьВоВременноеХранилище(Объект.СчетаФактурыВыданныеПокупателям.Выгрузить(), КэшЗначений.АдресРасшифровкиПокупателей);
	
КонецПроцедуры

&НаСервере
Функция ДанныеДокументаТабличнойЧасти(СчетФактураВыданный)
	
	ДанныеДокумента = Новый Структура("Покупатель, СуммаДокумента, СуммаНДСДокумента");
	Если НЕ ЗначениеЗаполнено(СчетФактураВыданный) Тогда
		Возврат ДанныеДокумента;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СчетФактураВыданный", СчетФактураВыданный);
	Запрос.УстановитьПараметр("ОтчетыКомитенту", КэшЗначений.МассивДокументовОснований);
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗапасыИАгентскиеУслугиПринятые.Партия КАК Партия
	|ПОМЕСТИТЬ ВТПартииКомитента
	|ИЗ
	|	РегистрНакопления.ЗапасыИАгентскиеУслугиПринятые КАК ЗапасыИАгентскиеУслугиПринятые
	|ГДЕ
	|	ЗапасыИАгентскиеУслугиПринятые.ТипПриемаПередачи = ЗНАЧЕНИЕ(Перечисление.ТипыПриемаПередачиТоваров.ОтчетКомитенту)
	|	И ЗапасыИАгентскиеУслугиПринятые.Регистратор В (&ОтчетыКомитенту)
	|	И ЗапасыИАгентскиеУслугиПринятые.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|СГРУППИРОВАТЬ ПО
	|	ЗапасыИАгентскиеУслугиПринятые.Партия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапасыИАгентскиеУслугиПринятые.Регистратор КАК Регистратор,
	|	ЗапасыИАгентскиеУслугиПринятые.Партия КАК Партия
	|ПОМЕСТИТЬ ВТПродажиПартий
	|ИЗ
	|	РегистрНакопления.ЗапасыИАгентскиеУслугиПринятые КАК ЗапасыИАгентскиеУслугиПринятые
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПартииКомитента КАК ВТПартииКомитента
	|		ПО ЗапасыИАгентскиеУслугиПринятые.Партия = ВТПартииКомитента.Партия
	|		И ЗапасыИАгентскиеУслугиПринятые.ТипПриемаПередачи = ЗНАЧЕНИЕ(Перечисление.ТипыПриемаПередачиТоваров.ОтчетКомитенту)
	|		И ЗапасыИАгентскиеУслугиПринятые.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|СГРУППИРОВАТЬ ПО
	|	ЗапасыИАгентскиеУслугиПринятые.Регистратор,
	|	ЗапасыИАгентскиеУслугиПринятые.Партия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Продажи.Контрагент КАК Покупатель,
	|	СУММА(Продажи.Сумма - Продажи.СуммаНДС) КАК СуммаДокумента,
	|	СУММА(Продажи.СуммаНДС) КАК СуммаНДСДокумента
	|ИЗ
	|	РегистрНакопления.Продажи КАК Продажи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПродажиПартий КАК ВТПродажиПартий
	|		ПО Продажи.Регистратор = ВТПродажиПартий.Регистратор
	|		И Продажи.Партия = ВТПродажиПартий.Партия
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактура.ДокументыОснования КАК СчетФактураДокументыОснования
	|		ПО Продажи.Регистратор = СчетФактураДокументыОснования.ДокументОснование
	|		И СчетФактураДокументыОснования.Ссылка = &СчетФактураВыданный
	|СГРУППИРОВАТЬ ПО
	|	Продажи.Контрагент";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеДокумента, Выборка);
	Иначе	
		ДанныеДокумента.Покупатель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетФактураВыданный, "Контрагент");
		ДанныеДокумента.СуммаДокумента = 0;
		ДанныеДокумента.СуммаНДСДокумента = 0;
	КонецЕсли;
	
	Возврат ДанныеДокумента;
	
КонецФункции

&НаСервере
Процедура ОбновитьИтогиДокумента()
	
	Объект.СуммаДокумента = Объект.СчетаФактурыВыданныеПокупателям.Итог("Сумма");
	Объект.СуммаНДСДокумента = Объект.СчетаФактурыВыданныеПокупателям.Итог("НДС");
	
КонецПроцедуры

#КонецОбласти
