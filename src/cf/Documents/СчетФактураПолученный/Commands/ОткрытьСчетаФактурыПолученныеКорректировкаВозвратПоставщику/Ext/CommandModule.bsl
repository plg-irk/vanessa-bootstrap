
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ЭтоСчетФактураПолученныйКорректировочныйНаВозвратПоставщику", Истина);
	ДанныеЗаполнения.Вставить("Ссылка", ПараметрКоманды);
	
	ПараметрыФормы = Новый Структура("Основание, ЭтоСчетФактураПолученныйКорректировочныйНаВозвратПоставщику", ДанныеЗаполнения, Истина);
	
	ОткрытьФорму("Документ.СчетФактураПолученный.ФормаОбъекта", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник,
		ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно,
		ПараметрыВыполненияКоманды.НавигационнаяСсылка);
		
КонецПроцедуры