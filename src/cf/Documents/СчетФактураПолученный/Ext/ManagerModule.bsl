	|	Реквизиты.СтранаРегистрации КАК СтранаРегистрации,
	|	Реквизиты.РеализацияТоваровКомитента КАК РеализацияТоваровКомитента
	|ИЗ
	|	Реквизиты КАК Реквизиты";
	
	Реквизиты = Запрос.Выполнить().Выбрать();
	Реквизиты.Следующий();
	
	Если Реквизиты.СводныйСчетФактураКомитентаПо1279 Тогда
		
		Если Реквизиты.ВидСчетаФактуры = Перечисления.ВидыОперацийСчетФактураПолученный.Корректировка Тогда
			
			ТекстЗапроса = ТекстЗапросаДляЖурналаСводныйСчетФактураКомитентаКорректировочный();
			
		Иначе
			
			ТекстЗапроса = ТекстЗапросаДляЖурналаСводныйСчетФактураКомитента();
			
		КонецЕсли;
	
	ИначеЕсли Реквизиты.ВидСчетаФактуры = Перечисления.ВидыОперацийСчетФактураПолученный.КорректировкаАванса Тогда
		
		ТекстЗапроса = ТекстЗапросаДляЖурналаКорректировочныйНаАванс();

	ИначеЕсли Реквизиты.ВидСчетаФактуры = Перечисления.ВидыОперацийСчетФактураПолученный.Корректировка Тогда
		
		ТекстЗапроса = ТекстЗапросаДляЖурналаКорректировочный();
		
	Иначе
		ТекстЗапроса = ТекстЗапросаДляЖурнала();
		
	КонецЕсли;
		
	Запрос.Текст = ТекстЗапроса;
	ЗаписиЖурнала = Запрос.Выполнить().Выгрузить();
	ПодготовленныеЗаписи = УчетНДСУНФ.ПодготовитьЗаписьЖурналаУчетаСчетовФактур(ЗаписиЖурнала);
	УчетНДСУНФ.СформироватьДвиженияЖурналУчетаСчетовФактурРегистрация(ПодготовленныеЗаписи, ТаблицаЗаписи);

	Если Реквизиты.Исправление Тогда 
		Запрос.УстановитьПараметр("ИсправляемыйСчетФактура", Реквизиты.ИсправляемыйСчетФактура);
		Запрос.Текст = ТекстЗапросаСторнирующаяЗаписьЖурналаСФ();
		ЗаписиЖурналаСторно = Запрос.Выполнить().Выгрузить();
		ПодготовленныеЗаписиСторно = УчетНДСУНФ.ПодготовитьЗаписьЖурналаУчетаСчетовФактур(ЗаписиЖурналаСторно);
		УчетНДСУНФ.СформироватьДвиженияЖурналУчетаСчетовФактурРегистрация(ПодготовленныеЗаписиСторно, ТаблицаЗаписи);
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстЗапросаДляЖурналаСводныйСчетФактураКомитента()
	
	Возврат "ВЫБРАТЬ
	|	СУММА(СчетаФактурыВыданныеПокупателям.Сумма + СчетаФактурыВыданныеПокупателям.НДС) КАК Сумма,
