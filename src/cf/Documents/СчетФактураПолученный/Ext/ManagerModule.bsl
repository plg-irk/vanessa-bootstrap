#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.УправлениеДоступом

// Параметры:
//   Ограничение - см. УправлениеДоступомПереопределяемый.ПриЗаполненииОграниченияДоступа.Ограничение.
//
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт

	Ограничение.Текст =
	"РазрешитьЧтениеИзменение
	|ГДЕ
	|	ЗначениеРазрешено(Организация)
	|	И ЗначениеРазрешено(Контрагент)";

КонецПроцедуры

// Конец СтандартныеПодсистемы.УправлениеДоступом

// Определяет список команд заполнения.
//
// Параметры:
//   КомандыЗаполнения - ТаблицаЗначений - Таблица с командами заполнения. Для изменения.
//       См. описание 1 параметра процедуры ЗаполнениеОбъектовПереопределяемый.ПередДобавлениемКомандЗаполнения().
//   Параметры - Структура - Вспомогательные параметры. Для чтения.
//       См. описание 2 параметра процедуры ЗаполнениеОбъектовПереопределяемый.ПередДобавлениемКомандЗаполнения().
//
Процедура ДобавитьКомандыЗаполнения(КомандыЗаполнения, Параметры) Экспорт
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если Данные.Номер = Null
		ИЛИ НЕ ЗначениеЗаполнено(Данные.Ссылка) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	НомерДокумента	= Данные.НомерВходящегоДокумента;
	ДатаДокумента	= Формат(Данные.ДатаВходящегоДокумента, "ДЛФ=Д");
	Состояние		= ?(Данные.ПометкаУдаления, НСтр("ru='(удален)'"), ?(Данные.Проведен, "", НСтр("ru='(не проведен)'")));
	
	Представление	= СтрШаблон(НСтр("ru = 'Счет-фактура (%1) %2 от %3 %4'"), Строка(Данные.ВидОперации), НомерДокумента, ДатаДокумента, Состояние);
	
КонецПроцедуры

Процедура ОбработкаПолученияПолейПредставления(Поля, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Поля.Добавить("Проведен");
	Поля.Добавить("Номер");
	Поля.Добавить("Ссылка");
	Поля.Добавить("ПометкаУдаления");
	Поля.Добавить("ВидОперации");
	Поля.Добавить("НомерВходящегоДокумента");
	Поля.Добавить("ДатаВходящегоДокумента");
	
КонецПроцедуры

#КонецОбласти

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныеПроцедурыИФункции

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		
		Если Параметры.Свойство("Ключ")
			И Параметры.Ключ.УдалитьЗапасы.Количество() > 0 Тогда
			
			СтандартнаяОбработка = Ложь;
			ВыбраннаяФорма = "УдалитьФормаДокумента";
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
// Параметры:
//  ДокументСсылкаСчетФактураПолученный - ДокументСсылка.СчетФактураПолученный
//  СтруктураДополнительныеСвойства - Структура
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства) Экспорт

	Запрос = Новый Запрос(ТекстЗапросаИнициализироватьДанныеДокумента());
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаСчетФактураПолученный);
	Запрос.ВыполнитьПакет();

	// Прослеживаемость
	СформироватьТаблицаОперацииПрослеживаемости(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства);	
	
   // НДС
	УчетНДСУНФ.СформироватьДвиженияПолученСчетФактураНаПоступление(ДокументСсылкаСчетФактураПолученный,
		СтруктураДополнительныеСвойства);

	УчетНДСУНФ.СформироватьДвиженияПолученСчетФактураНаВыданныйАванс(ДокументСсылкаСчетФактураПолученный,
		СтруктураДополнительныеСвойства);
	УчетНДСУНФ.СформироватьТаблицаНДСАвансыВыданные(ДокументСсылкаСчетФактураПолученный,
		СтруктураДополнительныеСвойства);
	СформироватьТаблицаЖурналУчетаСчетовФактур(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства);

	Если Не СтруктураДополнительныеСвойства.НеобходимоОтразитьСчетФактуройЗапасыВРазрезеГТД Тогда
		АрхивныеАлгоритмыПустыеТаблицыДляПроведения(СтруктураДополнительныеСвойства);
		Возврат;
	КонецЕсли;

	АрхивныеАлгоритмыЗапасыВРазрезеГТД(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства);

КонецПроцедуры // ИнициализироватьДанныеДокумента()

Функция ТекстЗапросаИнициализироватьДанныеДокумента()

	ТекстЗапроса =
	"ВЫБРАТЬ
	|    СчетФактураПолученный.Договор.ВалютаРасчетов КАК ДоговорВалютаРасчетов,
	|    СчетФактураПолученный.Контрагент,
	|    СчетФактураПолученный.ВалютаДокумента,
	|    СчетФактураПолученный.Кратность,
	|    СчетФактураПолученный.Курс,
	|    СчетФактураПолученный.Договор КАК ДоговорКонтрагента,
	|    СчетФактураПолученный.Дата,
	|    СчетФактураПолученный.Организация,
	|    СчетФактураПолученный.Исправление,
	|    СчетФактураПолученный.ДокументОснование,
	|    СчетФактураПолученный.ИсправляемыйСчетФактура,
	|    СчетФактураПолученный.Ссылка,
	|    СчетФактураПолученный.ДокументОснование.Дата,
	|    СчетФактураПолученный.ИсправлениеСобственнойОшибки,
	|    СчетФактураПолученный.НДСПредъявленКВычету,
	|    СчетФактураПолученный.КодВидаОперации
	|ПОМЕСТИТЬ ВременнаяТаблицаШапка
	|ИЗ
	|    Документ.СчетФактураПолученный КАК СчетФактураПолученный
	|ГДЕ
	|    СчетФактураПолученный.Ссылка = &Ссылка";

	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов();
	Возврат ТекстЗапроса;
КонецФункции 

// Формирует таблицу движений по регистру ЖурналУчетаСчетовФактур.
// 
// Параметры:
//  ДокументСсылкаСчетФактура - ДокументСсылка.СчетФактура
//  СтруктураДополнительныеСвойства - Структура - 
//		см. ПроведениеДокументовУНФ.ИнициализироватьДополнительныеСвойстваДляПроведения, ДополнительныеСвойства
Процедура СформироватьТаблицаЖурналУчетаСчетовФактур(ДокументСсылкаСчетФактура, СтруктураДополнительныеСвойства)
	
	Организация = СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности;
	Период = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
	
	ТаблицаЗаписи = Новый ТаблицаЗначений;
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЖурналУчетаСчетовФактур", ТаблицаЗаписи);

	ЕстьУчетНДС = УчетнаяПолитика.ПлательщикНДСПрименяющийУСН(Организация, Период)
		ИЛИ УчетнаяПолитика.ПлательщикНДС(Организация, Период);
	ИспользуетсяОтчетность = (ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ИспользуетсяОтчетность") = Истина);
	Если НЕ ЕстьУчетНДС И НЕ ИспользуетсяОтчетность Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаСчетФактура);
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("ВалютаРеглУчета", СтруктураДополнительныеСвойства.НациональнаяВалюта);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
	|	СчетФактураПолученный.Ссылка КАК Ссылка,
	|	СчетФактураПолученный.Дата КАК Дата,
	|	СчетФактураПолученный.Организация КАК Организация,
	|	СчетФактураПолученный.ДокументОснование КАК ДокументОснование,
	|	СчетФактураПолученный.ВалютаДокумента КАК ВалютаДокумента,
	|	СчетФактураПолученный.Контрагент КАК Контрагент,
	|	"""" КАК КППКонтрагента,
	|	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) КАК Продавец,
	|	СчетФактураПолученный.Договор КАК ДоговорКонтрагента,
	|	СчетФактураПолученный.Договор.ВалютаРасчетов КАК ВалютаВзаиморасчетов,
	|	ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДокументОснованиеДата,
	|	СчетФактураПолученный.Договор.ВидДоговора КАК ВидДоговора,
	|	СчетФактураПолученный.Договор.ВидАгентскогоДоговора КАК ВидАгентскогоДоговора,
	|	ЕСТЬNULL(СчетФактураПолученный.Договор.УчетАгентскогоНДС, ЛОЖЬ) КАК УчетАгентскогоНДС,
	|	ЕСТЬNULL(СчетФактураПолученный.Договор.РасчетыВУсловныхЕдиницах, ЛОЖЬ) КАК РасчетыВУсловныхЕдиницах,
	|	ВЫБОР
	|		КОГДА СчетФактураПолученный.Дата < ДАТАВРЕМЯ(2018, 1, 1)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ЕСТЬNULL(СчетФактураПолученный.Договор.УчетАгентскогоНДС, ЛОЖЬ) = ИСТИНА
	|				И ЕСТЬNULL(СчетФактураПолученный.Договор.ВидАгентскогоДоговора, ЗНАЧЕНИЕ(Перечисление.ВидыАгентскихДоговоров.ПустаяСсылка)) = ЗНАЧЕНИЕ(Перечисление.ВидыАгентскихДоговоров.РеализацияТоваров)
	|	КОНЕЦ КАК НДСИсчисляетсяНалоговымАгентом,
	|	СчетФактураПолученный.ВидОперации КАК ВидСчетаФактуры,
	|	СчетФактураПолученный.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
	|	СчетФактураПолученный.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	|	СчетФактураПолученный.Исправление КАК Исправление,
	|	СчетФактураПолученный.НомерИсправления КАК НомерИсправления,
	|	СчетФактураПолученный.ДатаИсправления КАК ДатаИсправления,
	|	Ложь КАК СформированПриВводеНачальныхОстатковНДС,
	|	СчетФактураПолученный.БланкСтрогойОтчетности КАК БланкСтрогойОтчетности,
	|	Неопределено КАК ЗаявлениеОВвозеТоваровОтКомиссионера,
	|	СчетФактураПолученный.НДСПредъявленКВычету КАК НДСПредъявленКВычету,
	|	ВЫБОР
	|		КОГДА СчетФактураПолученный.КодСпособаВыставления = 0
	|			ТОГДА 1
	|		ИНАЧЕ СчетФактураПолученный.КодСпособаВыставления
	|	КОНЕЦ КАК КодСпособаПолучения,
	|	СчетФактураПолученный.КодВидаОперации КАК КодВидаОперации,
	|	СчетФактураПолученный.КодВидаОперацииНаУменьшение КАК КодВидаОперацииНаУменьшение,
	|	СчетФактураПолученный.СуммаДокумента + СчетФактураПолученный.СуммаНДСДокумента КАК СуммаДокумента,
	|	СчетФактураПолученный.СуммаНДСДокумента КАК СуммаНДСДокумента,
	|	СчетФактураПолученный.СуммаУвеличение + СчетФактураПолученный.СуммаНДСУвеличение КАК СуммаУвеличение,
	|	СчетФактураПолученный.СуммаУменьшение + СчетФактураПолученный.СуммаНДСУменьшение КАК СуммаУменьшение,
	|	СчетФактураПолученный.СуммаНДСУвеличение КАК СуммаНДСУвеличение,
	|	СчетФактураПолученный.СуммаНДСУменьшение КАК СуммаНДСУменьшение,
	|	СчетФактураПолученный.СуммаДокументаКомиссия + СчетФактураПолученный.СуммаНДСДокументаКомиссия КАК СуммаДокументаКомиссия,
	|	СчетФактураПолученный.СуммаНДСДокументаКомиссия КАК СуммаНДСДокументаКомиссия,
	|	СчетФактураПолученный.СуммаУвеличениеКомиссия + СчетФактураПолученный.СуммаНДСУвеличениеКомиссия КАК СуммаУвеличениеКомиссия,
	|	СчетФактураПолученный.СуммаУменьшениеКомиссия + СчетФактураПолученный.СуммаНДСУменьшениеКомиссия КАК СуммаУменьшениеКомиссия,
	|	СчетФактураПолученный.СуммаНДСУвеличениеКомиссия КАК СуммаНДСУвеличениеКомиссия,
	|	СчетФактураПолученный.СуммаНДСУменьшениеКомиссия КАК СуммаНДСУменьшениеКомиссия,
	|	Ложь КАК СчетФактураБезНДС,
	|	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) КАК Субкомиссионер,
	|	Неопределено КАК СчетФактураВыданныйПокупателю,
	|	ВЫБОР
	|		КОГДА СчетФактураПолученный.Договор.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоров.СКомитентом)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК РеализацияТоваровКомитента,
	|	ВЫБОР
	|		КОГДА СчетФактураПолученный.Договор.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоров.СКомитентом)
	|				И СчетФактураПолученный.Дата >= ДАТАВРЕМЯ(2015, 1, 1)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СводныйСчетФактураКомитентаПо1279,
	|	ВЫБОР
	|		КОГДА СчетФактураПолученный.ДокументОснование ССЫЛКА Документ.АвансовыйОтчет
	|				И СчетФактураПолученный.Дата >= ДАТАВРЕМЯ(2014, 10, 1)
	|			ТОГДА ЕСТЬNULL(ДанныеПервичныхДокументов.Номер, """")
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК НомерДокументаОплаты,
	|	ВЫБОР
	|		КОГДА СчетФактураПолученный.ДокументОснование ССЫЛКА Документ.АвансовыйОтчет
	|				И СчетФактураПолученный.Дата >= ДАТАВРЕМЯ(2014, 10, 1)
	|			ТОГДА ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, ДАТАВРЕМЯ(1, 1, 1))
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК ДатаДокументаОплаты,
	|	ЛОЖЬ КАК ИсправлениеСобственнойОшибки,
	|	СчетФактураПолученный.ИсправляемыйСчетФактура КАК ИсправляемыйСчетФактура,
	|	ЕСТЬNULL(ДанныеПервичныхДокументовИсправляемыйСчетФактура.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИсправляемогоСчетаФактуры,
	|	"""" КАК ИННКонтрагента,
	|	СчетФактураПолученный.СуммаДокументаКомиссия > 0
	|		ИЛИ СчетФактураПолученный.СуммаУвеличениеКомиссия > 0
	|		ИЛИ СчетФактураПолученный.СуммаУменьшениеКомиссия > 0 КАК ЕстьКомиссия,
	|	ЛОЖЬ КАК ПовторноеИсправлениеСобственнойОшибки,
	|	СчетФактураПолученный.СводныйКорректировочный КАК СводныйКорректировочный,
	|	СчетФактураПолученный.Контрагент.СтранаРегистрации КАК СтранаРегистрации
	|ПОМЕСТИТЬ Реквизиты
	|ИЗ
	|	Документ.СчетФактураПолученный КАК СчетФактураПолученный
