	Возврат ПоместитьВоВременноеХранилище(
		Объект.ЭквайринговыеОперации.Выгрузить(),
		УникальныйИдентификатор);
	
КонецФункции // ПоместитьЭквайринговыеОперацииВХранилище()

// Функция получает табличную часть РасшифровкаРасчетов из временного хранилища.
//
&НаСервере
Процедура ПолучитьЭквайринговыеОперацииИзХранилища(АдресЭквайринговыеОперацииВХранилище)
	
	ТаблицаЭквайринговыеОперации = ПолучитьИзВременногоХранилища(АдресЭквайринговыеОперацииВХранилище);
	Объект.ЭквайринговыеОперации.Очистить();
	Для каждого СтрокаЭквайринговыеОперации Из ТаблицаЭквайринговыеОперации Цикл
		Строка = Объект.ЭквайринговыеОперации.Добавить();
		ЗаполнитьЗначенияСвойств(Строка, СтрокаЭквайринговыеОперации);
	КонецЦикла;
	
КонецПроцедуры // ПолучитьРасшифровкаПлатежаИзХранилища()

&НаСервереБезКонтекста
Функция ПолучитьПараметрыЭквайринговогоТерминалаПриИзменении(Знач ЭквайринговыйТерминал)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СпособыОплаты.Договор КАК Договор,
	|	СпособыОплаты.СчетУчета КАК СчетУчета,
	|	СпособыОплаты.СчетЗатрат КАК СчетЗатрат,
	|	СпособыОплаты.СчетЗатрат.ТипСчета КАК СчетЗатратТипСчета,
	|	СпособыОплаты.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	СпособыОплаты.Подразделение КАК Подразделение,
	|	СпособыОплаты.БанковскийСчетЭквайринг КАК БанковскийСчетЭквайринг
	|ИЗ
	|	Справочник.СпособыОплаты КАК СпособыОплаты
	|ГДЕ
	|	СпособыОплаты.Ссылка = &ЭквайринговыйТерминал";
	СвойстваЭквайринговогоТерминала = Запрос.Выполнить().Выбрать();
	СвойстваЭквайринговогоТерминала.Следующий();
	
	ПараметрыЭквайринговогоТерминала = Новый Структура;
	ПараметрыЭквайринговогоТерминала.Вставить("Договор", СвойстваЭквайринговогоТерминала.Договор);
	Если ЗначениеЗаполнено(СвойстваЭквайринговогоТерминала.СчетУчета) Тогда
		ПараметрыЭквайринговогоТерминала.Вставить("СчетУчета", СвойстваЭквайринговогоТерминала.СчетУчета);
	Иначе
		ПараметрыЭквайринговогоТерминала.Вставить("СчетУчета", ПланыСчетов.Управленческий.ПереводыВПути);
	КонецЕсли;
	Если ЗначениеЗаполнено(СвойстваЭквайринговогоТерминала.СчетЗатрат) Тогда
		ПараметрыЭквайринговогоТерминала.Вставить("СчетЗатрат", СвойстваЭквайринговогоТерминала.СчетЗатрат);
		ПараметрыЭквайринговогоТерминала.Вставить("ТипСчетаЗатрат", СвойстваЭквайринговогоТерминала.СчетЗатратТипСчета);
	Иначе
		ПараметрыЭквайринговогоТерминала.Вставить("СчетЗатрат", ПланыСчетов.Управленческий.ПрочиеРасходы);
		СчетЗатратТипСчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПараметрыЭквайринговогоТерминала.СчетЗатрат,
			"ТипСчета");
		ПараметрыЭквайринговогоТерминала.Вставить("ТипСчетаЗатрат", СчетЗатратТипСчета);
	КонецЕсли;
	Если ЗначениеЗаполнено(СвойстваЭквайринговогоТерминала.НаправлениеДеятельности) Тогда
		ПараметрыЭквайринговогоТерминала.Вставить("НаправлениеДеятельности",
			СвойстваЭквайринговогоТерминала.НаправлениеДеятельности);
	Иначе
		ПараметрыЭквайринговогоТерминала.Вставить("НаправлениеДеятельности", Справочники.НаправленияДеятельности.Прочее);
	КонецЕсли;
	Если ЗначениеЗаполнено(СвойстваЭквайринговогоТерминала.Подразделение) Тогда
		ПараметрыЭквайринговогоТерминала.Вставить("Подразделение", СвойстваЭквайринговогоТерминала.Подразделение);
	Иначе
		ЗначениеНастройки = ПерсональныеНастройкиРУНФ.Прочитать("ОсновноеПодразделение", , ,
			Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение);
		ПараметрыЭквайринговогоТерминала.Вставить("Подразделение", ЗначениеНастройки);
	КонецЕсли;
	ПараметрыЭквайринговогоТерминала.Вставить("БанковскийСчетЭквайринг",
		СвойстваЭквайринговогоТерминала.БанковскийСчетЭквайринг);
	
	Возврат ПараметрыЭквайринговогоТерминала;
	
КонецФункции

&НаКлиенте
Функция ПроверитьРеквизитыПередЗаполнениемТабличнойЧасти()
	
	ВыполнитьВозврат = Ложь;
	Если Объект.Контрагент.Пустая() Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Укажите вначале контрагента!'");
		Сообщение.Поле = "Контрагент";
		Сообщение.ПутьКДанным = "Объект";
		Сообщение.Сообщить();
		
		ВыполнитьВозврат = Истина;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.БанковскийСчет)
	   И НЕ ЗначениеЗаполнено(Объект.ВалютаДенежныхСредств) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Укажите вначале банковский счет!'");
		Сообщение.Поле = "БанковскийСчет";
		Сообщение.ПутьКДанным = "Объект";
		Сообщение.Сообщить();
		
		ВыполнитьВозврат = Истина;
	КонецЕсли;

	Если Объект.ПоложениеЭквайринговогоТерминала = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке") Тогда
		Если Объект.ЭквайринговыйТерминал.Пустая() Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ru = 'Укажите вначале эквайринговый терминал!'");
			Сообщение.Поле = "ЭквайринговыйТерминал";
			Сообщение.ПутьКДанным = "Объект";
			Сообщение.Сообщить();
			
			ВыполнитьВозврат = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ДоговорЭквайринга.Пустая() Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Укажите вначале договор эквайринга!'");
		Сообщение.Поле = "ДоговорЭквайринга";
		Сообщение.ПутьКДанным = "ДоговорЭквайринга";
		Сообщение.Сообщить();
		
		ВыполнитьВозврат = Истина;
	КонецЕсли;
	
	Возврат ВыполнитьВозврат;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьЭквайринговыеОперацииЗавершение(Ответ, Параметры) Экспорт
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЭквайринговыеОперацииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЭквайринговыеОперацииНаСервере(ДатаНачала = '00010101', ДатаОкончания = '00010101')
	
	ЭквайринговыеОперацииСервер.ЗаполнитьЭквайринговыеОперации(Объект, ДатаНачала, ДатаОкончания, ДоговорЭквайринга);
	
	Модифицированность = Истина;
	СуммаПлатежаЭквайринг = Объект.СуммаДокумента;
	
	ФормыДокументовДеньги.ОбновитьОтображениеНалоговогоУчетаВТабличнойЧасти(ЭтотОбъект);
	РаспределитьСуммуКомиссии();
	
КонецПроцедуры

&НаКлиенте
Процедура ЭквайрингПодборЗавершение(Результат1, ДополнительныеПараметры) Экспорт
	
	АдресЭквайринговыеОперацииВХранилище = ДополнительныеПараметры.АдресЭквайринговыеОперацииВХранилище;
	
	Результат = Результат1;
	Если Результат = КодВозвратаДиалога.OK Тогда
		
		ПолучитьЭквайринговыеОперацииИзХранилища(АдресЭквайринговыеОперацииВХранилище);
		
		Для Каждого ТекущаяСтрока Из Объект.ЭквайринговыеОперации Цикл
			ТекущаяСтрока.СуммаПлатежаИтогоПоСтроке = ТекущаяСтрока.СуммаРасчетовВозврата
									+ТекущаяСтрока.СуммаРасчетовКомиссии+ТекущаяСтрока.СуммаРасчетовКомиссииВозврата-ТекущаяСтрока.СуммаРасчетов;
			
			ТекущаяСтрока.НалоговыйУчет = РаботаСФормойДокументаКлиентСервер.ПредставлениеНалоговогоУчетаСтроки(
				ТекущаяСтрока, ВидимостьУчитыватьВНУ);
			
		КонецЦикла;
		
		УстановитьТекущуюСтраницу();
		
		СуммаПлатежаЭквайринг = Объект.ЭквайринговыеОперации.Итог("СуммаПлатежаИтогоПоСтроке");
		
		Если Объект.ЭквайринговыеОперации.Количество() = 1 Тогда
			Объект.СуммаДокумента = СуммаПлатежаЭквайринг;
		КонецЕсли;
		
	РаспределитьСуммуКомиссии();
		
	КонецЕсли;

КонецПроцедуры // ЭквайрингПодборЗавершение()

&НаСервере
Процедура НастроитьВидимостьЭлементовВЗависимостиОтТипаСчетаЗатрат(УстанавливатьЗначения = Истина)
	
	Если ТипСчетаЗатратШапка = Перечисления.ТипыСчетов.Расходы Тогда
		ПараметрыЭквайринговогоТерминала = ПолучитьПараметрыЭквайринговогоТерминалаПриИзменении(Объект.ЭквайринговыйТерминал);
		
		Если УстанавливатьЗначения Тогда
			Объект.НаправлениеДеятельностиЗатраты = ПараметрыЭквайринговогоТерминала.НаправлениеДеятельности;
			Объект.ПодразделениеЗатраты = ПараметрыЭквайринговогоТерминала.Подразделение;
		КонецЕсли;
		
		Элементы.ПодразделениеЗатраты.Видимость = Истина;
		Элементы.НаправлениеДеятельностиЗатраты.Видимость = Истина;
	Иначе
		
		Если УстанавливатьЗначения Тогда
			Объект.НаправлениеДеятельностиЗатраты = Справочники.НаправленияДеятельности.Прочее;
			Объект.ПодразделениеЗатраты = Неопределено;
		КонецЕсли;
		
		Элементы.ПодразделениеЗатраты.Видимость = Ложь;
		Элементы.НаправлениеДеятельностиЗатраты.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСуммуПлатежаЭквайринга(ТекущаяСтрока)
	
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока.СуммаПлатежаИтогоПоСтроке = ТекущаяСтрока.СуммаРасчетовВозврата
		+ ТекущаяСтрока.СуммаРасчетовКомиссии + ТекущаяСтрока.СуммаРасчетовКомиссииВозврата
		- ТекущаяСтрока.СуммаРасчетов;
	
	СуммаПлатежаЭквайринг = Объект.ЭквайринговыеОперации.Итог("СуммаПлатежаИтогоПоСтроке");
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСуммуПлатежаИКомиссииЭквайринга(ТекущаяСтрока)
	
	Если ТекущаяСтрока <> Неопределено Тогда
		ПересчитатьСуммуПлатежаИКомиссииЭквайрингаВСтроке(ТекущаяСтрока);
		Если Объект.ВидОперации =
				ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ВозвратОплатыНаПлатежныеКарты")
			Или Объект.ВидОперации =
				ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ВозвратПродажиВКредит") Тогда
			Возврат;
		КонецЕсли;
		Если Объект.ЭквайринговыеОперации.Количество() = 1 Тогда
			Объект.СуммаДокумента = Объект.ЭквайринговыеОперации[0].СуммаПлатежаИтогоПоСтроке;
			Объект.СуммаКомиссииДокумента = Объект.ЭквайринговыеОперации[0].СуммаКомиссииИтогоПоСтроке;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ПересчитатьСуммуПлатежаИКомиссииЭквайрингаВСтроке(ТекущаяСтрока)
	
	ТекущаяСтрока.СуммаПлатежаИтогоПоСтроке = ТекущаяСтрока.СуммаРасчетовВозврата
		- ТекущаяСтрока.СуммаРасчетовКомиссииВозврата;
	ТекущаяСтрока.СуммаКомиссииИтогоПоСтроке = ТекущаяСтрока.СуммаРасчетовКомиссии
		+ ТекущаяСтрока.СуммаРасчетовКомиссииВозврата;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПараметрыЭквайринговойОперации(СсылкаНаДокумент, ЭквайринговыйТерминал)
	
	Результат = Новый Структура("ДатаПлатежа, НомерПлатежнойКарты, ВидПлатежнойКарты");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СсылкаНаДокумент", СсылкаНаДокумент);
	
	Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОперацияПоПлатежнымКартам.Дата КАК Дата,
		|	ОперацияПоПлатежнымКартам.ВидПлатежнойКарты КАК ВидПлатежнойКарты,
		|	ОперацияПоПлатежнымКартам.НомерПлатежнойКарты КАК НомерПлатежнойКарты,
		|	ОперацияПоПлатежнымКартам.РасшифровкаПлатежа.(
		|		Заказ КАК Заказ) КАК РасшифровкаПлатежа
		|ИЗ
		|	Документ.ОперацияПоПлатежнымКартам КАК ОперацияПоПлатежнымКартам
		|ГДЕ
		|	ОперацияПоПлатежнымКартам.Ссылка = &СсылкаНаДокумент";
		СвойстваДокумента = Запрос.Выполнить().Выбрать();
		Если СвойстваДокумента.Следующий() Тогда
			Результат.ДатаПлатежа = СвойстваДокумента.Дата;
			Результат.ВидПлатежнойКарты = СвойстваДокумента.ВидПлатежнойКарты;
			Результат.НомерПлатежнойКарты = СвойстваДокумента.НомерПлатежнойКарты;
			РасшифровкаПлатежа = СвойстваДокумента.РасшифровкаПлатежа.Выбрать();
			Если РасшифровкаПлатежа.Следующий() Тогда
				Если ЗначениеЗаполнено(РасшифровкаПлатежа.Заказ) Тогда
					Результат.Вставить("Заказ", РасшифровкаПлатежа.Заказ);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОтчетОРозничныхПродажах.Дата КАК Дата,
		|	ОтчетОРозничныхПродажах.БезналичнаяОплата.(
		|		ВидОплаты КАК ВидОплаты,
		|		ВидПлатежнойКарты КАК ВидПлатежнойКарты,
		|		НомерПлатежнойКарты КАК НомерПлатежнойКарты) КАК БезналичнаяОплата
		|ИЗ
		|	Документ.ОтчетОРозничныхПродажах КАК ОтчетОРозничныхПродажах
		|ГДЕ
		|	ОтчетОРозничныхПродажах.Ссылка = &СсылкаНаДокумент";
		СвойстваДокумента = Запрос.Выполнить().Выбрать();
		Если СвойстваДокумента.Следующий() Тогда
			Результат.ДатаПлатежа = СвойстваДокумента.Дата;
			БезналичнаяОплата = СвойстваДокумента.БезналичнаяОплата.Выбрать();
			ПараметрПоиска = Новый Структура("ВидОплаты", Перечисления.ВидыБезналичныхОплат.БанковскаяКарта);
			Если БезналичнаяОплата.НайтиСледующий(ПараметрПоиска) Тогда
				Результат.ВидПлатежнойКарты = БезналичнаяОплата.ВидПлатежнойКарты;
				Результат.НомерПлатежнойКарты = БезналичнаяОплата.НомерПлатежнойКарты;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьЭквайринговыеОперацииСВыборомПериодаЗавершение(Ответ, Параметры) Экспорт
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуВыбораПериодаРасчета();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораПериодаРасчета()
	
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("Контрагент", Объект.Контрагент);
	ПараметрыЗаполнения.Вставить("БанковскийСчет", Объект.БанковскийСчет);
	ПараметрыЗаполнения.Вставить("ЭквайринговыйТерминал", Объект.ЭквайринговыйТерминал);
	ПараметрыЗаполнения.Вставить("Организация", Объект.Организация);
	ПараметрыЗаполнения.Вставить("Ссылка", Объект.Ссылка);
	ПараметрыЗаполнения.Вставить("ВалютаДенежныхСредств", Объект.ВалютаДенежныхСредств);
	ПараметрыЗаполнения.Вставить("ПоложениеЭквайринговогоТерминала", Объект.ПоложениеЭквайринговогоТерминала);
	ПараметрыЗаполнения.Вставить("РасшифровкаПлатежа", ПоместитьРасшифровкаПлатежаВХранилище());
	
	ОписаниеОповещенияОЗавершении = Новый ОписаниеОповещения("ОткрытьФормуВыбораПериодаРасчетаЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.ПоступлениеНаСчет.Форма.ФормаВыбораПериода", ПараметрыЗаполнения, ЭтотОбъект,
		УникальныйИдентификатор, , , ОписаниеОповещенияОЗавершении, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораПериодаРасчетаЗавершение(Результат, Параметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		ЗаполнитьЭквайринговыеОперацииНаСервере(Результат.ПериодРасчетовДатаНачала, Результат.ПериодРасчетовДатаОкончания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЭквайринговыйТерминалПриИзмененииНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", Объект.ЭквайринговыйТерминал);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СпособыОплаты.Договор КАК Договор,
	|	СпособыОплаты.Договор.КонтрольВзаиморасчетовЭквайринг КАК КонтрольВзаиморасчетовЭквайринг,
	|	СпособыОплаты.Договор.РасчетКомиссииВОтчетеЭквайера КАК РасчетКомиссииВОтчетеЭквайера
	|ИЗ
	|	Справочник.СпособыОплаты КАК СпособыОплаты
	|ГДЕ
	|	СпособыОплаты.Ссылка = &ЭквайринговыйТерминал";
	СвойстваДоговораЭквайринга = Запрос.Выполнить().Выбрать();
	СвойстваДоговораЭквайринга.Следующий();
	
	Если ЗначениеЗаполнено(СвойстваДоговораЭквайринга.Договор) Тогда
		Если Не СвойстваДоговораЭквайринга.КонтрольВзаиморасчетовЭквайринг
			Или СвойстваДоговораЭквайринга.РасчетКомиссииВОтчетеЭквайера Тогда
			Объект.ПоложениеЭквайринговогоТерминала = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке;
		КонецЕсли;
	КонецЕсли;
	
	НастроитьВидимостьЭлементовВЗависимостиОтТипаСчетаЗатрат();
	ФормыДокументовДеньги.УстановитьВидимостьЭлементовВЗависимостиОтВидаОперации(ЭтотОбъект);
	
КонецПроцедуры

// Открытие формы настроек налогового учета для строки табличной части "ЭквайринговыеОперации"
//
&НаКлиенте
Процедура ОткрытьФормуРедактированияНастроекНалоговогоУчета(ВыбранноеЗначение)
	
	ВыбраннаяСтрока =  Объект.ЭквайринговыеОперации.НайтиПоИдентификатору(ВыбранноеЗначение);
	
	ПараметрыПодбора = Новый Структура;
	ПараметрыПодбора.Вставить("ВидимостьУчитыватьВНУ",		 ВидимостьУчитыватьВНУ);
	ПараметрыПодбора.Вставить("ВидимостьНалогообложениеНДС", Истина);
	ПараметрыПодбора.Вставить("ВидимостьПатент",			 Ложь);
	ПараметрыПодбора.Вставить("УчитыватьВНУ", 				 ВыбраннаяСтрока.УчитыватьВНУ);
	ПараметрыПодбора.Вставить("НалогообложениеНДС", 		 ВыбраннаяСтрока.НалогообложениеНДС);
	ПараметрыПодбора.Вставить("Патент", 					 Неопределено);
	ПараметрыПодбора.Вставить("Организация", 				 Объект.Организация);
	ПараметрыПодбора.Вставить("ИдентификаторСтроки",		 ВыбранноеЗначение);
	
	Обработчик = Новый ОписаниеОповещения("ПриЗавершенииВыбораНастроекНалогообложения", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.ФормаНастройкиНалоговогоУчета", ПараметрыПодбора, ЭтотОбъект,,,, Обработчик, ПредопределенноеЗначение("РежимОткрытияОкнаФормы.БлокироватьОкноВладельца"));
	
КонецПроцедуры

// Завершение подбора настроек налогового учета для строки табличной части "ЭквайринговыеОперации"

&НаКлиенте
Процедура ПриЗавершенииВыбораНастроекНалогообложения(СтруктураРезультата, ДополнительныеПараметры) Экспорт
	
	Если СтруктураРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли; 
	
	Если СтруктураРезультата.КодВозвратаДиалога = КодВозвратаДиалога.OK И СтруктураРезультата.БылиВнесеныИзменения Тогда
		
		Модифицированность = Истина;
		
		ВыбраннаяСтрока = Объект.ЭквайринговыеОперации.НайтиПоИдентификатору(СтруктураРезультата.ИдентификаторСтроки);
		
		ВыбраннаяСтрока.УчитыватьВНУ = СтруктураРезультата.УчитыватьВНУ;
		ВыбраннаяСтрока.НалогообложениеНДС = СтруктураРезультата.НалогообложениеНДС;
		
		ВыбраннаяСтрока.НалоговыйУчет = РаботаСФормойДокументаКлиентСервер.ПредставлениеНалоговогоУчетаСтроки(
			ВыбраннаяСтрока, ВидимостьУчитыватьВНУ);
		
	КонецЕсли;
	
КонецПроцедуры

// Функция возвращает структуру настроек налогообложения для эквайрингового терминала из параметра
//
&НаСервереБезКонтекста
Функция ПолучитьНастройкиНалоговогоУчетаТерминала(Терминал)

	Возврат ЭквайринговыеОперацииСервер.ПолучитьНастройкиНалоговогоУчетаТерминала(Терминал);

КонецФункции

// Процедура приводит в соответствие с выбранным договором табличную часть "ЭквайринговыеОперации"
//
&НаСервере
Процедура ДоговорЭквайрингаПриИзмененииНаСервере()
	
	МассивДляУдаления = Новый Массив;
	
	Ссылки = Объект.ЭквайринговыеОперации.Выгрузить( , "ЭквайринговыйТерминал").ВыгрузитьКолонку(
		"ЭквайринговыйТерминал");
	ДоговорыЭквайринга = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Ссылки, "Договор");
	
	Для каждого СтрокаЭквайринг Из Объект.ЭквайринговыеОперации Цикл
		
		Если ДоговорыЭквайринга[СтрокаЭквайринг.ЭквайринговыйТерминал] <> ДоговорЭквайринга Тогда
			МассивДляУдаления.Добавить(СтрокаЭквайринг);
		КонецЕсли; 
		
	КонецЦикла;
	
	Для каждого СтрокаДляУдаления Из МассивДляУдаления Цикл
		Объект.ЭквайринговыеОперации.Удалить(СтрокаДляУдаления);
	КонецЦикла;
	
	ФормыДокументовДеньги.УстановитьВидимостьЭлементовВЗависимостиОтВидаОперации(ЭтотОбъект);
	
КонецПроцедуры

// Процедура распределяет сумму комиссии по всем строкам табличной части, когда в комиссия рассчитывается в отчете эквайера
//
&НаСервере
Процедура РаспределитьСуммуКомиссии()
	
	ДанныеДоговораЭквайринга = ПолучитьДанныеЭквайринговогоДоговора(ДоговорЭквайринга);
	
	Если Не ДанныеДоговораЭквайринга.РасчетКомиссииВОтчетеЭквайера Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ДанныеДоговораЭквайринга.КонтрольВзаиморасчетовЭквайринг Тогда
		Возврат;
	КонецЕсли;
	
	// Необходимо перераспределить комиссию по всем строкам табличной части
	Если Объект.ЭквайринговыеОперации.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаЭквайринга = Объект.ЭквайринговыеОперации.Выгрузить();
	
	ИмяКолонки = "СуммаРасчетов";
	Если Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ВозвратОплатыНаПлатежныеКарты
		Или Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ВозвратПродажиВКредит Тогда
		ИмяКолонки = "СуммаРасчетовВозврата";
	КонецЕсли;
	
	МассивКоэффициентов = ТаблицаЭквайринга.ВыгрузитьКолонку(ИмяКолонки);
	МассивСумм = ЭквайринговыеОперацииСервер.РаспределитьПропорционально(Объект.СуммаКомиссииДокумента,
		МассивКоэффициентов);
	Если МассивСумм <> Неопределено Тогда
		ТаблицаЭквайринга.ЗагрузитьКолонку(МассивСумм, "СуммаРасчетовКомиссииВозврата");
		ТаблицаЭквайринга.ЗагрузитьКолонку(МассивСумм, "СуммаКомиссииИтогоПоСтроке");
		Объект.ЭквайринговыеОперации.Загрузить(ТаблицаЭквайринга);
		
		Для Каждого ТекущаяСтрока Из Объект.ЭквайринговыеОперации Цикл
			ПересчитатьСуммуПлатежаИКомиссииЭквайрингаВСтроке(ТекущаяСтрока);
		КонецЦикла;
	Иначе
		Для Каждого ТекущаяСтрока Из Объект.ЭквайринговыеОперации Цикл
			ТекущаяСтрока.СуммаРасчетовКомиссииВозврата = 0;
			ТекущаяСтрока.СуммаКомиссииИтогоПоСтроке = 0;
			ПересчитатьСуммуПлатежаИКомиссииЭквайрингаВСтроке(ТекущаяСтрока);
		КонецЦикла;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДанныеЭквайринговогоДоговора(ДоговорЭквайринга)
	
	РеквизитыДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ДоговорЭквайринга, "КонтрольВзаиморасчетовЭквайринг, РасчетКомиссииВОтчетеЭквайера");
	
	Результат = Новый Структура;
	Результат.Вставить("КонтрольВзаиморасчетовЭквайринг",
		РеквизитыДоговора.КонтрольВзаиморасчетовЭквайринг = Истина);
	Результат.Вставить("РасчетКомиссииВОтчетеЭквайера",
		РеквизитыДоговора.РасчетКомиссииВОтчетеЭквайера = Истина);
	
	Возврат Результат;
	
КонецФункции

