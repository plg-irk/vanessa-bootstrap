#Область Бонусы

// Формирует таблицу значение, содержащую данные для проведения по регистру.
// Таблицу значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаБонусныеБаллы(ДокументСсылкаОтчетОРозничныхПродажах, СтруктураДополнительныеСвойства)
	
	Если СтруктураДополнительныеСвойства.ДляПроведения.ПолноеПроведение Тогда
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Текст = РаботаСБонусами.СформироватьТекстЗапросаПоБонуснымБаллам();
		
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		ТаблицаБонусныеБаллы = РезультатЗапроса[0].Выгрузить();
		ТаблицаОплатаБонусами = РезультатЗапроса[1].Выгрузить();
		РаботаСБонусами.ВыделитьВозвратыИзТаблицыБонусов(ТаблицаБонусныеБаллы, ТаблицаОплатаБонусами);
		
		Если ТаблицаОплатаБонусами.Количество() > 0 Тогда
			
			РаботаСБонусами.ОбъединитьТаблицыБонусов(
				ТаблицаБонусныеБаллы,
				ТаблицаОплатаБонусами,
				ДокументСсылкаОтчетОРозничныхПродажах);
			
		КонецЕсли;
		
	Иначе
		
		ТаблицаБонусныеБаллы = Новый ТаблицаЗначений;
		
	КонецЕсли;
		
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаБонусныеБаллы", ТаблицаБонусныеБаллы);
	
КонецПроцедуры

Процедура СформироватьТаблицаНачисленияБонусныхБаллов(ДокументСсылкаОтчетОРозничныхПродажах, СтруктураДополнительныеСвойства)
	
	Если СтруктураДополнительныеСвойства.ДляПроведения.ПолноеПроведение Тогда
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Текст = РаботаСБонусами.СформироватьТекстЗапросаПоНачислениямБонусныхБаллов();
		ТаблицаНачисленияБонусныхБаллов = Запрос.Выполнить().Выгрузить();
		
	Иначе
		
		ТаблицаНачисленияБонусныхБаллов = Новый ТаблицаЗначений;
		
	КонецЕсли;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаНачисленияБонусныхБаллов", ТаблицаНачисленияБонусныхБаллов);
	
КонецПроцедуры

#КонецОбласти

#Область СтатусыОтчетаОРозничныхПродажах

// Записывает в регистр сведений Статусы отчетов о розничных продажах.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка - Ссылка
//  ДополнительныеСвойства - Структура - Дополнительные свойства
//  Отказ - Булево 
Процедура ОбновитьСтатусыОтчетаОРозничныхПродажах(ДокументСсылка, ДополнительныеСвойства, Отказ = Ложь) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ОтслеживатьСтатусыОтчетовОРозничныхПродажах") Тогда
		Возврат;
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДокументСсылка)
		ИЛИ ТипЗнч(ДокументСсылка) <> Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда
		
		Возврат;
	КонецЕсли;
	
	ДатаДокумента = ДополнительныеСвойства.ДляПроведения.Дата;
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВременнаяТаблицаЗапасы.Организация КАК Организация,
		|	ВременнаяТаблицаЗапасы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ВременнаяТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|	ВременнаяТаблицаЗапасы.Характеристика КАК Характеристика,
		|	ВременнаяТаблицаЗапасы.Партия КАК Партия,
		|	ЗапасыОстатки.КоличествоОстаток КАК КоличествоОстатокЗапасы
		|ИЗ
		|	ВременнаяТаблицаЗапасы КАК ВременнаяТаблицаЗапасы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(
		|				&ГраницаВключая,
		|				(Организация, СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия) В
		|					(ВЫБРАТЬ
		|						ВременнаяТаблицаЗапасы.Организация КАК Организация,
		|						ВременнаяТаблицаЗапасы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|						ВременнаяТаблицаЗапасы.Номенклатура КАК Номенклатура,
		|						ВременнаяТаблицаЗапасы.Характеристика КАК Характеристика,
		|						ВременнаяТаблицаЗапасы.Партия КАК Партия
		|					ИЗ
		|						ВременнаяТаблицаЗапасы КАК ВременнаяТаблицаЗапасы
		|							ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
		|							ПО
		|								ВременнаяТаблицаЗапасы.Номенклатура = СпрНоменклатура.Ссылка
		|									И СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас))) КАК ЗапасыОстатки
		|		ПО ВременнаяТаблицаЗапасы.Организация = ЗапасыОстатки.Организация
		|			И ВременнаяТаблицаЗапасы.СтруктурнаяЕдиница = ЗапасыОстатки.СтруктурнаяЕдиница
		|			И ВременнаяТаблицаЗапасы.Номенклатура = ЗапасыОстатки.Номенклатура
		|			И ВременнаяТаблицаЗапасы.Характеристика = ЗапасыОстатки.Характеристика
		|			И ВременнаяТаблицаЗапасы.Партия = ЗапасыОстатки.Партия
		|			И (ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) < 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОРП.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ОРПДляПроверки
		|ИЗ
		|	Документ.ОтчетОРозничныхПродажах КАК ОРП
		|ГДЕ
		|	ОРП.Ссылка = &ДокументСсылка
		|	И ОРП.СтатусКассовойСмены = ЗНАЧЕНИЕ(Перечисление.СтатусыОтчетаОРозничныхПродажах.Закрыта)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СуммыПоЧекамИОРП.Ссылка КАК Ссылка,
		|	СуммыПоЧекамИОРП.Номенклатура КАК Номенклатура,
		|	СуммыПоЧекамИОРП.Характеристика КАК Характеристика,
		|	СуммыПоЧекамИОРП.Партия КАК Партия,
		|	СУММА(СуммыПоЧекамИОРП.СуммаПоЧекамККМ) КАК СуммаПоЧекамККМ,
		|	СУММА(СуммыПоЧекамИОРП.КоличествоПоЧекамККМ) КАК КоличествоПоЧекамККМ,
		|	СУММА(СуммыПоЧекамИОРП.СуммаПоЧекамККМВозврат) КАК СуммаПоЧекамККМВозврат,
		|	СУММА(СуммыПоЧекамИОРП.КоличествоПоЧекамККМВозврат) КАК КоличествоПоЧекамККМВозврат,
		|	СУММА(СуммыПоЧекамИОРП.СуммаПоОРП) КАК СуммаПоОРП,
		|	СУММА(СуммыПоЧекамИОРП.КоличествоПоОРП) КАК КоличествоПоОРП
		|ИЗ
		|	(ВЫБРАТЬ
		|		ОРПДляПроверки.Ссылка КАК Ссылка,
		|		ЧекККМЗапасы.Номенклатура КАК Номенклатура,
		|		ЧекККМЗапасы.Характеристика КАК Характеристика,
		|		ЧекККМЗапасы.Партия КАК Партия,
		|		СУММА(ЧекККМЗапасы.Всего) КАК СуммаПоЧекамККМ,
		|		СУММА(ЧекККМЗапасы.Количество) КАК КоличествоПоЧекамККМ,
		|		0 КАК СуммаПоЧекамККМВозврат,
		|		0 КАК КоличествоПоЧекамККМВозврат,
		|		0 КАК СуммаПоОРП,
		|		0 КАК КоличествоПоОРП
		|	ИЗ
		|		Документ.ЧекККМ КАК ЧекККМ
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОРПДляПроверки КАК ОРПДляПроверки
		|			ПО ЧекККМ.КассоваяСмена = ОРПДляПроверки.Ссылка
		|				И (ЧекККМ.Проведен)
		|				И (НЕ ЧекККМ.Архивный)
		|				И (НЕ ЧекККМ.ОперацияСДенежнымиСредствами)
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Запасы КАК ЧекККМЗапасы
		|			ПО ЧекККМ.Ссылка = ЧекККМЗапасы.Ссылка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОРПДляПроверки.Ссылка,
		|		ЧекККМЗапасы.Номенклатура,
		|		ЧекККМЗапасы.Характеристика,
		|		ЧекККМЗапасы.Партия
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ОРПДляПроверки.Ссылка,
		|		ЧекККМВозвратЗапасы.Номенклатура,
		|		ЧекККМВозвратЗапасы.Характеристика,
		|		ЧекККМВозвратЗапасы.Партия,
		|		0,
		|		0,
		|		СУММА(ЧекККМВозвратЗапасы.Всего),
		|		СУММА(ЧекККМВозвратЗапасы.Количество),
		|		0,
		|		0
		|	ИЗ
		|		Документ.ЧекККМВозврат КАК ЧекККМВозврат
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОРПДляПроверки КАК ОРПДляПроверки
		|			ПО ЧекККМВозврат.КассоваяСмена = ОРПДляПроверки.Ссылка
		|				И (ЧекККМВозврат.Проведен)
		|				И (НЕ ЧекККМВозврат.Архивный)
		|				И (НЕ ЧекККМВозврат.ОперацияСДенежнымиСредствами)
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМВозврат.Запасы КАК ЧекККМВозвратЗапасы
		|			ПО ЧекККМВозврат.Ссылка = ЧекККМВозвратЗапасы.Ссылка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОРПДляПроверки.Ссылка,
		|		ЧекККМВозвратЗапасы.Номенклатура,
		|		ЧекККМВозвратЗапасы.Характеристика,
		|		ЧекККМВозвратЗапасы.Партия
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ОРПДляПроверки.Ссылка,
		|		ОРПЗапасы.Номенклатура,
		|		ОРПЗапасы.Характеристика,
		|		ОРПЗапасы.Партия,
		|		0,
		|		0,
		|		0,
		|		0,
		|		СУММА(ЕСТЬNULL(ОРПЗапасы.Всего, 0)),
		|		СУММА(ЕСТЬNULL(ОРПЗапасы.Количество, 0))
		|	ИЗ
		|		ОРПДляПроверки КАК ОРПДляПроверки
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах.Запасы КАК ОРПЗапасы
		|			ПО ОРПДляПроверки.Ссылка = ОРПЗапасы.Ссылка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОРПДляПроверки.Ссылка,
		|		ОРПЗапасы.Номенклатура,
		|		ОРПЗапасы.Характеристика,
		|		ОРПЗапасы.Партия) КАК СуммыПоЧекамИОРП
		|
		|СГРУППИРОВАТЬ ПО
		|	СуммыПоЧекамИОРП.Ссылка,
		|	СуммыПоЧекамИОРП.Номенклатура,
		|	СуммыПоЧекамИОРП.Характеристика,
		|	СуммыПоЧекамИОРП.Партия
		|
		|ИМЕЮЩИЕ
		|	НЕ(СУММА(СуммыПоЧекамИОРП.СуммаПоОРП) = СУММА(СуммыПоЧекамИОРП.СуммаПоЧекамККМ) - СУММА(СуммыПоЧекамИОРП.СуммаПоЧекамККМВозврат)
		|			И СУММА(СуммыПоЧекамИОРП.КоличествоПоОРП) = СУММА(СуммыПоЧекамИОРП.КоличествоПоЧекамККМ) - СУММА(СуммыПоЧекамИОРП.КоличествоПоЧекамККМВозврат))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОплатыПоЧекамИОРП.Ссылка КАК Ссылка,
		|	ОплатыПоЧекамИОРП.ВидОплаты КАК ВидОплаты,
		|	ОплатыПоЧекамИОРП.НомерПлатежнойКарты КАК НомерПлатежнойКарты,
		|	ОплатыПоЧекамИОРП.ПодарочныйСертификат КАК ПодарочныйСертификат,
		|	ОплатыПоЧекамИОРП.НомерСертификата КАК НомерСертификата,
		|	ОплатыПоЧекамИОРП.БонуснаяКарта КАК БонуснаяКарта,
		|	СУММА(ОплатыПоЧекамИОРП.ОплатаПоЧекамККМ) КАК ОплатаПоЧекамККМ,
		|	СУММА(ОплатыПоЧекамИОРП.ОплатаПоЧекамККМВозврат) КАК ОплатаПоЧекамККМВозврат,
		|	СУММА(ОплатыПоЧекамИОРП.ОплатаПоДокументуОРП) КАК ОплатаПоДокументуОРП
		|ИЗ
		|	(ВЫБРАТЬ
		|		ОРПДляПроверки.Ссылка КАК Ссылка,
		|		ЧекККМБезналичнаяОплата.ВидОплаты КАК ВидОплаты,
		|		ЧекККМБезналичнаяОплата.НомерПлатежнойКарты КАК НомерПлатежнойКарты,
		|		ЧекККМБезналичнаяОплата.ПодарочныйСертификат КАК ПодарочныйСертификат,
		|		ЧекККМБезналичнаяОплата.НомерСертификата КАК НомерСертификата,
		|		ЧекККМБезналичнаяОплата.БонуснаяКарта КАК БонуснаяКарта,
		|		СУММА(ЧекККМБезналичнаяОплата.Сумма) КАК ОплатаПоЧекамККМ,
		|		0 КАК ОплатаПоЧекамККМВозврат,
		|		0 КАК ОплатаПоДокументуОРП
		|	ИЗ
		|		Документ.ЧекККМ КАК ЧекККМ
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОРПДляПроверки КАК ОРПДляПроверки
		|			ПО ЧекККМ.КассоваяСмена = ОРПДляПроверки.Ссылка
		|				И (ЧекККМ.Проведен)
		|				И (НЕ ЧекККМ.Архивный)
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.БезналичнаяОплата КАК ЧекККМБезналичнаяОплата
		|			ПО ЧекККМ.Ссылка = ЧекККМБезналичнаяОплата.Ссылка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОРПДляПроверки.Ссылка,
		|		ЧекККМБезналичнаяОплата.ВидОплаты,
		|		ЧекККМБезналичнаяОплата.НомерПлатежнойКарты,
		|		ЧекККМБезналичнаяОплата.ПодарочныйСертификат,
		|		ЧекККМБезналичнаяОплата.НомерСертификата,
		|		ЧекККМБезналичнаяОплата.БонуснаяКарта
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ОРПДляПроверки.Ссылка,
		|		ЧекККМВозвратБезналичнаяОплата.ВидОплаты,
		|		ЧекККМВозвратБезналичнаяОплата.НомерПлатежнойКарты,
		|		ЧекККМВозвратБезналичнаяОплата.ПодарочныйСертификат,
		|		ЧекККМВозвратБезналичнаяОплата.НомерСертификата,
		|		ЧекККМВозвратБезналичнаяОплата.БонуснаяКарта,
		|		0,
		|		СУММА(ЧекККМВозвратБезналичнаяОплата.Сумма),
		|		0
		|	ИЗ
		|		Документ.ЧекККМВозврат КАК ЧекККМВозврат
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОРПДляПроверки КАК ОРПДляПроверки
		|			ПО ЧекККМВозврат.КассоваяСмена = ОРПДляПроверки.Ссылка
		|				И (ЧекККМВозврат.Проведен)
		|				И (НЕ ЧекККМВозврат.Архивный)
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМВозврат.БезналичнаяОплата КАК ЧекККМВозвратБезналичнаяОплата
		|			ПО ЧекККМВозврат.Ссылка = ЧекККМВозвратБезналичнаяОплата.Ссылка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОРПДляПроверки.Ссылка,
		|		ЧекККМВозвратБезналичнаяОплата.ВидОплаты,
		|		ЧекККМВозвратБезналичнаяОплата.НомерПлатежнойКарты,
		|		ЧекККМВозвратБезналичнаяОплата.ПодарочныйСертификат,
		|		ЧекККМВозвратБезналичнаяОплата.НомерСертификата,
		|		ЧекККМВозвратБезналичнаяОплата.БонуснаяКарта
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ОРПДляПроверки.Ссылка,
		|		ОРПБезналичнаяОплата.ВидОплаты,
		|		ОРПБезналичнаяОплата.НомерПлатежнойКарты,
		|		ОРПБезналичнаяОплата.ПодарочныйСертификат,
		|		ОРПБезналичнаяОплата.НомерСертификата,
		|		ОРПБезналичнаяОплата.БонуснаяКарта,
		|		0,
		|		0,
		|		СУММА(ОРПБезналичнаяОплата.Сумма)
		|	ИЗ
		|		ОРПДляПроверки КАК ОРПДляПроверки
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах.БезналичнаяОплата КАК ОРПБезналичнаяОплата
		|			ПО ОРПДляПроверки.Ссылка = ОРПБезналичнаяОплата.Ссылка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОРПДляПроверки.Ссылка,
		|		ОРПБезналичнаяОплата.ВидОплаты,
		|		ОРПБезналичнаяОплата.НомерПлатежнойКарты,
		|		ОРПБезналичнаяОплата.ПодарочныйСертификат,
		|		ОРПБезналичнаяОплата.НомерСертификата,
		|		ОРПБезналичнаяОплата.БонуснаяКарта) КАК ОплатыПоЧекамИОРП
		|
		|СГРУППИРОВАТЬ ПО
		|	ОплатыПоЧекамИОРП.Ссылка,
		|	ОплатыПоЧекамИОРП.ВидОплаты,
		|	ОплатыПоЧекамИОРП.НомерПлатежнойКарты,
		|	ОплатыПоЧекамИОРП.ПодарочныйСертификат,
		|	ОплатыПоЧекамИОРП.НомерСертификата,
		|	ОплатыПоЧекамИОРП.БонуснаяКарта
		|
		|ИМЕЮЩИЕ
		|	СУММА(ОплатыПоЧекамИОРП.ОплатаПоДокументуОРП) <> СУММА(ОплатыПоЧекамИОРП.ОплатаПоЧекамККМ) - СУММА(ОплатыПоЧекамИОРП.ОплатаПоЧекамККМВозврат)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	СпрНоменклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК СпрНоменклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Константа.ВестиСведенияДляДекларацийПоАлкогольнойПродукции КАК ИспользуетсяЕГАИС
		|		ПО (ИспользуетсяЕГАИС.Значение)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаЗапасы КАК ВременнаяТаблицаЗапасы
		|		ПО СпрНоменклатура.Ссылка = ВременнаяТаблицаЗапасы.Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыАлкогольнойПродукции КАК ВидыАлкогольнойПродукции
		|		ПО СпрНоменклатура.ВидАлкогольнойПродукции = ВидыАлкогольнойПродукции.Ссылка
		|			И (НЕ ВидыАлкогольнойПродукции.Маркируемый)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АктСписанияЕГАИС КАК АктСписанияЕГАИС
		|		ПО (ВременнаяТаблицаЗапасы.Документ = АктСписанияЕГАИС.ДокументОснование)
		|			И (АктСписанияЕГАИС.Проведен)
		|ГДЕ
		|	АктСписанияЕГАИС.Ссылка ЕСТЬ NULL";
	
	ГраницаВключая = Новый Граница(ДатаДокумента, ВидГраницы.Включая);
	Запрос.УстановитьПараметр("ГраницаВключая", ГраницаВключая);
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	ДанныеИзменения = Новый Структура;
	
	Если НЕ МассивРезультатов[0].Пустой() Тогда
		ДанныеИзменения.Вставить("ЕстьОтрицательныеОстатки", Истина);
	КонецЕсли;
	
	Если НЕ МассивРезультатов[2].Пустой() Тогда
		ДанныеИзменения.Вставить("ЕстьРасхождениеПоТоварам", Истина);
	Иначе
		ДанныеИзменения.Вставить("ЕстьРасхождениеПоТоварам", Ложь);
	КонецЕсли;
	
	Если НЕ МассивРезультатов[3].Пустой() Тогда
		ДанныеИзменения.Вставить("ЕстьРасхождениеПоОплате", Истина);
	Иначе
		ДанныеИзменения.Вставить("ЕстьРасхождениеПоОплате", Ложь);
	КонецЕсли;
	
	Если НЕ МассивРезультатов[4].Пустой() Тогда
		ДанныеИзменения.Вставить("НеОформленАктСписанияЕГАИС", Истина);
	Иначе
		ДанныеИзменения.Вставить("НеОформленАктСписанияЕГАИС", Ложь);
	КонецЕсли;
	
	РегистрыСведений.СтатусыОтчетовОРозничныхПродажах.ОбновитьЗапись(ДокументСсылка, ДанныеИзменения);
	
КонецПроцедуры

// Удаляет запись из регистра сведений Статусы отчетов о розничных продажах.
// 
// Параметры:
//  ДокументСсылка - ДокументСсылка.ОтчетОРозничныхПродажах - Документ
Процедура УдалитьСтатусыОтчетаОРозничныхПродажах(ДокументСсылка) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ОтслеживатьСтатусыОтчетовОРозничныхПродажах") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДокументСсылка)
		ИЛИ ТипЗнч(ДокументСсылка) <> Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда
		
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запись = РегистрыСведений.СтатусыОтчетовОРозничныхПродажах.СоздатьМенеджерЗаписи();
	Запись.ОтчетОРозничныхПродажах = ДокументСсылка;
	Запись.Удалить();
	
КонецПроцедуры

#КонецОбласти

Функция ЧекиОтчетаОРозничныхПродажах(ОтчетОРозничныхПродажах, ЧекиНаВозврат = Ложь)
	
	Если ЧекиНаВозврат Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ЧекККМВозврат.Ссылка
		|ИЗ
		|	Документ.ЧекККМВозврат КАК ЧекККМВозврат
		|ГДЕ
		|	ЧекККМВозврат.КассоваяСмена = &КассоваяСмена
		|	И ЧекККМВозврат.Проведен
		|	И ЧекККМВозврат.НомерЧекаККМ <> 0";
	Иначе
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ЧекККМ.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЧекККМ КАК ЧекККМ
		|ГДЕ
		|	ЧекККМ.КассоваяСмена = &КассоваяСмена
		|	И ЧекККМ.Проведен
		|	И ЧекККМ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("КассоваяСмена", ОтчетОРозничныхПродажах);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

#Область ГосИС

Функция ОбработатьДанныеШтрихкода(Форма, ДанныеШтрихкода, ПараметрыСканирования,
	ВложенныеШтрихкоды = Неопределено) Экспорт
	
	// Подготовка параметров штрихкода для обработки.
