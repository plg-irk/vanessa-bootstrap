// Распределяет сумму безналичной оплаты в строке по патентам.
// 
// Параметры:
//  ТаблицаЗапасы - ТаблицаЗначений - Таблица  из запроса по заполнению ОРП
//  ТабличнаяЧастьБезнала - ДокументТабличнаяЧасть.ОтчетОРозничныхПродажах.БезналичнаяОплата - Табличная часть, которую заполняеем
//  СтрокаОплатаПлатежнойКартой - СтрокаТаблицыЗначений - Строка оплата платежной картой
Процедура РазбитьСтрокуОплатыПоПатентам(ТаблицаЗапасы, ТабличнаяЧастьБезнала, СтрокаОплатаПлатежнойКартой)
	
	ЧекККМ = СтрокаОплатаПлатежнойКартой.ЧекККМДляРаспределенияПатентов;
	ОтборСтрок = Новый Структура("ЧекККМДляРаспределенияПатентов", ЧекККМ);
	
	ТаблицаПатентов = ТаблицаЗапасы.Скопировать(ОтборСтрок);
	ТаблицаПатентов.Свернуть("Патент, УчитыватьВНУ, ЭтоВозврат", "Сумма");
	
	СтрокиСуммирования = Новый Структура("ЭтоВозврат", Ложь);
	СуммаВЧекеККМ = ТаблицаПатентов.Скопировать(СтрокиСуммирования).Итог("Сумма");
	КоличествоСтрокСПатентом = ТаблицаПатентов.Количество();
	
	СуммаКомиссииДляРаспределения = СтрокаОплатаПлатежнойКартой.СуммаКомиссии;
	СуммаОплатыКартойДляРаспределения = СтрокаОплатаПлатежнойКартой.Сумма;
	
	НомерСтроки = 1;
	Для Каждого ТекСтрока Из ТаблицаПатентов Цикл
		
		СтрокаТЧ = ТабличнаяЧастьБезнала.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаОплатаПлатежнойКартой);
		
		Если НомерСтроки = КоличествоСтрокСПатентом Тогда
			
			СтрокаТЧ.СуммаКомиссии = СуммаКомиссииДляРаспределения;
			СтрокаТЧ.Сумма = СуммаОплатыКартойДляРаспределения;
			СтрокаТЧ.УчитыватьВНУ = ТекСтрока.УчитыватьВНУ;
			СтрокаТЧ.Патент = ТекСтрока.Патент;
			
		Иначе
			
			ПроцентнаяДоля = ТекСтрока.Сумма / СуммаВЧекеККМ;
			
			СтрокаТЧ.СуммаКомиссии = СтрокаОплатаПлатежнойКартой.СуммаКомиссии * ПроцентнаяДоля;
			СтрокаТЧ.Сумма = СтрокаОплатаПлатежнойКартой.Сумма * ПроцентнаяДоля;
			СтрокаТЧ.УчитыватьВНУ = ТекСтрока.УчитыватьВНУ;
			СтрокаТЧ.Патент = ТекСтрока.Патент;
			
			НомерСтроки = НомерСтроки + 1;
			СуммаКомиссииДляРаспределения = СуммаКомиссииДляРаспределения - СтрокаТЧ.СуммаКомиссии;
			СуммаОплатыКартойДляРаспределения = СуммаОплатыКартойДляРаспределения - СтрокаТЧ.Сумма;
		КонецЕсли;
		
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
