	// Форма
	ТолькоПросмотр = ТолькоПросмотр
		ИЛИ (Объект.ПереданВЕГАИС ИЛИ НЕ ПравоДоступа("Изменение", Метаданные.Документы.ОтчетОРозничныхПродажах));
	
	// Шапка
	ДоступнаОтправкаЕГАИС = ПолучитьФункциональнуюОпцию("ВестиСведенияДляДекларацийПоАлкогольнойПродукции");
	
