&НаКлиенте
Процедура ОплатаПлатежнымиКартамиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "БезналичнаяОплатаНалоговыйУчет" Тогда
		
		ОткрытьФормуРедактированияНастроекНалоговогоУчета(ВыбраннаяСтрока, "БезналичнаяОплата");
		СтандартнаяОбработка = Ложь;
		Возврат;
		
	КонецЕсли;
	
	АвтономнаяККМ = Ложь;
	КэшЗначений.Свойство("АвтономнаяККМ", АвтономнаяККМ);
	
	Если Не РеквизитыЗаблокированы
		И Не Поле.Имя = "БезналичнаяОплатаСуммаКомиссии"
		И Не АвтономнаяККМ Тогда
		РедактироватьОплату();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОплатаПлатежнымиКартамиПередНачаломИзменения(Элемент, Отказ)
	
	АвтономнаяККМ = Ложь;
	КэшЗначений.Свойство("АвтономнаяККМ", АвтономнаяККМ);
	
	Если Не Элемент.ТекущийЭлемент.Имя = "БезналичнаяОплатаСуммаКомиссии"
		И Не АвтономнаяККМ Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

