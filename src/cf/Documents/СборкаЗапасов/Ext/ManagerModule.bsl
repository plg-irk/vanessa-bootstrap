			ВыборкаИзРезультатаЗапроса = РезультатыЗапроса[7].Выбрать(); 
			УправлениеНебольшойФирмойСервер.СообщитьОбОшибкахПроведенияПоРегиструПрослеживаемыеТовары(
				ДокументОбъектСборкаЗапасов, ВыборкаИзРезультатаЗапроса, Отказ);
			
		КонецЕсли;
			
		// Отрицательный остаток запасов к поступлению.
		Если НЕ РезультатыЗапроса[8].Пустой() Тогда 
			ВыборкаИзРезультатаЗапроса = РезультатыЗапроса[8].Выбрать();
			КонтрольОстатковУНФ.ЗапасыКПоступлению(ДокументОбъектСборкаЗапасов, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
		// Отрицательный остаток по сериям номенклатуры к поступлению.
		Если НЕ РезультатыЗапроса[9].Пустой() Тогда 
			ВыборкаИзРезультатаЗапроса = РезультатыЗапроса[9].Выбрать();
			КонтрольОстатковУНФ.СерииНоменклатурыКПоступлению(ДокументОбъектСборкаЗапасов, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
		// Отрицательный остаток запасов к расходу.
		Если НЕ РезультатыЗапроса[10].Пустой() Тогда 
			ВыборкаИзРезультатаЗапроса = РезультатыЗапроса[10].Выбрать();
			КонтрольОстатковУНФ.ЗапасыКРасходу(ДокументОбъектСборкаЗапасов, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
		// Отрицательный остаток по сериям номенклатуры к расходу.
		Если НЕ РезультатыЗапроса[11].Пустой() Тогда 
			ВыборкаИзРезультатаЗапроса = РезультатыЗапроса[11].Выбрать();
			КонтрольОстатковУНФ.СерииНоменклатурыКРасходуПоДокументам(ДокументОбъектСборкаЗапасов, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
		// Отрицательный остаток по запасам с учетом резервов к передаче
		Если НЕ РезультатыЗапроса[12].Пустой() И НЕ Отказ Тогда
			ВыборкаИзРезультатаЗапроса = РезультатыЗапроса[12].Выбрать();
			КонтрольОстатковУНФ.РезервыКПередачиСУчетомОстатковПоЗапасамНаСкладах(ДокументОбъектСборкаЗапасов, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры // ВыполнитьКонтроль()

#КонецОбласти 

#Область ИнтерфейсПечати

Функция ДанныеДокументовБланкТоварногоНаполнения(МассивОбъектов)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("ПроизводствоСборка", НСтр("ru = 'Производство (сборка)'"));
	Запрос.УстановитьПараметр("ПроизводствоРазборка", НСтр("ru = 'Производство (разборка)'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СборкаЗапасов.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА СборкаЗапасов.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСборкаЗапасов.Сборка)
	|			ТОГДА &ПроизводствоСборка
	|		ИНАЧЕ &ПроизводствоРазборка
	|	КОНЕЦ КАК ПредставлениеРегистратора,
	|	СборкаЗапасов.ВидОперации КАК ВидОперации,
	|	СборкаЗапасов.Номер КАК Номер,
	|	СборкаЗапасов.Дата КАК ДатаДокумента,
	|	СборкаЗапасов.ПоложениеСклада КАК ПоложениеСклада,
	|	СборкаЗапасов.СтруктурнаяЕдиница КАК ПредставлениеСклада,
	|	СборкаЗапасов.Ячейка КАК ПредставлениеЯчейки,
	|	СборкаЗапасов.Организация.Префикс КАК Префикс,
	|	СборкаЗапасов.Запасы.(
	|		НомерСтроки КАК НомерСтроки,
	|		НЕОПРЕДЕЛЕНО КАК Содержание,
	|		ВЫБОР
	|			КОГДА ВЫРАЗИТЬ(СборкаЗапасов.Запасы.Номенклатура.НаименованиеПолное КАК СТРОКА(1000)) = """"
	|				ТОГДА СборкаЗапасов.Запасы.Номенклатура.Наименование
	|			ИНАЧЕ ВЫРАЗИТЬ(СборкаЗапасов.Запасы.Номенклатура.НаименованиеПолное КАК СТРОКА(1000))
	|		КОНЕЦ КАК ПредставлениеНоменклатуры,
	|		Характеристика КАК Характеристика,
	|		Номенклатура.Артикул КАК Артикул,
	|		Номенклатура.Штрихкод КАК Штрихкод,
	|		Номенклатура.Код КАК Код,
	|		Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|		СтруктурнаяЕдиница КАК Склад,
	|		Ячейка КАК Ячейка,
	|		ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|		Количество КАК Количество,
	|		КлючСвязи КАК КлючСвязи) КАК ТаблицаЗапасы,
	|	СборкаЗапасов.Продукция.(
	|		НомерСтроки КАК НомерСтроки,
	|		НЕОПРЕДЕЛЕНО КАК Содержание,
	|		ВЫБОР
	|			КОГДА ВЫРАЗИТЬ(СборкаЗапасов.Продукция.Номенклатура.НаименованиеПолное КАК СТРОКА(100)) = """"
	|				ТОГДА СборкаЗапасов.Продукция.Номенклатура.Наименование
	|			ИНАЧЕ СборкаЗапасов.Продукция.Номенклатура.НаименованиеПолное
	|		КОНЕЦ КАК ПредставлениеНоменклатуры,
	|		Характеристика КАК Характеристика,
	|		Номенклатура.Артикул КАК Артикул,
	|		Номенклатура.Штрихкод КАК Штрихкод,
	|		Номенклатура.Код КАК Код,
	|		Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|		СтруктурнаяЕдиница КАК Склад,
	|		Ячейка КАК Ячейка,
	|		ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|		Количество КАК Количество,
	|		КлючСвязи КАК КлючСвязи) КАК ТаблицаПродукция,
	|	СборкаЗапасов.СерииНоменклатуры.(
	|		Серия КАК Серия,
	|		КлючСвязи КАК КлючСвязи) КАК ТаблицаСерииНоменклатуры,
	|	СборкаЗапасов.СерииНоменклатурыПродукция.(
	|		Серия КАК Серия,
	|		КлючСвязи КАК КлючСвязи) КАК ТаблицаСерииНоменклатурыПродукции
	|ИЗ
	|	Документ.СборкаЗапасов КАК СборкаЗапасов
	|ГДЕ
	|	СборкаЗапасов.Ссылка В (&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СборкаЗапасовЗапасы.НомерСтроки КАК НомерСтроки,
	|	СборкаЗапасовЗапасы.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ШтрихкодыНоменклатуры.Штрихкод, СборкаЗапасовЗапасы.Номенклатура.Штрихкод) КАК Штрихкод
	|ИЗ
	|	Документ.СборкаЗапасов.Запасы КАК СборкаЗапасовЗапасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ПО СборкаЗапасовЗапасы.Номенклатура = ШтрихкодыНоменклатуры.Номенклатура
	|		И СборкаЗапасовЗапасы.Характеристика = ШтрихкодыНоменклатуры.Характеристика
	|		И СборкаЗапасовЗапасы.Партия = ШтрихкодыНоменклатуры.Партия
	|ГДЕ
	|	СборкаЗапасовЗапасы.Ссылка В (&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	НомерСтроки,
	|	Штрихкод
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СборкаЗапасовПродукция.НомерСтроки КАК НомерСтроки,
	|	СборкаЗапасовПродукция.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ШтрихкодыНоменклатуры.Штрихкод, СборкаЗапасовПродукция.Номенклатура.Штрихкод) КАК Штрихкод
	|ИЗ
	|	Документ.СборкаЗапасов.Продукция КАК СборкаЗапасовПродукция
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ПО СборкаЗапасовПродукция.Номенклатура = ШтрихкодыНоменклатуры.Номенклатура
	|		И СборкаЗапасовПродукция.Характеристика = ШтрихкодыНоменклатуры.Характеристика
	|		И СборкаЗапасовПродукция.Партия = ШтрихкодыНоменклатуры.Партия
	|ГДЕ
	|	СборкаЗапасовПродукция.Ссылка В (&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	НомерСтроки,
	|	Штрихкод";
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ТаблицаДанных = РезультатыЗапроса[0].Выгрузить();
	
	ШтрихкодыНоменклатурыЗапасы = РезультатыЗапроса[1].Выгрузить();
	ШтрихкодыНоменклатурыЗапасы.Индексы.Добавить("Ссылка");
	ШтрихкодыНоменклатурыЗапасы.Индексы.Добавить("НомерСтроки");
	
	ШтрихкодыНоменклатурыПродукция = РезультатыЗапроса[2].Выгрузить();
	ШтрихкодыНоменклатурыПродукция.Индексы.Добавить("Ссылка");
	ШтрихкодыНоменклатурыПродукция.Индексы.Добавить("НомерСтроки");
	
	ПараметрыПоискаШтрихкодыНоменклатуры = Новый Структура("Ссылка, НомерСтроки");
	
	Для каждого СтрокаТаблицы Из ТаблицаДанных Цикл
		
		ПараметрыПоискаШтрихкодыНоменклатуры.Ссылка = СтрокаТаблицы.Ссылка;
		
		Для Каждого СтрокаТаблицыЗапасы Из СтрокаТаблицы.ТаблицаЗапасы Цикл
			ПараметрыПоискаШтрихкодыНоменклатуры.НомерСтроки = СтрокаТаблицыЗапасы.НомерСтроки;
			НайденныеСтрокиШтрихкодыЗапасы = ШтрихкодыНоменклатурыЗапасы.НайтиСтроки(
				ПараметрыПоискаШтрихкодыНоменклатуры);
			Если НайденныеСтрокиШтрихкодыЗапасы.Количество() > 0 Тогда
				СтрокаТаблицыЗапасы.Штрихкод = НайденныеСтрокиШтрихкодыЗапасы[0].Штрихкод;
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого СтрокаТаблицыПродукция Из СтрокаТаблицы.ТаблицаПродукция Цикл
			ПараметрыПоискаШтрихкодыНоменклатуры.НомерСтроки = СтрокаТаблицыПродукция.НомерСтроки;
			НайденныеСтрокиШтрихкодыПродукция = ШтрихкодыНоменклатурыЗапасы.НайтиСтроки(
				ПараметрыПоискаШтрихкодыНоменклатуры);
			Если НайденныеСтрокиШтрихкодыПродукция.Количество() > 0 Тогда
				СтрокаТаблицыПродукция.Штрихкод = НайденныеСтрокиШтрихкодыПродукция[0].Штрихкод;
			КонецЕсли;
		КонецЦикла;
		
		Если СтрокаТаблицы.ВидОперации = Перечисления.ВидыОперацийСборкаЗапасов.Разборка Тогда
			
			СтрокаТаблицы.ТаблицаЗапасы = СтрокаТаблицы.ТаблицаПродукция;
			СтрокаТаблицы.ТаблицаСерииНоменклатуры = СтрокаТаблицы.ТаблицаСерииНоменклатурыПродукции;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаДанных.Колонки.Удалить("ТаблицаПродукция");
	ТаблицаДанных.Колонки.Удалить("ТаблицаСерииНоменклатурыПродукции");
	
	Возврат ТаблицаДанных;
	
КонецФункции

Функция ДанныеДокументовМХ18(МассивОбъектов)
	
	ДанныеДокументовДляПечати = Новый ТаблицаЗначений;
	
	ВалютаВидаЦен = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Справочники.ВидыЦен.Учетная, "ВалютаЦены");
	ДатыДокументов = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(МассивОбъектов, "Дата");
	Для каждого ОбъектПечати Из МассивОбъектов Цикл
		
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("ТекущийДокумент", ОбъектПечати);
		Запрос.УстановитьПараметр("ДатаКурса", ДатыДокументов[ОбъектПечати]);
		Запрос.УстановитьПараметр("ДатаДокумента", ДатыДокументов[ОбъектПечати]);
		Запрос.УстановитьПараметр("ВалютаВидаЦен", ВалютаВидаЦен);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	СборкаЗапасов.Ссылка КАК Ссылка,
		|	СборкаЗапасов.Дата КАК ДатаДокумента,
		|	СборкаЗапасов.Организация КАК Организация,
		|	СборкаЗапасов.Номер КАК Номер,
		|	СборкаЗапасов.Организация.Префикс КАК Префикс,
		|	СборкаЗапасов.СтруктурнаяЕдиница КАК Отправитель,
		|	СборкаЗапасов.СтруктурнаяЕдиницаПродукции КАК Получатель,
		|	НЕОПРЕДЕЛЕНО КАК КорСчет,
		|	НациональнаяВалюта.Значение КАК ВалютаДокумента,
		|	СборкаЗапасов.ПодписьКладовщикаОтправил.Должность КАК ДолжностьКладовщикаОтпустил,
		|	СборкаЗапасов.ПодписьКладовщикаОтправил.РасшифровкаПодписи КАК РасшифровкаПодписиКладовщикаОтпустил,
		|	СборкаЗапасов.ПодписьКонтролера.Должность КАК ДолжностьКонтролера,
		|	СборкаЗапасов.ПодписьКонтролера.РасшифровкаПодписи КАК РасшифровкаПодписиКонтролера,
		|	СборкаЗапасов.ПодписьКладовщикаПолучил.Должность КАК ДолжностьКладовщикаПринял,
		|	СборкаЗапасов.ПодписьКладовщикаПолучил.РасшифровкаПодписи КАК РасшифровкаПодписиКладовщикаПринял,
		|	ВЫБОР
		|		КОГДА СборкаЗапасов.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСборкаЗапасов.Сборка)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоСборкаЗапасов,
		|	НЕОПРЕДЕЛЕНО КАК ТаблицаЗапасы
		|ИЗ
		|	Документ.СборкаЗапасов КАК СборкаЗапасов,
		|	Константа.НациональнаяВалюта КАК НациональнаяВалюта
		|ГДЕ
		|	СборкаЗапасов.Ссылка = &ТекущийДокумент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СборкаЗапасовПродукция.НомерСтроки,
		|	ВЫБОР
		|		КОГДА ВЫРАЗИТЬ(СборкаЗапасовПродукция.Номенклатура.НаименованиеПолное КАК СТРОКА(1000)) = """"
		|			ТОГДА СборкаЗапасовПродукция.Номенклатура.Наименование
		|		ИНАЧЕ ВЫРАЗИТЬ(СборкаЗапасовПродукция.Номенклатура.НаименованиеПолное КАК СТРОКА(1000))
		|	КОНЕЦ КАК ПредставлениеНоменклатуры,
		|	СборкаЗапасовПродукция.Характеристика,
		|	СборкаЗапасовПродукция.Номенклатура.Код КАК Код,
		|	СборкаЗапасовПродукция.Номенклатура.Артикул КАК Артикул,
		|	СборкаЗапасовПродукция.Номенклатура.Штрихкод КАК Штрихкод,
		|	СборкаЗапасовПродукция.Номенклатура.СчетУчетаЗапасов.Код КАК Счет,
		|	СборкаЗапасовПродукция.Номенклатура.Код КАК ТоварКод,
		|	СборкаЗапасовПродукция.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияНаименование,
		|	СборкаЗапасовПродукция.Номенклатура.ЕдиницаИзмерения.Код КАК ЕдиницаИзмеренияКодПоОКЕИ,
		|	СборкаЗапасовПродукция.Количество КАК Количество,
		|	СборкаЗапасовПродукция.Количество КАК КоличествоМест,
		|	СборкаЗапасовПродукция.Резерв КАК Резерв,
		|	СборкаЗапасовПродукция.ЗаказПокупателя КАК ЗаказПокупателя,
		|	СборкаЗапасовПродукция.ЕдиницаИзмерения.Наименование КАК ВидУпаковки,
		|	ВЫБОР
