Функция ПолучитьТаблицуВосстановленПоАвансамУпрощенныйУчетНДС(СтруктураПараметров)

//	ВидыСубконто = Новый Массив;
//	ВидыСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
//	ВидыСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СФПолученные);
//	
//	МассивСчетовАвансов = Новый Массив();
//	МассивСчетовАвансов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданным); // 60.02
//	МассивСчетовАвансов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданнымВал); // 60.22
//	МассивСчетовАвансов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданнымУЕ); // 60.32
//	
//	СубконтоСчетаРасчетов_ЕстьДР = Новый Массив();
//	СубконтоСчетаРасчетов_ЕстьДР.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
//	СубконтоСчетаРасчетов_ЕстьДР.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
//	СубконтоСчетаРасчетов_ЕстьДР.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами);
//	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",         СтруктураПараметров.Организация);
	Запрос.УстановитьПараметр("ДатаГраница",         Новый Граница(КонецДня(СтруктураПараметров.Дата), ВидГраницы.Включая));
	
	// Движения по курсовым разницам не должны вызывать регистрации аванса
//	Запрос.УстановитьПараметр("МассивСчетовАвансов",          МассивСчетовАвансов);
//	Запрос.УстановитьПараметр("ВидыСубконто",                 ВидыСубконто);
//	Запрос.УстановитьПараметр("СубконтоСчетаРасчетов_ЕстьДР", СубконтоСчетаРасчетов_ЕстьДР);
	
	// Подготавливаем исходные данные.
	Запрос.Текст = ПолучитьТекстЗапросаВосстановленПоАвансамУпрощенныйУчетНДС();
	
	УстановитьПривилегированныйРежим(Истина);
	Результаты = Запрос.ВыполнитьПакет();
	
	ОстаткиПоРегистру = Результаты[5].Выгрузить();
	КоличествоСтрокОстаткаПоРегистру = ОстаткиПоРегистру.Количество();
	Если КоличествоСтрокОстаткаПоРегистру = 0 Тогда
		Возврат ОстаткиПоРегистру;
	КонецЕсли;
	
	ОстаткиПоСчету = Результаты[6].Выгрузить();
	
	// Параллельно обходим две таблицы, одинаково отсортированые.
	ИндексСтрокиОстаткаПоРегистру = 0;
	Для каждого СтрокаОстаткаПоСчету Из ОстаткиПоСчету Цикл
		
		// Проходим остатки по регистру, которые соответствуют остаткам по счету.
	    Пока ИндексСтрокиОстаткаПоРегистру < КоличествоСтрокОстаткаПоРегистру Цикл
	    
	    	СтрокаОстаткаПоРегистру = ОстаткиПоРегистру[ИндексСтрокиОстаткаПоРегистру];
			Если СтрокаОстаткаПоРегистру.СчетФактура <> СтрокаОстаткаПоСчету.СчетФактура
			 Или СтрокаОстаткаПоРегистру.Поставщик <> СтрокаОстаткаПоСчету.Поставщик Тогда
				Прервать; // данные, соответствующие другому остатку по счету
			КонецЕсли;
	
	        Если СтрокаОстаткаПоСчету.СуммаНДСАванса = 0 Тогда
		    	// не должно быть остатков по регистру, если нет остатков по счету
		    	ОстаткиПоРегистру.Удалить(ИндексСтрокиОстаткаПоРегистру);
		    	КоличествоСтрокОстаткаПоРегистру = КоличествоСтрокОстаткаПоРегистру - 1;
		    	
		    Иначе
				
		    	Если СтрокаОстаткаПоСчету.СуммаНДСАванса >= СтрокаОстаткаПоРегистру.НДС Тогда
					СтрокаОстаткаПоСчету.СуммаНДСАванса = СтрокаОстаткаПоСчету.СуммаНДСАванса - СтрокаОстаткаПоРегистру.НДС;
				Иначе				
					СтрокаОстаткаПоРегистру.СуммаБезНДС = Окр(СтрокаОстаткаПоРегистру.СуммаБезНДС
						- (СтрокаОстаткаПоРегистру.СуммаБезНДС / СтрокаОстаткаПоРегистру.НДС) * СтрокаОстаткаПоСчету.СуммаНДСАванса, 2);
					СтрокаОстаткаПоРегистру.НДС = СтрокаОстаткаПоРегистру.НДС - СтрокаОстаткаПоСчету.СуммаНДСАванса;
				КонецЕсли;
				ИндексСтрокиОстаткаПоРегистру = ИндексСтрокиОстаткаПоРегистру + 1;
		    
			КонецЕсли; 
	    
	    КонецЦикла;
	    
	КонецЦикла;
	
	Если КоличествоСтрокОстаткаПоРегистру = 0 Тогда
		Возврат ОстаткиПоРегистру;
	КонецЕсли;
	
	СравнениеПоИдентификатору = Новый СравнениеЗначений;
	ОстаткиПоРегистру.Сортировать("Поставщик, СчетФактура, ДоговорКонтрагента", СравнениеПоИдентификатору);
	НепогашенныеАвансы = Результаты[7].Выбрать(); // отсортированы как ОстаткиПоРегистру
	
	// Параллельно обходим две таблицы, одинаково отсортированые.
	СтруктураОтбора = СтруктураОтбораСтрок();
	МассивСуммаБезНДС = Новый Массив;
	МассивСуммаНДС    = Новый Массив;
	ИндексСтрокиОстаткаПоРегистру = 0;
	Пока НепогашенныеАвансы.Следующий() Цикл
	
		СуммаБезНДС = 0;
		МассивСуммаБезНДС.Очистить();
		СуммаНДС = 0;
		МассивСуммаНДС.Очистить();
		СтавкаНДС = Перечисления.СтавкиНДС.ПустаяСсылка();
		
		СуммаНепогашенногоАванса = НепогашенныеАвансы.Сумма;
		
		Если СтруктураОтбора.СчетФактура <> НепогашенныеАвансы.СчетФактура
			ИЛИ СтруктураОтбора.Поставщик <> НепогашенныеАвансы.Поставщик 
			ИЛИ СтруктураОтбора.ДоговорКонтрагента <> НепогашенныеАвансы.ДоговорКонтрагента Тогда
			// Повторный поиск (например, если разные ДатаСобытия) не выполняем. Используем ранее полученные строки.
			
			СтруктураОтбора.Поставщик          = НепогашенныеАвансы.Поставщик;
			СтруктураОтбора.ДоговорКонтрагента = НепогашенныеАвансы.ДоговорКонтрагента;
			СтруктураОтбора.СчетФактура        = НепогашенныеАвансы.СчетФактура;
			СтрокиАвансаПоОтбору = УчетНДСПереопределяемый.НайтиСтрокиПоОтбору(
				ОстаткиПоРегистру, ИндексСтрокиОстаткаПоРегистру, СтруктураОтбора, "Поставщик", СравнениеПоИдентификатору);
				
		КонецЕсли;
	
		Для каждого СтрокаАвансаПоОтбору Из СтрокиАвансаПоОтбору Цикл
			МассивСуммаБезНДС.Добавить(СтрокаАвансаПоОтбору.СуммаБезНДС);
			МассивСуммаНДС.Добавить(СтрокаАвансаПоОтбору.НДС);
			
			СуммаБезНДС = СуммаБезНДС + СтрокаАвансаПоОтбору.СуммаБезНДС;
			СуммаНДС    = СуммаНДС + СтрокаАвансаПоОтбору.НДС;
			
			Если СтрокаАвансаПоОтбору.ВидЦенности = Перечисления.ВидыЦенностей.АвансыВыданныеНалоговыйАгент Тогда
				СтавкаНДС = СтрокаАвансаПоОтбору.СтавкаНДС;
			КонецЕсли;
			
		КонецЦикла;
		
		Если СтавкаНДС <> Перечисления.СтавкиНДС.ПустаяСсылка() Тогда
			// Поставщик товаров, указанных в п.8 ст. 161 НК, не предъявляет НДС.
			// Соответственно сумма остатка аванса на счете 60.х2 не включает НДС.
			// Для правильного определения суммы без НДС и НДС необходимо увеличить сумму непогашенного аванса на сумму НДС.
			СтавкаНДСЧисло = УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(СтавкаНДС);
			СуммаНепогашенногоАванса = СуммаНепогашенногоАванса + СуммаНепогашенногоАванса * СтавкаНДСЧисло / 100;
		КонецЕсли; 
		
		СуммаСНДС = Мин(СуммаНепогашенногоАванса, СуммаБезНДС + СуммаНДС);
		Если СуммаСНДС = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СуммаБезНДС = Окр(СуммаБезНДС * СуммаСНДС / (СуммаБезНДС + СуммаНДС), 2);
		Если СуммаБезНДС > 0 Тогда
			МассивСуммаБезНДС = ОбщегоНазначенияУНФКлиентСервер.РаспределитьПропорционально(СуммаБезНДС, МассивСуммаБезНДС);
		КонецЕсли;
		
		СуммаНДС = СуммаСНДС - СуммаБезНДС;
		Если СуммаНДС > 0 Тогда
			МассивСуммаНДС = ОбщегоНазначенияУНФКлиентСервер.РаспределитьПропорционально(СуммаНДС, МассивСуммаНДС);
		КонецЕсли;
		
		Если МассивСуммаБезНДС = Неопределено
		 Или МассивСуммаНДС = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Счетчик = 0;
		Для каждого СтрокаАвансаПоОтбору Из СтрокиАвансаПоОтбору Цикл
			СтрокаАвансаПоОтбору.СуммаБезНДС = СтрокаАвансаПоОтбору.СуммаБезНДС - ?(СуммаБезНДС > 0, МассивСуммаБезНДС[Счетчик], 0);
			СтрокаАвансаПоОтбору.НДС = СтрокаАвансаПоОтбору.НДС - ?(СуммаНДС > 0, МассивСуммаНДС[Счетчик], 0);
			Счетчик = Счетчик + 1;
		КонецЦикла;
		
	КонецЦикла;
	
	СтрокиКУдалению = ОстаткиПоРегистру.НайтиСтроки(Новый Структура("СуммаБезНДС, НДС", 0, 0));
	Для каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
		ОстаткиПоРегистру.Удалить(СтрокаКУдалению);
	КонецЦикла; 
	
	Возврат ОстаткиПоРегистру;
		
КонецФункции

Функция ПолучитьТекстЗапросаВосстановленПоАвансамУпрощенныйУчетНДС()

    // 0. Остатки по БУ.
    // 1. Исключаем полученные счета-фактуры на аванс по договорам вида "С комиссионером на закупку", составленные от имени поставщиков.
    //    Восстановление НДС по таким счетам-фактурам производится вручную на основании информации, полученной от комиссионера.
    // 2. Договоры счетов-фактур по документу аванса.
    // 3-5. Получаем обороты из регистра накопления НДСЗаписиКнигиПокупок за вычетом НДСЗаписиКнигиПродаж.
    // 6. Получаем остатки по БУ.
    // 7. Список счетов, имеющих субконто ДокументыРасчетовСКонтрагентами.
    // 8. Получим остатки по авансам для определения суммы незачтенного аванса.
    
    ТекстЗапроса =
    "ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	НДСАвансыВыданные.Контрагент КАК Поставщик,
    |	НДСАвансыВыданные.ДокументОплаты КАК СчетФактура,
    |	-1 * НДСАвансыВыданные.НДСОстаток КАК СуммаНДСАванса,
    |	НДСАвансыВыданные.ДоговорКонтрагента КАК ДоговорКонтрагента
    |ПОМЕСТИТЬ ОстаткиПоСчету
    |ИЗ
    |	РегистрНакопления.НДСАвансыВыданные.Остатки(&ДатаГраница, Организация = &Организация) КАК НДСАвансыВыданные
    |
    |ИНДЕКСИРОВАТЬ ПО
    |	СчетФактура
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	ОстаткиПоСчету.СчетФактура КАК СчетФактура
    |ПОМЕСТИТЬ СписокСчетовФактур
    |ИЗ
    |	ОстаткиПоСчету КАК ОстаткиПоСчету
    |
    |ИНДЕКСИРОВАТЬ ПО
    |	СчетФактура
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ОстаткиПоСчету.СчетФактура КАК СчетФактура,
    |	ЕСТЬNULL(ОстаткиПоСчету.СчетФактура.Договор, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК
    |		ДоговорКонтрагента
    |ПОМЕСТИТЬ ДоговорыСчетовФактур
    |ИЗ
    |	ОстаткиПоСчету КАК ОстаткиПоСчету
    |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный.ДокументыОснования КАК СчетФактураПолученныйДокументыОснования
    |		ПО ОстаткиПоСчету.СчетФактура = СчетФактураПолученныйДокументыОснования.ДокументОснование
    |ГДЕ
    |	СчетФактураПолученныйДокументыОснования.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСчетФактураПолученный.Аванс)
    |	И НЕ СчетФактураПолученныйДокументыОснования.Ссылка.ПометкаУдаления
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ОстаткиПоСчету.СчетФактура,
    |	ЕСТЬNULL(СчетФактураПолученныйДокументыОснования.Ссылка.Договор,
    |		ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка))
    |ИЗ
    |	ОстаткиПоСчету КАК ОстаткиПоСчету
    |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный.ДокументыОснования КАК СчетФактураПолученныйДокументыОснования
    |		ПО ОстаткиПоСчету.СчетФактура = СчетФактураПолученныйДокументыОснования.ДокументОснование
    |ГДЕ
    |	СчетФактураПолученныйДокументыОснования.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСчетФактураПолученный.КорректировкаАванса)
    |	И НЕ СчетФактураПолученныйДокументыОснования.Ссылка.ПометкаУдаления
    |
    |ИНДЕКСИРОВАТЬ ПО
    |	СчетФактура,
    |	ДоговорКонтрагента
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	НДСЗаписиКнигиПокупокОбороты.СчетФактура КАК СчетФактура,
    |	НДСЗаписиКнигиПокупокОбороты.Поставщик КАК Поставщик,
    |	НДСЗаписиКнигиПокупокОбороты.ДоговорКонтрагента КАК ДоговорКонтрагента,
    |	НДСЗаписиКнигиПокупокОбороты.СтавкаНДС КАК СтавкаНДС,
    |	НДСЗаписиКнигиПокупокОбороты.ВидЦенности КАК ВидЦенности,
    |	НДСЗаписиКнигиПокупокОбороты.СуммаБезНДСОборот КАК СуммаБезНДС,
    |	НДСЗаписиКнигиПокупокОбороты.НДСОборот КАК НДС,
    |	НДСЗаписиКнигиПокупокОбороты.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура
    |ПОМЕСТИТЬ НДСЗаписиКнигиПокупокОбороты
    |ИЗ
    |	РегистрНакопления.НДСЗаписиКнигиПокупок.Обороты(, &ДатаГраница,, СчетФактура В
    |		(ВЫБРАТЬ
    |			СписокСчетовФактур.СчетФактура
    |		ИЗ
    |			СписокСчетовФактур КАК СписокСчетовФактур)
    |	И ВидЦенности В (ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.АвансыВыданные),
    |		ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.АвансыВыданныеНалоговыйАгент))) КАК НДСЗаписиКнигиПокупокОбороты
    |
    |ИНДЕКСИРОВАТЬ ПО
    |	СчетФактура
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	НДСЗаписиКнигиПокупокОбороты.СчетФактура КАК СчетФактура,
    |	НДСЗаписиКнигиПокупокОбороты.Покупатель КАК Покупатель,
    |	НДСЗаписиКнигиПокупокОбороты.ДоговорКонтрагента КАК ДоговорКонтрагента,
    |	НДСЗаписиКнигиПокупокОбороты.СтавкаНДС КАК СтавкаНДС,
    |	НДСЗаписиКнигиПокупокОбороты.ВидЦенности КАК ВидЦенности,
    |	НДСЗаписиКнигиПокупокОбороты.СуммаБезНДСОборот КАК СуммаБезНДС,
    |	НДСЗаписиКнигиПокупокОбороты.НДСОборот КАК НДС,
    |	НДСЗаписиКнигиПокупокОбороты.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура
    |ПОМЕСТИТЬ НДСЗаписиКнигиПродажОбороты
    |ИЗ
    |	РегистрНакопления.НДСЗаписиКнигиПродаж.Обороты(, &ДатаГраница,, СчетФактура В
    |		(ВЫБРАТЬ
    |			СписокСчетовФактур.СчетФактура
    |		ИЗ
    |			СписокСчетовФактур КАК СписокСчетовФактур)
    |	И ВидЦенности В (ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.АвансыВыданные),
    |		ЗНАЧЕНИЕ(Перечисление.ВидыЦенностей.АвансыВыданныеНалоговыйАгент))) КАК НДСЗаписиКнигиПокупокОбороты
    |
    |ИНДЕКСИРОВАТЬ ПО
    |	СчетФактура
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	НДСЗаписиКнигиПокупокОбороты.СчетФактура КАК СчетФактура,
    |	НДСЗаписиКнигиПокупокОбороты.Поставщик КАК Поставщик,
    |	НДСЗаписиКнигиПокупокОбороты.ДоговорКонтрагента КАК ДоговорКонтрагента,
    |	НДСЗаписиКнигиПокупокОбороты.СтавкаНДС КАК СтавкаНДС,
    |	НДСЗаписиКнигиПокупокОбороты.ВидЦенности КАК ВидЦенности,
    |	НДСЗаписиКнигиПокупокОбороты.СуммаБезНДС - ЕСТЬNULL(НДСЗаписиКнигиПродажОбороты.СуммаБезНДС, 0) КАК СуммаБезНДС,
    |	НДСЗаписиКнигиПокупокОбороты.НДС - ЕСТЬNULL(НДСЗаписиКнигиПродажОбороты.НДС, 0) КАК НДС,
    |	НДСЗаписиКнигиПокупокОбороты.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура
    |ИЗ
    |	НДСЗаписиКнигиПокупокОбороты КАК НДСЗаписиКнигиПокупокОбороты
    |		ЛЕВОЕ СОЕДИНЕНИЕ НДСЗаписиКнигиПродажОбороты КАК НДСЗаписиКнигиПродажОбороты
    |		ПО НДСЗаписиКнигиПокупокОбороты.СчетФактура = НДСЗаписиКнигиПродажОбороты.СчетФактура
    |		И НДСЗаписиКнигиПокупокОбороты.ВидЦенности = НДСЗаписиКнигиПродажОбороты.ВидЦенности
    |		И НДСЗаписиКнигиПокупокОбороты.СтавкаНДС = НДСЗаписиКнигиПродажОбороты.СтавкаНДС
    |		И НДСЗаписиКнигиПокупокОбороты.ДоговорКонтрагента = НДСЗаписиКнигиПродажОбороты.ДоговорКонтрагента
    |		И НДСЗаписиКнигиПокупокОбороты.ИсправленныйСчетФактура = НДСЗаписиКнигиПродажОбороты.ИсправленныйСчетФактура
    |		И НДСЗаписиКнигиПокупокОбороты.Поставщик = НДСЗаписиКнигиПродажОбороты.Покупатель
    |ГДЕ
    |	НДСЗаписиКнигиПокупокОбороты.НДС - ЕСТЬNULL(НДСЗаписиКнигиПродажОбороты.НДС, 0) > 0
    |
    |УПОРЯДОЧИТЬ ПО
    |	СчетФактура,
    |	Поставщик
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	ОстаткиПоСчету.СчетФактура КАК СчетФактура,
    |	ОстаткиПоСчету.Поставщик КАК Поставщик,
    |	ОстаткиПоСчету.СуммаНДСАванса КАК СуммаНДСАванса
    |ИЗ
    |	ОстаткиПоСчету КАК ОстаткиПоСчету
    |
    |УПОРЯДОЧИТЬ ПО
    |	СчетФактура,
    |	Поставщик
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	РасчетыСПоставщиками.Контрагент КАК Поставщик,
    |	ЕСТЬNULL(ДоговорыСчетовФактур.ДоговорКонтрагента, РасчетыСПоставщиками.Договор) КАК ДоговорКонтрагента,
    |	РасчетыСПоставщиками.Документ КАК СчетФактура,
    |	СУММА(РасчетыСПоставщиками.СуммаОстаток) * -1 КАК Сумма
    |ИЗ
    |	РегистрНакопления.РасчетыСПоставщиками.Остатки(&ДатаГраница, ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс)
    |	И Организация = &Организация
    |	И Документ В
    |		(ВЫБРАТЬ
    |			СписокСчетовФактур.СчетФактура
    |		ИЗ
    |			СписокСчетовФактур КАК СписокСчетовФактур)) КАК РасчетыСПоставщиками
    |		ЛЕВОЕ СОЕДИНЕНИЕ ДоговорыСчетовФактур КАК ДоговорыСчетовФактур
    |		ПО РасчетыСПоставщиками.Документ = ДоговорыСчетовФактур.СчетФактура
    |		И ВЫБОР
    |			КОГДА ДоговорыСчетовФактур.ДоговорКонтрагента <> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
    |				ТОГДА РасчетыСПоставщиками.Договор = ДоговорыСчетовФактур.ДоговорКонтрагента
    |			ИНАЧЕ ИСТИНА
    |		КОНЕЦ
    |ГДЕ
    |	РасчетыСПоставщиками.СуммаОстаток * -1 > 0
    |СГРУППИРОВАТЬ ПО
    |	РасчетыСПоставщиками.Контрагент,
    |	РасчетыСПоставщиками.Документ,
    |	ЕСТЬNULL(ДоговорыСчетовФактур.ДоговорКонтрагента, РасчетыСПоставщиками.Договор)
    |
    |УПОРЯДОЧИТЬ ПО
    |	Поставщик,
    |	СчетФактура,
    |	ДоговорКонтрагента";
    
    Возврат ТекстЗапроса;

КонецФункции

Функция СтруктураОтбораСтрок()
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Поставщик");
	СтруктураОтбора.Вставить("ДоговорКонтрагента");
	СтруктураОтбора.Вставить("СчетФактура");
	Возврат СтруктураОтбора;

КонецФункции

#КонецОбласти

#Область ФормированиеДвижений

// Процедура выполняет восстановление НДС по выданным авансам, вызывается Из документа ФормированиеЗаписейКнигиПродаж
//
Процедура СформироватьДвиженияВосстановлениеНДСПоВыданнымАвансам(ТаблицаРеквизиты, ТаблицаАвансов, Движения, Отказ) Экспорт

    Реквизиты = ТаблицаРеквизиты[0];

	ПлательщикНДСНаУСНСВычетами = УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(Реквизиты.Организация, Реквизиты.Период);
	ПлательщикНДС               = УчетнаяПолитика.ПлательщикНДС(Реквизиты.Организация, Реквизиты.Период)
		Или ПлательщикНДСНаУСНСВычетами;

	Если Не ПлательщикНДС Тогда
		Возврат;
	КонецЕсли;

	ТаблицаАвансов.Свернуть(
        "Покупатель,ДоговорКонтрагента,СчетФактура,ДокументОплаты,ИсправленныйСчетФактура,СтавкаНДС,ДатаСобытия,Событие,
		|ВидЦенности,ЗаписьДополнительногоЛиста,КорректируемыйПериод,СторнирующаяЗаписьДопЛиста,ДатаОплаты,КодВидаОперации",
		"НДС,СуммаБезНДС");

	СформироватьДвиженияНДСЗаписиКнигиПродажВосстановлениеНДСВыданныйАванс(Реквизиты, ТаблицаАвансов, Движения, Отказ);
    СформироватьДвиженияНДСАвансыВыданные(Реквизиты, ТаблицаАвансов, Движения, Отказ);
 
КонецПроцедуры

Процедура СформироватьДвиженияНДСЗаписиКнигиПродажВосстановлениеНДСВыданныйАванс(Реквизиты, ТаблицаАвансов, Движения, Отказ)

	Для каждого СтрокаТаблицы Из ТаблицаАвансов Цикл

		НоваяЗапись = Движения.НДСЗаписиКнигиПродаж.Добавить();

		ЗаполнитьЗначенияСвойств(НоваяЗапись, Реквизиты);
		ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТаблицы);

		Если СтрокаТаблицы.ВидЦенности = Перечисления.ВидыЦенностей.АвансыВыданныеНалоговыйАгент Тогда
			НоваяЗапись.КодВидаОперации = "43";
		Иначе
			НоваяЗапись.КодВидаОперации = СтрокаТаблицы.КодВидаОперации;
		КонецЕсли;
		
	КонецЦикла;

	Движения.НДСЗаписиКнигиПродаж.Записывать = Истина;

КонецПроцедуры

Процедура СформироватьДвиженияНДСАвансыВыданные(Реквизиты, ТаблицаАвансов, Движения, Отказ)

	Если ТаблицаАвансов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ТаблицаДвиженийНДСАвансыВыданные = Движения.НДСАвансыВыданные.ВыгрузитьКолонки();

	Для Каждого СтрокаТаблицы Из ТаблицаАвансов Цикл

		Если ТипЗнч(СтрокаТаблицы.СчетФактура) = Тип("ДокументСсылка.СчетФактураПолученный") Тогда
			Продолжить;
		КонецЕсли;

		НоваяЗапись = ТаблицаДвиженийНДСАвансыВыданные.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Реквизиты);
		ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТаблицы);

		ДоговорКонтрагента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТаблицы.СчетФактура,
			"ДокументОснование.Договор");

		НоваяЗапись.ВидДвижения = ВидДвиженияНакопления.Приход;
		НоваяЗапись.Контрагент = СтрокаТаблицы.Покупатель;
		НоваяЗапись.ДокументОплаты = СтрокаТаблицы.СчетФактура;
		НоваяЗапись.ДоговорКонтрагента = ДоговорКонтрагента;
		НоваяЗапись.НДСУпр = СтрокаТаблицы.НДС;
//		ДокументЗачетаАванса = 
		
		Если СтрокаТаблицы.ВидЦенности = Перечисления.ВидыЦенностей.Возврат Тогда
			НоваяЗапись.Событие = Перечисления.СобытияНДСАвансы.ВосстановлениеПриВозвратеАванса;
		Иначе
			НоваяЗапись.Событие = Перечисления.СобытияНДСАвансы.ВосстановлениеПриЗачетеАванса;
		КонецЕсли;
		НоваяЗапись.СтавкаНДС = Справочники.СтавкиНДС.СтавкаНДСПоПеречислениюСтавкиНДС(СтрокаТаблицы.СтавкаНДС);
		НоваяЗапись.РегламентнаяОперация = Ложь;
		НоваяЗапись.Сторно = Ложь;
		НоваяЗапись.Активность = Истина;
	КонецЦикла;

	ТаблицаДвиженийНДСАвансыВыданные.Свернуть(
		"Период,Активность,Организация,ДокументОплаты,Контрагент,ДоговорКонтрагента,СтавкаНДС,НаправлениеДеятельности,ИсправленныйСчетФактура, ВидДвижения, Событие, ДатаСобытия, ДокументЗачетаАванса",
		"СуммаБезНДС,НДС,НДСУпр");

	Движения.НДСАвансыВыданные.Загрузить(ТаблицаДвиженийНДСАвансыВыданные);

	Движения.НДСАвансыВыданные.Записывать = Истина;

КонецПроцедуры

