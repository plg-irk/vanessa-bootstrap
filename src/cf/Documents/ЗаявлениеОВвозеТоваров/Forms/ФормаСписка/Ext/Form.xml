			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ВЫБОР
		КОГДА ДокументЗаявлениеОВвозеТоваров.РучнаяКорректировка = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА ДокументЗаявлениеОВвозеТоваров.ПометкаУдаления = ИСТИНА
						ТОГДА 10
					КОГДА ДокументЗаявлениеОВвозеТоваров.Проведен = ЛОЖЬ
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ДокументЗаявлениеОВвозеТоваров.ПометкаУдаления = ИСТИНА
					ТОГДА 2
				КОГДА ДокументЗаявлениеОВвозеТоваров.Проведен = ИСТИНА
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостояниеДокумента,
	ДокументЗаявлениеОВвозеТоваров.Ссылка,
	ДокументЗаявлениеОВвозеТоваров.ПометкаУдаления,
	ДокументЗаявлениеОВвозеТоваров.Номер,
	ДокументЗаявлениеОВвозеТоваров.Дата,
	ДокументЗаявлениеОВвозеТоваров.Проведен,
	ДокументЗаявлениеОВвозеТоваров.Организация,
	ДокументЗаявлениеОВвозеТоваров.Контрагент,
	ДокументЗаявлениеОВвозеТоваров.ДоговорКонтрагента,
	"руб." КАК ВалютаДокумента,
	ДокументЗаявлениеОВвозеТоваров.Ответственный,
	ДокументЗаявлениеОВвозеТоваров.Комментарий,
	ДокументЗаявлениеОВвозеТоваров.РучнаяКорректировка,
	ДокументЗаявлениеОВвозеТоваров.СуммаДокумента,
	ДокументЗаявлениеОВвозеТоваров.МоментВремени
ИЗ
	Документ.ЗаявлениеОВвозеТоваров КАК ДокументЗаявлениеОВвозеТоваров</QueryText>
