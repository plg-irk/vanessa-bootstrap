&НаСервере
Процедура ОбновитьЦены()
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПеремещениеЗапасов.СписаниеНаРасходы") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыЦена", "Видимость", Истина);
	КонецЕсли;
	
	Если Объект[ИмяТчЗапасы()].Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПометку(ИмяТЧЗапасы(), Истина);
	
	ПараметрыДействий = Новый Структура;
	ПараметрыДействий.Вставить("Действие", ПредопределенноеЗначение(
		"Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьЦеныПоВиду"));
	ПараметрыДействий.Вставить("Реквизит", "Цена");
	ПараметрыДействий.Вставить("Значение", Объект.ВидЦенСписания);
	ОбработатьТаблицуНаСервере("Запасы", ПараметрыДействий);
	
	УстановитьПометку(ИмяТЧЗапасы(), Ложь);

КонецПроцедуры

