&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьОтПользовательскихНастроек(Форма)

	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	Если Объект.ПоложениеПроекта = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти") Тогда
		Элементы.РасходыПроект.Видимость = Истина;
		Элементы.Проект.Видимость = Ложь;
	Иначе
		Элементы.РасходыПроект.Видимость = Ложь;
		Элементы.Проект.Видимость = Истина;
	КонецЕсли;
	
	// Видимость колонок, настроенная пользователем
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыСодержание", "Видимость",
		Форма.ПоказыватьКолонкуСодержаниеВАвансовомОтчетеЗапасы);

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыСодержание", "Видимость",
		Форма.ПоказыватьКолонкуСодержаниеВАвансовомОтчетеРасходы);
		
КонецПроцедуры
	
&НаСервере
Процедура ЗаполнитьПараметрыСтрокиПоСчетФактуре(НомерСтроки, СчетФактура)
	
	ДанныеСчетаФактуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СчетФактура,
		"ДатаВходящегоДокумента, НомерВходящегоДокумента");
	
	СтрокаТаблицы = Объект.Запасы[НомерСтроки - 1];
	СтрокаТаблицы.ДатаСФ = ДанныеСчетаФактуры.ДатаВходящегоДокумента;
	СтрокаТаблицы.НомерСФ = ДанныеСчетаФактуры.НомерВходящегоДокумента;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСчетФактуруВСтрокеНаКлиенте(ИмяТаблицы = "Запасы")
	
	ТекущиеДанные = Элементы[ИмяТаблицы].ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.Поставщик)
		Или Не ЗначениеЗаполнено(ТекущиеДанные.ДатаСФ)
		Или Не ЗначениеЗаполнено(ТекущиеДанные.НомерСФ)
		Или ЗначениеЗаполнено(ТекущиеДанные.СчетФактура) Тогда
		Возврат
	КонецЕсли;
	
	ЗаполнитьСчетФактуруВСтроке(ТекущиеДанные.НомерСтроки, ИмяТаблицы);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСчетФактуруВСтроке(НомерСтроки, ИмяТаблицы)
	
	СтрокаТаблицы = Объект[ИмяТаблицы][НомерСтроки - 1];

	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Контрагент",СтрокаТаблицы.Поставщик);
	Запрос.УстановитьПараметр("ДатаСФ",СтрокаТаблицы.ДатаСФ);
	Запрос.УстановитьПараметр("НомерСФ",СтрокаТаблицы.НомерСФ);
	Запрос.УстановитьПараметр("Организация",Объект.Организация);
	
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СчетФактураПолученный.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.СчетФактураПолученный КАК СчетФактураПолученный
	|ГДЕ
	|	СчетФактураПолученный.НомерВходящегоДокумента = &НомерСФ
	|	И СчетФактураПолученный.ДатаВходящегоДокумента = &ДатаСФ
	|	И СчетФактураПолученный.Организация = &Организация
	|	И СчетФактураПолученный.Контрагент = &Контрагент
	|	И НЕ СчетФактураПолученный.ПометкаУдаления";
	
	Если Запрос.Выполнить().Пустой() Тогда
		Возврат
	КонецЕсли;
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Пока Результат.Следующий() Цикл
		СтрокаТаблицы.СчетФактура = Результат.Ссылка;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзмененияРеквизитовПечати(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		
		ПечатьДокументовУНФКлиент.ОбновитьЗначенияРеквизитовПечати(ЭтотОбъект, Результат.ИзмененныеРеквизиты);
		
		Если Результат.Свойство("Команда") Тогда
			
			Подключаемый_ВыполнитьКоманду(Результат.Команда);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура вызывает обработку заполнения документа по основанию.
//
&НаСервере
Процедура ЗаполнитьПоДокументу(ДокОснование)

	Документ = РеквизитФормыВЗначение("Объект");
	Документ.Заполнить(ДокОснование);
	ЗначениеВРеквизитФормы(Документ, "Объект");
	Модифицированность = Истина;

	СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта",
		Объект.ВалютаДокумента));
	Объект.Курс = ?(
		СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
	Объект.Кратность = ?(
		СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);

	НоменклатураВДокументахСервер.ЗаполнитьПризнакиИспользованияХарактеристик(Объект);

	Компания = Константы.УчетПоКомпании.Компания(Объект.Организация);

КонецПроцедуры

// Функция помещает табличную часть ВыданныеАвансы во временное хранилище
// и возвращает адрес.
//
&НаСервере
Функция ПоместитьВыданныеАвансыВХранилище()
	
	Возврат ПоместитьВоВременноеХранилище(
		Объект.ВыданныеАвансы.Выгрузить(,
			"Документ,
			|Сумма"),
		УникальныйИдентификатор);
	
КонецФункции // ПоместитьВыданныеАвансыВХранилище()

&НаСервереБезКонтекста
Процедура ПолучитьДанныеПоШтрихКодам(СтруктураДанные)
	
	МассивШтрихкодовБезГОСИС = Новый Массив;
	ДанныеПоШтрихКодамГОСИС = Новый Соответствие;
	
	// Преобразование весовых штрихкодов.
	Для каждого ТекШтрихкод Из СтруктураДанные.МассивШтрихкодов Цикл
		
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ТекШтрихкод, "ЭтоКодМаркировки")
			И ТекШтрихкод.ЭтоКодМаркировки Тогда
			ДополнитьДанныеПоШтрихкодамГОСИС(СтруктураДанные.ПараметрыСканированияМаркировки,
				СтруктураДанные.ДанныеФормы, ТекШтрихкод, ДанныеПоШтрихКодамГОСИС);
		Иначе
			РегистрыСведений.ШтрихкодыНоменклатуры.ПреобразоватьВесовойШтрихкод(ТекШтрихкод);
			МассивШтрихкодовБезГОСИС.Добавить(ТекШтрихкод);
		КонецЕсли;
		
	КонецЦикла;
	
	ДанныеПоШтрихКодам = РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьДанныеПоШтрихкодамВМассиве(
		МассивШтрихкодовБезГОСИС);
	Если ДанныеПоШтрихКодамГОСИС.Количество() Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьСоответствие(ДанныеПоШтрихКодам, ДанныеПоШтрихКодамГОСИС, Истина);
	КонецЕсли;
	
	Для каждого ТекШтрихкод Из СтруктураДанные.МассивШтрихкодов Цикл
		
		МассивДанныхШтрихкода = ДанныеПоШтрихкодам[ТекШтрихкод.Штрихкод];
		
		Если МассивДанныхШтрихкода <> Неопределено
			И МассивДанныхШтрихкода.Количество() <> 0 Тогда
			
			Для Каждого ДанныеШтрихкода Из МассивДанныхШтрихкода Цикл
				
				Если ДанныеШтрихкода <> Неопределено
					И ДанныеШтрихкода.Количество() <> 0 Тогда
					
					РеквизитыНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеШтрихкода.Номенклатура,
						"ТипНоменклатуры, ЕдиницаИзмерения");
					
					СтруктураДанныеНоменклатуры = Новый Структура();
					СтруктураДанныеНоменклатуры.Вставить("Организация", СтруктураДанные.Организация);
					СтруктураДанныеНоменклатуры.Вставить("Номенклатура", ДанныеШтрихкода.Номенклатура);
					СтруктураДанныеНоменклатуры.Вставить("ТипНоменклатуры", РеквизитыНоменклатуры.ТипНоменклатуры);
					СтруктураДанныеНоменклатуры.Вставить("Характеристика", ДанныеШтрихкода.Характеристика);
					СтруктураДанныеНоменклатуры.Вставить("НалогообложениеНДС", СтруктураДанные.НалогообложениеНДС);
					СтруктураДанныеНоменклатуры.Вставить("ДатаОбработки", СтруктураДанные.Дата);
					ДанныеШтрихкода.Вставить("СтруктураДанныеНоменклатуры", ПолучитьДанныеНоменклатураПриИзменении(
						СтруктураДанныеНоменклатуры));
					
					Если НЕ ЗначениеЗаполнено(ДанныеШтрихкода.ЕдиницаИзмерения) Тогда
						ДанныеШтрихкода.ЕдиницаИзмерения  = РеквизитыНоменклатуры.ЕдиницаИзмерения;
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	СтруктураДанные.Вставить("ДанныеПоШтрихКодам", ДанныеПоШтрихКодам);
	
	Для Каждого парам Из Метаданные.Документы.АвансовыйОтчет.ТабличныеЧасти.Запасы.Реквизиты.Номенклатура.ПараметрыВыбора Цикл
		Если парам.Имя = "Отбор.ТипНоменклатуры" Тогда
			Если ТипЗнч(парам.Значение) = Тип("ФиксированныйМассив") Тогда
				СтруктураДанные.Вставить("ОтборТипНоменклатуры", парам.Значение);
			Иначе
				МассивТипов = Новый Массив;
				МассивТипов.Добавить(парам.Значение);
				СтруктураДанные.Вставить("ОтборТипНоменклатуры", МассивТипов);
			КонецЕсли;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ПолучитьДанныеПоШтрихКодам()

// Процедура обрабатывает полученные штрихкоды.
//
&НаКлиенте
Функция ЗаполнитьПоДаннымШтрихкодов(ДанныеШтрихкодов)
	
	НеизвестныеШтрихкоды = Новый Массив;
	ШтрихкодыНекорректногоТипа = Новый Массив;
	
	Если ТипЗнч(ДанныеШтрихкодов) = Тип("Массив") Тогда
		МассивШтрихкодов = ДанныеШтрихкодов;
	Иначе
		МассивШтрихкодов = Новый Массив;
		МассивШтрихкодов.Добавить(ДанныеШтрихкодов);
	КонецЕсли;
	
	КодМаркировки = Ложь;
	ПодготовленныеШтрихкоды = ПодготовленныеШтрихкоды(МассивШтрихкодов, КодМаркировки);
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("МассивШтрихкодов", ПодготовленныеШтрихкоды);
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	СтруктураДанные.Вставить("Дата", Объект.Дата);
	СтруктураДанные.Вставить("ВалютаДокумента", Объект.ВалютаДокумента);
	СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	СтруктураДанные.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
	Если КодМаркировки Тогда
		ДанныеФормы = Новый Структура;
		ДанныеФормы.Вставить("ИмяФормы", ИмяФормы);
		ДанныеФормы.Вставить("Объект", Новый Структура("Ссылка", Объект.Ссылка));
		ДанныеФормы.Вставить("Модифицированность", Модифицированность);
		ПараметрыСканированияМаркировки = ШтрихкодированиеОбщегоНазначенияИСКлиент.ПараметрыСканирования(ЭтотОбъект);
		
		СтруктураДанные.Вставить("ПараметрыСканированияМаркировки", ПараметрыСканированияМаркировки);
		СтруктураДанные.Вставить("ДанныеФормы", ДанныеФормы);
	КонецЕсли;
	ПолучитьДанныеПоШтрихКодам(СтруктураДанные);
	
	Для Каждого ТекШтрихкод Из СтруктураДанные.МассивШтрихкодов Цикл
		ДанныеШтрихкода = СтруктураДанные.ДанныеПоШтрихкодам[ТекШтрихкод.Штрихкод];

		Если ДанныеШтрихкода.Количество() > 1 Тогда

			ПараметрыОткрытия = Новый Структура("МассивНоменклатуры, ТекШтрихкод", ДанныеШтрихкода, ТекШтрихкод);
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("СтруктураДанные", СтруктураДанные);
			ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗаполнитьПоДаннымШтрихкодовЗавершение", ЭтотОбъект,
				ДополнительныеПараметры);

			ОткрытьФорму("РегистрСведений.ШтрихкодыНоменклатуры.Форма.ДублиНоменклатурыПоШтрихКодам",
				ПараметрыОткрытия, ЭтотОбъект, , , , ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

			Продолжить;
		КонецЕсли;

		Если ДанныеШтрихкода <> Неопределено И ДанныеШтрихкода.Количество() = 0 Тогда
			
			НеизвестныеШтрихкоды.Добавить(ТекШтрихкод);
			
		ИначеЕсли СтруктураДанные.ОтборТипНоменклатуры.Найти(
			ДанныеШтрихкода[0].СтруктураДанныеНоменклатуры.ТипНоменклатуры) = Неопределено
			Или ДанныеШтрихкода[0].СтруктураДанныеНоменклатуры.ЭтоНабор Тогда
			
			ОписаниеШтрихкода = Новый Структура;
			ОписаниеШтрихкода.Вставить("Штрихкод", ТекШтрихкод.Штрихкод);
			ОписаниеШтрихкода.Вставить("Номенклатура", ДанныеШтрихкода[0].Номенклатура);
			ОписаниеШтрихкода.Вставить("ТипНоменклатуры",
				ДанныеШтрихкода[0].СтруктураДанныеНоменклатуры.ТипНоменклатуры);
			ОписаниеШтрихкода.Вставить("ЭтоНабор", ДанныеШтрихкода[0].СтруктураДанныеНоменклатуры.ЭтоНабор);
			
			ШтрихкодыНекорректногоТипа.Добавить(ОписаниеШтрихкода);
			
		Иначе
			
			ДанныеШтрихкода = ДанныеШтрихкода[0];
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Номенклатура", ДанныеШтрихкода.Номенклатура);
			ПараметрыОтбора.Вставить("Характеристика", ДанныеШтрихкода.Характеристика);
			ПараметрыОтбора.Вставить("Партия", ДанныеШтрихкода.Партия);
			ПараметрыОтбора.Вставить("ЕдиницаИзмерения", ДанныеШтрихкода.ЕдиницаИзмерения);
			МассивСтрокТЧ = Объект.Запасы.НайтиСтроки(ПараметрыОтбора);
			
			Если ЗапрашиватьОбъединениеСтрок И МассивСтрокТЧ.Количество() Тогда
				
				ДопПараметр = Новый Структура;
				ДопПараметр.Вставить("ЭтоПоискПоШтрихКоду", Истина);
				ДопПараметр.Вставить("ДанныеШтрихкода", ДанныеШтрихкода);
				ДопПараметр.Вставить("ТекШтрихкод", ТекШтрихкод);
				ДопПараметр.Вставить("СтруктураДанные", СтруктураДанные);
				Оповещение = Новый ОписаниеОповещения("ЗапасыПодтверждениеСбросаКоличестваЗавершение", ЭтотОбъект,
					ДопПараметр);
				ОткрытьФорму("ОбщаяФорма.ПодтверждениеОбъединенияСтрокПриДобавленииВТабличнуюЧасть", , , , , ,
					Оповещение);
				Возврат Новый Структура("НеизвестныеШтрихкоды, ШтрихкодыНекорректногоТипа", НеизвестныеШтрихкоды,
					ШтрихкодыНекорректногоТипа);
				
			КонецЕсли;
			
			Если МассивСтрокТЧ.Количество() = 0 Или НЕ ОбъединятьСтрокиПриДобавлении Тогда
				НоваяСтрока = Объект.Запасы.Добавить();
				НоваяСтрока.Номенклатура = ДанныеШтрихкода.Номенклатура;
				НоваяСтрока.СтавкаНДС = ПолучитьСтавкуНоменклатуры(НоваяСтрока.Номенклатура, Объект.Дата);
				НоваяСтрока.Характеристика = ДанныеШтрихкода.Характеристика;
				НоваяСтрока.Партия = ДанныеШтрихкода.Партия;
				НоваяСтрока.Количество = ТекШтрихкод.Количество;
				НоваяСтрока.ЕдиницаИзмерения = ?(ЗначениеЗаполнено(ДанныеШтрихкода.ЕдиницаИзмерения),
					ДанныеШтрихкода.ЕдиницаИзмерения, ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ЕдиницаИзмерения);
				РассчитатьСуммуВСтрокеТабличнойЧасти(НоваяСтрока);
				Элементы.Запасы.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
				
				НоваяСтрока.СтруктурнаяЕдиница = ДанныеШтрихкода.СтруктураДанныеНоменклатуры.СтруктурнаяЕдиница;
				НоваяСтрока.УказыватьДокументПоступления = ДанныеШтрихкода.СтруктураДанныеНоменклатуры.УказыватьДокументПоступления;
				
			Иначе
				НайденнаяСтрока = МассивСтрокТЧ[0];
				НайденнаяСтрока.Количество = НайденнаяСтрока.Количество + ТекШтрихкод.Количество;
				РассчитатьСуммуВСтрокеТабличнойЧасти(НайденнаяСтрока);
				Элементы.Запасы.ТекущаяСтрока = НайденнаяСтрока.ПолучитьИдентификатор();
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Возврат Новый Структура("НеизвестныеШтрихкоды, ШтрихкодыНекорректногоТипа", НеизвестныеШтрихкоды,
		ШтрихкодыНекорректногоТипа);
	
КонецФункции // ЗаполнитьПоДаннымШтрихкодов()

&НаКлиенте
Процедура ЗаполнитьПоДаннымШтрихкодовЗавершение(СтруктураНоменклатуры, ДополнительныеПараметры) Экспорт
	
	ОбработкаПослеУточненияОбъединенияКоличества = ДополнительныеПараметры.Свойство("ОбработкаПослеУточненияОбъединенияКоличества")
		И ДополнительныеПараметры.ОбработкаПослеУточненияОбъединенияКоличества;
	
	Если ОбработкаПослеУточненияОбъединенияКоличества Тогда
		ДанныеШтрихкода = ДополнительныеПараметры.ДанныеШтрихкода;
		ТекШтрихкод = ДополнительныеПараметры.ТекШтрихкод;
		СтруктураДанные = ДополнительныеПараметры.СтруктураДанные;
	Иначе
		
		Если СтруктураНоменклатуры = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ДанныеШтрихкода = СтруктураНоменклатуры.МассивНоменклатуры[0];
		ТекШтрихкод = СтруктураНоменклатуры.ТекШтрихкод;
		СтруктураДанные = ДополнительныеПараметры.СтруктураДанные;
		
	КонецЕсли;
	
	ШтрихкодыНекорректногоТипа = Новый Массив;
	
	Если СтруктураДанные.ОтборТипНоменклатуры.Найти(ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ТипНоменклатуры) = Неопределено 
		ИЛИ ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ЭтоНабор Тогда
		ОписаниеШтрихкода = Новый Структура;
		ОписаниеШтрихкода.Вставить("Штрихкод", ТекШтрихкод.Штрихкод);
		ОписаниеШтрихкода.Вставить("Номенклатура", ДанныеШтрихкода.Номенклатура);
		ОписаниеШтрихкода.Вставить("ТипНоменклатуры", ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ТипНоменклатуры);
		ОписаниеШтрихкода.Вставить("ЭтоНабор", ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ЭтоНабор);
		ШтрихкодыНекорректногоТипа.Добавить(ОписаниеШтрихкода);
	Иначе
		
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Номенклатура", ДанныеШтрихкода.Номенклатура);
		ПараметрыОтбора.Вставить("Характеристика", ДанныеШтрихкода.Характеристика);
		ПараметрыОтбора.Вставить("Партия", ДанныеШтрихкода.Партия);
		ПараметрыОтбора.Вставить("ЕдиницаИзмерения", ДанныеШтрихкода.ЕдиницаИзмерения);
		МассивСтрокТЧ = Объект.Запасы.НайтиСтроки(ПараметрыОтбора);
		
		Если МассивСтрокТЧ.Количество() И ЗапрашиватьОбъединениеСтрок И Не ОбработкаПослеУточненияОбъединенияКоличества Тогда
			ДопПараметр = Новый Структура;
			ДопПараметр.Вставить("ЭтоПоискПоШтрихКоду", Истина);
			ДопПараметр.Вставить("ДанныеШтрихкода", ДанныеШтрихкода);
			ДопПараметр.Вставить("ТекШтрихкод", ТекШтрихкод);
			ДопПараметр.Вставить("СтруктураДанные", СтруктураДанные);

			Оповещение = Новый ОписаниеОповещения("ЗапасыПодтверждениеСбросаКоличестваЗавершение", ЭтотОбъект, ДопПараметр);
			ОткрытьФорму("ОбщаяФорма.ПодтверждениеОбъединенияСтрокПриДобавленииВТабличнуюЧасть", , , , , , Оповещение);
			Возврат;
		КонецЕсли;
		
		Если МассивСтрокТЧ.Количество() = 0 Или НЕ ОбъединятьСтрокиПриДобавлении Тогда
			НоваяСтрока = Объект.Запасы.Добавить();
			НоваяСтрока.Номенклатура = ДанныеШтрихкода.Номенклатура;
			НоваяСтрока.СтавкаНДС = ПолучитьСтавкуНоменклатуры(НоваяСтрока.Номенклатура, Объект.Дата);
			НоваяСтрока.Характеристика = ДанныеШтрихкода.Характеристика;
			НоваяСтрока.Партия = ДанныеШтрихкода.Партия;
			НоваяСтрока.Количество = ТекШтрихкод.Количество;
			НоваяСтрока.ЕдиницаИзмерения = ?(ЗначениеЗаполнено(ДанныеШтрихкода.ЕдиницаИзмерения),
				ДанныеШтрихкода.ЕдиницаИзмерения, ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ЕдиницаИзмерения);
			РассчитатьСуммуВСтрокеТабличнойЧасти(НоваяСтрока);
			Элементы.Запасы.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		Иначе
			НайденнаяСтрока = МассивСтрокТЧ[0];
			НайденнаяСтрока.Количество = НайденнаяСтрока.Количество + ТекШтрихкод.Количество;
			РассчитатьСуммуВСтрокеТабличнойЧасти(НайденнаяСтрока);
			Элементы.Запасы.ТекущаяСтрока = НайденнаяСтрока.ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
		
	ПолученыШтрихкодыНекорректногоТипа(ШтрихкодыНекорректногоТипа);
	ЗаполнитьПризнакиИспользованияХарактеристик();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолученыШтрихкоды(ДанныеШтрихкодов) Экспорт
	
	Модифицированность = Истина;
	
	НеДобавленныеШтрихкоды		= ЗаполнитьПоДаннымШтрихкодов(ДанныеШтрихкодов);
	НеизвестныеШтрихкоды		= НеДобавленныеШтрихкоды.НеизвестныеШтрихкоды;
	ШтрихкодыНекорректногоТипа	= НеДобавленныеШтрихкоды.ШтрихкодыНекорректногоТипа;
	
	ПолученыШтрихкодыНекорректногоТипа(ШтрихкодыНекорректногоТипа);
	
	Если НеизвестныеШтрихкоды.Количество() > 0 Тогда
		
		Оповещение = Новый ОписаниеОповещения("ПолученыШтрихкодыЗавершение", ЭтотОбъект, НеизвестныеШтрихкоды);
		
		ОткрытьФорму(
			"РегистрСведений.ШтрихкодыНоменклатуры.Форма.РегистрацияШтрихкодовНоменклатуры",
			Новый Структура("НеизвестныеШтрихкоды", НеизвестныеШтрихкоды), ЭтотОбъект,,,,Оповещение);
		
		Возврат;
		
	КонецЕсли;
	
	ПолученыШтрихкодыФрагмент(НеизвестныеШтрихкоды);
	
КонецПроцедуры // ПолученыШтрихкоды()

&НаКлиенте
Процедура СодержаниеНачалоВыбора(Элемент, ИмяТабличнойЧасти)
	
	ТекущаяСтрока = Элементы[ИмяТабличнойЧасти].ТекущиеДанные;
	
	СвойстваРеквизита = Новый Структура;
	СвойстваРеквизита.Вставить("Объект", "Объект");
	СвойстваРеквизита.Вставить("ТабЧасть", ИмяТабличнойЧасти);
	СвойстваРеквизита.Вставить("НомерСтроки", ТекущаяСтрока.НомерСтроки - 1);
	СвойстваРеквизита.Вставить("ИмяРеквизита", "Содержание");
	ЗаголовокФормыРедактирования = СтрШаблон(НСтр("ru='%1: содержание'"), Строка(ТекущаяСтрока.Номенклатура));
	
	ОбщегоНазначенияУНФКлиент.ПоказатьФормуРедактированияРеквизита(Элемент.ТекстРедактирования, ЭтотОбъект,
		СвойстваРеквизита, ЗаголовокФормыРедактирования);
	
КонецПроцедуры


#Область Штрихкодирование

&НаКлиенте
Функция ПодготовленныеШтрихкоды(Знач МассивШтрихкодов, КодМаркировки)
	
	ТипСсылки = ТипЗнч(Объект.Ссылка);
	
	ИспользуетсяИСМП = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(КэшДанныхГОСИС,
		"ИнтеграцияИСМП");
	ИспользуетсяЕГАИС = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(КэшДанныхГОСИС,
		"ИнтеграцияЕГАИС");
	
	Для Каждого ТекШтрихкод Из МассивШтрихкодов Цикл
		
		ДополнительныеДанныеПоШтрихкоду = 
			ШтрихкодированиеУНФКлиент.ДополнительныеДанныеПоШтрихкоду(ТекШтрихкод.Штрихкод, ТипСсылки);
			
		Если ДополнительныеДанныеПоШтрихкоду.ЭтоКодМаркировки
			И ДополнительныеДанныеПоШтрихкоду.ЭтоПродукцияЕГАИС
			И ИспользуетсяЕГАИС Тогда
			ОбработатьКакМаркировкуТоваров = Истина;
		ИначеЕсли ДополнительныеДанныеПоШтрихкоду.ЭтоКодМаркировки
			И НЕ ДополнительныеДанныеПоШтрихкоду.ЭтоПродукцияЕГАИС
			И ИспользуетсяИСМП Тогда
			ОбработатьКакМаркировкуТоваров = Истина;
		Иначе
			ОбработатьКакМаркировкуТоваров = Ложь;
		КонецЕсли;
		
		Если ОбработатьКакМаркировкуТоваров Тогда
			ТекШтрихкод.Вставить("ЭтоКодМаркировки", Истина);
			ТекШтрихкод.Вставить("ШтрихкодBase64", ДополнительныеДанныеПоШтрихкоду.ШтрихкодBase64);
			Если ДополнительныеДанныеПоШтрихкоду.ЕстьРазделительGS1 Тогда
				ТекШтрихкод.Штрихкод = ДополнительныеДанныеПоШтрихкоду.ПредставлениеШтрихкода;
			КонецЕсли;
			КодМаркировки = Истина;
		ИначеЕсли ДополнительныеДанныеПоШтрихкоду.ЭтоКодМаркировки
			И ЗначениеЗаполнено(ДополнительныеДанныеПоШтрихкоду.EAN) Тогда
			ТекШтрихкод.Штрихкод = ДополнительныеДанныеПоШтрихкоду.EAN;
		ИначеЕсли ДополнительныеДанныеПоШтрихкоду.ЕстьРазделительGS1 Тогда
			ТекШтрихкод.Штрихкод = ДополнительныеДанныеПоШтрихкоду.ПредставлениеШтрихкода;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат МассивШтрихкодов;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ДополнитьДанныеПоШтрихкодамГОСИС(Знач ПараметрыСканированияМаркировки, Знач ДанныеФормы,
	Знач ШтрихкодГОСИС, ДанныеПоШтрихкодамГОСИС)
	
	НайденныеДанныеПоШтрихкодам = ДанныеПоШтрихкодамГОСИС.Получить(ШтрихкодГОСИС.Штрихкод);
	Если НайденныеДанныеПоШтрихкодам <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	ДанныеПоШтрихкодуГОСИС = Новый Массив;
	
	ДанныеШтрихкодаДляОбработки = Новый Структура;
	ДанныеШтрихкодаДляОбработки.Вставить("Количество", ШтрихкодГОСИС.Количество);
	ДанныеШтрихкодаДляОбработки.Вставить("ОбработатьБезМаркировки", Истина);
	ДанныеШтрихкодаДляОбработки.Вставить("ФорматBase64", Истина);
	ДанныеШтрихкодаДляОбработки.Вставить("Штрихкод", ШтрихкодГОСИС.ШтрихкодBase64);
	
	РезультатОбработкиШтрихкода = ШтрихкодированиеОбщегоНазначенияИС.ОбработатьВводШтрихкода(
		ДанныеФормы, ДанныеШтрихкодаДляОбработки, Неопределено, ПараметрыСканированияМаркировки);
	ДанныеШтрихкода = РезультатОбработкиШтрихкода.ДанныеШтрихкода;
	
	Если ДанныеШтрихкода = Неопределено Тогда
		ДанныеПоШтрихкодамГОСИС.Вставить(ШтрихкодГОСИС.Штрихкод, ДанныеПоШтрихкодуГОСИС);
		Возврат;
	КонецЕсли;
	
	Если ДанныеШтрихкода.СписокНоменклатуры.Количество() Тогда
		Для каждого ТекНоменклатура Из ДанныеШтрихкода.СписокНоменклатуры Цикл
			Если НЕ ЗначениеЗаполнено(ТекНоменклатура.Номенклатура) Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеПоШтрихкоду = ИнтеграцияИСУНФ.ДанныеПоШтрихкодуГосИС(ТекНоменклатура);
			ДанныеПоШтрихкодуГОСИС.Добавить(ДанныеПоШтрихкоду);
		КонецЦикла;
	Иначе
		Если ЗначениеЗаполнено(ДанныеШтрихкода.Номенклатура) Тогда
			ДанныеПоШтрихкоду = ИнтеграцияИСУНФ.ДанныеПоШтрихкодуГосИС(ДанныеШтрихкода);
			ДанныеПоШтрихкодуГОСИС.Добавить(ДанныеПоШтрихкоду);
		КонецЕсли;
	КонецЕсли;
	
	ДанныеПоШтрихкодамГОСИС.Вставить(ШтрихкодГОСИС.Штрихкод, ДанныеПоШтрихкодуГОСИС);
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ПолученыШтрихкодыЗавершение(ВозвращаемыеПараметры, Параметры) Экспорт
	
	НеизвестныеШтрихкоды = Параметры;
	
	Если ВозвращаемыеПараметры <> Неопределено Тогда
		
		МассивШтрихкодов = Новый Массив;
		
		Для каждого ЭлементМассива Из ВозвращаемыеПараметры.ЗарегистрированныеШтрихкоды Цикл
			МассивШтрихкодов.Добавить(ЭлементМассива);
		КонецЦикла;
		
		Для каждого ЭлементМассива Из ВозвращаемыеПараметры.ПолученыНовыеШтрихкоды Цикл
			МассивШтрихкодов.Добавить(ЭлементМассива);
		КонецЦикла;
		
		НеДобавленныеШтрихкоды		= ЗаполнитьПоДаннымШтрихкодов(МассивШтрихкодов);
		НеизвестныеШтрихкоды		= НеДобавленныеШтрихкоды.НеизвестныеШтрихкоды;
		ШтрихкодыНекорректногоТипа	= НеДобавленныеШтрихкоды.ШтрихкодыНекорректногоТипа;
		ПолученыШтрихкодыНекорректногоТипа(ШтрихкодыНекорректногоТипа);
	КонецЕсли;
	
	ПолученыШтрихкодыФрагмент(НеизвестныеШтрихкоды);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолученыШтрихкодыФрагмент(НеизвестныеШтрихкоды) Экспорт
	
	Для каждого ТекНеизвестныйШтрихкод Из НеизвестныеШтрихкоды Цикл
		
		СтрокаСообщения = НСтр("ru = 'Данные по штрихкоду не найдены: %1%; количество: %2%'");
		СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%1%", ТекНеизвестныйШтрихкод.Штрихкод);
		СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%2%", ТекНеизвестныйШтрихкод.Количество);
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрокаСообщения);
		
	КонецЦикла;
	
	ЗаполнитьПризнакиИспользованияХарактеристик();
	
	УстановитьВидимостьКолонкиДокументаПоступления(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПризнакиИспользованияХарактеристик()
	НоменклатураВДокументахСервер.ЗаполнитьПризнакиИспользованияХарактеристик(Объект);
КонецПроцедуры

&НаКлиенте
Процедура ПолученыШтрихкодыНекорректногоТипа(ШтрихкодыНекорректногоТипа) Экспорт
	
	Для каждого ТекНекорректныйШтрихкод Из ШтрихкодыНекорректногоТипа Цикл
		
		СтрокаСообщения = НСтр("ru = 'Найденная по штрихкоду %1% номенклатура -%2%- имеет тип %3%, который не подходит для этой табличной части'");
		СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%1%", ТекНекорректныйШтрихкод.Штрихкод);
		СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%2%", ТекНекорректныйШтрихкод.Номенклатура);
		Если ТекНекорректныйШтрихкод.Свойство("ЭтоНабор") И ТекНекорректныйШтрихкод.ЭтоНабор Тогда
			// Наборы
			СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%3%", НСтр("ru = 'Набор'"));
		Иначе
			СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%3%", ТекНекорректныйШтрихкод.ТипНоменклатуры);
		КонецЕсли; 
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрокаСообщения);
		
	КонецЦикла;
	
КонецПроцедуры

// Функция получает табличную часть ВыданныеАвансы из временного хранилища.
//
&НаСервере
Процедура ПолучитВыданныеАвансыИзХранилища(АдресВыданныеАвансыВХранилище)
	
	ТаблицаВыданныеАвансы = ПолучитьИзВременногоХранилища(АдресВыданныеАвансыВХранилище);
	Объект.ВыданныеАвансы.Очистить();
	Для каждого СтрокаВыданныеАвансы Из ТаблицаВыданныеАвансы Цикл
		Строка = Объект.ВыданныеАвансы.Добавить();
		ЗаполнитьЗначенияСвойств(Строка, СтрокаВыданныеАвансы);
	КонецЦикла;
	
КонецПроцедуры // ПолучитВыданныеАвансыИзХранилища()

// Процедура пересчитывает курс и кратность валюты документа при изменении
// даты документа.
//
&НаКлиенте
Процедура ПересчитатьКурсКратностьВалютыДокумента(СтруктураДанные)

	КурсНовый = ?(СтруктураДанные.ВалютаКурсКратность.Курс = 0, 1, СтруктураДанные.ВалютаКурсКратность.Курс);
	КратностьНовый = ?(СтруктураДанные.ВалютаКурсКратность.Кратность = 0, 1,
		СтруктураДанные.ВалютаКурсКратность.Кратность);

	Если Объект.Курс <> КурсНовый Или Объект.Кратность <> КратностьНовый Тогда

		КурсВалютыСтрокой = СтрШаблон("%1 %2 = %3 %4", Объект.Кратность, СокрЛП(Объект.ВалютаДокумента), Объект.Курс,
			СокрЛП(НациональнаяВалюта));
			
		КурсНовыйВалютыСтрокой = СтрШаблон("%1 %2 = %3 %4", КратностьНовый, СокрЛП(Объект.ВалютаДокумента), КурсНовый,
			СокрЛП(НациональнаяВалюта));

		ТекстСообщения = СтрШаблон(
		НСтр("ru = 'На дату документа у валюты документа (%1) был задан курс.
			|Установить курс документа (%2) в соответствии с курсом валюты?'"), КурсВалютыСтрокой, КурсНовыйВалютыСтрокой);

		Режим = РежимДиалогаВопрос.ДаНет;

		ПоказатьВопрос(Новый ОписаниеОповещения("ПересчитатьКурсКратностьВалютыДокументаЗавершение", ЭтотОбъект,
			Новый Структура("КратностьНовый, КурсНовый", КратностьНовый, КурсНовый)), ТекстСообщения, Режим, 0);
		Возврат;

	КонецЕсли;
	
	// Сформируем надпись цены и валюты.
	ПересчитатьКурсКратностьВалютыДокументаФрагмент();
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьКурсКратностьВалютыДокументаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	КратностьНовый = ДополнительныеПараметры.КратностьНовый;
	КурсНовый = ДополнительныеПараметры.КурсНовый;
	
	
	Ответ = Результат;
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		Объект.Курс = КурсНовый;
		Объект.Кратность = КратностьНовый;
		
	КонецЕсли;
	
	
	ПересчитатьКурсКратностьВалютыДокументаФрагмент();

КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьКурсКратностьВалютыДокументаФрагмент()
	
	ПоляНадписи = Новый Структура;
	ПоляНадписи.Вставить("ВалютаДокумента", Объект.ВалютаДокумента);
	ПоляНадписи.Вставить("Курс", Объект.Курс);
	ПоляНадписи.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
	ПоляНадписи.Вставить("УчетВалютныхОпераций", УчетВалютныхОпераций);
	ПоляНадписи.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	ВалютаДокумента = СформироватьНадписьЦеныИВалюта(ПоляНадписи);

КонецПроцедуры // ПересчитатьКурсКратностьВалютыДокумента()

// Процедура выполняет пересчет в табличной части документа после изменений 
// в форме "Цены и валюта". Выполняется пересчет колонок: цена, скидка, сумма,
// сумма НДС, всего.
//
&НаКлиенте
Процедура ОбработатьИзмененияПоКнопкеРедактироватьВалюту()

	ПараметрыРедактированияВалюты = Новый Структура;

	ПараметрыРедактированияВалюты.Вставить("ДатаДокумента"				, Объект.Дата);
	ПараметрыРедактированияВалюты.Вставить("ВалютаДокумента"			, Объект.ВалютаДокумента);
	ПараметрыРедактированияВалюты.Вставить("НалогообложениеНДС"			, Объект.НалогообложениеНДС);
	ПараметрыРедактированияВалюты.Вставить("СуммаВключаетНДС"			, Объект.СуммаВключаетНДС);
	ПараметрыРедактированияВалюты.Вставить("НДСВключатьВСтоимость"		, Объект.НДСВключатьВСтоимость);
	ПараметрыРедактированияВалюты.Вставить("ПересчитатьЦеныПоВалюте"	, Ложь);
	ПараметрыРедактированияВалюты.Вставить("Курс"						, Объект.Курс);
	ПараметрыРедактированияВалюты.Вставить("Кратность"					, Объект.Кратность);  
	
    ПараметрыРедактированияВалюты.Вставить("РегистрироватьЦеныПоставщика", Объект.РегистрироватьЦеныПоставщика);
	ПараметрыРедактированияВалюты.Вставить("ВидЦенКонтрагента"			 , ВидЦенКонтрагентаДоговора);

	ОткрытьФорму("ОбщаяФорма.ФормаВалюта", ПараметрыРедактированияВалюты, , , , ,
		Новый ОписаниеОповещения("ОбработатьИзмененияПоКнопкеРедактироватьВалютуЗавершение", ЭтотОбъект,
		Новый Структура("ПараметрыРедактированияВалюты", ПараметрыРедактированияВалюты)));

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьИзмененияПоКнопкеРедактироватьВалютуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ПараметрыРедактированияВалюты = ДополнительныеПараметры.ПараметрыРедактированияВалюты;
	
	СтруктураВозврата = Результат;
	
	Если НЕ ЗначениеЗаполнено(СтруктураВозврата)
		ИЛИ НЕ СтруктураВозврата.БылиВнесеныИзменения
		ИЛИ СтруктураВозврата.КодВозвратаДиалога = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Объект, СтруктураВозврата);
	
	// Очистка табличной части выданные авансы.
	Если ПараметрыРедактированияВалюты.ВалютаДокумента <> СтруктураВозврата.ВалютаДокумента Тогда
		Объект.ВыданныеАвансы.Очистить();
	КонецЕсли;
	
	// Пересчитываем цены по валюте.
	Если СтруктураВозврата.ПересчитатьЦеныПоВалюте Тогда
		ЦенообразованиеКлиент.ПересчитатьЦеныТабличнойЧастиПоВалюте(ЭтотОбъект,
			ПараметрыРедактированияВалюты.ВалютаДокумента, "Запасы", СтруктураВозврата.КурсПересчетаЦен);
		ЦенообразованиеКлиент.ПересчитатьЦеныТабличнойЧастиПоВалюте(ЭтотОбъект,
			ПараметрыРедактированияВалюты.ВалютаДокумента, "Расходы", СтруктураВозврата.КурсПересчетаЦен);
	КонецЕсли;
	
	// Пересчитываем сумму если изменился признак Налогообложение НДС.
	Если НЕ СтруктураВозврата.НалогообложениеНДС = СтруктураВозврата.ПредНалогообложениеНДС Тогда
		ЗаполнитьСтавкуНДСПоНалогообложениеНДС();
	КонецЕсли;
	
	// Пересчитываем сумму если изменился признак "Сумма включает НДС".
	Если НЕ Объект.СуммаВключаетНДС = ПараметрыРедактированияВалюты.СуммаВключаетНДС Тогда
		ЦенообразованиеКлиент.ПересчитаемСуммуТабличнойЧастиПоФлагуСуммаВключаетНДС(ЭтотОбъект, "Запасы");
		ЦенообразованиеКлиент.ПересчитаемСуммуТабличнойЧастиПоФлагуСуммаВключаетНДС(ЭтотОбъект, "Расходы");
	КонецЕсли;
	
	Для каждого СтрокаОплата Из Объект.Оплаты Цикл
		РассчитатьСуммуПлатежа(СтрокаОплата);
	КонецЦикла;
	
	ПотраченоИтог = Объект.Запасы.Итог("Всего") + Объект.Расходы.Итог("Всего") + Объект.Оплаты.Итог("СуммаПлатежа");
	
	// Сформируем надпись цены и валюты.
	ПоляНадписи = Новый Структура;
	ПоляНадписи.Вставить("ВалютаДокумента", Объект.ВалютаДокумента);
	ПоляНадписи.Вставить("Курс", Объект.Курс);
	ПоляНадписи.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
	ПоляНадписи.Вставить("УчетВалютныхОпераций", УчетВалютныхОпераций);
	ПоляНадписи.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	ВалютаДокумента = СформироватьНадписьЦеныИВалюта(ПоляНадписи);

КонецПроцедуры // ОбработатьИзмененияПоКнопкеРедактироватьВалюту()

// Выполняем пересчет суммы платежа в переданной строке табличной части.
//
&НаКлиенте
Процедура РассчитатьСуммуПлатежа(СтрокаТабличнойЧасти)
	
	СтрокаТабличнойЧасти.Курс = ?(
		СтрокаТабличнойЧасти.Курс = 0,
		1,
		СтрокаТабличнойЧасти.Курс);
	СтрокаТабличнойЧасти.Кратность = ?(
		СтрокаТабличнойЧасти.Кратность = 0,
		1,
		СтрокаТабличнойЧасти.Кратность);
	
	СтрокаТабличнойЧасти.СуммаПлатежа = ВалютыУНФКлиентСервер.Пересчитать(СтрокаТабличнойЧасти.СуммаРасчетов,
		СтрокаТабличнойЧасти.Курс, Объект.Курс, СтрокаТабличнойЧасти.Кратность, Объект.Кратность);
	
КонецПроцедуры // РассчитатьСуммуПлатежа()

// Процедура рассчитывает сумму в строке табличной части.
//
&НаКлиенте
Процедура РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти = Неопределено)
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	КонецЕсли;
	
	ПараметрыРасчета = Новый Структура("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
	ТабличныеЧастиУНФКлиент.РассчитатьСуммыВСтрокеТЧ(СтрокаТабличнойЧасти, ПараметрыРасчета);

	ПотраченоИтог = Объект.Запасы.Итог("Всего") + Объект.Расходы.Итог("Всего") + Объект.Оплаты.Итог("СуммаПлатежа");
	
КонецПроцедуры // РассчитатьСуммуВСтрокеТабличнойЧасти()

&НаСервере
Процедура ДатаПриИзмененииНаСервере(ДанныеДляИзмененияДаты)
	
	ДокументыУНФ.ДатаПриИзменении(ДанныеДляИзмененияДаты, ЭтотОбъект, Объект);
	
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	ДокументыУНФ.ОрганизацияПриИзменении(ЭтотОбъект, Объект);
	ОпределитьВидимостьНастроекУчетаВНалогообложении();
	
КонецПроцедуры

// Процедура заполняет Ставку НДС в табличной части по системе налогообложения.
//
&НаСервере
Процедура ЗаполнитьСтавкуНДСПоНалогообложениеНДС()
	
	НоменклатураВДокументахСервер.ОбновитьСтавкуНДСТабличнойЧасти(Объект, "Запасы", Ложь);
	НоменклатураВДокументахСервер.ОбновитьСтавкуНДСТабличнойЧасти(Объект, "Расходы", Ложь);
	
	УстановитьВидимостьПоНалогообложению();
	
КонецПроцедуры // ЗаполнитьСтавкуНДСПоНалогообложениеНДС()

// Получает набор данных с сервера для процедуры НоменклатураПриИзменении.
//
&НаСервереБезКонтекста
Функция ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные)
	
	СписокРеквизитовНоменклатуры = Новый Массив;
	СписокРеквизитовНоменклатуры.Добавить("ЕдиницаИзмерения");
	СписокРеквизитовНоменклатуры.Добавить("ЭтоНабор");
	СписокРеквизитовНоменклатуры.Добавить("Склад");
	СписокРеквизитовНоменклатуры.Добавить("СчетУчетаЗатрат");
	СписокРеквизитовНоменклатуры.Добавить("ИспользоватьХарактеристики");
	СписокРеквизитовНоменклатуры.Добавить("ПроверятьЗаполнениеХарактеристики");
	СписокРеквизитовНоменклатуры.Добавить("ИспользоватьПартии");
	СписокРеквизитовНоменклатуры.Добавить("ПроверятьЗаполнениеПартий");
	СписокРеквизитовНоменклатуры.Добавить("ЗапретитьВводДробногоКоличества");
	
	ДанныеНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СтруктураДанные.Номенклатура,
		СписокРеквизитовНоменклатуры);
	
	Если ЗначениеЗаполнено(ДанныеНоменклатуры.СчетУчетаЗатрат) Тогда
		ДанныеСчетаУчетаЗатрат = ДанныеНоменклатуры.СчетУчетаЗатрат;
	Иначе
		ДанныеСчетаУчетаЗатрат = ПланыСчетов.Управленческий.ПустаяСсылка();
	КонецЕсли;
	
	ТипСчетаУчетаЗатрат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеСчетаУчетаЗатрат, "ТипСчета");
	
	СтруктураДанные.Вставить("СтруктурнаяЕдиница", ДанныеНоменклатуры.Склад);
	СтруктураДанные.Вставить("ЕдиницаИзмерения", ДанныеНоменклатуры.ЕдиницаИзмерения);
	// Наборы
	СтруктураДанные.Вставить("ЭтоНабор", ДанныеНоменклатуры.ЭтоНабор);
	
	ДанныеНДС = НоменклатураВДокументахСервер.ДанныеНДССтрокиНоменклатуры(СтруктураДанные);
	СтруктураДанные.Вставить("СтавкаНДС", ДанныеНДС.СтавкаНДС);
	
	СтруктураДанные.Вставить("ОчиститьЗаказИПодразделение", Ложь);
	СтруктураДанные.Вставить("ОчиститьНаправлениеДеятельности", Ложь);
	
	Если ТипСчетаУчетаЗатрат <> Перечисления.ТипыСчетов.Расходы
	   И ТипСчетаУчетаЗатрат <> Перечисления.ТипыСчетов.Доходы
	   И ТипСчетаУчетаЗатрат <> Перечисления.ТипыСчетов.НезавершенноеПроизводство
	   И ТипСчетаУчетаЗатрат <> Перечисления.ТипыСчетов.КосвенныеЗатраты Тогда
		СтруктураДанные.ОчиститьЗаказИПодразделение = Истина;
	КонецЕсли;
	
	Если ТипСчетаУчетаЗатрат <> Перечисления.ТипыСчетов.Расходы
	   И ТипСчетаУчетаЗатрат <> Перечисления.ТипыСчетов.СебестоимостьПродаж
	   И ТипСчетаУчетаЗатрат <> Перечисления.ТипыСчетов.Доходы Тогда
		СтруктураДанные.ОчиститьНаправлениеДеятельности = Истина;
	КонецЕсли;
	
	// Характеристики
	СтруктураДанные.Вставить("ИспользоватьХарактеристики",Ложь);
	СтруктураДанные.Вставить("ПроверятьЗаполнениеХарактеристики",Ложь);
	
	Если ЗначениеЗаполнено(СтруктураДанные.Номенклатура) И ДанныеНоменклатуры.ИспользоватьХарактеристики
		Тогда
		ЗначенияПоУмолчанию = НоменклатураВДокументахСервер.ЗначенияНоменклатурыПоУмолчанию(СтруктураДанные.Номенклатура);
		
		Если Не ЗначенияПоУмолчанию = Неопределено
			Тогда
			ХарактеристикаПоУмолчанию = ЗначенияПоУмолчанию;
		КонецЕсли;
		
		Если НЕ СтруктураДанные.Свойство("Характеристика") Тогда
			СтруктураДанные.Вставить("Характеристика",ХарактеристикаПоУмолчанию);
		Иначе
			СтруктураДанные.Характеристика = ?(ЗначениеЗаполнено(СтруктураДанные.Характеристика),
				СтруктураДанные.Характеристика, ХарактеристикаПоУмолчанию);
		КонецЕсли;
		
		СтруктураДанные.Вставить("ИспользоватьХарактеристики",Истина);
		СтруктураДанные.Вставить("ПроверятьЗаполнениеХарактеристики", ДанныеНоменклатуры.ПроверятьЗаполнениеХарактеристики);
	КонецЕсли; 
	// Конец Характеристики
	
	//Партии
	СтруктураДанные.Вставить("ИспользоватьПартии",Ложь);
	СтруктураДанные.Вставить("ПроверятьЗаполнениеПартий",Ложь);
	
	Если НЕ СтруктураДанные.Свойство("Партия") Тогда
		СтруктураДанные.Вставить("Партия", Неопределено);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураДанные.Номенклатура) И ДанныеНоменклатуры.ИспользоватьПартии
		Тогда
		
		Если Не СтруктураДанные.Свойство("ВидОперации")
			Тогда
			ВидОперации = Неопределено
		Иначе
			ВидОперации = СтруктураДанные.ВидОперации
		КонецЕсли;
		
		СтатусПартии = НоменклатураВДокументахСервер.СоответствиеВидаОперацииИлиХозОперацииСтатусуПартии(, ВидОперации);
		ЗначенияПартииПоУмолчанию = НоменклатураВДокументахСервер.ЗначенияПартийНоменклатурыПоУмолчанию(
			СтруктураДанные.Номенклатура, СтатусПартии);
		
		ПартияПоУмолчанию = Справочники.ПартииНоменклатуры.ПустаяСсылка();
		
		Если Не ЗначенияПартииПоУмолчанию = Неопределено
			Тогда
			ПартияПоУмолчанию = ЗначенияПартииПоУмолчанию;
		КонецЕсли;
		
		СтруктураДанные.Партия = ?(ЗначениеЗаполнено(СтруктураДанные.Партия), СтруктураДанные.Партия, ПартияПоУмолчанию);
		
		СтруктураДанные.ПроверятьЗаполнениеПартий = ДанныеНоменклатуры.ПроверятьЗаполнениеПартий;
		СтруктураДанные.ИспользоватьПартии = Истина;
		
	КонецЕсли;
	// Конец Партии
	
	СтруктураДанные.Вставить("ЗапретитьВводДробногоКоличества", ДанныеНоменклатуры.ЗапретитьВводДробногоКоличества);
	СтруктураДанные.Вставить("УказыватьДокументПоступления", СкладскойУчетСервер.УказыватьДокументПоступления(ДанныеНоменклатуры.Склад, Ложь));
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеНоменклатураПриИзменении()

// Получает набор данных с сервера для процедуры ЕдиницаИзмеренияПриИзменении.
//
&НаСервереБезКонтекста
Функция ПолучитьДанныеЕдиницаИзмеренияПриИзменении(Знач ТекущаяЕдиницаИзмерения = Неопределено,
	Знач ЕдиницаИзмерения = Неопределено)
	
	СтруктураДанные = Новый Структура();
	
	Если ТекущаяЕдиницаИзмерения = Неопределено Тогда
		СтруктураДанные.Вставить("ТекущийКоэффициент", 1);
	Иначе
		СтруктураДанные.Вставить("ТекущийКоэффициент", ТекущаяЕдиницаИзмерения.Коэффициент);
	КонецЕсли;
	
	Если ЕдиницаИзмерения = Неопределено Тогда
		СтруктураДанные.Вставить("Коэффициент", 1);
	Иначе	
		СтруктураДанные.Вставить("Коэффициент", ЕдиницаИзмерения.Коэффициент);
	КонецЕсли;
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеЕдиницаИзмеренияПриИзменении()

// Получает набор данных с сервера для процедуры ДоговорПриИзменении.
//
&НаСервереБезКонтекста
Функция ПолучитьДанныеОплатыДоговорПриИзменении(Дата, Договор)
	
	ВалютаРасчетовДоговора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВалютаРасчетов");
	
	СтруктураДанные = Новый Структура;
	
