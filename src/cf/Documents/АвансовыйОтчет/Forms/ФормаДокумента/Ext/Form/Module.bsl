	СтруктураПараметров.Вставить("ПоказыватьКолонкуСодержаниеВАвансовомОтчетеЗапасы",
		ПоказыватьКолонкуСодержаниеВАвансовомОтчетеЗапасы);
	СтруктураПараметров.Вставить("ПоказыватьКолонкуСодержаниеВАвансовомОтчетеРасходы", 
		ПоказыватьКолонкуСодержаниеВАвансовомОтчетеРасходы);
	
	СтруктураПараметров.Вставить("БылиВнесеныИзменения", Ложь);
	СтруктураПараметров.Вставить("ТолькоПросмотр", ТолькоПросмотр);
	
	ПоложениеСчетФактурыНаФорме = ?(Объект.СчетФактураВТабличнойЧастиДокумента, ПредопределенноеЗначение(
		"Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти"), ПредопределенноеЗначение(
		"Перечисление.ПоложениеРеквизитаНаФорме.ВШапке"));
									
	СтруктураПараметров.Вставить("ПоложениеСчетФактурыНаФорме", ПоложениеСчетФактурыНаФорме);
	
	ВидимостьПоложенияСчетафактуры = Новый Структура("ПоложениеДокументаПоступления", Не Объект.НалогообложениеНДС
		= ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НеОблагаетсяНДС"));
	СтруктураПараметров.Вставить("Видимость", ВидимостьПоложенияСчетафактуры);
	
	Если ИспользоватьПроекты Тогда
		СтруктураПараметров.Вставить("ПоложениеПроекта", Объект.ПоложениеПроекта);
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.ШапкаТабличнаяЧасть", СтруктураПараметров, , , , , 
		Новый ОписаниеОповещения("ШапкаТабличнаяЧастьЗавершение", ЭтотОбъект));
		
КонецПроцедуры

&НаКлиенте
Процедура ШапкаТабличнаяЧастьЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.БылиВнесеныИзменения Тогда
		
		ПоказыватьКолонкуСодержаниеВАвансовомОтчетеЗапасы = Результат.ПоказыватьКолонкуСодержаниеВАвансовомОтчетеЗапасы;
		ПоказыватьКолонкуСодержаниеВАвансовомОтчетеРасходы = Результат.ПоказыватьКолонкуСодержаниеВАвансовомОтчетеРасходы;
		Если Результат.Свойство("ПоложениеПроекта") Тогда
			Если Объект.ПоложениеПроекта <> Результат.ПоложениеПроекта Тогда
				Объект.ПоложениеПроекта = Результат.ПоложениеПроекта;
				ЗаполнениеОбъектовУНФКлиент.ОбработатьИзменениеПоложения(Объект, "Расходы", "Проект", "ПоложениеПроекта");
			КонецЕсли;
		КонецЕсли;
		
		Если Результат.Свойство("ПоложениеСчетФактурыНаФорме") Тогда
			
			СчетФактураВТабличнойЧасти = Результат.ПоложениеСчетФактурыНаФорме = ПредопределенноеЗначение(
				"Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти");
			
			Если НЕ Объект.СчетФактураВТабличнойЧастиДокумента = СчетФактураВТабличнойЧасти Тогда
				
				Объект.СчетФактураВТабличнойЧастиДокумента = СчетФактураВТабличнойЧасти;
				ПриИзмененииСчетФактураВТабличнойЧастиДокумента();
				УстановитьВидимостьПолейСозданияСчетФактуры();
				
				Модифицированность = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьВидимостьОтПользовательскихНастроек(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьПолейСозданияСчетФактуры()
	
	Если Объект.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС") Тогда	

		Элементы.СчетФактураНадпись.Видимость = НЕ Объект.СчетФактураВТабличнойЧастиДокумента;
		Элементы.ГруппаДанныеКонтрагента.Видимость = НЕ Объект.СчетФактураВТабличнойЧастиДокумента;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСчетФактураНомерДата",
			"Видимость", Не Объект.СчетФактураВТабличнойЧастиДокумента И Элементы.СчетФактураНадпись.Видимость
			И Не ЗначениеЗаполнено(КэшЗначений.СчетФактураСсылка));

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыПредъявленСФ", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыГруппаСчетФактура", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыПредъявленСФ", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыГруппаСчетФактура", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		
	Иначе

		Если Объект.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НаЭкспорт") Тогда
			Элементы.СчетФактураНадпись.Видимость = Истина;
		Иначе
			Элементы.СчетФактураНадпись.Видимость = Ложь;
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСчетФактураНомерДата",
			"Видимость", Не Объект.СчетФактураВТабличнойЧастиДокумента И Элементы.СчетФактураНадпись.Видимость
			И Не ЗначениеЗаполнено(КэшЗначений.СчетФактураСсылка));
		Элементы.ГруппаДанныеКонтрагента.Видимость = Истина;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыПредъявленСФ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыГруппаСчетФактура", "Видимость",
			Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыПредъявленСФ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыГруппаСчетФактура", "Видимость",
			Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПоНалогообложению()
	
	Если Объект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
		Элементы.ЗапасыСтавкаНДС.Видимость = Истина;
		Элементы.ЗапасыСуммаНДС.Видимость = Истина;
		Элементы.ЗапасыВсего.Видимость = Истина;
		Элементы.РасходыСтавкаНДС.Видимость = Истина;
		Элементы.РасходыСуммаНДС.Видимость = Истина;
		Элементы.РасходыВсего.Видимость = Истина;
		Элементы.СчетФактураНадпись.Видимость = НЕ Объект.СчетФактураВТабличнойЧастиДокумента;
		Элементы.ГруппаДанныеКонтрагента.Видимость = НЕ Объект.СчетФактураВТабличнойЧастиДокумента;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыПредъявленСФ", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыГруппаСчетФактура", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыПредъявленСФ", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыГруппаСчетФактура", "Видимость",
			Объект.СчетФактураВТабличнойЧастиДокумента);
		
	Иначе
		Элементы.ЗапасыСтавкаНДС.Видимость = Ложь;
		Элементы.ЗапасыСуммаНДС.Видимость = Ложь;
		Элементы.ЗапасыВсего.Видимость = Ложь;
		Элементы.РасходыСтавкаНДС.Видимость = Ложь;
		Элементы.РасходыСуммаНДС.Видимость = Ложь;
		Элементы.РасходыВсего.Видимость = Ложь;
		Если Объект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НаЭкспорт Тогда
			Элементы.СчетФактураНадпись.Видимость = Истина;
		Иначе
			Элементы.СчетФактураНадпись.Видимость = Ложь;
		КонецЕсли;
		
		Элементы.ГруппаДанныеКонтрагента.Видимость = Истина;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыПредъявленСФ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыГруппаСчетФактура", "Видимость",
			Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыПредъявленСФ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыГруппаСчетФактура", "Видимость",
			Ложь);
		
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСчетФактураНомерДата", "Видимость",
		Не Объект.СчетФактураВТабличнойЧастиДокумента И Элементы.СчетФактураНадпись.Видимость И Не ЗначениеЗаполнено(
		КэшЗначений.СчетФактураСсылка));
	
КонецПроцедуры

// Процедура устанавливает видимость реквизитов расчетов в зависимости от установленных контрагенту параметров.
// Параметры:
//  ПризнакиВеденияРасчетов - см. ПризнакиВеденияРасчетовПоУмолчанию
//
&НаСервере
Процедура УстановитьВидимостьРеквизитовРасчетов(ПризнакиВеденияРасчетов = Неопределено)
	
	Если ПризнакиВеденияРасчетов = Неопределено Тогда
		ПризнакиВеденияРасчетов = ПризнакиВеденияРасчетовПоУмолчанию();
	КонецЕсли;
	
	ВестиРасчетыПоДоговорам = ПризнакиВеденияРасчетов.ВестиРасчетыПоДоговорам;
	ВестиРасчетыПоДокументам = ПризнакиВеденияРасчетов.ВестиРасчетыПоДокументам;
	ВестиРасчетыПоЗаказам = ПризнакиВеденияРасчетов.ВестиРасчетыПоЗаказам;
	ВестиУчетОплатыПоСчетам = ПризнакиВеденияРасчетов.ВестиУчетОплатыПоСчетам;
	
	ЗаполнитьСлужебныеРеквизитыПоКонтрагентуВКоллекции(Объект.Оплаты);
	
	Для каждого ТекСтрока Из Объект.Оплаты Цикл
		Если ТекСтрока.ВестиРасчетыПоДоговорам Тогда
			ВестиРасчетыПоДоговорам = Истина;
		КонецЕсли;
		Если ТекСтрока.ВестиРасчетыПоДокументам Тогда
			ВестиРасчетыПоДокументам = Истина;
		КонецЕсли;
		Если ТекСтрока.ВестиРасчетыПоЗаказам Тогда
			ВестиРасчетыПоЗаказам = Истина;
		КонецЕсли;
		Если ТекСтрока.ВестиУчетОплатыПоСчетам Тогда
			ВестиУчетОплатыПоСчетам = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Элементы.ОплатыДоговор.Видимость = ВестиРасчетыПоДоговорам;
	Элементы.ОплатыДокумент.Видимость = ВестиРасчетыПоДокументам;
	Элементы.ОплатыЗаказ.Видимость = ВестиРасчетыПоЗаказам;
	Элементы.ОплатыСчетНаОплату.Видимость = ВестиУчетОплатыПоСчетам;
	
КонецПроцедуры

&НаСервере
Функция ПризнакиВеденияРасчетовПоУмолчанию()
	
	Признаки = Новый Структура;
	Признаки.Вставить("ВестиРасчетыПоДоговорам", Ложь);
	Признаки.Вставить("ВестиРасчетыПоДокументам", Ложь);
	Признаки.Вставить("ВестиРасчетыПоЗаказам", Ложь);
	Признаки.Вставить("ВестиУчетОплатыПоСчетам", Ложь);
	Возврат Признаки;
	
КонецФункции // УстановитьВидимостьРеквизитовРасчетов()

&НаСервереБезКонтекста
Функция ПолучитьСтавкуНоменклатуры(Номенклатура, ДатаДокумента)
	Если Не ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат Справочники.СтавкиНДС.ПустаяСсылка();
	КонецЕсли;

	ВидСтавкиНДС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "ВидСтавкиНДС");

	Возврат Справочники.СтавкиНДС.СтавкаНДС(ВидСтавкиНДС, ?(ЗначениеЗаполнено(ДатаДокумента),
		ДатаДокумента, ТекущаяДатаСеанса()));

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьПроектПоДоговору(Договор)
	
	Если ПолучитьФункциональнуюОпцию("УчетПоПроектам") Тогда
		Проект = Справочники.Проекты.ПолучитьПроектПоДоговору(Договор);
	Иначе
		Проект = Справочники.Проекты.ПустаяСсылка();
	КонецЕсли; 
	
	Возврат Проект;
	
КонецФункции

&НаКлиенте
Процедура ПроцедураПриИзменениеДоговора()
	
	ПриИзменениеДоговораНаСервере();
	
КонецПроцедуры 

&НаСервере
Процедура ПриИзменениеДоговораНаСервере()
	
	Если ЗначениеЗаполнено(Объект.СчетФактураДоговорКонтрагента) И НЕ ЗначениеЗаполнено(Объект.Проект) Тогда
		Объект.Проект = ПолучитьПроектПоДоговору(Объект.СчетФактураДоговорКонтрагента);
	КонецЕсли;  
	
	ЗаполнитьПризнакРегистрацииЦенПоставщика(); 
	
	ВидЦенКонтрагентаДоговора = ПолучитьВидЦенКонтрагентаПоДоговору(Объект.СчетФактураДоговорКонтрагента); 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПризнакРегистрацииЦенПоставщика() 
	
	АвтоРегистрацияЦенПоставщика = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.СчетФактураДоговорКонтрагента, 
		"АвтоматическиРегистрироватьЦены"); 
	 
	Объект.РегистрироватьЦеныПоставщика = АвтоРегистрацияЦенПоставщика;

КонецПроцедуры 

&НаСервереБезКонтекста
Функция ПолучитьВидЦенКонтрагентаПоДоговору(ДоговорСсылка)
	
	ВидЦенКонтрагента = Справочники.ВидыЦенКонтрагентов.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДоговорыКонтрагентов.ВидЦенКонтрагента КАК ВидЦенКонтрагента
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ДоговорСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();	
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			ВидЦенКонтрагента = ВыборкаДетальныеЗаписи.ВидЦенКонтрагента; 
		КонецЕсли;  
		
	Конецесли;
	
	Возврат ВидЦенКонтрагента;
	
КонецФункции

&НаКлиенте
Процедура ЗапасыПодтверждениеСбросаКоличестваЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ДополнительныеПараметры.Свойство("ЭтоПодбор") И ДополнительныеПараметры.ЭтоПодбор Тогда
		
		Если Результат = Неопределено Тогда
			Возврат
		КонецЕсли;
		
		ТекущаяСтраницыЗапасы	= (Элементы.Страницы.ТекущаяСтраница = Элементы.Товары);
		ИмяТабличнойЧасти		= ?(ТекущаяСтраницыЗапасы, "Запасы", "Расходы");
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Результат);
		МассивНомеровИдентичныхСтрок = Новый Массив;
		ПолучитьЗапасыИзХранилища(ДополнительныеПараметры.АдресЗапасовВХранилище, ИмяТабличнойЧасти, Истина, Истина,
			МассивНомеровИдентичныхСтрок);
		
		Для Каждого НомерСтроки Из МассивНомеровИдентичныхСтрок Цикл
			
			СтрокаТабличнойЧасти = Объект[ИмяТабличнойЧасти][НомерСтроки];
			РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
			
		КонецЦикла;
		
		Возврат;
		
	КонецЕсли;
	
	Если ДополнительныеПараметры.Свойство("ЭтоПоискПоШтрихКоду") И ДополнительныеПараметры.ЭтоПоискПоШтрихКоду Тогда
		
		Если Результат = Неопределено Тогда
			Возврат
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Результат);
		ДополнительныеПараметры.Вставить("ОбработкаПослеУточненияОбъединенияКоличества", Истина);
		ЗаполнитьПоДаннымШтрихкодовЗавершение(Неопределено, ДополнительныеПараметры);
		
		Возврат;
		
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		ЗапрашиватьСбросКоличества = Результат.ЗапрашиватьСбросКоличества;
		Если НЕ ЗапрашиватьСбросКоличества Тогда
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, Результат);
		КонецЕсли;
		Если Результат.СбрасыватьКоличество Тогда
			НовоеКоличество = Результат.НовоеКоличествоПриИзмененииНоменклатуры;
		Иначе
			НовоеКоличество = ДополнительныеПараметры.Количество;
		КонецЕсли;
	Иначе
		НовоеКоличество = ДополнительныеПараметры.Количество;
	КонецЕсли;
	
	ЗапасыНоменклатураПриИзмененииПродолжить(ДополнительныеПараметры.Элемент, НовоеКоличество);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапасыНоменклатураПриИзмененииПродолжить(Элемент, НовоеКоличество)

	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	
	СтруктураДанные = Новый Структура;
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
	СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	СтруктураДанные.Вставить("ДатаОбработки", Объект.Дата);
	СтруктураДанные.Вставить("Характеристика", СтрокаТабличнойЧасти.Характеристика);
	СтруктураДанные.Вставить("Партия", СтрокаТабличнойЧасти.Партия);
	
	СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	
	СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтруктураДанные.ЕдиницаИзмерения;
	СтрокаТабличнойЧасти.Количество = НовоеКоличество;	
	СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС;
	СтрокаТабличнойЧасти.Содержание = "";
	
	СтрокаТабличнойЧасти.ИспользоватьХарактеристики = СтруктураДанные.ИспользоватьХарактеристики;
	СтрокаТабличнойЧасти.ПроверятьЗаполнениеХарактеристики = СтруктураДанные.ПроверятьЗаполнениеХарактеристики;
	СтрокаТабличнойЧасти.ЗаполнениеХарактеристикиПроверено = Истина;
	
	Если СтруктураДанные.ИспользоватьХарактеристики Тогда
		Если ПодборНоменклатурыИзСписка И ТипЗнч(СтруктураВыбораНоменклатуры) = Тип("Структура") Тогда
			СтрокаТабличнойЧасти.Характеристика = СтруктураВыбораНоменклатуры.Характеристика;
			СтруктураВыбораНоменклатуры.Характеристика = Неопределено;
		Иначе
			СтрокаТабличнойЧасти.Характеристика = СтруктураДанные.Характеристика;
		КонецЕсли;
	КонецЕсли;
	
	//Партии
	СтрокаТабличнойЧасти.ИспользоватьПартии = СтруктураДанные.ИспользоватьПартии;
	СтрокаТабличнойЧасти.ПроверятьЗаполнениеПартий = СтруктураДанные.ПроверятьЗаполнениеПартий;
	
	Если СтруктураДанные.ИспользоватьПартии Тогда
		Если ПодборНоменклатурыИзСписка И ТипЗнч(СтруктураВыбораНоменклатуры) = Тип("Структура") Тогда
			СтрокаТабличнойЧасти.Партия = СтруктураВыбораНоменклатуры.Партия;
			СтруктураВыбораНоменклатуры.Партия = Неопределено;
		Иначе
			СтрокаТабличнойЧасти.Партия = СтруктураДанные.Партия;
		КонецЕсли;
	КонецЕсли;
	// Конец Партии
	
	СтрокаТабличнойЧасти.ЗапретитьВводДробногоКоличества = СтруктураДанные.ЗапретитьВводДробногоКоличества;
	
	СтрокаТабличнойЧасти.УказыватьДокументПоступления = СтруктураДанные.УказыватьДокументПоступления;
	СтрокаТабличнойЧасти.ДокументПоступления = Неопределено;
	
	Если ПодборНоменклатурыИзСписка Тогда
		Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтруктурнаяЕдиница) Тогда
			СтрокаТабличнойЧасти.СтруктурнаяЕдиница = СтруктураДанные.СтруктурнаяЕдиница;
		КонецЕсли;
	Иначе
		СтрокаТабличнойЧасти.СтруктурнаяЕдиница = СтруктураДанные.СтруктурнаяЕдиница;
	КонецЕсли;
	
	ПодборНоменклатурыИзСписка = Ложь;
	
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);

КонецПроцедуры

&НаСервере
Процедура ЗапасыСтруктурнаяЕдиницаПриИзмененииСерверДоступенОрдерныйУчет()
	НоменклатураВДокументахСервер.ЗаполнитьПризнакиИспользованияХарактеристик(Объект);
КонецПроцедуры

&НаКлиенте
Процедура РасходыПодтверждениеСбросаКоличестваЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		ЗапрашиватьСбросКоличества = Результат.ЗапрашиватьСбросКоличества;
		Если НЕ ЗапрашиватьСбросКоличества Тогда
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, Результат);
		КонецЕсли;
		Если Результат.СбрасыватьКоличество Тогда
			НовоеКоличество = Результат.НовоеКоличествоПриИзмененииНоменклатуры;
		Иначе
			НовоеКоличество = ДополнительныеПараметры.Количество;
		КонецЕсли;
	Иначе
		НовоеКоличество = ДополнительныеПараметры.Количество;
	КонецЕсли;
	
	РасходыНоменклатураПриИзмененииПродолжить(ДополнительныеПараметры.Элемент, НовоеКоличество);
	
КонецПроцедуры

&НаКлиенте
Процедура РасходыНоменклатураПриИзмененииПродолжить(Элемент, НовоеКоличество)
	
	СтрокаТабличнойЧасти = Элементы.Расходы.ТекущиеДанные;
	
	СтруктураДанные = Новый Структура;
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
	СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	СтруктураДанные.Вставить("ДатаОбработки", Объект.Дата);
	
	СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	
	СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтруктураДанные.ЕдиницаИзмерения;
	СтрокаТабличнойЧасти.Количество = НовоеКоличество;
	СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС;
	СтрокаТабличнойЧасти.Содержание = "";
	
	Если СтруктураДанные.ОчиститьЗаказИПодразделение Тогда
		СтрокаТабличнойЧасти.СтруктурнаяЕдиница = Неопределено;
		СтрокаТабличнойЧасти.ЗаказПокупателя = Неопределено;
	ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтруктурнаяЕдиница) Тогда
		СтрокаТабличнойЧасти.СтруктурнаяЕдиница = ОсновноеПодразделение;
	КонецЕсли;
	
	Если СтруктураДанные.ОчиститьНаправлениеДеятельности Тогда
		СтрокаТабличнойЧасти.НаправлениеДеятельности = Неопределено;
	КонецЕсли;
	
	СтрокаТабличнойЧасти.ЗапретитьВводДробногоКоличества = СтруктураДанные.ЗапретитьВводДробногоКоличества;
	
	ПодборНоменклатурыИзСписка = Ложь;
	
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
	
КонецПроцедуры // РасходыНоменклатураПриИзменении()

&НаСервереБезКонтекста
Функция ПроектИзЗаказа(ЗаказПокупателя)

	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗаказПокупателя, "Проект");

КонецФункции

&НаКлиенте
Процедура НастройкаСбросаКоличестваЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	НастройкиКоличества = ПолучитьНастройкиИзмененияКоличества();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, НастройкиКоличества);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииСчетФактураВТабличнойЧастиДокумента()
	
	СчетФактураСсылка = ПолучитьПодчиненныйСчетФактуру();
	Если Не СчетФактураСсылка = Неопределено Тогда
		СтрокаСообщения = НСтр("ru = 'Для документа введена(ы) счет-фактура(ы). Изменение положения невозможно.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(СтрокаСообщения);
		Объект.СчетФактураВТабличнойЧастиДокумента = Не Объект.СчетФактураВТабличнойЧастиДокумента;
		Возврат;
	КонецЕсли;
	
	Если Не Объект.СчетФактураВТабличнойЧастиДокумента Тогда
		
		ЕстьСчетФактурыВСтроках = Ложь;
		Для Каждого СтрокаЗапасы Из Объект.Запасы Цикл
			
			Если ЗначениеЗаполнено(СтрокаЗапасы.СчетФактура) Тогда
				ЕстьСчетФактурыВСтроках = Истина;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если Не ЕстьСчетФактурыВСтроках Тогда
			
			Для Каждого СтрокаРасходы Из Объект.Расходы Цикл
				
				Если ЗначениеЗаполнено(СтрокаРасходы.СчетФактура) Тогда
					ЕстьСчетФактурыВСтроках = Истина;
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Если ЕстьСчетФактурыВСтроках Тогда
			СтрокаСообщения = НСтр("ru = 'В строках табличных частей введены счет фактуры. Изменение положения невозможно.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(СтрокаСообщения);
			Объект.СчетФактураВТабличнойЧастиДокумента = Истина;
			Возврат;
		КонецЕсли;
		
		Для Каждого СтрокаЗапасы Из Объект.Запасы Цикл
			СтрокаЗапасы.ДатаСФ = Неопределено;
			СтрокаЗапасы.НомерСФ = "";
			СтрокаЗапасы.Поставщик = Неопределено;
			СтрокаЗапасы.ПредъявленСФ = Ложь;
		КонецЦикла;
		
	КонецЕсли;
	
	Элементы.СчетФактураНадпись.Видимость = НЕ Объект.СчетФактураВТабличнойЧастиДокумента;
	Элементы.ГруппаДанныеКонтрагента.Видимость = НЕ Объект.СчетФактураВТабличнойЧастиДокумента;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСчетФактураНомерДата", "Видимость",
		Не Объект.СчетФактураВТабличнойЧастиДокумента И Элементы.СчетФактураНадпись.Видимость И Не ЗначениеЗаполнено(
		КэшЗначений.СчетФактураСсылка));

	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыПредъявленСФ", "Видимость",
		Объект.СчетФактураВТабличнойЧастиДокумента);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапасыГруппаСчетФактура", "Видимость",
		Объект.СчетФактураВТабличнойЧастиДокумента);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыПредъявленСФ", "Видимость",
		Объект.СчетФактураВТабличнойЧастиДокумента);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РасходыГруппаСчетФактура", "Видимость",
		Объект.СчетФактураВТабличнойЧастиДокумента);
	
КонецПроцедуры


#Область Подбор

&НаКлиенте
Процедура АвансыПодборЗавершение(Результат1, ДополнительныеПараметры) Экспорт
	
	АдресВыданныеАвансыВХранилище = ДополнительныеПараметры.АдресВыданныеАвансыВХранилище;
	
	
	Результат = Результат1;
	Если Результат = КодВозвратаДиалога.OK Тогда
		ПолучитВыданныеАвансыИзХранилища(АдресВыданныеАвансыВХранилище);
		
	КонецЕсли;

КонецПроцедуры // АвансыПодбор()

// Получает список товаров из временного хранилища и добавляет их в табличную часть документа.
//
// Параметры:
//  АдресЗапасовВХранилище - Строка - Адрес временного хранилища, содержащий таблицу товаров.
//  ИмяТабличнойЧасти - Строка - Имя табличной части документа, в которую будут добавлены товары.
//  ЕстьХарактеристики - Булево - Признак наличия характеристики в табличной части.
//  ЕстьПартии - Булево - Признак наличия партии в табличной части.
//  МассивНомеровИдентичныхСтрок - Массив из Число - Номера строк, в которые были добавлены товары.
//
&НаСервере
Процедура ПолучитьЗапасыИзХранилища(АдресЗапасовВХранилище, ИмяТабличнойЧасти, ЕстьХарактеристики, ЕстьПартии,
	МассивНомеровИдентичныхСтрок = Неопределено)
	
	ТаблицаДляЗагрузки = ПолучитьИзВременногоХранилища(АдресЗапасовВХранилище);
	
	ЕстьСтруктурнаяЕдинцаВПодборе = НЕ ТаблицаДляЗагрузки.Колонки.Найти("СтруктурнаяЕдиница") = Неопределено;
	
	ЕстьЦенаВТабличнойЧасти = ДокументыУНФ.ЕстьЦенаВТабличнойЧасти(Объект, ИмяТабличнойЧасти);
	
	СтруктурыПоискаИдентичныхСтрок = ДокументыУНФ.СтруктурыПоискаИдентичныхСтрок(Объект, ТаблицаДляЗагрузки,
		ИмяТабличнойЧасти);
	СтруктураПоискаСЦеной = СтруктурыПоискаИдентичныхСтрок.СтруктураПоискаСЦеной;
	СтруктураПоискаБезЦены = СтруктурыПоискаИдентичныхСтрок.СтруктураПоискаБезЦены;
	
	ОбъединятьСтроки = ОбъединятьСтрокиПриДобавлении И Не МассивНомеровИдентичныхСтрок = Неопределено;
	
	Для Каждого СтрокаЗагрузки Из ТаблицаДляЗагрузки Цикл
		
		Если ОбъединятьСтроки Тогда
			
			Если НЕ ЗначениеЗаполнено(СтрокаЗагрузки.Цена) 
				Или Не ЕстьЦенаВТабличнойЧасти Тогда
				СтруктураПоиска = СтруктураПоискаБезЦены;
			Иначе
				СтруктураПоиска = СтруктураПоискаСЦеной;
			КонецЕсли;
			
			ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаЗагрузки);
			НайденныеСтроки = Объект[ИмяТабличнойЧасти].НайтиСтроки(СтруктураПоиска);
			
			Если НайденныеСтроки.Количество() Тогда
				НайденныеСтроки[0].Количество = НайденныеСтроки[0].Количество + СтрокаЗагрузки.Количество;
				МассивНомеровИдентичныхСтрок.Добавить(НайденныеСтроки[0].НомерСтроки - 1);
				Продолжить;
			КонецЕсли;
			
		КонецЕсли;
		
		НоваяСтрока = Объект[ИмяТабличнойЧасти].Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаЗагрузки);
		Если НоваяСтрока.Свойство("Пометка") Тогда
			НоваяСтрока.Пометка = Истина;
		КонецЕсли;
		
		Если ИмяТабличнойЧасти = "Запасы" Тогда
			
			Если ЕстьСтруктурнаяЕдинцаВПодборе И ЗначениеЗаполнено(СтрокаЗагрузки.СтруктурнаяЕдиница) Тогда
				НоваяСтрока.СтруктурнаяЕдиница = СтрокаЗагрузки.СтруктурнаяЕдиница;
			Иначе
				НоваяСтрока.СтруктурнаяЕдиница = ОсновнойСклад;
			КонецЕсли;
			
			ЗначенияПоУмолчанию = НоменклатураВДокументахСервер.ЗначенияНоменклатурыПоУмолчанию(СтрокаЗагрузки.Номенклатура);
			
			НоваяСтрока.Характеристика = ?(ЗначениеЗаполнено(СтрокаЗагрузки.Характеристика),
				СтрокаЗагрузки.Характеристика, ЗначенияПоУмолчанию);
			
			НоваяСтрока.ПроверятьЗаполнениеХарактеристики = СтрокаЗагрузки.Номенклатура.ПроверятьЗаполнениеХарактеристики;
			НоваяСтрока.ИспользоватьХарактеристики = СтрокаЗагрузки.Номенклатура.ИспользоватьХарактеристики;
			НоваяСтрока.ЗаполнениеХарактеристикиПроверено = Истина;
			
			//Партии
			НоваяСтрока.ИспользоватьПартии = СтрокаЗагрузки.Номенклатура.ИспользоватьПартии;
			НоваяСтрока.ПроверятьЗаполнениеПартий = СтрокаЗагрузки.Номенклатура.ПроверятьЗаполнениеПартий;
			
			ЗначенияПартииПоУмолчанию = НоменклатураВДокументахСервер.ЗначенияПартийНоменклатурыПоУмолчанию(
				СтрокаЗагрузки.Номенклатура, ПредопределенноеЗначение("Перечисление.СтатусыПартий.СобственныеЗапасы"));
			
			НоваяСтрока.Партия = ?(ЗначениеЗаполнено(СтрокаЗагрузки.Партия), СтрокаЗагрузки.Партия,
				ЗначенияПартииПоУмолчанию);
			// Конец Партии
			
		КонецЕсли;
		
		Если ИмяТабличнойЧасти = "Расходы" Тогда
			
			НоваяСтрока.СтруктурнаяЕдиница = ОсновноеПодразделение;
			
		КонецЕсли;
		НоваяСтрокаНоменклатура = НоваяСтрока.Номенклатура;  // СправочникСсылка.Номенклатура
		НоваяСтрока.ЗапретитьВводДробногоКоличества = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НоваяСтрокаНоменклатура,
			"ЗапретитьВводДробногоКоличества");
		
	КонецЦикла;
	
	Если ДоступенОрдерныйУчет И ИмяТабличнойЧасти = "Запасы" Тогда
		ЗапасыСтруктурнаяЕдиницаПриИзмененииСерверДоступенОрдерныйУчет();
		УстановитьВидимостьКолонкиДокументаПоступления(ЭтотОбъект);
	КонецЕсли;
	
	ПотраченоИтог = Объект.Запасы.Итог("Всего") + Объект.Расходы.Итог("Всего") + Объект.Оплаты.Итог("СуммаПлатежа");
	
КонецПроцедуры // ПолучитьЗапасыИзХранилища()

&НаСервере
Функция НомераИдентичныхСтрокВТабличнойЧасти(АдресЗапасовВХранилище, ИмяТабличнойЧасти = "Запасы")
	
	Возврат ДокументыУнф.НомераИдентичныхСтрокВТабличнойЧасти(Объект, АдресЗапасовВХранилище, ИмяТабличнойЧасти);
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПоОснованиюЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Ответ = Результат;
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьПоДокументу(Объект.ДокументОснование);
	
	ПотраченоИтог = Объект.Запасы.Итог("Всего") + Объект.Расходы.Итог("Всего") + Объект.Оплаты.Итог("СуммаПлатежа");
	
	ПоляНадписи = Новый Структура;
	ПоляНадписи.Вставить("ВалютаДокумента", Объект.ВалютаДокумента);
	ПоляНадписи.Вставить("Курс", Объект.Курс);
	ПоляНадписи.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
	ПоляНадписи.Вставить("УчетВалютныхОпераций", УчетВалютныхОпераций);
	ПоляНадписи.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	ВалютаДокумента = СформироватьНадписьЦеныИВалюта(ПоляНадписи);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоискПоШтрихкодуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ОценкаПроизводительностиКлиент.ЗамерВремени(СтрШаблон("ПоискПоШтрихкоду%1",
		РаботаСФормойДокументаКлиентСервер.ПолучитьИмяФормыСтрокой(ИмяФормы)));
	
	ТекШтрихкод = ?(Результат = Неопределено, СокрЛП(ДополнительныеПараметры.ТекШтрихкод), СокрЛП(Результат));
	
	Если НЕ ПустаяСтрока(ТекШтрихкод) Тогда
		ПолученыШтрихкоды(Новый Структура("Штрихкод, Количество", ТекШтрихкод, 1));
	КонецЕсли;
	
КонецПроцедуры // ПоискПоШтрихкоду()

&НаКлиенте
Процедура ПолучитьВесЗавершение(Параметры) Экспорт
	
	СтрокаТабличнойЧасти = Параметры;
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНастройкиИзмененияКоличества()
	
	НастройкиКоличества = ДокументыУНФКлиентСервер.ПараметрыСбросаКоличества();
	ДокументыУНФ.ЗаполнитьНастройкиКоличества(НастройкиКоличества);
	Возврат НастройкиКоличества;
	
КонецФункции

#КонецОбласти

#Область ЗаполнениеОбъектов

&НаСервере
Функция ОтображаемыеРеквизиты()
	
	Результат = Новый Массив;
	
	Для Каждого ТекЭлемент Из Элементы Цикл
		
		Если ТипЗнч(ТекЭлемент) <> Тип("ПолеФормы") Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не СтрНачинаетсяС(ТекЭлемент.ПутьКДанным, "Объект.") Тогда
			Продолжить;
		КонецЕсли;
		
		Результат.Добавить(СтрЗаменить(ТекЭлемент.ПутьКДанным, "Объект.", ""));
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ВыборТипаОснованияЗавершение(ВыбранноеИмяФормы, Параметры) Экспорт

	Если ВыбранноеИмяФормы <> Неопределено Тогда
		ПараметрыОтбора = Новый Структура("Отбор", Новый Структура("Контрагент, Договор", Контрагент, Договор));
		ОповещениеОЗакрытии = Новый ОписаниеОповещения("ВыбратьОснованиеЗавершение", ЭтотОбъект);
		ОткрытьФорму(ВыбранноеИмяФормы.Значение, ПараметрыОтбора, ЭтотОбъект, , , , ОповещениеОЗакрытии);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОснованиеЗавершение(ВыбранноеЗначение, Параметры) Экспорт

	Если ВыбранноеЗначение <> Неопределено Тогда
		Объект.ДокументОснование = ВыбранноеЗначение;
		Элементы.ДокументОснованиеНадпись.Заголовок = РаботаСФормойДокументаКлиентСервер.СформироватьНадписьДокументОснование(
			ВыбранноеЗначение);
		Модифицированность = Истина;

		ЗаполнитьПоОснованиюНачало();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоОснованиюНачало() Экспорт

	ОписаниеОповещения = Новый ОписаниеОповещения("ЗаполнитьПоОснованиюЗавершение", ЭтотОбъект);
	ПоказатьВопрос(
		ОписаниеОповещения, НСтр("ru = 'Заполнить документ по выбранному основанию?'"), РежимДиалогаВопрос.ДаНет, 0);

КонецПроцедуры

#КонецОбласти

#Область ГрупповоеИзменениеСтрок

// Устанавливает/снимает пометку для всех строк таблицы.
//
&НаСервере
Процедура УстановитьПометку(ИмяТЧ, Пометка)
	
	НаборЭлементов = НаборЭлементовГрупповогоИзмененияСтрокСервер(ИмяТЧ);
	НаборЭлементов.КнопкаСнятьФлажки.Видимость = НЕ НаборЭлементов.КнопкаСнятьФлажки.Видимость;
	НаборЭлементов.КнопкаУстановитьФлажки.Видимость = НЕ НаборЭлементов.КнопкаУстановитьФлажки.Видимость;
	
	Для каждого Строка Из Объект[НаборЭлементов.ИмяТЧ] Цикл
		Строка.Пометка = Пометка;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
// Открывает/закрывает панель редактирования ТЧ.
//
Процедура ПоказатьСкрытьПанельРедактирования(ИмяТЧ, ИзменяетДанные = Неопределено)
	
	Перем СостояниеПерехода;
	ГрупповоеИзменениеСтрокСервер.ПоказатьСкрытьПанельРедактирования(
		ЭтотОбъект,
		НаборЭлементовГрупповогоИзмененияСтрокСервер(ИмяТЧ),
		СостояниеПерехода,
		ИзменяетДанные);
	
	УправлениеРезервнымиКопиямиТаблицы(ИмяТЧ, СостояниеПерехода, ИзменяетДанные);
	
КонецПроцедуры

&НаСервере
// Управляет сохранением/отменой изменений в ТЧ.
//
Процедура УправлениеРезервнымиКопиямиТаблицы(ИмяТЧ, СостояниеПерехода, ИзменяетДанные)
	
	Если ИмяТЧ = "Запасы" Тогда
		РеквизитРезервнаяКопияТаблицыАдрес = "ЗапасыРезервнаяКопияТаблицыАдрес";
	ИначеЕсли ИмяТЧ = "Расходы" Тогда
		РеквизитРезервнаяКопияТаблицыАдрес = "РасходыРезервнаяКопияТаблицыАдрес";
	КонецЕсли;
	
	ГрупповоеИзменениеСтрокСервер.УправлениеРезервнымиКопиями(
		ЭтотОбъект,
		Объект[ИмяТЧ],
		ЭтотОбъект[РеквизитРезервнаяКопияТаблицыАдрес],
		СостояниеПерехода,
		ИзменяетДанные);
	
КонецПроцедуры

// Управляет оформлением панели редактирования таблицы.
//
&НаКлиенте
Процедура НастроитьОформлениеПанелиРедактирования(ИмяТЧ, Состояние, СохранитьИзменения = Неопределено)
	
	Если ИмяТЧ = "Запасы" Тогда
		РеквизитЗначение = "ЗапасыИзменениеСтрокЗначение";
	ИначеЕсли ИмяТЧ = "Расходы" Тогда
		РеквизитЗначение = "РасходыИзменениеСтрокЗначение";
	КонецЕсли;
	
	ГрупповоеИзменениеСтрокКлиент.НастроитьОформлениеПанелиРедактирования(
		ЭтотОбъект,
		НаборЭлементовГрупповогоИзмененияСтрокКлиент(ИмяТЧ),
		Состояние,
		ЭтотОбъект[РеквизитЗначение]);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьТекущееДействиеИзмененияСтрок()
	
	СохраняемыеНастройки = "";
	
	Если ЗапасыИзменениеСтрокДействие <> ЗапасыИзменениеСтрокДействиеПриОткрытии Тогда
		СохраняемыеНастройки = "Запасы";
	КонецЕсли;
	
	Если РасходыИзменениеСтрокДействие <> РасходыИзменениеСтрокДействиеПриОткрытии Тогда
		Если ЗначениеЗаполнено(СохраняемыеНастройки) Тогда
			СохраняемыеНастройки = СохраняемыеНастройки + ",";
		КонецЕсли;
		СохраняемыеНастройки = СохраняемыеНастройки + "Расходы";
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(СохраняемыеНастройки) Тогда
		Возврат
	КонецЕсли;
	
	СохранитьТекущееДействиеИзмененияСтрокСервер(СохраняемыеНастройки);
	
КонецПроцедуры

// Записывает в пользовательские настройки последнее выбранное действие для изменения таблицы.
//
&НаСервере
Процедура СохранитьТекущееДействиеИзмененияСтрокСервер(СохраняемыеНастройки)
	
	ИменаТЧ = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СохраняемыеНастройки);
	Для каждого ИмяТЧ Из ИменаТЧ Цикл
		ГрупповоеИзменениеСтрокСервер.СохранитьНастройки(НаборЭлементовГрупповогоИзмененияСтрокСервер(ИмяТЧ));
	КонецЦикла;
	
КонецПроцедуры

// Производит пересчет связанных реквизитов в строках таблицы после из группового изменения.
//
&НаКлиенте
Процедура ОбработатьТаблицу(ИмяТЧ)
	
	ОбработатьТаблицуНаСервере(ИмяТЧ);
	
	Если ИмяТЧ = "Запасы" Тогда
		ВыполненноеДействие = ЗапасыИзменениеСтрокДействие;
	ИначеЕсли ИмяТЧ = "Расходы" Тогда
		ВыполненноеДействие = РасходыИзменениеСтрокДействие;
	КонецЕсли;
	
	ИзменяемыеСтроки = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("Пометка", Истина));
	Для каждого Строка Из ИзменяемыеСтроки Цикл
		
		Если ВыполненноеДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ИзменитьЦеныНаПроцент")
			ИЛИ ВыполненноеДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ОкруглитьЦены")
			ИЛИ ВыполненноеДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ДобавитьИзДокумента") Тогда
			
			РассчитатьСуммуВСтрокеТабличнойЧасти(Строка);
			
		ИначеЕсли ВыполненноеДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.УстановитьСтавкуНДС") Тогда
			
			ПараметрыРасчета = Новый Структура("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
			ТабличныеЧастиУНФКлиент.РассчитатьСуммыВСтрокеТЧ(Строка, ПараметрыРасчета);
			
		ИначеЕсли ВыполненноеДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.РаспределитьСуммуПоКоличеству")
			ИЛИ ВыполненноеДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.РаспределитьСуммуПоСуммам") Тогда
			
			Если Строка.Количество <> 0 Тогда
				Строка.Цена = Строка.Сумма / Строка.Количество;
			КонецЕсли;
			
			ПараметрыРасчета = Новый Структура("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
			ТабличныеЧастиУНФКлиент.РассчитатьСуммыВСтрокеТЧ(Строка, ПараметрыРасчета);
			ПотраченоИтог = Объект.Запасы.Итог("Всего") + Объект.Расходы.Итог("Всего") + Объект.Оплаты.Итог("СуммаПлатежа");
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Производит пересчет связанных реквизитов в строках таблицы после из группового изменения.
//
&НаСервере
Процедура ОбработатьТаблицуНаСервере(ИмяТЧ)
	
	Если ИмяТЧ = "Запасы" Тогда
		
		ГрупповоеИзменениеСтрокСервер.ОбработатьТаблицу(
			ЭтотОбъект,
			Объект.Запасы,
			ЗапасыИзменениеСтрокДействие,
			ЗапасыИзменениеСтрокОбъектИзмененийРеквизит,
			ЗапасыИзменениеСтрокЗначение,
			"ЗапасыНоменклатура");
		
		Если ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ДобавитьИзДокумента") Тогда
			
			ИзменяемыеСтроки = Объект.Запасы.НайтиСтроки(Новый Структура("Пометка", Истина));
			Для каждого Строка Из ИзменяемыеСтроки Цикл
				
				СтруктураДанные = Новый Структура;
				СтруктураДанные.Вставить("Организация", Объект.Организация);
				СтруктураДанные.Вставить("Номенклатура", Строка.Номенклатура);
				СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
				СтруктураДанные.Вставить("ДатаОбработки", Объект.Дата);
				
				СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
				
				Строка.ЕдиницаИзмерения = СтруктураДанные.ЕдиницаИзмерения;
				Если НЕ ЗначениеЗаполнено(Строка.Количество) Тогда
					Если СбрасыватьКоличество Тогда 
						Строка.Количество = НовоеКоличествоПриИзмененииНоменклатуры;
					КонецЕсли;
				КонецЕсли;
				Строка.СтавкаНДС = СтруктураДанные.СтавкаНДС;
				Строка.Содержание = "";
				
			КонецЦикла;
			
		КонецЕсли;
		
	ИначеЕсли ИмяТЧ = "Расходы" Тогда
		
		ГрупповоеИзменениеСтрокСервер.ОбработатьТаблицу(
			ЭтотОбъект,
			Объект.Расходы,
			РасходыИзменениеСтрокДействие,
			РасходыИзменениеСтрокОбъектИзмененийРеквизит,
			РасходыИзменениеСтрокЗначение,
			"РасходыНоменклатура");
		
		Если РасходыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ДобавитьИзДокумента") Тогда
			
			ИзменяемыеСтроки = Объект.Расходы.НайтиСтроки(Новый Структура("Пометка", Истина));
			Для каждого Строка Из ИзменяемыеСтроки Цикл
				
				СтруктураДанные = Новый Структура;
				СтруктураДанные.Вставить("Организация", Объект.Организация);
				СтруктураДанные.Вставить("Номенклатура", Строка.Номенклатура);
				СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
				СтруктураДанные.Вставить("ДатаОбработки", Объект.Дата);
				
				СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
				
				Строка.ЕдиницаИзмерения = СтруктураДанные.ЕдиницаИзмерения;
				Если НЕ ЗначениеЗаполнено(Строка.Количество) Тогда
					Если СбрасыватьКоличество Тогда 
						Строка.Количество = НовоеКоличествоПриИзмененииНоменклатуры;
					КонецЕсли;
				КонецЕсли;
				Строка.СтавкаНДС = СтруктураДанные.СтавкаНДС;
				Строка.Содержание = "";
				
				Если СтруктураДанные.ОчиститьЗаказИПодразделение Тогда
					Строка.СтруктурнаяЕдиница = Неопределено;
					Строка.ЗаказПокупателя = Неопределено;
				КонецЕсли;
				
				Если СтруктураДанные.ОчиститьНаправлениеДеятельности Тогда
					Строка.НаправлениеДеятельности = Неопределено;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
	НоменклатураВДокументахСервер.ЗаполнитьПризнакиИспользованияХарактеристик(Объект);
	
КонецПроцедуры

// Определяет в зависимости от выбранного действия изменяемый реквизит и связанный с ним элемент на форме.
//
&НаКлиенте
Процедура ОпределитьОбъектИзменений(ИмяТЧ)
	
	Если ИмяТЧ = "Запасы" Тогда
		
		Если ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ИзменитьЦеныНаПроцент") Тогда
			
			ЗапасыИзменениеСтрокОбъектИзмененийРеквизит = "Цена";
			ЗапасыИзменениеСтрокОбъектИзмененийЭлемент = "ЗапасыЦена";
			
		ИначеЕсли ЗапасыИзменениеСтрокДействие = ПредопределенноеЗначение("Перечисление.ДействияГрупповогоИзмененияСтрок.ОкруглитьЦены") Тогда
			
