&НаКлиенте
Процедура УстановитьВидимостьКолонкиДокументаПоступленияЗапасыПриИзменении(Элемент, ПослеУдаления = Ложь)
	
	Если Элемент = Неопределено Или (ПослеУдаления Или (Не Элемент.ТекущийЭлемент = Неопределено
		И (Элемент.ТекущийЭлемент.Имя = "ЗапасыНоменклатура" Или Элемент.ТекущийЭлемент.Имя
		= "ЗапасыСтруктурнаяЕдиница"))) Тогда
			
			ПараметрыПоиска = Новый Структура("УказыватьДокументПоступления", Истина);
			
			НайденныеСтроки = Объект.Запасы.НайтиСтроки(ПараметрыПоиска);
			Элементы.ЗапасыДокументПоступления.Видимость = НайденныеСтроки.Количество();
			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьКолонкиДокументаПоступления(Форма)
	
	Если Не Форма.ДоступенОрдерныйУчет Тогда
		Форма.Элементы.ЗапасыДокументПоступления.Видимость = Ложь;
		Возврат
	КонецЕсли;
	
	
	ПараметрыПоиска = Новый Структура("УказыватьДокументПоступления", Истина);
	
	НайденныеСтроки = Форма.Объект.Запасы.НайтиСтроки(ПараметрыПоиска);
	Форма.Элементы.ЗапасыДокументПоступления.Видимость = НайденныеСтроки.Количество();
	
КонецПроцедуры

