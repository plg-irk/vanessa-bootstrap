// Получает набор данных с сервера для процедуры КонтрагентПриИзменении.
//
&НаСервере
Функция ПолучитьДанныеКонтрагентПриИзменении(Дата, Контрагент, Организация)
	
	СтруктураДанные = Новый Структура;
	
	Договор = Справочники.ДоговорыКонтрагентов.ДоговорПоУмолчанию(Контрагент);
	ВалютаРасчетовДоговора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Договор, "ВалютаРасчетов");
	
	СтруктураДанные.Вставить("Договор", Договор);
	
	ПризнакиВеденияРасчетовКонтрагента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Контрагент,
		"ВестиРасчетыПоДоговорам, ВестиРасчетыПоДокументам, ВестиРасчетыПоЗаказам, ВестиУчетОплатыПоСчетам");

	СтруктураДанные.Вставить("ВестиРасчетыПоДоговорам", ПризнакиВеденияРасчетовКонтрагента.ВестиРасчетыПоДоговорам);
	СтруктураДанные.Вставить("ВестиРасчетыПоДокументам", ПризнакиВеденияРасчетовКонтрагента.ВестиРасчетыПоДокументам);
	СтруктураДанные.Вставить("ВестиРасчетыПоЗаказам", ПризнакиВеденияРасчетовКонтрагента.ВестиРасчетыПоЗаказам);
	СтруктураДанные.Вставить("ВестиУчетОплатыПоСчетам", ПризнакиВеденияРасчетовКонтрагента.ВестиУчетОплатыПоСчетам);
	
	СтруктураДанные.Вставить(
		"ДоговорВалютаКурсКратность",
		РегистрыСведений.КурсыВалют.ПолучитьПоследнее(
			Дата,
			Новый Структура("Валюта", ВалютаРасчетовДоговора)));
		
	ПризнакиВеденияРасчетов = ПризнакиВеденияРасчетовПоУмолчанию();
	ЗаполнитьЗначенияСвойств(ПризнакиВеденияРасчетов, ПризнакиВеденияРасчетовКонтрагента);
	
	УстановитьВидимостьРеквизитовРасчетов(ПризнакиВеденияРасчетов);
	
	Возврат СтруктураДанные;
	
КонецФункции

// Получает набор данных с сервера для процедуры ЕдиницаИзмеренияПриИзменении.
//
&НаСервереБезКонтекста
Функция ПолучитьДанныеНаправлениеДеятельностиНачалоВыбора(Номенклатура)
	
	СтруктураДанные = Новый Структура;
	
	ВозможностьУказанияНаправленияДеятельности = Истина;
	
	СчетУчетаЗатратНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "СчетУчетаЗатрат");
	Если Не ЗначениеЗаполнено(СчетУчетаЗатратНоменклатуры) Тогда
		СчетУчетаЗатратНоменклатуры = ПланыСчетов.Управленческий.ПустаяСсылка();
	КонецЕсли;
	ТипСчетаУчетаЗатратНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СчетУчетаЗатратНоменклатуры, "ТипСчета");
	
	Если ТипСчетаУчетаЗатратНоменклатуры <> Перечисления.ТипыСчетов.Расходы
	   И ТипСчетаУчетаЗатратНоменклатуры <> Перечисления.ТипыСчетов.СебестоимостьПродаж
	   И ТипСчетаУчетаЗатратНоменклатуры <> Перечисления.ТипыСчетов.Доходы Тогда
		ВозможностьУказанияНаправленияДеятельности = Ложь;
	КонецЕсли;
	
	СтруктураДанные.Вставить("ВозможностьУказанияНаправленияДеятельности", ВозможностьУказанияНаправленияДеятельности);
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеНаправлениеДеятельностиНачалоВыбора()

