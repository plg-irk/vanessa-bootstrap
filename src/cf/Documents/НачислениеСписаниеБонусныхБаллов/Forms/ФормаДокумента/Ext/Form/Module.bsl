&НаКлиенте
Процедура БонуснаяПрограммаПриИзменении(Элемент)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВопросОЗаполненииПоБонуснойПрограммеЗавершение", ЭтотОбъект);
	ТекстВопроса = НСтр("ru = 'Заполнить табличную часть картами бонусной программы?'");
	
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	ОбновитьОтсрочкуСписания();
	
КонецПроцедуры
 
&НаКлиенте
Процедура ВопросОЗаполненииПоБонуснойПрограммеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		Если Объект.НачисленияБонусов.Количество() = 0 Тогда
			ЗаполнитьПоПрограммеНаСервере();
		Иначе
			ВопросОПерезаполнении();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияКомментария(Элемент.ТекстРедактирования, ЭтотОбъект, "Объект.Комментарий");
	
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовТабличныхЧастейФормы

&НаКлиенте
Процедура БонусыДатаНачисленияПриИзменении(Элемент)
	ИдентификаторСтроки = Элементы.Бонусы.ТекущаяСтрока;
	ТекущаяСтрока = Объект.НачисленияБонусов.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если НЕ ТекущаяСтрока = Неопределено Тогда	
		ТекущаяСтрока.ДатаСгорания = ПрибавитьКДатеПериод(ТекущаяСтрока.ДатаНачисления, ОтсрочкаСписания, ПериодичностьОтсрочкиСписания);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция ПрибавитьКДатеПериод(ИсходнаяДата, КоличествоПериодов, Периодичность)
	Результат = Неопределено;
	Если НЕ СписаниеНеиспользованных Тогда
		Результат = Дата(1,1,1);			
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.День") Тогда 
		Результат = ИсходнаяДата + (3600 * 24) * КоличествоПериодов;
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Неделя") Тогда 
		Результат = ИсходнаяДата + (3600 * 24 * 7) * КоличествоПериодов;
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Декада") Тогда 
		Результат = ИсходнаяДата + (3600 * 24 * 10) * КоличествоПериодов;
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Месяц") Тогда 
		Результат = ДобавитьМесяц(ИсходнаяДата, 1 * КоличествоПериодов);
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Квартал") Тогда 
		Результат = ДобавитьМесяц(ИсходнаяДата, 3 * КоличествоПериодов);
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Полугодие") Тогда 
		Результат = ДобавитьМесяц(ИсходнаяДата, 6 * КоличествоПериодов);
	ИначеЕсли Периодичность = ПредопределенноеЗначение("Перечисление.Периодичность.Год") Тогда 
		Результат = ДобавитьМесяц(ИсходнаяДата, 12 * КоличествоПериодов);
	КонецЕсли;
	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура БонусыБонуснаяКартаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	НачалоВыбораБонуснойКарты(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура СписанияБонусовБонуснаяКартаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	НачалоВыбораБонуснойКарты(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоВыбораБонуснойКарты(Элемент)
	
	ОписаниеОповещения = Новый ОписаниеОповещения(Элемент.Родитель.Имя + "БонуснаяКартаЗавершениеВыбора", ЭтотОбъект);
	ПараметрыФормы = Новый Структура("БонуснаяПрограмма", Объект.БонуснаяПрограмма);
	ОткрытьФорму("Справочник.ДисконтныеКарты.ФормаВыбора",
		ПараметрыФормы,
		Элемент.Родитель.ТекущиеДанные.БонуснаяКарта,
		УникальныйИдентификатор,,,
		ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура БонусыБонуснаяКартаЗавершениеВыбора(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Элементы.Бонусы.ТекущиеДанные.БонуснаяКарта = Результат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СписанияБонусовБонуснаяКартаЗавершениеВыбора(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Элементы.СписанияБонусов.ТекущиеДанные.БонуснаяКарта = Результат;
	КонецЕсли;
	
КонецПроцедуры

#КонецОБласти