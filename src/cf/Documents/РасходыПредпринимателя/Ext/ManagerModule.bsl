				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СерииНоменклатурыКПоступлению.Остатки(
				|				&МоментКонтроля,
				|				(Организация, СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия, ДокументОснование, Серия) В
				|					(ВЫБРАТЬ
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение.Организация КАК Организация,
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение.Номенклатура КАК Номенклатура,
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение.Характеристика КАК Характеристика,
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение.Партия КАК Партия,
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение.ДокументОснование КАК ДокументОснование,
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение.Серия КАК Серия
				|					ИЗ
				|						ДвиженияСерииНоменклатурыКПоступлениюИзменение КАК ДвиженияСерииНоменклатурыКПоступлениюИзменение)) КАК СерииНоменклатурыКПоступлениюОстатки
				|		ПО ДвиженияСерииНоменклатурыКПоступлениюИзменение.Организация = СерииНоменклатурыКПоступлениюОстатки.Организация
				|			И ДвиженияСерииНоменклатурыКПоступлениюИзменение.СтруктурнаяЕдиница = СерииНоменклатурыКПоступлениюОстатки.СтруктурнаяЕдиница
				|			И ДвиженияСерииНоменклатурыКПоступлениюИзменение.Номенклатура = СерииНоменклатурыКПоступлениюОстатки.Номенклатура
				|			И ДвиженияСерииНоменклатурыКПоступлениюИзменение.Характеристика = СерииНоменклатурыКПоступлениюОстатки.Характеристика
				|			И ДвиженияСерииНоменклатурыКПоступлениюИзменение.Партия = СерииНоменклатурыКПоступлениюОстатки.Партия
				|			И ДвиженияСерииНоменклатурыКПоступлениюИзменение.ДокументОснование = СерииНоменклатурыКПоступлениюОстатки.ДокументОснование
				|			И ДвиженияСерииНоменклатурыКПоступлениюИзменение.Серия = СерииНоменклатурыКПоступлениюОстатки.Серия
				|ГДЕ
				|	ВЫБОР
				|			КОГДА СерииНоменклатурыКПоступлениюОстатки.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоСкладскимОрдерам)
				|				ТОГДА ЕСТЬNULL(СерииНоменклатурыКПоступлениюОстатки.КоличествоОстаток, 0) < 0
				|			КОГДА СерииНоменклатурыКПоступлениюОстатки.СтруктурнаяЕдиница.ВидУчетаОрдерныхСкладов = ЗНАЧЕНИЕ(Перечисление.ВидыУчетаОрдерныхСкладов.УчетОстатковПоПрочимДокументам)
				|				ТОГДА ЕСТЬNULL(СерииНоменклатурыКПоступлениюОстатки.КоличествоОстаток, 0) > 0
				|			ИНАЧЕ ЛОЖЬ
				|		КОНЕЦ
				|	И ДвиженияСерииНоменклатурыКПоступлениюИзменение.СтруктурнаяЕдиница В(&МассивКонтроляПоЗапасамКПоступлениюПоСкладскимОрдерам)
				|
				|УПОРЯДОЧИТЬ ПО
				|	НомерСтроки
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	РезервыТоваровОрганизацийОстатки.Организация КАК Организация,
				|	РезервыТоваровОрганизацийОстатки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
				|	РезервыТоваровОрганизацийОстатки.Номенклатура КАК Номенклатура,
				|	РезервыТоваровОрганизацийОстатки.Характеристика КАК Характеристика,
				|	РезервыТоваровОрганизацийОстатки.Партия КАК Партия,
				|	РезервыТоваровОрганизацийОстатки.КоличествоОстаток КАК КоличествоОстаток
				|ИЗ
				|	РегистрНакопления.РезервыТоваровОрганизаций.Остатки(
				|			&МоментКонтроля,
				|			&ПередачаТоваровМеждуОрганизациями
				|				И (Организация, СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия, Ячейка) В
				|					(ВЫБРАТЬ
				|						ДвиженияЗапасыНаСкладахИзменение.Организация КАК Организация,
				|						ДвиженияЗапасыНаСкладахИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
				|						ДвиженияЗапасыНаСкладахИзменение.Номенклатура КАК Номенклатура,
				|						ДвиженияЗапасыНаСкладахИзменение.Характеристика КАК Характеристика,
				|						ДвиженияЗапасыНаСкладахИзменение.Партия КАК Партия,
				|						ДвиженияЗапасыНаСкладахИзменение.Ячейка КАК Ячейка
				|					ИЗ
				|						ДвиженияЗапасыНаСкладахИзменение КАК ДвиженияЗапасыНаСкладахИзменение)) КАК РезервыТоваровОрганизацийОстатки");

		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.УстановитьПараметр("МоментКонтроля", ДополнительныеСвойства.ДляПроведения.МоментКонтроля);

		// Интеркампани
		ИнтеркампаниСервер.УстановитьПараметрыКонтроляОстатков(Запрос, ДополнительныеСвойства);
		// Конец Интеркампани
		
		Запрос.УстановитьПараметр("МассивКонтроляПоЗапасамКПоступлениюПоСкладскимОрдерам", ДополнительныеСвойства.МассивКонтроляПоЗапасамКПоступлениюПоСкладскимОрдерам);

		МассивРезультатов = Запрос.ВыполнитьПакет();

		Если Не МассивРезультатов[0].Пустой()
			 Или Не МассивРезультатов[1].Пустой()
			 Или Не МассивРезультатов[2].Пустой()
			 Или Не МассивРезультатов[3].Пустой()
			 Или Не МассивРезультатов[4].Пустой() Тогда

			ДокументОбъектРасходыПредпринимателя = ДокументСсылкаРасходыПредпринимателя.ПолучитьОбъект();

		КонецЕсли;
		
		// Отрицательный остаток запасов на складе.
		Если Не МассивРезультатов[0].Пустой() Тогда
			ВыборкаИзРезультатаЗапроса = МассивРезультатов[0].Выбрать();
			КонтрольОстатковУНФ.ЗапасыНаСкладахСписком(
				ДокументОбъектРасходыПредпринимателя, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
		// Отрицательный остаток учета запасов.
		Если Не МассивРезультатов[1].Пустой() Тогда
			ОстаткиРезервов = МассивРезультатов[5].Выгрузить();
			ВыборкаИзРезультатаЗапроса = МассивРезультатов[1].Выбрать();
			КонтрольОстатковУНФ.ЗапасыСписком(
				ДокументОбъектРасходыПредпринимателя, ВыборкаИзРезультатаЗапроса, Отказ, ОстаткиРезервов);
		КонецЕсли;
		
		// Отрицательный остаток запасов к поступлению.
		Если НЕ МассивРезультатов[2].Пустой() Тогда
			ДокументОбъектРасходыПредпринимателя = ДокументСсылкаРасходыПредпринимателя.ПолучитьОбъект();
			ВыборкаИзРезультатаЗапроса = МассивРезультатов[2].Выбрать();
			КонтрольОстатковУНФ.ЗапасыКПоступлению(ДокументОбъектРасходыПредпринимателя, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
		// Отрицательный остаток по сериям номенклатуры.
		Если НЕ МассивРезультатов[3].Пустой() Тогда
			ВыборкаИзРезультатаЗапроса = МассивРезультатов[3].Выбрать();
			КонтрольОстатковУНФ.СерииНоменклатуры(ДокументОбъектРасходыПредпринимателя, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
		// Отрицательный остаток по сериям номенклатуры к поступлению.
		Если НЕ МассивРезультатов[4].Пустой() Тогда
			ВыборкаИзРезультатаЗапроса = МассивРезультатов[4].Выбрать();
			КонтрольОстатковУНФ.СерииНоменклатурыКПоступлению(ДокументСсылкаРасходыПредпринимателя, ВыборкаИзРезультатаЗапроса, Отказ);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры // ВыполнитьКонтроль()

Функция ПолучитьНОДДляМассива(МассивЧисел, Кратность) Экспорт
	
	Если МассивЧисел.Количество() = 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	НОД = МассивЧисел[0] * Кратность;
	
	Для каждого Сч Из МассивЧисел Цикл
		НОД = ПолучитьНОД(НОД, Сч * Кратность);
	КонецЦикла;
	
	Возврат НОД;
	
КонецФункции

Функция ПолучитьНОД(ЧислоА, ЧислоБ)
	
	Возврат ?(ЧислоБ = 0, ЧислоА, ПолучитьНОД(ЧислоБ, ЧислоА % ЧислоБ));
	
КонецФункции

