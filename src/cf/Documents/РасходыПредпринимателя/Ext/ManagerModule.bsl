	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МИНИМУМ(ТаблицаЗапасыКПоступлениюНаСклады.НомерСтроки) КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Период КАК Период,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Организация КАК Организация,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Характеристика КАК Характеристика,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Партия КАК Партия,
	|	ТаблицаЗапасыКПоступлениюНаСклады.ЯчейкаКПоступлению КАК Ячейка,
	|	ТаблицаЗапасыКПоступлениюНаСклады.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СУММА(ТаблицаЗапасыКПоступлениюНаСклады.Количество) КАК Количество
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаЗапасыКПоступлениюНаСклады
	|ГДЕ
	|	(НЕ ТаблицаЗапасыКПоступлениюНаСклады.ПеремещениеВРозницуСуммовойУчет)
	|	И ТаблицаЗапасыКПоступлениюНаСклады.ОрдерныйСклад
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаЗапасыКПоступлениюНаСклады.Период,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Организация,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Номенклатура,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Характеристика,
	|	ТаблицаЗапасыКПоступлениюНаСклады.Партия,
	|	ТаблицаЗапасыКПоступлениюНаСклады.ЯчейкаКПоступлению,
	|	ТаблицаЗапасыКПоступлениюНаСклады.СтруктурнаяЕдиница";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗапасыКПоступлениюНаСклады",
		РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаЗапасыКПоступлениюНаСклады()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаСуммовойУчетВРознице(ДокументСсылкаРасходыПредпринимателя, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаРасходыПредпринимателя);
	Запрос.УстановитьПараметр("МоментВремени",
		Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ПериодКонтроля", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени.Дата);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("ПоступлениеВРозницу", НСтр("ru = 'Поступление в розницу'"));
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ru='Курсовая разница'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.Период КАК Дата,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.РозничныйВидЦен КАК РозничныйВидЦен,
	|	ТаблицаДокумента.Номенклатура КАК Номенклатура,
	|	ТаблицаДокумента.Характеристика КАК Характеристика,
	|	ТаблицаДокумента.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЕСТЬNULL(ТаблицаДокумента.ВалютаЦены, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) КАК Валюта,
	|	ТаблицаДокумента.СчетУчетаВРознице КАК СчетУчета,
	|	ТаблицаДокумента.СчетУчетаНаценки КАК СчетУчетаНаценки,
	|	СУММА(ВЫРАЗИТЬ(ЦеныНоменклатурыСрезПоследних.Цена * ТаблицаДокумента.Количество * КурсыЦенВалюты.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * КурсыЦенВалюты.Кратность) / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения.Коэффициент, 1) КАК ЧИСЛО(15, 2))) КАК Сумма,
	|	СУММА(ВЫРАЗИТЬ(ЦеныНоменклатурыСрезПоследних.Цена * ТаблицаДокумента.Количество / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения.Коэффициент, 1) КАК ЧИСЛО(15, 2))) КАК СуммаВал,
	|	СУММА(ВЫРАЗИТЬ(ЦеныНоменклатурыСрезПоследних.Цена * ТаблицаДокумента.Количество * КурсыЦенВалюты.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * КурсыЦенВалюты.Кратность) / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения.Коэффициент, 1) КАК ЧИСЛО(15, 2))) КАК СуммаДляОстатка,
	|	СУММА(ВЫРАЗИТЬ(ЦеныНоменклатурыСрезПоследних.Цена * ТаблицаДокумента.Количество / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения.Коэффициент, 1) КАК ЧИСЛО(15, 2))) КАК СуммаВалДляОстатка,
	|	СУММА(ВЫБОР
	|			КОГДА ТаблицаДокумента.ВключатьРасходыВСебестоимость
	|				ТОГДА ТаблицаДокумента.Сумма + ТаблицаДокумента.СуммаРасходов
	|			ИНАЧЕ ТаблицаДокумента.Сумма
	|		КОНЕЦ) КАК Себестоимость,
	|	&ПоступлениеВРозницу КАК СодержаниеПроводки
	|ПОМЕСТИТЬ ВременнаяТаблицаСуммовойУчетВРознице
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&МоментВремени,
	|				(ВидЦен, Номенклатура, Характеристика) В
	|					(ВЫБРАТЬ
	|						ВременнаяТаблицаЗапасы.РозничныйВидЦен,
	|						ВременнаяТаблицаЗапасы.Номенклатура,
	|						ВременнаяТаблицаЗапасы.Характеристика
	|					ИЗ
	|						ВременнаяТаблицаЗапасы)) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ТаблицаДокумента.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И ТаблицаДокумента.РозничныйВидЦен = ЦеныНоменклатурыСрезПоследних.ВидЦен
	|			И ТаблицаДокумента.Характеристика = ЦеныНоменклатурыСрезПоследних.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(
	|				&МоментВремени,
	|				Валюта В
	|					(ВЫБРАТЬ
	|						КонстантаВалютаУчета.Значение
	|					ИЗ
	|						Константа.ВалютаУчета КАК КонстантаВалютаУчета)) КАК КурсыУпрВалюты
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, ) КАК КурсыЦенВалюты
	|		ПО ТаблицаДокумента.ВалютаЦены = КурсыЦенВалюты.Валюта
	|ГДЕ
	|	ТаблицаДокумента.ПеремещениеВРозницуСуммовойУчет
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДокумента.Период,
	|	ТаблицаДокумента.НомерСтроки,
	|	ТаблицаДокумента.Организация,
	|	ТаблицаДокумента.РозничныйВидЦен,
	|	ТаблицаДокумента.Номенклатура,
	|	ТаблицаДокумента.Характеристика,
	|	ТаблицаДокумента.СтруктурнаяЕдиница,
	|	ТаблицаДокумента.ВалютаЦены,
	|	ТаблицаДокумента.СчетУчетаВРознице,
	|	ТаблицаДокумента.СчетУчетаНаценки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СтруктурнаяЕдиница,
	|	Валюта,
	|	СчетУчета";
	
	Запрос.Выполнить();
	
	// Установка исключительной блокировки контролируемых остатков денежных средств.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВременнаяТаблицаСуммовойУчетВРознице.Организация КАК Организация,
	|	ВременнаяТаблицаСуммовойУчетВРознице.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ЕСТЬNULL(ВременнаяТаблицаСуммовойУчетВРознице.Валюта, ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка)) КАК Валюта
	|ИЗ
	|	ВременнаяТаблицаСуммовойУчетВРознице КАК ВременнаяТаблицаСуммовойУчетВРознице";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	НачатьТранзакцию();
	Попытка		
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.СуммовойУчетВРознице");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
		
		Для каждого КолонкаРезультатЗапроса Из РезультатЗапроса.Колонки Цикл
			ЭлементБлокировки.ИспользоватьИзИсточникаДанных(КолонкаРезультатЗапроса.Имя, КолонкаРезультатЗапроса.Имя);
		КонецЦикла;
		Блокировка.Заблокировать();
		
		НомерЗапроса = 0;
		Запрос.Текст = КурсовыеРазницыУНФ.ПолучитьТекстЗапросаКурсовыеРазницыСуммовойУчетВРознице(
			Запрос.МенеджерВременныхТаблиц, НомерЗапроса);
		МассивРезультатов = Запрос.ВыполнитьПакет();
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСуммовойУчетВРознице",
		МассивРезультатов[НомерЗапроса].Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаДоходыИРасходы()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаУправленческий(ДокументСсылкаРасходыПредпринимателя, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	1 КАК Порядок,
	|	ТаблицаУправленческий.НомерСтроки КАК НомерСтроки,
	|	ТаблицаУправленческий.Период КАК Период,
	|	ТаблицаУправленческий.Организация КАК Организация,
	|	ЗНАЧЕНИЕ(Справочник.СценарииПланирования.Фактический) КАК СценарийПланирования,
	|	ТаблицаУправленческий.СчетУчета КАК СчетДт,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаВалютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ВалютаДт,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаВалютный
	|			ТОГДА ВЫБОР
	|					КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|						ТОГДА ТаблицаУправленческий.СуммаВал
	|					ИНАЧЕ ТаблицаУправленческий.СуммаВал - ТаблицаУправленческий.СуммаНДСВал
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СуммаВалДт,
	|	ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя КАК СчетКт,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ВалютаКт,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ВЫБОР
	|					КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|						ТОГДА ТаблицаУправленческий.СуммаВал
	|					ИНАЧЕ ТаблицаУправленческий.СуммаВал - ТаблицаУправленческий.СуммаНДСВал
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СуммаВалКт,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|			ТОГДА ТаблицаУправленческий.Сумма
	|		ИНАЧЕ ТаблицаУправленческий.Сумма - ТаблицаУправленческий.СуммаНДС
	|	КОНЕЦ КАК Сумма,
	|	ЛОЖЬ КАК ЭтоВозвратВзаиморасчеты,
	|	ЛОЖЬ КАК ТолькоДляАвтоЗачета,
	|	NULL КАК ТипРасчетов,
	|	&ОприходованиеЗапасов КАК Содержание
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаУправленческий
	|ГДЕ
	|	НЕ ТаблицаУправленческий.ВключатьРасходыВСебестоимость
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ТаблицаУправленческий.НомерСтроки,
	|	ТаблицаУправленческий.Период,
	|	ТаблицаУправленческий.Организация,
	|	ЗНАЧЕНИЕ(Справочник.СценарииПланирования.Фактический),
	|	ТаблицаУправленческий.СчетУчетаНДСПоПриобретеннымЦенностям,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаНДСПоПриобретеннымЦенностямВалютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаНДСПоПриобретеннымЦенностямВалютный
	|			ТОГДА ТаблицаУправленческий.СуммаНДСВал
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ТаблицаУправленческий.СуммаНДСВал
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ТаблицаУправленческий.СуммаНДС,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	NULL,
	|	&ОтражениеНДС
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаУправленческий
	|ГДЕ
	|	НЕ ТаблицаУправленческий.НДСВключатьВСтоимость
	|	И ТаблицаУправленческий.СуммаНДСЗакупкиПродажи <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	3,
	|	ТаблицаУправленческий.НомерСтроки,
	|	ТаблицаУправленческий.Период,
	|	ТаблицаУправленческий.Организация,
	|	ЗНАЧЕНИЕ(Справочник.СценарииПланирования.Фактический),
	|	ТаблицаУправленческий.СчетУчета,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаВалютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаВалютный
	|			ТОГДА ВЫБОР
	|					КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|						ТОГДА ТаблицаУправленческий.СуммаВал + ТаблицаУправленческий.СуммаРасходовВал
	|					ИНАЧЕ ТаблицаУправленческий.СуммаВал + ТаблицаУправленческий.СуммаРасходовБезНДСВал - ТаблицаУправленческий.СуммаНДСВал
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ВЫБОР
	|					КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|						ТОГДА ТаблицаУправленческий.СуммаВал + ТаблицаУправленческий.СуммаРасходовВал
	|					ИНАЧЕ ТаблицаУправленческий.СуммаВал + ТаблицаУправленческий.СуммаРасходовБезНДСВал - ТаблицаУправленческий.СуммаНДСВал
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|			ТОГДА ТаблицаУправленческий.Сумма + ТаблицаУправленческий.СуммаРасходов
	|		ИНАЧЕ ТаблицаУправленческий.Сумма + ТаблицаУправленческий.СуммаРасходовБезНДС - ТаблицаУправленческий.СуммаНДСЗакупкиПродажи
	|	КОНЕЦ,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	NULL,
	|	&ОприходованиеЗапасов
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаУправленческий
	|ГДЕ
	|	ТаблицаУправленческий.ВключатьРасходыВСебестоимость
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	4,
	|	ТаблицаУправленческий.НомерСтроки,
	|	ТаблицаУправленческий.Период,
	|	ТаблицаУправленческий.Организация,
	|	ЗНАЧЕНИЕ(Справочник.СценарииПланирования.Фактический),
	|	ТаблицаУправленческий.СчетУчета,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчета.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчета.Валютный
	|			ТОГДА ВЫБОР
	|					КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|						ТОГДА ТаблицаУправленческий.СуммаВал
	|					ИНАЧЕ ТаблицаУправленческий.СуммаВал - ТаблицаУправленческий.СуммаНДСВал
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ВЫБОР
	|					КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|						ТОГДА ТаблицаУправленческий.СуммаВал
	|					ИНАЧЕ ТаблицаУправленческий.СуммаВал - ТаблицаУправленческий.СуммаНДСВал
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.НДСВключатьВСтоимость
	|			ТОГДА ТаблицаУправленческий.Сумма
	|		ИНАЧЕ ТаблицаУправленческий.Сумма - ТаблицаУправленческий.СуммаНДС
	|	КОНЕЦ,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	NULL,
	|	&ПрочиеРасходы
	|ИЗ
	|	ВременнаяТаблицаРасходы КАК ТаблицаУправленческий
	|ГДЕ
	|	НЕ ТаблицаУправленческий.ВключатьРасходыВСебестоимость
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	5,
	|	ТаблицаУправленческий.НомерСтроки,
	|	ТаблицаУправленческий.Период,
	|	ТаблицаУправленческий.Организация,
	|	ЗНАЧЕНИЕ(Справочник.СценарииПланирования.Фактический),
	|	ТаблицаУправленческий.СчетУчетаНДСПоПриобретеннымЦенностям,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаНДСПоПриобретеннымЦенностямВалютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаНДСПоПриобретеннымЦенностямВалютный
	|			ТОГДА ТаблицаУправленческий.СуммаНДСВал
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаЛичныхСредствПредпринимателя.Валютный
	|			ТОГДА ТаблицаУправленческий.СуммаНДСВал
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ТаблицаУправленческий.СуммаНДС,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	NULL,
	|	&ОтражениеНДС
	|ИЗ
	|	ВременнаяТаблицаРасходы КАК ТаблицаУправленческий
	|ГДЕ
	|	НЕ ТаблицаУправленческий.НДСВключатьВСтоимость
	|	И ТаблицаУправленческий.СуммаНДСЗакупкиПродажи <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	6,
	|	ТаблицаУправленческий.НомерСтроки,
	|	ТаблицаУправленческий.Дата,
	|	ТаблицаУправленческий.Организация,
	|	ЗНАЧЕНИЕ(Справочник.СценарииПланирования.Фактический),
	|	ТаблицаУправленческий.СчетУчета,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчета.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	0,
	|	ТаблицаУправленческий.СчетУчетаНаценки,
	|	ВЫБОР
	|		КОГДА ТаблицаУправленческий.СчетУчетаНаценки.Валютный
	|			ТОГДА ТаблицаУправленческий.Валюта
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	0,
	|	ТаблицаУправленческий.Сумма - ТаблицаУправленческий.Себестоимость,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	NULL,
	|	&Наценка
	|ИЗ
	|	ВременнаяТаблицаСуммовойУчетВРознице КАК ТаблицаУправленческий
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок,
	|	НомерСтроки";
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Взаимозачет", СодержанияПроводок.Взаимозачет());
	Запрос.УстановитьПараметр("ОприходованиеЗапасов", СодержанияПроводок.ОприходованиеЗапасов());
	Запрос.УстановитьПараметр("ПрочиеРасходы", СодержанияПроводок.ОтражениеЗатрат());
	Запрос.УстановитьПараметр("Наценка", СодержанияПроводок.Наценка());
	Запрос.УстановитьПараметр("ОтражениеНДС", СодержанияПроводок.ОтражениеНДСПриобретения());
	Запрос.УстановитьПараметр("ОтражениеНДСПродажи", СодержанияПроводок.ОтражениеНДСПродажи());
	Запрос.УстановитьПараметр("СчетУчетаНДСКУплате", Справочники.ВидыНалогов.СчетУчетаНДСКУплате());
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Пока Выборка.Следующий() Цикл  
		НоваяПроводка = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаУправленческий.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяПроводка, Выборка);
	КонецЦикла;
	
КонецПроцедуры // СформироватьТаблицаУправленческий()

// Формирует таблицу значений, содержащую данные для проведения по регистрам ПартииТоваровУСН и ОписаниеОперацииКУДиР.
//  Таблицы значений сохраняет в свойствах структуры "СтруктураДополнительныеСвойства".
//
// Параметры:
//  ДокументСсылкаРасходыПредпринимателя - ДокументСсылка.РасходыПредпринимателя - документ-источник движений
//  СтруктураДополнительныеСвойства	 - Структура - свойство объекта ДополнительныеСвойства
//
Процедура СформироватьТаблицаПартииТоваровУСН(ДокументСсылкаРасходыПредпринимателя, СтруктураДополнительныеСвойства) Экспорт
	
	ОрганизацияПартий = СтруктураДополнительныеСвойства.ДляПроведения.ОрганизацияДляРегОтчетности;
	ТаблицыДвижений = УчетПартийУСН.ТаблицыДвиженийПоПартиямУСН(ОрганизацияПартий,
		СтруктураДополнительныеСвойства.ДляПроведения.Дата);
		
	ТаблицаПартииТоваров = ТаблицыДвижений.ТаблицаПартииТоваровУСН;
	ТаблицаОписаниеОперации = ТаблицыДвижений.ТаблицаОписаниеОперацииКУДиР;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПартииТоваровУСН", ТаблицаПартииТоваров);
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаОписаниеОперацииКУДиР", ТаблицаОписаниеОперации);
	
	Если НЕ ТаблицыДвижений.ПроводитьПоПартиямУСН Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаРасходыПредпринимателя);
	Запрос.УстановитьПараметр("ДатаДокумента", СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Запрос.УстановитьПараметр("Период", СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Запрос.УстановитьПараметр("Организация", ОрганизацияПартий);
	Запрос.УстановитьПараметр("МоментВремени", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени);
	Запрос.УстановитьПараметр("ВалютаУчета", СтруктураДополнительныеСвойства.ВалютаУчета);
	Запрос.УстановитьПараметр("НациональнаяВалюта", СтруктураДополнительныеСвойства.НациональнаяВалюта);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	КурсыВалютСрезПоследних.Валюта КАК Валюта,
	               |	ВЫБОР
	               |		КОГДА КурсыВалютСрезПоследних.Кратность = 0
	               |			ТОГДА КурсыВалютСрезПоследних.Курс
	               |		ИНАЧЕ КурсыВалютСрезПоследних.Курс / КурсыВалютСрезПоследних.Кратность
	               |	КОНЕЦ КАК Курс
	               |ПОМЕСТИТЬ КурсыВалют
	               |ИЗ
	               |	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&НациональнаяВалюта, &ВалютаУчета)) КАК КурсыВалютСрезПоследних
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	РасходыПредпринимателя.Ссылка КАК Ссылка,
	               |	РасходыПредпринимателя.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	РасходыПредпринимателя.ВалютаДокумента КАК ВалютаДокумента,
	               |	ВЫБОР
	               |		КОГДА РасходыПредпринимателя.Кратность = 0
	               |			ТОГДА РасходыПредпринимателя.Курс
	               |		ИНАЧЕ РасходыПредпринимателя.Курс / РасходыПредпринимателя.Кратность
	               |	КОНЕЦ КАК Курс
	               |ПОМЕСТИТЬ ШапкаДокумента
	               |ИЗ
	               |	Документ.РасходыПредпринимателя КАК РасходыПредпринимателя
	               |ГДЕ
	               |	РасходыПредпринимателя.Ссылка = &Ссылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ШапкаДокумента.Ссылка КАК Ссылка,
	               |	ШапкаДокумента.УчитыватьВНУ КАК УчитыватьВНУ,
	               |	ВЫБОР
	               |		КОГДА ШапкаДокумента.ВалютаДокумента = &НациональнаяВалюта
	               |				И ЕСТЬNULL(ВалютаУчетаКурс.Курс, 0) > 0
	               |			ТОГДА НациональнаяВалютаКурс.Курс / ВалютаУчетаКурс.Курс
	               |		КОГДА ЕСТЬNULL(НациональнаяВалютаКурс.Курс, 0) > 0
	               |			ТОГДА ШапкаДокумента.Курс / НациональнаяВалютаКурс.Курс
	               |		ИНАЧЕ 1
	               |	КОНЕЦ КАК РасчетКурса
	               |ПОМЕСТИТЬ ДанныеДокументаДляНУ
	               |ИЗ
	               |	ШапкаДокумента КАК ШапкаДокумента
	               |		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалют КАК НациональнаяВалютаКурс
	               |		ПО (НациональнаяВалютаКурс.Валюта = &НациональнаяВалюта)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалют КАК ВалютаУчетаКурс
	               |		ПО (ВалютаУчетаКурс.Валюта = &ВалютаУчета)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	&Организация КАК Организация,
	               |	РасходыПредпринимателяЗапасы.Ссылка КАК ДокументПартии,
	               |	РасходыПредпринимателяЗапасы.Ссылка КАК ДокументРегистрацииВКУДиР,
	               |	&ДатаДокумента КАК Период,
	               |	РасходыПредпринимателяЗапасы.Номенклатура КАК Номенклатура,
	               |	РасходыПредпринимателяЗапасы.Количество * ЕСТЬNULL(ЕдиницыИзмерения.Коэффициент, 1) КАК Количество,
	               |	РасходыПредпринимателяЗапасы.Всего * ДанныеДокументаДляНУ.РасчетКурса КАК Сумма,
	               |	РасходыПредпринимателяЗапасы.СуммаНДС * ДанныеДокументаДляНУ.РасчетКурса КАК СуммаНДС,
	               |	НЕ РасходыПредпринимателяЗапасы.ТоварыДляПроизводства КАК ЭтоТоварыКРеализации,
	               |	РасходыПредпринимателяЗапасы.НомерСтроки КАК НомерСтрокиДокумента,
	               |	НоменклатураЗапасы.Наименование ЕСТЬ NULL КАК СписатьПриПоступлении,
	               |	ИСТИНА КАК ЭтоЗапасы,
	               |	ДанныеДокументаДляНУ.УчитыватьВНУ КАК УчитыватьВНУ
	               |ИЗ
	               |	Документ.РасходыПредпринимателя.Запасы КАК РасходыПредпринимателяЗапасы
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураЗапасы
	               |		ПО РасходыПредпринимателяЗапасы.Номенклатура = НоменклатураЗапасы.Ссылка
	               |			И (НоменклатураЗапасы.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас))
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДокументаДляНУ КАК ДанныеДокументаДляНУ
	               |		ПО РасходыПредпринимателяЗапасы.Ссылка = ДанныеДокументаДляНУ.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	               |		ПО РасходыПредпринимателяЗапасы.ЕдиницаИзмерения = ЕдиницыИзмерения.Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	&Организация,
	               |	РасходыПредпринимателяРасходы.Ссылка,
	               |	РасходыПредпринимателяРасходы.Ссылка,
	               |	&ДатаДокумента,
	               |	РасходыПредпринимателяРасходы.Номенклатура,
	               |	РасходыПредпринимателяРасходы.Количество,
	               |	РасходыПредпринимателяРасходы.Всего * ДанныеДокументаДляНУ.РасчетКурса,
	               |	РасходыПредпринимателяРасходы.СуммаНДС * ДанныеДокументаДляНУ.РасчетКурса,
	               |	ЛОЖЬ,
	               |	РасходыПредпринимателяРасходы.НомерСтроки,
	               |	ИСТИНА,
	               |	ЛОЖЬ,
	               |	ДанныеДокументаДляНУ.УчитыватьВНУ
	               |ИЗ
	               |	Документ.РасходыПредпринимателя.Расходы КАК РасходыПредпринимателяРасходы
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеДокументаДляНУ КАК ДанныеДокументаДляНУ
	               |		ПО РасходыПредпринимателяРасходы.Ссылка = ДанныеДокументаДляНУ.Ссылка
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерСтрокиДокумента,
	               |	СписатьПриПоступлении УБЫВ";
	
	Запасы = Запрос.Выполнить().Выбрать();

	ЕстьМатериалы = Ложь; ЕстьУслуги = Ложь;
	Пока Запасы.Следующий() Цикл
		НоваяСтрока = ТаблицаПартииТоваров.Добавить();
		НоваяСтрока.СтатусРасхода = Перечисления.СтатусыРасходовУСН.НеСписано;
		НоваяСтрока.ОтражатьВКУДиР = НЕ Запасы.ЭтоТоварыКРеализации И Запасы.УчитыватьВНУ;
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Запасы);
		
		Если Запасы.СписатьПриПоступлении Тогда
			СтрокаРасход = ТаблицаПартииТоваров.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРасход, НоваяСтрока);
			СтрокаРасход.ВидДвижения = ВидДвиженияНакопления.Расход;
			СтрокаРасход.ОтражатьВКУДиР = Ложь;
			
			Если Запасы.ЭтоЗапасы Тогда
				ЕстьМатериалы = Истина;
			Иначе
				ЕстьУслуги = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если НоваяСтрока.ОтражатьВКУДиР Тогда
			ЕстьУслуги = ЕстьУслуги ИЛИ НЕ Запасы.ЭтоЗапасы;
			ЕстьМатериалы = ЕстьМатериалы ИЛИ Запасы.ЭтоЗапасы;
		КонецЕсли;
	КонецЦикла;
	
	Если ТаблицаПартииТоваров.Найти(Истина, "ОтражатьВКУДиР") <> Неопределено Тогда
		СтрокаОписание = ТаблицаОписаниеОперации.Добавить();
		СтрокаОписание.Организация = ОрганизацияПартий;
		СтрокаОписание.Период = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
		СтрокаОписание.НомерПервичногоДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(
			СтруктураДополнительныеСвойства.ДляПроведения.Номер, Истина, Истина);
		СтрокаОписание.ДатаПервичногоДокумента = СтруктураДополнительныеСвойства.ДляПроведения.Дата;
		СтрокаОписание.Содержание = УчетПартийУСНКлиентСервер.СодержаниеРасходыЛичныеСредства(
			ЕстьМатериалы, ЕстьУслуги);
	КонецЕсли;
	
КонецПроцедуры // СформироватьТаблицаПартииТоваровУСН()

