// Перенос участников события в служебный справочник и новую таблицу
// Версия 3.0.2
// Удалить при удалении обработчика
// 
// Параметры:
//  СобытиеОбъект - ДокументОбъект.Событие - событие
Процедура ПеренестиУчастниковСобытия(СобытиеОбъект) Экспорт
	
	НачатьТранзакцию();
	
	Попытка
		
		СоответствиеНовыхАдресатов = Новый Соответствие;
		СобытиеОбъект.Заблокировать();
		МассивАдресов = Новый Массив;
				
		Для Каждого Участник Из СобытиеОбъект.УдалитьУчастники Цикл
			
			Если ТипЗнч(Участник.Контакт) <> Тип("Строка") Тогда
				УправлениеДоступом.ПроверитьЧтениеРазрешено(Участник.Контакт);
			КонецЕсли;
			
			Если СобытиеОбъект.ТипСобытия <> Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
				Прервать;
			КонецЕсли;
			
			Адреса = ОбщегоНазначенияКлиентСервер.АдресаЭлектроннойПочтыИзСтроки(Участник.КакСвязаться);
			Для Каждого Адрес Из Адреса Цикл
				Если НЕ ЗначениеЗаполнено(Адрес.ОписаниеОшибки) Тогда
					МассивАдресов.Добавить(Адрес.Адрес);
				Иначе
					МассивАдресов.Добавить(Адрес.Псевдоним);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		АдресатыСобытий = Справочники.АдресатыПисем.АдресатыПисемПоКакСвязаться(МассивАдресов);
		
		Для Каждого Участник Из СобытиеОбъект.УдалитьУчастники Цикл

			Если СобытиеОбъект.ТипСобытия <> Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
				НовыйУчастник = СобытиеОбъект.Участники.Добавить();
				ЗаполнитьЗначенияСвойств(НовыйУчастник, Участник);
				Продолжить;
			КонецЕсли;
			
			ПеренестиДанныеСобытияЭлектронноеПисьмо(СобытиеОбъект, Участник, АдресатыСобытий, СоответствиеНовыхАдресатов);
			
		КонецЦикла;
		
		СобытиеОбъект.КонтактыПеренесены = Истина;
		
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(СобытиеОбъект);
		СобытиеОбъект.Разблокировать();
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), СобытиеОбъект.Ссылка);
		
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

