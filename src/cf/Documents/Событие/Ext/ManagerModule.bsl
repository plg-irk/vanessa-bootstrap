#Область ЭлектроннаяПочтаУНФ

Процедура ОбработатьОдногоУчастникаДляСортировки(Участник, ОтКого, Кому, Копии)
	
	ТипПолучателяЭлектронногоПисьма = Участник.ТипПолучателяЭлектронногоПисьма;
	
	Если ТипПолучателяЭлектронногоПисьма = Перечисления.ТипыПолучателейЭлектронногоПисьма.ОтКого Тогда
		
		Если ОтКого = Неопределено Тогда
			
			ОтКого = Участник;
			
		Иначе
			
			ВажностьОтКого = ЭлектроннаяПочтаУНФ.ВажностьОтображенияКонтакта(ОтКого.Ссылка);
			ВажностьДубляОтправителя = ЭлектроннаяПочтаУНФ.ВажностьОтображенияКонтакта(Участник.Ссылка);
			Если ВажностьДубляОтправителя > ВажностьОтКого Тогда
				ОтКого = Участник;
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ТипПолучателяЭлектронногоПисьма = Перечисления.ТипыПолучателейЭлектронногоПисьма.Кому Тогда
		Кому.Добавить(Участник);
	ИначеЕсли ТипПолучателяЭлектронногоПисьма = Перечисления.ТипыПолучателейЭлектронногоПисьма.Копия Тогда
		Копии.Добавить(Участник);
	Иначе
		
		ЭтоСозданныйКонтактВРеквизитахСобытий =
			ТипПолучателяЭлектронногоПисьма = Перечисления.ТипыПолучателейЭлектронногоПисьма.ПустаяСсылка()
			И ТипЗнч(Участник.КонтактВПисьме) <> Тип("Строка")
			И Не Участник.КонтактВПисьме.Пустая();
		Если ЭтоСозданныйКонтактВРеквизитахСобытий Тогда
			Кому.Добавить(Участник);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЗначениеВМассиве(Значение, Массив)
	
	Для Каждого Элемент Из Массив Цикл
		Если Элемент = Значение Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция СодержаниеВОднуСтроку(Содержание, СодержаниеHTML, МаксДлина)
	
	Результат = "";
	
	Если ЗначениеЗаполнено(Содержание) Тогда
		Если СтрНайти(НРег(Содержание), "<html") Тогда
			Буфер = Гипертекст.ПолучитьТекстИзHTML(Содержание);
		Иначе
			Буфер = Содержание;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Буфер) Тогда
		Буфер = Гипертекст.ПолучитьТекстИзHTML(СодержаниеHTML);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Буфер) Тогда
		Возврат "";
	КонецЕсли;
	
	Для ИндексСтроки = 1 По СтрЧислоСтрок(Буфер) Цикл
		
		Если СтрДлина(Результат) > МаксДлина Тогда
			Прервать;
		КонецЕсли;
		
		СтрокаПодстановки = СокрЛ(СтрПолучитьСтроку(Буфер, ИндексСтроки));
		
		Результат = СокрЛП(
		СтрШаблон("%1 %2",
		Результат,
		СтрокаПодстановки));
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область АссистентУправления

Процедура ОтправитьЭлектронноеПисьмоБезДокументаСобытие( ЗначенияЗаполнения, ШаблонСообщения = Неопределено, ДополнительныеПараметры = Неопределено )
	
	ПредметСообщения = ЗначенияЗаполнения.ОснованиеЗаполнения;
	СообщениеПоШаблону = ШаблоныСообщений.СформироватьСообщение(ШаблонСообщения, ПредметСообщения, Новый УникальныйИдентификатор, ДополнительныеПараметры);
	
	СодержаниеHTML = СообщениеПоШаблону.Текст;
	ТекстПисьмаСКартинками = СодержаниеHTML;
	
	ПочтовыеАдресаПолучателейДляОтправкиПисьма = Новый Массив;
	ПочтовыеАдресаПоиск = Новый Соответствие;
	Для Каждого Получатель Из СообщениеПоШаблону.Получатель Цикл
		
		Попытка
			ПриведенныеПочтовыеАдреса = ОбщегоНазначенияКлиентСервер.РазобратьСтрокуСПочтовымиАдресами(Получатель.Адрес);
		Исключение
			ВызватьИсключение НСтр("ru='Некорректный адрес получателя для отправляемого письма'") + ":"
			+ Символы.ПС + ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
		
		Для Каждого ПриведенныйПочтовыйАдрес Из ПриведенныеПочтовыеАдреса Цикл
			
			Если ПочтовыеАдресаПоиск.Получить( ПриведенныйПочтовыйАдрес.Адрес ) = Истина Тогда
				Продолжить;
			КонецЕсли;
			
			ПочтовыеАдресаПолучателейДляОтправкиПисьма.Добавить( ПриведенныйПочтовыйАдрес );
			ПочтовыеАдресаПоиск.Вставить( ПриведенныйПочтовыйАдрес.Адрес, Истина );
			
		КонецЦикла;
	КонецЦикла;
	
	ПараметрыПисьма = Новый Структура;
	
	Если ПочтовыеАдресаПолучателейДляОтправкиПисьма.Количество() > 0 Тогда
		ПараметрыПисьма.Вставить( "Кому", ПочтовыеАдресаПолучателейДляОтправкиПисьма );
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СообщениеПоШаблону.Тема) Тогда
		ПараметрыПисьма.Вставить( "Тема", Строка(СообщениеПоШаблону.Тема) );
	КонецЕсли;
	
	АдресПолучателяСкрытойКопии = УправлениеНебольшойФирмойВзаимодействия.ПолучитьАдресПолучателяСкрытойКопии();
	Если ЗначениеЗаполнено(АдресПолучателяСкрытойКопии) Тогда
		ПараметрыПисьма.Вставить( "СкрытыеКопии", АдресПолучателяСкрытойКопии );
	КонецЕсли;
	
	ВложенияПисьма = Новый Соответствие;
	
	Если СообщениеПоШаблону.Вложения.Количество() > 0 Тогда
		
		Для Каждого Вложение Из СообщениеПоШаблону.Вложения Цикл

			Если ЗначениеЗаполнено( Вложение.Идентификатор ) Тогда

				ВложениеКартинка = Новый Структура( "ДвоичныеДанные, Идентификатор" );
				КартинкаОбъект = Новый Картинка( ПолучитьИзВременногоХранилища( Вложение.АдресВоВременномХранилище ) );
				ВложениеКартинка.ДвоичныеДанные = КартинкаОбъект.ПолучитьДвоичныеДанные();
				ВложениеКартинка.Идентификатор = Вложение.Идентификатор;
				
				ВложенияПисьма.Вставить( Вложение.Представление, ВложениеКартинка );
				
			Иначе
			
				ВложенияПисьма.Вставить( Вложение.Представление, Вложение.АдресВоВременномХранилище );
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ПараметрыПисьма.Вставить( "Тело", ТекстПисьмаСКартинками);
	ПараметрыПисьма.Вставить( "Вложения", ВложенияПисьма);
	ПараметрыПисьма.Вставить( "ТипТекста", "HTML");
	
	УчетнаяЗапись = ЗначенияЗаполнения.УчетнаяЗапись;
	
	Попытка
		
		ЭлектроннаяПочтаУНФ.ОтправитьПочтовоеСообщение(ПараметрыПисьма, УчетнаяЗапись);
		
	Исключение
	
		ТекстОшибкиШаблон = НСтр("ru='Не удалось выполнить отправку письма по причине:
		|%1'");
		
		ПричинаОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстОшибки = СтрШаблон(ТекстОшибкиШаблон, ПричинаОшибки);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
КонецПроцедуры

Функция СоздатьОтправитьЭлектронноеПисьмо(ЗначенияЗаполнения, ШаблонСообщения = Неопределено, ДополнительныеПараметры = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("Событие", ПустаяСсылка());
	Результат.Вставить("ТекстОшибки", "");

	Если НЕ ПолучитьФункциональнуюОпцию( "ИспользоватьСобытия" ) Тогда
	
		Если НЕ РегламентныеЗаданияСервер.РаботаСВнешнимиРесурсамиЗаблокирована() Тогда
			ОтправитьЭлектронноеПисьмоБезДокументаСобытие( ЗначенияЗаполнения, ШаблонСообщения, ДополнительныеПараметры );
		КонецЕсли;
		
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ЗначенияЗаполнения.Свойство("ТипСобытия") Тогда
		ЗначенияЗаполнения.Вставить("ТипСобытия", Перечисления.ТипыСобытий.ЭлектронноеПисьмо);
	КонецЕсли;
	
	Если НЕ ЗначенияЗаполнения.Свойство("Автор") Тогда
		ЗначенияЗаполнения.Вставить("Автор", Пользователи.АвторизованныйПользователь());
	КонецЕсли;
	
	СобытиеОбъект = СоздатьДокумент();
	СобытиеОбъект.Заполнить(ЗначенияЗаполнения);
	СобытиеОбъект.Дата = ТекущаяДатаСеанса();
		
	Если ШаблонСообщения <> Неопределено Тогда
		Если ДополнительныеПараметры = Неопределено Тогда
			ДополнительныеПараметры = Новый Структура;
		КонецЕсли;
		
		Если Не ДополнительныеПараметры.Свойство("ПараметрыСообщения") Тогда
			ДополнительныеПараметры.Вставить("ПараметрыСообщения", Новый Структура);
		КонецЕсли;
		
		Если ЗначенияЗаполнения.Свойство("ВыбранныйПолучатель") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ДополнительныеПараметры.ПараметрыСообщения, ЗначенияЗаполнения.ВыбранныйПолучатель, Истина);
		КонецЕсли;
		
		СобытиеОбъект.ЗаполнитьПоШаблону(ШаблонСообщения, ЗначенияЗаполнения.ОснованиеЗаполнения, ДополнительныеПараметры);
	КонецЕсли;
	
	Если НЕ РегламентныеЗаданияСервер.РаботаСВнешнимиРесурсамиЗаблокирована() Тогда
		Попытка
			СобытиеОбъект.ОтправитьЭлектронноеПисьмо(Ложь);
		Исключение
			Результат.ТекстОшибки = СтрШаблон(НСтр("ru='Не удалось автоматически отправить электронное письмо, требуется отправка из формы События.
				|По причине: %1'"), ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	Иначе
		Результат.ТекстОшибки = НСтр("ru='Автоматическая отправка письма невозможна, т.к. в базе установлена блокировка работы с внешними ресурсами.
			|Для разблокирования перейдите в Еще больше возможностей - Администрирование - Регламентные операции - Разблокировать работу с внешними ресурсами.'");
	КонецЕсли;
	
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура")
		И ДополнительныеПараметры.Свойство("ЭтоЗаписьАссистентом") Тогда
		СобытиеОбъект.ДополнительныеСвойства.Вставить("ЭтоЗаписьАссистентом", ДополнительныеПараметры.ЭтоЗаписьАссистентом);
	КонецЕсли;
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура")
		И ДополнительныеПараметры.Свойство("ЗадачаАссистентаУправления") Тогда
		СобытиеОбъект.ЗадачаАссистентаУправления = ДополнительныеПараметры.ЗадачаАссистентаУправления;
	КонецЕсли;
	
	СобытиеОбъект.Записать();
	Результат.Событие = СобытиеОбъект.Ссылка;
	
	Возврат Результат;
	
КонецФункции

Процедура ОтправитьSMSБезДокументаСобытие( ЗначенияЗаполнения, ШаблонСообщения = Неопределено, ДополнительныеПараметры = Неопределено )
	
	ПредметСообщения = ЗначенияЗаполнения.ОснованиеЗаполнения;
	СообщениеПоШаблону = ШаблоныСообщений.СформироватьСообщение(ШаблонСообщения, ПредметСообщения, Новый УникальныйИдентификатор, ДополнительныеПараметры);
	Содержание = СообщениеПоШаблону.Текст;
	
	МассивНомеров = Новый Массив;
	Для Каждого Получатель Из СообщениеПоШаблону.Получатель Цикл
		РезультатПроверки = УправлениеНебольшойФирмойКлиентСервер.ПреобразоватьНомерДляОтправкиSMS(Получатель.НомерТелефона);
		Если РезультатПроверки.НомерКорректен Тогда
			Если МассивНомеров.Найти( РезультатПроверки.НомерОтправки ) = Неопределено Тогда
				МассивНомеров.Добавить( РезультатПроверки.НомерОтправки );
			КонецЕсли;
		Иначе
			ТекстОшибки = НСтр("ru='Неверный формат номера в строке %1 списка получателей'") + ":" + Символы.ПС + РезультатПроверки.СообщениеОбОшибке;
			ВызватьИсключение ТекстОшибки;
		КонецЕсли;
	КонецЦикла;
	
	Если МассивНомеров.Количество() > 0 Тогда
		РезультатОтправки = ОтправкаSMS.ОтправитьSMS(МассивНомеров, Содержание);
		
		Если Не ПустаяСтрока(РезультатОтправки.ОписаниеОшибки) Тогда
			ТекстОшибки = НСтр("ru='Не удалось выполнить отправку SMS по причине'") + ":" + Символы.ПС + РезультатОтправки.ОписаниеОшибки;
			ВызватьИсключение ТекстОшибки;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция СоздатьОтправитьSMS(ЗначенияЗаполнения, ШаблонСообщения = Неопределено, ДополнительныеПараметры = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("Событие", ПустаяСсылка());
	Результат.Вставить("ТекстОшибки", "");

	Если НЕ ПолучитьФункциональнуюОпцию( "ИспользоватьСобытия" ) Тогда
		
		Если НЕ РегламентныеЗаданияСервер.РаботаСВнешнимиРесурсамиЗаблокирована() Тогда
			ОтправитьSMSБезДокументаСобытие( ЗначенияЗаполнения, ШаблонСообщения, ДополнительныеПараметры );
		КонецЕсли;
		
		Возврат Результат;
	КонецЕсли;
	
	Если НЕ ЗначенияЗаполнения.Свойство("ТипСобытия") Тогда
		ЗначенияЗаполнения.Вставить("ТипСобытия", Перечисления.ТипыСобытий.СообщениеSMS);
	КонецЕсли;
	
	Если НЕ ЗначенияЗаполнения.Свойство("Автор") Тогда
		ЗначенияЗаполнения.Вставить("Автор", Пользователи.АвторизованныйПользователь());
	КонецЕсли;
	
	СобытиеОбъект = СоздатьДокумент();
	СобытиеОбъект.Заполнить(ЗначенияЗаполнения);
	СобытиеОбъект.Дата = ТекущаяДатаСеанса();
	
	Если ШаблонСообщения <> Неопределено Тогда
		Если ДополнительныеПараметры = Неопределено Тогда
			ДополнительныеПараметры = Новый Структура;
		КонецЕсли;
		
		Если Не ДополнительныеПараметры.Свойство("ПараметрыСообщения") Тогда
			ДополнительныеПараметры.Вставить("ПараметрыСообщения", Новый Структура);
		КонецЕсли;
		
		Если ЗначенияЗаполнения.Свойство("ВыбранныйПолучатель") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(ДополнительныеПараметры.ПараметрыСообщения, ЗначенияЗаполнения.ВыбранныйПолучатель, Истина);
		КонецЕсли;
		
		СобытиеОбъект.ЗаполнитьПоШаблону(ШаблонСообщения, ЗначенияЗаполнения.ОснованиеЗаполнения, ДополнительныеПараметры);
	КонецЕсли;
	
	Если НЕ РегламентныеЗаданияСервер.РаботаСВнешнимиРесурсамиЗаблокирована() Тогда
		Попытка
			СобытиеОбъект.ОтправитьSMS(Ложь);
		Исключение
			Результат.ТекстОшибки = СтрШаблон(НСтр("ru='Не удалось автоматически отправить сообщение SMS, требуется отправка из формы События.
				|По причине: %1'"), ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	Иначе
		Результат.ТекстОшибки = НСтр("ru='Автоматическая отправка сообщения SMS невозможна, т.к. в базе установлена блокировка работы с внешними ресурсами.
			|Для разблокирования перейдите в Еще больше возможностей - Администрирование - Регламентные операции - Разблокировать работу с внешними ресурсами.'");
	КонецЕсли;
	
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура")
		И ДополнительныеПараметры.Свойство("ЭтоЗаписьАссистентом") Тогда
		СобытиеОбъект.ДополнительныеСвойства.Вставить("ЭтоЗаписьАссистентом", ДополнительныеПараметры.ЭтоЗаписьАссистентом);
	КонецЕсли;
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура")
		И ДополнительныеПараметры.Свойство("ЗадачаАссистентаУправления") Тогда
		СобытиеОбъект.ЗадачаАссистентаУправления = ДополнительныеПараметры.ЗадачаАссистентаУправления;
	КонецЕсли;
	
	СобытиеОбъект.Записать();
	Результат.Событие = СобытиеОбъект.Ссылка;
	
	Возврат Результат;
	
КонецФункции

