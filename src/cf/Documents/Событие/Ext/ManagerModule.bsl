// Вызывается из Обработка.ДокументыПоКритериюОтбора для изменения запроса по контрагенту
// 
// Параметры:
//  ТекстЗапроса - Строка
Процедура ИзменитьЗапросОтбораПоКонтрагенту(ТекстЗапроса) Экспорт
	
	СекцияНаИзменение = 
	"( 1 В
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|			1
	|	ИЗ
	|		Документ.Событие.УдалитьУчастники КАК ТаблицаСтрок
	|	ГДЕ
	|		ТаблицаСтрок.Ссылка =  ТаблицаШапки.Ссылка
	|		И (  ТаблицаСтрок.Контакт = &Параметр  )
	|	) ИЛИ  1 В
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|			1
	|	ИЗ
	|		Документ.Событие.Участники КАК ТаблицаСтрок
	|	ГДЕ
	|		ТаблицаСтрок.Ссылка =  ТаблицаШапки.Ссылка
	|		И (  ТаблицаСтрок.Контакт = &Параметр  )
	|	)";
	
	НоваяСекция = 
	"(ТаблицаШапки.ТипСобытия <> ЗНАЧЕНИЕ(Перечисление.ТипыСобытий.ЭлектронноеПисьмо) И
	|( 1 В
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|			1
	|	ИЗ
	|		Документ.Событие.УдалитьУчастники КАК ТаблицаСтрок
	|	ГДЕ
	|		ТаблицаСтрок.Ссылка =  ТаблицаШапки.Ссылка
	|		И (  ТаблицаСтрок.Контакт = &Параметр  )
	|	) ИЛИ  1 В
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|			1
	|	ИЗ
	|		Документ.Событие.Участники КАК ТаблицаСтрок
	|	ГДЕ
	|		ТаблицаСтрок.Ссылка =  ТаблицаШапки.Ссылка
	|		И (  ТаблицаСтрок.Контакт = &Параметр  )
	|	))
	|ИЛИ (ТаблицаШапки.ТипСобытия = ЗНАЧЕНИЕ(Перечисление.ТипыСобытий.ЭлектронноеПисьмо) И
	|( 1 В
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|			1
	|	ИЗ
	|		Документ.Событие.УдалитьУчастники КАК ТаблицаСтрок
	|	ГДЕ
	|		ТаблицаСтрок.Ссылка =  ТаблицаШапки.Ссылка
	|		И (  ТаблицаСтрок.Контакт = &Параметр  )
	|	) ИЛИ  1 В
	|	(ВЫБРАТЬ ПЕРВЫЕ 1
	|			1
	|	ИЗ
	|		Документ.Событие.Участники КАК ТаблицаСтрок
	|	ГДЕ
	|		ТаблицаСтрок.Ссылка =  ТаблицаШапки.Ссылка
	|		И (  ТаблицаСтрок.Контакт В (ВЫБРАТЬ
	|	СвязиАдресатКонтактCRM.Адресат КАК СсылкаКакСвязаться
	|ИЗ
	|	РегистрСведений.СвязиАдресатКонтактCRM КАК СвязиАдресатКонтактCRM
	|ГДЕ
	|	СвязиАдресатКонтактCRM.КонтактCRM В(&Параметр))  )
	|	)))";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, СекцияНаИзменение, НоваяСекция);
	
КонецПроцедуры

