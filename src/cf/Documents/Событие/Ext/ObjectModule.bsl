// Процедура заполнения документа на основании задания на работу.
//
// Параметры:
//	СтруктураЗаполнения - структура - структура с данными заполнения.
//	
Процедура ЗаполнитьПоТекущейСтрокеЗаданияНаРаботу(СтруктураЗаполнения)
	
	Участники.Очистить();
	ДокументыОснования.Очистить();
	Если ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
		СтрокаДокументыОснования = ДокументыОснования.Добавить();
		СтрокаДокументыОснования.ДокументОснование = СтруктураЗаполнения.Основание;
	Иначе
		ДокументОснование = СтруктураЗаполнения.Основание;
	КонецЕсли;
	
	Если ТипЗнч(СтруктураЗаполнения.Заказчик) = Тип("СправочникСсылка.Контрагенты") Тогда
		СтрокаУчастники = Участники.Добавить();
		СтрокаУчастники.Контакт = СтруктураЗаполнения.Заказчик;
	ИначеЕсли ТипЗнч(СтруктураЗаполнения.Заказчик) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		СтрокаУчастники = Участники.Добавить();
		СтрокаУчастники.Контакт = СтруктураЗаполнения.Заказчик.Владелец;
	ИначеЕсли ТипЗнч(СтруктураЗаполнения.Заказчик) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		СтрокаУчастники = Участники.Добавить();
		СтрокаУчастники.Контакт = СтруктураЗаполнения.Заказчик.Контрагент;
	КонецЕсли;
	
	Если СтрокаУчастники <> Неопределено И ЗначениеЗаполнено(СтрокаУчастники.Контакт) Тогда
		ЗаполнитьКакСвязаться();
	КонецЕсли;
	
	НачалоСобытия = СтруктураЗаполнения.ДатаНачала;
	ОкончаниеСобытия = СтруктураЗаполнения.ДатаОкончания;
	
	Ответственный = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойОтветственный");
	
КонецПроцедуры // ЗаполнитьПоТекущейСтрокеЗаданияНаРаботу()

// Процедура заполняет значение реквизита табличной части "Как связаться" в зависимости от типа события
//
Процедура ЗаполнитьКакСвязаться()
	
	Клиенты = Участники.ВыгрузитьКолонку("Контакт");
	ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияТипаИзМассива(Клиенты, Тип("Строка"));
	ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияТипаИзМассива(Клиенты, Тип("Неопределено"));
	КонтактныеЛица = ОбщегоНазначения.СкопироватьРекурсивно(Клиенты);
	ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияТипаИзМассива(Клиенты, Тип("СправочникСсылка.КонтактныеЛица"));
	ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияТипаИзМассива(КонтактныеЛица, Тип("СправочникСсылка.Контрагенты"));
	
	ТипыКИ = Новый Массив;
	Если НЕ ТипСобытия = Перечисления.ТипыСобытий.СообщениеSMS И НЕ ТипСобытия = Перечисления.ТипыСобытий.ТелефонныйЗвонок Тогда
		ТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	КонецЕсли;
	Если НЕ ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
		ТипыКИ.Добавить(Перечисления.ТипыКонтактнойИнформации.Телефон);
	КонецЕсли;
	
	Если Клиенты.Количество() > 0 Тогда
		ТаблицаКИ_Клиентов = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(Клиенты,
			ТипыКИ, , ТекущаяДатаСеанса());
		ТаблицаКИ_Клиентов.Сортировать("Объект ВОЗР, Тип УБЫВ");
	КонецЕсли;
	
	Если КонтактныеЛица.Количество() > 0 Тогда
		ТаблицаКИ_КонтактныхЛиц = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(КонтактныеЛица, 
			ТипыКИ, , ТекущаяДатаСеанса());
		ТаблицаКИ_КонтактныхЛиц.Сортировать("Объект ВОЗР, Тип УБЫВ");
	КонецЕсли;
	
	Отбор = Новый Структура("Объект");
	Индекс = 0;
	
	Пока Индекс <= Участники.Количество()-1 Цикл
		
		ТекСтр = Участники[Индекс];
		Отбор.Объект = ТекСтр.Контакт;
		СтрокиКИ = Новый Массив;
		
		Если (ТипЗнч(ТекСтр.Контакт) = Тип("СправочникСсылка.Контрагенты")
			Или ТипЗнч(ТекСтр.Контакт) = Тип("СправочникСсылка.Лиды"))
			И ТаблицаКИ_Клиентов <> Неопределено
			И ТаблицаКИ_Клиентов.Количество() > 0 Тогда
			СтрокиКИ = ТаблицаКИ_Клиентов.НайтиСтроки(Отбор);
		ИначеЕсли ТипЗнч(ТекСтр.Контакт) = Тип("СправочникСсылка.КонтактныеЛица")
			И ТаблицаКИ_КонтактныхЛиц <> Неопределено
			И ТаблицаКИ_КонтактныхЛиц.Количество() > 0 Тогда
			СтрокиКИ = ТаблицаКИ_КонтактныхЛиц.НайтиСтроки(Отбор);
		КонецЕсли;
		
		// Для SMS каждый телефон на новой строке
		// Для прочих типов события выводим контактную информацию в одну строку
		
		Если ТипСобытия = Перечисления.ТипыСобытий.СообщениеSMS Тогда
			ПервоеЗначениеКИ = Истина;
			Для Каждого СтрокаКИ Из СтрокиКИ Цикл
				Если НЕ ПервоеЗначениеКИ Тогда
					Индекс = Индекс + 1;
					ТекСтр = Участники.Вставить(Индекс);
					ТекСтр.Контакт = Отбор.Объект;
				КонецЕсли;
				ТекСтр.КакСвязаться = СтрокаКИ.Представление;
				ПервоеЗначениеКИ = Ложь;
			КонецЦикла;
		ИначеЕсли ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
			ПервоеЗначениеКИ = Истина;				
			Для Каждого СтрокаКИ Из СтрокиКИ Цикл
				Если НЕ ПервоеЗначениеКИ Тогда
					Индекс = Индекс + 1;
					ТекСтр = Участники.Вставить(Индекс);
					ТекСтр.Контакт = Отбор.Объект;
				КонецЕсли;
				ТекСтр.КакСвязаться = СтрокаКИ.Представление;
				ПервоеЗначениеКИ = Ложь;
			КонецЦикла;
		Иначе	
			Для Каждого СтрокаКИ Из СтрокиКИ Цикл
				ТекСтр.КакСвязаться = "" + ТекСтр.КакСвязаться + ?(ТекСтр.КакСвязаться = "", "", "; ") + СтрокаКИ.Представление;
			КонецЦикла;
		КонецЕсли;
		
		Индекс = Индекс + 1;
		
	КонецЦикла;
	
	Если ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
		Для Каждого Стр Из Участники Цикл
			Если НЕ ЗначениеЗаполнено(Стр.ТипПолучателяЭлектронногоПисьма) Тогда
				Стр.ТипПолучателяЭлектронногоПисьма = Перечисления.ТипыПолучателейЭлектронногоПисьма.Кому;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Функция проверяет тип значения документа основания.
//
Функция ДопустимыйТипДляВводаНаОсновании(ДокОснование)
	
	Возврат ОбщегоНазначения.ЕстьРеквизитОбъекта(
	"Контрагент",
	ДокОснование.Метаданные());
	
КонецФункции // ПроверитьТипЗнчДанныеЗаполнения(ДокОснование)

Процедура ЗаполнитьПоИнтернетПочтовоеСообщение(ДанныеЗаполнения)
	
	ИнтернетПочтовоеСообщение = Неопределено;
	Если Не ДанныеЗаполнения.Свойство("ИнтернетПочтовоеСообщение", ИнтернетПочтовоеСообщение) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ИнтернетПочтовоеСообщение) <> Тип("ИнтернетПочтовоеСообщение") Тогда
		Возврат;
	КонецЕсли;
	
	Дата = ИнтернетПочтовоеСообщение.ДатаПолучения;
	НачалоСобытия = ЛокальнаяДатаОтправления(ИнтернетПочтовоеСообщение);
	ОкончаниеСобытия = ИнтернетПочтовоеСообщение.ДатаПолучения;
	Если ОкончаниеСобытия < НачалоСобытия Тогда
		ОкончаниеСобытия = НачалоСобытия;
	КонецЕсли;
	
	ВариантЗагрузки = Неопределено;
	ДанныеЗаполнения.Свойство("ВариантЗагрузки", ВариантЗагрузки);
	Если Не ЗначениеЗаполнено(ВариантЗагрузки) Тогда
		ВариантЗагрузки = Перечисления.ВариантыЗагрузкиПисем.ТекстыИВложения;
	КонецЕсли;
	
	ОткрытиеВложенногоПисьма = Ложь;
	Если ДанныеЗаполнения.Свойство("ЭтоОткрытиеСтороннегоВложенногоПисьма") Тогда
		ОткрытиеВложенногоПисьма = ДанныеЗаполнения.ЭтоОткрытиеСтороннегоВложенногоПисьма;
	КонецЕсли;
	
	Тема = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыXML(ИнтернетПочтовоеСообщение.Тема);
	ЗаполнитьКонтактыПоИнтернетПочтовоеСообщение(ИнтернетПочтовоеСообщение, ОткрытиеВложенногоПисьма);
	ЗаполнитьСодержимоеПоИнтернетПочтовоеСообщение(ИнтернетПочтовоеСообщение, ВариантЗагрузки);
	
	ИдентификаторОригинальногоСообщения = ЭлектроннаяПочтаУНФ.ЗначениеПоляЗаголовкаПисьма(ИнтернетПочтовоеСообщение.Заголовок, "References");
	ИдентификаторыСвязанныхСообщений = ИдентификаторыСвязанныхСообщений(ИдентификаторОригинальногоСообщения);
	ИдентификаторОснования = ЭлектроннаяПочтаУНФ.ЗначениеПоляЗаголовкаПисьма(ИнтернетПочтовоеСообщение.Заголовок, "In-Reply-To");
	ЗаполнитьДокументыОснованияПоИнтернетПочтовоеСообщение(ИдентификаторОснования, ИдентификаторыСвязанныхСообщений);
	
	// Заполнение по интернет почтовому сообщению выполнено полностью.
	// Необходимо удалить его из данных заполнения, чтобы не мешать универсальному механизму заполнения объектов,
	// т.к. ИнтернетПочтовоеСообщение это мутабельное значение.
	ДанныеЗаполнения.Удалить("ИнтернетПочтовоеСообщение");
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункцииЭлектроннаяПочта

Процедура РазобратьСтрокуКакСвязаться()
	
	НоваяТаблицаУчастников = Новый ТаблицаЗначений;
	НоваяТаблицаУчастников.Колонки.Добавить("КакСвязаться");
	НоваяТаблицаУчастников.Колонки.Добавить("ИдентификаторСообщения");
	НоваяТаблицаУчастников.Колонки.Добавить("СтатусДоставки");
	НоваяТаблицаУчастников.Колонки.Добавить("ТипПолучателяЭлектронногоПисьма");
	НоваяТаблицаУчастников.Колонки.Добавить("Контакт");
	
	Для Каждого Участник Из Участники Цикл
		Если НЕ ЗначениеЗаполнено(Участник.КакСвязаться) Тогда
			СтрокаТаблицы = НоваяТаблицаУчастников.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы,Участник);
			Продолжить;
		КонецЕсли;
		Адреса = ОбщегоНазначенияКлиентСервер.АдресаЭлектроннойПочтыИзСтроки(Участник.КакСвязаться);
		Для Каждого Адрес Из Адреса Цикл
			Если ЗначениеЗаполнено(Адрес.ОписаниеОшибки) Тогда
				Продолжить;
			КонецЕсли;
			СтрокаТаблицы = НоваяТаблицаУчастников.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы,Участник);
			СтрокаТаблицы.КакСвязаться = Адрес.Адрес;
		КонецЦикла;
		
	КонецЦикла;
	
	Участники.Очистить();
	Для Каждого Участник Из НоваяТаблицаУчастников Цикл
		НовыйУчастник = Участники.Добавить();
		ЗаполнитьЗначенияСвойств(НовыйУчастник, Участник);
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьНедостающиеСвязи(СвязиУчастников)
	
	НеобходимыеАдресаЭПКонтактовCRM = Новый Соответствие;
	
	Для Каждого Участник Из Участники Цикл
		
		ТребуетсяУстановитьСвязь = СвязиУчастников.НайтиСтроки(Новый Структура("ИндексСтроки", Участники.Индекс(Участник)));
		Если ТребуетсяУстановитьСвязь.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ТребуетсяУстановитьСвязь[0].КонтактCRM) И НЕ ЗначениеЗаполнено(Участник.Контакт) Тогда
			Продолжить;
		КонецЕсли;
		
		МенеджерСвязи = РегистрыСведений.СвязиАдресатКонтактCRM.СоздатьМенеджерЗаписи();
		МенеджерСвязи.Адресат = Участник.Контакт;
		МенеджерСвязи.КонтактCRM = ТребуетсяУстановитьСвязь[0].КонтактCRM;
		МенеджерСвязи.Записать();
		
		Если НеобходимыеАдресаЭПКонтактовCRM[МенеджерСвязи.КонтактCRM] = Неопределено Тогда
			НеобходимыеАдресаЭПКонтактовCRM[МенеджерСвязи.КонтактCRM] = Новый Массив;
		КонецЕсли;
		
		НеобходимыеАдресаЭПКонтактовCRM[МенеджерСвязи.КонтактCRM].Добавить(Участник.КакСвязаться);
		
	КонецЦикла;
	
	Если НеобходимыеАдресаЭПКонтактовCRM.Количество() Тогда
		ОбновитьАдресаЭПКонтактовCRM(НеобходимыеАдресаЭПКонтактовCRM);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьАдресаЭПКонтактовCRM(НеобходимыеАдресаЭПКонтактовCRM)
	
	КонтактыCRM = Новый Массив;
	Для Каждого КлючЗначение Из НеобходимыеАдресаЭПКонтактовCRM Цикл
		КонтактыCRM.Добавить(КлючЗначение.Ключ);
	КонецЦикла;
	
	ОтборКИ = УправлениеКонтактнойИнформацией.ОтборКонтактнойИнформации();
	ОтборКИ.ТипыКонтактнойИнформации.Добавить(Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	ОтборКИ.Дата = ТекущаяДатаСеанса();
	
	КИКонтактов = УправлениеКонтактнойИнформацией.КонтактнаяИнформация(КонтактыCRM, ОтборКИ);
	
	СуществующиеАдресаЭПКонтактовCRM = Новый Соответствие;
	Для Каждого ЭлементКИ Из КИКонтактов Цикл
		
		АдресЭП = УправлениеКонтактнойИнформацией.АдресЭлектроннойПочты(ЭлементКИ.Значение);
		
		Если СуществующиеАдресаЭПКонтактовCRM[ЭлементКИ.Объект] = Неопределено Тогда
			СуществующиеАдресаЭПКонтактовCRM[ЭлементКИ.Объект] = Новый Массив;
		КонецЕсли;
		
		СуществующиеАдресаЭПКонтактовCRM[ЭлементКИ.Объект].Добавить(АдресЭП);
		
	КонецЦикла;
	
	АдресаЭПКонтактаCRMДляДобавления = Новый Соответствие;
	Для Каждого КлючЗначение Из НеобходимыеАдресаЭПКонтактовCRM Цикл
		
		КонтактCRM = КлючЗначение.Ключ;
		НеобходимыеАдресаЭП = КлючЗначение.Значение;
		
		СуществующиеАдресаЭП = СуществующиеАдресаЭПКонтактовCRM[КонтактCRM];
		Если СуществующиеАдресаЭП = Неопределено Тогда
			АдресаЭПКонтактаCRMДляДобавления[КонтактCRM] = НеобходимыеАдресаЭП;
			Продолжить;
		КонецЕсли;
		
		АдресаЭПДляДобавления = ОбщегоНазначенияКлиентСервер.РазностьМассивов(НеобходимыеАдресаЭП, СуществующиеАдресаЭП);
		Если АдресаЭПДляДобавления.Количество() Тогда
			АдресаЭПКонтактаCRMДляДобавления[КонтактCRM] = АдресаЭПДляДобавления;
		КонецЕсли;
		
	КонецЦикла;
	
	НоваяКИ = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация();
	Для Каждого КлючЗначение Из АдресаЭПКонтактаCRMДляДобавления Цикл
		
		ВидКИ = ВидКИАдресаЭППоОбъекту(КлючЗначение.Ключ);
		Если ВидКИ = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого АдресЭП Из КлючЗначение.Значение Цикл
			
			ЗначениеКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(АдресЭП, ВидКИ);
			
			СтрокаКИ = НоваяКИ.Добавить();
			
			СтрокаКИ.Объект = КлючЗначение.Ключ;
			СтрокаКИ.Вид = ВидКИ;
			СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
			СтрокаКИ.Значение = ЗначениеКИ;
			СтрокаКИ.Представление = АдресЭП;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если НоваяКИ.Количество() Тогда
		УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъектов(НоваяКИ, Ложь);
	КонецЕсли;
	
КонецПроцедуры

Функция ВидКИАдресаЭППоОбъекту(Ссылка)
	
	ТипСсылки = ТипЗнч(Ссылка);
	
	Если ТипСсылки = Тип("СправочникСсылка.Контрагенты") Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.EmailКонтрагента;
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.КонтактныеЛица") Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.EmailКонтактногоЛица;
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.Лиды") Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.EmailКомпанииЛида;
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.КонтактыЛидов") Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.EmailКонтактаЛида;
	ИначеЕсли ТипСсылки = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.EmailФизическиеЛица;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ТаблицаСвязейАдресатовПисьма()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СвязиАдресатКонтактCRM.Адресат КАК Адресат,
	|	СвязиАдресатКонтактCRM.КонтактCRM КАК КонтактCRM
	|ИЗ
	|	РегистрСведений.СвязиАдресатКонтактCRM КАК СвязиАдресатКонтактCRM
	|ГДЕ
	|	СвязиАдресатКонтактCRM.Адресат В(&Адресаты)
	|	И ВЫБОР
	|			КОГДА СвязиАдресатКонтактCRM.КонтактCRM ССЫЛКА Справочник.Лиды
	|				ТОГДА ВЫРАЗИТЬ(СвязиАдресатКонтактCRM.КонтактCRM КАК Справочник.Лиды).ВариантЗавершения = ЗНАЧЕНИЕ(Перечисление.ВариантЗавершенияРаботыСЛидом.ПустаяСсылка)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ";
	
	Запрос.УстановитьПараметр("Адресаты", Участники.ВыгрузитьКолонку("Контакт"));
	ТаблицаСвязей = Запрос.Выполнить().Выгрузить();
	Возврат ТаблицаСвязей;
	
КонецФункции

Процедура НайтиСоздатьАдресатовПисьма()
	
	АдресатыПисьма = Справочники.АдресатыПисем.АдресатыПисемПоКакСвязаться(Участники.ВыгрузитьКолонку("КакСвязаться"));
	
	Для Каждого Участник Из Участники Цикл
		
		Если ЗначениеЗаполнено(Участник.Контакт) 
			И ТипЗнч(Участник.Контакт) <> Тип("Строка") И ТипЗнч(Участник.Контакт) = Тип("СправочникСсылка.АдресатыПисем") Тогда
			Продолжить;
		КонецЕсли;
		
		СсылкиАдресата = АдресатыПисьма.НайтиСтроки(Новый Структура("Адресат", НРег(СокрЛП(Участник.КакСвязаться))));
		
		Если СсылкиАдресата.Количество() <> 0 Тогда
			Участник.Контакт = СсылкиАдресата[0].Ссылка;
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Участник.КакСвязаться) Тогда
			Продолжить;
		КонецЕсли;
		
		Участник.Контакт = Справочники.АдресатыПисем.НовыйАдресатПисьмаПоДаннымКонтакта(Участник.Контакт, Участник.КакСвязаться);
		НоваяСтрока = АдресатыПисьма.Добавить();
		НоваяСтрока.Адресат = НРег(СокрЛП(Участник.КакСвязаться));
		НоваяСтрока.Ссылка = Участник.Контакт; 
		
	КонецЦикла;

КонецПроцедуры

Процедура ЗаполнитьТемуПисьма(ДанныеЗаполнения)
	
	ЗначенияРеквизитовСобытия = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения.ОснованиеЗаполнения, "Тема, ВходящееИсходящееСобытие");
	Если ЗначенияРеквизитовСобытия.ВходящееИсходящееСобытие <> Перечисления.ВходящееИсходящееСобытие.Входящее Тогда
		Возврат;
	КонецЕсли;
	
	Тема = Документы.Событие.ТемаСПрефиксомОтвета(
	ЗначенияРеквизитовСобытия.Тема,
	ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
	ДанныеЗаполнения,
	"Команда",
	ЭлектроннаяПочтаУНФКлиентСервер.КомандаОтветить()));
	
КонецПроцедуры

Процедура ЗаполнитьПредставление()
	
	Если ДополнительныеСвойства.Свойство("ТемаИСодержание") Тогда
		ТемаИСодержание = ДополнительныеСвойства.ТемаИСодержание;
		Возврат;
	КонецЕсли;
	
	ТемаИСодержание = Документы.Событие.ТемаИСодержание(Тема, Содержание, СодержаниеHTML);
	
КонецПроцедуры

Процедура ЗаписатьИдентификаторы()
	
	Если ДополнительныеСвойства.Свойство("Идентификатор") Тогда
		РегистрыСведений.ИдентификаторыСобытий.ЗаписатьИдентификатор(УчетнаяЗапись, Ссылка, ДополнительныеСвойства.Идентификатор);
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ИдентификаторыСообщений") Тогда
		РегистрыСведений.ИдентификаторыСообщений.ЗаписатьИдентификаторы(УчетнаяЗапись, Ссылка, ДополнительныеСвойства.ИдентификаторыСообщений);
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ИдентификаторОснования") Тогда
		РегистрыСведений.ИдентификаторыПисемДляОтложеннойПривязки.ЗаписатьИдентификаторСообщения(УчетнаяЗапись, ДополнительныеСвойства.ИдентификаторОснования, Истина, Ссылка);
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("НесопоставленныеИдентификаторыСообщений") Тогда
		Для Каждого ТекИдентификатор Из ДополнительныеСвойства.НесопоставленныеИдентификаторыСообщений Цикл
			Если ДополнительныеСвойства.Свойство("ИдентификаторОснования")
				И ТекИдентификатор = ДополнительныеСвойства.ИдентификаторОснования Тогда
				Продолжить;
			КонецЕсли;
			РегистрыСведений.ИдентификаторыПисемДляОтложеннойПривязки.ЗаписатьИдентификаторСообщения(УчетнаяЗапись, ТекИдентификатор, Ложь, Ссылка);
		КонецЦикла;
	КонецЕсли;
	
	ВыполнитьОтложеннуюПривязкуСобытий();
	
КонецПроцедуры

Процедура ВыполнитьОтложеннуюПривязкуСобытий()
	
	Если Не ДополнительныеСвойства.Свойство("ИдентификаторыСообщений") Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ТекИдентификаторСообщения Из ДополнительныеСвойства.ИдентификаторыСообщений Цикл
		
		ИдентификаторСообщения = ЭлектроннаяПочтаУНФКлиентСервер.СократитьУгловыеСкобки(ТекИдентификаторСообщения);
		
		СобытияДляЗаписи = Новый Соответствие;
		
		ТаблицаСобытий = РегистрыСведений.ИдентификаторыПисемДляОтложеннойПривязки.СвязанныеСобытия(УчетнаяЗапись, ИдентификаторСообщения);
		Для Каждого ТекСтрокаТаблицыСобытий Из ТаблицаСобытий Цикл
			
			Если СобытияДляЗаписи[ТекСтрокаТаблицыСобытий.Событие] = Неопределено Тогда
				СобытияДляЗаписи[ТекСтрокаТаблицыСобытий.Событие] = ТекСтрокаТаблицыСобытий.Событие.ПолучитьОбъект();
			КонецЕсли;
			
			Если ТекСтрокаТаблицыСобытий.ЭтоОснование
				И Не ЗначениеЗаполнено(СобытияДляЗаписи[ТекСтрокаТаблицыСобытий.Событие].ДокументОснование) Тогда
				СобытияДляЗаписи[ТекСтрокаТаблицыСобытий.Событие].ДокументОснование = Ссылка;
				СобытияДляЗаписи[ТекСтрокаТаблицыСобытий.Событие].ЗаполнитьДокументыОснованияИзСвязанногоСобытия();
				Продолжить;
			КонецЕсли;
			
			Если СобытияДляЗаписи[ТекСтрокаТаблицыСобытий.Событие].ДокументыОснования.Найти(Ссылка) = Неопределено Тогда
				НоваяСтрокаДокументыОснования = СобытияДляЗаписи[ТекСтрокаТаблицыСобытий.Событие].ДокументыОснования.Добавить();
				НоваяСтрокаДокументыОснования.ДокументОснование = Ссылка;
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого ТекСобытиеДляЗаписи Из СобытияДляЗаписи Цикл
			ТекСобытиеДляЗаписи.Значение.Записать();
		КонецЦикла;
		
		РегистрыСведений.ИдентификаторыПисемДляОтложеннойПривязки.УдалитьИдентификаторСообщения(УчетнаяЗапись, ИдентификаторСообщения);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьИнтернетПочтовыеВложения()
	
	Если Не ДополнительныеСвойства.Свойство("Вложения") Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДополнительныеСвойства.Вложения) = Тип("Массив") Тогда
		
		ЗаписатьИнтернетПочтовыеВложенияИзМассива(ДополнительныеСвойства.Вложения);
		
	ИначеЕсли ТипЗнч(ДополнительныеСвойства.Вложения) = Тип("Соответствие") Тогда
		
		ЗаписатьИнтернетПочтовыеВложенияИзСоответствия(ДополнительныеСвойства.Вложения);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьИнтернетПочтовыеВложенияИзМассива(Вложения)
	
	Для Каждого ТекВложение Из Вложения Цикл
		
		ИмяИАдресВложения = ИмяИАдресВложения(ТекВложение);
		Если Не ЭтоАдресВременногоХранилища(ИмяИАдресВложения.АдресВоВременномХранилище) Тогда
			Продолжить;
		КонецЕсли;
		
		ПараметрыФайла = Новый Структура;
		ПараметрыФайла.Вставить("Автор", Автор);
		ПараметрыФайла.Вставить("ВладелецФайлов", Ссылка);
		ПараметрыФайла.Вставить("ИмяБезРасширения", ИмяИАдресВложения.ИмяБезРасширения);
		ПараметрыФайла.Вставить("РасширениеБезТочки", ИмяИАдресВложения.РасширениеБезТочки);
		ПараметрыФайла.Вставить("ВремяИзмененияУниверсальное", ТекущаяУниверсальнаяДата());
		
		Если ЗначениеЗаполнено(ТекВложение.Идентификатор) Тогда
			ПараметрыФайла.Вставить("ИДФайлаЭлектронногоПисьма", ТекВложение.Идентификатор);
		КонецЕсли;
		ПараметрыФайла.Вставить("ЭтоВложениеЭлектронногоПисьма", Истина);
		
		РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, ИмяИАдресВложения.АдресВоВременномХранилище);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ИмяИАдресВложения(Вложение)
	
	Результат = Новый Структура;
	Результат.Вставить("ИмяБезРасширения");
	Результат.Вставить("РасширениеБезТочки");
	Результат.Вставить("АдресВоВременномХранилище");
	
	Если ТипЗнч(Вложение.Данные) = Тип("ДвоичныеДанные") Тогда
		
		ПолноеИмяФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Вложение.ИмяФайла);
		Результат.ИмяБезРасширения = ПолноеИмяФайла.ИмяБезРасширения;
		Результат.РасширениеБезТочки = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(ПолноеИмяФайла.Расширение);
		Результат.АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(Вложение.Данные);
		
	ИначеЕсли ТипЗнч(Вложение.Данные) = Тип("ИнтернетПочтовоеСообщение") Тогда
		Наименование = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(Вложение.Данные.Тема);
		
		ПолноеИмяФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(СтрШаблон("%1.eml", Наименование));
		Результат.ИмяБезРасширения = ПолноеИмяФайла.ИмяБезРасширения;
		Результат.РасширениеБезТочки = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(ПолноеИмяФайла.Расширение);
		Результат.АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(Вложение.Данные.ПолучитьИсходныеДанные());
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаписатьИнтернетПочтовыеВложенияИзСоответствия(Вложения)
	
	Для Каждого ТекВложение Из Вложения Цикл
		
		АдресФайлаВоВременномХранилище = Неопределено;
		
		Если ТипЗнч(ТекВложение.Значение) = Тип("Строка") И ЭтоАдресВременногоХранилища(ТекВложение) Тогда
			АдресФайлаВоВременномХранилище = ТекВложение.Значение;
		ИначеЕсли ТипЗнч(ТекВложение.Значение) = Тип("ДвоичныеДанные") Тогда
			АдресФайлаВоВременномХранилище = ПоместитьВоВременноеХранилище(ТекВложение.Значение);
		ИначеЕсли ТипЗнч(ТекВложение.Значение) = Тип("Картинка") Тогда
			АдресФайлаВоВременномХранилище = ПоместитьВоВременноеХранилище(ТекВложение.Значение.ПолучитьДвоичныеДанные());
		ИначеЕсли ТипЗнч(ТекВложение.Значение) = Тип("Файл") И ТекВложение.Значение.Существует() И ТекВложение.Значение.ЭтоФайл() Тогда
			АдресФайлаВоВременномХранилище = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ТекВложение.Значение.ПолноеИмя));
		Иначе
			Продолжить;
		КонецЕсли;
		
		ПолноеИмяФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ТекВложение.Ключ);
		
		ПараметрыФайла = Новый Структура;
		ПараметрыФайла.Вставить("Автор", Автор);
		ПараметрыФайла.Вставить("ВладелецФайлов", Ссылка);
		ПараметрыФайла.Вставить("ИмяБезРасширения", ПолноеИмяФайла.ИмяБезРасширения);
		ПараметрыФайла.Вставить("РасширениеБезТочки", ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(ПолноеИмяФайла.Расширение));
		ПараметрыФайла.Вставить("ВремяИзмененияУниверсальное", ТекущаяУниверсальнаяДата());
		
		РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресФайлаВоВременномХранилище);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьКонтактыВКлассификатор()
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВсеПользователиУчетнойЗаписи = ВсеПользователиУчетнойЗаписи();
	
	Для Каждого ТекУчастник Из Участники Цикл
		
		Если ТипЗнч(ТекУчастник.Контакт) <> Тип("Строка") Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ОбщегоНазначенияКлиентСервер.АдресЭлектроннойПочтыСоответствуетТребованиям(ТекУчастник.КакСвязаться) Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого ТекПользователь Из ВсеПользователиУчетнойЗаписи Цикл
			
			КлассификаторКонтактовОбъект = Справочники.КлассификаторКонтактов.ОбъектПоИдентификатору(НРег(ТекУчастник.КакСвязаться), ТекПользователь);
			Если КлассификаторКонтактовОбъект = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			Справочники.КлассификаторКонтактов.УстановитьКонтактКакСвязаться(КлассификаторКонтактовОбъект, ТекУчастник.Контакт, ТекУчастник.КакСвязаться);
			КлассификаторКонтактовОбъект.Записать();
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ВсеПользователиУчетнойЗаписи()
	
	Результат = Новый Массив;
	Результат.Добавить(Автор);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	УчетныеЗаписиПользователя.Пользователь
	|ИЗ
	|	РегистрСведений.УчетныеЗаписиПользователя КАК УчетныеЗаписиПользователя
	|ГДЕ
	|	УчетныеЗаписиПользователя.УчетнаяЗапись = &УчетнаяЗапись");
	Запрос.УстановитьПараметр("УчетнаяЗапись", УчетнаяЗапись);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
	Результат,
	РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Пользователь"),
	Истина);
	
	Возврат Результат;
	
КонецФункции

Процедура ОпределитьНесопоставленныеИдентификаторыСообщений(ИдентификаторыСообщений, СвязанныеСобытия)
	
	НесопоставленныеИдентификаторыСообщений = Новый Массив;
	
	Для Каждого ТекИдентификатор Из ИдентификаторыСообщений Цикл
		
		Если СвязанныеСобытия[ТекИдентификатор] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НесопоставленныеИдентификаторыСообщений.Добавить(ТекИдентификатор);
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(НесопоставленныеИдентификаторыСообщений) Тогда
		ДополнительныеСвойства.Вставить("НесопоставленныеИдентификаторыСообщений", НесопоставленныеИдентификаторыСообщений);
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьУчастникКакСтрока(УчастникКакСтрока)
	
	Если ЗначениеЗаполнено(УчастникКакСтрока) Тогда
		Участники.Удалить(УчастникКакСтрока);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОчиститьАдресУКонтрагента(УчастникКакКонтрагент)
	
	Если ЗначениеЗаполнено(УчастникКакКонтрагент) Тогда
		УчастникКакКонтрагент.КакСвязаться = "";
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКонтрагентУчастник(Контакт)
	
	Если ТипЗнч(Контакт) <> Тип("СправочникСсылка.КонтактныеЛица") Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = Участники.Вставить(0);
	
	КонтрагентыКонтакта = Справочники.КонтактныеЛица.СвязанныеКонтрагенты(Контакт);
	Если КонтрагентыКонтакта.Количество() = 1 Тогда
		НоваяСтрока.Контакт = КонтрагентыКонтакта[0];
		НоваяСтрока.ТипПолучателяЭлектронногоПисьма
			= ПредопределенноеЗначение("Перечисление.ТипыПолучателейЭлектронногоПисьма.Кому");
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьЛидУчастник(Контакт)
	
	Если ТипЗнч(Контакт) <> Тип("СправочникСсылка.КонтактыЛидов") Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = Участники.Вставить(0);

	Если ЗначениеЗаполнено(Контакт.Владелец) Тогда
		НоваяСтрока.Контакт = Контакт.Владелец;
		НоваяСтрока.ТипПолучателяЭлектронногоПисьма
			= ПредопределенноеЗначение("Перечисление.ТипыПолучателейЭлектронногоПисьма.Кому");
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьВложениеВПрисоединенныеФайлы(Знач Выборка, Вложения)
	
	Если Не ЭтоАдресВременногоХранилища(Выборка.АдресВоВременномХранилище) Тогда
		Возврат;
	КонецЕсли;
	
	ПолноеИмяФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Выборка.Представление);
	
	ПараметрыФайла = Новый Структура;
	ПараметрыФайла.Вставить("Автор", Пользователи.ТекущийПользователь());
	ПараметрыФайла.Вставить("ВладелецФайлов", Ссылка);
	ПараметрыФайла.Вставить("ИмяБезРасширения", ПолноеИмяФайла.ИмяБезРасширения);
	ПараметрыФайла.Вставить("РасширениеБезТочки", ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(ПолноеИмяФайла.Расширение));
	ПараметрыФайла.Вставить("ВремяИзмененияУниверсальное", ТекущаяУниверсальнаяДата());
	
	ПрисоединенныйФайлСсылка = РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, Выборка.АдресВоВременномХранилище);
	
	Вложения.НайтиСтроки(Новый Структура("Представление, АдресВоВременномХранилище", Выборка.Представление, Выборка.АдресВоВременномХранилище))[0].Ссылка = ПрисоединенныйФайлСсылка;
	
	Если ЗначениеЗаполнено(Выборка.Идентификатор)
		ИЛИ Выборка.ЭтоВложениеЭлектронногоПисьма = Истина Тогда
		
		ПрисоединенныйФайлОбъект = ПрисоединенныйФайлСсылка.ПолучитьОбъект();
		
		Если ЗначениеЗаполнено(Выборка.Идентификатор) Тогда
			ПрисоединенныйФайлОбъект.ИДФайлаЭлектронногоПисьма = Выборка.Идентификатор;
		КонецЕсли;
		
		Если Выборка.ЭтоВложениеЭлектронногоПисьма = Истина Тогда
			ПрисоединенныйФайлОбъект.ЭтоВложениеЭлектронногоПисьма = Выборка.ЭтоВложениеЭлектронногоПисьма;
		КонецЕсли;
		
		ПрисоединенныйФайлОбъект.Записать();
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Выборка.Письмо) Тогда
		РегистрыСведений.ВложенныеПисьма.ЗаписатьВложение(ПрисоединенныйФайлСсылка, Выборка.Письмо);
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьВложениеИзПрисоединенныхФайлов(Знач Выборка)
	
	ПрисоединенныйФайлОбъект = Выборка.ПрисоединенныйФайлСсылка.ПолучитьОбъект();
	ПрисоединенныйФайлОбъект.УстановитьПометкуУдаления(Истина);
	
КонецПроцедуры

Процедура ОбновитьВложениеВПрисоединенныхФайлах(Знач Выборка)
	
	Если ЭтоАдресВременногоХранилища(Выборка.АдресВоВременномХранилище) Тогда
		РаботаСФайлами.ОбновитьФайл(Выборка.ПрисоединенныйФайлСсылка, 
		Новый Структура("АдресФайлаВоВременномХранилище, АдресВременногоХранилищаТекста", Выборка.АдресВоВременномХранилище, ""));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область КалендарьСотрудника

Процедура ДозаполнитьПоУмолчанию()
	
	Если ТипСобытия <> Перечисления.ТипыСобытий.ЭлектронноеПисьмо
		И ТипСобытия <> Перечисления.ТипыСобытий.СообщениеSMS Тогда
		
		Если НЕ ЗначениеЗаполнено(НачалоСобытия) Тогда
			НачалоСобытия = ТекущаяДатаСеанса();
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ОкончаниеСобытия) Тогда
			ОкончаниеСобытия = НачалоСобытия + 1800;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(КалендарьСотрудника) Тогда
		КалендарьСотрудника = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойКалендарь");
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьКолонкуЗаписиКалендаря(ЗаписьКалендаря)
	
	КолонкаКалендаря = Справочники.КолонкиКалендарейСотрудников.ПустаяСсылка();
	ДополнительныеСвойства.Свойство("КолонкаКалендаря", КолонкаКалендаря);
	
	Если ЗначениеЗаполнено(КолонкаКалендаря) Тогда
		ЗаписьКалендаря.КолонкаКалендаря = КолонкаКалендаря;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЗаписьКалендаря.КолонкаКалендаря) Тогда
		
		ВладелецКолонки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗаписьКалендаря.КолонкаКалендаря, "Владелец");
		Если ВладелецКолонки <> ЗаписьКалендаря.Календарь Тогда
			ЗаписьКалендаря.КолонкаКалендаря = Справочники.КолонкиКалендарейСотрудников.КолонкаНеобработанное(ЗаписьКалендаря.Календарь);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ЭлектроннаяПочта

// Заполняет участников в указанном Событии, полученные в Почтовом сообщении.
//
// Параметры:
//  ИнтернетПочтовоеСообщение - ИнтернетПочтовоеСообщение, Структура - данные, по которым будет заполняться участники
//  ЭтоОткрытиеСтороннегоВложенногоПисьма - Булево - открывается письмо-вложение
//
Процедура ЗаполнитьКонтактыПоИнтернетПочтовоеСообщение(ИнтернетПочтовоеСообщение, ЭтоОткрытиеСтороннегоВложенногоПисьма = Ложь)
	
	АдресЭПУчетнойЗаписи = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УчетнаяЗапись, "АдресЭлектроннойПочты");
	
	Если ДополнительныеСвойства.Свойство("СопоставленныеКонтакты")
		И ТипЗнч(ДополнительныеСвойства.СопоставленныеКонтакты) = Тип("Соответствие") Тогда
		СопоставленныеКонтакты = ДополнительныеСвойства.СопоставленныеКонтакты;
	Иначе
		СопоставленныеКонтакты = СопоставленныеКонтактыИзПочтовогоСообщения(ИнтернетПочтовоеСообщение);
	КонецЕсли;
	
	Если ВходящееИсходящееСобытие = Перечисления.ВходящееИсходящееСобытие.Входящее Тогда
		ЗаполнитьКонтактыОбработатьПолучателя(СопоставленныеКонтакты, ИнтернетПочтовоеСообщение.Отправитель,
		Перечисления.ТипыПолучателейЭлектронногоПисьма.ОтКого);
		ЗаполнитьКонтактыОбработатьПолучателей(ИнтернетПочтовоеСообщение, СопоставленныеКонтакты, ИнтернетПочтовоеСообщение.Получатели,
		Перечисления.ТипыПолучателейЭлектронногоПисьма.Кому, АдресЭПУчетнойЗаписи);
		ЗаполнитьКонтактыОбработатьПолучателей(ИнтернетПочтовоеСообщение, СопоставленныеКонтакты, ИнтернетПочтовоеСообщение.Копии,
		Перечисления.ТипыПолучателейЭлектронногоПисьма.Копия);
	Иначе
		Если ЭтоОткрытиеСтороннегоВложенногоПисьма Тогда
			ЗаполнитьКонтактыОбработатьПолучателя(СопоставленныеКонтакты, ИнтернетПочтовоеСообщение.Отправитель,
			Перечисления.ТипыПолучателейЭлектронногоПисьма.ОтКого);
		КонецЕсли;
		ЗаполнитьКонтактыОбработатьПолучателей(ИнтернетПочтовоеСообщение, СопоставленныеКонтакты, ИнтернетПочтовоеСообщение.Получатели,
		Перечисления.ТипыПолучателейЭлектронногоПисьма.Кому);
		ЗаполнитьКонтактыОбработатьПолучателей(ИнтернетПочтовоеСообщение, СопоставленныеКонтакты, ИнтернетПочтовоеСообщение.Копии,
		Перечисления.ТипыПолучателейЭлектронногоПисьма.Копия);
		ЗаполнитьКонтактыОбработатьПолучателей(ИнтернетПочтовоеСообщение, СопоставленныеКонтакты, ИнтернетПочтовоеСообщение.СлепыеКопии,
		Перечисления.ТипыПолучателейЭлектронногоПисьма.СкрытаяКопия);
	КонецЕсли;
	
	Для Каждого АдресЭП Из ОбщегоНазначенияКлиентСервер.СвернутьМассив(Участники.ВыгрузитьКолонку("КакСвязаться")) Цикл
		ОчиститьДублиУчастников(АдресЭП);
	КонецЦикла;
	
КонецПроцедуры

// Определяем контакты для документа "Событие"
//
// Параметры:
//  ИнтернетПочтовоеСообщение		 - ИнтернетПочтовоеСообщение, Структура - данные, по которым будет заполняться участники,
//  СопоставленныеКонтакты	 - Соответствие из КлючИЗначение - соответствие адресов электронной почты и ссылок на участников события.
//  Получатели	 - ИнтернетПочтовыеАдреса - коллекция почтовых адресов из ИнтернетПочтовоеСообщение.
//  ТипПолучателяЭлектронногоПисьма	 - ПеречислениеСсылка.ТипыПолучателейЭлектронногоПисьма - тип получателя электронного письма.
//  АдресЭПУчетнойЗаписи - Строка - адрес электронной почты учетной записи.
//
Процедура ЗаполнитьКонтактыОбработатьПолучателей(ИнтернетПочтовоеСообщение, СопоставленныеКонтакты, Получатели, ТипПолучателяЭлектронногоПисьма, АдресЭПУчетнойЗаписи = "")
	
	Если СопоставленныеКонтакты = Неопределено Тогда
		СопоставленныеКонтакты = СопоставленныеКонтактыИзПочтовогоСообщения(ИнтернетПочтовоеСообщение);
	КонецЕсли;
	
	Для Каждого Получатель Из Получатели Цикл
		ЗаполнитьКонтактыОбработатьПолучателя(СопоставленныеКонтакты, Получатель, ТипПолучателяЭлектронногоПисьма, АдресЭПУчетнойЗаписи);
	КонецЦикла;
	
КонецПроцедуры

// Возвращает соответствие адресов электронной почты для всех контактов,
// встречающихся в переданном сообщении.
//
// Параметры:
//  ИнтернетПочтовоеСообщение - ИнтернетПочтовоеСообщение - почтовое сообщение,
//                      контакты из которого нужно сопоставить.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение - Соответствие адресов электронной почты и ссылок
//  на контакты (контрагенты или контактные лица).
//
Функция СопоставленныеКонтактыИзПочтовогоСообщения(ИнтернетПочтовоеСообщение)
	
	АдресаЭП = Новый Массив;
	
	НормализованныйАдресОтправителя = НормализованныйАдрес(ИнтернетПочтовоеСообщение.Отправитель.Адрес);
	
	Если ЗначениеЗаполнено(НормализованныйАдресОтправителя)
		И АдресаЭП.Найти(НормализованныйАдресОтправителя) = Неопределено Тогда
		АдресаЭП.Добавить(НормализованныйАдресОтправителя);
	КонецЕсли;

	Для Каждого ТекПолучатель Из ИнтернетПочтовоеСообщение.Получатели Цикл
		НормализованныйАдресПолучателя = НормализованныйАдрес(ТекПолучатель.Адрес);
		Если Не ЗначениеЗаполнено(НормализованныйАдресПолучателя) Тогда
			Продолжить;
		КонецЕсли;
		Если АдресаЭП.Найти(НормализованныйАдресПолучателя) = Неопределено Тогда
			АдресаЭП.Добавить(НормализованныйАдресПолучателя);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЭлектроннаяПочтаУНФ.СопоставленныеКонтактыПоАдресамЭП(АдресаЭП);
	
КонецФункции

Процедура ДобавитьУчастникаЭлектронногоПисьма(Контакт, КакСвязаться, ТипПолучателяЭлектронногоПисьма = Неопределено)
	
	Если КонтактУжеЯвляетсяУчастником(Контакт, ТипПолучателяЭлектронногоПисьма) Тогда
		Возврат;
	КонецЕсли;
	
	НовыйУчастник = Участники.Добавить();
	Если ЗначениеЗаполнено(ТипПолучателяЭлектронногоПисьма) Тогда
		НовыйУчастник.ТипПолучателяЭлектронногоПисьма = ТипПолучателяЭлектронногоПисьма;
	Иначе
		НовыйУчастник.ТипПолучателяЭлектронногоПисьма = ПредопределенноеЗначение("Перечисление.ТипыПолучателейЭлектронногоПисьма.Кому");
	КонецЕсли;
	НовыйУчастник.Контакт = ?(ЗначениеЗаполнено(Контакт), Контакт, КакСвязаться);
	НовыйУчастник.КакСвязаться = КакСвязаться;
	
КонецПроцедуры

Процедура ЗаполнитьСодержимоеПоИнтернетПочтовоеСообщение(ИнтернетПочтовоеСообщение, ВариантЗагрузки)
	
	ДанныеСобытия = Документы.Событие.НовыеДанныеСобытия();
	
	Документы.Событие.ЗаполнитьТекстыИзПочтовогоСообщения(ДанныеСобытия, ИнтернетПочтовоеСообщение);
	
	Если ВариантЗагрузки = Перечисления.ВариантыЗагрузкиПисем.ТекстыИВложения Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеСобытия);
		Документы.Событие.ЗаполнитьВложенияИзПочтовогоСообщения(ДополнительныеСвойства, ИнтернетПочтовоеСообщение);
	КонецЕсли;
	
	ТемаИСодержание = Документы.Событие.ТемаИСодержание(ДанныеСобытия.Тема, ДанныеСобытия.Содержание, ДанныеСобытия.СодержаниеHTML);
	ДополнительныеСвойства.Вставить("ТемаИСодержание", ТемаИСодержание);
	
КонецПроцедуры

Процедура ЗаполнитьДокументыОснованияПоИнтернетПочтовоеСообщение(ИдентификаторОснования, ИдентификаторыСообщений)
	
	ИдентификаторОснования = ЭлектроннаяПочтаУНФКлиентСервер.СократитьУгловыеСкобки(ИдентификаторОснования);
	
	Если ЗначениеЗаполнено(ИдентификаторОснования)
		И ИдентификаторыСообщений.Найти(ИдентификаторОснования) = Неопределено Тогда
		ИдентификаторыСообщений.Добавить(ИдентификаторОснования);
	КонецЕсли;
	
	СвязанныеСобытия = РегистрыСведений.ИдентификаторыСообщений.СобытияПоИдентификаторамСообщений(
	УчетнаяЗапись,
	ИдентификаторыСообщений);
	
	Для Каждого КлючИЗначение Из СвязанныеСобытия Цикл
		
		Если ДокументыОснования.Найти(КлючИЗначение.Ключ, "ДокументОснование") <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрокаДокументыОснования = ДокументыОснования.Добавить();
		НоваяСтрокаДокументыОснования.ДокументОснование = КлючИЗначение.Значение;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ИдентификаторОснования)
		И Не ЗначениеЗаполнено(ДокументОснование) Тогда
		Если СвязанныеСобытия[ИдентификаторОснования] = Неопределено Тогда
			ДополнительныеСвойства.Вставить("ИдентификаторОснования", ИдентификаторОснования);
		Иначе
			ДокументОснование = СвязанныеСобытия[ИдентификаторОснования];
			ЗаполнитьДокументыОснованияИзСвязанногоСобытия();
		КонецЕсли;
	КонецЕсли;
	
	ОпределитьНесопоставленныеИдентификаторыСообщений(ИдентификаторыСообщений, СвязанныеСобытия);
	
	СвязанныеРассылки = РегистрыСведений.ИдентификаторыРассылок.МассовыеРассылкиПоИдентификаторамСообщений(
	УчетнаяЗапись,
	ИдентификаторыСообщений);
	
	Для Каждого КлючИЗначение Из СвязанныеРассылки Цикл
		
		Если ДокументыОснования.Найти(КлючИЗначение.Ключ, "ДокументОснование") <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрокаДокументыОснования = ДокументыОснования.Добавить();
		НоваяСтрокаДокументыОснования.ДокументОснование = КлючИЗначение.Значение;
		
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ДокументОснование) И ДокументыОснования.Количество() Тогда
		ДокументОснование = ДокументыОснования[0].ДокументОснование;
	КонецЕсли;
	
КонецПроцедуры

Функция НормализованныйАдрес(АдресЭП)
	
	Возврат НРег(ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыXML(АдресЭП, ""));
	
КонецФункции

// Дата отправления, приведенная к дате получателя. Смещение рассчитано на момент
// отправления сообщения.
Функция ЛокальнаяДатаОтправления(Сообщение)
	
	// Дата отправления сообщения, приведенная к UTC.
	ДатаОтправленияUTC = Сообщение.ДатаОтправления - Сообщение.СмещениеДатыОтправления;
	
	// Смещение времени получателя относительно UTC на дату отправки письма с учетом
	// смещения летнего времени.
	СмещениеПолучателя = СмещениеСтандартногоВремени(ЧасовойПоясСеанса(), ДатаОтправленияUTC)
	+ СмещениеЛетнегоВремени(ЧасовойПоясСеанса(), ДатаОтправленияUTC);
	
	Возврат Сообщение.ДатаОтправления + (СмещениеПолучателя - Сообщение.СмещениеДатыОтправления);
	
КонецФункции

#КонецОбласти

Процедура СохранитьДокументыОснования(Основание)
	
	ДокументыОснования.Очистить();
	
	Если ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
		СтрокаДокументыОснования = ДокументыОснования.Добавить();
		СтрокаДокументыОснования.ДокументОснование = Основание;
	КонецЕсли;
	
	ДокументОснование = Основание;
	
КонецПроцедуры

Функция КонтрагентВШапке()
	
	Возврат ТипСобытия = Перечисления.ТипыСобытий.ТелефонныйЗвонок
		ИЛИ ТипСобытия = Перечисления.ТипыСобытий.ЛичнаяВстреча
		ИЛИ ТипСобытия = Перечисления.ТипыСобытий.Запись
		ИЛИ ТипСобытия = Перечисления.ТипыСобытий.Прочее;
	
КонецФункции

Функция ЕстьПодчиненныеЗаказНаряды()
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Событие", Ссылка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказПокупателя.Ссылка КАК Ссылка,
	|	ЗаказПокупателя.ПометкаУдаления КАК ПометкаУдаления
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|ГДЕ
	|	ЗаказПокупателя.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд)
	|	И ЗаказПокупателя.Событие = &Событие
	|	И ЗаказПокупателя.Проведен";
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

Процедура ОтследитьИсточникПривлечения()
	
	Если ЗначениеЗаполнено(ИсточникПривлечения) Тогда
		Возврат;
	КонецЕсли;
	
	НомерОрганизации = "";
	ДополнительныеСвойства.Свойство("НомерОрганизации", НомерОрганизации);
	
	Если НЕ ЗначениеЗаполнено(НомерОрганизации) Тогда
		Возврат;
	КонецЕсли;
	
	ИсточникПривлечения = РегистрыСведений.ОтслеживаниеИсточниковПривлечения.ПолучитьИсточникПривлеченияПоКИ(НомерОрганизации, Истина);
	
	НомерОрганизации = "";
	Если ДополнительныеСвойства.Свойство("НомерОрганизации", НомерОрганизации) И НЕ ЗначениеЗаполнено(ИсточникПривлечения) Тогда
		ИсточникПривлечения = РегистрыСведений.ОтслеживаниеИсточниковПривлечения.ПолучитьИсточникПривлеченияПоКИ(НомерОрганизации, Истина);
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтоЗапись()
	
	Возврат ТипСобытия = Перечисления.ТипыСобытий.Запись;
	
КонецФункции

Процедура ЗаполнитьВремяСобытия()
	
	ТаблицаДвиженийРесурсы = Неопределено;
	ДополнительныеСвойства.Свойство("ТаблицаДвиженийРесурсы", ТаблицаДвиженийРесурсы);
	
	Если ЭтоЗапись() И ТаблицаДвиженийРесурсы <> Неопределено Тогда
		СтруктураИнтервалов = ПланированиеРесурсовУНФ.МаксимальныеГраницыИнтервала(ТаблицаДвиженийРесурсы, "Старт", "Финиш");
		Если СтруктураИнтервалов <> Неопределено Тогда
			НачалоСобытия = СтруктураИнтервалов.НачалоИнтервала;
			ОкончаниеСобытия = СтруктураИнтервалов.ОкончаниеИнтервала;
		Иначе
			НачалоСобытия = Неопределено;
			ОкончаниеСобытия = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗапланироватьРесурсыПредприятия(Отказ)
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЭтоЗапись() Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаДвиженийРесурсы = Неопределено;
	
	Если НЕ ПометкаУдаления
		И Состояние <> Справочники.СостоянияСобытий.НайтиПоНаименованию("Отменено")
		И НЕ ЕстьПодчиненныеЗаказНаряды() Тогда
		ДополнительныеСвойства.Свойство("ТаблицаДвиженийРесурсы", ТаблицаДвиженийРесурсы);
	КонецЕсли;
	
	ПланированиеРесурсовУНФ.СформироватьЗаписиКалендаряСотрудникаПоРесурсам(Ссылка, ТаблицаДвиженийРесурсы, Отказ);
	ПланированиеРесурсовУНФ.ЗаписатьРасписаниеЗагрузкиРесурсов(Ссылка, ТаблицаДвиженийРесурсы, Отказ);
	
КонецПроцедуры

Функция ИсключающиесяСвойстваПриЗаполнении(ДанныеЗаполнения)
	
	Если ТипЗнч(ДанныеЗаполнения) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Результат = "";
	
	Если ДанныеЗаполнения.Свойство("Автор")
		И ТипЗнч(ДанныеЗаполнения.Автор) = Тип("СправочникСсылка.Пользователи") Тогда
		Результат = СтрШаблон("%1,Автор", Результат);
	КонецЕсли;
	
	Возврат Сред(Результат, 2);
	
КонецФункции

