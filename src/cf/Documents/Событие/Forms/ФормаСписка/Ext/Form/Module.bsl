&НаКлиенте
Функция НужноЗаполнитьПредпросмотр(ПринудительноОбновитьСодержание = Ложь)
	
	Если Не НужноЗаполнитьПредпросмотрНаОснованииРеквизитов(ПринудительноОбновитьСодержание) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат НужноЗаполнитьПредпросмотрНаОснованииПисьма();
	
КонецФункции

&НаКлиенте
Функция НужноЗаполнитьПредпросмотрНаОснованииПисьма()
	
	ЭтотОбъект.Предпросмотр_СсылкаНаСобытие = Элементы.Список.ТекущаяСтрока;
	Элементы.НебезопасноеСодержимое.Видимость = Ложь;
	
	Если Элементы.Список.ТекущиеДанные = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Элементы.Список.ТекущиеДанные.ЗагрузитьПриОткрытии Тогда
		
		ЭлектроннаяПочтаУНФКлиент.ДобавитьКомандуЗагрузкиПисьма(ТекстПисьма);
		Элементы.СодержаниеПисьма.ТекущаяСтраница = Элементы.ТекстHTML;
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
Функция НужноЗаполнитьПредпросмотрНаОснованииРеквизитов(ПринудительноОбновитьСодержание = Ложь)
	
	#Если МобильныйКлиент Тогда
		Возврат Ложь;
	#КонецЕсли
	
	Возврат Элементы.Список.ТекущаяСтрока <> Неопределено
	И Элементы.Список.ТекущиеДанные <> Неопределено
	И Не ТипЗнч(Элементы.Список.ТекущаяСтрока) = Тип("СтрокаГруппировкиДинамическогоСписка")
	И Элементы.СодержаниеПисьма.Видимость
	И (Элементы.Список.ТекущаяСтрока <> ЭтотОбъект.Предпросмотр_СсылкаНаСобытие Или ПринудительноОбновитьСодержание);
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьНеобходимостьПоказатьПредпросмотрЕслиНужно(Значение)
	
	#Если МобильныйКлиент Тогда
		Возврат;
	#КонецЕсли
	
	ЭтотОбъект.Предпросмотр_НужноЗаполнитьПредпросмотрПриАктивизацииСтрокиТаблицы = Значение;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПредпросмотрНаОсновеПисьма()
	
	//@skip-check module-self-reference
	РезультатЗаполнения = ЭлектроннаяПочтаУНФ.ЗаполнитьПредпросмотр(
	ЭтотОбъект.Предпросмотр_СсылкаНаСобытие,
	УникальныйИдентификатор,
	ТекстПисьма);
	
	ЭтотОбъект.Предпросмотр_ИсточникПривлечения = РезультатЗаполнения.ИсточникПривлечения;
	
	Элементы.НебезопасноеСодержимое.Видимость = РезультатЗаполнения.НежелательныеHTTPОчищены;
	Элементы.СодержаниеПисьма.ТекущаяСтраница = Элементы.ТекстHTML;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСообщениеСПочтовогоСервера()
	
	Элементы.СодержаниеПисьма.ТекущаяСтраница = Элементы.Загрузка;
	
	УстановитьОтображениеЭлементовПриЗагрузкеПисьма(Ложь);
	
	//@skip-check module-self-reference
	Задание = ЗаданиеЗагрузитьСообщениеСПочтовогоСервера(
	ЭтотОбъект.Предпросмотр_СсылкаНаСобытие,
	УникальныйИдентификатор,
	ЭтотОбъект.Предпросмотр_ИдентификаторЗаданияЗагрузки);
	
	ЭтотОбъект.Предпросмотр_ИдентификаторЗаданияЗагрузки = Задание.ИдентификаторЗадания;
	
	ДополнительныеПараметры = Новый Структура;
	//@skip-check module-self-reference
	ДополнительныеПараметры.Вставить("ЗагружаемоеСобытие", ЭтотОбъект.Предпросмотр_СсылкаНаСобытие);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОбработчикЗагрузкиСообщения", ЭтотОбъект, ДополнительныеПараметры);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(Задание, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаданиеЗагрузитьСообщениеСПочтовогоСервера(
	Знач СсылкаНаСобытие,
	Знач УникальныйИдентификатор,
	Знач ИдентификаторПредыдущегоЗадания)
	
	Возврат ЭлектроннаяПочтаУНФ.ЗагрузитьСообщениеСПочтовогоСервера(
		СсылкаНаСобытие, УникальныйИдентификатор, , , ИдентификаторПредыдущегоЗадания);
	
КонецФункции

&НаКлиенте
Процедура ОбработчикЗагрузкиСообщения(Результат, Параметры) Экспорт
	
	УстановитьОтображениеЭлементовПриЗагрузкеПисьма(Истина);
	
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Статус = Неопределено;
	Если Не Результат.Свойство("Статус", Статус) Тогда
		Возврат;
	КонецЕсли;
	
	ЗагружаемоеСобытие = Неопределено;
	//@skip-check unknown-form-parameter-access
	Параметры.Свойство("ЗагружаемоеСобытие", ЗагружаемоеСобытие);
	Если ЗагружаемоеСобытие = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИзменятьТекстПисьма = (ЗагружаемоеСобытие = ЭтотОбъект.Предпросмотр_СсылкаНаСобытие);
	
	Если Статус = "Ошибка" Тогда
		
		Если ИзменятьТекстПисьма Тогда
			
			Элементы.СодержаниеПисьма.ТекущаяСтраница = Элементы.ПроизошлаОшибкаПриЗагрузкеПисьма;
			ОписаниеОшибкиЗагрузкиПисьма = Результат.ПодробноеПредставлениеОшибки;
			
		КонецЕсли;
		Возврат;
		
	КонецЕсли;
	
	Если Статус = "Выполнено" Тогда
		
		ОбработатьЗагруженноеСПочтовогоСервераСообщение(
			ЗагружаемоеСобытие, Результат.АдресРезультата, ИзменятьТекстПисьма);
		
		ОповеститьОбИзменении(ЗагружаемоеСобытие);
		
		Если ИзменятьТекстПисьма Тогда
			
			ДокументHTML = Элементы.ТекстПисьма.Документ;
			Если ДокументHTML <> Неопределено Тогда
				ДокументHTML.documentElement.innerHTML = ТекстПисьма;
				ГипертекстКлиент.ПрименитьНастройкиОтображения(ДокументHTML);
			
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьЗагруженноеСПочтовогоСервераСообщение(
	Знач ЗагружаемоеСобытие,
	Знач АдресРезультата,
	Знач ИзменятьТекстПисьма)
	
	ЭлектроннаяПочтаУНФ.ОбработатьЗагруженноеЧерезПредпросмотрСообщение(
	АдресРезультата,
	ЗагружаемоеСобытие,
	УникальныйИдентификатор,
	ТекстПисьма,
	ИзменятьТекстПисьма);
	
	Если ИзменятьТекстПисьма Тогда
		ЗаполнитьПредпросмотрНаОсновеПисьма();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтображениеЭлементовПриЗагрузкеПисьма(ПисьмоЗагружено)
	
	Элементы.Ответить.Доступность = ПисьмоЗагружено;
	Элементы.ОтветитьВсем.Доступность = ПисьмоЗагружено;
	Элементы.Переслать.Доступность = ПисьмоЗагружено;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНажатияДляЗагрузкиСообщения(Элемент)
	
	Если Элемент.nodeName = "#document" Или Элемент.nodeName = Неопределено
		Или Не Элемент.classList.contains("preview-download") Тогда
		Возврат;
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ЗагрузитьСообщениеСПочтовогоСервера", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область АктивизацияСтрокиСписка

&НаКлиенте
Процедура СписокПриАктивизацииСтрокиОбработчик()
	
	Если Элементы.Список.ТекущиеДанные = Неопределено
		Или ТипЗнч(Элементы.Список.ТекущаяСтрока) = Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
		Возврат;
	КонецЕсли;
	
	Ссылка = Элементы.Список.ТекущиеДанные.Ссылка;
	
	#Если МобильныйКлиент Тогда
		
		НужноЗаполнитьПредпросмотрНаОснованииПисьма = Ложь;
		
	#Иначе
		
		Если ЭтотОбъект.Предпросмотр_НужноЗаполнитьПредпросмотрПриАктивизацииСтрокиТаблицы Тогда
			НужноЗаполнитьПредпросмотрНаОснованииПисьма = НужноЗаполнитьПредпросмотрНаОснованииПисьма();
		Иначе
			НужноЗаполнитьПредпросмотрНаОснованииПисьма = Ложь;
		КонецЕсли;
		
	#КонецЕсли
	
	//@skip-check module-self-reference
	СписокПриАктивизацииСтрокиОбработчикНаСервере(
	Ссылка,
	НужноЗаполнитьПредпросмотрНаОснованииПисьма,
	ЭтотОбъект.КИ_НужноИзменитьДанныеПриАктивизацииСтрокиТаблицы);
	
КонецПроцедуры

&НаСервере
Процедура СписокПриАктивизацииСтрокиОбработчикНаСервере(
	Знач Ссылка, Знач НужноЗаполнитьПредпросмотрНаОснованииПисьма, Знач НужноИзменитьКИ)
	
	Если НужноЗаполнитьПредпросмотрНаОснованииПисьма Тогда
		ЗаполнитьПредпросмотрНаОсновеПисьма();
	КонецЕсли;
	
	Если НужноИзменитьКИ Тогда
		ОбновитьПанельКонтактнойИнформацииСервер();
	КонецЕсли;
	
	ОбновитьИнтерфейсКомандПоЗаявкам(Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область ИзменениеСостояний

&НаСервере
Процедура ЗаполнитьКомандыИзмененияСостояния()
	
	СостоянияДокументов.ЗаполнитьКомандыИзмененияСостояний(ЭтотОбъект, Элементы.СписокКонтекстноеМенюУстановитьСостояние);
	
КонецПроцедуры

#КонецОбласти 

#Область УправлениеФормой

&НаСервере
Процедура УправлениеФормойСервер()
	
	РежимОткрытияСписка = "ОбщийСписок";
	ЭтоСписокПисем = Ложь;
	
	Если ЗначениеЗаполнено(Параметры.ТипСобытия) Тогда
		РежимОткрытияСписка = "СписокСОтборомПоТипу";
		Если Параметры.ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
			ЭтоСписокПисем = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Список.Параметры.УстановитьЗначениеПараметра("ЭтоСписокПисем", ЭтоСписокПисем);
	
	Если РежимОткрытияСписка = "ОбщийСписок" ИЛИ РежимОткрытияСписка = "СписокСОтборомПоТипу" Тогда
		Элементы.ЛеваяПанель.Видимость = Ложь;
		Элементы.ГруппаКоманднаяПанель.Видимость = Истина;
		Элементы.ГруппаКоманднаяПанельЭлектронноеПисьмо.Видимость = Ложь;
		Элементы.ВходящееИсходящее.Видимость = Истина;
		Элементы.ГруппаКоманднаяПанель.Видимость = Истина;
		Элементы.ФормаУчетныеЗаписи.Видимость = Ложь;
		Элементы.Список.ПутьКДаннымКартинкиСтроки = "Список.ИндексПиктограммы";
		Элементы.ВажностьЭлектронноеПисьмо.Видимость = Ложь;
		Элементы.СписокВажность.Видимость = Истина;
		Элементы.Непрочитанное.Видимость = Ложь;
		Элементы.СписокКонтекстноеМенюГруппаЭлектронноеПисьмо.Видимость = Ложь;
		Элементы.СписокКонтекстноеМенюГруппаСтандартные.Видимость = Истина;
		Элементы.ЕстьФайлыСписокПисем.Видимость = Ложь;
	КонецЕсли;
	
	Если РежимОткрытияСписка = "СписокСОтборомПоТипу" Тогда
		Элементы.ГруппаКоманднаяПанель.Видимость = НЕ ЭтоСписокПисем;
		Элементы.ГруппаКоманднаяПанельЭлектронноеПисьмо.Видимость = ЭтоСписокПисем;
		Элементы.СписокКонтекстноеМенюГруппаСтандартные.Видимость = НЕ ЭтоСписокПисем;
		Элементы.СписокКонтекстноеМенюГруппаЭлектронноеПисьмо.Видимость = ЭтоСписокПисем;
		Элементы.ВходящееИсходящее.Видимость = Параметры.ТипСобытия <> Перечисления.ТипыСобытий.СообщениеSMS;
		АвтоЗаголовок = Ложь;
		Элементы.ОтборТипСобытия.Видимость = Ложь;
		Элементы.СписокГруппаСоздать.Видимость = Ложь;
		Элементы.ФормаГруппаСоздать.Видимость = Истина;
		ОтборТипСобытия = Параметры.ТипСобытия;
		Элементы.ГруппаПочтоваяСлужба.Видимость = ЭтоСписокПисем;
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "ТипСобытия", Параметры.ТипСобытия);
		Элементы.СписокОкончаниеСобытия.Видимость = НЕ ЭтоСписокПисем;
		Если Элементы.Найти("ПодменюОтчеты") <> Неопределено И ЭтоСписокПисем Тогда
			Элементы.Переместить(Элементы.ПодменюОтчеты, Элементы.ФормаГруппаСервисЕще);
		КонецЕсли;
		
		Элементы.Непрочитанное.Видимость = ЭтоСписокПисем;
		
		Элементы.Проекты.Видимость = Не (Параметры.ТипСобытия = Перечисления.ТипыСобытий.СообщениеSMS
			ИЛИ Параметры.ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо);
		
		Если Параметры.ТипСобытия = Перечисления.ТипыСобытий.ТелефонныйЗвонок Тогда
			Заголовок = НСтр("ru='События: телефонные звонки'");
		ИначеЕсли Параметры.ТипСобытия = Перечисления.ТипыСобытий.ЭлектронноеПисьмо Тогда
			Заголовок = НСтр("ru='События: электронные письма'");
		ИначеЕсли Параметры.ТипСобытия = Перечисления.ТипыСобытий.СообщениеSMS Тогда
			Заголовок = НСтр("ru='События: сообщения SMS'");
		ИначеЕсли Параметры.ТипСобытия = Перечисления.ТипыСобытий.ЛичнаяВстреча Тогда
			Заголовок = НСтр("ru='События: личные встречи'");
		ИначеЕсли Параметры.ТипСобытия = Перечисления.ТипыСобытий.Прочее Тогда
			Заголовок = НСтр("ru='События: прочие'");
		ИначеЕсли Параметры.ТипСобытия = Перечисления.ТипыСобытий.Запись Тогда
			Заголовок = НСтр("ru='События: запись'");
			Элементы.СписокТема.Видимость = Ложь;
			Элементы.ОтборВходящееИсходящее.Видимость = Ложь;
			Элементы.ОтборПроект.Видимость = Ложь;
		КонецЕсли;
		
		Элементы.ВажностьЭлектронноеПисьмо.Видимость = ЭтоСписокПисем;
		Элементы.СписокВажность.Видимость = НЕ ЭтоСписокПисем;
		Элементы.Список.ПутьКДаннымКартинкиСтроки = "Список.ИндексПиктограммы";
		
	КонецЕсли;
	
	Если ЭтоСписокПисем Тогда
		
		Элементы.ЕстьФайлы.Видимость = Ложь;
		Элементы.ПодключитьУчетнуюЗапись.Видимость = ПравоДоступа("Добавление", 
			Метаданные.Справочники.УчетныеЗаписиЭлектроннойПочты);
		Элементы.Список.ПутьКДаннымКартинкиСтроки = "Список.КартинкаПисем";
		Элементы.СписокНачалоСобытия.Заголовок = НСтр("ru = 'Дата'");
		УстановитьНастройкиСпискаПисем();
		
	Иначе
		
		ОбновитьПоложениеПредпросмотра();
		
	КонецЕсли;
	
	НастроитьГруппуПочтоваяСлужба();
	Элементы.ПроверитьПочтуОбщийСписок.Видимость = ПочтовыеСлужбыПодключены;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсКомандПоЗаявкам(Событие)
	
	ЗаголовокКомандыСозданияЗаказаПокупателя = НСтр("ru = 'Заказ покупателя'");
	ЗаголовокКомандыСозданияЗаказНаряда = НСтр("ru = 'Заказ-наряд'");
	
	ПервыйКонтактПисьма = Документы.Событие.ПервыйКонтакт(Событие);
	ПервыйКонтактЭтоЛид = (ТипЗнч(ПервыйКонтактПисьма) = Тип("СправочникСсылка.Лиды"));
	
	Если ПервыйКонтактЭтоЛид Тогда
		
		ИспользованиеЗаявок = РаботаСЗаявками.ИспользованиеЗаявокПоВидуОперации();
		
		Если ИспользованиеЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу] Тогда
			ЗаголовокКомандыСозданияЗаказаПокупателя = НСтр("ru = 'Заказ покупателя (заявка)'");
		КонецЕсли;
		Если ИспользованиеЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд] Тогда
			ЗаголовокКомандыСозданияЗаказНаряда = НСтр("ru = 'Заказ-наряд (заявка)'");
		КонецЕсли;
		
	КонецЕсли;
	
	КомандаСоздания = Элементы.Найти("ФормаДокументЗаказПокупателяСоздатьНаОсновании");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказаПокупателя;
	КонецЕсли;
	КомандаСоздания = Элементы.Найти("ФормаДокументЗаказПокупателяСоздатьНаОсновании1");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказаПокупателя;
	КонецЕсли;
	КомандаСоздания = Элементы.Найти("ФормаДокументСобытиеКомандаЗаказНарядСоздатьНаОсновании");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказНаряда;
	КонецЕсли;
	КомандаСоздания = Элементы.Найти("ФормаДокументСобытиеКомандаЗаказНарядСоздатьНаОсновании1");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказНаряда;
	КонецЕсли;
	
КонецПроцедуры

