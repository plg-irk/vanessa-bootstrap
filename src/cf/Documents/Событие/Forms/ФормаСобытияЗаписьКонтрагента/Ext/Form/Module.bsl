#Область ОбновлениеИнтерфейса

&НаСервере
Процедура ОбновитьИнтерфейсКомандПоЗаявкам()
	
	ЗаголовокКомандыСозданияЗаказаПокупателя = НСтр("ru = 'Заказ покупателя'");
	ЗаголовокКомандыСозданияЗаказНаряда = НСтр("ru = 'Заказ-наряд'");
	
	ПервыйКонтактЭтоЛид = (ТипЗнч(Контрагент) = Тип("СправочникСсылка.Лиды"));
	Если ПервыйКонтактЭтоЛид Тогда
		
		ИспользованиеЗаявок = РаботаСЗаявками.ИспользованиеЗаявокПоВидуОперации();
		
		Если ИспользованиеЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу] Тогда
			ЗаголовокКомандыСозданияЗаказаПокупателя = НСтр("ru = 'Заказ покупателя (заявка)'");
		КонецЕсли;
		Если ИспользованиеЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд] Тогда
			ЗаголовокКомандыСозданияЗаказНаряда = НСтр("ru = 'Заказ-наряд (заявка)'");
		КонецЕсли;
		
	КонецЕсли;
	
	КомандаСоздания = Элементы.Найти("ФормаДокументЗаказПокупателяСоздатьНаОсновании");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказаПокупателя;
	КонецЕсли;
	КомандаСоздания = Элементы.Найти("ФормаДокументЗаказПокупателяСоздатьНаОсновании1");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказаПокупателя;
	КонецЕсли;
	КомандаСоздания = Элементы.Найти("ФормаДокументСобытиеКомандаЗаказНарядСоздатьНаОсновании");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказНаряда;
	КонецЕсли;
	КомандаСоздания = Элементы.Найти("ФормаДокументСобытиеКомандаЗаказНарядСоздатьНаОсновании1");
	Если КомандаСоздания <> Неопределено Тогда
		КомандаСоздания.Заголовок = ЗаголовокКомандыСозданияЗаказНаряда;
	КонецЕсли;
	
КонецПроцедуры

