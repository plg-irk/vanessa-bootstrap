	|    НЕ ВычетПоПриобретеннымЦенностям.НДСРаспределенный
	|    И НДСЗаписиКнигиПродаж.СчетФактура ССЫЛКА Документ.СчетФактура
	|    И ПодтверждениеНулевойСтавкиНДССостав.Событие = ЗНАЧЕНИЕ(Перечисление.СобытияПоНДСПродажи.НеПодтвержденаСтавка0)
	|    И ПодтверждениеНулевойСтавкиНДССостав.Ссылка.Проведен
	|    И НЕ НДСЗаписиКнигиПродаж.НесырьевыеТовары
	|    И (НДСЗаписиКнигиПродаж.СуммаБезНДС > 0
	|    ИЛИ НДСЗаписиКнигиПродаж.НДС > 0)
	|    И НДСЗаписиКнигиПродаж.Период <= &КонецПериода
	|    И &КонецПериода <= ДОБАВИТЬКДАТЕ(КОНЕЦПЕРИОДА(ВычетПоПриобретеннымЦенностям.СчетФактураДата, ДЕНЬ), ГОД, 3)
	|    И НДСЗаписиКнигиПродаж.КодОперации0 В (&ТоварыКодыОпераций0)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|    ДляРаспредления.НДСРаспределенный КАК НДСРаспределенный,
	|    ДляРаспредления.ДокументОтгрузки КАК ДокументОтгрузки,
	|    ДляРаспредления.СчетФактура КАК СчетФактура,
	|    ДляРаспредления.СуммаБезНДС КАК СуммаБезНДС,
	|    ДляРаспредления.НДС КАК НДС,
	|    ДляРаспредления.КодОперации0 КАК КодОперации0,
	|    ДляРаспредления.Коэффициент КАК Коэффициент,
	|    ДляРаспредления.СчетФактураДата КАК СчетФактураДата,
	|    ДляРаспредления.ДатаПолученияСчетаФактуры КАК ДатаПолученияСчетаФактуры,
	|    ДляРаспредления.ВидЦенности КАК ВидЦенности,
	|    ДляРаспредления.СтавкаНДС КАК СтавкаНДС,
	|    ДляРаспредления.СчетУчетаНДС КАК СчетУчетаНДС,
	|    ДляРаспредления.Состояние КАК Состояние,
	|    ДляРаспредления.КодВидаОперации КАК КодВидаОперации,
	|    ДляРаспредления.КорректируемыйПериод КАК КорректируемыйПериод,
	|    ДляРаспредления.Поставщик КАК Поставщик,
	|    ДляРаспредления.ЗаписьДополнительногоЛиста КАК ЗаписьДополнительногоЛиста,
	|    ДляРаспредления.ИсправленныйСчетФактура КАК ИсправленныйСчетФактура,
	|    ДляРаспредления.ПредъявленВычетВПоследующихПериодах КАК ПредъявленВычетВПоследующихПериодах,
	|    ДляРаспредления.ДокументОплаты КАК ДокументОплаты,
	|    ДляРаспредления.ДатаОплаты КАК ДатаОплаты,
	|    ДляРаспредления.НомерДокументаОплаты КАК НомерДокументаОплаты,
	|    ДляРаспредления.ДатаДокументаОплаты КАК ДатаДокументаОплаты
	|ИЗ
	|    ДляРаспредления КАК ДляРаспредления
	|
	|УПОРЯДОЧИТЬ ПО
	|    НДСРаспределенный,
	|    ДокументОтгрузки,
	|    СчетФактура,
	|    КодОперации0
	|ИТОГИ
	|ПО
	|    НДСРаспределенный,
	|    ДокументОтгрузки,
	|    СчетФактура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ДляРаспредления";

	Запрос.Параметры.Вставить("КонецПериода", Дата);
	
	// Распределение по кодам операций НДС 0% прямых и распределенных вычетов НДС
	РезультатЗапоса = Запрос.Выполнить();

	ВыборкаНДСРаспределенный = РезультатЗапоса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаНДСРаспределенный.Следующий() Цикл

		ВыборкаПоДокументуОтгрузки = ВыборкаНДСРаспределенный.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

		Пока ВыборкаПоДокументуОтгрузки.Следующий() Цикл

			ВыборкаПоДокументуПриобретения = ВыборкаПоДокументуОтгрузки.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

			Пока ВыборкаПоДокументуПриобретения.Следующий() Цикл

				ВыборкаРаспределяемыхСумм = ВыборкаПоДокументуПриобретения.Выбрать();

				НДСДляРаспределения = 0;
				СуммаБезНДСДляРаспределения = 0;
				Коэффициенты.Очистить();

				Пока ВыборкаРаспределяемыхСумм.Следующий() Цикл

					Если НДСДляРаспределения = 0 Тогда
						НДСДляРаспределения = ВыборкаРаспределяемыхСумм.НДС;
					КонецЕсли;

					Если СуммаБезНДСДляРаспределения = 0 Тогда
						СуммаБезНДСДляРаспределения = ВыборкаРаспределяемыхСумм.СуммаБезНДС;
					КонецЕсли;

					Коэффициенты.Добавить(ВыборкаРаспределяемыхСумм.Коэффициент);

				КонецЦикла;

				МассивНДС = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
					НДСДляРаспределения, Коэффициенты);
				МассивСуммаБезНДС = ОбщегоНазначенияКлиентСервер.РаспределитьСуммуПропорциональноКоэффициентам(
					СуммаБезНДСДляРаспределения, Коэффициенты);

				Если МассивНДС <> Неопределено И МассивСуммаБезНДС <> Неопределено Тогда

					ВыборкаРаспределяемыхСумм.Сбросить();
					i = 0;

					Пока ВыборкаРаспределяемыхСумм.Следующий() Цикл
						СтрокаТЗ = ВычетПоПриобретеннымЦенностямКодамОпераций.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаТЗ, ВыборкаРаспределяемыхСумм, , "СуммаБезНДС,НДС");
						СтрокаТЗ.НДС = МассивНДС[i];
						СтрокаТЗ.СуммаБезНДС = МассивСуммаБезНДС[i];
						i = i + 1;
					КонецЦикла;

				КонецЕсли;

			КонецЦикла;

		КонецЦикла;

	КонецЦикла;

	ВычетПоПриобретеннымЦенностямКодамОпераций.Сортировать("ДатаПолученияСчетаФактуры,СчетФактура,ДокументОтгрузки",
		Новый СравнениеЗначений);

	Возврат ВычетПоПриобретеннымЦенностямКодамОпераций;

КонецФункции

#КонецОбласти

#Область АвансыПолученные

Функция ПодготовитьДанныеРазделаВычетНДССПолученныхАвансов(СтруктураПараметров) Экспорт

	НДСсАвансов = Новый ТаблицаЗначений;
	Для Каждого КолонкаТабличнойЧасти Из Метаданные.Документы.ФормированиеЗаписейКнигиПокупок.ТабличныеЧасти.НДСсАвансов.Реквизиты Цикл
		НДСсАвансов.Колонки.Добавить(КолонкаТабличнойЧасти.Имя, КолонкаТабличнойЧасти.Тип);
	КонецЦикла;
	НДСсАвансов.Колонки.Добавить("СчетФактураВыданныйДата");
	НДСсАвансов.Колонки.Добавить("СчетФактураДата", Новый ОписаниеТипов("Дата", , ,
		Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
    
    
//		Используется для     
//		ВидАгентскогоДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыАгентскихДоговоров.РеализацияТоваров
//		ОбратноеНачислениеНДС.ДополнитьДаннымиОЗачтенныхАвансах(СтруктураПараметров, НДсСАвансов);

	ТаблицаАвансов = ОстаткиНДССАвансовПолученных(СтруктураПараметров);
	Если ТаблицаАвансов.Количество() = 0 Тогда
		Возврат НДСсАвансов;
	КонецЕсли;

	МенеджерВТ_СписокСчетовФактур = Новый МенеджерВременныхТаблиц;
	СоздатьСписокСчетовФактур(ТаблицаАвансов, МенеджерВТ_СписокСчетовФактур);
	ЗачетыАвансов = ПолучитьДанныеОЗачтенныхАвансахПоСпискуСФ_УпрощенныйУчетНДС(СтруктураПараметров,
		МенеджерВТ_СписокСчетовФактур);
	РаспределитьЗачетыАвансаПоСФ_УпрощенныйУчетНДС(СтруктураПараметров, ТаблицаАвансов, НДсСАвансов,
		МенеджерВТ_СписокСчетовФактур, ЗачетыАвансов);

	ОтборВозвратаАвансовПолученных = Новый Структура("ВозвратАвансовПолученных", Истина);
	МенеджерВТ_СписокСчетовФактур = Новый МенеджерВременныхТаблиц;
	СоздатьСписокСчетовФактур(НДсСАвансов, МенеджерВТ_СписокСчетовФактур, ОтборВозвратаАвансовПолученных);
	ПолучитьДанныеОДокументахОплатыВозвратАванса(СтруктураПараметров, НДсСАвансов, МенеджерВТ_СписокСчетовФактур);
	
	ОтборЗачетАвансовПолученных = Новый Структура("ВозвратАвансовПолученных", Ложь);
	МенеджерВТ_СписокСчетовФактур = Новый МенеджерВременныхТаблиц;
	СоздатьСписокСчетовФактур(НДсСАвансов, МенеджерВТ_СписокСчетовФактур, ОтборЗачетАвансовПолученных);
	ПолучитьДанныеОбОтгрузочныхСчетахФактурах(СтруктураПараметров, НДсСАвансов, МенеджерВТ_СписокСчетовФактур);

	НДСсАвансов.Сортировать("СчетФактураДата,СчетФактура", Новый СравнениеЗначений);

	Возврат НДСсАвансов;

КонецФункции

Функция ПолучитьДанныеОЗачтенныхАвансахПоСпискуСФ_УпрощенныйУчетНДС(СтруктураПараметров, МенеджерВТ_СписокСчетовФактур)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ_СписокСчетовФактур;
	Запрос.УстановитьПараметр("Организация", СтруктураПараметров.Организация);
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(СтруктураПараметров.Дата));
	Запрос.УстановитьПараметр("ДатаГраница", Новый Граница(КонецДня(СтруктураПараметров.Дата), ВидГраницы.Включая));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасчетыСПокупателямиОбороты.Организация КАК Организация,
	|	РасчетыСПокупателямиОбороты.Контрагент КАК Покупатель,
	|	РасчетыСПокупателямиОбороты.Договор КАК ДоговорКонтрагента,
	|	РасчетыСПокупателямиОбороты.Регистратор КАК ДокументЗачетаАванса,
	|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход) КАК СуммаАванса,
	|	РасчетыСПокупателямиОбороты.Документ КАК СчетФактура,
	|	НАЧАЛОПЕРИОДА(РасчетыСПокупателямиОбороты.Период, ДЕНЬ) КАК ДатаСобытия,
	|	ВЫБОР
	|		КОГДА ТИП(Документ.РасходСоСчета) = ТИПЗНАЧЕНИЯ(РасчетыСПокупателямиОбороты.Регистратор)
	|		И РасчетыСПокупателямиОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Покупателю)
	|		ИЛИ ТИП(Документ.РасходИзКассы) = ТИПЗНАЧЕНИЯ(РасчетыСПокупателямиОбороты.Регистратор)
	|		И РасчетыСПокупателямиОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходИзКассы.Покупателю)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВозвратАвансовПолученных
	|ПОМЕСТИТЬ ОборотыПоДебету62Предварительная
	|ИЗ
	|	РегистрНакопления.РасчетыСПокупателями.Обороты(, &ДатаГраница, Регистратор, Организация = &Организация
	|	И Документ В
	|		(ВЫБРАТЬ
	|			СписокСчетовФактур.СчетФактура
	|		ИЗ
	|			СписокСчетовФактур КАК СписокСчетовФактур)) КАК РасчетыСПокупателямиОбороты
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСПокупателямиОбороты.Организация,
	|	РасчетыСПокупателямиОбороты.Контрагент,
	|	РасчетыСПокупателямиОбороты.Регистратор,
	|	НАЧАЛОПЕРИОДА(РасчетыСПокупателямиОбороты.Период, ДЕНЬ),
	|	РасчетыСПокупателямиОбороты.Договор,
	|	ВЫБОР
	|		КОГДА ТИП(Документ.РасходСоСчета) = ТИПЗНАЧЕНИЯ(РасчетыСПокупателямиОбороты.Регистратор)
	|		И РасчетыСПокупателямиОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Покупателю)
	|		ИЛИ ТИП(Документ.РасходИзКассы) = ТИПЗНАЧЕНИЯ(РасчетыСПокупателямиОбороты.Регистратор)
	|		И РасчетыСПокупателямиОбороты.Регистратор.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходИзКассы.Покупателю)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	РасчетыСПокупателямиОбороты.Документ
	|ИМЕЮЩИЕ
	|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход) > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОборотыПоДебету62Предварительная.СчетФактура КАК СчетФактура,
	|	ЕСТЬNULL(СчетФактураДокументыОснования.Ссылка.Договор, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК
	|		ДоговорКонтрагента
	|ПОМЕСТИТЬ ДоговорыСчетовФактур
	|ИЗ
	|	ОборотыПоДебету62Предварительная КАК ОборотыПоДебету62Предварительная
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактура.ДокументыОснования КАК СчетФактураДокументыОснования
	|		ПО ОборотыПоДебету62Предварительная.СчетФактура = СчетФактураДокументыОснования.ДокументОснование
	|ГДЕ
	|	(СчетФактураДокументыОснования.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСчетФактура.Аванс)
	|	ИЛИ
	|		СчетФактураДокументыОснования.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСчетФактура.КорректировкаАванса))
	|	И НЕ СчетФактураДокументыОснования.Ссылка.ПометкаУдаления
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СчетФактура,
	|	ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОборотыПоДебету62Предварительная.Организация КАК Организация,
	|	ОборотыПоДебету62Предварительная.Покупатель КАК Покупатель,
	|	ЕСТЬNULL(ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка),
	|		ОборотыПоДебету62Предварительная.ДоговорКонтрагента) КАК ДоговорКонтрагента,
	|	ОборотыПоДебету62Предварительная.СчетФактура КАК СчетФактура,
	|	СУММА(ОборотыПоДебету62Предварительная.СуммаАванса) КАК СуммаАванса,
	|	ОборотыПоДебету62Предварительная.ДатаСобытия КАК ДатаСобытия,
	|	ОборотыПоДебету62Предварительная.ВозвратАвансовПолученных КАК ВозвратАвансовПолученных,
	|	ОборотыПоДебету62Предварительная.ДокументЗачетаАванса
	|ПОМЕСТИТЬ ОборотыПоДебету62
	|ИЗ
	|	ОборотыПоДебету62Предварительная КАК ОборотыПоДебету62Предварительная
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДоговорыСчетовФактур КАК ДоговорыСчетовФактур
	|		ПО ОборотыПоДебету62Предварительная.СчетФактура = ДоговорыСчетовФактур.СчетФактура
	|		И ВЫБОР
	|			КОГДА ДоговорыСчетовФактур.ДоговорКонтрагента <> ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
	|				ТОГДА ОборотыПоДебету62Предварительная.ДоговорКонтрагента = ДоговорыСчетовФактур.ДоговорКонтрагента
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|СГРУППИРОВАТЬ ПО
	|	ОборотыПоДебету62Предварительная.Организация,
	|	ОборотыПоДебету62Предварительная.Покупатель,
	|	ОборотыПоДебету62Предварительная.СчетФактура,
	|	ОборотыПоДебету62Предварительная.ДатаСобытия,
	|	ОборотыПоДебету62Предварительная.ВозвратАвансовПолученных,
	|	ЕСТЬNULL(ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка),
	|		ОборотыПоДебету62Предварительная.ДоговорКонтрагента),
	|	ОборотыПоДебету62Предварительная.ДокументЗачетаАванса
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Покупатель,
	|	СчетФактура,
	|	ДоговорКонтрагента,
	|	ДатаСобытия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НДСПокупки.Организация КАК Организация,
	|	НДСПокупки.Поставщик КАК Покупатель,
	|	НДСПокупки.СчетФактура КАК СчетФактура,
	|	НДСПокупки.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	НАЧАЛОПЕРИОДА(НДСПокупки.ДатаСобытия, ДЕНЬ) КАК ДатаСобытия,
	|	СУММА(НДСПокупки.СуммаБезНДСОборот + НДСПокупки.НДСОборот) КАК СуммаВсего
	|ПОМЕСТИТЬ ОборотыКнигиПокупок
	|ИЗ
	|	РегистрНакопления.НДСЗаписиКнигиПокупок.Обороты(, &КонецПериода,, (Организация, Поставщик, СчетФактура) В
	|		(ВЫБРАТЬ
	|			ОборотыПоДебету62.Организация,
	|			ОборотыПоДебету62.Покупатель,
	|			ОборотыПоДебету62.СчетФактура
	|		ИЗ
	|			ОборотыПоДебету62 КАК ОборотыПоДебету62)) КАК НДСПокупки
	|СГРУППИРОВАТЬ ПО
	|	НДСПокупки.Организация,
	|	НДСПокупки.Поставщик,
	|	НДСПокупки.СчетФактура,
	|	НДСПокупки.ДоговорКонтрагента,
	|	НАЧАЛОПЕРИОДА(НДСПокупки.ДатаСобытия, ДЕНЬ)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Покупатель,
	|	СчетФактура,
	|	ДоговорКонтрагента,
	|	ДатаСобытия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОборотыПоДебету62.Организация КАК Организация,
	|	ОборотыПоДебету62.Покупатель КАК Покупатель,
	|	ОборотыПоДебету62.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ОборотыПоДебету62.СчетФактура КАК СчетФактура,
	|	ОборотыПоДебету62.ДатаСобытия КАК ДатаСобытия,
	|	ОборотыПоДебету62.ВозвратАвансовПолученных КАК ВозвратАвансовПолученных,
	|	ОборотыПоДебету62.СуммаАванса - ЕСТЬNULL(ОборотыКнигиПокупок.СуммаВсего, 0) КАК СуммаАванса,
	|	ОборотыПоДебету62.ДокументЗачетаАванса КАК ДокументОтгрузки
	|ИЗ
	|	ОборотыПоДебету62 КАК ОборотыПоДебету62
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОборотыКнигиПокупок КАК ОборотыКнигиПокупок
	|		ПО ОборотыПоДебету62.Организация = ОборотыКнигиПокупок.Организация
	|		И ОборотыПоДебету62.Покупатель = ОборотыКнигиПокупок.Покупатель
	|		И ОборотыПоДебету62.ДоговорКонтрагента = ОборотыКнигиПокупок.ДоговорКонтрагента
	|		И ОборотыПоДебету62.СчетФактура = ОборотыКнигиПокупок.СчетФактура
	|		И ОборотыПоДебету62.ДатаСобытия = ОборотыКнигиПокупок.ДатаСобытия
	|ГДЕ
	|	ОборотыПоДебету62.СуммаАванса - ЕСТЬNULL(ОборотыКнигиПокупок.СуммаВсего, 0) > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Покупатель,
	|	СчетФактура,
	|	ДоговорКонтрагента,
	|	ДатаСобытия,
	|	ВозвратАвансовПолученных УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ОборотыКнигиПокупок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ОборотыПоДебету62";

	УстановитьПривилегированныйРежим(Истина);

	ВремяНачала = ОценкаПроизводительности.НачатьЗамерВремени();
	КлючеваяОперация = "ИндексТаблицыСубконто.КнигаПокупок_ДанныеОЗачтенныхАвансахПоСпискуСФ";

	ЗачетыАвансов = Запрос.Выполнить().Выбрать();
	
	// Выборка специальным образом упорядочена для использования далее в алгоритме.

	ОценкаПроизводительности.ЗакончитьЗамерВремени(КлючеваяОперация, ВремяНачала);

	Возврат ЗачетыАвансов;

КонецФункции

Процедура РаспределитьЗачетыАвансаПоСФ_УпрощенныйУчетНДС(СтруктураПараметров, ТаблицаАвансов, ТаблицаРезультатов,
	МенеджерВТ_СписокСчетовФактур, ЗачетыАвансов)

	СравнениеПоИдентификатору = Новый СравнениеЗначений;
	// И ТаблицаАвансов, и ЗачетыАвансов были отсортированы ранее в порядке "Покупатель, СчетФактура, ДоговорКонтрагента".

	СтруктураОтбора = СтруктураОтбораСтрок();
	МассивСуммаБезНДС = Новый Массив;
	МассивСуммаНДС = Новый Массив;
	ИндексСтрокиТаблицыАвансов = 0;
	Пока ЗачетыАвансов.Следующий() Цикл

		СуммаБезНДС = 0;
		МассивСуммаБезНДС.Очистить();
		СуммаНДС = 0;
		МассивСуммаНДС.Очистить();

		Если СтруктураОтбора.СчетФактура <> ЗачетыАвансов.СчетФактура Или СтруктураОтбора.ДоговорКонтрагента
			<> ЗачетыАвансов.ДоговорКонтрагента Или СтруктураОтбора.Покупатель <> ЗачетыАвансов.Покупатель Тогда
			// Повторный поиск (например, если разные ДатаСобытия) не выполняем. Используем ранее полученные строки.

			СтруктураОтбора.Покупатель         = ЗачетыАвансов.Покупатель;
			СтруктураОтбора.ДоговорКонтрагента = ЗачетыАвансов.ДоговорКонтрагента;
			СтруктураОтбора.СчетФактура        = ЗачетыАвансов.СчетФактура;
			СтрокиАвансаПоОтбору = УчетНДСПереопределяемый.НайтиСтрокиПоОтбору(
				ТаблицаАвансов, ИндексСтрокиТаблицыАвансов, СтруктураОтбора, "Покупатель", СравнениеПоИдентификатору);
		КонецЕсли;
		Если СтрокиАвансаПоОтбору.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого СтрокаАвансаПоОтбору Из СтрокиАвансаПоОтбору Цикл
			Если СтрокаАвансаПоОтбору.ДатаСобытия > ЗачетыАвансов.ДатаСобытия Тогда
				// Не учитываем зачет аванса, произведенный до выписки счета-фактуры
				Продолжить;
			КонецЕсли;

			МассивСуммаБезНДС.Добавить(СтрокаАвансаПоОтбору.СуммаБезНДС);
			МассивСуммаНДС.Добавить(СтрокаАвансаПоОтбору.НДС);

			СуммаБезНДС = СуммаБезНДС + СтрокаАвансаПоОтбору.СуммаБезНДС;
			СуммаНДС = СуммаНДС + СтрокаАвансаПоОтбору.НДС;
		КонецЦикла;

		Если СуммаБезНДС + СуммаНДС = 0 Тогда
			Продолжить;
		КонецЕсли;

		СуммаСНДС = Мин(ЗачетыАвансов.СуммаАванса, СуммаБезНДС + СуммаНДС);
		Если СуммаСНДС = 0 Тогда
			Продолжить;
		КонецЕсли;

		СуммаБезНДС = Окр(СуммаБезНДС * СуммаСНДС / (СуммаБезНДС + СуммаНДС), 2);
		Если СуммаБезНДС > 0 Тогда
			МассивСуммаБезНДС = ОбщегоНазначенияУнФКлиентСервер.РаспределитьПропорционально(СуммаБезНДС,
				МассивСуммаБезНДС);
		КонецЕсли;

		СуммаНДС = Окр(СуммаСНДС - СуммаБезНДС, 2);
		Если СуммаНДС > 0 Тогда
			МассивСуммаНДС = ОбщегоНазначенияУНФКлиентСервер.РаспределитьПропорционально(СуммаНДС, МассивСуммаНДС);
		КонецЕсли;

		Счетчик = 0;
		Для Каждого СтрокаАвансаПоОтбору Из СтрокиАвансаПоОтбору Цикл
			Если СтрокаАвансаПоОтбору.ДатаСобытия > ЗачетыАвансов.ДатаСобытия Тогда
				// Не учитываем зачет аванса, произведенный до выписки счета-фактуры
				Продолжить;
			КонецЕсли;

			Если ?(СуммаБезНДС > 0, МассивСуммаБезНДС[Счетчик], 0) = 0 И ?(СуммаНДС > 0, МассивСуммаНДС[Счетчик], 0)
				= 0 Тогда
				Продолжить;
			КонецЕсли;

			СтрокаРезультата = ТаблицаРезультатов.Добавить();

			ЗаполнитьЗначенияСвойств(СтрокаРезультата, СтрокаАвансаПоОтбору,
				"СчетФактура,СчетФактураДата,Покупатель,ДоговорКонтрагента,СтавкаНДС,ИсправленныйСчетФактура");
			ЗаполнитьЗначенияСвойств(СтрокаРезультата, ЗачетыАвансов, "ДатаСобытия,ВозвратАвансовПолученных");

			СтрокаРезультата.СуммаБезНДС     = ?(СуммаБезНДС > 0, МассивСуммаБезНДС[Счетчик], 0);
			СтрокаРезультата.НДС             = ?(СуммаНДС > 0, МассивСуммаНДС[Счетчик], 0);
			СтрокаРезультата.ДокументОтгрузки = ЗачетыАвансов.ДокументОтгрузки;

			СтрокаАвансаПоОтбору.СуммаБезНДС = СтрокаАвансаПоОтбору.СуммаБезНДС - ?(СуммаБезНДС > 0,
				МассивСуммаБезНДС[Счетчик], 0);
			СтрокаАвансаПоОтбору.НДС         = СтрокаАвансаПоОтбору.НДС - ?(СуммаНДС > 0, МассивСуммаНДС[Счетчик], 0);

			Счетчик = Счетчик + 1;
		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

Процедура ПолучитьДанныеОДокументахОплатыВозвратАванса(СтруктураПараметров, ТаблицаРезультатов,
	МенеджерВТ_СписокСчетовФактур)

	Если УчетНДСПереопределяемый.ВерсияПостановленияНДС1137(СтруктураПараметров.Дата) < 3 Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ_СписокСчетовФактур;
	Запрос.УстановитьПараметр("Организация", СтруктураПараметров.Организация);
	Запрос.УстановитьПараметр("ДатаГраница", Новый Граница(КонецДня(СтруктураПараметров.Дата), ВидГраницы.Включая));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход) КАК СуммаВозврата,
	|	РасчетыСПокупателямиОбороты.Регистратор КАК ДокументВозвратаАванса,
	|	РасчетыСПокупателямиОбороты.Период КАК ДатаСобытия,
	|	РасчетыСПокупателямиОбороты.Документ КАК СчетФактура,
	|	РасчетыСПокупателямиОбороты.Организация КАК Организация
	|ПОМЕСТИТЬ ДокументыВозвратаАванса
	|ИЗ
	|	РегистрНакопления.РасчетыСПокупателями.Обороты(, &ДатаГраница, Регистратор, Организация = &Организация
	|	И Документ В
	|		(ВЫБРАТЬ
	|			СписокСчетовФактур.СчетФактура
	|		ИЗ
	|			СписокСчетовФактур)) КАК РасчетыСПокупателямиОбороты
	|ГДЕ
	|	РасчетыСПокупателямиОбороты.СуммаПриход > 0
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСПокупателямиОбороты.Организация,
	|	РасчетыСПокупателямиОбороты.Документ,
	|	РасчетыСПокупателямиОбороты.Регистратор,
	|	РасчетыСПокупателямиОбороты.Период
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыВозвратаАванса.СчетФактура КАК СчетФактура,
	|	НАЧАЛОПЕРИОДА(ДокументыВозвратаАванса.ДатаСобытия, ДЕНЬ) КАК ДатаСобытия,
	|	ДокументыВозвратаАванса.СуммаВозврата КАК СуммаБазис,
	|	ДокументыВозвратаАванса.ДокументВозвратаАванса,
	|	ЕСТЬNULL(ДанныеПервичныхДокументов.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаДокументаОплаты,
	|	ЕСТЬNULL(ДанныеПервичныхДокументов.Номер, """") КАК НомерДокументаОплаты
	|ИЗ
	|	ДокументыВозвратаАванса КАК ДокументыВозвратаАванса
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
	|		ПО ДокументыВозвратаАванса.Организация = ДанныеПервичныхДокументов.Организация
	|		И ДокументыВозвратаАванса.ДокументВозвратаАванса = ДанныеПервичныхДокументов.Документ
	|
	|УПОРЯДОЧИТЬ ПО
	|	СчетФактура";

	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();

	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;

	ОплаченныйНДС = Результат.Выгрузить();
	ОплаченныйНДС.Индексы.Добавить("СчетФактура,ДатаСобытия");
	Отбор = Новый Структура("СчетФактура,ДатаСобытия");

	ДополнительныеДокументыОплаты = ТаблицаРезультатов.СкопироватьКолонки();

	Для Каждого СтрокаТаблицы Из ТаблицаРезультатов Цикл

		Если Не СтрокаТаблицы.ВозвратАвансовПолученных Тогда
			Продолжить;
		КонецЕсли;

		Отбор.СчетФактура = СтрокаТаблицы.СчетФактура;
		Отбор.ДатаСобытия = СтрокаТаблицы.ДатаСобытия;
		СтрокиОтбора = ОплаченныйНДС.НайтиСтроки(Отбор);

		Если СтрокиОтбора.Количество() = 0 Тогда
			Продолжить;
		ИначеЕсли СтрокиОтбора.Количество() = 1 Тогда
			// Документ оплаты один, распределение оплат не требуется
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокиОтбора[0]);
			Продолжить;
		КонецЕсли;

		БазисРаспределения = Новый Массив;
		ПустойМассив = Новый Массив;

		Для Каждого СтрокаОтбора Из СтрокиОтбора Цикл
			БазисРаспределения.Добавить(СтрокаОтбора.СуммаБазис);
			ПустойМассив.Добавить(0);
		КонецЦикла;

		Если СтрокаТаблицы.СуммаБезНДС > 0 Тогда
			МассивСуммаБезНДС = ОбщегоНазначенияУНФКлиентСервер.РаспределитьПропорционально(СтрокаТаблицы.СуммаБезНДС,
				БазисРаспределения);
		Иначе
			МассивСуммаБезНДС = ПустойМассив;
		КонецЕсли;

		Если СтрокаТаблицы.НДС > 0 Тогда
			МассивНДС = ОбщегоНазначенияУНФКлиентСервер.РаспределитьПропорционально(СтрокаТаблицы.НДС,
				БазисРаспределения);
		Иначе
			МассивНДС = ПустойМассив;
		КонецЕсли;

		Счетчик = 0;
		ПерваяСтрока = Истина;

		Для Каждого СтрокаОтбора Из СтрокиОтбора Цикл
			Если ПерваяСтрока Тогда
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаОтбора);
				СтрокаТаблицы.СуммаБезНДС = МассивСуммаБезНДС[Счетчик];
				СтрокаТаблицы.НДС = МассивНДС[Счетчик];
				ПерваяСтрока = Ложь;
			Иначе
				ДополнительнаяСтрока = ДополнительныеДокументыОплаты.Добавить();
				ЗаполнитьЗначенияСвойств(ДополнительнаяСтрока, СтрокаТаблицы, , "СуммаБезНДС, НДС");
				ЗаполнитьЗначенияСвойств(ДополнительнаяСтрока, СтрокаОтбора);
				ДополнительнаяСтрока.СуммаБезНДС = МассивСуммаБезНДС[Счетчик];
				ДополнительнаяСтрока.НДС = МассивНДС[Счетчик];
			КонецЕсли;
			Счетчик = Счетчик + 1;
		КонецЦикла;

	КонецЦикла;

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДополнительныеДокументыОплаты, ТаблицаРезультатов);

КонецПроцедуры

Процедура ПолучитьДанныеОбОтгрузочныхСчетахФактурах(СтруктураПараметров, ТаблицаРезультатов, МенеджерВТ_СписокСчетовФактур)
	
	Если УчетНДСПереопределяемый.ВерсияПостановленияНДС1137(СтруктураПараметров.Дата) < 8 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ_СписокСчетовФактур;
	Запрос.УстановитьПараметр("Организация", СтруктураПараметров.Организация);
	Запрос.УстановитьПараметр("ДатаГраница", Новый Граница(КонецДня(СтруктураПараметров.Дата), ВидГраницы.Включая));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход) КАК СуммаЗачета,
	|	РасчетыСПокупателямиОбороты.Регистратор КАК ДокументЗачетаАванса,
	|	РасчетыСПокупателямиОбороты.Период КАК ДатаСобытия,
	|	РасчетыСПокупателямиОбороты.Документ КАК СчетФактура,
	|	РасчетыСПокупателямиОбороты.Организация КАК Организация
	|ПОМЕСТИТЬ ДокументыЗачетаАванса
	|ИЗ
	|	РегистрНакопления.РасчетыСПокупателями.Обороты(, &ДатаГраница, Регистратор, Организация = &Организация
	|	И Документ В
	|		(ВЫБРАТЬ
	|			СписокСчетовФактур.СчетФактура
	|		ИЗ
	|			СписокСчетовФактур)) КАК РасчетыСПокупателямиОбороты
	|ГДЕ
	|	РасчетыСПокупателямиОбороты.СуммаПриход > 0
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСПокупателямиОбороты.Организация,
	|	РасчетыСПокупателямиОбороты.Документ,
	|	РасчетыСПокупателямиОбороты.Регистратор,
	|	РасчетыСПокупателямиОбороты.Период
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДокументыЗачетаАванса.СчетФактура КАК СчетФактура,
	|	НАЧАЛОПЕРИОДА(ДокументыЗачетаАванса.ДатаСобытия, ДЕНЬ) КАК ДатаСобытия,
	|	ДокументыЗачетаАванса.СуммаЗачета КАК СуммаБазис,
	|	ДокументыЗачетаАванса.ДокументЗачетаАванса КАК ДокументЗачетаАванса,
	|	ЕСТЬNULL(ЖурналУчетаСчетовФактур.НомерСчетаФактуры, """") КАК НомерСчетаФактуры,
	|	ЕСТЬNULL(ЖурналУчетаСчетовФактур.ДатаСчетаФактуры, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаСчетаФактуры,
	|	ЕСТЬNULL(ЖурналУчетаСчетовФактур.НомерИсправления, """") КАК НомерИсправленияСчетаФактуры,
	|	ЕСТЬNULL(ЖурналУчетаСчетовФактур.ДатаИсправления, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаИсправленияСчетаФактуры
	|ИЗ
	|	ДокументыЗачетаАванса КАК ДокументыЗачетаАванса
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактура.ДокументыОснования КАК СчетФактураДокументыОснования
	|		ПО ДокументыЗачетаАванса.ДокументЗачетаАванса = СчетФактураДокументыОснования.ДокументОснование
	|		И СчетФактураДокументыОснования.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСчетФактура.Продажа)
	|		И СчетФактураДокументыОснования.Ссылка.ПометкаУдаления = ЛОЖЬ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЖурналУчетаСчетовФактур КАК ЖурналУчетаСчетовФактур
	|		ПО СчетФактураДокументыОснования.Ссылка = ЖурналУчетаСчетовФактур.СчетФактура
	|ГДЕ
	|	ЖурналУчетаСчетовФактур.НомерСчетаФактуры <> """"
	|	И ЖурналУчетаСчетовФактур.ДатаСчетаФактуры <> ДАТАВРЕМЯ(1, 1, 1)
	|
	|УПОРЯДОЧИТЬ ПО
	|	СчетФактура";
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли; 
	
	ЗачтенныйНДС = Результат.Выгрузить();
	ЗачтенныйНДС.Индексы.Добавить("СчетФактура,ДатаСобытия");
	Отбор = Новый Структура("СчетФактура,ДатаСобытия");

	ДополнительныеЗачтенныеОплаты = ТаблицаРезультатов.СкопироватьКолонки();
	
	Для каждого СтрокаТаблицы Из ТаблицаРезультатов Цикл
		
		Если СтрокаТаблицы.ВозвратАвансовПолученных Тогда
			Продолжить;
		КонецЕсли;
		
		Отбор.СчетФактура = СтрокаТаблицы.СчетФактура;
		Отбор.ДатаСобытия = СтрокаТаблицы.ДатаСобытия;
		СтрокиОтбора = ЗачтенныйНДС.НайтиСтроки(Отбор);
		
		Если СтрокиОтбора.Количество() = 0 Тогда
			Продолжить;
		ИначеЕсли СтрокиОтбора.Количество() = 1 Тогда
			// Документ оплаты один, распределение оплат не требуется
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокиОтбора[0]);
			Продолжить;
		КонецЕсли;
		
		БазисРаспределения = Новый Массив();
		ПустойМассив = Новый Массив();
		
		Для каждого СтрокаОтбора Из СтрокиОтбора Цикл
			БазисРаспределения.Добавить(СтрокаОтбора.СуммаБазис);
			ПустойМассив.Добавить(0);
		КонецЦикла;
		
		Если СтрокаТаблицы.СуммаБезНДС > 0 Тогда
			МассивСуммаБезНДС = ОбщегоНазначенияУНФКлиентСервер.РаспределитьПропорционально(СтрокаТаблицы.СуммаБезНДС, БазисРаспределения);
		Иначе
			МассивСуммаБезНДС = ПустойМассив;
		КонецЕсли;
		
		Если СтрокаТаблицы.НДС > 0 Тогда
			МассивНДС = ОбщегоНазначенияУНФКлиентСервер.РаспределитьПропорционально(СтрокаТаблицы.НДС, БазисРаспределения);
		Иначе
			МассивНДС = ПустойМассив;
		КонецЕсли; 

		Счетчик = 0;
		ПерваяСтрока = Истина;
		
		Для каждого СтрокаОтбора Из СтрокиОтбора Цикл
			Если ПерваяСтрока Тогда
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаОтбора);
				СтрокаТаблицы.СуммаБезНДС = МассивСуммаБезНДС[Счетчик];
				СтрокаТаблицы.НДС = МассивНДС[Счетчик];
				ПерваяСтрока = Ложь;
			Иначе
				ДополнительнаяСтрока = ДополнительныеЗачтенныеОплаты.Добавить();
				ЗаполнитьЗначенияСвойств(ДополнительнаяСтрока, СтрокаТаблицы, ,"СуммаБезНДС, НДС");
				ЗаполнитьЗначенияСвойств(ДополнительнаяСтрока, СтрокаОтбора);
				ДополнительнаяСтрока.СуммаБезНДС = МассивСуммаБезНДС[Счетчик];
				ДополнительнаяСтрока.НДС = МассивНДС[Счетчик];
			КонецЕсли;
			Счетчик = Счетчик + 1;
		КонецЦикла;
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДополнительныеЗачтенныеОплаты, ТаблицаРезультатов);
	
КонецПроцедуры

#КонецОбласти

#Область НалоговыйАгент

Функция ПодготовитьДанныеРазделаВычетНДСПоНалоговомуАгенту(СтруктураПараметров) Экспорт

	МетаданныеДокумента = Метаданные.Документы.ФормированиеЗаписейКнигиПокупок;
	ВычетНДСПоНалоговомуАгенту = Новый ТаблицаЗначений;
	Для Каждого КолонкаТабличнойЧасти Из МетаданныеДокумента.ТабличныеЧасти.ВычетНДСПоНалоговомуАгенту.Реквизиты Цикл
		ВычетНДСПоНалоговомуАгенту.Колонки.Добавить(КолонкаТабличнойЧасти.Имя, КолонкаТабличнойЧасти.Тип);
	КонецЦикла;

	ТаблицаРезультатаПриВозвратеАванса = Новый ТаблицаЗначений;
	Если Не СтруктураПараметров.ПредъявленНДСКВычету0 Тогда
		ТаблицаРезультатов = ЗаполнитьНДСПоНалоговомуАгентуКВычетуПоДаннымРегистраНДСПредъявленный(СтруктураПараметров);
//		ТаблицаРезультатаПриВозвратеАванса = ТаблицаВычетаПриВозвратеАвансаНерезидента(СтруктураПараметров);
	Иначе
		ТаблицаРезультатов = ЗаполнитьНДСПоНалоговомуАгентуКВычетуПоДаннымРегистраНДСПредъявленныйРеализация0(
			СтруктураПараметров);
	КонецЕсли;

	Если ТаблицаРезультатов.Количество() = 0 И ТаблицаРезультатаПриВозвратеАванса.Количество() = 0 Тогда
		// Дальнейшая обработка не требуется, не обнаружен НДС, который может быть принят к вычету.
		Возврат ВычетНДСПоНалоговомуАгенту;
	КонецЕсли;

	ВычетНДСПоНалоговомуАгенту.Очистить();
	ВычетНДСПоНалоговомуАгенту.Колонки.Добавить("СчетФактураДата", Новый ОписаниеТипов("Дата", , ,
		Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	
	// Заполним вычет НДС после поступления ценностей.
	Если ТаблицаРезультатов.Количество() <> 0 Тогда

		ТаблицаРезультатов.Колонки.Добавить("ДокументОплаты",
			Новый ОписаниеТипов(МетаданныеДокумента.ТабличныеЧасти.ВычетНДСПоНалоговомуАгенту.Реквизиты.ДокументОплаты.Тип.Типы()));
		Если ТаблицаРезультатов.Колонки.Найти("ДатаОплаты") = Неопределено Тогда
			ТаблицаРезультатов.Колонки.Добавить("ДатаОплаты", Новый ОписаниеТипов("Дата"));
		КонецЕсли;

		ИсключитьНДСНалоговогоАгентаНеоплаченныйПоставщику(СтруктураПараметров, ТаблицаРезультатов);
		
//		ИсключитьНДСпоНепринятымКУчетуНМА(СтруктураПараметров, ТаблицаРезультатов);

		ПолучитьДанныеОДокументахОплаты(СтруктураПараметров, ТаблицаРезультатов);

		ИсключитьНДСНалоговогоАгентаНеоплаченныйВБюджет(СтруктураПараметров, ТаблицаРезультатов);

		ОтфактурованныеВычеты = ОпределитьНаличиеСчетовФактурНалоговогоАгента(СтруктураПараметров, ТаблицаРезультатов);
		ОтфактурованныеВычеты.Индексы.Добавить("ДокументОплаты, ДоговорКонтрагента");

		ПолучитьДанныеОДокументахОплатыАгентскогоНДСВБюджет(СтруктураПараметров, ТаблицаРезультатов);

		СтруктураОтбора = Новый Структура("ДокументОплаты, ДоговорКонтрагента");
		Для Каждого СтрокаТаблицы Из ТаблицаРезультатов Цикл

			Если СтрокаТаблицы.ВидЦенности = Перечисления.ВидыЦенностей.ТоварыНалоговыйАгент Тогда

				СтруктураОтбора.ДокументОплаты = СтрокаТаблицы.СчетФактура;
				СтруктураОтбора.ДоговорКонтрагента = СтрокаТаблицы.ДоговорКонтрагента;

				МассивСчетовФактур = ОтфактурованныеВычеты.НайтиСтроки(СтруктураОтбора);

				Если МассивСчетовФактур.Количество() <> 0 Тогда

					НоваяСтрока = ВычетНДСПоНалоговомуАгенту.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);

					Если МассивСчетовФактур[0].Исправление Тогда
						// Вычеты отсортированы по убыванию номера исправления, установим последний исправленный счет-фактуру
						НоваяСтрока.ИсправленныйСчетФактура = МассивСчетовФактур[0].Ссылка;
					КонецЕсли;

				КонецЕсли;

			Иначе

				ЗаполнитьЗначенияСвойств(СтруктураОтбора, СтрокаТаблицы);
				МассивСчетовФактур = ОтфактурованныеВычеты.НайтиСтроки(СтруктураОтбора);

				Если МассивСчетовФактур.Количество() <> 0 Тогда

					НоваяСтрока = ВычетНДСПоНалоговомуАгенту.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);

					Если МассивСчетовФактур[0].Исправление Тогда
						// Вычеты отсортированы по убыванию номера исправления, установим последний исправленный счет-фактуру
						НоваяСтрока.ИсправленныйСчетФактура = МассивСчетовФактур[0].Ссылка;
					КонецЕсли;

				КонецЕсли;

			КонецЕсли;

		КонецЦикла;

	КонецЕсли;
	
	// Заполним вычет НДС при возврате аванса от поставщика.
	Если ТаблицаРезультатаПриВозвратеАванса.Количество() <> 0 Тогда

		ИсключитьНДСНалоговогоАгентаНеоплаченныйВБюджет(СтруктураПараметров, ТаблицаРезультатаПриВозвратеАванса);

		ПолучитьДанныеОДокументахОплатыАгентскогоНДСВБюджет(СтруктураПараметров, ТаблицаРезультатаПриВозвратеАванса);

		Для Каждого СтрокаТаблицы Из ТаблицаРезультатаПриВозвратеАванса Цикл
			НоваяСтрока = ВычетНДСПоНалоговомуАгенту.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			НоваяСтрока.ВозвратАвансовВыданных = Истина;
		КонецЦикла;

	КонецЕсли;

	ВычетНДСПоНалоговомуАгенту.Свернуть(
		"СчетФактураДата,СчетФактура,ДатаОплаты,ВидЦенности,Поставщик,ДоговорКонтрагента,СтавкаНДС,ДокументОплаты,
		|ДокументОплатыНДС,ДокументОтгрузки,Состояние,ЗаписьДополнительногоЛиста,КорректируемыйПериод,СчетУчетаНДС,
		|ИсправленныйСчетФактура", "СуммаБезНДС,НДС, ВозвратАвансовВыданных");

	ВычетНДСПоНалоговомуАгенту.Сортировать("ВозвратАвансовВыданных, СчетФактураДата,СчетФактура,ДатаОплаты",
		Новый СравнениеЗначений);

	Возврат ВычетНДСПоНалоговомуАгенту;

КонецФункции

Функция ОпределитьНаличиеСчетовФактурНалоговогоАгента(СтруктураПараметров, ТаблицаДокументов)

	УстановитьПривилегированныйРежим(Истина);
	
	// Документы поступления, к которым должны быть зарегистированные счета-фактуры поставщиков товаров п.8 ст. 161 НК.
	ТаблицаСчетовФактур = ТаблицаДокументов.Скопировать( , "СчетФактура");
	
	// Документы оплаты, к которым должны быть выписанные счета-фактуры налогового агента.
	ТаблицаДокументовОплаты = ТаблицаДокументов.Скопировать( , "ДокументОплаты");
	ТаблицаДокументовОплаты.Колонки.ДокументОплаты.Имя = "СчетФактура";

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаСчетовФактур, ТаблицаДокументовОплаты);

	МенеджерВТ_СписокСчетовФактур = Новый МенеджерВременныхТаблиц;
	СоздатьСписокСчетовФактур(ТаблицаДокументовОплаты, МенеджерВТ_СписокСчетовФактур);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ_СписокСчетовФактур;
	Запрос.УстановитьПараметр("ДоговорКонтрагента", ТаблицаДокументов.ВыгрузитьКолонку("ДоговорКонтрагента"));
	Запрос.УстановитьПараметр("Дата", СтруктураПараметров.Дата);

	Запрос.Текст =
	"ВЫБРАТЬ
	|    СчетФактура.УдалитьДокументОснование КАК ДокументОплаты,
	|    СчетФактура.Ссылка КАК Ссылка,
	|    СчетФактура.НомерИсправления КАК НомерИсправления,
	|    СчетФактура.Исправление КАК Исправление,
	|    СчетФактура.Договор КАК ДоговорКонтрагента
	|ИЗ
	|    Документ.СчетФактура КАК СчетФактура
	|        ВНУТРЕННЕЕ СОЕДИНЕНИЕ СписокСчетовФактур КАК СписокСчетовФактур
	|        ПО СчетФактура.УдалитьДокументОснование = СписокСчетовФактур.СчетФактура
	|ГДЕ
	|    СчетФактура.Договор В (&ДоговорКонтрагента)
	|    И СчетФактура.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСчетФактура.НалоговыйАгент)
	|    И СчетФактура.Проведен
	|    И НАЧАЛОПЕРИОДА(СчетФактура.Дата, ДЕНЬ) <= &Дата
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|    СчетФактураПолученныйДокументыОснования.ДокументОснование,
	|    СчетФактураПолученный.Ссылка,
	|    СчетФактураПолученный.НомерИсправления,
	|    СчетФактураПолученный.Исправление,
	|    СчетФактураПолученный.Договор
	|ИЗ
	|    СписокСчетовФактур КАК СписокСчетовФактур
	|        ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный.ДокументыОснования КАК
	|            СчетФактураПолученныйДокументыОснования
	|        ПО СчетФактураПолученныйДокументыОснования.ДокументОснование = СписокСчетовФактур.СчетФактура
	|        ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный КАК СчетФактураПолученный
	|        ПО СчетФактураПолученныйДокументыОснования.Ссылка = СчетФактураПолученный.Ссылка
	|ГДЕ
	|    СчетФактураПолученный.Договор В (&ДоговорКонтрагента)
	|    И СчетФактураПолученный.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийСчетФактураПолученный.Поступление)
	|    И СчетФактураПолученный.Проведен
	|    И НАЧАЛОПЕРИОДА(СчетФактураПолученный.ДатаИсправления, ДЕНЬ) <= &Дата
	|
	|УПОРЯДОЧИТЬ ПО
	|    НомерИсправления УБЫВ";

	Возврат Запрос.Выполнить().Выгрузить();

