Функция НоваяСтруктураНачисленияИВычеты()

	СтруктураНачисленияИВычеты = Новый Структура;
	СтруктураНачисленияИВычеты.Вставить("НачисленийЗа12месяцев", 0);
	СтруктураНачисленияИВычеты.Вставить("ВычетовЗа12Месяцев", 0);
	СтруктураНачисленияИВычеты.Вставить("ВычетовЗаКвартал", 0);
	СтруктураНачисленияИВычеты.Вставить("НачисленийЗаКвартал", 0);

	Возврат СтруктураНачисленияИВычеты;

