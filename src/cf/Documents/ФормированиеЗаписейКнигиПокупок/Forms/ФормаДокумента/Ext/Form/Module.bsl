#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ПолучитьНачисленияИВычетыДляИтогов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьНачисленияИВычетыДляИтогов()
	
	Если Объект.Дата < ДатаНачалаРаботыКонтроляДолиВычетов 
		ИЛИ Не ЗначениеЗаполнено(Объект.Организация) Тогда 
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьНачисленияИВычетыНаСервере();
	
	Если Результат.Статус = "Выполнено" Тогда
		ЗагрузитьРезультатНачисленияИВычеты();
	Иначе
		ИдентификаторЗаданияНачисленияИВычеты = Результат.ИдентификаторЗадания;
		АдресХранилищаНачисленияИВычеты       = Результат.АдресРезультата;
		
		ДлительныеОперацииКлиент.ИнициализироватьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
		ПодключитьОбработчикОжидания(
			"Подключаемый_ПроверитьВыполнениеЗаданияНачисленияИВычеты", 
			ПараметрыОбработчикаОжидания.ТекущийИнтервал,
			Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьНачисленияИВычетыНаСервере()
	
	ПараметрыЗадачи = Новый Структура;
	ПараметрыЗадачи.Вставить("Организация", Объект.Организация);
	ПараметрыЗадачи.Вставить("Период", Объект.Дата);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	
	Результат = ДлительныеОперации.ВыполнитьВФоне("Документы.ФормированиеЗаписейКнигиПокупок.НачисленияИВычеты", 
		ПараметрыЗадачи, ПараметрыВыполнения);
		
	АдресХранилищаНачисленияИВычеты = Результат.АдресРезультата;
	
	Если Результат.Статус = "Выполнено" Тогда
		ЗагрузитьРезультатНачисленияИВычеты();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗагрузитьРезультатНачисленияИВычеты()
	
	Результат = ПолучитьИзВременногоХранилища(АдресХранилищаНачисленияИВычеты);
	
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Результат);
	
	ИдентификаторЗаданияНачисленияИВычеты = Неопределено;
	
	ОбновитьИтогиВПодвале(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПроверитьВыполнениеЗаданияНачисленияИВычеты()
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторЗаданияНачисленияИВычеты) Тогда
		ОтключитьОбработчикОжидания("Подключаемый_ПроверитьВыполнениеЗаданияНачисленияИВычеты");
		Возврат;
	КонецЕсли;

	Если ЗаданиеВыполнено(ИдентификаторЗаданияНачисленияИВычеты) Тогда
		ПоказателиПолучены = Истина;
		ЗагрузитьРезультатНачисленияИВычеты();
	Иначе
		ДлительныеОперацииКлиент.ОбновитьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
		ПодключитьОбработчикОжидания(
			"Подключаемый_ПроверитьВыполнениеЗаданияНачисленияИВычеты", 
			ПараметрыОбработчикаОжидания.ТекущийИнтервал, 
			Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблиц(ИмяТаблицы = "")

	ПараметрыОбъекта = Неопределено;
	ЗаполнитьПараметрыОбъектаДляЗаполненияДобавленныхКолонок(ЭтотОбъект, ПараметрыОбъекта);
	
	Если ПустаяСтрока(ИмяТаблицы) ИЛИ ИмяТаблицы = "ВычетПоПриобретеннымЦенностям" Тогда
		Для каждого СтрокаТаблицы Из Объект.ВычетПоПриобретеннымЦенностям Цикл
			ЗаполнитьДобавленныеКолонкиСтрокиТаблицы(СтрокаТаблицы, ПараметрыОбъекта);
		КонецЦикла;
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяТаблицы) ИЛИ ИмяТаблицы = "НДССАвансов" Тогда
		Для каждого СтрокаТаблицы Из Объект.НДСсАвансов Цикл
			ЗаполнитьДобавленныеКолонкиСтрокиТаблицы(СтрокаТаблицы, ПараметрыОбъекта);
		КонецЦикла;
	КонецЕсли;
	
	Если ПустаяСтрока(ИмяТаблицы) ИЛИ ИмяТаблицы = "ВычетПриИзмененииСтоимостиВСторонуУменьшения" Тогда
		Для каждого СтрокаТаблицы Из Объект.ВычетПриИзмененииСтоимостиВСторонуУменьшения Цикл
			ЗаполнитьДобавленныеКолонкиСтрокиТаблицы(СтрокаТаблицы, ПараметрыОбъекта);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьПараметрыОбъектаДляЗаполненияДобавленныхКолонок(Знач Форма, ПараметрыОбъекта)

	Объект = Форма.Объект;
	
	Если ТипЗнч(ПараметрыОбъекта) <> Тип("Структура") Тогда
		ПараметрыОбъекта = Новый Структура;
	КонецЕсли;
	
	ПараметрыОбъекта.Вставить("Дата", Объект.Дата);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьДобавленныеКолонкиСтрокиТаблицы(СтрокаТабличнойЧасти, ПараметрыОбъекта)
	
	Если НЕ (СтрокаТабличнойЧасти.ЗаписьДополнительногоЛиста
			И НачалоКвартала(СтрокаТабличнойЧасти.КорректируемыйПериод) <> ПараметрыОбъекта.Дата) Тогда
		СтрокаТабличнойЧасти.НДСТекущегоКвартала = СтрокаТабличнойЧасти.НДС;
	Иначе
		СтрокаТабличнойЧасти.НДСТекущегоКвартала = 0;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура КодыОперацийПоСтавке0ДляТоваров()
	
	// Получает коды операций НДС 0%, которые используются:
	// 1. только для товаров;
	// 2. как для товаров так и для услуг.
	
	ТоварыИУслугиКодыОпераций0.Очистить();
	
	КлассификаторXML = ПолучитьОбщийМакет("ПереченьКодовОпераций0").ПолучитьТекст();
	
	Чтение = Новый ЧтениеXML;
	Чтение.УстановитьСтроку(КлассификаторXML);
	ТаблицаКодовОпераций0 = СериализаторXDTO.ПрочитатьXML(Чтение); // ТаблицаЗначений
	
	ПредыдущийКод = "";
	
	Для Каждого СтрокаТаблицыКодовОпераций0 Из ТаблицаКодовОпераций0 Цикл
		Если ПредыдущийКод <> СтрокаТаблицыКодовОпераций0.Код
			И (СтрокаТаблицыКодовОпераций0.ДляТоваров
				ИЛИ СтрокаТаблицыКодовОпераций0.ДляУслуг)
			И (СтрокаТаблицыКодовОпераций0.ДатаОкончания = '00010101'
					И СтрокаТаблицыКодовОпераций0.ДатаНачала <= Объект.Дата
				ИЛИ Объект.Дата <= СтрокаТаблицыКодовОпераций0.ДатаОкончания
					И Объект.Дата >= СтрокаТаблицыКодовОпераций0.ДатаНачала) Тогда
			
			НоваяСтрокаТоварыИУслугиКодыОпераций0 = ТоварыИУслугиКодыОпераций0.Добавить();
			НоваяСтрокаТоварыИУслугиКодыОпераций0.Код = СтрокаТаблицыКодовОпераций0.Код;
			НоваяСтрокаТоварыИУслугиКодыОпераций0.Название = СтрокаТаблицыКодовОпераций0.Наименование;
			
			ПредыдущийКод = СтрокаТаблицыКодовОпераций0.Код;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте 
Функция ПараметрыПереносаСтрокТабличныхЧастей(РежимЗаписи)
	
	ТабличныеЧасти = Новый Соответствие;
	
	Если Элементы.ВычетПоПриобретеннымЦенностям.Видимость Тогда
		ТабличныеЧасти.Вставить("ВычетПоПриобретеннымЦенностям", Новый Структура("КоличествоСтрокДляПереноса", 0));
	КонецЕсли;
	
	Если Элементы.ГруппаНДСсАвансов.Видимость Тогда
		ТабличныеЧасти.Вставить("НДСсАвансов", Новый Структура("КоличествоСтрокДляПереноса", 0));
	КонецЕсли;
	
	Если Элементы.ГруппаВычетНДСПоНалоговомуАгенту.Видимость Тогда
		ТабличныеЧасти.Вставить("ВычетНДСПоНалоговомуАгенту", Новый Структура("КоличествоСтрокДляПереноса", 0));
	КонецЕсли;
	
	Если Элементы.ГруппаВычетПриИзмененииСтоимостиВСторонуУменьшения.Видимость Тогда
		ТабличныеЧасти.Вставить("ВычетПриИзмененииСтоимостиВСторонуУменьшения", Новый Структура("КоличествоСтрокДляПереноса", 0));
	КонецЕсли;
	
	РеквизитыДокумента = "Дата, Организация, ПредъявленНДСКВычету0, РучнаяКорректировка, Ответственный";
	
	ПараметрыПереносаСтрокТЧ = Новый Структура;
	ПараметрыПереносаСтрокТЧ.Вставить("ТабличныеЧасти", ТабличныеЧасти);
	ПараметрыПереносаСтрокТЧ.Вставить("РеквизитыДокумента", РеквизитыДокумента);
	ПараметрыПереносаСтрокТЧ.Вставить("РежимЗаписи", РежимЗаписи);
	
	Возврат ПараметрыПереносаСтрокТЧ;

КонецФункции

&НаКлиенте
Процедура ВопросПеренестиСтрокиТабличныхЧастейВДругойДокументЗавершение(Результат, ПараметрыПереносаСтрокТЧ) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		УчетНДСКлиент.ПеренестиСтрокиТабличныхЧастейВДругойДокумент(ПараметрыПереносаСтрокТЧ);
	КонецЕсли;
	
	ЭтотОбъект.Прочитать();
	
КонецПроцедуры

&НаСервере
Процедура ИспользуемыеКодыОперацийПоСтавке0(Знач ДокументОтгрузки, Знач ДокументПриобретения, Знач Состояние)
	
	Если Состояние = Перечисления.НДССостоянияРеализация0.ПодтвержденаРеализация0 Тогда
		
		Событие = Перечисления.СобытияПоНДСПродажи.ПодтвержденаСтавка0;
		СчетФактура = ДокументОтгрузки;
		
	Иначе
		
		Событие = Перечисления.СобытияПоНДСПродажи.НеПодтвержденаСтавка0;
		
		// Найдём счет-фактуру выданный на документ отгрузки при неподтверждении нулевой ставки
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПодтверждениеНулевойСтавкиНДССостав.СчетФактураВыданный КАК СчетФактураВыданный
			|ИЗ
			|	Документ.ПодтверждениеНулевойСтавкиНДС.Состав КАК ПодтверждениеНулевойСтавкиНДССостав
			|ГДЕ
			|	ПодтверждениеНулевойСтавкиНДССостав.Событие = &Событие
			|	И ПодтверждениеНулевойСтавкиНДССостав.ДокументОтгрузки = &ДокументОтгрузки
			|	И ПодтверждениеНулевойСтавкиНДССостав.Ссылка.Проведен";
		
		Запрос.УстановитьПараметр("ДокументОтгрузки", ДокументОтгрузки);
		Запрос.УстановитьПараметр("Событие", Событие);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			СчетФактура = Выборка.СчетФактураВыданный;
		КонецЕсли;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НДСЗаписиКнигиПродаж.КодОперации0 КАК Код
		|ПОМЕСТИТЬ КодыОперацийДокументаОтгрузки
		|ИЗ
		|	РегистрНакопления.НДСЗаписиКнигиПродаж КАК НДСЗаписиКнигиПродаж
		|ГДЕ
		|	НДСЗаписиКнигиПродаж.СчетФактура = &СчетФактура
		|	И НДСЗаписиКнигиПродаж.Событие = &Событие
		|	И НЕ НДСЗаписиКнигиПродаж.НесырьевыеТовары
		|	И НДСЗаписиКнигиПродаж.КодОперации0 <> """"
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Код
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаКодовОпераций0.Код КАК Код,
		|	ТаблицаКодовОпераций0.Название КАК Название
		|ПОМЕСТИТЬ КодыОпераций0
		|ИЗ
		|	&ТаблицаКодовОпераций0 КАК ТаблицаКодовОпераций0
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Код
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	КодыОпераций0.Код КАК Код,
		|	КодыОпераций0.Название КАК Название
		|ИЗ
		|	КодыОпераций0 КАК КодыОпераций0
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ КодыОперацийДокументаОтгрузки КАК КодыОперацийДокументаОтгрузки
		|		ПО КодыОпераций0.Код = КодыОперацийДокументаОтгрузки.Код
		|
		|УПОРЯДОЧИТЬ ПО
		|	КодыОпераций0.Код
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ КодыОперацийДокументаОтгрузки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ КодыОпераций0";
	
	Запрос.УстановитьПараметр("Событие", Событие);
	Запрос.УстановитьПараметр("СчетФактура", СчетФактура);
	Запрос.УстановитьПараметр("ТаблицаКодовОпераций0", РеквизитФормыВЗначение(ТоварыИУслугиКодыОпераций0, Тип("ТаблицаЗначений")));
	
	ТаблицаВыбораКодовОпераций0.Очистить();
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрокаТаблицыВыбораКодовОпераций0 = ТаблицаВыбораКодовОпераций0.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицыВыбораКодовОпераций0, Выборка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиКодОперацииЗавершение(РезультатВыбора, ТолькоПросмотр) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ТолькоПросмотр Тогда
		Элементы.ВычетПоПриобретеннымЦенностям.ТекущиеДанные.КодОперации0= РезультатВыбора.Код;
	КонецЕсли;
	
КонецПроцедуры

