&НаКлиенте
Процедура ВычетПоПриобретеннымЦенностямВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "ВычетПоПриобретеннымЦенностямКодОперации0" Тогда
		
		СтандартнаяОбработка = Ложь;
		ТекДанные = Элементы.ВычетПоПриобретеннымЦенностям.ТекущиеДанные;
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Заголовок","Выбор кода операции НДС 0%");
		ИспользуемыеКодыОперацийПоСтавке0(ТекДанные.ДокументОтгрузки,ТекДанные.СчетФактура,ТекДанные.Состояние);
		
		Если ТаблицаВыбораКодовОпераций0.Количество() > 0 Тогда
			ПараметрыФормы.Вставить("ТаблицаЗначений",ТаблицаВыбораКодовОпераций0);
		Иначе
			ПараметрыФормы.Вставить("ТаблицаЗначений",ТоварыИУслугиКодыОпераций0);
		КонецЕсли;
		
		ПараметрыФормы.Вставить("СтруктураДляПоиска", Новый Структура("Код", ТекДанные.КодОперации0));
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВвестиКодОперацииЗавершение", ЭтотОбъект, Элементы.ВычетПоПриобретеннымЦенностям.ТолькоПросмотр);
		
		ОткрытьФорму("Обработка.ОбщиеОбъектыРеглОтчетности.Форма.ФормаВыбораЗначенияИзТаблицы",
		ПараметрыФормы, ЭтотОбъект,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;

КонецПроцедуры

