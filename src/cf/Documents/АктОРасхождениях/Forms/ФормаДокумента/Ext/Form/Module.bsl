	КонецЕсли;
	
	// Ставка НДС, Сумма НДС, Всего.
	УстановитьВидимостьПоНалогообложению();
	ОпределитьВидимостьНастроекУчетаВНалогообложении();
	
	// Прослеживаемость
	Если Не КэшЗначений.Свойство("УчетГТД") Тогда
