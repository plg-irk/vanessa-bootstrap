КонецПроцедуры

&НаКлиенте
Процедура ДобавитьОплатуСертификатом(Команда)
	
	ТекстПредупреждения = "";
	Если РаботаСПодарочнымиСертификатамиКлиентСервер.ИспользованиеСертификатовЗапрещено(ВалютаРасчетов, НациональнаяВалюта, ТекстПредупреждения) Тогда
		ПоказатьПредупреждение(, ТекстПредупреждения);
		Возврат;
	КонецЕсли;
	
	// Проверим рассчитанность скидок перед добавлением сертификата
	Если ИспользоватьАвтоматическиеСкидки Тогда
		
		Если Не Объект.СкидкиРассчитаны Тогда
			РассчитатьСкидкиНаценкиКлиент();
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ru = 'Рассчитаны автоматические скидки (наценки).'");
			Сообщение.КлючДанных = Объект.Ссылка;
			Сообщение.Сообщить();
		Иначе
			Объект.СкидкиРассчитаны = Истина;
			ОбновитьКартинкуАвтоСкидкиПослеЗаписи = Истина;
		КонецЕсли;
		
	КонецЕсли;
	// Конец АвтоматическиеСкидки
	
	Оповещение = Новый ОписаниеОповещения("ДобавитьОплатуСертификатомЗавершение", ЭтотОбъект);
	ОтборСтрок = Новый Структура("ОплатаБонусами", Ложь);
	СтрокиБезОплатыБонусами = Объект.Предоплата.НайтиСтроки(ОтборСтрок);
	ПредоплатаБезОплатыБонусами = 0;
	Для Каждого СтрокаПредоплаты Из СтрокиБезОплатыБонусами Цикл
		ПредоплатаБезОплатыБонусами = ПредоплатаБезОплатыБонусами + СтрокаПредоплаты.СуммаРасчетов; 
	КонецЦикла;

	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("КОплате", ИтогВсего - ПредоплатаБезОплатыБонусами);
	СтруктураПараметров.Вставить("Документ", Объект.Ссылка);
	СтруктураПараметров.Вставить("Товары", Объект.Запасы);
	
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаОплатыСертификатом", СтруктураПараметров, , , , , Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьОплатуБонусами(Команда)
	
	ТекстПредупреждения = "";
	Если РаботаСБонусамиКлиентСервер.ИспользованиеБонусовЗапрещено(ВалютаРасчетов, НациональнаяВалюта,
		ТекстПредупреждения) Тогда
		ПоказатьПредупреждение( , ТекстПредупреждения);
		Возврат;
	КонецЕсли;
	ЗаказПокупателя = Объект.Заказ;
	Если Объект.ПоложениеЗаказаПокупателя = ПредопределенноеЗначение(
		"Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти") Тогда
		ЗаказПокупателя = ЗаполнениеОбъектовУНФКлиент.ЗначениеДляШапки(Объект.Запасы, "Заказ");
	КонецЕсли;
	Если ЗначениеЗаполнено(ЗаказПокупателя) Тогда
		ТекстПредупреждения = НСтр("ru = 'При продаже по заказу, оплата бонусами используется в заказе покупателя.'");
		ПоказатьПредупреждение(, ТекстПредупреждения);
		Возврат;
	КонецЕсли;
	
	// Проверим рассчитанность скидок перед добавлением оплаты бонусами
	Если ИспользоватьАвтоматическиеСкидки Тогда
		
		Если Не Объект.СкидкиРассчитаны Тогда
			Если ВыдатьПодаркиНаВыбор ИЛИ ВывестиСообщения Тогда
				// Если на форме уже выведены сообщения, то всего лишь сбросим флаг расчета скидок, но не станем дублировать окна
				СброситьФлагСкидкиРассчитаныКлиент("ВыборДисконтнойКарты");
			Иначе
				РассчитатьСкидкиНаценкиКлиент();
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = НСтр("ru = 'Рассчитаны автоматические скидки (наценки).'");
				Сообщение.КлючДанных = Объект.Ссылка;
				Сообщение.Сообщить();
			КонецЕсли;
		Иначе
			Объект.СкидкиРассчитаны = Истина;
			ОбновитьКартинкуАвтоСкидкиПослеЗаписи = Истина;
		КонецЕсли;
		
	КонецЕсли;
	// Конец АвтоматическиеСкидки
	
	Оповещение = Новый ОписаниеОповещения("ДобавитьОплатуБонусамиЗавершение", ЭтотОбъект);
	// ИтогоВсего уже включает в себя скидку-оплату бонусами
	ОтборСтрок = Новый Структура("ОплатаБонусами", Ложь);
	СтрокиБезОплатыБонусами = Объект.Предоплата.НайтиСтроки(ОтборСтрок);
	ПредоплатаБезОплатыБонусами = 0;
	Для Каждого СтрокаПредоплаты Из СтрокиБезОплатыБонусами Цикл
		ПредоплатаБезОплатыБонусами = ПредоплатаБезОплатыБонусами + СтрокаПредоплаты.СуммаРасчетов; 
	КонецЦикла;
	СуммаОплатыБонусами = Объект.Запасы.Итог("СуммаСкидкиОплатыБонусом");
	СтруктураПараметров = Новый Структура();
	// К оплате исходная стоимость товара с учетом скидок, но без учета оплат бонусами, за вычетом уже зачтенной предоплаты.
	СтруктураПараметров.Вставить("КОплате", ИтогВсего + СуммаОплатыБонусами - ПредоплатаБезОплатыБонусами);
	СтруктураПараметров.Вставить("Документ", Объект);
	СтруктураПараметров.Вставить("СуммаБонусов", СуммаОплатыБонусами);
	СтруктураПараметров.Вставить("Товары", Объект.Запасы);
	
	Если Не ЗначениеЗаполнено(Объект.ДисконтнаяКарта) Тогда
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Оповещение", Оповещение);
		ДополнительныеПараметры.Вставить("СтруктураПараметров", СтруктураПараметров);
		ОповещениеКарты = Новый ОписаниеОповещения("СчитатьДисконтнуюКартуИДобавитьОплатуЗавершение", ЭтотОбъект,
			ДополнительныеПараметры);
		ОткрытьФорму("Справочник.ДисконтныеКарты.Форма.СчитываниеДисконтнойКарты", , ЭтотОбъект, , , , ОповещениеКарты,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		СтруктураПараметров.Вставить("БонуснаяКарта", Объект.ДисконтнаяКарта);
		ОткрытьФорму("Справочник.ДисконтныеКарты.Форма.ФормаОплатыБонусами", СтруктураПараметров, ЭтотОбъект, , , ,
			Оповещение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НомераГТДЗаполнитьПоФактическимОстаткам(Команда)
	
	НомераГТДЗаполнитьПоФактическимОстаткамНаСервере(Истина);
	
