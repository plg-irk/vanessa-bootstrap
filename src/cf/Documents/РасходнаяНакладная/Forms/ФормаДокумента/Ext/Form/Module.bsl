&НаСервере
Процедура ЗаполнитьРеквизитыПечати()
	
	Объект.ПодписьКладовщика = 
		ПерсональныеНастройкиРУНФ.Прочитать("ПодписьМОЛ", Объект.Организация);
	Объект.Автомобиль = 
		ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойАвтомобиль", Объект.Организация);
	Объект.Водитель = 
		ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойВодитель", Объект.Организация);
	Объект.Перевозчик = 
		ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойПеревозчик", Объект.Организация);
	Объект.ОрганизацияОплачиваетПеревозку = 
		ПерсональныеНастройкиРУНФ.Прочитать("ОрганизацияОплачиваетПеревозку", Объект.Организация);
		
	ОбновитьУсловияПечатныхФорм();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьУсловияПечатныхФорм()
	
	Если ПустаяСтрока(Объект.ТекстУсловийСчетаЗаказа) Тогда
		Объект.УсловияСчетаЗаказа = ПерсональныеНастройкиРУНФ.Прочитать("УсловияСчетаЗаказа", 
			Объект.Организация);
	КонецЕсли;
	
	Если ПустаяСтрока(Объект.ТекстУсловийГарантийногоТалона) Тогда
		Объект.УсловияГарантийногоТалона = 
			ПерсональныеНастройкиРУНФ.Прочитать("УсловияГарантии", Объект.Организация);
	КонецЕсли;
	
	Объект.РекламныйБлокПечтаныхФорм = Справочники.РекламныеБлокиПечатныхФорм.ПолучитьРекламныйБлок(Объект.Организация);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПодборСерииПодарка()
		
	ТекущиеДанныеИдентификатор = Элементы.Подарки.ТекущиеДанные.ПолучитьИдентификатор();
	ПараметрыСерийНоменклатуры = ПараметрыПодбораСерийПодарков(ТекущиеДанныеИдентификатор);
	ПараметрыСерийНоменклатуры.Вставить("ОтключитьОбщееОповещение", Истина);
	ОповещениеПодбора = Новый ОписаниеОповещения("ОповещениеПодбораСерийПодарков", ЭтотОбъект);
	
	ОткрытьФорму("Обработка.ПодборСерийНоменклатуры.Форма", ПараметрыСерийНоменклатуры, ЭтотОбъект, , , ,
		ОповещениеПодбора);

КонецПроцедуры

&НаСервере
Функция ПараметрыПодбораСерийПодарков(ТекущиеДанныеИдентификатор)
	
	Возврат СерииНоменклатурыУНФ.ПараметрыПодбораСерийНоменклатуры(Объект, УникальныйИдентификатор,
		ТекущиеДанныеИдентификатор, , "Подарки", "СерииПодарков", "КлючСвязи");
	
КонецФункции

&НаСервере
Процедура ОбновитьВидимостьПодарков()  
	
	ЕстьПодарки = Объект.Подарки.Количество() > 0;
	Элементы.ГруппаПодарки.Видимость = ЕстьПодарки;
	
	ОтборПродажиПодарков = Новый Структура("ПродажаПодарка", Истина);
	ПродажиПодарков = Объект.Запасы.НайтиСтроки(ОтборПродажиПодарков);
	ОтражатьВозможностьСписанияПодарков = ПродажиПодарков.Количество() > 0 ИЛИ Объект.ОтменаПереносаПодарковВПродажи;
	Элементы.ЗапасыИсключитьПодаркиИзПродажи.Видимость = ОтражатьВозможностьСписанияПодарков;
	Элементы.ЗапасыИсключитьПодаркиИзПродажи.Пометка = Объект.ОтменаПереносаПодарковВПродажи;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимостьБонусовКНачислению()  
	
	ЕстьБонусы = Объект.БонусныеБаллыКНачислению.Количество() > 0;	
	Элементы.БонусныеБаллыКНачислению.Видимость = ЕстьБонусы;
	
КонецПроцедуры

