	ПараметрыОткрытияФормы.ИдентификаторЗаказа = ИдентификаторЗаказаНаДоставку;
	ПараметрыОткрытияФормы.РежимМастера = 2;
	
	СервисДоставкиКлиент.ОткрытьФормуСервисаДоставки(ПараметрыОткрытияФормы);
	
