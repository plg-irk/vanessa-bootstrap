	Элементы.ДекорацияДлинаНазначенияПлатежа.Заголовок = ТекстЗаголовка;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТекстДекорацииНазначенияНаСервере()
	
	ТекстЗаголовка = ПолучитьТекстДекорацииНазначения(Объект.НазначениеПлатежа);
