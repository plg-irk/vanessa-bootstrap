		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.Доверенность") Тогда
		
		СписокВидовДоговора.Добавить(Перечисления.ВидыДоговоров.СПоставщиком);
