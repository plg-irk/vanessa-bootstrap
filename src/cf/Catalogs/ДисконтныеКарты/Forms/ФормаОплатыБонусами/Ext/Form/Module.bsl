#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	
	Документ = Неопределено;
	Если Не Параметры.Свойство("Документ", Документ) Тогда
		Возврат;
	КонецЕсли; 
	
	Если Параметры.Свойство("БонуснаяКарта") Тогда
		БонуснаяКарта = Параметры.БонуснаяКарта;
	Иначе
		БонуснаяКарта = Документ.ДисконтнаяКарта;
	КонецЕсли;
	
	Если Параметры.Свойство("БонуснаяПрограмма") Тогда
		БонуснаяПрограмма = Параметры.БонуснаяПрограмма;
	КонецЕсли;
	
	Владелец = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БонуснаяКарта, "Владелец");
	
	Если Не Документ = Неопределено Тогда
		СтруктураДанных = РаботаСБонусами.ПолучитьДанныеБонуснойКарты(БонуснаяКарта, Документ.Дата, Документ.Ссылка);
		СтруктураОстатка.Загрузить(СтруктураДанных.ТаблицаДвижений);
		Если СтруктураДанных.Свойство("ДвиженияДокумента") Тогда
			ДвижениеОплачено = СтруктураДанных.ДвиженияДокумента.Оплачено;
		КонецЕсли;
		ЭтоЧекККМ = ТипЗнч(Документ.Ссылка) = Тип("ДокументСсылка.ЧекККМ");
	КонецЕсли;
	
	Если Параметры.Свойство("МассивВыбранныхКарт")
		И Параметры.МассивВыбранныхКарт.Количество() > 0 Тогда
		ОбъединитьКарты = Ложь;
		
		Если Параметры.Свойство("ОбъединитьКарты") Тогда
			ОбъединитьКарты = Параметры.ОбъединитьКарты;
		КонецЕсли;
		
		Если ОбъединитьКарты Тогда
			ОстатокБаллов = 0;
			Для Каждого СтрокаМассива Из Параметры.МассивВыбранныхКарт Цикл
				ДанныеДисконтнойКарты = ДисконтныеКартыУНФСервер.ПолучитьДанныеКарты(СтрокаМассива);
				ОстатокБаллов = ОстатокБаллов + ДанныеДисконтнойКарты.ОстатокБаллов;
			КонецЦикла;
			
			НоваяСтрока = ТаблицаВыбранныхДисконтныхКарт.Добавить();
			НоваяСтрока.ДисконтнаяКарта = БонуснаяКарта;
			НоваяСтрока.ОстатокБонусов = ОстатокБаллов;
		Иначе
			Для Каждого СтрокаМассива Из Параметры.МассивВыбранныхКарт Цикл
				НоваяСтрока = ТаблицаВыбранныхДисконтныхКарт.Добавить();
				НоваяСтрока.ДисконтнаяКарта = СтрокаМассива;
				ДанныеДисконтнойКарты = ДисконтныеКартыУНФСервер.ПолучитьДанныеКарты(НоваяСтрока.ДисконтнаяКарта);
				НоваяСтрока.ОстатокБонусов = ДанныеДисконтнойКарты.ОстатокБаллов;
			КонецЦикла;
		КонецЕсли;
		
	Иначе
		
		НоваяСтрока = ТаблицаВыбранныхДисконтныхКарт.Добавить();
		НоваяСтрока.ДисконтнаяКарта = БонуснаяКарта;
		ДанныеДисконтнойКарты = ДисконтныеКартыУНФСервер.ПолучитьДанныеКарты(НоваяСтрока.ДисконтнаяКарта);
		НоваяСтрока.ОстатокБонусов = ДанныеДисконтнойКарты.ОстатокБаллов;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(БонуснаяКарта) Тогда
		БонуснаяКарта = Документ.ДисконтнаяКарта;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(БонуснаяКарта) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	Если ЗначениеЗаполнено(БонуснаяПрограмма) Тогда
		ПараметрыБонуснойПрограммы = РаботаСБонусами.НастройкиБонуснойПрограммы(БонуснаяПрограмма);
	Иначе
		ПараметрыБонуснойПрограммы = РаботаСБонусами.РеквизитыБонуснойПрограммы(БонуснаяКарта);
	КонецЕсли;

	Товары = Неопределено;
	ТоварыКЗагрузке = ТоварыКОплате.Выгрузить();
	Если Параметры.Свойство("Товары", Товары) Тогда 
		Если ТипЗнч(Товары) = Тип("ТаблицаЗначений") Тогда
			ТоварыКЗагрузке = Товары;
		ИначеЕсли ТипЗнч(Товары) = Тип("ДанныеФормыКоллекция") Тогда
			ТоварыКЗагрузке = Товары.Выгрузить(,"Номенклатура, Характеристика, Сумма, СуммаСкидкиОплатыБонусом"); 
		ИначеЕсли ТипЗнч(Товары) = Тип("Массив") Тогда
			Для Каждого стрТовары Из Товары Цикл
				НовСтрока = ТоварыКЗагрузке.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрока, стрТовары);
				НовСтрока.Сумма = стрТовары.Всего;
			КонецЦикла;
		КонецЕсли;	
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
		ТоварыКЗагрузке = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Документ, "РаботыИУслуги").Выгрузить().Скопировать(,"Номенклатура, Характеристика, Сумма, СуммаСкидкиОплатыБонусом");
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		ДанныеДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Документ, "ВидОперации, Запасы, Работы");
		ТоварыКЗагрузке = ДанныеДокумента.Запасы.Выгрузить().Скопировать(,"Номенклатура, Характеристика, Сумма, СуммаСкидкиОплатыБонусом");
		Если ДанныеДокумента.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд Тогда
			Товары = ДанныеДокумента.Работы.Выгрузить().Скопировать(,"Номенклатура, Характеристика, Сумма, СуммаСкидкиОплатыБонусом");
			Для Каждого стрРаботы Из Товары Цикл
				ЗаполнитьЗначенияСвойств(ТоварыКЗагрузке.Добавить(), стрРаботы);
			КонецЦикла;
		КонецЕсли;
	ИначеЕсли ЗначениеЗаполнено(Документ) Тогда
		ТоварыКЗагрузке = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Документ, "Запасы").Выгрузить().Скопировать(,"Номенклатура, Характеристика, Сумма, СуммаСкидкиОплатыБонусом");
	КонецЕсли;
	ТоварыКОплате.Загрузить(ТоварыКЗагрузке);
	ОграничениеОплаты = РаботаСБонусами.ПолучитьМаксимальнуюСуммуОплатыДокумента(ТоварыКОплате, БонуснаяКарта);
	СуммаУжеПримененныхБонусов = ТоварыКОплате.Итог("СуммаСкидкиОплатыБонусом");
	
	Если Параметры.Свойство("КОплате") Тогда
		КОплате = Параметры.КОплате;
	Иначе
		Возврат;
	КонецЕсли;
	СуммаОплатыВВалюте = КОплате;

	КурсБонусов = ?(ЗначениеЗаполнено(ПараметрыБонуснойПрограммы.КурсБонусов), ПараметрыБонуснойПрограммы.КурсБонусов, 1);
	Валюта = УправлениеНебольшойФирмойПовтИсп.ПолучитьВалютуУчета();
	Если КурсБонусов = 1 Тогда
		Элементы.СуммаОплатыВВалюте.Видимость = Ложь;
		Элементы.ОстатокВВалюте.Видимость = Ложь;
		Элементы.МаксимальнаяСуммаВВалюте.Видимость = Ложь;
		Элементы.ГруппаКурсБаллов.Видимость = Ложь;
	КонецЕсли;

	ОграничениеОплатыБаллами =  Окр(ОграничениеОплаты / КурсБонусов, 2, РежимОкругления.Окр15как10);
	КОплатеБонусов = Окр(СуммаОплатыВВалюте / КурсБонусов, 2, РежимОкругления.Окр15как10);
	
	// Итого, максимум, сколько можно оплатить баллами в данном документе, с учетом других предоплат
	МожноОплатитьБалламиЧисло = Мин(СуммаОплатыВВалюте, ОграничениеОплаты);
	Если МожноОплатитьБалламиЧисло = 0 Тогда
		МожноОплатитьБаллами = "";
	Иначе
		МожноОплатитьБаллами = Формат(МожноОплатитьБалламиЧисло, "ЧДЦ=2") +" "+ Строка(Валюта);
		МожноОплатитьБаллами = "("+МожноОплатитьБаллами+")";
	КонецЕсли;
	МожноПотратитьБаллов = Окр(МожноОплатитьБалламиЧисло / КурсБонусов, 2, РежимОкругления.Окр15как10);
	
	Если Параметры.Свойство("СуммаБонусов") Тогда
		// Из документов в качестве параметра СуммаБонусов передается сумма скидки за оплаты бунусами, т.е. сумма в валюте документа
		СуммаБонусов = Окр(Параметры.СуммаБонусов / КурсБонусов, 2);
	Иначе
		СуммаБонусов = Окр(СуммаУжеПримененныхБонусов / КурсБонусов, 2);
	КонецЕсли;
	
	ОстатокБонусов = 0;
	ОстатокВВалютеЧисло = 0;
	Для Каждого СтрокаТаблицы Из ТаблицаВыбранныхДисконтныхКарт Цикл
		ПараметрыБонуснойПрограммы = РаботаСБонусами.РеквизитыБонуснойПрограммы(СтрокаТаблицы.ДисконтнаяКарта);
		ОстатокБонусов = ОстатокБонусов + СтрокаТаблицы.ОстатокБонусов;
		
		ОстатокВВалютеЧисло = ОстатокВВалютеЧисло + СтрокаТаблицы.ОстатокБонусов * ПараметрыБонуснойПрограммы.КурсБонусов;
		СтрокаТаблицы.КурсБонусов = ПараметрыБонуснойПрограммы.КурсБонусов;
	КонецЦикла;
	
	Остаток = ОстатокБонусов + ДвижениеОплачено;
	
	ОстатокВВалютеЧисло =  Окр(ОстатокВВалютеЧисло + ДвижениеОплачено, 2);
	Если ОстатокВВалютеЧисло = 0 Тогда
		ОстатокВВалюте = "";
	Иначе
		ОстатокВВалюте = Формат(ОстатокВВалютеЧисло, "ЧДЦ=2") +" "+ Строка(Валюта);
		ОстатокВВалюте = "(" + ОстатокВВалюте + ")";
	КонецЕсли;
	
	Если Остаток < МожноПотратитьБаллов Тогда
		Элементы.ГруппаСуммаОплаты.Видимость = Ложь;
	КонецЕсли;
	
	ОстатокПривышаетЛимит = Истина;
	Если ПараметрыБонуснойПрограммы.КоличествоОграниченияОстатка > 0
		И ПараметрыБонуснойПрограммы.КоличествоОграниченияОстатка > Остаток Тогда
		ОстатокПривышаетЛимит = Ложь;
	КонецЕсли;
	
	Если ОстатокПривышаетЛимит Тогда
		ДоступноКСписаниюБаллов = Мин(Остаток, КОплатеБонусов, ОграничениеОплатыБаллами);
	Иначе
		ШаблонДекорации = НСтр("ru = 'Оплата возможна, если остаток больше %1 баллов'");
		Элементы.ИнформацияОбОграничениях.Заголовок = СтрШаблон(ШаблонДекорации, ПараметрыБонуснойПрограммы.КоличествоОграниченияОстатка);
		Элементы.ИнформацияОбОграничениях.Видимость = Истина;
		Элементы.МожноСписать.Видимость = Ложь;
	КонецЕсли;
	
	СуммаБонусов = Мин(СуммаБонусов, ДоступноКСписаниюБаллов);
	Если СуммаБонусов = 0 Тогда
		СуммаОплатыВВалютеДокумента = "";
	Иначе
		СуммаОплатыВВалютеДокумента = Формат(Окр(СуммаБонусов, 2), "ЧДЦ=2") +" "+ Строка(Валюта);
		СуммаОплатыВВалютеДокумента = "("+СуммаОплатыВВалютеДокумента+")";
	КонецЕсли;
	
	ШаблонТекстаПодсказки = НСтр("ru = '%1 (К оплате)'");
	Если Остаток = ДоступноКСписаниюБаллов Тогда  
		ШаблонТекстаПодсказки = НСтр("ru = '%1 (Остаток)'");
	ИначеЕсли ОграничениеОплатыБаллами = ДоступноКСписаниюБаллов Тогда
		ШаблонТекстаПодсказки = НСтр("ru = '%1 (Макс.)'");
	КонецЕсли;
	Элементы.СуммаБонусов.СписокВыбора.Добавить(ДоступноКСписаниюБаллов, СтрШаблон(ШаблонТекстаПодсказки, ДоступноКСписаниюБаллов));
	ЧислоДоступныхБалловСтрокой = ПолучитьСклоненияСтрокиПоЧислу("", ДоступноКСписаниюБаллов, "бонусный балл")[0];
	Элементы.ДекорацияМожноСписатьМаксимум.Заголовок = СтрШаблон(НСтр("ru = 'Использовать %1'"), ЧислоДоступныхБалловСтрокой);
КонецПроцедуры

&НаКлиенте
Процедура СуммаОплатыПриИзменении(Элемент)
	Если СуммаБонусов > МожноПотратитьБаллов Тогда
		ТекстСообщения = НСтр("ru = 'Превышена сумма доступной оплаты баллами.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "СуммаОплаты", "СуммаОплаты");
		СуммаБонусов = МожноПотратитьБаллов;
	КонецЕсли;
	
	Если СуммаБонусов > Остаток Тогда
		ТекстСообщения = НСтр("ru = 'Превышен остаток баллов.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "СуммаОплаты", "СуммаОплаты");
		СуммаБонусов = Остаток;
	КонецЕсли;
	
	ОбновитьРасчетПоКурсу();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Отмена(Команда)
	
	Закрыть(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	
	Если СуммаБонусов > Остаток Тогда
		ТекстСообщения = НСтр("ru = 'Превышен остаток баллов по карте.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "СуммаОплаты", "СуммаОплаты");
		Возврат;
	КонецЕсли;
	
	Если СуммаБонусов > КОплате / КурсБонусов Тогда
		ТекстСообщения = НСтр("ru = 'Сумма оплаты не может превышать сумму документа.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "СуммаОплаты", "СуммаОплаты");
		Возврат;
	КонецЕсли;
	
	Если СуммаБонусов > ОграничениеОплатыБаллами Тогда
		ТекстСообщения = НСтр("ru = 'Сумма оплаты не может превышать ограничение, установленное для бонусной программы.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "СуммаОплаты", "СуммаОплаты");
		Возврат;
	КонецЕсли;
	
	Если СуммаБонусов = 0 Тогда
		ПараметрыЗакрытия = Неопределено;
	ИначеЕсли ЭтоЧекККМ Тогда
		ПараметрыЗакрытия = Новый Структура("МассивВыбранныхКарт, ЕстьОплатаБонусами");
		МассивВыбранныхКарт = Новый Массив;
		Для Каждого СтрокаТаблицы Из ТаблицаВыбранныхДисконтныхКарт Цикл
			СтруктураСтроки = Новый Структура("БонуснаяКарта, СуммаБонусов, ВидОплаты");
			СтруктураСтроки.БонуснаяКарта = СтрокаТаблицы.ДисконтнаяКарта;
			СтруктураСтроки.СуммаБонусов = СтрокаТаблицы.СуммаСписания;
			СтруктураСтроки.ВидОплаты = ПредопределенноеЗначение("Перечисление.ВидыБезналичныхОплат.Бонусы");
			МассивВыбранныхКарт.Добавить(СтруктураСтроки);
		КонецЦикла;
		ПараметрыЗакрытия.МассивВыбранныхКарт = МассивВыбранныхКарт;
		ПараметрыЗакрытия.ЕстьОплатаБонусами = Истина;
	Иначе
		
		ПараметрыЗакрытия = Новый Структура;
		ПараметрыЗакрытия.Вставить("БонуснаяКарта", БонуснаяКарта);
		ПараметрыЗакрытия.Вставить("СуммаБонусов", СуммаБонусов);
		ПараметрыЗакрытия.Вставить("ВидОплаты", ПредопределенноеЗначение("Перечисление.ВидыБезналичныхОплат.Бонусы"));
		ПараметрыЗакрытия.Вставить("ЕстьОплатаБонусами", Истина);
		
	КонецЕсли;
	
	Закрыть(ПараметрыЗакрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияМожноСписатьМаксимумНажатие(Элемент)
	СуммаБонусов = ДоступноКСписаниюБаллов;
	ОбновитьРасчетПоКурсу();
	ОК(Неопределено);
КонецПроцедуры  

&НаКлиенте
Процедура ОбновитьРасчетПоКурсу()
	Если КурсБонусов = 0 Тогда
		СуммаОплатыВВалютеДокумента = "";
	Иначе 
		СуммаОплатыВВалютеДокумента = "("+Формат(Окр(СуммаБонусов * КурсБонусов, 2)) + " " + Валюта + ")";
		СуммаБонусовВВалюте = Окр(СуммаБонусов * КурсБонусов, 2);
	КонецЕсли;
	РаспределитьСуммуБонусов();
КонецПроцедуры

&НаКлиенте
Процедура РаспределитьСуммуБонусов()
	ОбщийИтогБонусовРаспределено = 0;
	Для Каждого СтрокаТаблицы Из ТаблицаВыбранныхДисконтныхКарт Цикл
		КурсБонусов = ?(СтрокаТаблицы.КурсБонусов = 0, 1, СтрокаТаблицы.КурсБонусов);
		ОбщийИтогБонусовРаспределено = ОбщийИтогБонусовРаспределено + СтрокаТаблицы.ОстатокБонусов * КурсБонусов;
	КонецЦикла;
	
	Если ОбщийИтогБонусовРаспределено <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	СуммаБонусовКРаспределению = СуммаБонусовВВалюте;
	СуммаРаспределено = 0;
	Для Каждого СтрокаТаблицы Из ТаблицаВыбранныхДисконтныхКарт Цикл
		КурсБонусов = ?(СтрокаТаблицы.КурсБонусов = 0, 1, СтрокаТаблицы.КурсБонусов);
		СуммаРаспределения = Окр(СуммаБонусовКРаспределению * (СтрокаТаблицы.ОстатокБонусов * КурсБонусов/ОбщийИтогБонусовРаспределено), 2, РежимОкругления.Окр15как20);
		СтрокаТаблицы.СуммаСписания = СуммаРаспределения/КурсБонусов;
		СуммаРаспределено = СуммаРаспределено + СуммаРаспределения;
	КонецЦикла;
	РазницаРаспределения = СуммаБонусовКРаспределению - СуммаРаспределено;
	
	Если ТаблицаВыбранныхДисконтныхКарт.Количество() > 0 
		И РазницаРаспределения <> 0 Тогда
		КурсБонусов = ?(ТаблицаВыбранныхДисконтныхКарт[0].КурсБонусов = 0, 1, ТаблицаВыбранныхДисконтныхКарт[0].КурсБонусов);
		ТаблицаВыбранныхДисконтныхКарт[0].СуммаСписания = ТаблицаВыбранныхДисконтныхКарт[0].СуммаСписания + РазницаРаспределения/КурсБонусов;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти
