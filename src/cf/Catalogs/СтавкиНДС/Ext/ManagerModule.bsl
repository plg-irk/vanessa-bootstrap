#Область ОбработчикиСобытий

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)

	Если ЗначениеЗаполнено(Параметры.СтрокаПоиска) Тогда
		Возврат;
	КонецЕсли;
 
	СтандартнаяОбработка = Ложь;

	ПериодДействия = ТекущаяДатаСеанса();
	До2019Года = ПериодДействия < '20190101';
    До2026Года = ПериодДействия < '20260101';

	Если Параметры.Свойство("Дата") Тогда
		ПериодДействия = Макс(Параметры.Дата, ПериодДействия);
	КонецЕсли;
	Применяется176ФЗ = РегламентированнаяОтчетностьУСНКлиентСервер.Применяется176ФЗ(ПериодДействия);

	Запрос = Новый Запрос;

	ТекстЗапроса = "ВЫБРАТЬ
				   |	СтавкиНДС.Ссылка КАК СтавкаНДС,
				   |	СтавкиНДС.ВидСтавкиНДС КАК ВидСтавкиНДС,
				   |	СтавкиНДС.Ставка КАК ЗначениеСтавки,
				   |	-1 КАК Порядок,
				   |	СтавкиНДС.Представление КАК Представление
				   |ИЗ
				   |	Справочник.СтавкиНДС КАК СтавкиНДС
				   |ГДЕ
				   |	НЕ СтавкиНДС.ПометкаУдаления";

	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);

	Запрос = Новый Запрос;

	Для Каждого ЭлементОтбора Из Параметры.Отбор Цикл
		ИмяПараметра = "Отбор" + ЭлементОтбора.Ключ;
		Запрос.УстановитьПараметр(ИмяПараметра, ЭлементОтбора.Значение);
		Если ТипЗнч(ЭлементОтбора.Значение) = Тип("ФиксированныйМассив") Тогда
			Условие = СтрШаблон("СтавкиНДС.%1 В (&%2)", ЭлементОтбора.Ключ, ИмяПараметра);
		Иначе
			Условие = СтрШаблон("СтавкиНДС.%1 = &%2", ЭлементОтбора.Ключ, ИмяПараметра);
		КонецЕсли;
		СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Отбор.Добавить(Условие);
	КонецЦикла;
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();

	ВсеСтавки = Запрос.Выполнить().Выгрузить();

	ПорядокСтавок = Новый Массив;
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.Общая);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ОбщаяРасчетная);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.Пониженная);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.Нулевая);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.БезНДС);
	Если Применяется176ФЗ Тогда
		ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ОбщаяУСН);
		ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ОбщаяУСНРасчетная);
		ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяУСН);
		ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяУСНРасчетная);
	КонецЕсли;

	Для Каждого Строка Из ВсеСтавки Цикл

		Порядок = ПорядокСтавок.Найти(Строка.ВидСтавкиНДС);
		Если Порядок = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Если Строка.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая Или Строка.ВидСтавкиНДС
			= Перечисления.ВидыСтавокНДС.ОбщаяРасчетная Тогда
			
			Если Строка.ЗначениеСтавки = 20 И Не До2026Года Или Строка.ЗначениеСтавки = 22 И До2026Года Тогда
					Порядок = Порядок + ВсеСтавки.Количество();
			КонецЕсли;
			
			Если Строка.ЗначениеСтавки = 18 И Не До2019Года Или Строка.ЗначениеСтавки = 20 И До2019Года Тогда
				Порядок = Порядок + ВсеСтавки.Количество() + 2;
			КонецЕсли;

		КонецЕсли;
		Строка.Порядок = Порядок;
	КонецЦикла;

	ВсеСтавки.Сортировать("Порядок");

	ДанныеВыбора = Новый СписокЗначений;
	Для Каждого Строка Из ВсеСтавки Цикл
		Если Строка.Порядок >= 0 Тогда
			ДанныеВыбора.Добавить(Строка.СтавкаНДС, Строка.Представление);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СтавкаНДСПоВидуСтавки(Знач ВидСтавки)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СтавкиНДС.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СтавкиНДС КАК СтавкиНДС
	|ГДЕ
	|	СтавкиНДС.ВидСтавкиНДС = &ВидСтавкиНДС";
	Запрос.УстановитьПараметр("ВидСтавкиНДС", ВидСтавки);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Если ВидСтавки = Перечисления.ВидыСтавокНДС.БезНДС Тогда
			Возврат НайтиПоНаименованию("Без НДС");
		КонецЕсли;

		Возврат ПустаяСсылка();
	КонецЕсли;

КонецФункции

Функция ОбщаяСтавкаНДС(Знач Период, Расчетная = Ложь)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СтавкиНДС.Ссылка КАК Ссылка,
	|	1 КАК Приоритет
	|ИЗ
	|	Справочник.СтавкиНДС КАК СтавкиНДС
	|ГДЕ
	|	СтавкиНДС.ВидСтавкиНДС = ЗНАЧЕНИЕ(Перечисление.ВидыСтавокНДС.Общая)
	|	И СтавкиНДС.Ставка = &ЗначениеСтавки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СтавкиНДС.Ссылка,
	|	2
	|ИЗ
	|	Справочник.СтавкиНДС КАК СтавкиНДС
	|ГДЕ
	|	СтавкиНДС.ВидСтавкиНДС = ЗНАЧЕНИЕ(Перечисление.ВидыСтавокНДС.Общая)
	|	И СтавкиНДС.Ставка <> &ЗначениеСтавки
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет";

    Если Период >= Дата('20260101') Тогда
    	Запрос.УстановитьПараметр("ЗначениеСтавки", 22); 
    ИначеЕсли Период >= Дата('20190101') Тогда
		Запрос.УстановитьПараметр("ЗначениеСтавки", 20);
	Иначе
		Запрос.УстановитьПараметр("ЗначениеСтавки", 18);
	КонецЕсли;
	Если Расчетная Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, ".Общая", ".ОбщаяРасчетная");
	КонецЕсли;
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.СтавкиНДС.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция ОписаниеСтавокНДС_УСН2025()

	Ставки = Новый Массив;
	Ставки.Добавить(ОписаниеСтавки(НСтр("ru='5%'"), 5, Перечисления.ВидыСтавокНДС.ПониженнаяУСН,
		Перечисления.СтавкиНДС.НДС5));
	Ставки.Добавить(ОписаниеСтавки(НСтр("ru='5% / 105%'"), 5, Перечисления.ВидыСтавокНДС.ПониженнаяУСНРасчетная,
		Перечисления.СтавкиНДС.НДС5_105, Истина));
	Ставки.Добавить(ОписаниеСтавки(НСтр("ru='7%'"), 7, Перечисления.ВидыСтавокНДС.ОбщаяУСН,
		Перечисления.СтавкиНДС.НДС7));
	Ставки.Добавить(ОписаниеСтавки(НСтр("ru='7% / 107%'"), 7, Перечисления.ВидыСтавокНДС.ОбщаяУСНРасчетная,
		Перечисления.СтавкиНДС.НДС7_107, Истина));
	Возврат Ставки;
