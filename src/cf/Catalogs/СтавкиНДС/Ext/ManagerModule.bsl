	|ИЗ
	|	Справочник.СтавкиНДС КАК СтавкиНДС
	|ГДЕ
	|	СтавкиНДС.ВидСтавкиНДС = ЗНАЧЕНИЕ(Перечисление.ВидыСтавокНДС.ПониженнаяРасчетная2)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСтавкиОбщая
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТСтавкиОбщаяРасчетная;";

    Если Период >= Дата('20260101') Тогда
        ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ЗначениеСтавки", "22");
    ИначеЕсли Период >= Дата('20190101') Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ЗначениеСтавки", "20");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ЗначениеСтавки", "18");
	КонецЕсли;

	Возврат ТекстЗапроса;
КонецФункции

// Заполняет список выбора ставок, исключая значения не характеризующие номенклатурную позицию.
//
// Параметры:
//   Форма - Форма - управляемая форма, в которой расположено поле для выбора ставки НДС
//   ИмяЭлемента - Строка - элемент формы - поле выбора ставки НДС.
//   ПодсказкаУСН - Булево - Истина, если нужно добавить информацию о ставках УСН
//
Процедура ЗаполнитьСписокВыбораСтавокНДС(Форма, ИмяЭлемента, ПодсказкаУСН = Ложь) Экспорт

	Элементы = Форма.Элементы;

	Элементы[ИмяЭлемента].РежимВыбораИзСписка = Истина;
	Элементы[ИмяЭлемента].СписокВыбора.Очистить();

	СоответствиеСтавок = СоответствиеСтавокНДС(ТекущаяДатаСеанса());

	ПорядокСтавок = ВидыСтавокНДСНоменклатуры();
	Для Каждого ВидСтавки Из ПорядокСтавок Цикл

		ПредставлениеСтавки = СоответствиеСтавок.Получить(ВидСтавки);
		Если ЗначениеЗаполнено(ПредставлениеСтавки) Тогда
		    Если ПодсказкаУСН И (ВидСтавки = Перечисления.ВидыСтавокНДС.Общая Или ВидСтавки
				= Перечисления.ВидыСтавокНДС.Пониженная) Тогда
				ТекстСтавка = 	УчетНДСКлиентСервер.ТекстовоеПредставлениеСтавкиНДС(
			ВидСтавки, ОбщегоНазначения.ТекущаяДатаПользователя());
			Иначе
				ТекстСтавка = СтрШаблон(НСтр("ru='%1'"), ПредставлениеСтавки);
			КонецЕсли;	
			Элементы[ИмяЭлемента].СписокВыбора.Добавить(ВидСтавки, ТекстСтавка);
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

// Возвращает массив видов ставок, доступных для установки в Номенклатуре
// 
// Возвращаемое значение:
//   - Массив из ПеречислениеСсылка.ВидыСтавокНДС
//
Функция ВидыСтавокНДСНоменклатуры() Экспорт

	ПорядокСтавок = Новый Массив;
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.Общая);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ОбщаяРасчетная);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.Пониженная);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.Нулевая);
	ПорядокСтавок.Добавить(Перечисления.ВидыСтавокНДС.БезНДС);

	Возврат ПорядокСтавок;

КонецФункции

// Заполняет список выбора ставок, доступных организациям, применяющим УСН
//
// Параметры:
//   Форма - Форма - управляемая форма, в которой расположено поле для выбора ставки НДС
//   ИмяЭлемента - Строка - элемент формы - поле выбора ставки НДС.
//
Процедура ЗаполнитьСписокВыбораСтавокНДСНаУСН(Форма, ИмяЭлемента) Экспорт

	Элементы = Форма.Элементы;

	Элементы[ИмяЭлемента].РежимВыбораИзСписка = Истина;
	Элементы[ИмяЭлемента].СписокВыбора.Очистить();

	ДоступныеВидыСтавок = Новый Массив;
	ДоступныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяУСН);
	ДоступныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.ОбщаяУСН);
	ДоступныеВидыСтавок.Добавить(Перечисления.ВидыСтавокНДС.Общая);

	СоответствиеСтавок = СоответствиеСтавокНДС();

	Для Каждого Ставка Из ДоступныеВидыСтавок Цикл

		ПредставлениеСтавки = СоответствиеСтавок.Получить(Ставка);
		Если ЗначениеЗаполнено(ПредставлениеСтавки) Тогда
			Элементы[ИмяЭлемента].СписокВыбора.Добавить(Ставка, Строка(ПредставлениеСтавки));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

