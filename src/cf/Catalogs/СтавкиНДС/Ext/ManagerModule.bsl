// Заполнение рекавизитов элементов справочника.
Процедура ЗаполнитьВидыСтавокНДС() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СтавкиНДС.Ссылка КАК Ссылка,
	|	СтавкиНДС.Ставка КАК Ставка,
	|	СтавкиНДС.НеОблагается КАК НеОблагается,
	|	СтавкиНДС.Расчетная КАК Расчетная
	|ИЗ
	|	Справочник.СтавкиНДС КАК СтавкиНДС";

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

		СтавкиНДСОбъект = Выборка.Ссылка.ПолучитьОбъект();
		СтавкиНДСОбъект.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.ВидСтавки(Выборка);
		СтавкиНДСОбъект.ДополнительныеСвойства.Вставить("ОбновлениеВидовСтавокНДС");

		Попытка
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(СтавкиНДСОбъект);
		Исключение
			ТекстСообщения = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ЗаписьЖурналаРегистрации("ru='Ошибка заполнения вида ставки НДС'", УровеньЖурналаРегистрации.Ошибка, ,
				СтавкиНДСОбъект.Ссылка, ТекстСообщения);
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры

Процедура СоздатьСтавки_УСН2025() Экспорт

	ОписанияСтавок = ОписаниеСтавокНДС_УСН2025();

	Для Каждого Описание Из ОписанияСтавок Цикл

		СтавкаНДС = СтавкаНДСПоВидуСтавки(Описание.ВидСтавкиНДС);
		Если ЗначениеЗаполнено(СтавкаНДС) Тогда
			Продолжить;
		КонецЕсли;

		СтавкаОбъект = СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(СтавкаОбъект, Описание);
		СтавкаОбъект.Записать();

	КонецЦикла;

КонецПроцедуры

Процедура СоздатьСтавки_НДС2026() Экспорт
	
	// 22% / 122%
	СтавкаНДС = СоздатьЭлемент();
	СтавкаНДС.Наименование = НСтр("ru='22% / 122%'");
	СтавкаНДС.Расчетная = Истина;
	СтавкаНДС.Ставка = 22;
	СтавкаНДС.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.ОбщаяРасчетная;
	СтавкаНДС.ПеречислениеСтавкаНДС = Перечисления.СтавкиНДС.НДС22_122;
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(СтавкаНДС);
    
    // 20%
	СтавкаНДС = СоздатьЭлемент();
	СтавкаНДС.Наименование = НСтр("ru='22%'");
	СтавкаНДС.Ставка = 22;
	СтавкаНДС.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая;
	СтавкаНДС.ПеречислениеСтавкаНДС = Перечисления.СтавкиНДС.НДС22;
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(СтавкаНДС);

КонецПроцедуры

// Заполнение реквизита ПеречислениеСтавкаНДС
Процедура ЗаполнитьПеречислениеСтавокНДС() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|    СтавкиНДС.Ссылка КАК Ссылка,
	|    СтавкиНДС.Ставка КАК Ставка,
	|    СтавкиНДС.НеОблагается,
	|    СтавкиНДС.Расчетная
	|ИЗ
	|    Справочник.СтавкиНДС КАК СтавкиНДС
	|ГДЕ
	|    СтавкиНДС.ПеречислениеСтавкаНДС = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.ПустаяСсылка)";

	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

		СтавкиНДСОбъект = Выборка.Ссылка.ПолучитьОбъект();
		СтавкиНДСОбъект.ПеречислениеСтавкаНДС = УстановитьПеречислениеСтавкиНДС(СтавкиНДСОбъект, Выборка.Ставка,
			Выборка.НеОблагается, Выборка.Расчетная);

		Попытка
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(СтавкиНДСОбъект);
		Исключение
			ТекстСообщения = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ЗаписьЖурналаРегистрации("ru='Ошибка при установки соответствия перечислениям в ставках НДС'",
				УровеньЖурналаРегистрации.Ошибка, , СтавкиНДСОбъект.Ссылка, ТекстСообщения);
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

// Ставка НДС.
// 
// Параметры:
//  ВидСтавки - ПеречислениеСсылка.ВидыСтавокНДС
//  Период - Дата, Неопределено - Период
// 
// Возвращаемое значение:
//  - Неопределено
//	  СправочникСсылка.СтавкиНДС
Функция СтавкаНДС(ВидСтавки, Период = Неопределено) Экспорт

	Если Не ЗначениеЗаполнено(Период) Тогда
		Период = ТекущаяДатаСеанса();
	КонецЕсли;

	Если ВидСтавки = Перечисления.ВидыСтавокНДС.Общая Тогда
		Возврат ОбщаяСтавкаНДС(Период);
	ИначеЕсли ВидСтавки = Перечисления.ВидыСтавокНДС.ОбщаяРасчетная Тогда
		Возврат ОбщаяСтавкаНДС(Период, Истина);
	Иначе
		Возврат СтавкаНДСПоВидуСтавки(ВидСтавки);
	КонецЕсли;

КонецФункции

// Ставка НДС по значению перечисления Ставки НДС.
// 
// Параметры:
//  ЗначениеПеречисления - ПеречислениеСсылка.СтавкиНДС
// 
// Возвращаемое значение:
//  - Неопределено
//	  СправочникСсылка.СтавкиНДС
Функция СтавкаНДСПоПеречислениюСтавкиНДС(ЗначениеПеречисления) Экспорт

	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ПеречислениеСтавкаНДС", ЗначениеПеречисления);
	
	Запрос.Текст = 
	 "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	 |	СтавкиНДС.Ссылка КАК Ссылка
	 |ИЗ
	 |	Справочник.СтавкиНДС КАК СтавкиНДС
	 |ГДЕ
	 |	СтавкиНДС.ПеречислениеСтавкаНДС = &ПеречислениеСтавкаНДС";
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	Иначе
		Возврат Неопределено
	КонецЕсли;
	
КонецФункции

// Соответствие ставок НДС.
// 
// Параметры:
//  Период - Неопределено, Дата - Период
// 
// Возвращаемое значение:
//  - Соответствие из КлючИЗначение:
//		* Ключ - ПеречислениеСсылка.ВидыСтавокНДС
//		* Значение - СправочникСсылка.СтавкиНДС
Функция СоответствиеСтавокНДС(Период = Неопределено) Экспорт
	Если Период = Неопределено Тогда
		Период = ТекущаяДатаСеанса();
	КонецЕсли;

	Результат = Новый Соответствие;
	Результат.Вставить(Перечисления.ВидыСтавокНДС.Общая, ОбщаяСтавкаНДС(Период));
	Результат.Вставить(Перечисления.ВидыСтавокНДС.ОбщаяРасчетная, ОбщаяСтавкаНДС(Период, Истина));

	МассивПеречислений = Новый Массив;
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.Пониженная);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.Пониженная2);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная2);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.Нулевая);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.БезНДС);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.ОбщаяУСН);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.ОбщаяУСНРасчетная);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяУСН);
	МассивПеречислений.Добавить(Перечисления.ВидыСтавокНДС.ПониженнаяУСНРасчетная);

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СтавкиНДС.Ссылка КАК СтавкаНДС,
	|	СтавкиНДС.ВидСтавкиНДС КАК ВидСтавкиНДС
	|ИЗ
	|	Справочник.СтавкиНДС КАК СтавкиНДС
	|ГДЕ
	|	СтавкиНДС.ВидСтавкиНДС В (&ВидыСтавокНДС)";
	Запрос.УстановитьПараметр("ВидыСтавокНДС", МассивПеречислений);
	СтавкиНДСПоВидамСтавок = Запрос.Выполнить().Выгрузить();

	Для Каждого ВидСтавки Из МассивПеречислений Цикл
		СтрокаСтавки = СтавкиНДСПоВидамСтавок.Найти(ВидСтавки, "ВидСтавкиНДС");
		Если СтрокаСтавки = Неопределено Тогда
			СтавкаНДС = ?(ВидСтавки = Перечисления.ВидыСтавокНДС.БезНДС,
				УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС(), ПустаяСсылка());
		Иначе
			СтавкаНДС = СтрокаСтавки.СтавкаНДС;
		КонецЕсли;
		Результат.Вставить(ВидСтавки, СтавкаНДС);
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ПолучитьТекстЗапросаСозданияВТСтавкиНДС(Период = Неопределено) Экспорт
	Если Период = Неопределено Тогда
		Период = ТекущаяДатаСеанса();
	КонецЕсли;

	ТекстЗапроса =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СтавкиНДС.Ссылка КАК Ссылка,
