
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("СостояниеКонтроля") Тогда
		НастроитьОтборСписка(Параметры.СостояниеКонтроля);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура НастроитьОтборСписка(ОтборыТипов)
	
	СписокОтбора = Новый СписокЗначений;
	ТипыКонтроляНаЧек = ИнтерфейсРМКСлужебныйКлиентСервер.ТипыКонтроляНаЧек();
	Если ОтборыТипов.ЕстьПроверкиНаЧек Тогда
		
		СписокОтбора.ЗагрузитьЗначения(ТипыКонтроляНаЧек);
		
	ИначеЕсли ОтборыТипов.ЕстьПроверкиНаСтроку Тогда
		
		ЗначенияТиповКонтроля = Метаданные.Перечисления.ТипыКонтроля.ЗначенияПеречисления;
		Для Каждого ЗначениеТипа Из ЗначенияТиповКонтроля Цикл
			ЗначениеПеречисления = Перечисления.ТипыКонтроля[ЗначениеТипа.Имя];
			Если ТипыКонтроляНаЧек.Найти(ЗначениеПеречисления) = Неопределено Тогда
				
				СписокОтбора.Добавить(ЗначениеПеречисления);
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	Если СписокОтбора.Количество() > 0 Тогда
		
		ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТипКонтроля");
		ЭлементОтбора.ПравоеЗначение = СписокОтбора;
		ЭлементОтбора.Использование = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти