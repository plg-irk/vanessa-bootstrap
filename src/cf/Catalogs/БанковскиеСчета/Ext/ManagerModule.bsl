#Область ПрямойОбменСБанком

Функция БанкиИНастройкиСПрямымОбменом(Организация) Экспорт
	
	Настройки = Новый Соответствие;
	Для Каждого СчетНастройка Из БанковскиеСчетаСНастройкамиПрямогоОбмена(Организация) Цикл
		Если Настройки[СчетНастройка.Банк] = Неопределено Тогда
			Настройки.Вставить(СчетНастройка.Банк, СчетНастройка.НастройкаОбмена);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Настройки;
	
КонецФункции

Функция БанковскиеСчетаСНастройкамиПрямогоОбмена(Организация) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Банки.Ссылка КАК Банк,
	|	БанковскиеСчета.Ссылка КАК БанковскийСчет,
	|	Банки.Код КАК БИК,
	|	ЕСТЬNULL(НастройкиОбменСБанками.Ссылка, НастройкиОбменСБанкамиПоБИК.Ссылка) КАК НастройкаОбмена,
	|	ВЫБОР
	|		КОГДА НастройкиОбменСБанками.ПрограммаБанка = ЗНАЧЕНИЕ(Перечисление.ПрограммыБанка.СбербанкОнлайн)
	|			ТОГДА 0
	|		КОГДА НастройкиОбменСБанкамиПоБИК.ПрограммаБанка = ЗНАЧЕНИЕ(Перечисление.ПрограммыБанка.СбербанкОнлайн)
	|			ТОГДА 0
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Приоритет
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Банки КАК Банки
	|		ПО БанковскиеСчета.Банк = Банки.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НастройкиОбменСБанками КАК НастройкиОбменСБанками
	|		ПО БанковскиеСчета.Банк = НастройкиОбменСБанками.Банк
	|			И (НастройкиОбменСБанками.Организация = &Организация)
	|			И (НЕ НастройкиОбменСБанками.ПометкаУдаления)
	|			И (НЕ НастройкиОбменСБанками.Недействительна)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НастройкиОбменСБанками КАК НастройкиОбменСБанкамиПоБИК
	|		ПО (Банки.Код = НастройкиОбменСБанкамиПоБИК.Банк.Код)
	|			И (НастройкиОбменСБанкамиПоБИК.Организация = &Организация)
	|			И (НЕ НастройкиОбменСБанкамиПоБИК.ПометкаУдаления)
	|			И (НЕ НастройкиОбменСБанкамиПоБИК.Недействительна)
	|ГДЕ
	|	НЕ БанковскиеСчета.ПометкаУдаления
	|	И БанковскиеСчета.ДатаЗакрытия = ДАТАВРЕМЯ(1, 1, 1)
	|	И БанковскиеСчета.Владелец = &Организация
	|	И (НастройкиОбменСБанками.Ссылка ЕСТЬ НЕ NULL 
	|			ИЛИ НастройкиОбменСБанкамиПоБИК.Ссылка ЕСТЬ НЕ NULL )
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет,
	|	БИК";
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция БанковскиеСчетаБезПрямогоОбмена(Организация) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	БанковскиеСчета.Банк КАК Банк,
	|	БанковскиеСчета.Ссылка КАК БанковскийСчет
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Банки КАК Банки
	|		ПО БанковскиеСчета.Банк = Банки.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НастройкиОбменСБанками КАК НастройкиОбменСБанками
	|		ПО БанковскиеСчета.Банк = НастройкиОбменСБанками.Банк
	|			И (БанковскиеСчета.Владелец = &Организация)
	|			И (НЕ НастройкиОбменСБанками.ПометкаУдаления)
	|			И (НЕ НастройкиОбменСБанками.Недействительна)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НастройкиОбменСБанками КАК НастройкиОбменСБанкамиПоБИК
	|		ПО (Банки.Код = НастройкиОбменСБанками.Банк.Код)
	|			И (БанковскиеСчета.Владелец = &Организация)
	|			И (НЕ НастройкиОбменСБанкамиПоБИК.ПометкаУдаления)
	|			И (НЕ НастройкиОбменСБанкамиПоБИК.Недействительна)
	|ГДЕ
	|	НЕ БанковскиеСчета.ПометкаУдаления
	|	И БанковскиеСчета.ДатаЗакрытия = ДАТАВРЕМЯ(1, 1, 1)
	|	И БанковскиеСчета.Владелец = &Организация
	|	И НастройкиОбменСБанками.Ссылка ЕСТЬ NULL
	|	И НастройкиОбменСБанкамиПоБИК.Ссылка ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	Банки.Код";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Возвращает соответствие БИК банков банковских счетов организации с информацией о настройке прямого обмена. 
//
// Параметры:
//  Организация - СправочникСсылка.Организации - ссылка на организацию.
//
// Возвращаемое значение:
//  Соответствие - Ключ - БИК банка, 
//                 Значение - Структура - см. Справочники.БанковскиеСчета.ИнформацияОНастройкеПрямогоОбмена.
//
Функция БИКБанковСИнформациейОНастройкеПрямогоОбмена(Организация) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Банки.Код КАК БИК,
	|	ВЫБОР
	|		КОГДА НастройкиОбменСБанками.Ссылка ЕСТЬ НЕ NULL 
	|				ИЛИ НастройкиОбменСБанкамиПоБИК.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СтатусДиректБанк
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Банки КАК Банки
	|		ПО БанковскиеСчета.Банк = Банки.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НастройкиОбменСБанками КАК НастройкиОбменСБанками
	|		ПО БанковскиеСчета.Банк = НастройкиОбменСБанками.Банк
	|			И (НастройкиОбменСБанками.Организация = &Организация)
	|			И (НЕ НастройкиОбменСБанками.ПометкаУдаления)
	|			И (НЕ НастройкиОбменСБанками.Недействительна)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НастройкиОбменСБанками КАК НастройкиОбменСБанкамиПоБИК
	|		ПО (Банки.Код = НастройкиОбменСБанкамиПоБИК.Банк.Код)
	|			И (НастройкиОбменСБанкамиПоБИК.Организация = &Организация)
	|			И (НЕ НастройкиОбменСБанкамиПоБИК.ПометкаУдаления)
	|			И (НЕ НастройкиОбменСБанкамиПоБИК.Недействительна)
	|ГДЕ
	|	НЕ БанковскиеСчета.ПометкаУдаления
	|	И БанковскиеСчета.ДатаЗакрытия = ДАТАВРЕМЯ(1, 1, 1)
	|	И БанковскиеСчета.Владелец = &Организация
	|
	|СГРУППИРОВАТЬ ПО
	|	Банки.Код,
	|	ВЫБОР
	|		КОГДА НастройкиОбменСБанками.Ссылка ЕСТЬ НЕ NULL 
	|				ИЛИ НастройкиОбменСБанкамиПоБИК.Ссылка ЕСТЬ НЕ NULL 
	|			ТОГДА Истина
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	БИК";
	
	Результат = Новый Соответствие;
    БИКБанковДляПроверки = Новый Соответствие;
	
	УстановитьПривилегированныйРежим(Истина);	
			
	ВыборкаРезультат = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаРезультат.Следующий() Цикл
		
		ИнформацияОНастройкеПрямогоОбмена = СведенияОНастройкеПрямогоОбмена();
		
		ИнформацияОНастройкеПрямогоОбмена.БИК = ВыборкаРезультат.БИК;
		ИнформацияОНастройкеПрямогоОбмена.Настройка = ВыборкаРезультат.СтатусДиректБанк;
		ИнформацияОНастройкеПрямогоОбмена.Рублевый = Ложь;
		ИнформацияОНастройкеПрямогоОбмена.Валютный = Ложь;
		
		БИКБанковДляПроверки.Вставить(ВыборкаРезультат.БИК, ИнформацияОНастройкеПрямогоОбмена);

	КонецЦикла;
	
	// Не для всех БИК банков могли существовать настройки
	// проверяем по макетам возможность прямого обмена
	Для ИндексМакета = 0 По 1 Цикл
		
		Если БИКБанковДляПроверки.Количество() = 0 Тогда
			Прервать;
		КонецЕсли;
		Если ИндексМакета = 0 Тогда 
			ТекущийМакет = ОбменСБанкамиСлужебныйПовтИсп.СписокБанков();
		Иначе
			ТекущийМакет = УчетДенежныхСредствПовтИсп.СписокБанковСВалютнойВыпиской();	
		КонецЕсли;
		
		КоличествоЗаписей = ТекущийМакет.ВысотаТаблицы;
		
		// Первая строка в макете - заголовок	
		Для Индекс = 2 По КоличествоЗаписей Цикл
			
			БИКБанка = ТекущийМакет.Область(Индекс, 2).Текст;
			ИнформацияОНастройкеПрямогоОбмена = БИКБанковДляПроверки.Получить(БИКБанка);
			Если ИнформацияОНастройкеПрямогоОбмена <> Неопределено Тогда
				
				ПроектыВФайлеСтрокой = ТекущийМакет.Область(Индекс, 8).Текст;
				Если ЗначениеЗаполнено(ПроектыВФайлеСтрокой) Тогда 
					МассивПроектовВФайле = СтрРазделить(ПроектыВФайлеСтрокой, ",", Ложь);
					Для каждого ТекПроект из МассивПроектовВФайле Цикл
						Проект = СокрЛП(ТекПроект);
						Если Проект = "1" Тогда
							ИнформацияОНастройкеПрямогоОбмена.Рублевый = Истина;
						ИначеЕсли Проект = "3" Тогда
							ИнформацияОНастройкеПрямогоОбмена.Валютный = Истина;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				Если ИнформацияОНастройкеПрямогоОбмена.Рублевый ИЛИ ИнформацияОНастройкеПрямогоОбмена.Валютный Тогда
					Результат.Вставить(БИКБанка, ИнформацияОНастройкеПрямогоОбмена);
					БИКБанковДляПроверки.Удалить(БИКБанка);
				КонецЕсли;
				
				Если БИКБанковДляПроверки.Количество() = 0 Тогда
					Прервать;	
				КонецЕсли;
								
			КонецЕсли;
			
		КонецЦикла;	
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

// Возвращает структуру с информацией о настройке прямого обмена с банком
//
// Параметры:
//  Организация - СправочникСсылка.Орагнизации - ссылка на организацию
//  Банк - СправочникСсылка.Банки - ссылка на банк
//
// Возвращаемое значение:
//   Структура - см. Справочники.БанковскиеСчета.ПараметрыНастройкиПрямогоОбмена
//
Функция ИнформацияОНастройкеПрямогоОбменаСБанком(Организация, Банк) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЕстьНастройкаПрямогоОбмена = ЗначениеЗаполнено(ОбменСБанками.НастройкаОбмена(Организация, Банк));
	БИКБанка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Банк, "Код");
	ИнформацияОНастройкеПрямогоОбмена = СведенияОНастройкеПрямогоОбмена();
	ИнформацияОНастройкеПрямогоОбмена.Настройка = ЕстьНастройкаПрямогоОбмена;
	ИнформацияОНастройкеПрямогоОбмена.БИК = БИКБанка;
	
	Для ИндексМакета = 0 По 1 Цикл
		
		Если ИнформацияОНастройкеПрямогоОбмена.Рублевый ИЛИ ИнформацияОНастройкеПрямогоОбмена.Валютный Тогда
			Прервать;
		КонецЕсли;
		Если ИндексМакета = 0 Тогда 
			ТекущийМакет = ОбменСБанкамиСлужебныйПовтИсп.СписокБанков();
		Иначе
			ТекущийМакет = УчетДенежныхСредствПовтИсп.СписокБанковСВалютнойВыпиской();	
		КонецЕсли;
		
		КоличествоЗаписей = ТекущийМакет.ВысотаТаблицы;
		
		// Первая строка в макете - заголовок	
		Для Индекс = 2 По КоличествоЗаписей Цикл
			
			Если ИнформацияОНастройкеПрямогоОбмена.БИК = ТекущийМакет.Область(Индекс, 2).Текст Тогда
				
				ПроектыВФайлеСтрокой = ТекущийМакет.Область(Индекс, 8).Текст;
				Если ЗначениеЗаполнено(ПроектыВФайлеСтрокой) Тогда 
					МассивПроектовВФайле = СтрРазделить(ПроектыВФайлеСтрокой, ",", Ложь);
					Для каждого ТекПроект из МассивПроектовВФайле Цикл
						Проект = СокрЛП(ТекПроект);
						Если Проект = "1" Тогда
							ИнформацияОНастройкеПрямогоОбмена.Рублевый = Истина;
						ИначеЕсли Проект = "3" Тогда
							ИнформацияОНастройкеПрямогоОбмена.Валютный = Истина;
						КонецЕсли;
					КонецЦикла;		
				КонецЕсли;
				
				Если ИнформацияОНастройкеПрямогоОбмена.Рублевый ИЛИ ИнформацияОНастройкеПрямогоОбмена.Валютный Тогда
					Прервать;
				КонецЕсли;
												
			КонецЕсли;
			
		КонецЦикла;	
	КонецЦикла;
	
	Возврат ИнформацияОНастройкеПрямогоОбмена; 
	
КонецФункции

// Формирует структуру информации о настройке прямого обмена.
//
// Возвращаемое значение:
//   Структура - содержит поля:
//     * БИК - Строка - БИК Банка.
//     * Настройка - Булево - если Истина, то есть действующая настройка прямого обмена.
//     * Рублевый - Булево - если Истина, то возможен обмен рублевыми платежными документами.
//     * Валютный - Булево - если Истина, то возможен обмен валютными платежными документами.
//
Функция СведенияОНастройкеПрямогоОбмена()
	
	Результат = Новый Структура;
	Результат.Вставить("БИК", "");
	Результат.Вставить("Настройка", Ложь);
	Результат.Вставить("Рублевый", Ложь);
	Результат.Вставить("Валютный", Ложь);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли