&НаКлиентеНаСервереБезКонтекста
Функция КоличествоМесяцевМеждуДатами(ДатаНачала, ДатаОкончания)
	
	МесяцНачала = Месяц(ДатаНачала);
	МесяцОкончания = Месяц(ДатаОкончания);
	ГодовМеждуДатами = Год(ДатаОкончания) - Год(ДатаНачала);
	Возврат МесяцОкончания - МесяцНачала + ГодовМеждуДатами * 12;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьДатуНачала(ДатаНачалаИзДокумента, АктивнаяТаблица = Неопределено) 
	
	Если ЗначениеЗаполнено(ДатаНачалаИзДокумента) Тогда
		ДатаНачала = ДатаНачалаИзДокумента;
	Иначе
		Если ЗначениеЗаполнено(АктивнаяТаблица) Тогда
			Документ = АктивнаяТаблица.Получить(0);
			ДатаНачала = Документ.Период;
		Иначе
			Возврат '00010101';
		КонецЕсли;
	КонецЕсли;
	Возврат ДатаНачала; 
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьДатуОкончания(ДатаОкончанияИзДокумента, ТекДатаСеанса = Неопределено, АктивнаяТаблица = Неопределено)
	
	Если ЗначениеЗаполнено(ДатаОкончанияИзДокумента) Тогда
		ДатаОкончания = ДатаОкончанияИзДокумента;
	Иначе
		Если ЗначениеЗаполнено(АктивнаяТаблица) Тогда
			Документ = АктивнаяТаблица.Получить(АктивнаяТаблица.Количество() - 1);
			ДатаОкончания = Документ.Период;
		Иначе
			Возврат ТекДатаСеанса;
		КонецЕсли;
	КонецЕсли;
	Возврат ДатаОкончания;
	
КонецФункции

&НаСервереБезКонтекста
Функция СсылкаВариантаОтчета(ИмяОтчета, КлючВарианта)
	
	Отчет = ОбщегоНазначения.ИдентификаторОбъектаМетаданных("Отчет." + ИмяОтчета);
	Возврат ВариантыОтчетов.ВариантОтчета(Отчет, КлючВарианта);
	
КонецФункции

&НаКлиенте
Процедура ПерейтиКОтчету()

	Если ВидФинансовогоОтчета = ПредопределенноеЗначение("Перечисление.ВидыФинансовыхОтчетов.ДоходыРасходы") Тогда 
		КольцеваяДиаграмма = КольцеваяДиаграммаДР;
		АктивнаяТаблица = ДоходыИРасходы; 
		СписокДатИзГистограммы = СписокДатИзГистограммыДР;
		Вариант = СсылкаВариантаОтчета("ДоходыИРасходы", "ДоходыИРасходыПоПроектам");		
	Иначе            
		КольцеваяДиаграмма = КольцеваяДиаграммаДП;       
		АктивнаяТаблица = ДенежныйПоток;    
		СписокДатИзГистограммы = СписокДатИзГистограммыДП;
		Вариант = СсылкаВариантаОтчета("ДвижениеДенежныхСредствПоПроектам", "ДвижениеДенежныхСредствПоПроектам");		
	КонецЕсли;      

	Период = Новый СтандартныйПериод;
	ОтборРасшифровки = Новый Структура;
	ОтборРасшифровки.Вставить("Проект", Объект.Ссылка);
	
	Если КольцеваяДиаграмма.ОбластьЗаголовка.Текст = ПолучитьЗаголовокДиаграммы(ВидФинансовогоОтчета) Тогда
		Период.ДатаНачала = ПолучитьДатуНачала(Объект.ДатаНачала, АктивнаяТаблица);
		Период.ДатаОкончания = КонецМесяца(ПолучитьДатуОкончания(Объект.ДатаОкончания, ОбщегоНазначенияКлиент.ДатаСеанса(), АктивнаяТаблица));
	Иначе
		Индекс = СписокДатИзГистограммы.Количество() - 1;
		ДатаИзГистограммы = СписокДатИзГистограммы[Индекс].Значение;
		Период.ДатаНачала = НачалоМесяца(ДатаИзГистограммы);
		Период.ДатаОкончания = КонецМесяца(ДатаИзГистограммы);
	КонецЕсли;
	ОтборРасшифровки.Вставить("СтПериод", Период);
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("СформироватьПриОткрытии", Истина);
	ПараметрыОткрытия.Вставить("Отбор", ОтборРасшифровки); 
	
	ВариантыОтчетовКлиент.ОткрытьФормуОтчета(ЭтаФорма, Вариант, ПараметрыОткрытия);

КонецПроцедуры

&НаСервереБезКонтекста
Функция СимволВалюты()
	
	ВалютаУчета = УправлениеНебольшойФирмойПовтИсп.ПолучитьВалютуУчета();
	
	СимволВалюты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВалютаУчета, "СимвольноеПредставление");
	Если НЕ ЗначениеЗаполнено(СокрЛП(СимволВалюты)) Тогда
		СимволВалюты = Строка(ВалютаУчета);
	КонецЕсли;
	
	Возврат СимволВалюты;
	
КонецФункции

