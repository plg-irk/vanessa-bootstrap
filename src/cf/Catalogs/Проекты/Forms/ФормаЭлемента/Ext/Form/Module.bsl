#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьДополнительныйРеквизит(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТекущийНаборСвойств", НаборСвойств_Справочник_Проекты);
	ПараметрыФормы.Вставить("ЭтоДополнительноеСведение", Ложь);
	
	ОткрытьФорму("ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения.ФормаОбъекта", ПараметрыФормы, , , , , ,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	
	СтруктураДанных = ПолучитьДанныеКонтрагентПриИзменении(Объект.Контрагент);
	Объект.Договор = СтруктураДанных.Договор;
	
КонецПроцедуры

&НаКлиенте
Процедура ДиаграммаВыбор(Элемент, ЗначениеДиаграммы, СтандартнаяОбработка)	
	
	Если ВидФинансовогоОтчета = ПредопределенноеЗначение("Перечисление.ВидыФинансовыхОтчетов.ДоходыРасходы") Тогда 
		Период = СписокДатИзГистограммыДР.НайтиПоЗначению(ЗначениеДиаграммы.Точка.Значение); 
		ТипПериода = ТипПериодаДР;
	Иначе            
        Период = СписокДатИзГистограммыДП.НайтиПоЗначению(ЗначениеДиаграммы.Точка.Значение); 
		ТипПериода = ТипПериодаДП;
	КонецЕсли;
	
	Если ТипПериода = ПредопределенноеЗначение("Перечисление.Периодичность.Квартал") Тогда
		ПерестроитьГистограммуКМесяцам(Период.Значение, Ложь);
	ИначеЕсли ТипПериода = ПредопределенноеЗначение("Перечисление.Периодичность.Год") Тогда
		ПерестроитьГистограммуКМесяцам(Период.Значение, Истина);
	Иначе
		ПерестроитьКольцевуюДиаграмму(Период.Значение, ЗначениеДиаграммы.Серия.Значение);
		Если ВидФинансовогоОтчета = ПредопределенноеЗначение("Перечисление.ВидыФинансовыхОтчетов.ДоходыРасходы") Тогда 
			СписокДатИзГистограммыДР.Добавить(Период.Значение, Период.Представление);
		Иначе            
	        СписокДатИзГистограммыДП.Добавить(Период.Значение, Период.Представление);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДиаграммыНажатие(Элемент)
		
	Если Объект.Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если ВидФинансовогоОтчета = ПредопределенноеЗначение("Перечисление.ВидыФинансовыхОтчетов.ДоходыРасходы") Тогда
		КольцеваяДиаграмма = КольцеваяДиаграммаДР;
		Гистограмма = ГистограммаДР;
		АктивнаяТаблица = ДоходыИРасходы;
		БылаПерестроенаКольцеваяДиаграмма = БылаПерестроенаКольцеваяДиаграммаДР;
	Иначе
		КольцеваяДиаграмма = КольцеваяДиаграммаДП;
		Гистограмма = ГистограммаДП; 
		АктивнаяТаблица = ДенежныйПоток; 
		БылаПерестроенаКольцеваяДиаграмма = БылаПерестроенаКольцеваяДиаграммаДП;
	КонецЕсли;
	
	Если АктивнаяТаблица.Количество() < 1 Тогда
		Возврат;
	КонецЕсли;
	
	КольцеваяДиаграмма.Очистить();
	Гистограмма.Очистить();
	Если БылаПерестроенаКольцеваяДиаграмма Тогда
		КольцеваяДиаграмма.ОбластьЗаголовка.Верх = 0.99;
		КольцеваяДиаграмма.ОбластьЗаголовка.Лево = 0.42;
	КонецЕсли; 
	
	ЗаполнитьДиаграммы(ВидФинансовогоОтчета, Ложь);
	
КонецПроцедуры

