&НаСервере
Процедура УстановитьОформленияБаннераОПереносеСроков() 
	
	Если ТекущаяДатаСеанса() > '20220101' И ТекущаяДатаСеанса() < '20230101' Тогда
		
		Элементы.ДекорацияПереносСроков.Видимость = Истина;
		Элементы.ДекорацияПереносСроков.Заголовок = ТекстБаннераПереносСроковУплатыНалогов(Организация, ТекущаяДатаСеанса());
	ИначеЕсли ТекущаяДатаСеанса() > '20230101' И ТекущаяДатаСеанса() < '20240101' Тогда
		Элементы.ДекорацияПереносСроков.Видимость = Истина;
		Элементы.ДекорацияПереносСроков.Заголовок = ТекстБаннераЕНП();
	Иначе
		Элементы.ДекорацияПереносСроков.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстБаннераПереносСроковУплатыНалогов(Организация, Период)
	
	ТекстЗаголовка = НовыйЗаголовок(НСтр("ru='Перенос сроков уплаты налогов в 2022 году'"));
	ШрифтТекста =  Новый Шрифт(ШрифтыСтиля.ШрифтТекстаБаннера, , 10);
	
	СистемаНалогообложения = РегистрыСведений.СистемыНалогообложенияОрганизаций.ОпределитьСистемуНалогообложенияОрганизации(
		Организация, ТекущаяДатаСеанса());
	ПрименяетсяУСН = СистемаНалогообложения.ПрименяетсяАУСН;
	
	Если ПрименяетсяУСН Тогда
		ТекстПодзаголовка = Новый ФорматированнаяСтрока(
			НовыйСтрокаБаннера(НСтр("ru='В некоторых регионах'"), , ШрифтТекста),
			НовыйСтрокаБаннера(" ", , ШрифтТекста),
			НовыйСтрокаБаннера(НСтр("ru='перенесены'") , ГиперссылкаПереносСроковВРегионах(), ШрифтТекста),
			НовыйСтрокаБаннера(" ", , ШрифтТекста),
			НовыйСтрокаБаннера(НСтр("ru='сроки уплаты налогов, а также для ряда отраслей'"), , ШрифтТекста),
			НовыйСтрокаБаннера(" ", , ШрифтТекста),
			НовыйСтрокаБаннера(НСтр("ru='продлены'"), ГиперссылкаПереносСроковУСН(), ШрифтТекста),
			НовыйСтрокаБаннера(НСтр("ru=' сроки уплаты налога и аванса по УСН'"), , ШрифтТекста));
	Иначе
		ТекстПодзаголовка = Новый ФорматированнаяСтрока(
			НовыйСтрокаБаннера(НСтр("ru='В некоторых регионах'"), , ШрифтТекста),
			НовыйСтрокаБаннера(" ", , ШрифтТекста),
			НовыйСтрокаБаннера(НСтр("ru='перенесены'") , ГиперссылкаПереносСроковВРегионах(), ШрифтТекста),
			НовыйСтрокаБаннера(" ", , ШрифтТекста),
			НовыйСтрокаБаннера(НСтр("ru='сроки уплаты налогов'"), , ШрифтТекста));
	КонецЕсли;
		
	Возврат НовыйТекстБаннера(ТекстЗаголовка, ТекстПодзаголовка)
	
КонецФункции

