&НаСервере
Функция ПолучитьQRКодКлиента(КодКлиента)
	
	QRСтрока = "sbmcs" + ";" + АдресПриложения + ";" + КодКлиента;
	
	ПараметрыШтрихкода = ГенерацияШтрихкода.ПараметрыГенерацииШтрихкода();
	ПараметрыШтрихкода.Ширина = 190;
	ПараметрыШтрихкода.Высота = 190;
	ПараметрыШтрихкода.Штрихкод = QRСтрока;
	ПараметрыШтрихкода.УровеньКоррекцииQR = 0;
	ПараметрыШтрихкода.ТипКода = 16; // QR
	ПараметрыШтрихкода.УбратьЛишнийФон = Истина;
	ПараметрыШтрихкода.ПрозрачныйФон = Ложь;
	
	Попытка
		РезультатФормированияШтрихкода = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода);
		ДвоичныеДанныеКартинки = РезультатФормированияШтрихкода.ДвоичныеДанные;
	Исключение
		ОбщегоНазначенияБПО.ЗаписатьОшибкуВЖурналРегистрации(
			НСтр("ru = 'Ошибка генерации qr-кода'", ОбщегоНазначения.КодОсновногоЯзыка()));
	КонецПопытки;
	
	Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанныеКартинки, УникальныйИдентификатор);
	
КонецФункции // ()

