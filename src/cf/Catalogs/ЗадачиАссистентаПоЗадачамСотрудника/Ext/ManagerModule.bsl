// Получить массив неоткрытых задач сотрудника.
// 
// Параметры:
//  Сотрудник - СправочникСсылка.Сотрудники -  Сотрудник
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка.ЗадачаСотрудника - массив неоткрытых задач сотрудника
Функция ПолучитьМассивНеоткрытыхЗадачСотрудника(Сотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗадачаСотрудника.Ссылка КАК Задача,
	|	ЗадачаСотрудника.Ответственный КАК Ответственный,
	|	СотрудникиПользователя.Пользователь КАК Пользователь
	|ПОМЕСТИТЬ втПользователиСотрудника
	|ИЗ
	|	Документ.ЗадачаСотрудника КАК ЗадачаСотрудника
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СотрудникиПользователя КАК СотрудникиПользователя
	|		ПО ЗадачаСотрудника.Ответственный = СотрудникиПользователя.Сотрудник
	|ГДЕ
	|	ЗадачаСотрудника.Ответственный = &Сотрудник
	|	И ЗадачаСотрудника.ПометкаУдаления = ЛОЖЬ
	|	И ЗадачаСотрудника.ДатаПоследнегоИзменения <> &ПустаяДата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	втПользователиСотрудника.Задача КАК Ссылка
	|ИЗ
	|	втПользователиСотрудника КАК втПользователиСотрудника
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияОткрытийЗадачПользователями КАК ИсторияОткрытийЗадачПользователями
	|		ПО втПользователиСотрудника.Задача = ИсторияОткрытийЗадачПользователями.Задача
	|			И втПользователиСотрудника.Пользователь = ИсторияОткрытийЗадачПользователями.Пользователь
	|ГДЕ
	|	ИсторияОткрытийЗадачПользователями.ДатаОткрытияЗадачи ЕСТЬ NULL";
	Запрос.УстановитьПараметр("Сотрудник",  Сотрудник);
	Запрос.УстановитьПараметр("ПустаяДата", Дата(1,1,1));	                           

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции    

// Получить массив приближающихся задач сотрудника.
// 
// Параметры:
//  Сотрудник - СправочникСсылка.Сотрудники -  Сотрудник
// 
// Возвращаемое значение:
//  Массив из  ДокументСсылка.ЗадачаСотрудника - массив приближающихся задач сотрудника
Функция ПолучитьМассивПриближающихсяЗадачСотрудника(Сотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗадачаСотрудника.Ответственный КАК Ответственный,
	|	ЗадачаСотрудника.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗадачаСотрудника КАК ЗадачаСотрудника
	|ГДЕ
	|	ЗадачаСотрудника.Ответственный = &Сотрудник
	|	И ЗадачаСотрудника.ДатаНачала <> &ПустаяДата
	|	И ЗадачаСотрудника.ПометкаУдаления = ЛОЖЬ
	|	И ЗадачаСотрудника.ДатаНачала >= &ДатаСегодня
	|	И ЗадачаСотрудника.ДатаНачала <= &КонецДня";
	Запрос.УстановитьПараметр("Сотрудник",  Сотрудник);
	Запрос.УстановитьПараметр("ПустаяДата", Дата(1,1,1));	                           
	Запрос.УстановитьПараметр("ДатаСегодня", НачалоДня(ТекущаяДатаСеанса()));	                           
	Запрос.УстановитьПараметр("КонецДня", КонецДня(ТекущаяДатаСеанса()));	                           

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции


#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗапланироватьЗадачиКВыполнению(НовыеЗадачиКВыполнению, ВыбранныеЗадачиАссистента) Экспорт
	
	СекундВЧасе = 3600;
	СекундВСутках = 86400;
	ВремяОтправленияЗадач = НачалоДня(ТекущаяДатаСеанса()) + СекундВСутках + ВремяОтправленияЗадач() * СекундВЧасе;
	
	Для каждого ЗадачаАссистента Из ВыбранныеЗадачиАссистента Цикл
		НоваяЗадача = НовыеЗадачиКВыполнению.Добавить();
		НоваяЗадача.Дата = ВремяОтправленияЗадач;
		НоваяЗадача.Задача = ЗадачаАссистента; 
	КонецЦикла;
	
КонецПроцедуры

Процедура ПоприветствоватьПользователяПриЗаписиПервыхЗадач(ЗадачиАссистента) Экспорт
	
	АссистентПодключен = АссистентУправления.Подключен();
	Если Не АссистентПодключен Тогда
		АссистентУправления.Подключить();
	КонецЕсли;
	
	Для каждого ЗадачаАссистента Из ЗадачиАссистента Цикл
		ЗадачаОбъект = ЗадачаАссистента.ПолучитьОбъект();
		ЗадачаОбъект.ПоприветствоватьПользователяПередПервымВыполнением();
	КонецЦикла;
	
КонецПроцедуры

Функция ВремяОтправленияЗадач() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЗадачиАссистентаПоЗадачамСотрудника.ВремяОтправления КАК ВремяОтправления
	|ИЗ
	|	Справочник.ЗадачиАссистентаПоЗадачамСотрудника КАК ЗадачиАссистентаПоЗадачамСотрудника";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеЗадачи = Результат.Выбрать();
	ДанныеЗадачи.Следующий();
	Возврат ДанныеЗадачи.ВремяОтправления;
	
КонецФункции

#КонецОбласти

#КонецЕсли