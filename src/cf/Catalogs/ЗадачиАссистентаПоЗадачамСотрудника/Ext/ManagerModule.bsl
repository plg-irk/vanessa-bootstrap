// Получить массив активных задач сотрудника.
// 
// Параметры:
//  Сотрудник - СправочникСсылка.Сотрудники -  Сотрудник
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка.ЗадачаСотрудника - массив активных задач сотрудника
Функция ПолучитьМассивАктивныхЗадачСотрудника(Сотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗадачаСотрудника.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗадачаСотрудника КАК ЗадачаСотрудника
	|ГДЕ
	|	ЗадачаСотрудника.Ответственный = &Сотрудник
	|	И ЗадачаСотрудника.ПометкаУдаления = ЛОЖЬ
	|	И ЗадачаСотрудника.Выполнена = ЛОЖЬ"; 
 	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции         

// Получить массив просроченных задач сотрудника.
// 
// Параметры:
//  Сотрудник - СправочникСсылка.Сотрудники -  Сотрудник
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка.ЗадачаСотрудника - массив просроченных задач сотрудника
Функция ПолучитьМассивПросроченныхЗадачСотрудника(Сотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗадачаСотрудника.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗадачаСотрудника КАК ЗадачаСотрудника
	|ГДЕ
	|	ЗадачаСотрудника.Ответственный = &Сотрудник
	|	И ЗадачаСотрудника.ДатаНачала <> &ПустаяДата
	|	И ЗадачаСотрудника.ДатаОкончания <> &ПустаяДата
	|	И ЗадачаСотрудника.ПометкаУдаления = ЛОЖЬ
	|	И ЗадачаСотрудника.Выполнена = ЛОЖЬ
	|	И ЗадачаСотрудника.ДатаОкончания < &ТекДата";
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("ПустаяДата", Дата(1,1,1));
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции  

// Получить массив новых задач сотрудника.
// 
// Параметры:
//  Сотрудник - СправочникСсылка.Сотрудники -  Сотрудник
// 
// Возвращаемое значение:
//  Массив из ДокументСсылка.ЗадачаСотрудника - массив новых задач сотрудника
Функция ПолучитьМассивНовыхЗадачСотрудника(Сотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗадачаСотрудника.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗадачаСотрудника КАК ЗадачаСотрудника
	|ГДЕ
	|	ЗадачаСотрудника.Ответственный = &Сотрудник
	|	И ЗадачаСотрудника.Дата >= &ДатаВчера
	|	И ЗадачаСотрудника.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("ДатаВчера", НачалоДня(НачалоДня(ТекущаяДатаСеанса())-1));

	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

