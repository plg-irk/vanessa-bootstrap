// Возвращает Истина, если есть включенные задачи по напоминаниям о записи
// 
// Возвращаемое значение:
//  Булево
//
Функция ЕстьЗадачиВРаботеПросроченные() Экспорт
	
	МассивИдентификаторов = Новый Массив;
	МассивИдентификаторов.Добавить("ОповеститьСотрудникаОПросроченныхЗадачахПоEmail");
	МассивИдентификаторов.Добавить("ОповеститьСотрудникаОПросроченныхЗадачахВОбсуждении");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЗадачиАссистентаПоЗадачамСотрудника.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ЗадачиАссистентаПоЗадачамСотрудника КАК ЗадачиАссистентаПоЗадачамСотрудника
	|ГДЕ
	|	НЕ ЗадачиАссистентаПоЗадачамСотрудника.ПометкаУдаления
	|	И ЗадачиАссистентаПоЗадачамСотрудника.Используется
	|	И ЗадачиАссистентаПоЗадачамСотрудника.Идентификатор В (&МассивИдентификаторов)";
	Запрос.УстановитьПараметр("МассивИдентификаторов", МассивИдентификаторов);	
	Результат = Запрос.Выполнить();
	Возврат НЕ Результат.Пустой();
	
КонецФункции

