#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьЗадание = Ложь;
	
	Если ЭтоНовый() Тогда
		ОбновитьЗадание = Истина;
	Иначе
		ОтражениеВключеноТекущее = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ОтражениеВключено");
		Если ОтражениеВключеноТекущее <> ОтражениеВключено Тогда
			ОбновитьЗадание = Истина;
		КонецЕсли;
	КонецЕсли; 
	
	Если ОбновитьЗадание Тогда
		ОписаниеОбработчика = СовместноеИспользование.ОбработчикЗаданияОбновленияДанных();
		
	    ПараметрыЗадания = Новый Структура;
		ПараметрыЗадания.Вставить("ОбластьДанных", РаботаВМоделиСервиса.ЗначениеРазделителяСеанса());
		ПараметрыЗадания.Вставить("ИмяМетода", ОписаниеОбработчика.ИмяМетода);
		ПараметрыЗадания.Вставить("Использование", Истина);
		
		ЗаданияОбновления = ОчередьЗаданий.ПолучитьЗадания(ПараметрыЗадания);
		
		Если ОтражениеВключено Тогда
			Если ЗаданияОбновления.Количество() = 0 Тогда
				ПараметрыЗадания.Вставить("Расписание", ОписаниеОбработчика.РасписаниеПоУмолчанию);
				
				ОчередьЗаданий.ДобавитьЗадание(ПараметрыЗадания);
			КонецЕсли;
		Иначе
			Для Каждого ОписаниеЗадания Из ЗаданияОбновления Цикл
				ОчередьЗаданий.УдалитьЗадание(ОписаниеЗадания.Идентификатор);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли