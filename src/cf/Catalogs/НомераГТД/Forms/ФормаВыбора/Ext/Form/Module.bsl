
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СформироватьОтборНомеровГТД();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПолучитьНомераГТД(УсловияОтбора)
	
	УсловияОтбора.Вставить("Организация");
	УсловияОтбора.Вставить("Номенклатура");
	УсловияОтбора.Вставить("Характеристика");
	УсловияОтбора.Вставить("Партия");
	УсловияОтбора.Вставить("СтранаПроисхождения");
	УсловияОтбора.Вставить("ПоддержкаИнтеркампани");
	ЗаполнитьЗначенияСвойств(УсловияОтбора, Параметры);
	
	Если Не Параметры.Свойство("Характеристика") Тогда
		УсловияОтбора.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	Если Не Параметры.Свойство("Партия") Тогда
		УсловияОтбора.Партия = Справочники.ПартииНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	
	Если Не Параметры.Свойство("ПоддержкаИнтеркампани") Тогда
		УсловияОтбора.ПоддержкаИнтеркампани = Истина;
	КонецЕсли;
	
	Возврат Справочники.НомераГТД.ПолучитьМассивИспользуемыхНомеровГТД(УсловияОтбора);
	
КонецФункции

&НаСервере
Процедура СформироватьОтборНомеровГТД()
	
	УсловияОтбора = Новый Структура;
	
	МассивГТД = ПолучитьНомераГТД(УсловияОтбора);
	
	Элементы.Остаток.Видимость = Параметры.Свойство("Номенклатура") И ЗначениеЗаполнено(Параметры.Номенклатура) И МассивГТД.Количество() > 0;
	Элементы.ЕдиницаИзмерения.Видимость = Элементы.Остаток.Видимость;
	
	Если Элементы.Остаток.Видимость Тогда
		УстановитьПараметрСписка(Список, "ЕдиницаИзмерения", Параметры.Номенклатура.ЕдиницаИзмерения);
	Иначе
		УстановитьПараметрСписка(Список, "ЕдиницаИзмерения", Неопределено);
	КонецЕсли;
	
	Если МассивГТД.Количество() > 0 Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, "Ссылка", МассивГТД,
			ВидСравненияКомпоновкиДанных.ВСписке, НСтр("ru = 'Отбор по номеру ГТД'"), Истина,
			РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный);
			
		УстановитьПараметрСписка(Список, "Организация", УсловияОтбора.Организация);
		УстановитьПараметрСписка(Список, "Номенклатура", УсловияОтбора.Номенклатура);
		УстановитьПараметрСписка(Список, "Характеристика", УсловияОтбора.Характеристика);
		УстановитьПараметрСписка(Список, "Партия", УсловияОтбора.Партия);
		УстановитьПараметрСписка(Список, "СтранаПроисхождения", УсловияОтбора.СтранаПроисхождения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрСписка(Список, ИмяПараметра, ЗначениеПараметра)
	
	Если Список.Параметры.Элементы.Найти(ИмяПараметра)<>Неопределено Тогда
		Список.Параметры.УстановитьЗначениеПараметра(ИмяПараметра, ЗначениеПараметра);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
