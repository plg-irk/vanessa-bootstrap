
#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ОткрытьФорму(
	"Справочник.Организации.Форма.ФормаРедактированияСчетовУчета",
	СтруктураПараметров(ПараметрКоманды),
	ПараметрыВыполненияКоманды.Источник,
	ПараметрыВыполненияКоманды.Уникальность,
	ПараметрыВыполненияКоманды.Окно,
	ПараметрыВыполненияКоманды.НавигационнаяСсылка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция СтруктураПараметров(ПараметрКоманды)
	
	Результат = Новый Структура;
	Результат.Вставить("СчетУчетаЛичныхСредствПредпринимателя", ПараметрКоманды.СчетУчетаЛичныхСредствПредпринимателя);
	Результат.Вставить("Ссылка", ПараметрКоманды.Ссылка);
	Результат.Вставить("ЭтоЮрЛицо", Справочники.Организации.ЭтоЮрЛицо(ПараметрКоманды.Ссылка));
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти
