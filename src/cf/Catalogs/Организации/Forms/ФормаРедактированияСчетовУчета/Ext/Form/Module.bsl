
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СчетУчетаЛичныхСредствПредпринимателя = Параметры.СчетУчетаЛичныхСредствПредпринимателя;
	Организация = Параметры.Ссылка;
	
	Если Параметры.ЭтоЮрЛицо Тогда
		Элементы.ЗапретРедактированияСчетУчетаЛичныхСредствПредпринимателяНеИП.Видимость = Истина;
		Элементы.ГруппаСчетУчетаЛичныхСредствПредпринимателя.Видимость = Ложь;
		Элементы.ПоУмолчанию.Видимость = Ложь;
		Возврат;
	КонецЕсли;
		
	Если ОтказИзменитьСчетУчетаЛичныхСредствПредпринимателя() Тогда
		Элементы.ЗапретРедактированияСчетУчетаЛичныхСредствПредпринимателя.Видимость = Истина;
		Элементы.ГруппаСчетУчетаЛичныхСредствПредпринимателя.ТолькоПросмотр = Истина;
	КонецЕсли;
		
	Если Не ПравоДоступа("Редактирование", Организация.Метаданные()) Тогда
		Элементы.ГруппаСчетУчетаЛичныхСредствПредпринимателя.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Если Элементы.ГруппаСчетУчетаЛичныхСредствПредпринимателя.ТолькоПросмотр Тогда
		Элементы.ПоУмолчанию.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура СчетУчетаЛичныхСредствПредпринимателяПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(СчетУчетаЛичныхСредствПредпринимателя) Тогда
		СчетУчетаЛичныхСредствПредпринимателя = ПредопределенноеЗначение("ПланСчетов.Управленческий.НераспределеннаяПрибыль");
	КонецЕсли;
	ОповеститьОбИзмененииСчетовРасчетов();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПоУмолчанию(Команда)
	
	Если Не Элементы.ГруппаСчетУчетаЛичныхСредствПредпринимателя.ТолькоПросмотр Тогда
		СчетУчетаЛичныхСредствПредпринимателя = ПредопределенноеЗначение("ПланСчетов.Управленческий.НераспределеннаяПрибыль");
	КонецЕсли;
	
	ОповеститьОбИзмененииСчетовРасчетов();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ОтказИзменитьСчетУчетаЛичныхСредствПредпринимателя()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РасходыПредпринимателя.Организация КАК Организация
	|ИЗ
	|	Документ.РасходыПредпринимателя КАК РасходыПредпринимателя
	|ГДЕ
	|	РасходыПредпринимателя.Организация = &Организация");
	
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Результат = Запрос.Выполнить();
	
	Возврат НЕ Результат.Пустой();
	
КонецФункции

&НаКлиенте
Процедура ОповеститьОбИзмененииСчетовРасчетов()
	
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("СчетУчетаЛичныхСредствПредпринимателя", СчетУчетаЛичныхСредствПредпринимателя);
	
	Оповестить("ИзменилисьСчетаРасчетов", СтруктураПараметры, Организация);
	
КонецПроцедуры

#КонецОбласти
