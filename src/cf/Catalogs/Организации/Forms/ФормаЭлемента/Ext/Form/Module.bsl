// Процедура устанавливает заголовок свернутого отображения для группы, по шаблону:
// <заголовок группы (как задан в конфигураторе)> : <динамический параметр 1>, <динамический параметр 2>
//
// Параметры:
//  Форма					 - Форма	 - текущая форма
//  НазваниеГруппы			 - Строка	 - имя группы формы, для которой устанавливается заголовок
//  ДинамическиеПараметры	 - Массив из Строка - массив частей заголовка.
//
&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокСвернутогоОтображения(Форма, НазваниеГруппы, ДинамическиеПараметры)

	ЗаголовокТекст = Форма.Элементы[НазваниеГруппы].Заголовок;
	Если ДинамическиеПараметры.Количество() > 0 Тогда
		ЗаголовокТекст = ЗаголовокТекст + ": ";
		Для Каждого Параметр Из ДинамическиеПараметры Цикл
			ЗаголовокТекст = ЗаголовокТекст + Параметр + ", ";
		КонецЦикла;
		СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ЗаголовокТекст, 2);
	КонецЕсли;

	Форма.Элементы[НазваниеГруппы].ЗаголовокСвернутогоОтображения = ЗаголовокТекст;
	
	Если НазваниеГруппы = "ГруппаАкцизы" И ДинамическиеПараметры.Количество() > 0 Тогда
		ЗаголовокТекст = СтрЗаменить(ЗаголовокТекст, "Акцизы:", "Настроены для:");
		Форма.Элементы.ДекорацияФормаНастройкиАкцизов.Заголовок = ЗаголовокТекст;
	КонецЕсли;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокТерриториальныеУсловия(Форма)

	ДинамическиеПараметры = Новый Массив;
	
	Объект = Форма.Объект;
	Если Объект.ПрименятьРайонныйКоэффициент Тогда
		ТекстКоэффициент = "";
		Если Объект.РайонныйКоэффициент = Объект.РайонныйКоэффициентРФ И Объект.РайонныйКоэффициент <> 1 Тогда
			ТекстКоэффициент = Строка(Объект.РайонныйКоэффициент);
		Иначе
			СтрокиКоэффициенты = Новый Массив;
			Если Объект.РайонныйКоэффициент <> 1 Тогда
				СтрокиКоэффициенты.Добавить(СтрШаблон(НСтр("ru = '%1 (местный)'"), Объект.РайонныйКоэффициент));
			КонецЕсли;
			
			Если Объект.РайонныйКоэффициентРФ <> 1 Тогда
				СтрокиКоэффициенты.Добавить(СтрШаблон(НСтр("ru = '%1 (федеральный)'"), Объект.РайонныйКоэффициентРФ));
			КонецЕсли;
		
			Если СтрокиКоэффициенты.Количество() > 0 Тогда
				ТекстКоэффициент = СтрСоединить(СтрокиКоэффициенты, ", ");
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекстКоэффициент) Тогда
			ШаблонКоэффициенты = НСтр("ru = 'Районный коэффициент: %1'");
			ДинамическиеПараметры.Добавить(СтрШаблон(ШаблонКоэффициенты, ТекстКоэффициент));
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Форма.ТерриториальныеУсловияПФР.ТерриториальныеУсловияПФР) Тогда
		Если Объект.ПрименятьСевернуюНадбавку Тогда
			ШаблонСевернаяНадбавка = НСтр("ru = 'Северная надбавка, особые условия: %1'");
		Иначе
			ШаблонСевернаяНадбавка = НСтр("ru = 'Особые условия: %1'");
		КонецЕсли;
		ДинамическиеПараметры.Добавить(СтрШаблон(ШаблонСевернаяНадбавка, Форма.ТерриториальныеУсловияПФР.ТерриториальныеУсловияПФР));
	КонецЕсли;
	
	Если ДинамическиеПараметры.Количество() = 0 Тогда
		ДинамическиеПараметры.Добавить(НСтр("ru = '<Без особенностей>'"));
	КонецЕсли;
	
	Форма.Элементы.ГруппаТерриториальныеУсловияДетали.Заголовок = СтрСоединить(ДинамическиеПараметры, ", ");

КонецПроцедуры

