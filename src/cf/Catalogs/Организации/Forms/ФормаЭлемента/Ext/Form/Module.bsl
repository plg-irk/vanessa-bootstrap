&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокКонтактнойИнформации(Форма)
	
	Если Не Форма.КонтактнаяИнформацияПроинициализирована Тогда
		Возврат;
	КонецЕсли;
	
	ДинамическиеПараметры = Новый Массив;
	
	Если Форма.Объект.КонтактнаяИнформация.Количество() <> 0 Тогда
		ВидКИ = ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации");
		ПредставленияКИ = УправлениеКонтактнойИнформациейУНФКлиентСервер.ПолучитьПредставлениеКонтактнойИнформации(Форма, ВидКИ);
		Если ПредставленияКИ.Количество() <> 0 И ЗначениеЗаполнено(ПредставленияКИ[0]) Тогда
			ПредставлениеАдреса = ПредставленияКИ[0];
			ДинамическиеПараметры.Добавить(ПредставлениеАдреса);
		КонецЕсли;
		
		ВидКИ = ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонОрганизации");
		ПредставленияКИ = УправлениеКонтактнойИнформациейУНФКлиентСервер.ПолучитьПредставлениеКонтактнойИнформации(Форма, ВидКИ);
		Если ПредставленияКИ.Количество() <> 0 И ЗначениеЗаполнено(ПредставленияКИ[0]) Тогда
			ПредставлениеТелефона = НСтр("ru='тел.: %1'");
			ПредставлениеТелефона = СтрШаблон(ПредставлениеТелефона, ПредставленияКИ[0]);
			ДинамическиеПараметры.Добавить(ПредставлениеТелефона);
		КонецЕсли;
	КонецЕсли;
	
	УстановитьЗаголовокСвернутогоОтображения(Форма, "КонтактнаяИнформация", ДинамическиеПараметры);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокНалогообложения(Форма)

	Объект = Форма.КлючСистемыНалогообложения;
	ДинамическиеПараметры = Новый Массив;
	Если ЭтоЮрЛицо(Форма.Объект.ЮридическоеФизическоеЛицо) Тогда
		НадписьСтавка = "";
	Иначе
		НадписьСтавка =  ?(Не ПустаяСтрока(Объект.СтавкаНалога), " - " + Объект.СтавкаНалога + "%", "");
	КонецЕсли;

	Если Объект.ПлательщикУСН Тогда
		ДинамическиеПараметры.Добавить(НСтр("ru='УСН'") + НадписьСтавка);
	КонецЕсли;
	
	Если Объект.ПрименяетсяАУСН Тогда
		ДинамическиеПараметры.Добавить(НСтр("ru='АУСН'") + НадписьСтавка);
	КонецЕсли;
	
	Если Объект.ПлательщикЕНВД Тогда
		ДинамическиеПараметры.Добавить(НСтр("ru='ЕНВД'"));
	КонецЕсли;

	Если Объект.ПрименяетсяПатент Тогда
		ДинамическиеПараметры.Добавить(НСтр("ru='Патент'"));
	КонецЕсли;

	Если Объект.ПлательщикТорговыйСбор Тогда
		ДинамическиеПараметры.Добавить(НСтр("ru='Торговый сбор'"));
	КонецЕсли;

	УстановитьЗаголовокСвернутогоОтображения(Форма, "Налогообложение", ДинамическиеПараметры);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовокУСНСтавкаНДС(Форма)
	
	ДатаПримененияНДС = Форма.ДатаПримененияНДС;

	ДинамическиеПараметры = Новый Массив;
	
	ВыбраннаяСтавка = Форма.КлючНастройкиНДС.СтавкаНалогообложенияПриУСН;
	
	Если ВыбраннаяСтавка = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.ПониженнаяУСН") Тогда
		ТекстСтавка = СтрШаблон("%1 (при доходе до %2 млн рублей)",
		УчетНДСКлиентСервер.ПониженнаяУСНСтавкаНДС(ДатаПримененияНДС), УчетНДСКлиентСервер.ПорогПримененияПониженнойСтавкиНДСПриУСН(ДатаПримененияНДС));
	ИначеЕсли ВыбраннаяСтавка = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.ОбщаяУСН") Тогда
		ТекстСтавка = СтрШаблон("%1 (при доходе до %2 млн рублей)",
		УчетНДСКлиентСервер.ОбщаяУСНСтавкаНДС(ДатаПримененияНДС), УчетНДСКлиентСервер.ПорогПримененияОбщейСтавкиНДСПриУСН(ДатаПримененияНДС));
	ИначеЕсли ВыбраннаяСтавка = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.Общая") Тогда
		ТекстСтавка = СтрШаблон("%1 (при доходе свыше %2 млн рублей или добровольно, с правом на вычет)",
		УчетНДСКлиентСервер.ОбщаяСтавкаНДС(ДатаПримененияНДС), УчетНДСКлиентСервер.ПорогПримененияОбщейСтавкиНДСПриУСН(ДатаПримененияНДС));
	Иначе
		ТекстСтавка = "";
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ТекстСтавка) Тогда
		ДинамическиеПараметры.Добавить(ТекстСтавка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Форма.КлючНастройкиНДС.Период) Тогда
		ТекстНачало = СтрШаблон(НСтр("ru = 'с %1'"), Формат(Форма.КлючНастройкиНДС.Период, "ДЛФ=D"));
		ДинамическиеПараметры.Добавить(ТекстНачало);
	КонецЕсли;
	
	Если ДинамическиеПараметры.Количество() = 0 Тогда
		ДинамическиеПараметры.Добавить(НСтр("ru = '<Не указана>'"));
	КонецЕсли;
	
	Форма.Элементы.ГруппаСтавкаНДСУСН.Заголовок = СтрСоединить(ДинамическиеПараметры, ", ");
	
КонецПроцедуры

