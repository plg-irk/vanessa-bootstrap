		ДинамическиеПараметры.Добавить(НСтр("ru='КПП'") + " " + Объект.КПП);
	КонецЕсли;

	Если Не ПустаяСтрока(Объект.ОГРН) Тогда
		Если Объект.ЮридическоеФизическоеЛицо = ПредопределенноеЗначение(
