			КлючТарифаСтраховыхВзносов.Период = '20000101';
		КонецЕсли;
		УстановитьПодсказкуПоТарифу();
		ОбновитьОтображениеДанных();
	Иначе
		Элементы.ДекорацияОписаниеТарифа.Заголовок = "";
	КонецЕсли;
	ПроверитьЗаполнениеЭлемента(Элемент.Имя);

КонецПроцедуры

