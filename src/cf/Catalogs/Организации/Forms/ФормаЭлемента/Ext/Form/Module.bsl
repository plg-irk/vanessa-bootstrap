		Элементы.ОГРН.ПодсказкаВвода		= НСтр("ru = '13 цифр'");
		Элементы.ОГРН.ОграничениеТипа		= Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(13));
		Элементы.КодПоОКПО.ПодсказкаВвода	= НСтр("ru = '8 цифр'");
		Элементы.КодПоОКПО.ОграничениеТипа	= Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(8));
		
		Элементы.Налоговая.Видимость				= Истина; //для прослеживаемости
		Элементы.ГруппаКодыРосстатаКоды.Видимость	= Ложь;
		Элементы.ГруппаПФР.Видимость				= Ложь;
		Элементы.ГруппаСФР.Видимость				= Ложь;
		Элементы.ГруппаФСС.Видимость				= Ложь;
		Элементы.ПлательщикЕНВДГруппа.Видимость		= Ложь;
		Элементы.ИспользуетсяОтчетность.Видимость	= Ложь;
		Элементы.ПлательщикУСНГруппа.Видимость		= Форма.КлючСистемыНалогообложения.ПлательщикУСН 
		ИЛИ Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН;  
		Элементы.ПовышеннаяСтавкаНалога.Видимость = Форма.КлючСистемыНалогообложения.ПлательщикУСН;
		Элементы.ДекорацияПроцент.Видимость = Форма.КлючСистемыНалогообложения.ПлательщикУСН;
		Элементы.ГруппаПатент.Видимость 			= Ложь;
		Элементы.ПрименяетсяПатентГруппа.Видимость 	= Ложь;
		Элементы.ПлательщикТорговыйСборГруппа.Видимость = Ложь;
		Элементы.ГруппаТорговыйСборИстория.Видимость= Ложь;
		Элементы.ПродажиСлабогоАлкоголяГруппа.Видимость= Ложь;
		Элементы.ПострадавшаяИзРеестраМСП.Видимость = Ложь;
		Элементы.ПоддержкаИП.Видимость = Ложь;
		Объект.ИспользуетсяОтчетность = Ложь;

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ИНН", "Доступность",
			Не ЗначениеЗаполнено(Объект.ГоловнаяОрганизация) ИЛИ Объект.ГоловнаяОрганизация = Объект.Ссылка);
		
		Если Форма.ОтображатьРеквизитыНалогообложенияОрганизации Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
				"ЦифровойИндексОбособленногоПодразделения", "Видимость", ЗначениеЗаполнено(Объект.ГоловнаяОрганизация)
				И Не Объект.ГоловнаяОрганизация = Объект.Ссылка);
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
				"ЦифровойИндексОбособленногоПодразделения", "Видимость", Ложь);
		КонецЕсли;
		
		Элементы.ПодписьРуководителя.Заголовок = НСтр("ru = 'Подпись руководителя'");
		Элементы.ПодписьГлавногоБухгалтера.Видимость = Истина;
		
		// БЗКБ
		Элементы.НДФЛГруппа.Видимость = Ложь;
		// БЗКБ 
	Иначе

		Элементы.ГруппаФИО.Видимость							= Истина;
		Элементы.КПП.Видимость									= Ложь;
		Элементы.СвидетельствоСерияНомер.Видимость				= Истина;
		Элементы.СвидетельствоДатаВыдачи.Видимость				= Истина;
		Элементы.ГруппаДанныеПФР_ИП.Видимость					= Истина;
		Элементы.ГруппаФСС.Видимость							= Объект.ИПИспользуетТрудНаемныхРаботников;
		Элементы.РегистрационныйНомерПФР.Видимость				= Объект.ИПИспользуетТрудНаемныхРаботников;
		Элементы.ГруппаИмеютсяСотрудники.Видимость				= Истина;
		Элементы.СвидетельствоСерияНомер.Видимость				= Истина;
		Элементы.СвидетельствоДатаВыдачи.Видимость				= Истина;
		Элементы.ГруппаДокументУдостоверяющийЛичность.Видимость	= Истина;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Гражданство", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Пол", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДатаРождения", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ИНН", "ПодсказкаВвода", НСтр(
			"ru = '12 цифр'"));
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ИНН", "ОграничениеТипа",
			Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(12)));
		
		Элементы.ОГРН.Заголовок				= НСтр("ru = 'ОГРН ИП'");
		Элементы.ОГРН.Подсказка 			= НСтр("ru = 'Основной государственный регистрационный номер индивидуального предпринимателя, 
												   |указан в Свидетельстве о государственной регистрации физического лица в качестве ИП'");
		Элементы.ОГРН.ПодсказкаВвода		= НСтр("ru = '15 цифр'");
		Элементы.ОГРН.ОграничениеТипа		= Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(15));
		Элементы.КодПоОКПО.ПодсказкаВвода	= НСтр("ru = '10 цифр'");
		Элементы.КодПоОКПО.ОграничениеТипа	= Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10));

		Элементы.Налоговая.Видимость				= Истина;
		Элементы.ГруппаКодыРосстатаКоды.Видимость	= Истина;
		Элементы.ГруппаПФР.Видимость				= Истина;
		Элементы.ГруппаСФР.Видимость				= Истина;
		Элементы.ГруппаПатент.Видимость 			= Истина;
		Элементы.ПлательщикУСНГруппа.Видимость		= Форма.КлючСистемыНалогообложения.ПлательщикУСН
		ИЛИ Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН;   
		Элементы.ПовышеннаяСтавкаНалога.Видимость = Форма.КлючСистемыНалогообложения.ПлательщикУСН;
		Элементы.ДекорацияПроцент.Видимость = Форма.КлючСистемыНалогообложения.ПлательщикУСН;
		Элементы.ПлательщикЕНВДГруппа.Видимость		= Форма.КлючСистемыНалогообложения.ПлательщикЕНВД;
		Элементы.ИспользуетсяОтчетность.Видимость	= (Форма.КлючСистемыНалогообложения.ПлательщикЕНВД
			Или Форма.КлючСистемыНалогообложения.ПлательщикУСН Или Форма.КлючСистемыНалогообложения.ПрименяетсяПатент
			ИЛИ Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН) И Форма.ДоступнаОтчетность;
		Элементы.ПрименяетсяПатент.Видимость 		= Форма.КлючСистемыНалогообложения.СистемаНалогообложения
			<> ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.ОсобыйПорядок") 
			И Форма.КлючСистемыНалогообложения.СистемаНалогообложения
			<> ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.АУСН");
		Элементы.ПрименяетсяПатентГруппа.Видимость	= Форма.КлючСистемыНалогообложения.ПрименяетсяПатент;
		Элементы.ГруппаТорговыйСборИстория.Видимость = Истина;
		Элементы.ПлательщикТорговыйСборГруппа.Видимость= Форма.КлючСистемыНалогообложения.ПлательщикТорговыйСбор;
		Элементы.ПродажиСлабогоАлкоголяГруппа.Видимость= Истина;
		Элементы.ПострадавшаяИзРеестраМСП.Видимость = Истина;
		Элементы.ПоддержкаИП.Видимость = Истина;
		
		Элементы.ПодписьРуководителя.Заголовок = НСтр("ru = 'Подпись предпринимателя'");
		Элементы.ПодписьГлавногоБухгалтера.Видимость = Ложь;
		
		// БЗКБ
		Элементы.НДФЛГруппа.Видимость = Объект.ИПИспользуетТрудНаемныхРаботников;
		// БЗКБ
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
			"ЦифровойИндексОбособленногоПодразделения", "Видимость", Ложь);
		
	КонецЕсли;
	
	Если НЕ Форма.ОтображатьРеквизитыНалогообложенияОрганизации Тогда
		Элементы.ГруппаПФР.Видимость = Ложь;
		Элементы.Налоговая.Видимость = Ложь;
		Элементы.ГруппаДокументУдостоверяющийЛичность.Видимость = Ложь;
		Элементы.Гражданство.Видимость = Ложь;
		Элементы.Пол.Видимость = Ложь;
		Элементы.ДатаРождения.Видимость = Ложь;
	КонецЕсли;
	
	// БЗКБ
	ИспользоватьРеглУчетЗарплаты = НЕ ЭтоЮридическоеЛицо И Объект.ИспользуетсяОтчетность
		И Объект.ИПИспользуетТрудНаемныхРаботников;
	Элементы.ГруппаВыплатаЗарплатыИАванса.Видимость = ИспользоватьРеглУчетЗарплаты;	
	Элементы.ГруппаВзносыРегламентированныйУчет.Видимость = ИспользоватьРеглУчетЗарплаты;
	ЗаголовокВзносыУпрУчет = НСтр("ru = 'Взносы'");
	Элементы.ГруппаВзносыУправленческийУчет.Заголовок = ?(Элементы.ГруппаВзносыРегламентированныйУчет.Видимость,
		СтрШаблон("%1 (%2)", ЗаголовокВзносыУпрУчет, НСтр("ru = 'управленческий учет'")),
		ЗаголовокВзносыУпрУчет);
	
	// Если установлена льготная ставка, оставляем без изменений
	Если (Форма.КлючСистемыНалогообложения.СтавкаНалога = 8
		ИЛИ Форма.КлючСистемыНалогообложения.СтавкаНалога = 6
		ИЛИ Форма.КлючСистемыНалогообложения.СтавкаНалога = 20
		ИЛИ Форма.КлючСистемыНалогообложения.СтавкаНалога = 15)
		И ЗначениеЗаполнено(Форма.КлючСистемыНалогообложения.СтавкаНалога) Тогда
		
		Если Форма.КлючСистемыНалогообложения.СистемаНалогообложения 
			= ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.АУСН") Тогда
			
			Если Форма.КлючСистемыНалогообложения.ОбъектНалогообложения = 
				ПредопределенноеЗначение("Перечисление.ВидыОбъектовНалогообложения.Доходы") Тогда
				Форма.КлючСистемыНалогообложения.СтавкаНалога = 8;
			Иначе
				Форма.КлючСистемыНалогообложения.СтавкаНалога = 20;
			КонецЕсли;                                             
			Форма.КлючСистемыНалогообложения.ПовышеннаяСтавкаНалога = 0;
			Форма.КлючСистемыНалогообложения.ПовышеннаяСтавкаНалога = 0;
		ИначеЕсли Форма.КлючСистемыНалогообложения.СистемаНалогообложения 
			= ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.Упрощенная") Тогда
			
			Если Форма.КлючСистемыНалогообложения.ОбъектНалогообложения = 
				ПредопределенноеЗначение("Перечисление.ВидыОбъектовНалогообложения.Доходы") Тогда
				Форма.КлючСистемыНалогообложения.СтавкаНалога = 6; 
				Форма.КлючСистемыНалогообложения.ПовышеннаяСтавкаНалога = 8;
			Иначе
				Форма.КлючСистемыНалогообложения.СтавкаНалога = 15; 
				Форма.КлючСистемыНалогообложения.ПовышеннаяСтавкаНалога = 20;
			КонецЕсли;
			
		КонецЕсли; 
	КонецЕсли;
	
	Если Форма.КлючСистемыНалогообложения.ПлательщикУСН Тогда
		Элементы.ПлательщикНДСНаУСН.Видимость = Истина;
		Элементы.ГруппаНДСНаУСН.Видимость
			= Форма.КлючСистемыНалогообложения.ПлательщикНДСПрименяющийУСН;
	Иначе
		Элементы.ПлательщикНДСНаУСН.Видимость = Ложь;
		Элементы.ГруппаНДСНаУСН.Видимость = Ложь;
	КонецЕсли;
	Элементы.ВидСтавкиНДСПоУмолчанию.Подсказка = ВидСтавкиНДСПоУмолчаниюТекстПодсказки(Элементы.ГруппаНДСНаУСН.Видимость);
	
	Элементы.ПлательщикЕНВД.Видимость = Форма.КлючСистемыНалогообложения.СистемаНалогообложения
		<> ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.ОсобыйПорядок");
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГоловнаяОрганизация", "Видимость",
		ЭтоЮридическоеЛицо И Не Объект.ГоловнаяОрганизация = Объект.Ссылка);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НоваяГоловнаяОрганизация", "Видимость",
		ЭтоЮридическоеЛицо И Объект.ГоловнаяОрганизация = Объект.Ссылка);
	
	// Установим видимость элементов формы в зависимости от применяемых схем налогообложения
	Элементы.ПримененияЕНВД.Видимость = Форма.КлючСистемыНалогообложения.ПлательщикЕНВД;
	Элементы.ПримененияПатентов.Видимость = Форма.КлючСистемыНалогообложения.ПрименяетсяПатент;
	Элементы.ГруппаВидУчетаСтраховыхВзносов.Видимость =  Форма.КлючСистемыНалогообложения.ПлательщикУСН
		И Форма.КлючСистемыНалогообложения.ПлательщикЕНВД;
	
	// Управление формированием наименования плательщика в бюджет
	Элементы.НаименованиеПлательщикаПриПеречисленииНалогов.Доступность = Форма.ФормироватьНаименованиеПлательщикаАвтоматически
		= 1;
	
	// Заполнение по ЕГР
	Элементы.ГруппаЗаполнениеПоДаннымЕГР.Видимость			= Не ЗначениеЗаполнено(Объект.Ссылка);
	Элементы.ФормаЗаполнитьРеквизитыПоДаннымЕГР.Видимость	= ЗначениеЗаполнено(Объект.Ссылка);
	
	// Доступность тарифа
	Элементы.ВидТарифаУНФ.ТолькоПросмотр = Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВидТарифа", "ТолькоПросмотр",
	Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН);
	Элементы.НовыйТарифСтраховыхВзносов.Видимость = НЕ Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН;
	Элементы.ГруппаТарифПодсказка.Видимость = НЕ Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН;
	
	// Доступность тарифа на трафматизм
	Элементы.ГруппаТарифНаТравматизмФиксированный.Видимость = Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН; 
	Элементы.ГруппаСтавкаФСС_НС.Видимость = НЕ Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН;
	Элементы.ГруппаТарифНаТравматизм.Видимость = НЕ Форма.КлючСистемыНалогообложения.ПрименяетсяАУСН;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьСписокРежимовНалогообложения(Форма, ПоказыватьНастройкиЕНВД)
	Объект = Форма.Объект;
	Элементы = Форма.Элементы;
	Элементы.СистемаНалогообложения.СписокВыбора.Очистить();
	Элементы.СистемаНалогообложения.СписокВыбора.Добавить(0, НСтр("ru = 'Общая'"));
	Элементы.СистемаНалогообложения.СписокВыбора.Добавить(1, НСтр("ru = 'УСН'"));
	Элементы.СистемаНалогообложения.СписокВыбора.Добавить(4, НСтр("ru = 'АУСН'"));
	Если ПоказыватьНастройкиЕНВД Тогда
		Элементы.СистемаНалогообложения.СписокВыбора.Добавить(2, НСтр("ru = 'Только ЕНВД'"));  
	КонецЕсли;
	
	Если Не (Объект.ЮридическоеФизическоеЛицо = ПредопределенноеЗначение(
		"Перечисление.ЮридическоеФизическоеЛицо.ЮридическоеЛицо")) Тогда
		Элементы.СистемаНалогообложения.СписокВыбора.Добавить(3, НСтр("ru = 'Только патент'"));
	Иначе
		Если Форма.КлючСистемыНалогообложения.СистемаНалогообложения = ПредопределенноеЗначение(
			"Перечисление.СистемыНалогообложения.ОсобыйПорядок") И Форма.КлючСистемыНалогообложения.ПрименяетсяПатент Тогда
			Форма.КлючСистемыНалогообложения.СистемаНалогообложения = ПредопределенноеЗначение(
				"Перечисление.СистемыНалогообложения.Общая");
			Форма.СистемаНалогообложенияПредставление = 0;
		КонецЕсли;
		Форма.КлючСистемыНалогообложения.ПрименяетсяПатент = Ложь;
	КонецЕсли;
КонецПроцедуры

