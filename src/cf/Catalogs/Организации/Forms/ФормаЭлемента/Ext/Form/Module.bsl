		Или КлючСистемыНалогообложения.ПлательщикЕНВД Или КлючСистемыНалогообложения.ПрименяетсяПатент
		Или КлючСистемыНалогообложения.ПрименяетсяАУСН;

	УправлениеФормой(ЭтотОбъект);
	Модифицированность = Истина;

	УстановитьЗаголовокНалогообложения(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура СистемаНалогообложенияПриИзменении(Элемент)
	
	Объект.ИспользуетсяОтчетность = КлючСистемыНалогообложения.ПлательщикУСН
	Или КлючСистемыНалогообложения.ПлательщикЕНВД Или КлючСистемыНалогообложения.ПрименяетсяПатент;
	
	Если СистемаНалогообложенияПредставление = 0 Тогда
		КлючСистемыНалогообложения.СистемаНалогообложения = ПредопределенноеЗначение(
		"Перечисление.СистемыНалогообложения.Общая");
		КлючСистемыНалогообложения.ПлательщикУСН = Ложь;  
		КлючСистемыНалогообложения.ПрименяетсяАУСН = Ложь;  
		
		КлючТарифаСтраховыхВзносов.ВидТарифа = ПредопределенноеЗначение("Справочник.ВидыТарифовСтраховыхВзносовУНФ.ПустаяСсылка");
	ИначеЕсли СистемаНалогообложенияПредставление = 1 Тогда
		КлючСистемыНалогообложения.СистемаНалогообложения = ПредопределенноеЗначение(
		"Перечисление.СистемыНалогообложения.Упрощенная");
		КлючСистемыНалогообложения.ПлательщикУСН = Истина;
		КлючСистемыНалогообложения.ПрименяетсяАУСН = Ложь; 
		
		КлючТарифаСтраховыхВзносов.ВидТарифа = ПредопределенноеЗначение("Справочник.ВидыТарифовСтраховыхВзносовУНФ.ПустаяСсылка");
	ИначеЕсли СистемаНалогообложенияПредставление = 2 Тогда
		КлючСистемыНалогообложения.ПлательщикЕНВД = Истина;
		КлючСистемыНалогообложения.ПрименяетсяПатент = Ложь;
		КлючСистемыНалогообложения.ПрименяетсяАУСН = Ложь;
		КлючСистемыНалогообложения.ПлательщикУСН = Ложь;
		КлючСистемыНалогообложения.СистемаНалогообложения = ПредопределенноеЗначение(
		"Перечисление.СистемыНалогообложения.ОсобыйПорядок"); 
		
		КлючТарифаСтраховыхВзносов.ВидТарифа = ПредопределенноеЗначение("Справочник.ВидыТарифовСтраховыхВзносовУНФ.ПустаяСсылка");
	ИначеЕсли СистемаНалогообложенияПредставление = 3 Тогда
		КлючСистемыНалогообложения.ПрименяетсяПатент = Истина;
		КлючСистемыНалогообложения.ПлательщикУСН = Ложь; 
		КлючСистемыНалогообложения.ПрименяетсяАУСН = Ложь;
		КлючСистемыНалогообложения.ПлательщикЕНВД = Ложь;
		КлючСистемыНалогообложения.СистемаНалогообложения = ПредопределенноеЗначение(
		"Перечисление.СистемыНалогообложения.ОсобыйПорядок"); 
		
		КлючТарифаСтраховыхВзносов.ВидТарифа = ПредопределенноеЗначение("Справочник.ВидыТарифовСтраховыхВзносовУНФ.ПустаяСсылка");
	ИначеЕсли СистемаНалогообложенияПредставление = 4 Тогда		
		КлючСистемыНалогообложения.СистемаНалогообложения = ПредопределенноеЗначение(
		"Перечисление.СистемыНалогообложения.АУСН");
		КлючСистемыНалогообложения.ПлательщикУСН = Ложь;
		КлючСистемыНалогообложения.ПлательщикЕНВД = Ложь;
		КлючСистемыНалогообложения.ПрименяетсяПатент = Ложь;
		КлючСистемыНалогообложения.ПлательщикУСН = Ложь; 
		КлючСистемыНалогообложения.ПрименяетсяАУСН = Истина;
		
		УстановитьТарифДляАУСН();
	КонецЕсли;

	Если НЕ КлючСистемыНалогообложения.ПлательщикУСН Тогда
		КлючСистемыНалогообложения.ПлательщикНДСПрименяющийУСН = Ложь;
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);

	Если КлючСистемыНалогообложения.ПлательщикУСН Или КлючСистемыНалогообложения.СистемаНалогообложения
		= ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.ОсобыйПорядок")
		ИЛИ КлючСистемыНалогообложения.ПрименяетсяАУСН Тогда
		ВидСтавки = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.БезНДС");
	Иначе
		ВидСтавки = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.Общая");
	КонецЕсли;

	Если ВидСтавки <> Неопределено Тогда
		Объект.ВидСтавкиНДСПоУмолчанию = ВидСтавки;
	КонецЕсли;
	Модифицированность = Истина;

	УстановитьЗаголовокНалогообложения(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура ПлательщикНДСПрименяющийУСНПриИзменении(Элемент)
	
	Элементы.ГруппаНДСНаУСН.Видимость = КлючСистемыНалогообложения.ПлательщикНДСПрименяющийУСН;
	
	Если НЕ ЗначениеЗаполнено(КлючНастройкиНДС.Период) Тогда
		КлючНастройкиНДС.Период = Макс(НачалоМесяца(ОбщегоНазначенияКлиент.ДатаСеанса()),
			РегламентированнаяОтчетностьУСНКлиентСервер.ДатаНачалаПримененияНДСНаУСН());
		КлючНастройкиНДСПредставлениеПериода = ПредставлениеМесяца(КлючНастройкиНДС.Период);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(КлючНастройкиНДС.СтавкаНалогообложенияПриУСН) Тогда
		КлючНастройкиНДС.СтавкаНалогообложенияПриУСН = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.ПониженнаяУСН");
	КонецЕсли;
	
	Элементы.ВидСтавкиНДСПоУмолчанию.Подсказка = ВидСтавкиНДСПоУмолчаниюТекстПодсказки(КлючСистемыНалогообложения.ПлательщикНДСПрименяющийУСН);
	
	УстановитьЗаголовокУСНСтавкаНДС(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура КлючНастройкиНДСПредставлениеПериодаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыВыбораПериода = Новый Структура;
	ПараметрыВыбораПериода.Вставить("НачалоПериода", НачалоМесяца(КлючНастройкиНДС.Период));
	ПараметрыВыбораПериода.Вставить("КонецПериода",  КонецМесяца(КлючНастройкиНДС.Период));
	ПараметрыВыбораПериода.Вставить("ВидПериода",    ПредопределенноеЗначение("Перечисление.ДоступныеПериодыОтчета.Месяц"));
	ПараметрыВыбораПериода.Вставить("ОграничениеСнизу", РегламентированнаяОтчетностьУСНКлиентСервер.ДатаНачалаПримененияНДСНаУСН());
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПериодНастройкиНДСЗавершениеВыбора", ЭтотОбъект);
	
	ОткрытьФорму("ОбщаяФорма.ВыборСтандартногоПериодаМесяц", 
		ПараметрыВыбораПериода, Элементы.КлючНастройкиНДСПредставлениеПериода, , , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура КлючНастройкиНДСПредставлениеПериодаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Структура") Тогда
		ВыбранныйМесяц = ВыбранноеЗначение.НачалоПериода;
	Иначе
		ВыбранныйМесяц = ВыбранноеЗначение;
	КонецЕсли;
	
	КлючНастройкиНДС.Период = НачалоМесяца(ВыбранныйМесяц);
	КлючНастройкиНДСПредставлениеПериода = ПредставлениеМесяца(ВыбранныйМесяц);
	КлючНастройкиНДСИзменен = Истина;
	УстановитьЗаголовокУСНСтавкаНДС(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура СтавкаНДСПриУСНПриИзменении(Элемент)
	
	Элементы.КлючНастройкиНДСПредставлениеПериода.Видимость = Истина;
