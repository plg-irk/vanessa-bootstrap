			ДинамическиеПараметры.Добавить(НСтр("ru='ОГРН'") + " " + Объект.ОГРН);
		Иначе
			ДинамическиеПараметры.Добавить(НСтр("ru='ОГРН ИП'") + " " + Объект.ОГРН);
		КонецЕсли;
	КонецЕсли;

	УстановитьЗаголовокСвернутогоОтображения(Форма, "ЮридическиеДанные", ДинамическиеПараметры);

