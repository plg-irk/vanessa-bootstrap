
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Если ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда
			Цвет = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.ЗначениеКопирования, "Цвет").Получить();
			Цветфона = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.ЗначениеКопирования, "ЦветФона").Получить();
		Иначе
			Цвет = Метаданные.ЭлементыСтиля.БазовыйЦветСостояний.Значение;
			Цветфона = Новый Цвет(255, 255, 255);
		КонецЕсли;
		
		ОбновитьИнтерфейсПоЦветам();
		
	КонецЕсли;
	
	Параметры.Свойство("ЭтоСостояниеДляЗаявок", ЭтоСостояниеДляЗаявок);
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ЦветТекстаОбъекта = ТекущийОбъект.Цвет.Получить();
	Если ЦветТекстаОбъекта = Неопределено Тогда
		ЦветТекстаОбъекта = Новый Цвет(0, 0, 0);
	КонецЕсли;
	
	ЦветФонаОбъекта = ТекущийОбъект.ЦветФона.Получить();
	Если ЦветФонаОбъекта = Неопределено Тогда
		ЦветФонаОбъекта = Новый Цвет(255, 255, 255);
	КонецЕсли;
	
	Цвет = ЦветТекстаОбъекта;
	ЦветФона = ЦветФонаОбъекта;
	
	ОбновитьИнтерфейсПоЦветам();
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ЗначениеЦвета = Цвет;
	ЗначениеЦветаФона = ЦветФона;
	
	Если ЗначениеЦвета = Новый Цвет(0, 0, 0) Тогда
		ЗначениеЦвета = Неопределено;
	КонецЕсли;
	
	Если ЗначениеЦветаФона = Новый Цвет(255, 255, 255) Тогда
		ЗначениеЦветаФона = Неопределено;
	КонецЕсли;
	
	ТекущийОбъект.Цвет = Новый ХранилищеЗначения(ЗначениеЦвета);
	ТекущийОбъект.ЦветФона = Новый ХранилищеЗначения(ЗначениеЦветаФона);
	
	ПараметрыЗаписи.Вставить("ЭтоНовый", Объект.Ссылка.Пустая());
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ПараметрыЗаписи.Вставить("Ссылка", Объект.Ссылка);
	Если ЭтоСостояниеДляЗаявок Тогда
		ПараметрыЗаписи.Вставить("ЭтоСостояниеДляЗаявок");
	КонецЕсли;
	
	Оповестить("Запись_СостоянияЗаказовПокупателей", ПараметрыЗаписи, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы 

&НаКлиенте
Процедура УстановитьЦвет(Элемент)
	
	ОписаниеОповещения = Новый ОписаниеОповещения(
		"ОбработчикОповещенияЦветВыборНажатие", ЭтотОбъект);
	
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("Цвет", Цвет);
	
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораЦветаУНФ", ПараметрыОткрытияФормы, ЭтотОбъект, , , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЦветФона(Элемент) 
	
	ОписаниеОповещения = Новый ОписаниеОповещения(
		"ОбработчикОповещенияЦветФонаВыборНажатие", ЭтотОбъект);
	
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("Цвет", ЦветФона);
	
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораЦветаУНФ", ПараметрыОткрытияФормы, ЭтотОбъект, , , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОповещенияЦветВыборНажатие(ПолученныйЦвет, ДополнительныеПараметры) Экспорт
	
	Если ПолученныйЦвет <> Неопределено И ПолученныйЦвет <> КодВозвратаДиалога.Отмена Тогда
		Цвет = ПолученныйЦвет;
		ОбновитьИнтерфейсПоЦветуТекста();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОповещенияЦветФонаВыборНажатие(ПолученныйЦвет, ДополнительныеПараметры) Экспорт
	
	Если ПолученныйЦвет <> Неопределено И ПолученныйЦвет <> КодВозвратаДиалога.Отмена Тогда
		ЦветФона = ПолученныйЦвет;
		ОбновитьИнтерфейсПоЦветуФона();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ОбновитьИнтерфейсПоЦветам()
	
	ОбновитьИнтерфейсПоЦветуТекста();
	ОбновитьИнтерфейсПоЦветуФона();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсПоЦветуТекста()
	
	Элементы.Цвет.ЦветТекста = Цвет;
	Элементы.Цвет.ЦветФона = Цвет;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсПоЦветуФона()
	
	Элементы.ЦветФона.ЦветТекста = ЦветФона;
	Элементы.ЦветФона.ЦветФона = ЦветФона;
	Элементы.ЦветФона.Рамка = Новый Рамка(ТипРамкиЭлементаУправления.БезРамки, 0);
	
КонецПроцедуры

#КонецОбласти