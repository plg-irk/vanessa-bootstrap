			|	0 КАК КоличествоОстаток,
			|	0 КАК Резерв";
		КонецЕсли;
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
		"&ДопПоляШаблон КАК ДопПоляШаблон", ТекстЗамены);
		
		Если ПоказыватьОстатки Или ОтборПоКоличеству Тогда
			
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
