			|	ЕСТЬNULL(ОстаткиТоваров.Количество, 0) КАК КоличествоОстаток,
			|	ЕСТЬNULL(ОстаткиТоваров.Резерв, 0) КАК Резерв");
			
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
			"ПО СправочникНоменклатура.Ссылка = НаличиеФайлов.ОбъектСФайлами",
