&НаКлиенте
Процедура ИзменитьПорядокГруппыНоменклатуры(Шаг)
	
	Если СортироватьГруппыПоНаименованию Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для выполнения этого действия необходимо отключить сортировку по наименованию.'"));
		Возврат
	КонецЕсли;
	
	ДанныеТекущейСтроки = Элементы.ОтборИерархия.ТекущиеДанные;
	Если ДанныеТекущейСтроки = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ГруппаНоменклатурыСсылка = ДанныеТекущейСтроки.Значение;
	Если ЗначениеЗаполнено(ГруппаНоменклатурыСсылка) Тогда
		
		ИзменитьПорядокГруппыНоменклатурыНаСервере(ГруппаНоменклатурыСсылка, Шаг);
		ЗаполнитьДеревоИерархии(ГруппаНоменклатурыСсылка);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПорядокГруппыНоменклатурыНоменклатураПоставщика(Шаг)
	
	ДанныеТекущейСтроки = Элементы.ОтборНоменклатураПоставщиков.ТекущиеДанные;
	Если ДанныеТекущейСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ГруппаНоменклатурыСсылка = ДанныеТекущейСтроки.Значение;
	Если ЗначениеЗаполнено(ГруппаНоменклатурыСсылка) Тогда
		
		ИзменитьПорядокГруппыНоменклатурыПоставщикаНаСервере(ГруппаНоменклатурыСсылка, Шаг);
		ЗаполнитьДеревоГруппПоставщика(ГруппаНоменклатурыСсылка, Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ИзменитьПорядокГруппыНоменклатурыПоставщикаНаСервере(ГруппаНоменклатурыСсылка, Шаг)
	
	ГруппаНоменклатурыСсылкаРодитель = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ГруппаНоменклатурыСсылка, "Родитель");
	РеквизитДопУпорядочиванияУНФ = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ГруппаНоменклатурыСсылка, "РеквизитДопУпорядочиванияУНФ");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ГруппаНоменклатуры",			ГруппаНоменклатурыСсылка);
	Запрос.УстановитьПараметр("РодительГруппыНоменклатуры",	ГруппаНоменклатурыСсылкаРодитель);
	Запрос.УстановитьПараметр("РеквизитДопУпорядочивания",	РеквизитДопУпорядочиванияУНФ);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	НоменклатураПоставщиков.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.НоменклатураПоставщиков КАК НоменклатураПоставщиков
	|ГДЕ
	|	НоменклатураПоставщиков.Ссылка <> &ГруппаНоменклатуры
	|	И НоменклатураПоставщиков.ЭтоГруппа
	|	И НоменклатураПоставщиков.Родитель = &РодительГруппыНоменклатуры
	|	И НоменклатураПоставщиков.РеквизитДопУпорядочиванияУНФ <= &РеквизитДопУпорядочивания
	|
	|УПОРЯДОЧИТЬ ПО
	|	НоменклатураПоставщиков.РеквизитДопУпорядочиванияУНФ УБЫВ";
	
	// Вверх	Шаг	-1
	// Вниз		Шаг	+1
	
	Если Шаг > 0 Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,	"<=",	">=");
		Запрос.Текст = СтрЗаменить(Запрос.Текст,	"УБЫВ",	"Возр");
		
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		ГруппаНоменклатурыСмещения = Выборка.Ссылка.ПолучитьОбъект();
		ГруппаНоменклатурыИсходная = ГруппаНоменклатурыСсылка.ПолучитьОбъект();
		
		КэшРеквизита = ГруппаНоменклатурыСмещения.РеквизитДопУпорядочиванияУНФ;
		
		Если КэшРеквизита = ГруппаНоменклатурыИсходная.РеквизитДопУпорядочиванияУНФ Тогда
			КэшРеквизита = КэшРеквизита + Шаг;
		КонецЕсли;
		
		ГруппаНоменклатурыСмещения.РеквизитДопУпорядочиванияУНФ = ГруппаНоменклатурыИсходная.РеквизитДопУпорядочиванияУНФ;
		ГруппаНоменклатурыИсходная.РеквизитДопУпорядочиванияУНФ = КэшРеквизита;
		
		ГруппаНоменклатурыИсходная.Записать();
		ГруппаНоменклатурыСмещения.Записать();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПорядокКатегорийНоменклатуры(Шаг)
	
	Если СортироватьКатегорииПоНаименованию Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для выполнения этого действия необходимо отключить сортировку по наименованию.'"));
		Возврат
	КонецЕсли;
	
	ДанныеТекущейСтроки = Элементы.ОтборКатегории.ТекущиеДанные;
	Если ДанныеТекущейСтроки = Неопределено Или Не ЗначениеЗаполнено(ДанныеТекущейСтроки.Значение) Тогда
		Возврат;
	КонецЕсли;
	
	Если ИзменитьПорядокКатегорииНоменклатурыНаСервере(ДанныеТекущейСтроки.Значение, Шаг) = Истина Тогда
		ЗаполнитьДеревоКатегорий(ДанныеТекущейСтроки.Значение);
	КонецЕсли;
	
