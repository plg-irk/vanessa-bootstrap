	ЭтотОбъект[Элемент] = Значение;
	НоваяСтрока = ЗначенияНастроек.Добавить();
	НоваяСтрока.Элемент = Элемент;
	НоваяСтрока.Значение = Значение;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЗаполнениеКолонкиРезерв(ТипДокументаВладельца, ВидОперации, ВариантыЗаполненияКолонкиРезерв)
	
	Если Не ЗначениеЗаполнено(ВариантыЗаполненияКолонкиРезерв) 
		Или ВариантыЗаполненияКолонкиРезерв = ПредопределенноеЗначение("Перечисление.ВариантыЗаполненияКолонкиРезерв.ДляДокументовПродажи") Тогда
		
		Если ТипДокументаВладельца = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
			Если ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю")
				Или ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ПередачаНаКомиссию") Тогда
				Возврат Истина
			КонецЕсли;
		КонецЕсли;
		
		Если ТипДокументаВладельца = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
			Если РаботаСЗаявкамиКлиентСервер.ЭтоТипЗаказаНаПродажу(ВидОперации)
				Или РаботаСЗаявкамиКлиентСервер.ЭтоТипЗаказНаряда(ВидОперации) Тогда
				Возврат Истина
			КонецЕсли;
		КонецЕсли;
		
		Если ТипДокументаВладельца = Тип("ДокументСсылка.ЧекККМ") Тогда
			Возврат Истина
		КонецЕсли;
		
	ИначеЕсли ВариантыЗаполненияКолонкиРезерв = ПредопределенноеЗначение("Перечисление.ВариантыЗаполненияКолонкиРезерв.ДляВсехДокументов") Тогда
		Возврат Истина
	Иначе
		Возврат Ложь
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция СписокСкладовПоРодителю(РодительИерархии)
	
	Запрос = Новый Запрос;
	
