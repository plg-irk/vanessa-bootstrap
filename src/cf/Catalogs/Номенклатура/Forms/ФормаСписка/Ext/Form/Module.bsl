&НаКлиенте
Процедура КомандыГрупп(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("КомандыГруппПродолжение", ЭтотОбъект);
	
	КомандыСпискаГруппы = Новый СписокЗначений;
	
	Если Элементы.ОтборИерархияКонтекстноеМенюГруппаВыбрать.Видимость Тогда
		КомандыСпискаГруппы.Добавить("Выбрать", НСтр("ru = 'Выбрать'"),,БиблиотекаКартинок.ВыбратьЗначение);
	КонецЕсли;
	
	КомандыСпискаГруппы.Добавить("Создать", НСтр("ru = 'Создать'"),,БиблиотекаКартинок.СоздатьГруппу);
	Если ЗначениеЗаполнено(Элементы.ОтборИерархия.ТекущиеДанные.Значение) Тогда
		КомандыСпискаГруппы.Добавить("Изменить", НСтр("ru = 'Изменить'"),,БиблиотекаКартинок.Изменить);
		КомандыСпискаГруппы.Добавить("Скопировать", НСтр("ru = 'Скопировать'"),,БиблиотекаКартинок.СкопироватьОбъект);
		КомандыСпискаГруппы.Добавить("УстановитьПометкуУдаления", НСтр("ru = 'Установить пометку удаления'"),,БиблиотекаКартинок.Удалить);
	КонецЕсли;
	
	Если ИерархияВключаяВложенные Тогда
		КомандыСпискаГруппы.Добавить("ИерархияВключаяВложенные", НСтр("ru = 'Показывать номенклатуру вложенных групп         '"),, БиблиотекаКартинок.НаследованиеВключено);
	Иначе
		КомандыСпискаГруппы.Добавить("ИерархияВключаяВложенные", НСтр("ru = 'Показывать номенклатуру вложенных групп         '"),, БиблиотекаКартинок.НаследованиеОтключено);
	КонецЕсли;
	
	Если СортироватьГруппыПоНаименованию Тогда
		КомандыСпискаГруппы.Добавить("СортироватьГруппыПоНаименованию", НСтр("ru = 'Сортировать по наименованию         '"),, БиблиотекаКартинок.НаследованиеВключено);
	Иначе
		КомандыСпискаГруппы.Добавить("СортироватьГруппыПоНаименованию", НСтр("ru = 'Сортировать по наименованию         '"),, БиблиотекаКартинок.НаследованиеОтключено);
	КонецЕсли;
	
	КомандыСпискаГруппы.Добавить("ДопУпорядочиваниеУвеличить", НСтр("ru = 'Вверх'"),,БиблиотекаКартинок.ПереместитьВверх);
	КомандыСпискаГруппы.Добавить("ДопУпорядочиваниеУменьшить", НСтр("ru = 'Вниз'"),,БиблиотекаКартинок.ПереместитьВниз);
	
	КомандыСпискаГруппы.Добавить("СвернутьВсеГруппы", НСтр("ru = 'Свернуть все'"),,БиблиотекаКартинок.СвернутьВсе);
	КомандыСпискаГруппы.Добавить("РазвернутьВсеГруппы", НСтр("ru = 'Развернуть все'"),,БиблиотекаКартинок.РазвернутьВсе);
	
	ПоказатьВыборИзСписка(ОписаниеОповещения, КомандыСпискаГруппы, ТекущийЭлемент);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандыКатегорий(Команда)
	
