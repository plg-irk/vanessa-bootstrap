	КомандыСпискаКатегории = Новый СписокЗначений;
	
	КомандыСпискаКатегории.Добавить("Создать", НСтр("ru = 'Создать'"),,БиблиотекаКартинок.СоздатьЭлементСписка);
	Если ЗначениеЗаполнено(Элементы.ОтборКатегории.ТекущиеДанные.Значение) Тогда
		КомандыСпискаКатегории.Добавить("Изменить", НСтр("ru = 'Изменить'"),,БиблиотекаКартинок.Изменить);
		КомандыСпискаКатегории.Добавить("Скопировать", НСтр("ru = 'Скопировать'"),,БиблиотекаКартинок.СкопироватьОбъект);
		КомандыСпискаКатегории.Добавить("УстановитьПометкуУдаления", НСтр("ru = 'Установить пометку удаления        '"),,БиблиотекаКартинок.Удалить);
	КонецЕсли;
	КомандыСпискаКатегории.Добавить("ОткрытьСправочникКатегории", НСтр("ru = 'Список категорий        '"),,БиблиотекаКартинок.Справочник);
	
	Если СортироватьКатегорииПоНаименованию Тогда
		КомандыСпискаКатегории.Добавить("СортироватьКатегорииПоНаименованию", НСтр("ru = 'Сортировать по наименованию         '"),, БиблиотекаКартинок.НаследованиеВключено);
	Иначе
		КомандыСпискаКатегории.Добавить("СортироватьКатегорииПоНаименованию", НСтр("ru = 'Сортировать по наименованию         '"),, БиблиотекаКартинок.НаследованиеОтключено);
	КонецЕсли;
	
	КомандыСпискаКатегории.Добавить("ДопУпорядочиваниеУвеличить", НСтр("ru = 'Вверх'"),,БиблиотекаКартинок.ПереместитьВверх);
	КомандыСпискаКатегории.Добавить("ДопУпорядочиваниеУменьшить", НСтр("ru = 'Вниз'"),,БиблиотекаКартинок.ПереместитьВниз);
	
	КомандыСпискаКатегории.Добавить("СвернутьВсеКатегории", НСтр("ru = 'Свернуть все'"),,БиблиотекаКартинок.СвернутьВсе);
	КомандыСпискаКатегории.Добавить("РазвернутьВсеКатегории", НСтр("ru = 'Развернуть все'"),,БиблиотекаКартинок.РазвернутьВсе);
	
	ПоказатьВыборИзСписка(ОписаниеОповещения, КомандыСпискаКатегории, ТекущийЭлемент);
	
