&НаКлиенте
// Функция возвращает Ставку НДС в зависимости от значения параметра НалогообложениеНДС
//
Функция ПолучитьСтавкуНДС(СтавкаНДС)
	
	Если НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС") 
		Или Не ЗначениеЗаполнено(НалогообложениеНДС) Тогда
		Если ЗначениеЗаполнено(СтавкаНДС) Тогда
			Возврат СтавкаНДС;
		Иначе
			Возврат ПодборНоменклатурыВДокументахВызовСервераПовтИсп.ПолучитьСтавкуНДСОрганизации(Организация, ПериодЦен);
		КонецЕсли;
	Иначе
		Если НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НеОблагаетсяНДС") Тогда
			Возврат УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
		Иначе
			Возврат УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
		КонецЕсли;
	КонецЕсли;
	
КонецФункции // ПолучитьСтавкуНДС()

&НаСервереБезКонтекста
// Получает набор данных с сервера для процедуры НоменклатураПриИзменении.
//
Функция ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные)

	// Характеристики
	СтруктураДанные.Вставить("ИспользоватьХарактеристики", Ложь);
	СтруктураДанные.Вставить("ПроверятьЗаполнениеХарактеристики", Ложь);
	
	ЗначенияРеквизитовНоменклатуры = Неопределено;
	Если ЗначениеЗаполнено(СтруктураДанные.Номенклатура) Тогда 
		
		ЗначенияРеквизитовНоменклатуры = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			СтруктураДанные.Номенклатура, "ИспользоватьХарактеристики, ПроверятьЗаполнениеХарактеристики, 
				|ИспользоватьПартии, ПроверятьЗаполнениеПартий, ЕдиницаИзмерения");
		
	КонецЕсли;
	
	Если ЗначенияРеквизитовНоменклатуры <> Неопределено И ЗначенияРеквизитовНоменклатуры.ИспользоватьХарактеристики Тогда
			
		СтруктураДанные.Вставить("ИспользоватьХарактеристики", Истина);
		СтруктураДанные.Вставить("ПроверятьЗаполнениеХарактеристики", ЗначенияРеквизитовНоменклатуры.ПроверятьЗаполнениеХарактеристики);
		
	КонецЕсли;
	
	// Конец Характеристики
	
	//Партии
	СтруктураДанные.Вставить("ИспользоватьПартии",Ложь);
	СтруктураДанные.Вставить("ПроверятьЗаполнениеПартий",Ложь);
	
	Если НЕ СтруктураДанные.Свойство("Партия") Тогда
		СтруктураДанные.Вставить("Партия", Неопределено);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураДанные.Номенклатура) И ЗначенияРеквизитовНоменклатуры <> Неопределено 
		И ЗначенияРеквизитовНоменклатуры.ИспользоватьПартии Тогда
			
		СтруктураДанные.ПроверятьЗаполнениеПартий = ЗначенияРеквизитовНоменклатуры.ПроверятьЗаполнениеПартий;
		СтруктураДанные.ИспользоватьПартии = Истина;
		
	КонецЕсли;
	// Конец Партии
	
	ПараметрыНДС = НоменклатураВДокументахСервер.ПараметрыОпределенияСтавкиНДС(СтруктураДанные);
	ДанныеНДС = НоменклатураВДокументахСервер.ДанныеНДССтрокиНоменклатуры(ПараметрыНДС);
	СтруктураДанные.Вставить("НоменклатураСтавкаНДС", ДанныеНДС.СтавкаНДС);
	
	СтруктураДанные.Вставить("НоменклатураПоставщика", НоменклатураВДокументахСервер.НоменклатураПоставщикаПоНоменклатуре(СтруктураДанные.Поставщик, СтруктураДанные.Номенклатура, СтруктураДанные.Характеристика));
	
	Если СтруктураДанные.Свойство("ВидЦен") Тогда
		
		СтруктураЦенаИЕдиницаИзмерения = ПодборНоменклатурыВДокументах.ПолучитьЦенуИЕдиницуИзмеренияНоменклатурыПоВидуЦен(СтруктураДанные);
		СтруктураДанные.Вставить("Цена", СтруктураЦенаИЕдиницаИзмерения.Цена);
		
		ЕдиницаВРегистреЦен = СтруктураЦенаИЕдиницаИзмерения.ЕдиницаИзмерения;  
		
		Если ЗначениеЗаполнено(ЗначенияРеквизитовНоменклатуры) Тогда
			ЕдиницаВКарточкеТовара = ЗначенияРеквизитовНоменклатуры.ЕдиницаИзмерения;
		Иначе	
			ЕдиницаВКарточкеТовара = ?(ЗначениеЗаполнено(СтруктураДанные.Номенклатура), 
				ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураДанные.Номенклатура, "ЕдиницаИзмерения"), 
				Справочники.ЕдиницыИзмерения.ПустаяСсылка());
		КонецЕсли;
		
		ЕдиницаИзмерения = ?(ЗначениеЗаполнено(ЕдиницаВРегистреЦен), ЕдиницаВРегистреЦен, ЕдиницаВКарточкеТовара);	
		СтруктураДанные.Вставить("ЕдиницаИзмерения", ЕдиницаИзмерения);
		
	Иначе
		
		СтруктураДанные.Вставить("Цена", 0);
		СтруктураДанные.Вставить("ЕдиницаИзмерения", ?(ЗначениеЗаполнено(СтруктураДанные.Номенклатура), 
			ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураДанные.Номенклатура, "ЕдиницаИзмерения"), 
			Справочники.ЕдиницыИзмерения.ПустаяСсылка()));
		
	КонецЕсли;
	
	//@skip-check bsl-legacy-check-string-literal
	ЗначениеПроцент = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураДанные.ВидСкидкиНаценки, "Процент");	
	ПроцентСкидкиНаценки = ?(ЗначениеПроцент = Неопределено, 0, ЗначениеПроцент);

	//@skip-check bsl-legacy-check-string-literal
	ЗапретитьВводДробногоКоличества = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураДанные.Номенклатура, "ЗапретитьВводДробногоКоличества");
	
	СтруктураДанные.Вставить("ПроцентСкидкиНаценки", ПроцентСкидкиНаценки);
	СтруктураДанные.Вставить("ЗапретитьВводДробногоКоличества", ЗапретитьВводДробногоКоличества);
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеНоменклатураПриИзменении()

&НаСервереБезКонтекста
// Получает набор данных с сервера для процедуры КорзинаЦенаОстатокРезервХарактеристикаЕдиницаИзмеренияОбработкаВыбора.
//
Функция ПолучитьДанныеЕдиницаИзмеренияПриИзменении(ТекущаяЕдиницаИзмерения = Неопределено, ЕдиницаИзмерения = Неопределено)
	
	СтруктураДанные = Новый Структура();
	
	Если ТекущаяЕдиницаИзмерения = Неопределено Тогда
		СтруктураДанные.Вставить("ТекущийКоэффициент", 1);
	Иначе
		СтруктураДанные.Вставить("ТекущийКоэффициент", ТекущаяЕдиницаИзмерения.Коэффициент);
	КонецЕсли;
		
	Если ЕдиницаИзмерения = Неопределено Тогда
		СтруктураДанные.Вставить("Коэффициент", 1);
	Иначе
		СтруктураДанные.Вставить("Коэффициент", ЕдиницаИзмерения.Коэффициент);
	КонецЕсли;
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеЕдиницаИзмеренияПриИзменении()

&НаКлиенте
// Рассчитывается сумма НДС в строке табличной части.
//
Процедура РассчитатьСуммуНДС(СтрокаКорзины)
	
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаКорзины.СтавкаНДС);
	
	СтрокаКорзины.СуммаНДС = ?(СуммаВключаетНДС, 
									СтрокаКорзины.Сумма - (СтрокаКорзины.Сумма) / ((СтавкаНДС + 100) / 100),
									СтрокаКорзины.Сумма * СтавкаНДС / 100);
	
КонецПроцедуры // РассчитатьСуммуНДС()

&НаКлиенте
Процедура ОповещениеПеренестиВДокумент(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть(ЗаписатьПодборВХранилище());
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКартинкуКорзинаРасшифровкаОстатков()
	
	ПараметрыОтбора = Новый Структура("Номенклатура, Характеристика, СтруктурнаяЕдиница");
	
	Для Каждого СтрокаОстатков Из РасшифровкаОстатков Цикл
		
		ЗаполнитьЗначенияСвойств(ПараметрыОтбора, СтрокаОстатков);
		
		НайденныеЭлементы = Корзина.НайтиСтроки(ПараметрыОтбора);
		
		Если Не СтрокаОстатков.КартинкаКорзина = -1 Тогда
			СтрокаОстатков.КартинкаКорзина = ?(НайденныеЭлементы.Количество(), 1, 0);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

