
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	// СтандартныеПодсистемы.ЗапретРедактированияРеквизитовОбъектов
	ЗапретРедактированияРеквизитовОбъектов.ЗаблокироватьРеквизиты(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ЗапретРедактированияРеквизитовОбъектов
	
	ОткрытаИзБыстрогоСоздания = Параметры.Свойство("БыстроеСоздание");
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И НЕ ЗначениеЗаполнено(Параметры.ЗначениеКопирования)Тогда
		КатегорииНоменклатурыСервер.ЗаполнитьСвойстваНоменклатурыПоКатегории(Объект);
	КонецЕсли;
	
	Если ОткрытаИзБыстрогоСоздания И Не Параметры.ЗначенияЗаполнения.ТипНоменклатуры = Объект.КатегорияНоменклатуры.ТипНоменклатурыПоУмолчанию Тогда
		Объект.ТипНоменклатуры = Параметры.ЗначенияЗаполнения.ТипНоменклатуры;
		ТипНоменклатурыПриИзмененииПриСозданииНаСервере();
	КонецЕсли;
	
	ВидСтавкиНДСПоУмолчанию              = Перечисления.ВидыСтавокНДС.Общая;
	ФОИспользоватьПодсистемуПроизводство = ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуПроизводство");
	ФормироватьНаименованиеПолноеАвтоматически = Истина;
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Объект.НаименованиеПолное = Объект.Наименование;
		
		Если Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат") Тогда
			Объект.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.БезНДС;
		ИначеЕсли Не ЗначениеЗаполнено(Объект.ВидСтавкиНДС) Тогда
			Объект.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая;
		КонецЕсли;
		
		ЗаполнитьЗначенияОбъектаПоУмолчанию();
		
	КонецЕсли;
	
	Если Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас И Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		СтруктурнаяЕдиница = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойСклад");
		Если ЗначениеЗаполнено(СтруктурнаяЕдиница) И Не ЗначениеЗаполнено(Объект.Склад) Тогда
			Объект.Склад = СтруктурнаяЕдиница;
		Иначе
			Объект.Склад = ?(Не ЗначениеЗаполнено(Объект.Склад), Справочники.СтруктурныеЕдиницы.ОсновнойСклад, Объект.Склад);
		КонецЕсли;
	КонецЕсли;
	
	// Настройка видимости элементов при открытии из формы списка
	ИспользоватьУпрощеннуюФормуНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьУпрощеннуюФормуНоменклатуры");
	Элементы.ГруппаАртикулКод.Видимость = НЕ ОткрытаИзБыстрогоСоздания;
	Элементы.ГруппаАртикулКод.Видимость = НЕ ОткрытаИзБыстрогоСоздания;
	Элементы.НедействительнаРастяжение.Видимость = НЕ ОткрытаИзБыстрогоСоздания;
	Элементы.ФормаЗаписать.Видимость = НЕ ОткрытаИзБыстрогоСоздания;
	Элементы.Артикул.Видимость = ОткрытаИзБыстрогоСоздания;
	Элементы.НаименованиеПолное.Видимость = ИспользоватьУпрощеннуюФормуНоменклатуры;
	Элементы.ДекорацияПоказатьВсеРеквизиты.Видимость = ОткрытаИзБыстрогоСоздания
						И НЕ ИспользоватьУпрощеннуюФормуНоменклатуры;
	
	ПараметрыПолученияЦены = Новый Структура;
	ПараметрыПолученияЦены.Вставить("ВидЦен", Справочники.ВидыЦен.ПолучитьОсновнойВидЦенПродажи()); 
	ПараметрыПолученияЦены.Вставить("ДатаОбработки", ТекущаяДатаСеанса());
	ПараметрыПолученияЦены.Вставить("Номенклатура", Объект.Ссылка);
	ПараметрыПолученияЦены.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	ПараметрыПолученияЦены.Вставить("Коэффициент", 1);
	ПараметрыПолученияЦены.Вставить("ВалютаДокумента", Константы.ВалютаУчета.Получить());
	ПараметрыПолученияЦены.Вставить("СуммаВключаетНДС", Истина);
	
	Если ИспользоватьУпрощеннуюФормуНоменклатуры И НЕ Объект.Ссылка.Пустая() Тогда
		Цена = ЦенаНоменклатуры(Объект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры // ПриСозданииНаСервере()

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаполнитьЗначенияПоУмолчанию(Истина);
	КонецЕсли;
	
	Если Объект.Числитель <> 1 Тогда
		КоэффициентЧислительЗнаменатель = 0;
	ИначеЕсли Объект.Знаменатель <> 1 Тогда
		КоэффициентЧислительЗнаменатель = 1;
	КонецЕсли;
	УправлениеЭлементамиКоэффициента(Истина);
	
	КонецСтроки = СтрДлина(Объект.Наименование) + 1;
	Элементы.Наименование.УстановитьГраницыВыделения(КонецСтроки, КонецСтроки);
	
КонецПроцедуры // ПриОткрытии()

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// Обработчик подсистемы запрета редактирования реквизитов объектов
	ЗапретРедактированияРеквизитовОбъектов.ЗаблокироватьРеквизиты(ЭтотОбъект);
	
	// Запишем новую цену
	Если Цена <> 0 И ЦенаНоменклатуры(Объект.Ссылка) <> Цена Тогда
		НоваяЦена = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
		НоваяЦена.Период = ТекущаяДатаСеанса();
		НоваяЦена.ВидЦен = Справочники.ВидыЦен.ПолучитьОсновнойВидЦенПродажи();
		НоваяЦена.Номенклатура = Объект.Ссылка;
		НоваяЦена.Цена = Цена;
		НоваяЦена.Актуальность = Истина;
		НоваяЦена.ВалютаЦены = Константы.ВалютаУчета.Получить();
		НоваяЦена.ЕдиницаИзмерения = Объект.ЕдиницаИзмерения;
		НоваяЦена.Записать();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("Запись_Номенклатура", Объект.Ссылка);
	
КонецПроцедуры // ПослеЗаписи()

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ОценкаПроизводительности
	ОценкаПроизводительностиКлиент.ЗамерВремени("СправочникНоменклатураЗапись");
	// СтандартныеПодсистемы.ОценкаПроизводительности
	
КонецПроцедуры //ПередЗаписью()

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура НаименованиеПриИзменении(Элемент)
	
	Если ФормироватьНаименованиеПолноеАвтоматически Тогда
		Объект.НаименованиеПолное = Объект.Наименование;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ТипНоменклатурыПриИзмененииСервер()
	
	Если (ПолучитьФункциональнуюОпцию("ИспользоватьТехоперации")
		И Объект.ТипНоменклатуры=Перечисления.ТипыНоменклатуры.Операция)
		ИЛИ Объект.ТипНоменклатуры=Перечисления.ТипыНоменклатуры.Работа Тогда
		Объект.ФиксированнаяСтоимость = Константы.РасчетСтоимостиОперацийПоНормеВремени.Получить()=Перечисления.ДаНет.Нет;
	Иначе
		Объект.ФиксированнаяСтоимость = Ложь;
	КонецЕсли;
	
	// ПризнакПредметаРасчета
	ТребуетсяПризнакПредметаРасчета = РозничныеПродажиСервер.ТребуетсяПризнакПредметаРасчета(Объект.ТипНоменклатуры);
	
КонецПроцедуры

&НаКлиенте
Процедура КатегорияНоменклатурыПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		ТекстВопроса = НСтр("ru = 'Заполнить значениями по умолчанию для категории?'");
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПерезаполнитьПоКатегории", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);
	Иначе
		ПродолжитьЗаполнениеПоКатегории(Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаПерезаполнитьПоКатегории(Результат, ДополнительныеПараметры) Экспорт
	
	ПродолжитьЗаполнениеПоКатегории(Результат = КодВозвратаДиалога.Да);
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьЗаполнениеПоКатегории(ОбновитьРеквизиты)
	
	КатегорияНоменклатурыПриИзмененииНаСервере(ОбновитьРеквизиты);
	
	Если ЗначениеЗаполнено(Объект.КатегорияНоменклатуры) Тогда
		ЗаполнитьЗначенияПоУмолчанию();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура КатегорияНоменклатурыПриИзмененииНаСервере(ОбновитьРеквизиты)
	
	Если ЗначениеЗаполнено(Объект.КатегорияНоменклатуры) Тогда
		КатегорииНоменклатурыСервер.ЗаполнитьСвойстваНоменклатурыПоКатегории(Объект, ОбновитьРеквизиты);
	КонецЕсли;

	
КонецПроцедуры

&НаКлиенте
Процедура ЕдиницаИзмеренияПриИзменении(Элемент)
	
	УправлениеЭлементамиКоэффициента();
	
КонецПроцедуры

&НаКлиенте
Процедура ЕдиницаИзмеренияАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	ОбработкаАвтоПодбораЕдиницаИзмерения(Текст, ДанныеВыбора, СтандартнаяОбработка, ПараметрыПолученияДанных);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаАвтоПодбораЕдиницаИзмерения(Текст, ДанныеВыбора, СтандартнаяОбработка, Параметры)
	
	Если ПустаяСтрока(Текст) Тогда
		Возврат
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Текст) И СтрДлина(Текст)<2 Тогда
		ДанныеВыбора = Новый СписокЗначений;
	Иначе
		ДанныеВыбора = ДанныеВыбораЕдиницаИзмерения(Параметры);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеВыбораЕдиницаИзмерения(Параметры)
	
	ТаблицаПоказателей = Справочники.КлассификаторЕдиницИзмерения.ТаблицаКлассификатораЕдиницИзмерения();
	
	// Для числовой строки использует поиск по коду банка, в остальных случаях поиск идет по коду, SWIFT и наименованию банка.
	Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Параметры.СтрокаПоиска) Тогда
		
		СтрокаПоиска = Параметры.СтрокаПоиска + "%";
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ТаблицаПоказателей.КодЧисловой КАК СТРОКА(4)) КАК КодЧисловой,
		|	ВЫРАЗИТЬ(ТаблицаПоказателей.УсловноеОбозначениеНациональное КАК СТРОКА(100)) КАК Наименование,
		|	ВЫРАЗИТЬ(ТаблицаПоказателей.УсловноеОбозначениеНациональное КАК СТРОКА(50)) КАК УсловноеОбозначениеНациональное
		|ПОМЕСТИТЬ ВтТаблицаПоказателей
		|ИЗ
		|	&ТаблицаПоказателей КАК ТаблицаПоказателей
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТаблицаПоказателей.КодЧисловой КАК КодЧисловой,
		|	ВтТаблицаПоказателей.Наименование КАК Наименование,
		|	ВтТаблицаПоказателей.УсловноеОбозначениеНациональное КАК УсловноеОбозначениеНациональное
		|ПОМЕСТИТЬ ВТТаблицаСУсловием
		|ИЗ
		|	ВтТаблицаПоказателей КАК ВтТаблицаПоказателей
		|ГДЕ
		|	НЕ ВтТаблицаПоказателей.КодЧисловой В
		|				(ВЫБРАТЬ
		|					КлассификаторЕдиницИзмерения.Код КАК Код
		|				ИЗ
		|					Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	КлассификаторЕдиницИзмерения.Ссылка КАК Ссылка,
		|	КлассификаторЕдиницИзмерения.Код КАК ПолеПоиска,
		|	КлассификаторЕдиницИзмерения.Наименование КАК ПолеРасшифровки,
		|	0 КАК Сортировка,
		|	0 КАК Упорядочивание
		|ИЗ
		|	Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
		|ГДЕ
		|	КлассификаторЕдиницИзмерения.Код ПОДОБНО &СтрокаПоиска
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	КлассификаторЕдиницИзмерения.Ссылка,
		|	КлассификаторЕдиницИзмерения.Наименование,
		|	КлассификаторЕдиницИзмерения.Код,
		|	0,
		|	0
		|ИЗ
		|	Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
		|ГДЕ
		|	КлассификаторЕдиницИзмерения.Код ПОДОБНО &СтрокаПоиска
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	ВТТаблицаСУсловием.КодЧисловой,
		|	ВТТаблицаСУсловием.КодЧисловой,
		|	ВТТаблицаСУсловием.УсловноеОбозначениеНациональное,
		|	0,
		|	1
		|ИЗ
		|	ВТТаблицаСУсловием КАК ВТТаблицаСУсловием
		|ГДЕ
		|	ВТТаблицаСУсловием.КодЧисловой ПОДОБНО &СтрокаПоиска
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	ВТТаблицаСУсловием.КодЧисловой,
		|	ВТТаблицаСУсловием.УсловноеОбозначениеНациональное,
		|	ВТТаблицаСУсловием.КодЧисловой,
		|	0,
		|	1
		|ИЗ
		|	ВТТаблицаСУсловием КАК ВТТаблицаСУсловием
		|ГДЕ
		|	ВТТаблицаСУсловием.УсловноеОбозначениеНациональное ПОДОБНО &СтрокаПоиска
		|
		|УПОРЯДОЧИТЬ ПО
		|	Упорядочивание,
		|	ПолеПоиска";
		
	Иначе
		
		// Для повышения производительности в файловом режиме используем индексируемый поиск по началу строки.
		Если ОбщегоНазначения.ИнформационнаяБазаФайловая() Тогда
			СтрокаПоиска = Параметры.СтрокаПоиска + "%";
		Иначе
			СтрокаПоиска = "%" + Параметры.СтрокаПоиска + "%";
		КонецЕсли;
		
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ТаблицаПоказателей.КодЧисловой КАК СТРОКА(4)) КАК КодЧисловой,
		|	ВЫРАЗИТЬ(ТаблицаПоказателей.Наименование КАК СТРОКА(100)) КАК Наименование,
		|	ВЫРАЗИТЬ(ТаблицаПоказателей.УсловноеОбозначениеНациональное КАК СТРОКА(50)) КАК УсловноеОбозначениеНациональное
		|ПОМЕСТИТЬ ВтТаблицаПоказателей
		|ИЗ
		|	&ТаблицаПоказателей КАК ТаблицаПоказателей
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтТаблицаПоказателей.КодЧисловой КАК КодЧисловой,
		|	ВтТаблицаПоказателей.Наименование КАК Наименование,
		|	ВтТаблицаПоказателей.УсловноеОбозначениеНациональное КАК УсловноеОбозначениеНациональное
		|ПОМЕСТИТЬ ВтТаблицаСУсловием
		|ИЗ
		|	ВтТаблицаПоказателей КАК ВтТаблицаПоказателей
		|ГДЕ
		|	НЕ ВтТаблицаПоказателей.КодЧисловой В
		|				(ВЫБРАТЬ
		|					КлассификаторЕдиницИзмерения.Код КАК Код
		|				ИЗ
		|					Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	КлассификаторЕдиницИзмерения.Ссылка КАК Ссылка,
		|	КлассификаторЕдиницИзмерения.Код КАК ПолеПоиска,
		|	КлассификаторЕдиницИзмерения.Наименование КАК ПолеРасшифровки,
		|	0 КАК Сортировка,
		|	КлассификаторЕдиницИзмерения.Код КАК Код,
		|	КлассификаторЕдиницИзмерения.Наименование КАК Наименование
		|ИЗ
		|	Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
		|ГДЕ
		|	КлассификаторЕдиницИзмерения.Код ПОДОБНО &СтрокаПоиска
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	КлассификаторЕдиницИзмерения.Ссылка,
		|	КлассификаторЕдиницИзмерения.Наименование,
		|	КлассификаторЕдиницИзмерения.Код,
		|	1,
		|	КлассификаторЕдиницИзмерения.Код,
		|	КлассификаторЕдиницИзмерения.Наименование
		|ИЗ
		|	Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
		|ГДЕ
		|	КлассификаторЕдиницИзмерения.Наименование ПОДОБНО &СтрокаПоиска
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	ВтТаблицаСУсловием.Наименование,
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	2,
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	ВтТаблицаСУсловием.Наименование
		|ИЗ
		|	ВтТаблицаСУсловием КАК ВтТаблицаСУсловием
		|ГДЕ
		|	ВтТаблицаСУсловием.Наименование ПОДОБНО &СтрокаПоиска
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	ВтТаблицаСУсловием.УсловноеОбозначениеНациональное,
		|	3,
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	ВтТаблицаСУсловием.Наименование
		|ИЗ
		|	ВтТаблицаСУсловием КАК ВтТаблицаСУсловием
		|ГДЕ
		|	ВтТаблицаСУсловием.КодЧисловой ПОДОБНО &СтрокаПоиска
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 20
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	ВтТаблицаСУсловием.УсловноеОбозначениеНациональное,
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	3,
		|	ВтТаблицаСУсловием.КодЧисловой,
		|	ВтТаблицаСУсловием.Наименование
		|ИЗ
		|	ВтТаблицаСУсловием КАК ВтТаблицаСУсловием
		|ГДЕ
		|	ВтТаблицаСУсловием.УсловноеОбозначениеНациональное ПОДОБНО &СтрокаПоиска
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сортировка,
		|	ПолеПоиска";
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("СтрокаПоиска", СтрокаПоиска);
	Запрос.УстановитьПараметр("ТаблицаПоказателей", ТаблицаПоказателей);
	
	Результат = Запрос.Выполнить();
	
	ДанныеВыбора = Новый СписокЗначений;
	
	Если Результат.Пустой() Тогда
		Возврат ДанныеВыбора;
	КонецЕсли;
	
	МаксКоличествоВыбранных = 20;
	
	РезультатыОтбора = Новый Соответствие;
	РезультатыОтбора.Вставить("ПолеПоиска");
	
	ШрифтВыделения = Новый Шрифт(,,Истина);
	ЦветВыделения  = ЦветаСтиля.ЦветУспешногоПоиска;
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если РезультатыОтбора.Количество() >= МаксКоличествоВыбранных Тогда
			Прервать;
		КонецЕсли;
		
		Если ТипЗнч(Выборка.Ссылка) <> Тип("СправочникСсылка.КлассификаторЕдиницИзмерения")
			И РезультатыОтбора.Получить(Выборка.ПолеПоиска) <> Неопределено Тогда
			
			Продолжить;
		КонецЕсли;
		
		РезультатыОтбора.Вставить(Выборка.ПолеПоиска, Выборка.ПолеПоиска);
		
		// Для каждой строки результата формируем представление, аналогично платформенному.
		ПредставлениеСтроки = Новый Массив;
		ИсходнаяСтрока = СокрЛП(Выборка.ПолеПоиска);
		ВыделяемаяЧасть = Параметры.СтрокаПоиска;
		ПолеРасшифровки = СокрЛП(Выборка.ПолеРасшифровки);
		
		// Находим и выделяем цветом часть строки, которая была введена пользователем.
		Поз = СтрНайти(ВРег(ИсходнаяСтрока), ВРег(Параметры.СтрокаПоиска),, 1);
		ВыделяемаяПодстрока = Сред(ИсходнаяСтрока, Поз, СтрДлина(ВыделяемаяЧасть));
		ФорматВыделяемаяСтрока = Новый ФорматированнаяСтрока(ВыделяемаяПодстрока, ШрифтВыделения, ЦветВыделения);
		
		// Находим оставшуюся часть строки и формируем массив из введенной пользователем строки и оставшейся части.
		Если Поз = 1 Тогда
			// Часть введенной пользователем строки находится в начале, значит оставшуюся строку нужно искать с конца.
			ПредставлениеСтроки.Добавить(ФорматВыделяемаяСтрока);
			ПредставлениеСтроки.Добавить(Новый ФорматированнаяСтрока(Прав(ИсходнаяСтрока, СтрДлина(ИсходнаяСтрока) - СтрДлина(ВыделяемаяЧасть))));
		ИначеЕсли Поз = СтрДлина(ИсходнаяСтрока) Тогда
			// Часть введенной пользователем строки находится в конце, значит оставшуюся строку  искать с начала.
			ПредставлениеСтроки.Добавить(Новый ФорматированнаяСтрока(Лев(ИсходнаяСтрока, Поз-1)));
			ПредставлениеСтроки.Добавить(ФорматВыделяемаяСтрока);
		Иначе
			// Часть введенной пользователем строки находится в середине, значит оставшуюся строку нужно искать в начале и в конце.
			ПредставлениеСтроки.Добавить(Новый ФорматированнаяСтрока(Лев(ИсходнаяСтрока, Поз-1)));
			ПредставлениеСтроки.Добавить(ФорматВыделяемаяСтрока);
			ПредставлениеСтроки.Добавить(Новый ФорматированнаяСтрока(Сред(ИсходнаяСтрока, Поз + СтрДлина(ВыделяемаяЧасть))));
		КонецЕсли;
		
		КодЯвляетсяРасшифровкой = ?(Выборка.Сортировка = 0, Истина, Ложь);
		
		Если КодЯвляетсяРасшифровкой Тогда
			ДанныеВыбора.Добавить(Выборка.Ссылка, Новый ФорматированнаяСтрока(ПредставлениеСтроки, " ", ПолеРасшифровки));
		Иначе
			ДанныеВыбора.Добавить(Выборка.Ссылка, Новый ФорматированнаяСтрока(ПолеРасшифровки, " ", ПредставлениеСтроки));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДанныеВыбора;
	
КонецФункции

&НаКлиенте
Процедура ЕдиницаИзмеренияОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, СтандартнаяОбработка)

	Если Не ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Возврат
	КонецЕсли;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		ОбработатьВыбораЕдиницаИзмерения(ВыбранноеЗначение);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбработатьВыбораЕдиницаИзмерения(ВыбранноеЗначение)
	
	ТаблицаПоказателей = Справочники.КлассификаторЕдиницИзмерения.ТаблицаКлассификатораЕдиницИзмерения();
	
	ДанныеКлассификатора = ТаблицаПоказателей.Найти(СокрЛП(ВыбранноеЗначение), "КодЧисловой");
	
	Если ДанныеКлассификатора = Неопределено Тогда
		Возврат 
	КонецЕсли;
	
	ЭлементКлассификатора = Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(ВыбранноеЗначение);
	
	Если ЭлементКлассификатора = Неопределено Или НЕ ЗначениеЗаполнено(ЭлементКлассификатора) Тогда
		
		ЭлементКлассификатора = Справочники.КлассификаторЕдиницИзмерения.СоздатьЭлемент();
		ЭлементКлассификатора.Наименование = ДанныеКлассификатора.УсловноеОбозначениеНациональное;
		ЭлементКлассификатора.НаименованиеПолное = ДанныеКлассификатора.Наименование;
		ЭлементКлассификатора.Код = ДанныеКлассификатора.КодЧисловой;
		ЭлементКлассификатора.МеждународноеСокращение = ДанныеКлассификатора.КодовоеБуквенноеОбозначениеМеждународное;
		
		Если ЗначениеЗаполнено(ДанныеКлассификатора.ТипИзмеряемойВеличины) Тогда
			ЭлементКлассификатора.ТипИзмеряемойВеличины = Перечисления.ТипыИзмеряемыхВеличин[ДанныеКлассификатора.ТипИзмеряемойВеличины];
		КонецЕсли;
		
		ЭлементКлассификатора.Записать();
		
	КонецЕсли;
	
	ВыбранноеЗначение = ЭлементКлассификатора.Ссылка;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияПоказатьВсеРеквизитыНажатие(Элемент)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимВыбора",     Истина);
	ПараметрыФормы.Вставить("ПереходИзБыстройФормы", Истина);
	
	СтруктураЗаполнения = Новый Структура;
	СтруктураЗаполнения.Вставить("НаименованиеПолное", Объект.НаименованиеПолное);
	СтруктураЗаполнения.Вставить("Наименование", Объект.Наименование);
	СтруктураЗаполнения.Вставить("ТипНоменклатуры", Объект.ТипНоменклатуры);
	СтруктураЗаполнения.Вставить("КатегорияНоменклатуры", Объект.КатегорияНоменклатуры);
	СтруктураЗаполнения.Вставить("Артикул", Объект.Артикул);
	СтруктураЗаполнения.Вставить("Родитель", Объект.Родитель);
	СтруктураЗаполнения.Вставить("ЕдиницаИзмерения", Объект.ЕдиницаИзмерения);
	
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", СтруктураЗаполнения);
		
	ОткрытьФорму("Справочник.Номенклатура.ФормаОбъекта", ПараметрыФормы, ВладелецФормы);
	
	Модифицированность = Ложь;
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ЦенаНоменклатуры(Номенклатура)
	
	ПараметрыПолученияЦены = Новый Структура;
	ПараметрыПолученияЦены.Вставить("ВидЦен", Справочники.ВидыЦен.ПолучитьОсновнойВидЦенПродажи()); 
	ПараметрыПолученияЦены.Вставить("ДатаОбработки", ТекущаяДатаСеанса());
	ПараметрыПолученияЦены.Вставить("Номенклатура", Номенклатура);
	ПараметрыПолученияЦены.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	ПараметрыПолученияЦены.Вставить("Коэффициент", 1);
	ПараметрыПолученияЦены.Вставить("ВалютаДокумента", Константы.ВалютаУчета.Получить());
	ПараметрыПолученияЦены.Вставить("СуммаВключаетНДС", Истина);
	
	Возврат ЦенообразованиеСервер.ПолучитьЦенуНоменклатурыПоВидуЦен(ПараметрыПолученияЦены);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьЗначенияОбъектаПоУмолчанию()
	
	Если НЕ ЗначениеЗаполнено(Объект.СчетУчетаЗатрат) Тогда
		
		Объект.СчетУчетаЗатрат = ?(
			Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга ИЛИ НЕ Константы.ФункциональнаяОпцияИспользоватьПодсистемуПроизводство.Получить(),
			ПланыСчетов.Управленческий.КоммерческиеРасходы,
			ПланыСчетов.Управленческий.НезавершенноеПроизводство);
		
	КонецЕсли;
	
	Если Объект.ВидПродукцииИС = Перечисления.ВидыПродукцииИС.Алкогольная Тогда
		Объект.ИмпортнаяАлкогольнаяПродукция = ЗначениеЗаполнено(Объект.СтранаПроисхождения) 
			И Объект.СтранаПроисхождения <> Справочники.СтраныМира.Россия;
	КонецЕсли;
	
	// Подарочные сертификаты
	Объект.ТипСрокаДействия = Перечисления.СрокДействияПодарочныхСертификатов.БезОграниченияСрока;
	Объект.ИсключитьИзПрайсЛистов = (Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат"));
	// Конец Подарочные сертификаты
	
	Если (ПолучитьФункциональнуюОпцию("ИспользоватьТехоперации")
		И Объект.ТипНоменклатуры=Перечисления.ТипыНоменклатуры.Операция)
		ИЛИ Объект.ТипНоменклатуры=Перечисления.ТипыНоменклатуры.Работа Тогда
		Объект.ФиксированнаяСтоимость = Константы.РасчетСтоимостиОперацийПоНормеВремени.Получить()=Перечисления.ДаНет.Нет;
	Иначе
		Объект.ФиксированнаяСтоимость = Ложь;
	КонецЕсли;
	
	// Наборы
	Если Объект.ЭтоНабор Тогда
		Если НЕ ЗначениеЗаполнено(Объект.СпособРасчетаЦеныНабора) Тогда
			Объект.СпособРасчетаЦеныНабора = Перечисления.СпособыРасчетаЦеныНабора.СкладыватьИзЦенКомплектующих;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Объект.ВариантПечатиНабора) Тогда
			Объект.ВариантПечатиНабора = Перечисления.ВариантыПечатиНаборов.НаборИКомплектующие;
		КонецЕсли; 
	Иначе
		Объект.СпособРасчетаЦеныНабора = Перечисления.СпособыРасчетаЦеныНабора.ПустаяСсылка();
		Объект.ВариантПечатиНабора = Перечисления.ВариантыПечатиНаборов.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЗначенияПоУмолчанию(НовыйЭлемент = Ложь)
	
	ТипНоменклатуры = Объект.ТипНоменклатуры;
	
	Если Не НовыйЭлемент Тогда
		
		Объект.СрокПополнения = 0;
		Объект.НормаВремени = 0;
		
	Иначе
		Если ЭтоЗапас() И НЕ Объект.ЭтоНабор Тогда
		Объект.СпособПополнения = ?(Не ЗначениеЗаполнено(Объект.СпособПополнения), ПредопределенноеЗначение("Перечисление.СпособыПополненияЗапасов.Закупка"), Объект.СпособПополнения);
		Иначе
			Объект.СпособПополнения = ПредопределенноеЗначение("Перечисление.СпособыПополненияЗапасов.ПустаяСсылка");
		КонецЕсли;
	КонецЕсли;
	
	Если (ЭтоЗапас() ИЛИ ЭтоСертификат()) И НЕ Объект.ЭтоНабор Тогда
		Объект.МетодОценки = ?(Не ЗначениеЗаполнено(Объект.МетодОценки), ПредопределенноеЗначение("Перечисление.МетодОценкиЗапасов.ПоСредней"), Объект.МетодОценки);
	КонецЕсли;
	
	Если ЭтоЗапас() Или ЭтоУслуга() Или ЭтоРабота() ИЛИ ЭтоСертификат()Тогда
		Объект.НаправлениеДеятельности = ?(Не ЗначениеЗаполнено(Объект.НаправлениеДеятельности), ПредопределенноеЗначение("Справочник.НаправленияДеятельности.ОсновноеНаправление"), Объект.НаправлениеДеятельности);
	Иначе
		Объект.НаправлениеДеятельности = ПредопределенноеЗначение("Справочник.НаправленияДеятельности.ПустаяСсылка");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.СчетУчетаЗапасов) Тогда
		
		Объект.СчетУчетаЗапасов = ПредопределенноеЗначение("ПланСчетов.Управленческий.ПустаяСсылка");
		Если Не ЗначениеЗаполнено(Объект.ТипНоменклатуры)
			Или ЭтоЗапас() Или ЭтоСертификат() Тогда
			Объект.СчетУчетаЗапасов = ПолучитьСчетУчетаЗапасов();
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.СчетУчетаЗатрат) Тогда
		
		Объект.СчетУчетаЗатрат = ПредопределенноеЗначение("ПланСчетов.Управленческий.ПустаяСсылка");
		Если Не ЗначениеЗаполнено(Объект.ТипНоменклатуры)
			Или ЭтоЗапас()
			Или ЭтоРабота()
			Или ЭтоОперация()
			Или ЭтоСертификат() Тогда
			Если ФОИспользоватьПодсистемуПроизводство Тогда
				Объект.СчетУчетаЗатрат = ПредопределенноеЗначение("ПланСчетов.Управленческий.НезавершенноеПроизводство");
			Иначе
				Объект.СчетУчетаЗатрат = ПредопределенноеЗначение("ПланСчетов.Управленческий.КоммерческиеРасходы");
			КонецЕсли;
		КонецЕсли;
		
		Если ЭтоУслуга() Тогда
			Объект.СчетУчетаЗатрат = ПредопределенноеЗначение("ПланСчетов.Управленческий.КоммерческиеРасходы");
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.СчетУчетаДоходов) Тогда
		
		Объект.СчетУчетаДоходов = ПредопределенноеЗначение("ПланСчетов.Управленческий.ПустаяСсылка");
		Если ЭтоСертификат() Тогда
			Объект.СчетУчетаДоходов = ПредопределенноеЗначение("ПланСчетов.Управленческий.ПрочиеДоходы");
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.СчетУчетаНДСПоПриобретеннымЦенностям) Тогда
		Объект.СчетУчетаНДСПоПриобретеннымЦенностям = ПредопределенноеЗначение("ПланСчетов.Управленческий.НДСПоПриобретеннымЦенностям");
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.СчетУчетаНДСПоРеализации) Тогда
		Объект.СчетУчетаНДСПоРеализации = ПредопределенноеЗначение("ПланСчетов.Управленческий.Продажи_НДС");
	КонецЕсли;
	
	Объект.ТоварнаяНоменклатураВЭД = Неопределено;
	Объект.ПрослеживаемыйТовар = Ложь;
	
	Если ЭтоЗапас() Или ЭтоУслуга() Или ЭтоРабота() Тогда
		Объект.СрокИсполненияЗаказа = ?(Не ЗначениеЗаполнено(Объект.СрокИсполненияЗаказа),1, Объект.СрокИсполненияЗаказа);
	Иначе
		Объект.СрокИсполненияЗаказа = 0;
	КонецЕсли;
	
	Если ЭтоЗапас() Или ЭтоУслуга() Или ЭтоРабота() ИЛИ ЭтоСертификат() Тогда
		
		Если Не ЗначениеЗаполнено(Объект.ВидСтавкиНДС) Тогда
			
			Если Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат") Тогда
				Объект.ВидСтавкиНДС = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.БезНДС");
			Иначе
				Объект.ВидСтавкиНДС = ВидСтавкиНДСПоУмолчанию;
			КонецЕсли;
			
		КонецЕсли;
	
	Иначе
		Объект.ВидСтавкиНДС = ПредопределенноеЗначение("Перечисление.ВидыСтавокНДС.ПустаяСсылка");
	КонецЕсли;
	
	Если Не ЭтоЗапас() Тогда
		Объект.ВидАлкогольнойПродукции = Неопределено;
		Объект.ПроизводительИмпортерАлкогольнойПродукции = Неопределено;
		Объект.ОбъемДАЛ = 0;
	КонецЕсли;
	
	Если Не НовыйЭлемент Тогда
		ЗаполнитьЗначенияПоУмолчаниюСервер(НовыйЭлемент);
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначенияПоУмолчаниюСервер(НовыйЭлемент = Ложь)
	
	Если Не ЗначениеЗаполнено(Объект.СпособПополнения) Тогда
		Если ЗначениеЗаполнено(Объект.КатегорияНоменклатуры.СпособПополнения) Тогда
			Объект.СпособПополнения = Объект.КатегорияНоменклатуры.СпособПополнения;
		Иначе
			Объект.СпособПополнения = Перечисления.СпособыПополненияЗапасов.Закупка;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.КатегорияНоменклатуры) 
		И ЗначениеЗаполнено(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.КатегорияНоменклатуры, "ПризнакПредметаРасчета")) Тогда
		Объект.ПризнакПредметаРасчета = Объект.КатегорияНоменклатуры.ПризнакПредметаРасчета;
	Иначе
		Объект.ПризнакПредметаРасчета = ПолучитьОжидаемыйПризнакПредметаРасчета(Объект.ТипНоменклатуры, 
			Объект.ВидПродукцииИС, 
			Объект.ВидМаркировки, 
			Объект.ПодакцизныйТовар, 
			Объект.ПродаетсяВРозлив);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЭтоЗапас()
	Возврат Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Запас");
КонецФункции

&НаКлиенте
Функция ЭтоУслуга()
	Возврат Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга");
КонецФункции

&НаКлиенте
Функция ЭтоРабота()
	Возврат Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Работа");
КонецФункции

&НаКлиенте
Функция ЭтоОперация()
	Возврат Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Операция");
КонецФункции

&НаКлиенте
Функция ЭтоСертификат()
	Возврат Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.ПодарочныйСертификат");
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСчетУчетаЗапасов()
	Возврат Справочники.Номенклатура.СчетУчетаЗапасов();
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьОжидаемыйПризнакПредметаРасчета(ТипНоменклатуры, ВидПродукцииИС, ВидМаркировки, ПодакцизныйТовар = Ложь, ПродаетсяВРозлив = Ложь)
	
	Результат = РозничныеПродажиСервер.ПолучитьОжидаемыйПризнакПредметаРасчета(ТипНоменклатуры, ВидПродукцииИС, ВидМаркировки, ПодакцизныйТовар, ПродаетсяВРозлив); 
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура УправлениеЭлементамиКоэффициента(ОткрытиеФормы = Ложь)
	
	ТекстШаблона = НСтр("ru = '1 %1 состоит из:'");
	
	Если ЗначениеЗаполнено(Объект.ЕдиницаДляЦенников) Тогда
		
		Если Не ОткрытиеФормы Тогда
			Если КоэффициентЧислительЗнаменатель = 0 Тогда
				Объект.Знаменатель = 1;
			Иначе
				Объект.Числитель = 1;
			КонецЕсли;
		КонецЕсли;
		
	Иначе

		Если Не ОткрытиеФормы Тогда
			Объект.Знаменатель = 1;
			Объект.Числитель = 1;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ТипНоменклатурыПриИзмененииПриСозданииНаСервере()
	
	// Наборы
	Если Объект.ЭтоНабор И НЕ Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас 
		И НЕ Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Работа Тогда
		Объект.ЭтоНабор = Ложь;
		Объект.СпособРасчетаЦеныНабора = Неопределено;
		Объект.ВариантПечатиНабора = Неопределено;
	КонецЕсли;
	// Конец Наборы
	
	Если НЕ Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас Тогда
		Объект.СпособПополнения = ?(Не ЗначениеЗаполнено(Объект.СпособПополнения), 
			ПредопределенноеЗначение("Перечисление.СпособыПополненияЗапасов.Закупка"), 
			Объект.СпособПополнения);
		
		Объект.Производитель = Неопределено;
		Объект.СтранаПроисхождения = Неопределено;
		Объект.ПодакцизныйТовар = Ложь;
		Объект.ЕдиницаДляОтчетов = Неопределено;
		
	КонецЕсли;
	
	// Подарочные сертификаты
	Если Объект.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.ПодарочныйСертификат Тогда
		Объект.ИспользоватьХарактеристики = Ложь;
		Объект.ИспользоватьПартии = Ложь;
		Объект.ИсключитьИзПрайсЛистов = Истина;
	КонецЕсли;
	// Конец Подарочные сертификаты
	
	Если НЕ Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") Тогда
		Объект.ЭтоАгентскаяУслуга = Ложь;
		Объект.Договор = ПредопределенноеЗначение("Справочник.ДоговорыКонтрагентов.ПустаяСсылка");
	КонецЕсли;
	
	ТипНоменклатурыПриИзмененииСервер();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиБиблиотек

// СтандартныеПодсистемы.ЗапретРедактированияРеквизитовОбъектов
&НаКлиенте
Процедура Подключаемый_РазрешитьРедактированиеРеквизитовОбъекта(Команда)
	
	ЗаблокированныеРеквизиты = ЗапретРедактированияРеквизитовОбъектовКлиент.Реквизиты(ЭтотОбъект);
	Если ЗаблокированныеРеквизиты.Количество() > 0 Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ссылка", Объект.Ссылка);
		ПараметрыФормы.Вставить("ЗаблокированныеРеквизиты", ЗаблокированныеРеквизиты);
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораРеквизитовДляРазблокирования", ЭтотОбъект);
		
		ОткрытьФорму("Справочник.Номенклатура.Форма.РазблокированиеРеквизитов", ПараметрыФормы, ЭтотОбъект,,,, ОписаниеОповещения);
		
	Иначе
		
		ЗапретРедактированияРеквизитовОбъектовКлиент.ПоказатьПредупреждениеВсеВидимыеРеквизитыРазблокированы();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораРеквизитовДляРазблокирования(РазблокируемыеРеквизиты, Контекст) Экспорт
	
	Если ТипЗнч(РазблокируемыеРеквизиты) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	ЗапретРедактированияРеквизитовОбъектовКлиент.УстановитьДоступностьЭлементовФормы(ЭтотОбъект, РазблокируемыеРеквизиты);
	
	Если РазблокируемыеРеквизиты.Найти("ЕдиницаИзмерения") <> Неопределено Тогда
		ИнтеграцияИСУНФКлиентСервер.ЗаполнитьДанныеНастройкиПараметровНоменклатурыИС(ЭтотОбъект, Истина);
	КонецЕсли;
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ЗапретРедактированияРеквизитовОбъектов

#КонецОбласти