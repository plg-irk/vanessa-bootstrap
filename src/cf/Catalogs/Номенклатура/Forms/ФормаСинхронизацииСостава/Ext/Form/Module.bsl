#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ИнициализироватьПеременные();
	ИспользоватьХарактеристикиНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики");
	Элементы.СинхронизацияХарактеристика.Видимость = ИспользоватьХарактеристикиНоменклатуры;
	ОбработатьВходныеПараметры();
	УстановитьУсловноеОформление();
	ЗаполнитьТаблицуСинхронизации();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновлятьСоставПриИзмененииКлиент()
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СегментНоменклатурыПриИзменении(Элемент)
	ЗаполнитьТаблицуСинхронизации();
КонецПроцедуры

&НаКлиенте
Процедура КатегорияНоменклатурыПриИзменении(Элемент)
	ЗаполнитьТаблицуСинхронизации();
КонецПроцедуры

&НаКлиенте
Процедура ОбновлятьСоставПриИзменении(Элемент)
	
	ОбновлятьСоставПриИзмененииКлиент();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСинхронизация

&НаКлиенте
Процедура СинхронизацияПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Синхронизация.ТекущиеДанные;
	АктуализироватьОперациюВСтрокеСинхронизации(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура СинхронизацияНоменклатураОчистка(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура СинхронизацияХарактеристикаОчистка(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Применить(Команда)
	
	Ответ = ПодготовитьОтвет();
	Закрыть(Ответ);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПометки(Команда)
	УстановитьДоступнымСтрокамЗначениеПометки(Истина);
КонецПроцедуры

&НаКлиенте
Процедура СнятьПометки(Команда)
	УстановитьДоступнымСтрокамЗначениеПометки(Ложь);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Если РедактироватьТолькоРасхождения Тогда
		Элемент = УсловноеОформление.Элементы.Добавить();
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Синхронизация.Имя);
		
		ГруппаОтбораЭлементаВерхнегоУровня = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбораЭлементаВерхнегоУровня.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
		ЭлементОтбора = ГруппаОтбораЭлементаВерхнегоУровня.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Синхронизация.ПрисутствуетВИсточнике");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Истина;
		ЭлементОтбора = ГруппаОтбораЭлементаВерхнегоУровня.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Синхронизация.ПрисутствуетВСоставе");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Истина;
		
		Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
		Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.ТемноСерый);
	КонецЕсли;
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Синхронизация.Имя);
	ЭлементОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Синхронизация.ПрисутствуетВИсточнике");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Ложь;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.ТемноЗеленый);
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Синхронизация.Имя);
	ЭлементОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Синхронизация.ПрисутствуетВСоставе");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Ложь;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.Красный);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьВходныеПараметры()
	
	Если Параметры.Свойство("СегментНоменклатуры") Тогда
		СегментНоменклатуры = Параметры.СегментНоменклатуры;
		Элементы.СегментНоменклатуры.Видимость = Истина;
		ТипЗаполнения = ТипыЗаполнения.ПоСегментуНоменклатуры;
	ИначеЕсли Параметры.Свойство("КатегорияНоменклатуры") Тогда
		КатегорияНоменклатуры = Параметры.КатегорияНоменклатуры;
		Элементы.КатегорияНоменклатуры.Видимость = Истина;
		ТипЗаполнения = ТипыЗаполнения.ПоКатегорииНоменклатуры;
	КонецЕсли;
	
	РедактироватьТолькоРасхождения = Истина;
	Если Параметры.Свойство("РедактироватьТолькоРасхождения") Тогда
		РедактироватьТолькоРасхождения = Параметры.РедактироватьТолькоРасхождения;
	КонецЕсли;
	Если Параметры.Свойство("ИсходныйСостав") Тогда
		ЗаполнитьТаблицуСоставаИзМассиваСтруктур(Параметры.ИсходныйСостав, СоставИсточника);
	КонецЕсли;
	Если Параметры.Свойство("ОбновлятьСостав") Тогда
		ОбновлятьСостав = Параметры.ОбновлятьСостав;
	КонецЕсли;
	Если Параметры.Свойство("Служебная") И Параметры.Служебная Тогда
		Элементы.ОбновлятьСостав.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуСоставаИзМассиваСтруктур(ИсходныйСостав, ТаблицаПриемник)
	
	ЗначениеХарактеристики = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	Для Каждого ЭлементСостава Из ИсходныйСостав Цикл
	
		Если ИспользоватьХарактеристикиНоменклатуры Тогда
			ЗначениеХарактеристики = ЭлементСостава.Характеристика;
		КонецЕсли;
		ОтборСтрок = Новый Структура();
		ОтборСтрок.Вставить("Номенклатура", ЭлементСостава.Номенклатура);
		ОтборСтрок.Вставить("Характеристика", ЗначениеХарактеристики);
		СтрокиОтбора = ТаблицаПриемник.НайтиСтроки(ОтборСтрок);
		Если СтрокиОтбора.Количество() = 0 Тогда
			НоваяСтрока = ТаблицаПриемник.Добавить();
			НоваяСтрока.Номенклатура = ЭлементСостава.Номенклатура;
			НоваяСтрока.Характеристика = ЗначениеХарактеристики;
		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуСинхронизации()

	ИсточникЗаполнения = Неопределено;
	Если ТипЗаполнения = ТипыЗаполнения.ПоСегментуНоменклатуры Тогда
		ЗаполнитьТаблицуСинхронизацииПоСегментуНоменклатуры();
		ИсточникЗаполнения = СегментНоменклатуры;
	Иначе
		ЗаполнитьТаблицуСинхронизацииПоКатегорииНоменклатуры();
		ИсточникЗаполнения = КатегорияНоменклатуры;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ИсточникЗаполнения) Тогда
		Для Каждого СтрокаСинхронизации Из Синхронизация Цикл
			СтрокаСинхронизации.Пометка = Ложь;
			СтрокаСинхронизации.ПрисутствуетВСоставе = Истина;
			СтрокаСинхронизации.Операция = ОперацииССоставом.Пустая;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуСинхронизацииПоКатегорииНоменклатуры()
	
	ЗапросОбщейТаблицы = Новый Запрос;
	ЗапросОбщейТаблицы.Текст =
	"ВЫБРАТЬ
	|	СоставИсточника.Номенклатура КАК Номенклатура,
	|	СоставИсточника.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втСоставИсточника
	|ИЗ
	|	&СоставИсточника КАК СоставИсточника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СоставКатегории.Ссылка КАК Номенклатура
	|ПОМЕСТИТЬ втСоставКатегории
	|ИЗ
	|	Справочник.Номенклатура КАК СоставКатегории
	|ГДЕ
	|	СоставКатегории.КатегорияНоменклатуры = &КатегорияНоменклатуры
	|	И НЕ СоставКатегории.КатегорияНоменклатуры = ЗНАЧЕНИЕ(Справочник.КатегорииНоменклатуры.ПустаяСсылка)
	|	И НЕ СоставКатегории.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СоставКатегории.Номенклатура ЕСТЬ NULL
	|		ИЛИ СоставИсточника.Номенклатура ЕСТЬ NULL КАК Пометка,
	|	ЕСТЬNULL(СоставКатегории.Номенклатура, СоставИсточника.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(СоставИсточника.Характеристика, ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК Характеристика,
	|	ВЫБОР
	|		КОГДА СоставИсточника.Номенклатура ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПрисутствуетВИсточнике,
	|	ВЫБОР
	|		КОГДА СоставКатегории.Номенклатура ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПрисутствуетВСоставе,
	|	ВЫБОР
	|		КОГДА СоставИсточника.Номенклатура ЕСТЬ NULL
	|			ТОГДА &ОперацияДобавить
	|		КОГДА СоставКатегории.Номенклатура ЕСТЬ NULL
	|			ТОГДА &ОперацияУдалить
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Операция,
	|	ВЫБОР
	|		КОГДА СоставИсточника.Номенклатура ЕСТЬ NULL
	|			ТОГДА 1
	|		КОГДА СоставКатегории.Номенклатура ЕСТЬ NULL
	|			ТОГДА 2
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК КодОперации
	|ИЗ
	|	втСоставКатегории КАК СоставКатегории
	|		ПОЛНОЕ СОЕДИНЕНИЕ втСоставИсточника КАК СоставИсточника
	|		ПО СоставКатегории.Номенклатура = СоставИсточника.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	КодОперации";
	ЗапросОбщейТаблицы.УстановитьПараметр("СоставИсточника", СоставИсточника.Выгрузить());
	ЗапросОбщейТаблицы.УстановитьПараметр("КатегорияНоменклатуры", КатегорияНоменклатуры);
	ЗапросОбщейТаблицы.УстановитьПараметр("ОперацияДобавить", ОперацииССоставом.Добавить);
	ЗапросОбщейТаблицы.УстановитьПараметр("ОперацияУдалить", ОперацииССоставом.Удалить);
	
	Синхронизация.Загрузить(ЗапросОбщейТаблицы.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуСинхронизацииПоСегментуНоменклатуры()
	
	ТаблицаСоставаСегмента = СоставИсточника.Выгрузить(Новый Массив);
	Если ЗначениеЗаполнено(СегментНоменклатуры) Тогда
		МассивСегмента = Новый Массив;
		МассивСегмента.Добавить(СегментНоменклатуры);
		СоставСегмента = РегистрыСведений.СоставСегментаНоменклатуры.СоставВыбранногоСегмента(МассивСегмента);
		ЗаполнитьТаблицуСоставаИзМассиваСтруктур(СоставСегмента, ТаблицаСоставаСегмента);
	КонецЕсли;
	
	ЗапросОбщейТаблицы = Новый Запрос;
	ЗапросОбщейТаблицы.Текст =
	"ВЫБРАТЬ
	|	СоставИсточника.Номенклатура КАК Номенклатура,
	|	СоставИсточника.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втСоставИсточника
	|ИЗ
	|	&СоставИсточника КАК СоставИсточника
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СоставСегмента.Номенклатура КАК Номенклатура,
	|	СоставСегмента.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ втСоставСегмента
	|ИЗ
	|	&СоставСегмента КАК СоставСегмента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	(СоставСегмента.Номенклатура ЕСТЬ NULL ИЛИ СоставИсточника.Номенклатура ЕСТЬ NULL) КАК Пометка,
	|	ЕСТЬNULL(СоставСегмента.Номенклатура, СоставИсточника.Номенклатура) КАК Номенклатура,
	|	ЕСТЬNULL(СоставСегмента.Характеристика, СоставИсточника.Характеристика) КАК Характеристика,
	|	ВЫБОР КОГДА СоставИсточника.Номенклатура ЕСТЬ NULL ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПрисутствуетВИсточнике,
	|	ВЫБОР КОГДА СоставСегмента.Номенклатура ЕСТЬ NULL ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ПрисутствуетВСоставе,
	|	ВЫБОР КОГДА СоставИсточника.Номенклатура ЕСТЬ NULL ТОГДА &ОперацияДобавить
	|		КОГДА СоставСегмента.Номенклатура ЕСТЬ NULL ТОГДА &ОперацияУдалить
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Операция,
	|	ВЫБОР КОГДА СоставИсточника.Номенклатура ЕСТЬ NULL ТОГДА 1
	|		КОГДА СоставСегмента.Номенклатура ЕСТЬ NULL ТОГДА 2
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК КодОперации
	|Из
	|	втСоставСегмента КАК СоставСегмента
	|		ПОЛНОЕ СОЕДИНЕНИЕ втСоставИсточника КАК СоставИсточника
	|		ПО СоставСегмента.Номенклатура = СоставИсточника.Номенклатура
	|			И СоставСегмента.Характеристика = СоставИсточника.Характеристика
	|
	|УПОРЯДОЧИТЬ ПО
	|КодОперации";
	ЗапросОбщейТаблицы.УстановитьПараметр("СоставИсточника", СоставИсточника.Выгрузить());
	ЗапросОбщейТаблицы.УстановитьПараметр("СоставСегмента", ТаблицаСоставаСегмента);
	ЗапросОбщейТаблицы.УстановитьПараметр("ОперацияДобавить", ОперацииССоставом.Добавить);
	ЗапросОбщейТаблицы.УстановитьПараметр("ОперацияУдалить", ОперацииССоставом.Удалить);
	
	Синхронизация.Загрузить(ЗапросОбщейТаблицы.Выполнить().Выгрузить());
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьПеременные()
	
	ИнициализироватьТипыЗаполнения();
	ИнициализироватьОперацииССоставом();
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьТипыЗаполнения()
	
	ТипыЗаполнения = Новый Структура();
	ТипыЗаполнения.Вставить("ПоСегментуНоменклатуры", 1);
	ТипыЗаполнения.Вставить("ПоКатегорииНоменклатуры", 2);
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьОперацииССоставом()
	
	ОперацииССоставом = Новый Структура();
	ОперацииССоставом.Вставить("Пустая", "");
	ОперацииССоставом.Вставить("Добавить", "Добавить");
	ОперацииССоставом.Вставить("Удалить", "Удалить");
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступнымСтрокамЗначениеПометки(ЗначениеПометки)
	
	Для Каждого СтрокаСинхронизации Из Синхронизация Цикл
		
		РедактированиеДоступно = Не (РедактироватьТолькоРасхождения И СтрокаСинхронизации.ПрисутствуетВИсточнике
			И СтрокаСинхронизации.ПрисутствуетВСоставе);
		Если РедактированиеДоступно И Не СтрокаСинхронизации.Пометка = ЗначениеПометки Тогда
			СтрокаСинхронизации.Пометка = ЗначениеПометки;
			АктуализироватьОперациюВСтрокеСинхронизации(СтрокаСинхронизации);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура АктуализироватьОперациюВСтрокеСинхронизации(СтрокаСинхронизации)
	
	Если СтрокаСинхронизации.ПрисутствуетВИсточнике И СтрокаСинхронизации.ПрисутствуетВСоставе Тогда
		СтрокаСинхронизации.Операция = ?(СтрокаСинхронизации.Пометка, ОперацииССоставом.Удалить, ОперацииССоставом.Пустая);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПодготовитьОтвет()
	
	РезультатФункции = Новый Структура();
	ПодготовитьТаблицуДобавления(РезультатФункции);
	РезультатФункции.Вставить("СтрокиНаУдаление", ПодготовитьСтрокиНаУдаление());
	Если ТипЗаполнения = ТипыЗаполнения.ПоСегментуНоменклатуры Тогда
		РезультатФункции.Вставить("Сегмент", СегментНоменклатуры);
	Иначе
		РезультатФункции.Вставить("Категория", КатегорияНоменклатуры);
	КонецЕсли;
	РезультатФункции.Вставить("ОбновлятьСостав", ОбновлятьСостав);
		
	Возврат РезультатФункции;
	
КонецФункции

&НаСервере
Процедура ПодготовитьТаблицуДобавления(РезультатФункции)

	ОтборСтрокДобавления = Новый Структура();
	ОтборСтрокДобавления.Вставить("Пометка", Истина);
	ОтборСтрокДобавления.Вставить("Операция", ОперацииССоставом.Добавить);

	ТаблицаДобавления = Синхронизация.Выгрузить(ОтборСтрокДобавления, "Номенклатура,Характеристика");
	Адрес = ПоместитьВоВременноеХранилище(ТаблицаДобавления, УникальныйИдентификатор);
	РезультатФункции.Вставить("АдресКорзиныВХранилище", Адрес);

КонецПроцедуры

&НаСервере
Функция ПодготовитьСтрокиНаУдаление()
	
	СтрокиНаУдаление = Новый Массив;
	Для Каждого СтрокаСинхронизации Из Синхронизация Цикл
		Если СтрокаСинхронизации.Пометка И СтрокаСинхронизации.Операция = ОперацииССоставом.Удалить
				И ЗначениеЗаполнено(СтрокаСинхронизации.Номенклатура) Тогда
			ДанныеСтроки = Новый Структура("Номенклатура,Характеристика",
				СтрокаСинхронизации.Номенклатура, СтрокаСинхронизации.Характеристика);
			СтрокиНаУдаление.Добавить(ДанныеСтроки);
		КонецЕсли;
	КонецЦикла;
	Возврат СтрокиНаУдаление;
	
КонецФункции

&НаКлиенте
Процедура ОбновлятьСоставПриИзмененииКлиент()
	
	Элементы.СинхронизацияПометка.ТолькоПросмотр = ОбновлятьСостав;
	Элементы.УстановитьПометки.Доступность = Не ОбновлятьСостав;
	Элементы.СнятьПометки.Доступность = Не ОбновлятьСостав;
	
	Если ОбновлятьСостав Тогда
		Для Каждого СтрокаСинхронизации Из Синхронизация Цикл
			Если Не (СтрокаСинхронизации.ПрисутствуетВИсточнике И СтрокаСинхронизации.ПрисутствуетВСоставе) Тогда
				СтрокаСинхронизации.Пометка = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти