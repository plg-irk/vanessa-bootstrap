// Возвращает основную цену продажи для указанной номенклатуры, по указанному виду цен.
//
// Параметры:
//  ВидЦен - СправочникСсылка.ВидыЦен - вид цен,  
//        - Неопределено - основной вид цен вычисляется см. Справочники.ВидыЦен.ПолучитьОсновнойВидЦенПродажи,
//  Номенклатура - СправочникСсылка.Номенклатура - номенклатура по которой необходимо вычислить цену (обязательна к заполнению);
//  ЕдиницаИзмерения - СправочникСсылка.КлассификаторЕдиницИзмерения, СправочникСсылка.ЕдиницыИзмерения, Неопределено - .
// Возвращаемое значение:
// 	Произвольный, Число - Описание
Функция ПолучитьОсновнуюЦенуПродажи(ВидЦен, Номенклатура, ЕдиницаИзмерения = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Номенклатура) 
		ИЛИ НЕ ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ЦеныНоменклатуры) Тогда
		
		Возврат 0;
		
	КонецЕсли;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК ОсновнаяЦенаПродажи
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			,
	|			ВидЦен = &ВидЦен
	|				И Номенклатура = &Номенклатура
	|				И Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
	|				И Актуальность
	|				И &ПараметрЕдиницаИзмерения) КАК ЦеныНоменклатурыСрезПоследних");
	
	Запрос.УстановитьПараметр("ВидЦен", 
		?(ЗначениеЗаполнено(ВидЦен), ВидЦен, Справочники.ВидыЦен.ПолучитьОсновнойВидЦенПродажи()));
	
	Запрос.УстановитьПараметр("Номенклатура", 
		Номенклатура);
		
	Если ЗначениеЗаполнено(ЕдиницаИзмерения) Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ПараметрЕдиницаИзмерения", "ЕдиницаИзмерения = &ЕдиницаИзмерения");
		Запрос.УстановитьПараметр("ЕдиницаИзмерения", ЕдиницаИзмерения);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ПараметрЕдиницаИзмерения", "ИСТИНА");
		
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.ОсновнаяЦенаПродажи, 0);
	
КонецФункции

Функция ЕстьХарактеристики(Номенклатура) Экспорт
	
	Характеристики = Справочники.ХарактеристикиНоменклатуры.Выбрать(, Номенклатура);
	Если Характеристики.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

// Формирует строку представления номенклатуры с учетом характеристики и серий.
//
// Параметры:
//  НоменклатураПредставление - Строка - представление номенклатуры,
//  ХарактеристикаПредставление - Строка - представление характеристики,
//  ПартияПредставление - Строка - представление партии,
//  ЗаказПокупателяПредставление - Строка - представление партии.
//
// Возвращаемое значение:
//  Строка - строка с представлением номенклатуры.
Функция Представление(НоменклатураПредставление, ХарактеристикаПредставление = "", ПартияПредставление = "",
	ЗаказПокупателяПредставление = "") Экспорт
	
	КомпонентыПредставления = Новый Массив;
	КомпонентыПредставления.Добавить(СокрЛП(НоменклатураПредставление));
	
	Если ЗначениеЗаполнено(ХарактеристикаПредставление)Тогда
		КомпонентыПредставления.Добавить(СокрЛП(ХарактеристикаПредставление))
	КонецЕсли;
	
	Если  ЗначениеЗаполнено(ПартияПредставление) Тогда
		КомпонентыПредставления.Добавить(СокрЛП(ПартияПредставление));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗаказПокупателяПредставление) Тогда
		КомпонентыПредставления.Добавить(СокрЛП(ЗаказПокупателяПредставление));
	КонецЕсли;
	
	Возврат СтрСоединить(КомпонентыПредставления, " / ");
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	Если ТипЗнч(Параметры.Отбор) = Тип("Структура") И Параметры.Отбор.Свойство("НастройкиПолейСтрокой") Тогда 
		
		СтрокаДляПоиска = СокрЛП(Параметры.СтрокаПоиска);
		Если Не ЗначениеЗаполнено(СтрокаДляПоиска) Тогда
			Возврат;
		КонецЕсли; 
		
		НастройкиПолей = СтрРазделить(Параметры.Отбор.НастройкиПолейСтрокой, ",");
		Параметры.Отбор.Удалить("НастройкиПолейСтрокой");
		
		ВидЦены = Неопределено;
		Если Параметры.Отбор.Свойство("ВидЦеныРМК") Тогда
			ВидЦены = Параметры.Отбор.ВидЦеныРМК;
			Параметры.Отбор.Удалить("ВидЦеныРМК");
		КонецЕсли;
		
		ИспользуетсяПоискСПрефиксом = Ложь;
		Для Каждого НастройкаПоля Из НастройкиПолей Цикл
			ИмяИНастройкиПоля = СтрРазделить(НастройкаПоля, "/");
			СпособПоискаСПрефиксом = ИмяИНастройкиПоля[2];
			Если СпособПоискаСПрефиксом = "0" Тогда
				Продолжить;
			КонецЕсли;
			ИспользуетсяПоискСПрефиксом = Истина;
			Прервать;
		КонецЦикла;
		
		ВведенПрефикс = Ложь;
		Если ИспользуетсяПоискСПрефиксом Тогда
			ВведенПрефикс = Лев(СтрокаДляПоиска, 1) = "*" И СтрДлина(СтрокаДляПоиска) > 1;
		КонецЕсли;
		
		ОтображаемыеПоля = Новый Массив;
		ИменаПолейПоиска = Новый ТаблицаЗначений;
		ИменаПолейПоиска.Колонки.Добавить("ИмяПоля");
		ИменаПолейПоиска.Колонки.Добавить("СпособПоиска");
		ИменаПолейПоиска.Колонки.Добавить("Порядок");
		ИменаПолейПоиска.Колонки.Добавить("СПрефиксом");
		Для Каждого НастройкаПоля Из НастройкиПолей Цикл
			
			ИмяИНастройкиПоля = СтрРазделить(НастройкаПоля, "/");
			ИмяПоля = ИмяИНастройкиПоля[0];
			СпособПоиска = ИмяИНастройкиПоля[1];
			СпособПоискаСПрефиксом = ИмяИНастройкиПоля[2];
			Порядок = ИмяИНастройкиПоля[3];
			Отображать = ИмяИНастройкиПоля[4];
			
			Если Отображать = "1" Или ИмяПоля = "Наименование" Тогда
				ОтображаемыеПоля.Добавить(ИмяПоля);
			КонецЕсли;
			
			Если ВведенПрефикс И СпособПоискаСПрефиксом = "0" Тогда
				Продолжить;
			ИначеЕсли Не ВведенПрефикс И СпособПоиска = "0" Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаПоля = ИменаПолейПоиска.Добавить();
			СтрокаПоля.ИмяПоля = ИмяПоля;
			СтрокаПоля.СпособПоиска = ?(ВведенПрефикс, СпособПоискаСПрефиксом, СпособПоиска);
			СтрокаПоля.Порядок = Порядок;
			СтрокаПоля.СПрефиксом = ?(ВведенПрефикс, 1, 0);
			
		КонецЦикла;
		
		ИспользоватьРасширенныйПоиск = Истина;
		Если ИменаПолейПоиска.Количество() = 0 Тогда
			Если ОтображаемыеПоля.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
			ИспользоватьРасширенныйПоиск = Ложь;
		КонецЕсли;
		
		Если ИспользоватьРасширенныйПоиск Тогда
			
			ДанныеВыбора = Новый СписокЗначений;
			СтандартнаяОбработка = Ложь;
			
			ИменаПолейПоиска.Сортировать("Порядок");
				
			Если ВведенПрефикс Тогда
				СтрокаДляПоиска = Сред(СтрокаДляПоиска, 2);
			КонецЕсли;
			ОписаниеТипаЧисла = Новый ОписаниеТипов("Число");
			
			СловаПоиска = СтрРазделить(СтрокаДляПоиска, " ", Ложь);
			
			УсловиеШтрихода = "";
			УсловиеЦены = "";
			УсловиеSKU = "";
			УсловиеОбщее = "";
			
			НомерСлова = 0;
			Для Каждого СловоПоиска Из СловаПоиска Цикл
				НомерСлова = НомерСлова + 1;
				СловоПоискаЧисло = ОписаниеТипаЧисла.ПривестиЗначение(СловоПоиска);
				СловоПоискаЭтоЦелоеЧисло = Цел(СловоПоискаЧисло) = СловоПоискаЧисло;
				
				УсловиеСлова = "";
				Для Каждого СтрокаПоля Из ИменаПолейПоиска Цикл
					ИмяПоля = СтрокаПоля.ИмяПоля;
					
					Если ИмяПоля = "Штрихкод" Тогда
						УсловиеШтрихода = УсловиеШтрихода + " ИЛИ Штрихкоды.Штрихкод ПОДОБНО &СловоПоиска" + НомерСлова;
					КонецЕсли;
					
					Если СловоПоискаЧисло > 0 Тогда
						Если ИмяПоля = "Цена" Тогда
							Если СловоПоискаЭтоЦелоеЧисло Тогда
								УсловиеЦены = УсловиеЦены + " ИЛИ ЦЕЛ(Цены.Цена) = &СловоПоискаЧисло" + НомерСлова;
							Иначе
								УсловиеЦены = УсловиеЦены + " ИЛИ Цены.Цена = &СловоПоискаЧисло" + НомерСлова;
							КонецЕсли;
						ИначеЕсли ИмяПоля = "SKU" Тогда
							УсловиеSKU = УсловиеSKU + " ИЛИ КодыSKU.SKU = &СловоПоискаЧисло" + НомерСлова; 
						КонецЕсли;
					КонецЕсли;
					
					Если ИмяПоля = "Наименование" Тогда
						УсловиеСлова = УсловиеСлова + " ИЛИ НоменклатураСпр.Наименование ПОДОБНО &СловоПоиска" + НомерСлова;
					ИначеЕсли ИмяПоля = "Код" Тогда
						УсловиеСлова = УсловиеСлова + " ИЛИ НоменклатураСпр.Код ПОДОБНО &СловоПоиска" + НомерСлова;
					ИначеЕсли ИмяПоля = "Артикул" Тогда
						УсловиеСлова = УсловиеСлова + " ИЛИ НоменклатураСпр.Артикул ПОДОБНО &СловоПоиска" + НомерСлова;
					ИначеЕсли ИмяПоля = "Штрихкод" Тогда
						УсловиеСлова = УсловиеСлова + " ИЛИ Штрихкоды.Штрихкод ПОДОБНО &СловоПоиска" + НомерСлова;
					КонецЕсли;
					Если СловоПоискаЧисло > 0 Тогда
						Если ИмяПоля = "Цена" Тогда
							Если СловоПоискаЭтоЦелоеЧисло Тогда
								УсловиеСлова = УсловиеСлова + " ИЛИ ЦЕЛ(Цены.Цена) = &СловоПоискаЧисло" + НомерСлова;
							Иначе
								УсловиеСлова = УсловиеСлова + " ИЛИ Цены.Цена = &СловоПоискаЧисло" + НомерСлова;
							КонецЕсли;
						ИначеЕсли ИмяПоля = "SKU" Тогда
							УсловиеСлова = УсловиеСлова + " ИЛИ КодыSKU.SKU = &СловоПоискаЧисло" + НомерСлова;
						КонецЕсли;
					КонецЕсли;
					
				КонецЦикла;
				
				Если Не ЗначениеЗаполнено(УсловиеСлова) Тогда
					Возврат;
				КонецЕсли;
				
				УсловиеСлова = "(" + Сред(УсловиеСлова, 6) + ")";
				УсловиеОбщее = УсловиеОбщее + " И " + УсловиеСлова;
				
			КонецЦикла;
			
			УсловиеШтрихода = Сред(УсловиеШтрихода, 6);
			УсловиеЦены = Сред(УсловиеЦены, 6);
			УсловиеSKU = Сред(УсловиеSKU, 6);
			УсловиеОбщее = Сред(УсловиеОбщее, 4);
			
			ТекстыВыборкиНайденныхСлов = Новый Массив;
			
			Для Каждого СтрокаПоля Из ИменаПолейПоиска Цикл
				ИмяПоля = СтрокаПоля.ИмяПоля;
				ИмяПоляСПорядком = Строка(СтрокаПоля.Порядок) + ИмяПоля;
				НомерСлова = 0;
				ТекстПоля = "";
				Если ИмяПоля = "Наименование" Или ИмяПоля = "Код" Или ИмяПоля = "Артикул" Тогда
					ТекстПоля = "НоменклатураСпр." + ИмяПоля + " ПОДОБНО &СловоПоиска";
				ИначеЕсли ИмяПоля = "Штрихкод" Тогда
					ТекстПоля = "Штрихкоды.Штрихкод ПОДОБНО &СловоПоиска";
				ИначеЕсли ИмяПоля = "Цена" Тогда
					ТекстПоля = "ЦЕЛ(Цены.Цена) = &СловоПоискаЧисло";
				ИначеЕсли ИмяПоля = "SKU" Тогда
					ТекстПоля = "КодыSKU.SKU = &СловоПоискаЧисло";
				КонецЕсли;
				
				Для Каждого СловоПоиска Из СловаПоиска Цикл
					НомерСлова = НомерСлова + 1;
					
					Если ИмяПоля = "Цена" Или ИмяПоля = "SKU" Тогда
						СловоПоискаЧисло = ОписаниеТипаЧисла.ПривестиЗначение(СловоПоиска);
						Если СловоПоискаЧисло = 0 Тогда
							Продолжить;
						КонецЕсли;
						Если ИмяПоля = "Цена" Тогда
							СловоПоискаЭтоЦелоеЧисло = Цел(СловоПоискаЧисло) = СловоПоискаЧисло;
							Если СловоПоискаЭтоЦелоеЧисло Тогда
								ТекстПоля = "ЦЕЛ(Цены.Цена) = &СловоПоискаЧисло";
							Иначе
								ТекстПоля = "Цены.Цена = &СловоПоискаЧисло";
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
					
					ТекстыВыборкиНайденныхСлов.Добавить("КОГДА " + ТекстПоля + НомерСлова + " ТОГДА """ + ИмяПоляСПорядком + """");
				КонецЦикла;
				
			КонецЦикла;
			
			ТекстВыборкиНайденныхСлов = СтрСоединить(ТекстыВыборкиНайденныхСлов, Символы.ПС);
			ТекстВыборкиНайденныхСлов = "ВЫБОР " + ТекстВыборкиНайденныхСлов + " ИНАЧЕ Неопределено КОНЕЦ КАК ИмяПоля";
			
			ТекстСоединения = "Справочник.Номенклатура КАК НоменклатураСпр";
			ТекстыЗапросов = Новый Массив;
			Если ЗначениеЗаполнено(УсловиеШтрихода) Тогда
				ТекстЗапросаШтрихкода =
				"ВЫБРАТЬ
				|	Штрихкоды.Номенклатура КАК Номенклатура,
				|	Штрихкоды.Штрихкод КАК Штрихкод
				|ПОМЕСТИТЬ Штрихкоды
				|ИЗ
				|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
				|ГДЕ
				|	ДЛИНАСТРОКИ(Штрихкоды.Штрихкод) < 15
				|	И &УсловиеШтрихода
				|;
				|";
				ТекстЗапросаШтрихкода = СтрЗаменить(ТекстЗапросаШтрихкода, "&УсловиеШтрихода", УсловиеШтрихода);
				ТекстыЗапросов.Добавить(ТекстЗапросаШтрихкода);
				ТекстСоединения = ТекстСоединения + "
				|	ЛЕВОЕ СОЕДИНЕНИЕ Штрихкоды КАК Штрихкоды
				|	ПО НоменклатураСпр.Ссылка = Штрихкоды.Номенклатура";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(УсловиеЦены) Тогда
				ТекстЗапросаЦены =
				"ВЫБРАТЬ
				|	Цены.Номенклатура КАК Номенклатура,
				|	Цены.Цена КАК Цена
				|ПОМЕСТИТЬ Цены
				|ИЗ
				|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦен = &ВидЦены) КАК Цены
				|ГДЕ
				|	&УсловиеЦены
				|;
				|";
				Если Не ЗначениеЗаполнено(ВидЦены) Тогда
					ТекстЗапросаЦены = СтрЗаменить(ТекстЗапросаЦены, "ВидЦен = &ВидЦены", "");
				КонецЕсли;
				ТекстЗапросаЦены = СтрЗаменить(ТекстЗапросаЦены, "&УсловиеЦены", УсловиеЦены);
				ТекстыЗапросов.Добавить(ТекстЗапросаЦены);
				ТекстСоединения = ТекстСоединения + "
				|	ЛЕВОЕ СОЕДИНЕНИЕ Цены КАК Цены
				|	ПО НоменклатураСпр.Ссылка = Цены.Номенклатура";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(УсловиеSKU) Тогда
				ТекстЗапросаSKU =
				"ВЫБРАТЬ
				|	КодыSKU.Номенклатура КАК Номенклатура,
				|	КодыSKU.SKU КАК SKU
				|ПОМЕСТИТЬ КодыSKU
				|ИЗ
				|	РегистрСведений.КодыТоваровSKU КАК КодыSKU
				|ГДЕ
				|	&УсловиеSKU
				|;
				|";
				ТекстЗапросаSKU = СтрЗаменить(ТекстЗапросаSKU, "&УсловиеSKU", УсловиеSKU);
				ТекстыЗапросов.Добавить(ТекстЗапросаSKU);
				ТекстСоединения = ТекстСоединения + "
				|	ЛЕВОЕ СОЕДИНЕНИЕ КодыSKU КАК КодыSKU
				|	ПО НоменклатураСпр.Ссылка = КодыSKU.Номенклатура";
			КонецЕсли;
			
			ИтоговыйТекстЗапроса =
			"ВЫБРАТЬ ПЕРВЫЕ 15
			|	НоменклатураСпр.Ссылка КАК Ссылка,
			|	НоменклатураСпр.Наименование КАК Наименование,
			|	НоменклатураСпр.Артикул КАК Артикул,
			|	НоменклатураСпр.Код КАК Код,
			|	НЕОПРЕДЕЛЕНО КАК Штрихкод,
			|	НЕОПРЕДЕЛЕНО КАК Цена,
			|	НЕОПРЕДЕЛЕНО КАК SKU,
			|	НЕОПРЕДЕЛЕНО КАК ИмяПоля,
			|	ВЫРАЗИТЬ("""" КАК СТРОКА(1000)) КАК ИмяПоляИЗначение
			|ИЗ
			|	Справочник.Номенклатура КАК НоменклатураСпр
			|ГДЕ
			|	НЕ НоменклатураСпр.ЭтоГруппа
			|	И НЕ НоменклатураСпр.ПометкаУдаления
			|	И НЕ НоменклатураСпр.Недействителен
			|	И &УсловиеОбщее";
			
			Если ЗначениеЗаполнено(УсловиеШтрихода) Или ЗначениеЗаполнено(УсловиеЦены) Или ЗначениеЗаполнено(УсловиеSKU) Тогда
				ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса,
					"Справочник.Номенклатура КАК НоменклатураСпр", ТекстСоединения);
				Если ЗначениеЗаполнено(УсловиеШтрихода) Тогда
					ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК Штрихкод", "Штрихкоды.Штрихкод КАК Штрихкод");
				КонецЕсли;
				Если ЗначениеЗаполнено(УсловиеЦены) Тогда
					ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК Цена", "Цены.Цена КАК Цена");
				КонецЕсли;
				Если ЗначениеЗаполнено(УсловиеSKU) Тогда
					ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК SKU", "КодыSKU.SKU КАК SKU");
				КонецЕсли;
			КонецЕсли;
			
			Если Не Параметры.Отбор.Свойство("ПометкаУдаления") Тогда
				ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, "И НЕ НоменклатураСпр.ПометкаУдаления", "");
				ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, "И НЕ НоменклатураСпр.Недействителен", "");
			КонецЕсли;
			
			ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, "&УсловиеОбщее", УсловиеОбщее);
			ИтоговыйТекстЗапроса = СтрЗаменить(ИтоговыйТекстЗапроса, "НЕОПРЕДЕЛЕНО КАК ИмяПоля", ТекстВыборкиНайденныхСлов);
			
			ТекстыЗапросов.Добавить(ИтоговыйТекстЗапроса);
			ТекстЗапроса = СтрСоединить(ТекстыЗапросов);
			
			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапроса;
			
			НомерСлова = 0;
			Для Каждого СловоПоиска Из СловаПоиска Цикл
				НомерСлова = НомерСлова + 1;
				Запрос.УстановитьПараметр("СловоПоиска" + Строка(НомерСлова), "%" + СловоПоиска + "%");
				СловоПоискаЧисло = ОписаниеТипаЧисла.ПривестиЗначение(СловоПоиска);
				Если СловоПоискаЧисло > 0 Тогда
					Запрос.УстановитьПараметр("СловоПоискаЧисло" + Строка(НомерСлова), СловоПоискаЧисло);
				КонецЕсли;
			КонецЦикла;
			
			Если ЗначениеЗаполнено(УсловиеЦены) И ЗначениеЗаполнено(ВидЦены) Тогда
				Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
			КонецЕсли;
			
			РезультатЗапроса = Запрос.Выполнить();
			ПозицииНоменклатуры = РезультатЗапроса.Выгрузить();
			
			Для Каждого ПозицияНоменклатуры Из ПозицииНоменклатуры Цикл
				ИмяПоля = Сред(ПозицияНоменклатуры.ИмяПоля, 2);
				ЗначениеПоля = ПозицияНоменклатуры[ИмяПоля];
				ПозицияНоменклатуры.ИмяПоляИЗначение = ПозицияНоменклатуры.ИмяПоля + "_" + ЗначениеПоля;
				ПозицияНоменклатуры.ИмяПоля = ИмяПоля;
			КонецЦикла;
			
			ПозицииНоменклатуры.Сортировать("ИмяПоляИЗначение");
		
		Иначе
			Если Не Параметры.Отбор.Свойство("ЭтоВызовИзРМК") Тогда
				Параметры.Отбор.Вставить("ЭтоВызовИзРМК", Истина);
			КонецЕсли;
			ПозицииНоменклатуры = ПолучитьДанныеВыбора(Параметры);
			Для Каждого ПозицияНоменклатуры Из ПозицииНоменклатуры Цикл
				Если ТипЗнч(ПозицияНоменклатуры.Значение) = Тип("Структура") Тогда
					ПозицияНоменклатуры.Значение = ПозицияНоменклатуры.Значение.Значение;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		ДанныеВыбора = Новый СписокЗначений;
		СтандартнаяОбработка = Ложь;
		
		НуженЗапросШтрихкода = Ложь;
		НуженЗапросЦены = Ложь;
		НуженЗапросSKU = Ложь;
		Для Каждого ОтображаемоеПоле Из ОтображаемыеПоля Цикл
			НуженЗапрос = Ложь;
			Если ОтображаемоеПоле = "Штрихкод" Или ОтображаемоеПоле = "Цена" Или ОтображаемоеПоле = "SKU" Тогда
				Если ИспользоватьРасширенныйПоиск Тогда
					Для Каждого ПозицияНоменклатуры Из ПозицииНоменклатуры Цикл
						Если ОтображаемоеПоле = ПозицияНоменклатуры.ИмяПоля Тогда
							Продолжить;
						КонецЕсли;
						НуженЗапрос = Истина;
					КонецЦикла;
				Иначе
					НуженЗапрос = Истина;
				КонецЕсли;
				
				Если ОтображаемоеПоле = "Штрихкод" Тогда
					НуженЗапросШтрихкода = НуженЗапрос;
				ИначеЕсли ОтображаемоеПоле = "Цена" Тогда
					НуженЗапросЦены = НуженЗапрос;
				ИначеЕсли ОтображаемоеПоле = "SKU" Тогда
					НуженЗапросSKU = НуженЗапрос;
				Иначе
					НуженЗапрос = Ложь;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		ТекстЗапросаШтрихкодаИЦены = "";
		Если НуженЗапросШтрихкода Или НуженЗапросЦены Или НуженЗапросSKU Тогда
			
			ТекстыЗапросов = Новый Массив;
			ТекстыВыборки = Новый Массив;
			ТекстыСоединений = Новый Массив;
			
			ТекстЗапроса =
				"ВЫБРАТЬ
				|	Номенклатура.Ссылка КАК Номенклатура
				|ПОМЕСТИТЬ Позиции
				|ИЗ
				|	Справочник.Номенклатура КАК Номенклатура
				|ГДЕ
				|	Номенклатура.Ссылка В (&Номенклатура)
				|;
				|";
			ТекстыЗапросов.Добавить(ТекстЗапроса);
			
			Если НуженЗапросШтрихкода Тогда
				ТекстЗапроса =
				"ВЫБРАТЬ
				|	Штрихкоды.Номенклатура КАК Номенклатура,
				|	МИНИМУМ(Штрихкоды.Штрихкод) КАК Штрихкод
				|ПОМЕСТИТЬ Штрихкоды
				|ИЗ
				|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
				|ГДЕ
				|	Штрихкоды.Номенклатура В (&Номенклатура)
				|	И ДЛИНАСТРОКИ(Штрихкоды.Штрихкод) < 15
				|СГРУППИРОВАТЬ ПО
				|	Штрихкоды.Номенклатура
				|;
				|";
				ТекстыЗапросов.Добавить(ТекстЗапроса);
				ТекстыВыборки.Добавить(
					"Штрихкоды.Штрихкод КАК Штрихкод,
					|");
				ТекстыСоединений.Добавить(
					"ЛЕВОЕ СОЕДИНЕНИЕ Штрихкоды КАК Штрихкоды 
					|ПО Позиции.Номенклатура = Штрихкоды.Номенклатура
					|");
			Конецесли;
			
			Если НуженЗапросЦены Тогда
				ТекстЗапроса =
				"ВЫБРАТЬ
				|	Цены.Номенклатура КАК Номенклатура,
				|	МАКСИМУМ(Цены.Цена) КАК Цена
				|ПОМЕСТИТЬ Цены
				|ИЗ
				|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, Номенклатура В (&Номенклатура)
				|	И ВидЦен = &ВидЦены) КАК Цены
				|СГРУППИРОВАТЬ ПО
				|	Цены.Номенклатура
				|;
				|";
				Если Не ЗначениеЗаполнено(ВидЦены) Тогда
					ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "И ВидЦен = &ВидЦены", "");
				КонецЕсли;
				ТекстыЗапросов.Добавить(ТекстЗапроса);
				ТекстыВыборки.Добавить(
					"Цены.Цена КАК Цена,
					|");
				ТекстыСоединений.Добавить(
					"ЛЕВОЕ СОЕДИНЕНИЕ Цены КАК Цены 
					|ПО Позиции.Номенклатура = Цены.Номенклатура
					|");
			КонецЕсли;
			
			Если НуженЗапросSKU Тогда
				ТекстЗапроса =
				"ВЫБРАТЬ
				|	КодыТоваровSKU.Номенклатура КАК Номенклатура,
				|	МАКСИМУМ(КодыТоваровSKU.SKU) КАК SKU
				|ПОМЕСТИТЬ КодыТоваровSKU
				|ИЗ
				|	РегистрСведений.КодыТоваровSKU КАК КодыТоваровSKU
				|ГДЕ
				|	КодыТоваровSKU.Номенклатура В (&Номенклатура)
				|СГРУППИРОВАТЬ ПО
				|	КодыТоваровSKU.Номенклатура
				|;
				|";
				ТекстыЗапросов.Добавить(ТекстЗапроса);
				ТекстыВыборки.Добавить(
					"КодыТоваровSKU.SKU КАК SKU,
					|");
				ТекстыСоединений.Добавить(
					"ЛЕВОЕ СОЕДИНЕНИЕ КодыТоваровSKU КАК КодыТоваровSKU 
					|ПО Позиции.Номенклатура = КодыТоваровSKU.Номенклатура
					|");
			КонецЕсли;
			
			ТекстыВыборки.Добавить("Позиции.Номенклатура КАК Номенклатура");
			
			ТекстЗапросаШтрихкодаИЦены =
				СтрСоединить(ТекстыЗапросов) +
				"ВЫБРАТЬ
				|" + СтрСоединить(ТекстыВыборки) +
				"
				| ИЗ Позиции КАК Позиции
				|" + СтрСоединить(ТекстыСоединений);
		Иначе
			ТекстЗапросаШтрихкодаИЦены = "";
		КонецЕсли;
		
		ДанныеШтрихкодовИЦен = Неопределено;
		Если ЗначениеЗаполнено(ТекстЗапросаШтрихкодаИЦены) Тогда
			Запрос = Новый Запрос(ТекстЗапросаШтрихкодаИЦены);
			Если ИспользоватьРасширенныйПоиск Тогда
				Запрос.УстановитьПараметр("Номенклатура", ПозицииНоменклатуры.ВыгрузитьКолонку("Ссылка"));
			Иначе
				Запрос.УстановитьПараметр("Номенклатура", ПозицииНоменклатуры);
			КонецЕсли;
			Если ЗначениеЗаполнено(ВидЦены) Тогда
				Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
			КонецЕсли;
			ДанныеШтрихкодовИЦен = Запрос.Выполнить().Выгрузить();
		КонецЕсли;
		
		НаименованияПолей = Новый Структура();
		НаименованияПолей.Вставить("Наименование", "");
		НаименованияПолей.Вставить("Код", НСтр("ru = 'Код:'"));
		НаименованияПолей.Вставить("Артикул", НСтр("ru = 'Арт.:'"));
		НаименованияПолей.Вставить("Цена", НСтр("ru = 'Цена:'"));
		НаименованияПолей.Вставить("SKU", НСтр("ru = 'SKU:'"));
		НаименованияПолей.Вставить("Штрихкод", НСтр("ru = 'ШК:'"));
		
		Для Каждого ПозицияНоменклатуры Из ПозицииНоменклатуры Цикл
			
			Если ИспользоватьРасширенныйПоиск Тогда
				Если ЗначениеЗаполнено(ПозицияНоменклатуры.ИмяПоля) Тогда
					ЗначениеПоиска = ПозицияНоменклатуры[ПозицияНоменклатуры.ИмяПоля];
				Иначе
					ЗначениеПоиска = ПозицияНоменклатуры.Наименование;
				КонецЕсли;
				
				Позиция = 0;
				ЗначениеПоиска = СокрЛП(ЗначениеПоиска);
				Для Каждого СловоПоиска Из СловаПоиска Цикл
					Если ПозицияНоменклатуры.ИмяПоля = "Цена" Или ПозицияНоменклатуры.ИмяПоля = "SKU" Тогда
						СловоПоискаЧисло = ОписаниеТипаЧисла.ПривестиЗначение(СловоПоиска);
						Если СловоПоискаЧисло > 0 Тогда
							СловоПоиска = Строка(СловоПоискаЧисло);
						КонецЕсли;
					КонецЕсли;
					Позиция = СтрНайти(НРег(ЗначениеПоиска), НРег(СловоПоиска));
					Если Позиция > 0 Тогда
						Прервать;
					КонецЕсли;
				КонецЦикла;
				
				ТекстИмяПоля = НаименованияПолей[ПозицияНоменклатуры.ИмяПоля];
				
				Если Позиция>0 Тогда
					
					ТекстДо = Лев(ЗначениеПоиска, Позиция-1);
					ТекстЦентр = Сред(ЗначениеПоиска, Позиция, СтрДлина(СловоПоиска));
					ТекстПосле = Сред(ЗначениеПоиска, Позиция + СтрДлина(СловоПоиска));
					ВыделенныйТекст = Новый ФорматированнаяСтрока(ТекстЦентр, Новый Шрифт(,,Истина), WebЦвета.ЗеленыйЛес);
					
					Представление = Новый ФорматированнаяСтрока(ТекстИмяПоля, ТекстДо, ВыделенныйТекст, ТекстПосле);
					
				Иначе
					Представление = Новый ФорматированнаяСтрока(ТекстИмяПоля, ЗначениеПоиска);
				КонецЕсли;
				
			Иначе
				Представление = ПозицияНоменклатуры.Представление;
			КонецЕсли;
			
			ПредставлениеПолей = "";
			ДанныеШтрихкодовИЦенПоНоменклатуре = Неопределено;
			Для Каждого ОтображаемоеПоле Из ОтображаемыеПоля Цикл
				Если ИспользоватьРасширенныйПоиск И ОтображаемоеПоле = ПозицияНоменклатуры.ИмяПоля Тогда
					Продолжить;
				КонецЕсли;
				
				ТекстИмяПоля = НаименованияПолей[ОтображаемоеПоле];
				
				ЗначениеПоля = "";
				Если ОтображаемоеПоле = "Цена" Или ОтображаемоеПоле = "SKU" Или ОтображаемоеПоле = "Штрихкод" Тогда
					Если ДанныеШтрихкодовИЦен = Неопределено Тогда
						Продолжить;
					КонецЕсли;
					Если ДанныеШтрихкодовИЦенПоНоменклатуре = Неопределено Тогда
						Если ИспользоватьРасширенныйПоиск Тогда
							ДанныеШтрихкодовИЦенПоНоменклатуре = ДанныеШтрихкодовИЦен.Найти(ПозицияНоменклатуры.Ссылка);
						Иначе
							ДанныеШтрихкодовИЦенПоНоменклатуре = ДанныеШтрихкодовИЦен.Найти(ПозицияНоменклатуры.Значение);
						КонецЕсли;
					КонецЕсли;
					Если Не ДанныеШтрихкодовИЦенПоНоменклатуре = Неопределено Тогда
						ЗначениеПоля = ДанныеШтрихкодовИЦенПоНоменклатуре[ОтображаемоеПоле];
					КонецЕсли;
				Иначе
					Если Не ИспользоватьРасширенныйПоиск Тогда
						Продолжить;
					КонецЕсли;
					ЗначениеПоля = ПозицияНоменклатуры[ОтображаемоеПоле];
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(ЗначениеПоля) Тогда
					Продолжить;
				КонецЕсли;
				
				ПредставлениеПолей = ПредставлениеПолей + ", " + ТекстИмяПоля + ЗначениеПоля;
			КонецЦикла;
			
			Если ЗначениеЗаполнено(ПредставлениеПолей) Тогда
				ПредставлениеПолей = Сред(ПредставлениеПолей, 3);
			КонецЕсли;
			
			ВыделенныйТекстВСкобках = "";
			Если ЗначениеЗаполнено(ПредставлениеПолей) Тогда
				ПредставлениеПолей = " (" + ПредставлениеПолей + ")";
				ВыделенныйТекстВСкобках = Новый ФорматированнаяСтрока(ПредставлениеПолей, , ЦветаСтиля.ЦветТекстаСверхЗаказаРМК);
					
				Представление = Новый ФорматированнаяСтрока(Представление, ВыделенныйТекстВСкобках);
			КонецЕсли;
			
			Если ИспользоватьРасширенныйПоиск Тогда
				ДанныеВыбора.Добавить(ПозицияНоменклатуры.Ссылка, Представление);
			Иначе
				ДанныеВыбора.Добавить(ПозицияНоменклатуры.Значение, Представление);
			КонецЕсли;
		
		КонецЦикла;
		
		Возврат;
	КонецЕсли;
	
	Если Параметры.Отбор.Свойство("ЭтоВызовИзРМК") Тогда
		Параметры.Отбор.Удалить("ЭтоВызовИзРМК");
		Если Параметры.Отбор.Свойство("ПометкаУдаления") Тогда
			Если Параметры.Отбор.ПометкаУдаления = Ложь Тогда
				Параметры.Отбор.Вставить("Недействителен", Ложь);
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если Параметры.ВыборГруппИЭлементов <> ИспользованиеГруппИЭлементов.Группы
			И Не Параметры.Отбор.Свойство("Недействителен") Тогда
			
			Параметры.Отбор.Вставить("Недействителен", Ложь);
		КонецЕсли;
	Конецесли;
		
КонецПроцедуры

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьУпрощеннуюФормуНоменклатуры") И ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка = Ложь;
		ВыбраннаяФорма = "ФормаЭлементаБыстрая";
	КонецЕсли;
	
КонецПроцедуры

