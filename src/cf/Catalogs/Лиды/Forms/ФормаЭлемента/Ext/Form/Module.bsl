#КонецОбласти

#Область ИзменениеИнтерфейсаПоДанным

&НаСервере
Процедура УправлениеФормой(ОбновлятьИнформациюПоКонтрагенту = Истина)
	
	ОбновитьВидимостьИДоступностьЭлементов();
	ОбновитьЗаголовок();
	ОбновитьИнтерфейсГруппыРезультат();
	ОбновитьИнтерфейсГруппыЗаявок();
	ОбновитьИнтерфейсПоВидуЛида();
	
	Если ОбновлятьИнформациюПоКонтрагенту Тогда
		ОбновитьИнтерфейсПоКонтрагенту();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсПриСоздании()
	
	ОбновитьОтображениеКнопокЗаявок();
	ОпределитьИнтерфейсПриТолькоПросмотре();
	
	Элементы.Запись.Видимость = ПланироватьЗагрузкуРесурсовПредприятияЖурналЗаписи;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимостьИДоступностьЭлементов()
	
	МожноРедактировать = ПравоДоступа("Редактирование", Метаданные.Справочники.Лиды);
	ЭтоНекачественныйЛид = ЭтоНекачественныйЛид();
	ЛидПереведенВПокупателя = ЛидПереведенВПокупателя();
	ЛидЗавершен = ЭтоНекачественныйЛид Или ЛидПереведенВПокупателя;
	
	Если ЛидЗавершен Тогда
		Элементы.СостояниеЛида.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
	Иначе
		Элементы.СостояниеЛида.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	КонецЕсли;
	
	ТолькоПросмотр = ЛидПереведенВПокупателя ИЛИ НЕ МожноРедактировать;
	
	Элементы.ОблакоТегов.Доступность = НЕ ЭтоНекачественныйЛид;
	Элементы.КолонкаСлева.Доступность = НЕ ЭтоНекачественныйЛид;
	Элементы.Представление.Доступность = НЕ ЭтоНекачественныйЛид;
	Элементы.Детали.Доступность = НЕ ЭтоНекачественныйЛид;
	
	Элементы.ПодменюЗаявки.Доступность = Не ЛидЗавершен;
	
	Элементы.УдаленныеКонтакты.Видимость = ЕстьУдаленныеКонтакты();
	Элементы.ЛидыПокупателя.Видимость = Не ЛидЗавершен;
	Элементы.ФормаПроверитьЛидаНаДубли.Видимость = ПроверятьПредставлениеНаДубли ИЛИ ПроверятьАдресЭПНаДубли
	ИЛИ ПроверятьНомерТелефонаНаДубли ИЛИ ПроверятьЮрНазваниеНаДубли;
	
	Если ОбязательноЗаполнятьИсточникВЛидах Тогда
		Элементы.ИсточникПривлечения.АвтоОтметкаНезаполненного = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗаголовок()
	
	Если Объект.Ссылка.Пустая() Тогда
		Заголовок = НСтр("ru = 'Лид (создание)'");
	ИначеЕсли ЭтоПовторныйЛидНаСервере() Тогда
		Заголовок = СтрШаблон(НСтр("ru = '%1 (Лид: Повторное обращение)'"), Объект.Ссылка);
	Иначе
		Заголовок = СтрШаблон(НСтр("ru = '%1 (Лид: Первичное обращение)'"), Объект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсПоВидуЛида()
	
	ЭтоПовторныйЛид = ЭтоПовторныйЛидНаСервере();
	
	Если ЭтоПовторныйЛид Тогда
		УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыВидыЛидов, Элементы.СтраницаПовторноеОбращение);
	Иначе
		УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыВидыЛидов, Элементы.СтраницаПервичноеОбращение);
	КонецЕсли;
	
	Элементы.ФормаПроверитьЛидаНаДубли.Видимость = Не ЭтоПовторныйЛид;
	
	ОбновитьКнопкиПереводаКачественногоЛида();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсПоКонтрагенту()
	
	ОбновитьКИПокупателя();
	ОбновитьСсылкуНаЛидовПокупателяВРаботе();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсГруппыРезультат()
	
	ЭтоНекачественныйЛид = ЭтоНекачественныйЛид();
	ЛидПереведенВПокупателя = ЛидПереведенВПокупателя();
	ЛидЗавершен = ЭтоНекачественныйЛид ИЛИ ЛидПереведенВПокупателя;
	
	Если ЛидЗавершен Тогда
		
		Элементы.ДекорацияЗаголовокРезультат.Заголовок = СтрШаблон(НСтр("ru='Работа с лидом завершена %1'"),
		Формат(Объект.ДатаЗавершенияРаботы,"ДЛФ=Д"));
		
	Иначе
		
		Элементы.ДекорацияЗаголовокРезультат.Заголовок = НСтр("ru='Завершение работы с лидом'");
		
	КонецЕсли;
	
	Если ЛидПереведенВПокупателя Тогда
		
		ТекущаяСтраницаРезультата = Элементы.СтраницаКачественныйЛид;
		ОбновитьОтображениеРезультатаКачественногоЛида();
		
	ИначеЕсли ЭтоНекачественныйЛид Тогда
		
		ТекущаяСтраницаРезультата = Элементы.СтраницаНекачественныйЛид;
		ОбновитьОтображениеРезультатаНекачественногоЛида();
		
	Иначе
		
		ТекущаяСтраницаРезультата = Элементы.СтраницаЛидВРаботе;
		
	КонецЕсли;
	
	УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыЗавершенияРаботы, ТекущаяСтраницаРезультата);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнтерфейсГруппыЗаявок()
	
	ИспользуютсяЗаявкиДляЗаказовНаПродажу = ИспользованиеЗаявок.ЗаказНаПродажу;
	ИспользуютсяЗаявкиДляЗаказНарядов = ИспользованиеЗаявок.ЗаказНаряд;
	
	Если Не ИспользуютсяЗаявкиДляЗаказовНаПродажу И Не ИспользуютсяЗаявкиДляЗаказНарядов Тогда
		Элементы.ГруппаЗаявки.Видимость = Ложь;
		Возврат;
	Иначе
		Элементы.ГруппаЗаявки.Видимость = Истина;
	КонецЕсли;
	
	КоличестваЗаявок = РаботаСЗаявками.ДанныеКоличестваЗаявокЛида();
	
	Если ИспользуютсяЗаявкиДляЗаказовНаПродажу И ИспользуютсяЗаявкиДляЗаказНарядов Тогда
		
		КоличествоЗаявок = РаботаСЗаявками.КоличествоЗаявокЛида(Объект.Ссылка);
		КоличествоЗаявокЗаказовПокупателей = КоличествоЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу];
		КоличествоЗаявокЗаказНарядов = КоличествоЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд];
		
	ИначеЕсли ИспользуютсяЗаявкиДляЗаказовНаПродажу Тогда
		
		КоличествоЗаявокЗаказовПокупателей = РаботаСЗаявками.КоличествоЗаявокЛида(
		Объект.Ссылка, Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу);
		КоличествоЗаявокЗаказНарядов = КоличестваЗаявок;
		
	Иначе
		
		КоличествоЗаявокЗаказовПокупателей = КоличестваЗаявок;
		КоличествоЗаявокЗаказНарядов = РаботаСЗаявками.КоличествоЗаявокЛида(
		Объект.Ссылка, Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд);
		
	КонецЕсли;
	
	Элементы.ГруппаЗаявкиЗаказыПокупателей.Видимость = ИспользуютсяЗаявкиДляЗаказовНаПродажу;
	Элементы.ГруппаЗаявкиЗаказНаряды.Видимость = ИспользуютсяЗаявкиДляЗаказНарядов;
	
	Если ИспользуютсяЗаявкиДляЗаказовНаПродажу Тогда
		Элементы.ЗаявкиЗаказыПокупателей.Заголовок = ЗаголовокПредставленияКоличестваЗаявок(
		КоличествоЗаявокЗаказовПокупателей);
	КонецЕсли;
	Если ИспользуютсяЗаявкиДляЗаказНарядов Тогда
		Элементы.ЗаявкиЗаказНаряды.Заголовок = ЗаголовокПредставленияКоличестваЗаявок(
		КоличествоЗаявокЗаказНарядов);
	КонецЕсли;
	
	ПоказатьОтменуЗаявок =
	ЗначениеЗаполнено(Объект.ВариантЗавершения)
	И (КоличествоЗаявокЗаказовПокупателей.КоличествоЗаявокВРаботе
	Или КоличествоЗаявокЗаказНарядов.КоличествоЗаявокВРаботе);
	
	Элементы.ОтменитьВсеЗаявкиВРаботе.Видимость = ПоказатьОтменуЗаявок;
	
КонецПроцедуры

&НаСервере
Функция ЗаголовокПредставленияКоличестваЗаявок(КоличестваЗаявок)
	
	Если КоличестваЗаявок.КоличествоОтмененныхЗаявок Тогда
		
		ПредставлениеОтмененныхЗаявок = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
		НСтр("ru=';%1 отмененная;;%1 отмененных;%1 отмененных;%1 отмененных'"),
		КоличестваЗаявок.КоличествоОтмененныхЗаявок);
		
	КонецЕсли;
	
	Если КоличестваЗаявок.КоличествоЗаявокВРаботе И КоличестваЗаявок.КоличествоОтмененныхЗаявок Тогда
		Возврат СтрШаблон("%1 в работе, %2", КоличестваЗаявок.КоличествоЗаявокВРаботе, ПредставлениеОтмененныхЗаявок);
	ИначеЕсли КоличестваЗаявок.КоличествоЗаявокВРаботе Тогда
		Возврат СтрШаблон("%1 в работе", КоличестваЗаявок.КоличествоЗаявокВРаботе);
	ИначеЕсли КоличестваЗаявок.КоличествоОтмененныхЗаявок Тогда
		Возврат ПредставлениеОтмененныхЗаявок;
	Иначе
		Возврат НСтр("ru = 'нет заявок в работе'");
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ОпределитьИнтерфейсПриТолькоПросмотре()
	
	Элементы.ПеревестиКачественногоЛида.Доступность = Не ТолькоПросмотр;
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСПовторнымОбращением

&НаСервере
Процедура ОбновитьСсылкуНаЛидовПокупателяВРаботе()
	
	Если ЗначениеЗаполнено(Контрагент) И ЧтениеРазрешено(Контрагент) Тогда
		Элементы.ЛидыПокупателя.Видимость = Истина;
	Иначе
		Элементы.ЛидыПокупателя.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЕСТЬNULL(СУММА(ВЫБОР
		|				КОГДА СвязиКонтрагентЛид.Лид.ВариантЗавершения = ЗНАЧЕНИЕ(Перечисление.ВариантЗавершенияРаботыСЛидом.ПустаяСсылка)
		|					ТОГДА 1
		|				ИНАЧЕ 0
		|			КОНЕЦ), 0) КАК КоличествоЛидовПокупателяВРаботе
		|ИЗ
		|	РегистрСведений.СвязиКонтрагентЛид КАК СвязиКонтрагентЛид
		|ГДЕ
		|	СвязиКонтрагентЛид.Контрагент = &Контрагент";
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Не Выборка.Следующий() Или Не Выборка.КоличествоЛидовПокупателяВРаботе Тогда
		Элементы.ЛидыПокупателя.Заголовок = НСтр("ru = 'Нет лидов в работе'");
		Возврат;
	КонецЕсли;
	
	ПредставлениеКоличестваЛидов = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
	НСтр("ru = ';%1 лид;;%1 лида;%1 лидов;%1 лида'"), Выборка.КоличествоЛидовПокупателяВРаботе);
	
	Элементы.ЛидыПокупателя.Заголовок = СтрШаблон(НСтр("ru = '%1 в работе'"), ПредставлениеКоличестваЛидов);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКИПокупателя()
	
	Если Не ЧтениеРазрешено(Контрагент) Тогда
		УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыПовторноеОбращениеКИ, Элементы.СтраницаНетДоступаКПокупателю);
		УдалитьКИПокупателя();
	ИначеЕсли Не ЗначениеЗаполнено(Контрагент) Тогда
		УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыПовторноеОбращениеКИ, Элементы.СтраницаНетПокупателя);
		УдалитьКИПокупателя();
	Иначе
		
		УстановитьПривилегированныйРежим(Истина);
		// СтандартныеПодсистемы.КонтактнаяИнформация
		ИмяЭлементаДляРазмещения = Элементы.КонтактнаяИнформацияПокупателя.Имя;
		УправлениеКонтактнойИнформацией.ПриЧтенииНаСервере(ЭтотОбъект, Контрагент, ИмяЭлементаДляРазмещения);
		// Конец СтандартныеПодсистемы.КонтактнаяИнформация
		УстановитьПривилегированныйРежим(Ложь);
		
		ОбновитьКонтактыПокупателя();
		
		УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыПовторноеОбращениеКИ, Элементы.СтраницаЕстьПокупатель);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьКИПокупателя()
	
	ЭлементыДляУдаления = Новый Массив;
	
	Для Каждого Элемент Из Элементы.КонтактнаяИнформацияПокупателя.ПодчиненныеЭлементы Цикл
		ЭлементыДляУдаления.Добавить(Элемент);
	КонецЦикла;
	
	Для Каждого Элемент Из ЭлементыДляУдаления Цикл
		Элементы.Удалить(Элемент);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКонтактыПокупателя()
	
	ЗаполнитьТаблицуКонтактовПокупателя();
	ОбновитьКонтактыПокупателяНаФорме();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуКонтактовПокупателя()
	
	ДанныеКонтактныхЛицПокупателя.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СвязиКонтрагентКонтактСрезПервых.Контакт КАК Контакт,
		|	СвязиКонтрагентКонтактСрезПервых.Порядок КАК Порядок
		|ПОМЕСТИТЬ втПорядокКонтактовКонтрагента
		|ИЗ
		|	РегистрСведений.СвязиКонтрагентКонтакт.СрезПервых(, Контрагент = &Контрагент) КАК СвязиКонтрагентКонтактСрезПервых
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтактныеЛица.Ссылка КАК КонтактноеЛицо,
		|	СвязиКонтрагентКонтакт.Контрагент КАК Владелец,
		|	СвязиКонтрагентКонтакт.Должность КАК Должность,
		|	КонтактныеЛица.Наименование КАК Наименование,
		|	втПорядокКонтактовКонтрагента.Порядок КАК РеквизитДопУпорядочивания
		|ПОМЕСТИТЬ втКонтакты
		|ИЗ
		|	РегистрСведений.СвязиКонтрагентКонтакт.СрезПоследних(, Контрагент = &Контрагент) КАК СвязиКонтрагентКонтакт
		|		ЛЕВОЕ СОЕДИНЕНИЕ втПорядокКонтактовКонтрагента КАК втПорядокКонтактовКонтрагента
		|		ПО (втПорядокКонтактовКонтрагента.Контакт = СвязиКонтрагентКонтакт.Контакт)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛица КАК КонтактныеЛица
		|		ПО СвязиКонтрагентКонтакт.Контакт = КонтактныеЛица.Ссылка
		|ГДЕ
		|	КонтактныеЛица.Недействителен = ЛОЖЬ
		|	И СвязиКонтрагентКонтакт.СвязьНедействительна = ЛОЖЬ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Контрагенты.КонтактноеЛицо КАК КонтактноеЛицо,
		|	Контрагенты.КонтактноеЛицоПодписант КАК КонтактноеЛицоПодписант
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Ссылка = &Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втКонтакты.КонтактноеЛицо КАК КонтактноеЛицо,
		|	втКонтакты.Наименование КАК Наименование,
		|	втКонтакты.Должность КАК Должность
		|ИЗ
		|	втКонтакты КАК втКонтакты
		|
		|УПОРЯДОЧИТЬ ПО
		|	втКонтакты.РеквизитДопУпорядочивания,
		|	Наименование";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаДанныхКонтрагента = РезультатыЗапроса[2].Выбрать();
	ВыборкаДанныхКонтрагента.Следующий();
	
	ВыборкаКонтактов = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаКонтактов.Следующий() Цикл
		
		СтрокаТЗ = ДанныеКонтактныхЛицПокупателя.Добавить();
		СтрокаТЗ.Ссылка = ВыборкаКонтактов.КонтактноеЛицо;
		СтрокаТЗ.КонтактноеЛицо = ВыборкаКонтактов.КонтактноеЛицо;
		СтрокаТЗ.Наименование = ВыборкаКонтактов.Наименование;
		СтрокаТЗ.Должность = ВыборкаКонтактов.Должность;
		СтрокаТЗ.Основной = (ВыборкаДанныхКонтрагента.КонтактноеЛицо = ВыборкаКонтактов.КонтактноеЛицо);
		СтрокаТЗ.Подписант = (ВыборкаДанныхКонтрагента.КонтактноеЛицоПодписант = ВыборкаКонтактов.КонтактноеЛицо);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьКонтактыПокупателяНаФорме(Знач ИндексОбновляемогоКонтакта = Неопределено)
	
	КоличествоКонтактовПокупателя = ДанныеКонтактныхЛицПокупателя.Количество();
	КоличествоКонтактовДляПоказаПоУмолчанию = КоличествоКонтактовДляПоказаПоУмолчанию();
	
	Если КоличествоКонтактовПокупателя = 0 Тогда
		
		УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыКонтактыПокупателя, Элементы.СтраницаНетКонтактовПокупателя);
		Возврат;
		
	КонецЕсли;
	
	УстановитьТекущуюСтраницуНаСервере(Элементы.СтраницыКонтактыПокупателя, Элементы.СтраницаКонтактыПокупателя);
	
	Если ИндексОбновляемогоКонтакта <> Неопределено
		И ИндексОбновляемогоКонтакта > КоличествоКонтактовДляПоказаПоУмолчанию - 1
		И Не ПоказыватьВсеКонтакты Тогда
		ПоказыватьВсеКонтакты = Истина;
		ИндексОбновляемогоКонтакта = Неопределено;
	КонецЕсли;
	
	Если ИндексОбновляемогоКонтакта = 0 И КоличествоКонтактовПокупателя = 1 Тогда
		ИндексОбновляемогоКонтакта = Неопределено;
	КонецЕсли;
	
	УдалитьКонтактыПокупателяСФормы(ИндексОбновляемогоКонтакта);

	
	Если ПоказыватьВсеКонтакты Тогда
		ПоследнийИндексКонтакта = КоличествоКонтактовПокупателя - 1;
	ИначеЕсли КоличествоКонтактовПокупателя > КоличествоКонтактовДляПоказаПоУмолчанию Тогда
		ПоследнийИндексКонтакта = КоличествоКонтактовДляПоказаПоУмолчанию - 1;
	ИначеЕсли КоличествоКонтактовПокупателя <> 0 Тогда
		ПоследнийИндексКонтакта = КоличествоКонтактовПокупателя - 1;
	Иначе
		ПоследнийИндексКонтакта = -1;

	КонецЕсли;
	
	ЕстьПоказанныеКонтакты = Ложь;
	
	Для ИндексКонтакта = 0 По ПоследнийИндексКонтакта Цикл
		
		ДанныеКонтактногоЛица = ДанныеКонтактныхЛицПокупателя[ИндексКонтакта];
		
		Если ИндексОбновляемогоКонтакта <> Неопределено И ИндексКонтакта <> ИндексОбновляемогоКонтакта Тогда
			Продолжить;
		КонецЕсли;
		
		Если ИндексКонтакта = 0 Тогда
			
			ЕстьПоказанныеКонтакты = Истина;
			ГруппаКИ = Элементы.КонтактнаяИнформацияКонтактаПокупателя_0;
			
			ЗаголовкиГрупп = ЗаголовкиГруппыКонтактаПокупателя(ДанныеКонтактныхЛицПокупателя[0]);
			Элементы.КонтактПокупателя_0.ЗаголовокСвернутогоОтображения = ЗаголовкиГрупп.ЗаголовокСвернутойГруппы;
			Элементы.КонтактПокупателя_0.Заголовок = ЗаголовкиГрупп.ЗаголовокГруппы;
			
		КонецЕсли;
		
		// Для первого контактного лица элементы формы созданы в конфигураторе
		Если ИндексКонтакта > 0 Тогда
			
			ЕстьПоказанныеКонтакты = Истина;
			
			ИмяГруппаКонтактногоЛица = СтрШаблон("КонтактПокупателя_%1", ИндексКонтакта);
			ИмяГруппаСледующегоКонтактногоЛица = СтрШаблон("КонтактПокупателя_%1", ИндексКонтакта + 1);
			
			ГруппаКонтактногоЛица = Элементы.Найти(ИмяГруппаКонтактногоЛица);
			Если ГруппаКонтактногоЛица = Неопределено Тогда
				ГруппаКонтактногоЛица = Элементы.Добавить(
				ИмяГруппаКонтактногоЛица, Тип("ГруппаФормы"), Элементы.ГруппаСписокКонтактовПокупателя);
			КонецЕсли;
			
			ГруппаКонтактногоЛица.Видимость = Истина;
			ГруппаКонтактногоЛица.Вид = Элементы.КонтактПокупателя_0.Вид;
			ГруппаКонтактногоЛица.Отображение = Элементы.КонтактПокупателя_0.Отображение;
			ГруппаКонтактногоЛица.Группировка = Элементы.КонтактПокупателя_0.Группировка;
			ГруппаКонтактногоЛица.ОтображатьЗаголовок = Элементы.КонтактПокупателя_0.ОтображатьЗаголовок;
			ГруппаКонтактногоЛица.Поведение = Элементы.КонтактПокупателя_0.Поведение;
			ГруппаКонтактногоЛица.ОтображениеУправления = Элементы.КонтактПокупателя_0.ОтображениеУправления;
			ГруппаКонтактногоЛица.ЦветТекстаЗаголовка = Элементы.КонтактПокупателя_0.ЦветТекстаЗаголовка;
			
			НужноПереместитьГруппу = ИндексОбновляемогоКонтакта <> Неопределено И ИндексКонтакта <> ПоследнийИндексКонтакта;
			Если НужноПереместитьГруппу Тогда
				ГруппаМестоположение = Элементы.Найти(ИмяГруппаСледующегоКонтактногоЛица);
			КонецЕсли;
			Если ГруппаМестоположение <> Неопределено Тогда
				Элементы.Переместить(ГруппаКонтактногоЛица, ГруппаКонтактногоЛица.Родитель, ГруппаМестоположение);
			КонецЕсли;
			
			ЗаголовкиГрупп = ЗаголовкиГруппыКонтактаПокупателя(ДанныеКонтактныхЛицПокупателя[ИндексКонтакта]);
			ГруппаКонтактногоЛица.ЗаголовокСвернутогоОтображения = ЗаголовкиГрупп.ЗаголовокСвернутойГруппы;
			ГруппаКонтактногоЛица.Заголовок = ЗаголовкиГрупп.ЗаголовокГруппы;
			
			Если Не ДанныеКонтактныхЛицПокупателя[ИндексКонтакта].ГруппаРазвернута
				Или Не ЗначениеЗаполнено(ДанныеКонтактныхЛицПокупателя[ИндексКонтакта].КонтактноеЛицо) Тогда
				ГруппаКонтактногоЛица.Скрыть();
			КонецЕсли;
			
			НаименованиеЭлемента = СтрШаблон("НаименованиеКонтактаПокупателя_%1", ИндексКонтакта);
			ПолеНаименование = Элементы.Добавить(НаименованиеЭлемента, Тип("ПолеФормы"), ГруппаКонтактногоЛица);
			ПолеНаименование.Вид = Элементы.НаименованиеКонтактаПокупателя_0.Вид;
			ПолеНаименование.ПутьКДанным = "ДанныеКонтактныхЛицПокупателя[" + ИндексКонтакта + "].Наименование";
			ПолеНаименование.ПоложениеЗаголовка = Элементы.НаименованиеКонтактаПокупателя_0.ПоложениеЗаголовка;
			ПолеНаименование.ПодсказкаВвода = Элементы.НаименованиеКонтактаПокупателя_0.ПодсказкаВвода;
			ПолеНаименование.АвтоМаксимальнаяШирина = Элементы.НаименованиеКонтактаПокупателя_0.АвтоМаксимальнаяШирина;
			ПолеНаименование.МаксимальнаяШирина = Элементы.НаименованиеКонтактаПокупателя_0.МаксимальнаяШирина;
			ПолеНаименование.КнопкаОткрытия = Элементы.НаименованиеКонтактаПокупателя_0.КнопкаОткрытия;
			ПолеНаименование.УстановитьДействие("Открытие", "Подключаемый_НаименованиеКонтактаПокупателя_Открытие");
			
			НаименованиеЭлемента = СтрШаблон("ДолжностьКонтактаПокупателя_%1", ИндексКонтакта);
			ПолеДолжность = Элементы.Добавить(НаименованиеЭлемента, Тип("ПолеФормы"), ГруппаКонтактногоЛица);
			ПолеДолжность.Вид = Элементы.ДолжностьКонтактаПокупателя_0.Вид;
			ПолеДолжность.ПутьКДанным = "ДанныеКонтактныхЛицПокупателя[" + ИндексКонтакта + "].Должность";
			ПолеДолжность.ПоложениеЗаголовка = Элементы.ДолжностьКонтактаПокупателя_0.ПоложениеЗаголовка;
			ПолеДолжность.ПодсказкаВвода = Элементы.ДолжностьКонтактаПокупателя_0.ПодсказкаВвода;
			ПолеДолжность.АвтоМаксимальнаяШирина = Элементы.ДолжностьКонтактаПокупателя_0.АвтоМаксимальнаяШирина;
			ПолеДолжность.МаксимальнаяШирина = Элементы.ДолжностьКонтактаПокупателя_0.МаксимальнаяШирина;
			
			НаименованиеЭлемента = СтрШаблон("КонтактнаяИнформацияКонтактаПокупателя_%1", ИндексКонтакта);
			ГруппаКИ = Элементы.Добавить(НаименованиеЭлемента, Тип("ГруппаФормы"), ГруппаКонтактногоЛица);
			ГруппаКИ.Вид = Элементы.КонтактнаяИнформацияКонтактаПокупателя_0.Вид;
			ГруппаКИ.Отображение = Элементы.КонтактнаяИнформацияКонтактаПокупателя_0.Отображение;
			ГруппаКИ.Группировка = Элементы.КонтактнаяИнформацияКонтактаПокупателя_0.Группировка;
			ГруппаКИ.ОтображатьЗаголовок = Элементы.КонтактнаяИнформацияКонтактаПокупателя_0.ОтображатьЗаголовок;
			ГруппаКИ.Ширина = Элементы.КонтактнаяИнформацияКонтактаПокупателя_0.Ширина;
			ГруппаКИ.РастягиватьПоГоризонтали = Элементы.КонтактнаяИнформацияКонтактаПокупателя_0.РастягиватьПоГоризонтали;
			
		КонецЕсли;
		
		ДанныеКонтактногоЛица.ИмяЭлементаДляРазмещения = ГруппаКИ.Имя;
		УстановитьПривилегированныйРежим(Истина);
		УправлениеКонтактнойИнформацией.ПриЧтенииНаСервереСвязанныхВладельцевКИ(ЭтотОбъект, ДанныеКонтактногоЛица);
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЦикла;
	
	СкрытьДобавлениеКИДляКонтактовПокупателя();
	
	ОсталосьКонтактов = КоличествоКонтактовПокупателя - ПоследнийИндексКонтакта - 1;
	Если ОсталосьКонтактов Тогда
		Элементы.ГруппаКомандКонтактовПокупателей.Видимость = Истина;
		Элементы.ПоказатьВсеКонтактыПокупателя.Заголовок = СтрШаблон(НСтр("ru = 'показать еще (%1)'"), ОсталосьКонтактов);
	Иначе
		Элементы.ГруппаКомандКонтактовПокупателей.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.КонтактПокупателя_0.Видимость = ЕстьПоказанныеКонтакты;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьКонтактыПокупателяСФормы(ИндексОбновляемогоКонтакта)
	
	УдаляемыеЭлементы = Новый Массив;
	Для ИндексГруппы = 1 По Элементы.ГруппаСписокКонтактовПокупателя.ПодчиненныеЭлементы.Количество()-1 Цикл
		Если ИндексОбновляемогоКонтакта = Неопределено Или ИндексГруппы = ИндексОбновляемогоКонтакта Тогда
			УдаляемыеЭлементы.Добавить(Элементы.ГруппаСписокКонтактовПокупателя.ПодчиненныеЭлементы[ИндексГруппы]);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
		Элементы.Удалить(УдаляемыйЭлемент);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ЗаголовкиГруппыКонтактаПокупателя(ДанныеКЛ)
	
	ЗаголовокСвернутойГруппы = Новый Массив;
	ЗаголовокГруппы = Новый Массив;
	
	Если ЗначениеЗаполнено(ДанныеКЛ.Наименование) Тогда
		ЗаголовокСвернутойГруппы.Добавить(ДанныеКЛ.Наименование);
		ЗаголовокГруппы.Добавить(ДанныеКЛ.Наименование);
	Иначе
		ЗаголовокСвернутойГруппы.Добавить(НСтр("ru = '<Не указано>'"));
		ЗаголовокГруппы.Добавить(НСтр("ru = '<Не указано>'"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеКЛ.Должность) Тогда
		ЗаголовокСвернутойГруппы.Добавить(ДанныеКЛ.Должность);
	Иначе
		ЗаголовокСвернутойГруппы.Добавить(НСтр("ru = '<Не указана>'"));
	КонецЕсли;
	
	ОтборПоТелефону = Новый Структура("Тип", ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон"));
	ТипКИТелефон = ДанныеКЛ.КонтактнаяИнформация.НайтиСтроки(ОтборПоТелефону);
	Если ТипКИТелефон.Количество() > 0 Тогда
		
		МассивСтрокКИ = Новый Массив;
		
		Если ЗначениеЗаполнено(ТипКИТелефон[0].Представление) Тогда
			МассивСтрокКИ.Добавить(ТипКИТелефон[0].Представление);
		КонецЕсли;
		
		Если ТипКИТелефон.Количество() > 1 Тогда
			МассивСтрокКИ.Добавить(СтрШаблон(НСтр("ru = '(еще %1)'"), ТипКИТелефон.Количество() - 1));



		КонецЕсли;
		
		Если МассивСтрокКИ.Количество() > 0 Тогда
			ЗаголовокСвернутойГруппы.Добавить(СтрСоединить(МассивСтрокКИ, Символы.НПП));
		КонецЕсли;
		
	КонецЕсли;
	
	ОтборПоПочте = Новый Структура("Тип", ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты"));
	ТипКИПочта = ДанныеКЛ.КонтактнаяИнформация.НайтиСтроки(ОтборПоПочте);
	
	Если ТипКИПочта.Количество() > 0 Тогда
		
		МассивСтрокКИ = Новый Массив;
		Если ЗначениеЗаполнено(ТипКИПочта[0].Представление) Тогда
			МассивСтрокКИ.Добавить(ТипКИПочта[0].Представление);
		КонецЕсли;
		
		Если ТипКИПочта.Количество() > 1 Тогда
			МассивСтрокКИ.Добавить(СтрШаблон(НСтр("ru = '(еще %1)'"), ТипКИПочта.Количество() - 1));
		КонецЕсли;
		
		Если МассивСтрокКИ.Количество() > 0 Тогда
			ЗаголовокСвернутойГруппы.Добавить(СтрСоединить(МассивСтрокКИ, Символы.НПП));
		КонецЕсли;
		
	КонецЕсли;
	
	Заголовки = Новый Структура;
	Заголовки.Вставить("ЗаголовокСвернутойГруппы", СтрСоединить(ЗаголовокСвернутойГруппы, ", "));
	Заголовки.Вставить("ЗаголовокГруппы", СтрСоединить(ЗаголовокГруппы, ", "));
	ДобавитьДанныеОсновнойПодписант(Заголовки, ДанныеКЛ);
	
	Возврат Заголовки;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ДобавитьДанныеОсновнойПодписант(Заголовки, ДанныеКЛ)
	
	СтрокаОсновнойПодписант = "";
	МассивОсновнойПодписант  = Новый Массив;
	
	Если НЕ ДанныеКЛ.Основной И НЕ ДанныеКЛ.Подписант Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеКЛ.Основной Тогда
		МассивОсновнойПодписант.Добавить(НСтр("ru = 'основной'"));
	КонецЕсли;
	
	Если ДанныеКЛ.Подписант Тогда
		МассивОсновнойПодписант.Добавить(НСтр("ru = 'подписант'"));
	КонецЕсли;
	
	СтрокаОсновнойПодписант = СтрСоединить(МассивОсновнойПодписант, ", ");


	
	Если НЕ ЗначениеЗаполнено(СтрокаОсновнойПодписант) Тогда
		Возврат;
	КонецЕсли;
	
	Заголовки.ЗаголовокСвернутойГруппы = СтрШаблон("%1 (%2)", Заголовки.ЗаголовокСвернутойГруппы, СтрокаОсновнойПодписант);
	Заголовки.ЗаголовокГруппы  = СтрШаблон("%1 (%2)", Заголовки.ЗаголовокГруппы, СтрокаОсновнойПодписант);
	
КонецПроцедуры

&НаСервере
Процедура СкрытьДобавлениеКИДляКонтактовПокупателя()
	
	КоличествоКонтактов = Элементы.ГруппаСписокКонтактовПокупателя.ПодчиненныеЭлементы.Количество();
	
	Для Индекс = 0 По КоличествоКонтактов - 1 Цикл
		
		ГруппаКИ = СтрШаблон("КонтактнаяИнформацияКонтактаПокупателя_%1", Индекс);
		ГруппаКИ = Элементы[ГруппаКИ];
		
		МожноУбратьВидимостьНеобходимогоЭлемента =
		ГруппаКИ.ПодчиненныеЭлементы.Количество()
		И ТипЗнч(ГруппаКИ.ПодчиненныеЭлементы[0]) = Тип("ГруппаФормы")
		И ГруппаКИ.ПодчиненныеЭлементы[0].ПодчиненныеЭлементы.Количество() > 1;
		
		Если МожноУбратьВидимостьНеобходимогоЭлемента Тогда
			ГруппаКИ.ПодчиненныеЭлементы[0].ПодчиненныеЭлементы[1].Видимость = Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
