&НаКлиенте
Асинх Процедура ПеревестиВНекачественныйЛид(Команда)
	
	Если ЭтоПовторныйЛид() И Не ЗначениеЗаполнено(Контрагент) Тогда
		
		ОбщегоНазначенияКлиент.СообщитьПользователю(
		НСтр("ru = 'Поле ""Покупатель"" не заполнено.'"), ,
		"Контрагент");
		Возврат;
		
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда
		
		ОтветОтПользователя = Ждать ВопросАсинх(
		НСтр("ru = 'Данные еще не записаны.
		|Перевод лида в некачественного возможен только после записи данных.
		|Данные будут записаны'"),
		РежимДиалогаВопрос.ОКОтмена);
		
		Если ОтветОтПользователя <> КодВозвратаДиалога.ОК Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ПеревестиВНекачественныйЛидСервер();
	РаботаСЛидамиКлиент.ОповеститьОбИзмененном(Объект.Ссылка);
	
КонецПроцедуры

