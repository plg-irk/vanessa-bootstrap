Процедура ДекорацияПеревестиВПокупателяИЗаказНарядПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка)
	
	ПеревестиЛидаПеретаскиваниемВНижнююПанель(СтандартнаяОбработка, ПараметрыПеретаскивания, "ЗаказНаряд");
	
КонецПроцедуры

#КонецОбласти

#Область Планировщик

&НаКлиенте
Процедура ПланировщикПриОкончанииРедактирования(Элемент, НовыйЭлемент, ОтменаРедактирования)
	
	ВыделенныеЭлементы = Элемент.ВыделенныеЭлементы;
	
	Лиды = Новый Массив;
	Для каждого ВыделенныйЭлемент Из ВыделенныеЭлементы Цикл
		Если ЗначениеЗаполнено(ВыделенныйЭлемент.Значение) Тогда
			Лиды.Добавить(ВыделенныйЭлемент.Значение);
		КонецЕсли;
	КонецЦикла;
	
	ДанныеЛидов = ДанныеЛидовПослеПроверкиВозможностиПереносаПоКанбану(Лиды, ОтменаРедактирования);
	Если ОтменаРедактирования Тогда
		Возврат;
	КонецЕсли;
	
	НовоеИзмерение = ВыделенныеЭлементы[0].ЗначенияИзмерений["СостоянияЛидов"];
	
	Если НовоеИзмерение =
		ПредопределенноеЗначение("Перечисление.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид") Тогда
		ОтменаРедактирования = Истина;
		ОткрытьФормуДляПереводаВНекачественного(Лиды);
		Возврат;
	КонецЕсли;
	
	Если НовоеИзмерение =
		ПредопределенноеЗначение("Перечисление.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя") Тогда
		
		ОтменаРедактирования = Истина;
		
		Лид = Лиды[0];
		ДанныеЛида = ДанныеЛидов[Лид];
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Лид", Лид);
		ПараметрыОповещения.Вставить("ДанныеЛида", ДанныеЛида);
		ОписаниеОповещения = Новый ОписаниеОповещения(
		"ВопросСОповещениемПроНаличиеЗаявокПередПереводомЛидаЗавершение", ЭтотОбъект, ПараметрыОповещения);
		
		ЕстьЗаявки =
		ДанныеЛида.НаличиеЗаявок[ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу")]
		Или ДанныеЛида.НаличиеЗаявок[ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд")];
		
		Если ЕстьЗаявки Тогда
			РаботаСЛидамиКлиент.ВопросСОповещениемПроНаличиеЗаявокПередПереводомЛида(ОписаниеОповещения);
		Иначе
			ВыполнитьОбработкуОповещения(ОписаниеОповещения, Новый Структура("Значение", "Продолжить"));
		КонецЕсли;
		
		Возврат;
		
	КонецЕсли;
	
	Если ДанныеЛидов[Лиды[0]].ВариантЗавершения =
		ПредопределенноеЗначение("Перечисление.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид") Тогда
		ОтменаРедактирования = Истина;
		ВернутьНекачественныхЛидовВРаботуКанбан(Лиды, НовоеИзмерение);
		Возврат;
	КонецЕсли;
	
	ПараметрыПеретаскивания = Новый Структура;

	ПараметрыПеретаскивания.Вставить("СмещаемыйЛид", Неопределено);
	ПараметрыПеретаскивания.Вставить("ПеретаскиваемыеЛиды", Лиды);
	ПараметрыПеретаскивания.Вставить("ПеретаскиваниеВНачалоСписка", Ложь);
	ПараметрыПеретаскивания.Вставить("ПеретаскиваниеВКонецСписка", Ложь);
	ПараметрыПеретаскивания.Вставить("Состояние", ВыделенныеЭлементы[0].ЗначенияИзмерений["СостоянияЛидов"]);
	
	Если ВыделенныеЭлементы[0].Начало = Планировщик.ТекущиеПериодыОтображения[0].Начало Тогда
		ПараметрыПеретаскивания.Вставить("ПеретаскиваниеВНачалоСписка", Истина);
		ОбновитьЭлементыПланировщикаПеретаскивание(ПараметрыПеретаскивания);
		РаботаСЛидамиКлиент.ОповеститьОбИзмененном(Лиды);
		Возврат;
	ИначеЕсли ВыделенныеЭлементы[0].Начало >= Планировщик.ТекущиеПериодыОтображения[0].Конец Тогда 
		ПараметрыПеретаскивания.Вставить("ПеретаскиваниеВКонецСписка", Истина);
		ОбновитьЭлементыПланировщикаПеретаскивание(ПараметрыПеретаскивания);
		РаботаСЛидамиКлиент.ОповеститьОбИзмененном(Лиды);
		Возврат;
	КонецЕсли;

	Для каждого ЭлементПланировщика Из Планировщик.Элементы Цикл
		// Поиск смещаемого лида
		//@skip-check bsl-legacy-check-dynamic-feature-access
		Если ((ЭлементПланировщика.Начало = ВыделенныеЭлементы[0].Начало 
			И ЭлементПланировщика.Конец = ВыделенныеЭлементы[0].Конец) 
			ИЛИ (ВыделенныеЭлементы[ВыделенныеЭлементы.ВГраница()].Конец > ЭлементПланировщика.Начало 
			И ВыделенныеЭлементы[ВыделенныеЭлементы.ВГраница()].Конец < ЭлементПланировщика.Конец))
			И ВыделенныеЭлементы[0].ЗначенияИзмерений.Получить("СостоянияЛидов") = ЭлементПланировщика.ЗначенияИзмерений.Получить("СостоянияЛидов")
			И ЭлементПланировщика.Значение <> ВыделенныеЭлементы[0].Значение Тогда
			
			ПараметрыПеретаскивания.Вставить("СмещаемыйЛид",ЭлементПланировщика.Значение);
			Прервать;
			
		КонецЕсли;
	КонецЦикла;
	
	ОбновитьЭлементыПланировщикаПеретаскивание(ПараметрыПеретаскивания);
	РаботаСЛидамиКлиент.ОповеститьОбИзмененном(Лиды);
	
КонецПроцедуры

&НаКлиенте
Процедура ПланировщикПриСменеТекущегоПериодаОтображения(Элемент, ТекущиеПериодыОтображения, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если МаксимальныйЭлементКанбан < ТекущиеПериодыОтображения[0].Начало - 1 Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеПериодыОтображения[0].Начало > Планировщик.ТекущиеПериодыОтображения[0].Конец Тогда
		ТекущийЭкранКанбан = ТекущийЭкранКанбан + 1;
		ОбновитьЭлементыПланировщика("Прокрутка","ПрокруткаВперед");
	ИначеЕсли ТекущиеПериодыОтображения[0].Начало < Планировщик.ТекущиеПериодыОтображения[0].Начало Тогда
		
		ТекущийЭкранКанбан = ТекущийЭкранКанбан - 1;
		
		Если ТекущийЭкранКанбан < 0 Тогда
			ТекущийЭкранКанбан = 0;
			Возврат;
		КонецЕсли;
		
		Если ТекущийЭкранКанбан = 0 Тогда
			ОбновитьЭлементыПланировщика("Создание");
		Иначе
			ОбновитьЭлементыПланировщика("Прокрутка","ПрокруткаНазад");
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

