&НаСервере
Процедура ОбновитьИзмеренияПланировщика()
	
	//@skip-check new-font
	ШрифтЗаголовка = Новый Шрифт(ШрифтыСтиля.ОбычныйШрифтТекста, , , Истина);
	
	ИзмеренияПланировщика = Планировщик.Измерения;
	ИзмеренияПланировщика.Очистить();
	ИзмерениеСостоянияЛидов = ИзмеренияПланировщика.Добавить("СостоянияЛидов");
	
	ОтборыПоРезультату = УстановленныеОтборыПоРезультату();
	
	Если ОтборыПоРезультату.ВРаботе Тогда
		
		ФильтрПоСостоянию = "";
		ЭлементыОтбора = ОбщегоНазначенияКлиентСервер.НайтиЭлементыИГруппыОтбора(Список.Отбор, "СостояниеЛида");
		Если ЭлементыОтбора.Количество() <> 0
			И ((ТипЗнч(ЭлементыОтбора[0].ПравоеЗначение) = Тип("СписокЗначений") И ЭлементыОтбора[0].ПравоеЗначение.Количество() <> 0) 
			И ЭлементыОтбора[0].Использование) Тогда
			ФильтрПоСостоянию = " И Ссылка в (&Состояния)";
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СостоянияЛидов.Ссылка КАК Ссылка,
			|	СостоянияЛидов.Наименование КАК Наименование,
			|	СостоянияЛидов.Цвет КАК Цвет
			|ИЗ
			|	Справочник.СостоянияЛидов КАК СостоянияЛидов
			|ГДЕ
			|	СостоянияЛидов.Ссылка <> ЗНАЧЕНИЕ(Справочник.СостоянияЛидов.Завершен)"
			+ Символы.ПС + ФильтрПоСостоянию + Символы.ПС +
			" УПОРЯДОЧИТЬ ПО СостоянияЛидов.РеквизитДопУпорядочивания";
		Если ЗначениеЗаполнено(ФильтрПоСостоянию) Тогда
			Запрос.УстановитьПараметр("Состояния",ЭлементыОтбора[0].ПравоеЗначение);
		КонецЕсли;
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			НовоеСостояние = ИзмерениеСостоянияЛидов.Элементы.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
			Цвет = ВыборкаДетальныеЗаписи.Цвет.Получить();
			
			Если Цвет = Неопределено Тогда
				Цвет = ЦветаСтиля.ЦветТекстаПоля;
			КонецЕсли;
			
			НовоеСостояние.ЦветТекста = Цвет;
			НовоеСостояние.Шрифт = ШрифтЗаголовка;
			НовоеСостояние.Текст =" ";
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если ОтборыПоРезультату.КачественныеЛиды Тогда
		НовоеСостояние = ИзмерениеСостоянияЛидов.Элементы.Добавить(
		Перечисления.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя);
		НовоеСостояние.Шрифт = ШрифтЗаголовка;
		НовоеСостояние.Текст =" ";
	КонецЕсли;
	
	Если ОтборыПоРезультату.НекачественныеЛиды Тогда
		НовоеСостояние = ИзмерениеСостоянияЛидов.Элементы.Добавить(
		Перечисления.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид);
		НовоеСостояние.Шрифт = ШрифтЗаголовка;
		НовоеСостояние.Текст =" ";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыПланировщикаПеретаскивание(ДанныеПеретаскивания)
	
	КанбанЛидов = Новый Структура;
	КанбанЛидов.Вставить("Операция","ПереместитьЛид");
	
	Если ДанныеПеретаскивания.ПеретаскиваниеВНачалоСписка Тогда
		КанбанЛидов.Вставить("Порядок",0);
	ИначеЕсли ДанныеПеретаскивания.ПеретаскиваниеВКонецСписка ИЛИ ДанныеПеретаскивания.СмещаемыйЛид = Неопределено Тогда
		КанбанЛидов.Вставить("Порядок",Неопределено);
	Иначе
		КанбанЛидов.Вставить("Порядок",ПорядокСмещаемогоЭлемента(ДанныеПеретаскивания.СмещаемыйЛид));
	КонецЕсли;
	
	КоличествоЛидов = ДанныеПеретаскивания.ПеретаскиваемыеЛиды.Количество();
	
	Для Каждого Лид Из ДанныеПеретаскивания.ПеретаскиваемыеЛиды Цикл
		
		ЛидОбъект = Лид.Ссылка.ПолучитьОбъект();
		КанбанЛидов.Вставить("СостояниеЛида",ЛидОбъект.СостояниеЛида);
		ЛидОбъект.СостояниеЛида = ДанныеПеретаскивания.Состояние;
		Если КоличествоЛидов = 1 Тогда
			ЛидОбъект.ДополнительныеСвойства.Вставить("КанбанЛидов",КанбанЛидов);
		Иначе
			ЛидОбъект.ДополнительныеСвойства.Вставить("НеЗаписыватьДанныеВРегистр",Истина);
		КонецЕсли;
		
		Если Не ЛидОбъект.ПроверитьЗаполнение() Тогда
			Продолжить;
		КонецЕсли;
		
		ЛидОбъект.Записать();
		
		Если ДанныеПеретаскивания.ПеретаскиваниеВКонецСписка
			ИЛИ ДанныеПеретаскивания.СмещаемыйЛид = Неопределено
			ИЛИ ДанныеПеретаскивания.ПеретаскиваниеВНачалоСписка Тогда
			
			Строка = ПервыйПоследнийЭлементКанбан.НайтиСтроки(Новый Структура("Состояние",ДанныеПеретаскивания.Состояние));
			Строка[0].Количество = Строка[0].Количество + 1;
			ОбновитьТаблицуПервыйПоследнийЭлементКанбан(ЛидОбъект,ДанныеПеретаскивания.ПеретаскиваниеВНачалоСписка);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если КоличествоЛидов > 1 Тогда
		РегистрыСведений.КанбанЛидов.ПереместитьЛиды(
		КанбанЛидов.СостояниеЛида,
		ДанныеПеретаскивания.Состояние,
		ДанныеПеретаскивания.ПеретаскиваемыеЛиды,
		КанбанЛидов.Порядок);
	КонецЕсли;
	
	ОбновитьЭлементыПланировщика("Перетаскивание");
	
	// Если при перетаскивании на текущем экране не осталось элементов возвращение на предыдущий экран
	Если КоличествоСостоянийБезОтображаемыхЭлементов = Планировщик.Измерения[0].Элементы.Количество() Тогда
		ТекущийЭкранКанбан = ТекущийЭкранКанбан - 1;
		ОбновитьЭлементыПланировщика("Прокрутка","ПрокруткаНазад");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЭлементыПланировщика(Операция, НаправлениеПрокрутки = Неопределено)
	
	ШиринаКарточкиКанбан = 2;
	ШиринаПанелейКанбан = 1;
	КоличествоОтображаемыхЭлементовКанбан = 14;
	НачалоОтображенияКанбан = НачалоДня(ТекущаяДатаСеанса());
	КонецОтображенияКанбан = НачалоОтображенияКанбан 
		+ КоличествоОтображаемыхЭлементовКанбан * ШиринаКарточкиКанбан 
		+ ШиринаПанелейКанбан;
	МаксимальныйЭлементКанбан = НачалоОтображенияКанбан;
	Планировщик.ТекущиеПериодыОтображения.Очистить();
	Планировщик.ТекущиеПериодыОтображения.Добавить(НачалоОтображенияКанбан, КонецОтображенияКанбан);
	ЭлементыПланировщика = Планировщик.Элементы;
	ЭлементыПланировщика.Очистить();
	ДанныеПанелиКИКанбан.Очистить();
	
	СтрокаФильтровКанбан = СтрокаФильтровКанбан();
	КоличествоЛидовПоСостояниям = КоличествоЭлементовПоСостояниямКанбан();
	КоличествоСостоянийБезОтображаемыхЭлементов = 0;
	
	Для Каждого Состояние Из Планировщик.Измерения[0].Элементы Цикл
		
		ЭтоИзмерениеСЗавершеннымиЛидами =
		(ТипЗнч(Состояние.Значение) = Тип("ПеречислениеСсылка.ВариантЗавершенияРаботыСЛидом"));
		
		КоличествоЛидовПоСостоянию = КоличествоЛидовПоСостояниям.Найти(Состояние.Значение, "СостояниеЛида");
		ЦветаЭлементовСостояния = ЦветаЭлементовСостояния(Состояние);
		
		// Панель в начало
		ДобавитьЭлементВКанбан(НачалоОтображенияКанбан,
			НачалоОтображенияКанбан + 1,
			Строка(Состояние.Значение),
			Справочники.Лиды.ПустаяСсылка(),
			Состояние,
			ЦветаЭлементовСостояния.ЦветПанели,
			БиблиотекаКартинок.ПеретащитьЭлементВНачало);
		// Панель в конец
		ДобавитьЭлементВКанбан(КонецОтображенияКанбан,
			КонецОтображенияКанбан + 1,
			?(КоличествоЛидовПоСостоянию = Неопределено,"Всего: 0","Всего: " + Строка(КоличествоЛидовПоСостоянию.Количество)),
			Справочники.Лиды.ПустаяСсылка(),
			Состояние, 
			ЦветаЭлементовСостояния.ЦветПанели,
			БиблиотекаКартинок.ПеретащитьЭлементВКонец);
			
		Строка = ПервыйПоследнийЭлементКанбан.НайтиСтроки(Новый Структура("Состояние",Состояние.Значение));
		Если Строка.Количество() = 0 Тогда
			НоваяСтрока = ПервыйПоследнийЭлементКанбан.Добавить();
			НоваяСтрока.Состояние = Состояние.Значение;
			Строка.Добавить(НоваяСтрока);
		КонецЕсли;
		Если Операция = "Создание" ИЛИ ТекущийЭкранКанбан = 0 Тогда
			Строка[0].ПорядокПервогоЭлемента = 0;
			ТекущийЭкранКанбан = 0;
		КонецЕсли;
		
		Если КоличествоЛидовПоСостоянию = Неопределено 
			ИЛИ КоличествоЛидовПоСостоянию.Количество < (ТекущийЭкранКанбан*КоличествоОтображаемыхЭлементовКанбан - (ТекущийЭкранКанбан - 1))  Тогда
			КоличествоСостоянийБезОтображаемыхЭлементов = КоличествоСостоянийБезОтображаемыхЭлементов + 1;
			Продолжить;
		КонецЕсли;
		
		Строка[0].Количество = КоличествоЛидовПоСостоянию.Количество;
		
		Если Операция = "Создание" ИЛИ Операция = "Перетаскивание" Тогда
			
			Если ЭтоИзмерениеСЗавершеннымиЛидами Тогда
				Порядок = РегистрыСведений.КанбанЛидов.НовыйКрайнийПорядковыйНомер(, Состояние.Значение);
			Иначе
				Порядок = Строка[0].ПорядокПервогоЭлемента;
			КонецЕсли;
			
		ИначеЕсли Операция = "Прокрутка" И НаправлениеПрокрутки = "ПрокруткаВперед" Тогда
			Порядок = Строка[0].ПорядокПоследнегоЭлемента;
		ИначеЕсли КоличествоЛидовПоСостоянию.Количество <=
			((ТекущийЭкранКанбан + 1) * КоличествоОтображаемыхЭлементовКанбан - ТекущийЭкранКанбан) Тогда
			Порядок = Строка[0].ПорядокПоследнегоЭлемента;
		Иначе
			Порядок = Строка[0].ПорядокПервогоЭлемента;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапросаКанбан(Операция,
		НаправлениеПрокрутки,
		ЭтоИзмерениеСЗавершеннымиЛидами,
		?(КоличествоЛидовПоСостоянию.Количество <= ((ТекущийЭкранКанбан + 1)*КоличествоОтображаемыхЭлементовКанбан - ТекущийЭкранКанбан),
		КоличествоЛидовПоСостоянию.Количество - (ТекущийЭкранКанбан*КоличествоОтображаемыхЭлементовКанбан - ТекущийЭкранКанбан),
		КоличествоОтображаемыхЭлементовКанбан));
		
		Запрос.УстановитьПараметр("Порядок", Порядок);
		Если ЭтоИзмерениеСЗавершеннымиЛидами Тогда
			Запрос.УстановитьПараметр("ВариантЗавершения",Состояние.Значение);
		Иначе
			Запрос.УстановитьПараметр("Состояние",Состояние.Значение);
		КонецЕсли;
		
		УстановитьПараметрыФильтров(Запрос);
		Результат = Запрос.Выполнить();
		Выборка = Результат.Выбрать();
		
		Если Выборка.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ИндексСтроки = 0;
		
		Пока Выборка.Следующий() Цикл
			
			Если Операция = "Прокрутка" И НаправлениеПрокрутки = "ПрокруткаНазад" Тогда
				КонецЭлемента = НачалоОтображенияКанбан + ((Выборка.Количество() * ШиринаКарточкиКанбан) 
				+ ШиринаПанелейКанбан - ИндексСтроки);
				НачалоЭлемента = КонецЭлемента - ШиринаКарточкиКанбан;
				Если ИндексСтроки = 0 Тогда
					Строка[0].ПорядокПоследнегоЭлемента = Выборка.Порядок;
					Строка[0].КонецОтображенияПоследнего = КонецЭлемента;
				Иначе
					Строка[0].ПорядокПервогоЭлемента = Выборка.Порядок;
				КонецЕсли;
			Иначе
				НачалоЭлемента = НачалоОтображенияКанбан + ШиринаПанелейКанбан + ИндексСтроки;
				КонецЭлемента = НачалоЭлемента + ШиринаКарточкиКанбан;
				Если ИндексСтроки = 0 Тогда
					Строка[0].ПорядокПервогоЭлемента = Выборка.Порядок;
				Иначе
					Строка[0].ПорядокПоследнегоЭлемента = Выборка.Порядок;
					Строка[0].КонецОтображенияПоследнего = КонецЭлемента;
				КонецЕсли;
			КонецЕсли;
			
			Если Выборка.Вид = Перечисления.ВидыЛидов.ПервичноеОбращение Тогда
				Картинка = БиблиотекаКартинок.ПервичныйЛид;
			Иначе
				Картинка = БиблиотекаКартинок.ПовторныйЛид;
			КонецЕсли;
			
			ДобавитьЭлементВКанбан(
			НачалоЭлемента,
			КонецЭлемента,
			ПредставлениеЛидаКанбан(Выборка),
			Выборка.Лид,
			Состояние,
			ЦветаЭлементовСостояния.ЦветЭлемента,
			Картинка);
			
			Если КонецЭлемента > МаксимальныйЭлементКанбан Тогда
				МаксимальныйЭлементКанбан = КонецЭлемента;
			КонецЕсли;
			ИндексСтроки = ИндексСтроки + ШиринаКарточкиКанбан;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаКанбан(
	Операция, НаправлениеПрокрутки, ЭтоИзмерениеСЗавершеннымиЛидами, Количество = 14)
	
	Если Операция = "Прокрутка" И НаправлениеПрокрутки = "ПрокруткаНазад" Тогда
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 14
		|	КанбанЛидов.Состояние КАК Состояние,
		|	КанбанЛидов.Лид КАК Лид,
		|	КанбанЛидов.Порядок КАК Порядок,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Лиды.Ссылка) КАК Представление,
		|	Лиды.КонтактнаяИнформация.(
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Тип, ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.ПустаяСсылка)) КАК Тип,
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Вид, ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПустаяСсылка)) КАК Вид,
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Представление, """") КАК Представление,
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Значение, """") КАК Значение
		|	) КАК КонтактнаяИнформация,
		|	СвязиКонтрагентЛид.Контрагент КАК Контрагент,
		|	СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.(
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Тип, ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.ПустаяСсылка)) КАК Тип,
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Вид, ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПустаяСсылка)) КАК Вид,
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Представление, """") КАК Представление,
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Значение, """") КАК Значение
		|	) КАК КонтактнаяИнформацияКонтрагента,
		|	Лиды.Теги.(
		|		Тег.Наименование КАК ТегНаименование
		|	) КАК Теги,
		|	Лиды.Комментарий КАК Комментарий,
		|	Лиды.ДатаСоздания КАК ДатаСоздания,
		|	Лиды.Вид КАК Вид
		|ИЗ
		|	Справочник.Лиды КАК Лиды
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КанбанЛидов КАК КанбанЛидов
		|		ПО (КанбанЛидов.Лид = Лиды.Ссылка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СвязиКонтрагентЛид КАК СвязиКонтрагентЛид
		|		ПО Лиды.Ссылка = СвязиКонтрагентЛид.Лид
		|ГДЕ
		|	КанбанЛидов.Состояние = &Состояние
		|	И Лиды.ПометкаУдаления = ЛОЖЬ
		|	И КанбанЛидов.Порядок <= &Порядок"
		+ СтрокаФильтровКанбан + Символы.ПС +
		"УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок УБЫВ";
		
		Если ЭтоИзмерениеСЗавершеннымиЛидами Тогда
			Текст = СтрЗаменить(Текст,
			"УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок УБЫВ",
			"УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок");
			Текст = СтрЗаменить(Текст,
			"И КанбанЛидов.Порядок <= &Порядок",
			"И КанбанЛидов.Порядок >= &Порядок");
		КонецЕсли;
		
	Иначе
		
		Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 14
		|	КанбанЛидов.Состояние КАК Состояние,
		|	КанбанЛидов.Лид КАК Лид,
		|	КанбанЛидов.Порядок КАК Порядок,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Лиды.Ссылка) КАК Представление,
		|	Лиды.КонтактнаяИнформация.(
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Тип, ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.ПустаяСсылка)) КАК Тип,
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Вид, ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПустаяСсылка)) КАК Вид,
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Представление, """") КАК Представление,
		|		ЕСТЬNULL(Лиды.КонтактнаяИнформация.Значение, """") КАК Значение
		|	) КАК КонтактнаяИнформация,
		|	СвязиКонтрагентЛид.Контрагент КАК Контрагент,
		|	СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.(
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Тип, ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.ПустаяСсылка)) КАК Тип,
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Вид, ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПустаяСсылка)) КАК Вид,
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Представление, """") КАК Представление,
		|		ЕСТЬNULL(СвязиКонтрагентЛид.Контрагент.КонтактнаяИнформация.Значение, """") КАК Значение
		|	) КАК КонтактнаяИнформацияКонтрагента,
		|	Лиды.Теги.(
		|		Тег.Наименование КАК ТегНаименование
		|	) КАК Теги,
		|	Лиды.Комментарий КАК Комментарий,
		|	Лиды.ДатаСоздания КАК ДатаСоздания,
		|	Лиды.Вид КАК Вид
		|ИЗ
		|	Справочник.Лиды КАК Лиды
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КанбанЛидов КАК КанбанЛидов
		|		ПО Лиды.Ссылка = КанбанЛидов.Лид
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СвязиКонтрагентЛид КАК СвязиКонтрагентЛид
		|		ПО Лиды.Ссылка = СвязиКонтрагентЛид.Лид
		|ГДЕ
		|	КанбанЛидов.Состояние = &Состояние
		|	И Лиды.ПометкаУдаления = ЛОЖЬ
		|	И КанбанЛидов.Порядок >= &Порядок"
		+ СтрокаФильтровКанбан + Символы.ПС +
		" УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок";
		
		Если ЭтоИзмерениеСЗавершеннымиЛидами Тогда
			Текст = СтрЗаменить(Текст,
			"УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок",
			"УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок УБЫВ");
			Текст = СтрЗаменить(Текст,
			"И КанбанЛидов.Порядок >= &Порядок",
			"И КанбанЛидов.Порядок <= &Порядок");
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоИзмерениеСЗавершеннымиЛидами Тогда
		Текст = СтрЗаменить(Текст,
		"КанбанЛидов.Состояние = &Состояние",
		"КанбанЛидов.ВариантЗавершения = &ВариантЗавершения");
	КонецЕсли;
	
	Текст = СтрЗаменить(Текст, "14", Количество);
	
	Возврат Текст;
	
КонецФункции

&НаСервере
Функция СтрокаФильтровКанбан()
	
	МассивСтрок = Новый Массив;
	
	Для Каждого ЭлементОтбора Из Список.КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
		
		Если ЭлементОтбора.Представление = "Период" Тогда
			Если ЭлементОтбора.Элементы[0].Использование И ЭлементОтбора.Элементы[1].Использование Тогда
				МассивСтрок.Добавить(" И ДатаСоздания >= &ДатаНачала И ДатаСоздания <= &ДатаОкончания");
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если Не ЭлементОтбора.Элементы.Количество() Или Не ЭлементОтбора.Элементы[0].Использование Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭлементОтбора.Представление = "ОтборИсточник" Тогда
			МассивСтрок.Добавить(" И ИсточникПривлечения В (&ИсточникПривлечения) ");
		ИначеЕсли ЭлементОтбора.Представление = "ОтборКонтрагент" Тогда
			МассивСтрок.Добавить(" И СвязиКонтрагентЛид.Контрагент В (&Контрагент) ");
		ИначеЕсли ЭлементОтбора.Представление = "ОтборОтветственный" Тогда
			МассивСтрок.Добавить(" И Ответственный В (&Ответственный) ");
		ИначеЕсли ЭлементОтбора.Представление = "ОтборВид" Тогда
			МассивСтрок.Добавить(" И Вид В (&Вид) ");
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого ЭлементОтбора Из Список.Отбор.Элементы Цикл
		
		Если (ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("Массив") 
			ИЛИ ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СписокЗначений"))
			И ЭлементОтбора.ПравоеЗначение.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ ЭлементОтбора.Использование Тогда
			Продолжить;
		КонецЕсли;
		
		Если Строка(ЭлементОтбора.ЛевоеЗначение) = "Теги.Тег" Тогда
			МассивСтрок.Добавить(" И Теги.Тег В (&Теги) ");
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "Ответственный" Тогда
			МассивСтрок.Добавить(" И Ответственный В (&Ответственный) ");
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "ИсточникПривлечения" Тогда
			МассивСтрок.Добавить(" И ИсточникПривлечения В (&ИсточникПривлечения) ");
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "СостояниеЛида" Тогда
			МассивСтрок.Добавить(" И СостояниеЛида В (&СостояниеФильтр) ");
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "Контрагент" Тогда
			МассивСтрок.Добавить(" И СвязиКонтрагентЛид.Контрагент В (&Контрагент) ");
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "Вид" Тогда
			МассивСтрок.Добавить(" И Вид В (&Вид) ");
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ОтборПоиск) Тогда
		МассивСтрок.Добавить(" И ОсновныеСведения ПОДОБНО &Поиск ");
	КонецЕсли;
	
	Для Каждого ЭлементОтбораСписка Из Список.Отбор.Элементы Цикл
		Если ЭлементОтбораСписка.Использование = Ложь Тогда
			Продолжить;
		КонецЕсли;
		Если Строка(ЭлементОтбораСписка.ЛевоеЗначение) = "Родитель" Тогда
			Если Элементы.ОтборИерархияКонтекстноеМенюИерархияВключаяВложенные.Пометка И ЗначениеЗаполнено(ЭлементОтбораСписка.ПравоеЗначение) Тогда
				МассивСтрок.Добавить(" И Родитель В ИЕРАРХИИ (&Родитель) ");
			Иначе
				МассивСтрок.Добавить(" И Родитель = &Родитель ");
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	СтрокаФильтров = СтрСоединить(МассивСтрок, Символы.ПС);
	
	Возврат СтрокаФильтров;
	
КонецФункции

&НаСервере
Функция ПредставлениеЛидаКанбан(Строка)
	
	МассивСтрок = Новый Массив;
	
	Если ЗначениеЗаполнено(Строка.Представление) Тогда
		МассивСтрок.Добавить(Строка.Представление);
	КонецЕсли;
	
	ОбработатьКИЛидаКанбан(Строка, МассивСтрок);
	
	Если ЗначениеЗаполнено(Строка.Комментарий) Тогда
		МассивСтрок.Добавить(Строка.Комментарий);
	КонецЕсли;
	
	МассивСтрок.Добавить(Формат(Строка.ДатаСоздания + Символы.ПС,"ДЛФ = DD"));
	
	ТегиКонтакта = Строка.Теги.Выгрузить();
	Для Каждого Тег Из ТегиКонтакта Цикл
		МассивСтрок.Добавить(СтрШаблон("#%1", Тег.ТегНаименование));
	КонецЦикла;
	
	Представление = СтрСоединить(МассивСтрок,Символы.ПС);
	
	Возврат Представление;
	
КонецФункции

&НаСервере
Процедура ОбработатьКИЛидаКанбан(Строка, МассивСтрок)
	
	Если Не ЧтениеРазрешено(Строка.Контрагент) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Строка.Контрагент) Тогда
		
		КИКонтрагента = Строка.КонтактнаяИнформацияКонтрагента.Выгрузить();
		
		ДополнительныйВыбор = Новый Структура;
		ДополнительныйВыбор.Вставить("Наименование");
		ДополнительныйВыбор.Вставить("КонтактнаяИнформация");
		Контакты = Справочники.Контрагенты.СвязанныеКонтакты(Строка.Контрагент, ДополнительныйВыбор);
		
	Иначе
		КИКонтрагента = Строка.КонтактнаяИнформация.Выгрузить();
		Контакты = Справочники.КонтактыЛидов.КонтактыЛида(Строка.Лид);
	КонецЕсли;
	
	Для Каждого СтрокаКИ Из КИКонтрагента Цикл
		НоваяСтрока = ДанныеПанелиКИКанбан.Добавить();
		Комментарий = УправлениеКонтактнойИнформацией.КомментарийКонтактнойИнформации(СтрокаКИ.Значение);
		НоваяСтрока.Отображение = Строка(СтрокаКИ.Вид) + ": " + СтрокаКИ.Представление + ?(ПустаяСтрока(Комментарий), "", ", " + Комментарий);
		НоваяСтрока.ИндексПиктограммы = КонтактнаяИнформацияПанельУнф.ИндексПиктограммыПоТипу(СтрокаКИ.Тип);
		НоваяСтрока.ТипОтображаемыхДанных = "ЗначениеКИ";
		НоваяСтрока.ВладелецКИ = Строка.Лид;
		НоваяСтрока.ПредставлениеКИ = СтрокаКИ.Представление;
		НоваяСтрока.СсылкаНаЛид = Строка.Лид;
		НоваяСтрока.ТипКИ = СтрокаКИ.Тип;
	КонецЦикла;
	
	ТекущийКонтакт = Неопределено;
	
	Для Каждого Контакт Из Контакты Цикл
		
		Если ЗначениеЗаполнено(Контакт.Наименование) И Контакт.Наименование <> Строка.Представление Тогда
			МассивСтрок.Добавить(Контакт.Наименование);
		КонецЕсли;
		
		// Заполнение таблицы для панели контактной информации
		Если ТекущийКонтакт <> Контакт.Наименование Тогда
			НоваяСтрока = ДанныеПанелиКИКанбан.Добавить();
			НоваяСтрока.Отображение = Контакт.Наименование;
			НоваяСтрока.ИндексПиктограммы = -1;
			НоваяСтрока.ТипОтображаемыхДанных = "КонтактноеЛицо";
			НоваяСтрока.ВладелецКИ = Строка.Лид;
			НоваяСтрока.СсылкаНаЛид = Строка.Лид;
			ТекущийКонтакт = Контакт.Наименование;
		КонецЕсли;
		
		КИКонтакта = Контакт.КонтактнаяИнформация;
		
		Для Каждого СтрокаКИ Из КИКонтакта Цикл
			
			МассивСтрок.Добавить(СтрокаКИ.Представление);
			Если НЕ ЗначениеЗаполнено(СтрокаКИ.Тип) Тогда
				Продолжить;
			КонецЕсли;
			
			// Заполнение таблицы для панели контактной информации
			НоваяСтрока = ДанныеПанелиКИКанбан.Добавить();
			Комментарий = УправлениеКонтактнойИнформацией.КомментарийКонтактнойИнформации(СтрокаКИ.Значение);
			НоваяСтрока.Отображение = Строка(СтрокаКИ.Вид) + ": " + СтрокаКИ.Представление + ?(ПустаяСтрока(Комментарий), "", ", " + Комментарий);
			НоваяСтрока.ИндексПиктограммы = КонтактнаяИнформацияПанельУнф.ИндексПиктограммыПоТипу(СтрокаКИ.Тип);
			НоваяСтрока.ТипОтображаемыхДанных = "ЗначениеКИ";
			НоваяСтрока.ВладелецКИ = Строка.Лид;
			НоваяСтрока.ПредставлениеКИ = СтрокаКИ.Представление;
			НоваяСтрока.СсылкаНаЛид = Строка.Лид;
			НоваяСтрока.ТипКИ = СтрокаКИ.Тип;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыФильтров(Запрос)
	
	Для Каждого ЭлементОтбора Из Список.КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
		
		Если ЭлементОтбора.Представление = "Период" Тогда
			Если ЭлементОтбора.Элементы[0].Использование И ЭлементОтбора.Элементы[1].Использование Тогда
				Запрос.УстановитьПараметр("ДатаНачала",ЭлементОтбора.Элементы[0].ПравоеЗначение);
				Запрос.УстановитьПараметр("ДатаОкончания",ЭлементОтбора.Элементы[1].ПравоеЗначение);
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если Не ЭлементОтбора.Элементы.Количество() Или Не ЭлементОтбора.Элементы[0].Использование Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭлементОтбора.Представление = "ОтборИсточник" Тогда
			Запрос.УстановитьПараметр("ИсточникПривлечения", ЭлементОтбора.Элементы[0].ПравоеЗначение);
		ИначеЕсли ЭлементОтбора.Представление = "ОтборКонтрагент" Тогда
			Запрос.УстановитьПараметр("Контрагент", ЭлементОтбора.Элементы[0].ПравоеЗначение);
		ИначеЕсли ЭлементОтбора.Представление = "ОтборОтветственный" Тогда
			Запрос.УстановитьПараметр("Ответственный", ЭлементОтбора.Элементы[0].ПравоеЗначение);
		ИначеЕсли ЭлементОтбора.Представление = "ОтборВид" Тогда
			Запрос.УстановитьПараметр("Вид", ЭлементОтбора.Элементы[0].ПравоеЗначение);
		КонецЕсли;
		
	КонецЦикла;
		
	Для Каждого ЭлементОтбора Из Список.Отбор.Элементы Цикл
		
		Если ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("Массив") 
			И ЭлементОтбора.ПравоеЗначение.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если Строка(ЭлементОтбора.ЛевоеЗначение) = "Теги.Тег" Тогда
			Запрос.УстановитьПараметр("Теги",ЭлементОтбора.ПравоеЗначение);
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "Ответственный" Тогда
			Запрос.УстановитьПараметр("Ответственный",ЭлементОтбора.ПравоеЗначение);
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "ИсточникПривлечения" Тогда
			Запрос.УстановитьПараметр("ИсточникПривлечения",ЭлементОтбора.ПравоеЗначение);
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "СостояниеЛида" Тогда
			Запрос.УстановитьПараметр("СостояниеФильтр",ЭлементОтбора.ПравоеЗначение);
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "Контрагент" Тогда
			Запрос.УстановитьПараметр("Контрагент", ЭлементОтбора.ПравоеЗначение);
		ИначеЕсли Строка(ЭлементОтбора.ЛевоеЗначение) = "Вид" Тогда
			Запрос.УстановитьПараметр("Вид", ЭлементОтбора.ПравоеЗначение);
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ОтборПоиск) Тогда
		Запрос.УстановитьПараметр("Поиск","%"+ОтборПоиск+"%");
	КонецЕсли;
	
	Для Каждого ЭлементОтбораСписка Из Список.Отбор.Элементы Цикл
		Если ЭлементОтбораСписка.Использование = Ложь Тогда
			Продолжить;
		КонецЕсли;
		Если Строка(ЭлементОтбораСписка.ЛевоеЗначение) = "Родитель" Тогда
			Запрос.УстановитьПараметр("Родитель",ЭлементОтбораСписка.ПравоеЗначение);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуТекущегоЭлементаПланировщика()
	
	Если Элементы.Планировщик.ВыделенныеЭлементы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеЭлемента = Элементы.Планировщик.ВыделенныеЭлементы[0].Значение;
	
	Если ЗначениеЗаполнено(ЗначениеЭлемента) И ТипЗнч(ЗначениеЭлемента) = Тип("СправочникСсылка.Лиды") Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Ключ", ЗначениеЭлемента);
		ОткрытьФорму("Справочник.Лиды.Форма.ФормаЭлемента", ПараметрыФормы, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПорядокСмещаемогоЭлемента(Лид)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КанбанЛидов.Порядок КАК Порядок
	|ИЗ
	|	РегистрСведений.КанбанЛидов КАК КанбанЛидов
	|ГДЕ
	|	КанбанЛидов.Лид = &Лид";
	
	Запрос.УстановитьПараметр("Лид", Лид.Ссылка);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Порядок;
	
КонецФункции

&НаСервере
Функция КоличествоЭлементовПоСостояниямКанбан()
	
	ОтборыПоРезультату = УстановленныеОтборыПоРезультату();
	
	Если Не ОтборыПоРезультату.КачественныеЛиды И Не ОтборыПоРезультату.НекачественныеЛиды Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	Лиды.СостояниеЛида КАК СостояниеЛида,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Лиды.Ссылка) КАК Количество
		|ИЗ
		|	Справочник.Лиды КАК Лиды
		|ГДЕ
		|	Лиды.ЭтоГруппа = ЛОЖЬ
		|	И Лиды.ПометкаУдаления = ЛОЖЬ
		|	%1
		|СГРУППИРОВАТЬ ПО
		|	Лиды.СостояниеЛида";
		
	Иначе
		
		ТекстЗапроса =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	Лиды.СостояниеЛида КАК СостояниеЛида,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Лиды.Ссылка) КАК Количество
		|ИЗ
		|	Справочник.Лиды КАК Лиды
		|ГДЕ
		|	НЕ Лиды.ЭтоГруппа
		|	И НЕ Лиды.ПометкаУдаления
		|	И Лиды.ВариантЗавершения = ЗНАЧЕНИЕ(Перечисление.ВариантЗавершенияРаботыСЛидом.ПустаяСсылка)
		|	%1
		|СГРУППИРОВАТЬ ПО
		|	Лиды.СостояниеЛида
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Лиды.ВариантЗавершения,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Лиды.Ссылка)
		|ИЗ
		|	Справочник.Лиды КАК Лиды
		|ГДЕ
		|	НЕ Лиды.ЭтоГруппа
		|	И НЕ Лиды.ПометкаУдаления
		|	И Лиды.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантЗавершенияРаботыСЛидом.ПустаяСсылка)
		|	%1
		|СГРУППИРОВАТЬ ПО
		|	Лиды.ВариантЗавершения";
		
	КонецЕсли;
	
	Если СтрНайти(СтрокаФильтровКанбан, "СвязиКонтрагентЛид.Контрагент") Тогда
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
		"Справочник.Лиды КАК Лиды",
		"Справочник.Лиды КАК Лиды
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СвязиКонтрагентЛид КАК СвязиКонтрагентЛид
		|		ПО Лиды.Ссылка = СвязиКонтрагентЛид.Лид");
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон(ТекстЗапроса, СтрокаФильтровКанбан);
	УстановитьПараметрыФильтров(Запрос);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

&НаСервере
Функция ЦветаЭлементовСостояния(Состояние)
	
	Если ТипЗнч(Состояние.Значение) = Тип("СправочникСсылка.СостоянияЛидов") Тогда
		Возврат Справочники.СостоянияЛидов.ЦветЭлементовСостояния(Состояние.ЦветТекста);
	КонецЕсли;
	
	Результат = Новый Структура;
	
	Если Состояние.Значение = Перечисления.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя Тогда
		//@skip-check new-color
		Результат.Вставить("ЦветПанели", Новый Цвет(128, 192, 115));
		//@skip-check new-color
		Результат.Вставить("ЦветЭлемента", Новый Цвет(185, 220, 168));
	КонецЕсли;
	
	Если Состояние.Значение = Перечисления.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид Тогда
		//@skip-check new-color
		Результат.Вставить("ЦветПанели", Новый Цвет(192, 115, 115));
		//@skip-check new-color
		Результат.Вставить("ЦветЭлемента", Новый Цвет(220, 168, 168));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ДобавитьЭлементВКанбан(Начало, Конец, Текст, Значение, Состояние, ЦветЭлемента, Картинка = Неопределено)
	
	СоответствиеЗначений = Новый Соответствие;
	СоответствиеЗначений.Вставить("СостоянияЛидов",Состояние.Значение);
	
	НовыйЭлемент = Планировщик.Элементы.Добавить(Начало, Конец);
	НовыйЭлемент.ЗначенияИзмерений = Новый ФиксированноеСоответствие(СоответствиеЗначений);
	НовыйЭлемент.Текст = Текст;
	НовыйЭлемент.ЦветФона = ЦветЭлемента;
	//@skip-check new-color
	//	НовыйЭлемент.ЦветТекста = Новый Цвет(0,0,0);
	НовыйЭлемент.Шрифт = ШрифтыСтиля.ОбычныйШрифтТекста;
	НовыйЭлемент.Значение = Значение;
	
	Если Картинка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НовыйЭлемент.Картинка = Картинка;
	
КонецПроцедуры

&НаСервере
Процедура ПланировщикПриАктивизацииНаСервере()
	
	ВыделенныеЭлементы = Элементы.Планировщик.ВыделенныеЭлементы;
	
	Если ВыделенныеЭлементы[0].Начало = (НачалоОтображенияКанбан + КоличествоОтображаемыхЭлементовКанбан*2 + 1) Тогда
		ПерейтиВКонецСостояния(ВыделенныеЭлементы[0].ЗначенияИзмерений["СостоянияЛидов"]);
	ИначеЕсли ВыделенныеЭлементы[0].Начало = НачалоОтображенияКанбан Тогда
		ТекущийЭкранКанбан = 0;
		ОбновитьЭлементыПланировщика("Создание");
	Иначе
		ТекущийЛид = ВыделенныеЭлементы[0].Значение;
		ОбновитьПанельКонтактнойИнформацииКанбанНаСервере();
	КонецЕсли;
	
	УстановитьОтображениеКомандДляИзмененияЛидаКанбан();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТаблицуПервыйПоследнийЭлементКанбан(Лид,ПеретаскиваниеВНачалоСписка)
	
	Строка = ПервыйПоследнийЭлементКанбан.НайтиСтроки(Новый Структура("Состояние",Лид.СостояниеЛида));
	Если Строка[0].Количество = (ТекущийЭкранКанбан*КоличествоОтображаемыхЭлементовКанбан - (ТекущийЭкранКанбан - 1)) Тогда
		Строка[0].ПорядокПервогоЭлемента = ?(ПеретаскиваниеВНачалоСписка,
			Строка[0].ПорядокПоследнегоЭлемента,
			ПорядокСмещаемогоЭлемента(Лид.Ссылка));
	Иначе
		Строка[0].ПорядокПоследнегоЭлемента = ПорядокСмещаемогоЭлемента(Лид.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПерейтиВКонецСостояния(Состояние)
	КоличествоЛидовПоСостоянию = ПервыйПоследнийЭлементКанбан.НайтиСтроки(Новый Структура("Состояние",Состояние));;
	Пока КоличествоЛидовПоСостоянию[0].Количество >= ((ТекущийЭкранКанбан + 1)*КоличествоОтображаемыхЭлементовКанбан - ТекущийЭкранКанбан) Цикл
		ТекущийЭкранКанбан = ТекущийЭкранКанбан + 1;
		ОбновитьЭлементыПланировщика("Прокрутка", "ПрокруткаВперед")
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Функция ДанныеЛидовПослеПроверкиВозможностиПереносаПоКанбану(МассивЛидов, ОтменаРедактирования)
	
	ВыделенныеЭлементы = Элементы.Планировщик.ВыделенныеЭлементы;
	КоличествоЛидов = МассивЛидов.Количество();
	
	Если КоличествоЛидов = 0 Тогда
		ОтменаРедактирования = Истина;
		ОбновитьЭлементыИИзмеренияПланировщика();
		Возврат Неопределено;
	КонецЕсли;
	
	Если Секунда(ВыделенныеЭлементы[0].Конец) - Секунда(ВыделенныеЭлементы[0].Начало) <> 2 Тогда
		ОтменаРедактирования = Истина;
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеЛидов = ДанныеЛидовПослеПроверкиВозможностиПереносаПоКанбануНаСервере(МассивЛидов);
	
	СтароеСостояниеЛида = Неопределено;
	СтарыйВариантЗавершения = Неопределено;
	УЛидовРазныеСостояния = Ложь;
	ЕстьНедоступныеКонтрагенты = Ложь;
	Для Каждого КлючЗначение Из ДанныеЛидов Цикл
		
		ДанныеЛида = КлючЗначение.Значение;
		
		Если Не ЕстьНедоступныеКонтрагенты
			И ДанныеЛида.Свойство("Контрагент") И Не ЧтениеРазрешено(ДанныеЛида.Контрагент) Тогда
			ЕстьНедоступныеКонтрагенты = Истина;
		КонецЕсли;
		
		Если СтароеСостояниеЛида = Неопределено Тогда
			СтароеСостояниеЛида = ДанныеЛида.СостояниеЛида;
			СтарыйВариантЗавершения = ДанныеЛида.ВариантЗавершения;
		КонецЕсли;
		
		Если Не УЛидовРазныеСостояния И СтароеСостояниеЛида <> ДанныеЛида.СостояниеЛида Тогда
			УЛидовРазныеСостояния = Истина;
		КонецЕсли;
		
		Если СтарыйВариантЗавершения <> ДанныеЛида.ВариантЗавершения Тогда
			ОтменаРедактирования = Истина;
			Возврат Неопределено;
		КонецЕсли;
		
	КонецЦикла;
	
	НовоеИзмерение = ВыделенныеЭлементы[0].ЗначенияИзмерений["СостоянияЛидов"];
	КачественныйЛид = ПредопределенноеЗначение("Перечисление.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя");
	НекачественныйЛид = ПредопределенноеЗначение("Перечисление.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид");
	
	Если УЛидовРазныеСостояния И НовоеИзмерение <> НекачественныйЛид Тогда
		ОтменаРедактирования = Истина;
		Возврат Неопределено;
	КонецЕсли;
	
	Если СтарыйВариантЗавершения = КачественныйЛид Тогда
		ОтменаРедактирования = Истина;
		Возврат Неопределено;
	КонецЕсли;
	
	Если СтарыйВариантЗавершения = НекачественныйЛид
		И ТипЗнч(НовоеИзмерение) = Тип("ПеречислениеСсылка.ВариантЗавершенияРаботыСЛидом") Тогда
		ОтменаРедактирования = Истина;
		Возврат Неопределено;
	КонецЕсли;
	
	Если НовоеИзмерение = КачественныйЛид И КоличествоЛидов > 1 Тогда
		ПоказатьПредупреждениеОНеобходимостиВыбораОдногоЛида();
		ОтменаРедактирования = Истина;
		Возврат Неопределено;
	КонецЕсли;
	
	Если НовоеИзмерение = КачественныйЛид И ЕстьНедоступныеКонтрагенты Тогда
		ПоказатьПредупреждениеОбОтсутствииПрав();
		ОтменаРедактирования = Истина;
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ДанныеЛидов;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеЛидовПослеПроверкиВозможностиПереносаПоКанбануНаСервере(Знач Лиды)
	
	Результат = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Лиды, "СостояниеЛида,ВариантЗавершения,Вид");
	
	ДанныеКонтрагентов = Справочники.Лиды.СвязанныеКонтрагенты(Лиды);
	Для Каждого ЛидКонтрагент Из ДанныеКонтрагентов Цикл
		Результат[ЛидКонтрагент.Ключ].Вставить("Контрагент", ЛидКонтрагент.Значение);
	КонецЦикла;
	
	Результат[Лиды[0]].Вставить("НаличиеЗаявок", РаботаСЗаявками.НаличиеЗаявокВРаботеПоЛидуПоВидуОперации(Лиды[0]));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ДекорацияПометитьНаУдалениеПеретаскиваниеСервер(Лиды)
	
	Для каждого Лид Из Лиды Цикл
		
		Если НЕ ЗначениеЗаполнено(Лид) Тогда
			Продолжить;
		КонецЕсли;
		
		ЛидОбъект = Лид.Ссылка.ПолучитьОбъект();
		ЛидОбъект.ПометкаУдаления = Истина;
		ЛидОбъект.Записать();
		
	КонецЦикла;
	
	ОбновитьЭлементыПланировщика("Перетаскивание");
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросСОповещениемПроНаличиеЗаявокПередПереводомЛидаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ДанныеЛида = ДополнительныеПараметры.ДанныеЛида;
	
	Если Результат.Значение = "ПерейтиКЗаявкам" Тогда
		РаботаСЛидамиКлиент.ОткрытьЗаявкиПоЛиду(ДополнительныеПараметры.Лид, , ДанныеЛида.НаличиеЗаявок);
		Возврат;
	КонецЕсли;
	
	Если Результат.Значение <> "Продолжить" Тогда
		Возврат;
	КонецЕсли;
	
	Если ИспользоватьПодсистемуРаботы
		Или ДанныеЛида.Вид = ПредопределенноеЗначение("Перечисление.ВидыЛидов.ПервичноеОбращение") Тогда
		ПеревестиЛидаВКачественныйСВыборомРезультата(ДополнительныеПараметры.Лид);
	Иначе
		ПеревестиВКлиентаБезПроверокЛида(ДополнительныеПараметры.Лид, "ЗаказПокупателя");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ИзменениеСостоянийЛидов

&НаСервере
Процедура ОбновитьКомандыИзмененияСостояний()
	
	УдаляемыеЭлементы = Новый Массив;
	
	Если Элементы.СписокКонтекстноеМенюУстановитьСостояние.ПодчиненныеЭлементы.Количество()<> 0 Тогда
		Для ИндексГруппы = 0 По Элементы.СписокКонтекстноеМенюУстановитьСостояние.ПодчиненныеЭлементы.Количество() - 1 Цикл
			
			УдаляемыеЭлементы.Добавить(Элементы.СписокКонтекстноеМенюУстановитьСостояние.ПодчиненныеЭлементы[ИндексГруппы]);
			
		КонецЦикла;
		
		Если Элементы.ФормаУстановитьСостояние.ПодчиненныеЭлементы.Количество() <> 0 Тогда
			Для ИндексГруппы = 0 По Элементы.ФормаУстановитьСостояние.ПодчиненныеЭлементы.Количество() - 1 Цикл
				УдаляемыеЭлементы.Добавить(Элементы.ФормаУстановитьСостояние.ПодчиненныеЭлементы[ИндексГруппы]);
			КонецЦикла;
		КонецЕсли;
		
		Для Каждого УдаляемыйЭлемент Из УдаляемыеЭлементы Цикл
			Элементы.Удалить(УдаляемыйЭлемент);
		КонецЦикла;
		
	КонецЕсли;
	
	ТаблицаСостоянийЛидов.Очистить();
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	|	СостоянияЛидов.Ссылка КАК Ссылка,
	|	СостоянияЛидов.Наименование КАК Наименование
	|ИЗ
	|	Справочник.СостоянияЛидов КАК СостоянияЛидов
	|
	|УПОРЯДОЧИТЬ ПО
	|	РеквизитДопУпорядочивания";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	НомерСостояния = 1;
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.Ссылка = Справочники.СостоянияЛидов.Завершен Тогда
			Продолжить;
		КонецЕсли;
		
		СостояниеВТаблице = ТаблицаСостоянийЛидов.НайтиСтроки(Новый Структура("Состояние", Выборка.Ссылка));
		
		Если СостояниеВТаблице.Количество() = 0 Тогда
			НовоеСостояние = ТаблицаСостоянийЛидов.Добавить();
			НовоеСостояние.Состояние = Выборка.Ссылка;
		Иначе 
			НовоеСостояние = СостояниеВТаблице[0];
		КонецЕсли;
		
		КнопкаУстановитьСостояниеЗаказаФорма = Элементы.Добавить("Состояние_" + Строка(ТаблицаСостоянийЛидов.Индекс(НовоеСостояние))+ "Форма", Тип("КнопкаФормы"),Элементы.ФормаУстановитьСостояние);
		КнопкаУстановитьСостояниеЗаказаФорма.Заголовок = Строка(НомерСостояния)+". "+ Строка(Выборка.Ссылка);
		КнопкаУстановитьСостояниеЗаказаФорма.ПоложениеВКоманднойПанели = 
		ПоложениеКнопкиВКоманднойПанели.ВДополнительномПодменю;
		
		КнопкаУстановитьСостояниеЗаказаСписок = Элементы.Добавить("Состояние_" + Строка(ТаблицаСостоянийЛидов.Индекс(НовоеСостояние)), Тип("КнопкаФормы"),Элементы.СписокКонтекстноеМенюУстановитьСостояние);
		КнопкаУстановитьСостояниеЗаказаСписок.Заголовок = Строка(НомерСостояния)+". "+ Строка(Выборка.Ссылка);
		
		НазваниеКоманды = "Состояние_" + Строка(ТаблицаСостоянийЛидов.Индекс(НовоеСостояние));
		Если Команды.Найти(НазваниеКоманды) <> Неопределено Тогда
			КомандаУстановитьСостояниеЗаказа = Команды[НазваниеКоманды];
		Иначе
			КомандаУстановитьСостояниеЗаказа = Команды.Добавить(НазваниеКоманды);
		КонецЕсли;
		
		КомандаУстановитьСостояниеЗаказа.Действие = "Подключаемый_УстановитьСостояниеЛида";
		КомандаУстановитьСостояниеЗаказа.Заголовок = Строка(Выборка.Ссылка);
		
		КнопкаУстановитьСостояниеЗаказаСписок.ИмяКоманды = КомандаУстановитьСостояниеЗаказа.Имя;
		КнопкаУстановитьСостояниеЗаказаФорма.ИмяКоманды = КомандаУстановитьСостояниеЗаказа.Имя;

		НомерСостояния = НомерСостояния + 1;
	КонецЦикла;
	
КонецПроцедуры

//@skip-warning
&НаКлиенте
Процедура Подключаемый_УстановитьСостояниеЛида(Команда)
	
	Лиды = Элементы.Список.ВыделенныеСтроки;
	
	Если Тип(Лиды) <> Тип("Массив") Или Лиды.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКоманды = Команда.Имя;
	
	Если Лиды.Количество() = 1 Тогда
		
		ДанныеОтСервера = УстановитьСостояниеЛидаСервер(ИмяКоманды, Лиды);
		Если ДанныеОтСервера <> Неопределено Тогда
			ПоказатьПредупреждениеОЗавершенномЛиде(ДанныеОтСервера);
			Возврат;
		КонецЕсли;
		
		Если Лиды.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
		
		ПоказатьОповещениеПользователя(НСтр("ru='Изменение:'"),
		ПолучитьНавигационнуюСсылку(Лиды[0]),
		СтрШаблон(НСтр("ru='%1'"),Строка(Лиды[0])),
		БиблиотекаКартинок.Информация32);
		Если Элементы.ФормаСписок.Пометка Тогда
			Элементы.Список.Обновить();
		КонецЕсли;
		
		РаботаСЛидамиКлиент.ОповеститьОбИзмененном(Лиды);
		Возврат;
		
	КонецЕсли;
	
	Состояние(НСтр("ru = 'Изменение состояния'"), 49);
	
	ДанныеОтСервера = УстановитьСостояниеЛидаСервер(ИмяКоманды, Лиды);
	Если ДанныеОтСервера <> Неопределено Тогда
		ПоказатьПредупреждениеОЗавершенномЛиде(ДанныеОтСервера);
		Возврат;
	КонецЕсли;
	
	Состояние(НСтр("ru = 'Изменение состояния'"), 100);
	
	Если Элементы.ФормаСписок.Пометка Тогда
		Элементы.Список.Обновить(); 
	КонецЕсли;
	РаботаСЛидамиКлиент.ОповеститьОбИзмененном(Лиды);
	
	ПоказатьОповещениеПользователя(СтрШаблон(НСтр("ru='Изменение (%1)'"),
	КоличествоИзмененныхЛидов),,
	НСтр("ru='Лиды'"),БиблиотекаКартинок.Информация32);
	
КонецПроцедуры

&НаСервере
Функция УстановитьСостояниеЛидаСервер(Знач ИмяКоманды, Знач Лиды)
	
	ДанныеЛидов = ДанныеЛидовДляПроверкиЗавершенных(Лиды);
	Если ДанныеЛидов.ЕстьЗавершенныйЛид Тогда
		Возврат ДанныеЛидов;
	КонецЕсли;
	
	ИндексСостояния = Число(Сред(ИмяКоманды,11,СтрДлина(ИмяКоманды)));
	СсылкаНаСостояние = ТаблицаСостоянийЛидов[ИндексСостояния].Состояние;
	
	КоличествоИзмененныхЛидов = 0;
	НеизмененныеЛиды = Новый Массив;
	
	Для Каждого Лид Из Лиды Цикл
		
		Если Лид.СостояниеЛида = СсылкаНаСостояние Тогда
			НеизмененныеЛиды.Добавить(Лид);
			Продолжить;
		КонецЕсли;
		
		Попытка
			Справочники.Лиды.ИзменитьСостояниеЛида(Лид, СсылкаНаСостояние);
		Исключение
			
			ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Лид);
			НеизмененныеЛиды.Добавить(Лид);
			Продолжить;
			
		КонецПопытки;
		
		КоличествоИзмененныхЛидов = КоличествоИзмененныхЛидов + 1;
		
	КонецЦикла;
	
	Для Каждого НеизмененныйЛид Из НеизмененныеЛиды Цикл
		
		ИндексЛида = Лиды.Найти(НеизмененныйЛид);
		Если ИндексЛида = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Лиды.Удалить(ИндексЛида);
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти

#Область ПереводЛида

&НаКлиенте
Асинх Процедура ПеревестиЛида(РезультатПеревода, Лид = Неопределено)
	
	Лид = ЛидИзСпискаИлиКанбана(Лид);
	Если Не ЗначениеЗаполнено(Лид) Тогда
		Возврат;
	КонецЕсли;
	
	ОтветОтСервера = ПеревестиЛидаНаСервере(Лид);
	Если ОтветОтСервера = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПоложительныйОтвет = Ждать РаботаСЛидамиКлиент.ВопросПередПереводомЛидаАсинх(
	ОтветОтСервера, РезультатПеревода, ОтветОтСервера.НаличиеЗаявок);
	Если Не ПоложительныйОтвет Тогда
		Возврат;
	КонецЕсли;
	
	ПеревестиВКлиентаБезПроверокЛида(Лид, РезультатПеревода);
	
КонецПроцедуры

&НаКлиенте
Процедура ПеревестиЛидаПеретаскиваниемВНижнююПанель(
	СтандартнаяОбработка, ПараметрыПеретаскивания, РезультатПеревода)
	
	СтандартнаяОбработка = Ложь;
	
	КоличествоЛидов = ПараметрыПеретаскивания.Значение.Количество();
	Если ТипЗнч(ПараметрыПеретаскивания.Значение) <> Тип("Массив")
		ИЛИ КоличествоЛидов = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если КоличествоЛидов > 1 Тогда
		ПоказатьПредупреждениеОНеобходимостиВыбораОдногоЛида();

		Возврат;
	КонецЕсли;
	
	Лид = ПараметрыПеретаскивания.Значение[0].Значение;
	Если НЕ ЗначениеЗаполнено(Лид) Тогда
		Возврат;
	КонецЕсли;
	
	ПеревестиЛида(РезультатПеревода, Лид);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПеревестиЛидаНаСервере(Знач Лид)
	
	МожноПеревестиВКлиента = РаботаСЛидами.МожноПеревестиВКлиента(Лид);
	Контрагент = Справочники.Лиды.СвязанныйКонтрагент(Лид, Новый Структура("ПроверятьРЛС"));
	
	Если Не ЗначениеЗаполнено(Контрагент) И Не МожноПеревестиВКлиента Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Ссылка", Лид);
	Результат.Вставить("НаличиеЗаявок", РаботаСЗаявками.НаличиеЗаявокВРаботеПоЛидуПоВидуОперации(Лид));
	Результат.Вставить("Контрагент", Контрагент);
	Результат.Вставить("ПредставлениеКонтрагента", "");
	Результат.Вставить("ВариантЗавершения");
	Результат.Вставить("Представление", "");
	Результат.Вставить("Вид");
	
	ДанныеЛида = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Лид, "ВариантЗавершения,Представление,Вид");
	ЗаполнитьЗначенияСвойств(Результат, ДанныеЛида);
	Если ЗначениеЗаполнено(ДанныеЛида.ВариантЗавершения) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Результат.Вставить("ПредставлениеКонтрагента", Строка(Контрагент));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПеревестиВКлиентаБезПроверокЛида(Лид, РезультатПеревода)
	
	Контрагент = ПеревестиВКлиентаБезПроверокЛидаНаСервере(Лид, РезультатПеревода);
	Если Не ЗначениеЗаполнено(Контрагент) Или Контрагент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РаботаСЛидамиКлиент.ОповеститьОбИзмененном(Лид);
	РаботаСЛидамиКлиент.ОткрытьРезультатПослеПереводаЛида(Лид, РезультатПеревода, Контрагент);
	
КонецПроцедуры

&НаСервере
Функция ПеревестиВКлиентаБезПроверокЛидаНаСервере(Знач Лид, Знач РезультатПеревода)
	
	ЛидОбъект = Лид.ПолучитьОбъект();
	ЛидОбъект.Заблокировать();
	
	РезультатПереводаЛида = РаботаСЛидами.ПеревестиЛида(ЛидОбъект);
	Если РезультатПереводаЛида = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Элементы.ФормаКанбан.Пометка Тогда
		ОбновитьЭлементыПланировщика("Перетаскивание");
	КонецЕсли;
	
	Возврат РезультатПереводаЛида.Контрагент;
	
КонецФункции

&НаКлиенте
Процедура ПеревестиЛидовВНекачественныеСПроверкойЛидов(Лиды)
	
	Если Лиды.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОтветОтСервера = ПеревестиЛидовВНекачественныеСПроверкойЛидовНаСервере(Лиды);
	Если ОтветОтСервера.ЕстьЗавершенныйЛид Тогда
		ПоказатьПредупреждениеОЗавершенномЛиде(ОтветОтСервера);
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуДляПереводаВНекачественного(Лиды);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПеревестиЛидовВНекачественныеСПроверкойЛидовНаСервере(Знач Лиды)
	
	Возврат ДанныеЛидовДляПроверкиЗавершенных(Лиды);
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуДляПереводаВНекачественного(Лиды)
	
	ПараметрыОповещения = Новый Структура("Лиды", Лиды);
	Оповещение = Новый ОписаниеОповещения("ОбработатьЗакрытиеФормыНекачественногоЛида", ЭтотОбъект, ПараметрыОповещения);
	ОткрытьФорму("Справочник.Лиды.Форма.ФормаНекачественныйЛидКанбан", , , , , , Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗакрытиеФормыНекачественногоЛида(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбработатьЗакрытиеФормыНекачественногоЛидаНаСервере(Результат, ДополнительныеПараметры.Лиды);
	Если Элементы.ФормаСписок.Пометка Тогда
		Элементы.Список.Обновить();
	КонецЕсли;
	
	РаботаСЛидамиКлиент.ОповеститьОбИзмененном(ДополнительныеПараметры.Лиды);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьЗакрытиеФормыНекачественногоЛидаНаСервере(Знач ДанныеНекачественногоЛида, Знач Лиды)
	
	Для Каждого Лид Из Лиды Цикл
		Попытка
			
			ПеретаскиваемыйЛид = Лид.ПолучитьОбъект();
			ДанныеЗаполнения = Новый Структура;
			ДанныеЗаполнения.Вставить("ПереводВНекачественныйЛид");
			ДанныеЗаполнения.Вставить("ЗаметкиЗавершенияРаботы", ДанныеНекачественногоЛида.Комментарий);
			ДанныеЗаполнения.Вставить("ПричинаНеуспешногоЗавершенияРаботы",
			ДанныеНекачественногоЛида.ПричинаНеуспешногоЗавершенияРаботы);
			ПеретаскиваемыйЛид.Заполнить(ДанныеЗаполнения);
			
			Если Не ПеретаскиваемыйЛид.ПроверитьЗаполнение() Тогда
				Продолжить;
			КонецЕсли;
			
			ПеретаскиваемыйЛид.Записать();
			
		Исключение
			ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Лид);
			Продолжить;
		КонецПопытки;
		
	КонецЦикла;
	
	Если Элементы.ФормаКанбан.Пометка Тогда
		ОбновитьЭлементыПланировщика("Перетаскивание");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПеревестиЛидаВКачественныйСВыборомРезультата(Лид)
	
	ПараметрыФормыИОповещения = Новый Структура("Лид", Лид);
	Оповещение = Новый ОписаниеОповещения("ОбработатьЗакрытиеФормыКачественногоЛида", ЭтотОбъект,
	ПараметрыФормыИОповещения);
	ОткрытьФорму("Справочник.Лиды.Форма.ФормаКачественныйЛидКанбан", ПараметрыФормыИОповещения, , , , , Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗакрытиеФормыКачественногоЛида(РезультатПеревода, ДополнительныеПараметры) Экспорт
	
	Если РезультатПеревода <> "Покупатель"
		И РезультатПеревода <> "ЗаказПокупателя"
		И РезультатПеревода <> "ЗаказНаряд" Тогда
		Возврат;
	КонецЕсли;
	
	ПеревестиВКлиентаБезПроверокЛида(ДополнительныеПараметры.Лид, РезультатПеревода);
	
КонецПроцедуры

&НаСервере
Процедура ВернутьНекачественныхЛидовВРаботуКанбан(Знач Лиды, Знач НовоеСостояние)
	
	Для Каждого Лид Из Лиды Цикл
		
		ЛидОбъект = Лид.ПолучитьОбъект();
		
		Попытка
			ЛидОбъект.Заблокировать();
		Исключение
			
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			
			ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			ТекстОшибки = СтрШаблон(НСтр("ru = 'Не удалось заблокировать объект %1
			|
			|Описание ошибки:
			|%2'"),
			ЛидОбъект,
			ТекстОшибки);
			
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Блокировки.Ошибка'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка, Метаданные.Справочники.Лиды, ,
			ТекстОшибки);
			
			ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке));
			
			Продолжить;
			
		КонецПопытки;
		
		ДанныеЗаполнения = Новый Структура;
		ДанныеЗаполнения.Вставить("ВозвратВРаботу");
		ДанныеЗаполнения.Вставить("СостояниеЛида", НовоеСостояние);
		ЛидОбъект.Заполнить(ДанныеЗаполнения);
		
		Если Не ЛидОбъект.ПроверитьЗаполнение() Тогда
			Продолжить;
		КонецЕсли;
		
		ЛидОбъект.Записать();
		
	КонецЦикла;
	
	Если Элементы.ФормаКанбан.Пометка Тогда
		ОбновитьЭлементыПланировщика("Перетаскивание");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ИзменениеИнтерфейса

&НаСервере
Процедура УправлениеФормой()
	
	ЭтоКанбан = Элементы.ФормаКанбан.Пометка;
	
	Элементы.СоздатьКанбан.Видимость = ЕстьПравоРедактирования И ЭтоКанбан;
	
	Если ЕстьПравоРедактирования Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Создать", "Видимость", Не ЭтоКанбан);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Скопировать", "Видимость", Не ЭтоКанбан);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ОбщаяКомандаНапомнить", "Видимость", Не ЭтоКанбан);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ОбщаяКомандаСоздатьЗадачуСотрудника", "Видимость", Не ЭтоКанбан);
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"СоздатьЗадачуСотрудникаКанбан",
		"Видимость",
		ЭтоКанбан И ПравоДоступа("Редактирование", Метаданные.Документы.ЗадачаСотрудника));
		
	КонецЕсли;
	
	Элементы.ФормаУстановитьСостояние.Видимость = ЕстьПравоРедактирования И Не ЭтоКанбан;
	Элементы.ФормаГруппаЗавершениеРаботыСЛидом.Видимость = ЕстьПравоРедактирования И Не ЭтоКанбан;
	Элементы.СписокКонтекстноеМенюУстановитьСостояние.Видимость = ЕстьПравоРедактирования;
	Элементы.СписокКонтекстноеМенюГруппаЗавершениеРаботыСЛидом.Видимость = ЕстьПравоРедактирования;
	Элементы.ПланировщикКонтекстноеМенюГруппаЗавершениеРаботыСЛидом.Видимость = ЕстьПравоРедактирования;
	Элементы.ПланировщикКонтекстноеМенюГруппаПеремещение.Видимость = ЕстьПравоРедактирования;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
	"СписокКонтекстноеМенюСправочникТегиРедактироватьТеги", 
	"Видимость",
	ЕстьПравоРедактирования);
	
	Элементы.ЗавершениеРаботыСЛидом.Видимость = ЭтоКанбан И Не ОбщегоНазначения.ЭтоВебКлиент();
	Элементы.ЗавершениеРаботыСЛидом.Доступность = ЕстьПравоРедактирования;
	
	Элементы.Планировщик.Видимость = ЭтоКанбан;
	Элементы.ОтборПоиск.Видимость = ЭтоКанбан;
	Элементы.ФормаОбновитьКанбан.Видимость = ЭтоКанбан;
	
	Элементы.Список.Видимость = Не ЭтоКанбан;
	Элементы.ПодменюОрганайзер.Видимость = Не ЭтоКанбан;
	Элементы.ГруппаПоиска.Видимость = Не ЭтоКанбан;
	Элементы.ФормаГруппаКомандыСписок.Видимость = Не ЭтоКанбан;
	
	Элементы.ГруппаПеревестиВПокупателяИЗаказНаряд.Видимость = ИспользоватьПодсистемуРаботы;
	Элементы.ФормаПеревестиВПокупателяИЗаказНаряд.Видимость = ИспользоватьПодсистемуРаботы;
	Элементы.СписокКонтекстноеМенюПеревестиВПокупателяИЗаказНаряд.Видимость = ИспользоватьПодсистемуРаботы;
	Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателяИЗаказНаряд.Видимость = ИспользоватьПодсистемуРаботы;
	
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсПриСоздании()
	
	ОбновитьОтображениеКнопокЗаявок();
	ОпределитьИнтерфейсКомандПереходаКЗаявкам();
	
	Элементы.Запись.Видимость = ПланироватьЗагрузкуРесурсовПредприятияЖурналЗаписи;
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьИнтерфейсПоОтборуПоРезультату()
	
	ОтборыПоРезультату = УстановленныеОтборыПоРезультату();
	
	КоличествоОтборовПоРезультату = 0;
	Для Каждого КлючЗначение Из ОтборыПоРезультату Цикл
		Если КлючЗначение.Значение Тогда
			КоличествоОтборовПоРезультату = КоличествоОтборовПоРезультату + 1;
		КонецЕсли;
	КонецЦикла;
	
	Элементы.Завершение.Видимость = (КоличествоОтборовПоРезультату > 1);
	Элементы.РезультатРаботы.Видимость = ОтборыПоРезультату.НекачественныеЛиды Или ОтборыПоРезультату.КачественныеЛиды;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
	"СписокКонтекстноеМенюСправочникТегиРедактироватьТеги",
	"Видимость",
	ЕстьПравоРедактирования);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
	"ГруппаИзменитьЭлементы",
	"Видимость",
	ЕстьПравоРедактирования);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
	"ФормаИзменитьОбъединитьВыделенные",
	"Видимость",
	ЕстьПравоРедактирования);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтображениеКомандДляИзмененияЛидаКанбан()
	
	ВыделенныеЭлементы = Элементы.Планировщик.ВыделенныеЭлементы;
	Если Не ВыделенныеЭлементы.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	Лид = ВыделенныеЭлементы[0].Значение;
	Контрагент = Справочники.Лиды.СвязанныйКонтрагент(Лид);
	ДанныеЛида = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Лид, "ВариантЗавершения,Вид");
	ДанныеЛида.Вставить("ЧтениеКонтрагентаРазрешено", ЧтениеРазрешено(Контрагент));
	
	Если Не ОбщегоНазначения.ЭтоВебКлиент() Тогда
		
		ИзменитьВидОбластейПодКанбаномПоЛиду(ДанныеЛида);
		
		ПоказатьКоманды = Не ЗначениеЗаполнено(ДанныеЛида.ВариантЗавершения);
		Элементы.ПланировщикКонтекстноеМенюГруппаЗавершениеРаботыСЛидом.Видимость = ПоказатьКоманды;
		Элементы.ПланировщикКонтекстноеМенюГруппаПеремещение.Видимость = ПоказатьКоманды;
		
		Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателя.Доступность = ДанныеЛида.ЧтениеКонтрагентаРазрешено;
		Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателяИЗаказ.Доступность = ДанныеЛида.ЧтениеКонтрагентаРазрешено;
		Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателяИЗаказНаряд.Доступность =
		ДанныеЛида.ЧтениеКонтрагентаРазрешено;
		
		ЭтоПовторныйЛид = (ДанныеЛида.Вид = Перечисления.ВидыЛидов.ПовторноеОбращение);
		Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателя.Видимость = Не ЭтоПовторныйЛид;
		
		Если ЭтоПовторныйЛид Тогда
			Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателяИЗаказ.Заголовок =
			НСтр("ru = 'Перевести в заказ покупателя'");
			Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателяИЗаказНаряд.Заголовок =
			НСтр("ru = 'Перевести в заказ-наряд'");
		Иначе
			Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателяИЗаказ.Заголовок =
			НСтр("ru = 'Перевести в покупателя + заказ'");
			Элементы.ПланировщикКонтекстноеМенюПеревестиВПокупателяИЗаказНаряд.Заголовок =
			НСтр("ru = 'Перевести в покупателя + заказ-наряд'");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьВидОбластейПодКанбаномПоЛиду(ДанныеЛида)
	
	Если ЗначениеЗаполнено(ДанныеЛида.ВариантЗавершения)
		Или ДанныеЛида.Вид = Перечисления.ВидыЛидов.ПовторноеОбращение
		Или Не ДанныеЛида.ЧтениеКонтрагентаРазрешено Тогда
		
		Цвета = РаботаСЛидами.ЦветОбластиПодКанбаном("Серый");
		ЛинияГоризонтальная = БиблиотекаКартинок.ЛинияГоризонтальнаяПунктирнаяСерая;
		ЛинияВертикальная = БиблиотекаКартинок.ЛинияВертикальнаяПунктирнаяСерая;
		
		Элементы.ДекорацияПометитьНаУдаление3.ЦветРамки = Цвета.ЦветРамки;
		Элементы.ДекорацияПеревестиВПокупателя.ЦветТекста = Цвета.ЦветТекста;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая1.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая2.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая1.Картинка = ЛинияВертикальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая2.Картинка = ЛинияВертикальная;
		Элементы.ГруппаПеревестиВПокупателя.Доступность = Ложь;
		
		Элементы.ДекорацияПометитьНаУдаление4.Заголовок = НСтр("ru = 'Заказ покупателя'");
		Элементы.ДекорацияПометитьНаУдаление5.Заголовок = НСтр("ru = 'Заказ-наряд'");
		
	Иначе
		
		Цвета = РаботаСЛидами.ЦветОбластиПодКанбаном("Зеленый");
		ЛинияГоризонтальная = БиблиотекаКартинок.ЛинияГоризонтальнаяПунктирнаяЗеленая;
		ЛинияВертикальная = БиблиотекаКартинок.ЛинияВертикальнаяПунктирнаяЗеленая;
		
		Элементы.ДекорацияПометитьНаУдаление3.ЦветРамки = Цвета.ЦветРамки;
		Элементы.ДекорацияПеревестиВПокупателя.ЦветТекста = Цвета.ЦветТекста;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая1.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая2.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая1.Картинка = ЛинияВертикальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая2.Картинка = ЛинияВертикальная;
		Элементы.ГруппаПеревестиВПокупателя.Доступность = Истина;
		
		Элементы.ДекорацияПометитьНаУдаление4.Заголовок = НСтр("ru = 'Покупатель + заказ'");
		Элементы.ДекорацияПометитьНаУдаление5.Заголовок = НСтр("ru = 'Покупатель + заказ-наряд'");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеЛида.ВариантЗавершения)
		Или Не ДанныеЛида.ЧтениеКонтрагентаРазрешено Тогда
		
		Цвета = РаботаСЛидами.ЦветОбластиПодКанбаном("Серый");
		ЛинияГоризонтальная = БиблиотекаКартинок.ЛинияГоризонтальнаяПунктирнаяСерая;
		ЛинияВертикальная = БиблиотекаКартинок.ЛинияВертикальнаяПунктирнаяСерая;
		
		Если ЗначениеЗаполнено(ДанныеЛида.ВариантЗавершения) Тогда
			Элементы.ДекорацияПометитьНаУдаление2.ЦветРамки = Цвета.ЦветРамки;
			Элементы.ДекорацияНекачественныйЛид.ЦветТекста = Цвета.ЦветТекста;
			Элементы.ЛинияГоризонтальнаяПунктирнаяКрасная1.Картинка = ЛинияГоризонтальная;
			Элементы.ЛинияГоризонтальнаяПунктирнаяКрасная2.Картинка = ЛинияГоризонтальная;
			Элементы.ЛинияВертикальнаяПунктирнаяКрасная1.Картинка = ЛинияВертикальная;
			Элементы.ЛинияВертикальнаяПунктирнаяКрасная2.Картинка = ЛинияВертикальная;
			Элементы.ГруппаПометитьНекачественный.Доступность = Ложь;
		КонецЕсли;
		
		Элементы.ДекорацияПометитьНаУдаление4.ЦветРамки = Цвета.ЦветРамки;
		Элементы.ДекорацияПеревестиВПокупателяИЗаказ.ЦветТекста = Цвета.ЦветТекста;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая3.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая4.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая3.Картинка = ЛинияВертикальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая4.Картинка = ЛинияВертикальная;
		Элементы.ГруппаПеревестиВПокупателяИЗаказ.Доступность = Ложь;
		
		Элементы.ДекорацияПометитьНаУдаление5.ЦветРамки = Цвета.ЦветРамки;
		Элементы.ДекорацияПеревестиВПокупателяИЗаказНаряд.ЦветТекста = Цвета.ЦветТекста;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая5.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая6.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая5.Картинка = ЛинияВертикальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая6.Картинка = ЛинияВертикальная;
		Элементы.ГруппаПеревестиВПокупателяИЗаказНаряд.Доступность = Ложь;
		
	Иначе
		
		Цвета = РаботаСЛидами.ЦветОбластиПодКанбаном("Зеленый");
		ЛинияГоризонтальная = БиблиотекаКартинок.ЛинияГоризонтальнаяПунктирнаяЗеленая;
		ЛинияВертикальная = БиблиотекаКартинок.ЛинияВертикальнаяПунктирнаяЗеленая;
		
		Элементы.ДекорацияПометитьНаУдаление4.ЦветРамки = Цвета.ЦветРамки;
		Элементы.ДекорацияПеревестиВПокупателяИЗаказ.ЦветТекста = Цвета.ЦветТекста;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая3.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая4.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая3.Картинка = ЛинияВертикальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая4.Картинка = ЛинияВертикальная;
		Элементы.ГруппаПеревестиВПокупателяИЗаказ.Доступность = Истина;
		
		Элементы.ДекорацияПометитьНаУдаление5.ЦветРамки = Цвета.ЦветРамки;
		Элементы.ДекорацияПеревестиВПокупателяИЗаказНаряд.ЦветТекста = Цвета.ЦветТекста;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая5.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияГоризонтальнаяПунктирнаяЗеленая5.Картинка = ЛинияГоризонтальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая5.Картинка = ЛинияВертикальная;
		Элементы.ЛинияВертикальнаяПунктирнаяЗеленая6.Картинка = ЛинияВертикальная;
		Элементы.ГруппаПеревестиВПокупателяИЗаказНаряд.Доступность = Истина;
		
		Цвета = РаботаСЛидами.ЦветОбластиПодКанбаном("Красный");
		Элементы.ДекорацияПометитьНаУдаление2.ЦветРамки = Цвета.ЦветРамки;
		Элементы.ДекорацияНекачественныйЛид.ЦветТекста = Цвета.ЦветТекста;
		Элементы.ЛинияГоризонтальнаяПунктирнаяКрасная1.Картинка = БиблиотекаКартинок.ЛинияГоризонтальнаяПунктирнаяКрасная;
		Элементы.ЛинияГоризонтальнаяПунктирнаяКрасная2.Картинка = БиблиотекаКартинок.ЛинияГоризонтальнаяПунктирнаяКрасная;
		Элементы.ЛинияВертикальнаяПунктирнаяКрасная1.Картинка = БиблиотекаКартинок.ЛинияВертикальнаяПунктирнаяКрасная;
		Элементы.ЛинияВертикальнаяПунктирнаяКрасная2.Картинка = БиблиотекаКартинок.ЛинияВертикальнаяПунктирнаяКрасная;
		Элементы.ГруппаПометитьНекачественный.Доступность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуМобильныйКлиент()
	
	Если НЕ ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗагрузкаДанныхИзВнешнегоИсточника", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СоздатьКанбан", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ОтборПоиск", "Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаВидОтображения", "Видимость", Ложь);
	
	Элементы.Иерархия.Показать();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеСписка()
	
	УсловноеОформление.Элементы.Очистить();
	
	УстановитьУсловноеОформлениеПоЦветамСостоянийСервер();
	УстановитьУсловноеОформлениеПоВариантамЗавершения();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеПоЦветамСостоянийСервер()
	
	СостоянияЛидов.УстановитьУсловноеОформлениеПоЦветамСостояний(Список.КомпоновщикНастроек.Настройки.УсловноеОформление,
		Метаданные.Справочники.СостоянияЛидов.ПолноеИмя());
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеПоВариантамЗавершения()
	
	НовоеУсловноеОформление = Список.УсловноеОформление.Элементы.Добавить();
	//@skip-check new-color
	НовоеУсловноеОформление.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(74, 134, 57));
	
	РаботаСФормой.ДобавитьЭлементОтбораКомпоновкиДанных(
	НовоеУсловноеОформление.Отбор,
	"ВариантЗавершения",
	Перечисления.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя);
	
	НовоеУсловноеОформление = Список.УсловноеОформление.Элементы.Добавить();
	//@skip-check new-color
	НовоеУсловноеОформление.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(155, 0, 0));
	
	РаботаСФормой.ДобавитьЭлементОтбораКомпоновкиДанных(
	НовоеУсловноеОформление.Отбор,
	"ВариантЗавершения",
	Перечисления.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеИОбновитьКомандыСостояний()
	УстановитьУсловноеОформлениеСписка();
	ОбновитьКомандыИзмененияСостояний();
КонецПроцедуры

&НаСервере
Процедура ОпределитьИнтерфейсКомандПереходаКЗаявкам()
	
	ВидимостьГруппыЗаявок = Ложь;
	ВидимостьКомандыЗаказыПокупателей = Ложь;
	ВидимостьКомандыЗаказНаряды = Ложь;
	
	Если ЗаявкиИспользуютсяДляЗаказовПокупателей И ЗаявкиИспользуютсяДляЗаказНарядов Тогда
		ВидимостьГруппыЗаявок = Истина;
	ИначеЕсли ЗаявкиИспользуютсяДляЗаказовПокупателей Тогда
		ВидимостьКомандыЗаказыПокупателей = Истина;
	ИначеЕсли ЗаявкиИспользуютсяДляЗаказНарядов Тогда
		ВидимостьКомандыЗаказНаряды = Истина;
	КонецЕсли;
	
	Элементы.СписокКонтекстноеМенюГруппаПерейтиКЗаявкам.Видимость = ВидимостьГруппыЗаявок;
	Элементы.СписокКонтекстноеМенюПерейтиКЗаявкамЗаказПокупателяОтдельная.Видимость = ВидимостьКомандыЗаказыПокупателей;
	Элементы.СписокКонтекстноеМенюПерейтиКЗаявкамЗаказНарядОтдельная.Видимость = ВидимостьКомандыЗаказНаряды;
	
	Элементы.ПланировщикКонтекстноеМенюГруппаПерейтиКЗаявкам.Видимость = ВидимостьГруппыЗаявок;
	Элементы.ПланировщикКонтекстноеМенюПерейтиКЗаявкамЗаказПокупателяОтдельная.Видимость = ВидимостьКомандыЗаказыПокупателей;
	Элементы.ПланировщикКонтекстноеМенюПерейтиКЗаявкамЗаказНарядОтдельная.Видимость = ВидимостьКомандыЗаказНаряды;
	
КонецПроцедуры

#КонецОбласти

#Область Заявки

&НаКлиенте
Процедура Заявка(ВидОперации)
	
	Лид = ЛидИзСпискаИлиКанбана();
	Если Не ЗначениеЗаполнено(Лид) Тогда
		Возврат;
	КонецЕсли;
	
	ОтветОтСервера = ЗаявкаНаСервере(Лид, ВидОперации);
	
	ПараметрыМетода = Новый Структура;
	ПараметрыМетода.Вставить("Лид", Лид);
	ПараметрыМетода.Вставить("ВидОперации", ВидОперации);
	ПараметрыМетода.Вставить("ЗаявкиИспользуются", ОтветОтСервера.ЗаявкиИспользуются);
	ПараметрыМетода.Вставить("ВариантЗавершенияЛида", ОтветОтСервера.ДанныеЛида.ВариантЗавершения);
	ПараметрыМетода.Вставить("ПредставлениеЛида", ОтветОтСервера.ДанныеЛида.Представление);
	ПараметрыМетода.Вставить("ИспользоватьВидыЗаказов", ОтветОтСервера.ИспользоватьВидыЗаказов);
	РаботаСЗаявкамиКлиент.СозданиеЗаявкиНаЛидаАсинх(ПараметрыМетода);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаявкаНаСервере(Знач Лид, Знач ВидОперации)
	
	Результат = Новый Структура;
	
	ДанныеЛида = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Лид, "ВариантЗавершения,Представление");
	ЗаявкиИспользуются = РаботаСЗаявками.ЗаявкиИспользуются(, ВидОперации);
	
	Результат.Вставить("ДанныеЛида", ДанныеЛида);
	Результат.Вставить("ЗаявкиИспользуются", ЗаявкиИспользуются);
	
	Если ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу Тогда
		ИспользоватьВидыЗаказов = ПолучитьФункциональнуюОпцию("ИспользоватьВидыЗаказовПокупателей");
	Иначе
		ИспользоватьВидыЗаказов = ПолучитьФункциональнуюОпцию("ИспользоватьВидыЗаказНарядов");
	КонецЕсли;
	
	Результат.Вставить("ИспользоватьВидыЗаказов", ИспользоватьВидыЗаказов);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОбновитьОтображениеКнопокЗаявок()
	
	Элементы.ПодменюЗаявки.Видимость = ИспользоватьПодсистемуРаботы;
	Элементы.ФормаЗаявкаЗаказПокупателяОтдельная.Видимость = Не ИспользоватьПодсистемуРаботы;
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКЗаявкам(ВидОперации)
	
	Лид = ЛидИзСпискаИлиКанбана();
	Если Не ЗначениеЗаполнено(Лид) Тогда
		Возврат;
	КонецЕсли;
	
	РаботаСЛидамиКлиент.ОткрытьЗаявкиПоЛиду(Лид, ВидОперации);
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Функция ВКанбанеИлиСпискеВыбранЭлемент()
	
	Возврат (Элементы.ФормаКанбан.Пометка И Элементы.Планировщик.ВыделенныеЭлементы.Количество() <> 0)
	ИЛИ (Элементы.ФормаСписок.Пометка
	И Элементы.Список.ТекущиеДанные <> Неопределено
	И Элементы.Список.ВыделенныеСтроки.Количество() <> 0
	И ТипЗнч(Элементы.Список.ТекущаяСтрока) <> Тип("СтрокаГруппировкиДинамическогоСписка"));
	
КонецФункции

&НаКлиенте
Функция ЛидИзСпискаИлиКанбана(Лид = Неопределено)
	
	Если Не ВКанбанеИлиСпискеВыбранЭлемент() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Лид) Тогда
		Если Элементы.ФормаСписок.Пометка Тогда
			Лид = Элементы.Список.ТекущиеДанные.Ссылка;
		Иначе
			Лид = Элементы.Планировщик.ВыделенныеЭлементы[0].Значение;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Лид;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеЛидовДляПроверкиЗавершенных(Лиды)
	
	ВариантыЗавершения = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Лиды, "ВариантЗавершения,Представление");
	
	Для Каждого КлючЗначение Из ВариантыЗавершения Цикл
		Если ЗначениеЗаполнено(КлючЗначение.Значение.ВариантЗавершения) Тогда
			
			Результат = Новый Структура;
			Результат.Вставить("Ссылка", КлючЗначение.Ключ);
			Результат.Вставить("Представление", КлючЗначение.Значение.Представление);
			Результат.Вставить("ЕстьЗавершенныйЛид", Истина);
			Возврат Результат;
			
		КонецЕсли;
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("ЕстьЗавершенныйЛид", Ложь);
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьПредупреждениеОНеобходимостиВыбораОдногоЛида()
	
	ПредупреждениеАсинх(НСтр("ru = 'Выберите только один лид для перевода.'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьПредупреждениеОЗавершенномЛиде(ДанныеЛида)
	
	ТекстПредупреждения = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
	НСтр("ru = 'Работа с лидом <a href=""%1"">%2</a> уже завершена'"),
	ПолучитьНавигационнуюСсылку(ДанныеЛида.Ссылка), ДанныеЛида.Представление);
	
	ПредупреждениеАсинх(ТекстПредупреждения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьПредупреждениеОбОтсутствииПрав()
	
	ПредупреждениеАсинх(НСтр("ru = 'Нет прав на выполнение действия.'"));
	
КонецПроцедуры

&НаСервере
Процедура ПереместитьВверхВнизСервер(Знач Лид, Знач Состояние, Знач Операция)
	
	ДанныеЛидов = Новый Структура();
	ДанныеЛидов.Вставить("СсылкаНаПервыйЛид",Лид);
	
	ПорядокПервогоЛида = ПорядокСмещаемогоЭлемента(Лид);
	ДанныеЛидов.Вставить("ПорядокПервогоЛида",ПорядокПервогоЛида);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	КанбанЛидов.Лид КАК Лид,
	|	КанбанЛидов.Порядок
	|ИЗ
	|	РегистрСведений.КанбанЛидов КАК КанбанЛидов
	|ГДЕ
	|	КанбанЛидов.Состояние = &Состояние";
	
	Если Операция = "ПеретаскиваниеВниз" Тогда
		Запрос.Текст = Запрос.Текст + Символы.ПС + "И КанбанЛидов.Порядок > &Порядок УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок";
	ИначеЕсли Операция = "ПеретаскиваниеВверх" Тогда
		Запрос.Текст = Запрос.Текст + Символы.ПС + "И КанбанЛидов.Порядок < &Порядок УПОРЯДОЧИТЬ ПО КанбанЛидов.Порядок УБЫВ";
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Порядок",ПорядокПервогоЛида);
	Запрос.УстановитьПараметр("Состояние",Состояние);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Пока Выборка.Следующий() Цикл
		ДанныеЛидов.Вставить("СсылкаНаВторойЛид",Выборка.Лид);
		ДанныеЛидов.Вставить("ПорядокВторогоЛида",Выборка.Порядок);
		Прервать;
	КонецЦикла;
	ДанныеЛидов.Вставить("Состояние", Состояние);
	РегистрыСведений.КанбанЛидов.ПоменятьПорядкиЛидов(ДанныеЛидов);
	
	ОбновитьЭлементыПланировщика("Перетаскивание");
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьСобытиеПоКонтакту(ИмяТипаСобытия, Лид)
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("ТипСобытия", ПредопределенноеЗначение("Перечисление.ТипыСобытий." + ИмяТипаСобытия));
	ЗначенияЗаполнения.Вставить("Лид", Лид);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	ОткрытьФорму("Документ.Событие.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура НастроитьКомандуЭкспортВАдреснуюКнигу()
	
	ИспользоватьМассовыеРассылкиИнтеграция = ПолучитьФункциональнуюОпцию("ИспользоватьМассовыеРассылкиИнтеграция")
		И ЗначениеЗаполнено(МассовыеРассылкиИнтеграция.ПодключенныйСервис());
	
	Элементы.ФормаЭкспортВАдреснуюКнигуСервисаРассылок.Видимость = ИспользоватьМассовыеРассылкиИнтеграция;
	Элементы.СписокКонтекстноеМенюЭкспортВАдреснуюКнигуСервисаРассылок.Видимость = ИспользоватьМассовыеРассылкиИнтеграция;
	
	Если Не ИспользоватьМассовыеРассылкиИнтеграция Тогда
		Возврат;
	КонецЕсли;
	
	ЗаголовокКомандыЭкспорта = СтрШаблон(НСтр("ru='Экспорт в адресную книгу %1'"), МассовыеРассылкиИнтеграция.ПредставлениеСервиса());
	
	Элементы.ФормаЭкспортВАдреснуюКнигуСервисаРассылок.Заголовок = ЗаголовокКомандыЭкспорта;
	Элементы.СписокКонтекстноеМенюЭкспортВАдреснуюКнигуСервисаРассылок.Заголовок = ЗаголовокКомандыЭкспорта;
	
КонецПроцедуры

&НаКлиенте
Функция ВыделенныеЛиды()
	
	ВыделенныеЛиды = Новый Массив;
	Для каждого ВыделеннаяСтрока Из Элементы.Список.ВыделенныеСтроки Цикл
		ТекущаяСтрока = Элементы.Список.ДанныеСтроки(ВыделеннаяСтрока);
		Если ТекущаяСтрока <> Неопределено Тогда
			ВыделенныеЛиды.Добавить(ТекущаяСтрока.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ВыделенныеЛиды;
	
КонецФункции

&НаСервере
Процедура СохранитьГлобальныеНастройки()
	
	ИспользоватьПодсистемуРаботы = ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуРаботы");
	ПланироватьЗагрузкуРесурсовПредприятияЖурналЗаписи = ПолучитьФункциональнуюОпцию("ПланироватьЗагрузкуРесурсовПредприятияЖурналЗаписи");
	
	ИспользованиеЗаявок = РаботаСЗаявками.ИспользованиеЗаявокПоВидуОперации();
	ЗаявкиИспользуютсяДляЗаказовПокупателей = ИспользованиеЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу];
	ЗаявкиИспользуютсяДляЗаказНарядов = ИспользованиеЗаявок[Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд];
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЧтениеРазрешено(Знач Ссылка)
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат УправлениеДоступом.ЧтениеРазрешено(Ссылка);
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти