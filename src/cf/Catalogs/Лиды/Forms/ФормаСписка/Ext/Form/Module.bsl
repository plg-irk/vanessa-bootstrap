&НаСервере
Процедура ЗаполнитьСпискиВыборовОтборов()
	
	Элементы.ОтборЗавершение.СписокВыбора.Очистить();
	ПредставлениеЗначения = РаботаСЛидами.ПредставлениеРезультатаЛидаВРаботе();
	Элементы.ОтборЗавершение.СписокВыбора.Добавить(ПредставлениеЗначения, ПредставлениеЗначения);
	ПредставлениеЗначения = РаботаСЛидами.ПредставлениеРезультатаКачественногоЛида();
	Элементы.ОтборЗавершение.СписокВыбора.Добавить(ПредставлениеЗначения, ПредставлениеЗначения);
	ПредставлениеЗначения = РаботаСЛидами.ПредставлениеРезультатаНекачественногоЛида();
	Элементы.ОтборЗавершение.СписокВыбора.Добавить(ПредставлениеЗначения, ПредставлениеЗначения);
	
	Элементы.ОтборВид.СписокВыбора.Очистить();
	ПредставлениеЗначения = СтроковыеФункции.ФорматированнаяСтрока(НСтр("ru = '<img src=""ПервичныйЛид""> Первичное'"));
	Элементы.ОтборВид.СписокВыбора.Добавить(Перечисления.ВидыЛидов.ПервичноеОбращение, ПредставлениеЗначения);
	ПредставлениеЗначения = СтроковыеФункции.ФорматированнаяСтрока(НСтр("ru = '<img src=""ПовторныйЛид""> Повторное'"));
	Элементы.ОтборВид.СписокВыбора.Добавить(Перечисления.ВидыЛидов.ПовторноеОбращение, ПредставлениеЗначения);
	
КонецПроцедуры

&НаСервере
Функция УстановленныеОтборыПоРезультату()
	
	ЭлементыОтбораПоРезультату = ОбщегоНазначенияКлиентСервер.НайтиЭлементыИГруппыОтбора(Список.Отбор, "Завершение");
	УстановленОтборПоРезультату =
	ЭлементыОтбораПоРезультату.Количество() И ЭлементыОтбораПоРезультату[0].Использование;
	
	ЭлементыОтбораПоСостояниям = ОбщегоНазначенияКлиентСервер.НайтиЭлементыИГруппыОтбора(Список.Отбор, "СостояниеЛида");
	УстановленОтборПоСостояниям =
	ЭлементыОтбораПоСостояниям.Количество() И ЭлементыОтбораПоСостояниям[0].Использование;
	
	Если Не УстановленОтборПоРезультату И Не УстановленОтборПоСостояниям Тогда
		
		ОтборПоЛидамВРаботе = Истина;
		ОтборПоКачественным = Истина;
		ОтборПоНекачественным = Истина;
		
	ИначеЕсли УстановленОтборПоСостояниям Тогда
		
		ОтборПоЛидамВРаботе = Истина;
		ОтборПоКачественным = Ложь;
		ОтборПоНекачественным = Ложь;
		
	Иначе
		
		ЗначениеОтбора = ЭлементыОтбораПоРезультату[0].ПравоеЗначение;
		Если ТипЗнч(ЗначениеОтбора) = Тип("Строка") Тогда
			
			ОтборПоЛидамВРаботе = (ЗначениеОтбора = РаботаСЛидами.ПредставлениеРезультатаЛидаВРаботе());
			ОтборПоКачественным = (ЗначениеОтбора = РаботаСЛидами.ПредставлениеРезультатаКачественногоЛида());
			ОтборПоНекачественным = (ЗначениеОтбора = РаботаСЛидами.ПредставлениеРезультатаНекачественногоЛида());
			
		Иначе
			
			ОтборПоЛидамВРаботе = ЗначениеОтбора.НайтиПоЗначению(
			РаботаСЛидами.ПредставлениеРезультатаЛидаВРаботе()) <> Неопределено;
			ОтборПоКачественным = ЗначениеОтбора.НайтиПоЗначению(
			РаботаСЛидами.ПредставлениеРезультатаКачественногоЛида()) <> Неопределено;
			ОтборПоНекачественным = ЗначениеОтбора.НайтиПоЗначению(
			РаботаСЛидами.ПредставлениеРезультатаНекачественногоЛида()) <> Неопределено;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ВРаботе", ОтборПоЛидамВРаботе);
	Результат.Вставить("КачественныеЛиды", ОтборПоКачественным);
	Результат.Вставить("НекачественныеЛиды", ОтборПоНекачественным);
	
	Возврат Результат;
	
КонецФункции

