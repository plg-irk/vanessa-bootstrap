
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьНачальноеОтображениеФормы();
	
	Параметры.Свойство("Лид", Лид);
	Если Не ЗначениеЗаполнено(Лид) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ПолучитьФункциональныеОпции();
	УправлениеФормой();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРезультатыПеревода

&НаКлиенте
Процедура РезультатыПереводаВыборЗначения(Элемент, Значение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Значение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Закрыть(РезультатыПеревода.НайтиПоИдентификатору(Значение).Значение);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПерейтиКЛиду(Команда)
	
	ОткрытьЗначениеАсинх(Лид);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ИзменениеИнтерфейсаПоДанным

&НаСервере
Процедура УстановитьНачальноеОтображениеФормы()
	
	КлючОбъекта = "Справочник.Лиды.Форма.ФормаКачественныйЛидКанбан/НастройкиОкна";
	ХранилищеСистемныхНастроек.Удалить(КлючОбъекта, "", ИмяПользователя());
	КлючСохраненияПоложенияОкна = Новый УникальныйИдентификатор;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеФормой()
	
	ИзменитьПодписиКСписку();
	ЗаполнитьСписокВыбора();
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьПодписиКСписку()
	
	Элементы.ПерейтиКЛиду.Заголовок = Строка(Лид);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокВыбора()
	
	УстановитьПривилегированныйРежим(Истина);
	Контрагент = Справочники.Лиды.СвязанныйКонтрагент(Лид);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ЗначениеЗаполнено(Контрагент) Тогда
		
		РезультатыПеревода.Добавить("ЗаказПокупателя", НСтр("ru = 'Заказ покупателя'"));
		
		Если ИспользоватьПодсистемуРаботы Тогда
			РезультатыПеревода.Добавить("ЗаказНаряд", НСтр("ru = 'Заказ-наряд'"));
		КонецЕсли;
		
	Иначе
		
		РезультатыПеревода.Добавить("Покупатель", НСтр("ru = 'Покупателя'"));
		РезультатыПеревода.Добавить("ЗаказПокупателя", НСтр("ru = 'Покупателя + заказ'"));
		
		Если ИспользоватьПодсистемуРаботы Тогда
			РезультатыПеревода.Добавить("ЗаказНаряд", НСтр("ru = 'Покупателя + заказ-наряд'"));
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ПолучитьФункциональныеОпции()
	
	ИспользоватьПодсистемуРаботы = ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуРаботы");
	
КонецПроцедуры

#КонецОбласти
