#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
		
		Если ДанныеЗаполнения.Свойство("ПереводВКачественныйЛид") Тогда
			ЗаполнитьЕслиЛидПереводитсяВКачественный();
		КонецЕсли;
		
		Если ДанныеЗаполнения.Свойство("ПереводВНекачественныйЛид") Тогда
			ЗаполнитьЕслиЛидПереводитсяВНекачественный();
		КонецЕсли;
		
		Если ДанныеЗаполнения.Свойство("ВозвратВРаботу") Тогда
			ЗаполнитьВозвратЛидаВРаботу(ДанныеЗаполнения);
		КонецЕсли;
		
	КонецЕсли;
	
	ДозаполнитьПоУмолчанию();
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	ПроверитьЗаполнениеПередЗаписью(Отказ);
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоНовый() Тогда
		ДатаСоздания = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ЗаполнитьНомерТелефона();
	ЗаполнитьАдресЭП();
	
	СостоянияЛидов.ПередЗаписьюЛида(ЭтотОбъект);
	
	ОбработатьКонтрагентаИВидПередЗаписью();
	
	СформироватьОсновныеСведенияЛида();
	
	СтарыеЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "СостояниеЛида,ВариантЗавершения");
	ДополнительныеСвойства.Вставить("ЭтоНовыйЛид", ЭтоНовый());
	ДополнительныеСвойства.Вставить("СостояниеЛидаПередЗаписью", СтарыеЗначенияРеквизитов.СостояниеЛида);
	ДополнительныеСвойства.Вставить("ВариантЗавершенияПередЗаписью", СтарыеЗначенияРеквизитов.ВариантЗавершения);
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	СостоянияЛидов.ПриЗаписиЛида(ЭтотОбъект);
	ДобавитьЗаписиВКанбанПриЗаписи();
	ОбработатьКонтрагентаПриЗаписи();
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Если ЭтоГруппа Тогда
		Возврат;
	КонецЕсли;
	
	СостояниеДоКопирования = СостояниеЛида;
	СостояниеЛида = ЗаполнениеОбъектовУНФ.ПолучитьСостояниеЛида();
	
	Если НЕ СостояниеДоКопирования = Справочники.СостоянияЛидов.Завершен Тогда
		Возврат;
	КонецЕсли;
	
	ПричинаНеуспешногоЗавершенияРаботы = Неопределено;
	ВариантЗавершения = Неопределено;
	ДатаЗавершенияРаботы = Дата('00010101');
	ЗаметкиЗавершенияРаботы = Неопределено;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	МассивНепроверяемыхРеквизитов = Новый Массив;
	
	Если Не Справочники.ГруппыДоступаЛидов.ИспользуютсяГруппыДоступа() Тогда
		МассивНепроверяемыхРеквизитов.Добавить("ГруппаДоступа");
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ВариантЗавершения) 
		ИЛИ ВариантЗавершения = Перечисления.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя Тогда
		МассивНепроверяемыхРеквизитов.Добавить("ПричинаНеуспешногоЗавершенияРаботы");
	КонецЕсли;
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

Процедура ПередУдалением(Отказ)
	
	Если ОбменДанными.Загрузка = Истина Тогда
		Возврат;
	КонецЕсли;
	
	РегистрыСведений.ТекущиеВходящиеЗвонки.ПередУдалениемКонтакта(Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Заполнение

Процедура ПроверитьЗаполнениеПередЗаписью(Отказ)
	
	ПроверитьЗаполнениеВидаИКонтрагента(Отказ);
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеВидаИКонтрагента(Отказ)
	
	Контрагент = Неопределено;
	ДополнительныеСвойства.Свойство("Контрагент", Контрагент);
	
	Если Вид = Перечисления.ВидыЛидов.ПовторноеОбращение Тогда
		
		Если ТипЗнч(Контрагент) <> Тип("СправочникСсылка.Контрагенты")
			Или Не ЗначениеЗаполнено(Контрагент)
			Или Не УправлениеДоступом.ЧтениеРазрешено(Контрагент) Тогда
			
			Если ЭтоНовый() Тогда
				Отказ = Истина;
				ВызватьИсключение НСтр("ru = 'Для повторного лида не указан контрагент'");
			КонецЕсли;
			
			Контрагент = Справочники.Лиды.СвязанныйКонтрагент(Ссылка);
			Если Не ЗначениеЗаполнено(Контрагент) Тогда
				Отказ = Истина;
				ВызватьИсключение НСтр("ru = 'Для повторного лида не заполнен контрагент'");
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(Контрагент) Тогда
		ДополнительныеСвойства.Удалить("Контрагент");
	КонецЕсли;
	
КонецПроцедуры

Процедура ДозаполнитьПоУмолчанию()
	
	Если Не ЗначениеЗаполнено(Ответственный) Тогда
		Ответственный = ПерсональныеНастройкиРУНФ.Прочитать("ОсновнойОтветственный");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СостояниеЛида) Тогда
		СостояниеЛида = ЗаполнениеОбъектовУНФ.ПолучитьСостояниеЛида();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ГруппаДоступа) Тогда
		ГруппаДоступа = Справочники.ГруппыДоступаЛидов.ГруппаДоступаПоУмолчанию();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Вид) Тогда
		Вид = Перечисления.ВидыЛидов.ПервичноеОбращение;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьЕслиЛидПереводитсяВКачественный()
	
	СостояниеЛида = Справочники.СостоянияЛидов.Завершен;
	ДатаЗавершенияРаботы = ТекущаяДатаСеанса();
	ПричинаНеуспешногоЗавершенияРаботы = Неопределено;
	ВариантЗавершения = Перечисления.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя;
	
КонецПроцедуры

Процедура ЗаполнитьЕслиЛидПереводитсяВНекачественный()
	
	СостояниеЛида = Справочники.СостоянияЛидов.Завершен;
	ДатаЗавершенияРаботы = ТекущаяДатаСеанса();
	ВариантЗавершения = Перечисления.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид;
	
КонецПроцедуры

Процедура ЗаполнитьВозвратЛидаВРаботу(ДанныеЗаполнения)
	
	Если Не ДанныеЗаполнения.Свойство("СостояниеЛида") Тогда
		СостояниеЛида = СостоянияЛидов.ПолучитьСостояниеЛидаПередЗавершением(
		Ссылка, Справочники.СостоянияЛидов.Завершен);
	КонецЕсли;
	
	ПричинаНеуспешногоЗавершенияРаботы = Неопределено;
	ВариантЗавершения = Неопределено;
	ДатаЗавершенияРаботы = Дата('00010101');
	ЗаметкиЗавершенияРаботы = Неопределено;
	
КонецПроцедуры

// Процедура заполняет вспомогательный реквизит "НомерТелефона"
//
Процедура ЗаполнитьНомерТелефона() Экспорт
	
	НомераТелефонов = Новый Массив;
	
	Для Каждого СтрокаКИ Из КонтактнаяИнформация Цикл
		Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
			НомераТелефонов.Добавить(СтрокаКИ.НомерТелефона);
		КонецЕсли;
	КонецЦикла;
	
	Если ДополнительныеСвойства.Свойство("НомераТелефоновКонтактаЛида") Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НомераТелефонов, ДополнительныеСвойства.НомераТелефоновКонтактаЛида);
	КонецЕсли;

	НомерТелефонаДляПоиска = СтрСоединить(НомераТелефонов, ", ");
	
КонецПроцедуры

// Процедура заполняет вспомогательный реквизит "АдресЭП"
//
Процедура ЗаполнитьАдресЭП() Экспорт
	
	АдресаЭП = Новый Массив;
	
	Для Каждого СтрокаКИ Из КонтактнаяИнформация Цикл
		Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
			АдресаЭП.Добавить(СтрокаКИ.Представление);
		КонецЕсли;
	КонецЦикла;
	
	Если ДополнительныеСвойства.Свойство("АдресаЭПКонтактовЛида") Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(АдресаЭП, ДополнительныеСвойства.АдресаЭПКонтактовЛида);
	КонецЕсли;
	
	АдресЭПДляПоиска = СтрСоединить(АдресаЭП, ", ");
	
КонецПроцедуры

Процедура СформироватьОсновныеСведенияЛида() Экспорт
	
	Если ДополнительныеСвойства.Свойство("ПроверенныйКонтрагент") Тогда
		
		//@skip-check bsl-legacy-check-string-literal
		ОсновныеСведения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
		ДополнительныеСвойства.ПроверенныйКонтрагент, "ОсновныеСведения");
		Возврат;
		
	КонецЕсли;
	
	МассивСтрок = Новый Массив;
	
	Если Не ПустаяСтрока(Наименование) Тогда
		МассивСтрок.Добавить(Наименование);
	КонецЕсли;
	
	Если Не ПустаяСтрока(НаименованиеКомпании) Тогда
		МассивСтрок.Добавить(НаименованиеКомпании);
	КонецЕсли;
	
	ТаблицаКИ = КонтактнаяИнформация.Выгрузить();
	ТаблицаКИ.Сортировать("Вид");
	Для Каждого СтрокаКИ Из ТаблицаКИ Цикл
		Если ПустаяСтрока(СтрокаКИ.Представление) Тогда
			Продолжить;
		КонецЕсли;
		МассивСтрок.Добавить(СтрокаКИ.Представление);
	КонецЦикла;
	
	Если ДополнительныеСвойства.Свойство("ОсновныеСведенияКонтактныхЛиц") Тогда
		
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивСтрок, ДополнительныеСвойства.ОсновныеСведенияКонтактныхЛиц);
		
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КонтактыЛида.Наименование КАК Наименование,
		|	КонтактыЛида.КонтактнаяИнформация.(
		|		Представление КАК Представление,
		|		Вид КАК ВидКИ
		|	) КАК КонтактнаяИнформация
		|ИЗ
		|	Справочник.КонтактыЛидов КАК КонтактыЛида
		|ГДЕ
		|	КонтактыЛида.ПометкаУдаления = ЛОЖЬ
		|	И КонтактыЛида.Владелец = &Лид
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование,
		|	ВидКИ";
		
		Запрос.УстановитьПараметр("Лид", Ссылка);
		
		ВыборкаКЛ = Запрос.Выполнить().Выбрать();
		Пока ВыборкаКЛ.Следующий() Цикл
			
			Если МассивСтрок.Количество() > 0 Тогда
				МассивСтрок.Добавить(Символы.ПС);
			КонецЕсли;
			МассивСтрок.Добавить(ВыборкаКЛ.Наименование);
			
			ВыборкаКИ = ВыборкаКЛ.КонтактнаяИнформация.Выбрать();
			Пока ВыборкаКИ.Следующий() Цикл
				Если ПустаяСтрока(ВыборкаКИ.Представление) Тогда
					Продолжить;
				КонецЕсли;
				МассивСтрок.Добавить(ВыборкаКИ.Представление);
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если Не ПустаяСтрока(Комментарий) Тогда
		МассивСтрок.Добавить(Комментарий);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ответственный) Тогда
		МассивСтрок.Добавить(Ответственный);
	КонецЕсли;
	
	ОсновныеСведения = СтрСоединить(МассивСтрок, Символы.ПС);
	
КонецПроцедуры

#КонецОбласти

#Область РаботаСКонтрагентом

Процедура ОбработатьКонтрагентаИВидПередЗаписью()
	
	Контрагент = Неопределено;
	ДополнительныеСвойства.Свойство("Контрагент", Контрагент);
	Если Не ЗначениеЗаполнено(Контрагент) Или Не УправлениеДоступом.ЧтениеРазрешено(Контрагент) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("ПроверенныйКонтрагент", Контрагент);
	//@skip-check bsl-legacy-check-string-literal
	Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Контрагент, "Наименование");
	
КонецПроцедуры

Процедура ОбработатьКонтрагентаПриЗаписи()
	
	Если Вид = Перечисления.ВидыЛидов.ПервичноеОбращение Тогда
		
		Если ЗначениеЗаполнено(ВариантЗавершения) Тогда
			Возврат;
		КонецЕсли;
		
		РегистрыСведений.СвязиКонтрагентЛид.УдалитьСвязи(Ссылка);
		
		Возврат;
		
	КонецЕсли;
	
	Если Вид <> Перечисления.ВидыЛидов.ПовторноеОбращение Тогда
		Возврат;
	КонецЕсли;
	
	Контрагент = Неопределено;
	Если Не ДополнительныеСвойства.Свойство("ПроверенныйКонтрагент", Контрагент) Тогда
		Возврат;
	КонецЕсли;
	
	Заказ = Неопределено;
	ДополнительныеСвойства.Свойство("Заказ", Заказ);
	СвязанныйКонтрагент = Справочники.Лиды.СвязанныйКонтрагент(Ссылка);
	РегистрыСведений.СвязиКонтрагентЛид.НоваяСвязь(Контрагент, Ссылка, Заказ);
	
	Если СвязанныйКонтрагент <> Контрагент Тогда
		ДобавитьКИЛидаВКонтрагента(Контрагент);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКИЛидаВКонтрагента(Контрагент)
	
	Если УправлениеДоступом.ИзменениеРазрешено(Контрагент) Тогда
		КонтрагентОбъект = ДобавитьОбычнуюКИЛидаВКонтрагента(Контрагент);
	КонецЕсли;
	
	Если КонтрагентОбъект = Неопределено Тогда
		ДобавитьКонтактыЛидаДляКонтрагента(Контрагент);
	Иначе
		ДобавитьКонтактыЛидаДляКонтрагента(КонтрагентОбъект);
	КонецЕсли;
	
КонецПроцедуры

Функция ДобавитьОбычнуюКИЛидаВКонтрагента(Контрагент)
	
	НоваяКИКонтрагента = КИОбъектаНаОсновеДругойКИДляПереноса(
	Контрагент, КонтактнаяИнформация);
	
	Если НоваяКИКонтрагента = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	КонтрагентОбъект = ОбъектСДобавленнойКИ(Контрагент, НоваяКИКонтрагента);
	Если КонтрагентОбъект = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	КонтрагентОбъект.Записать();
	Возврат КонтрагентОбъект;
	
КонецФункции

Процедура ДобавитьКонтактыЛидаДляКонтрагента(Контрагент)
	
	Если ТипЗнч(Контрагент) = Тип("СправочникОбъект.Контрагенты") Тогда
		ДанныеКонтрагента = Контрагент;
	Иначе
		ДанныеКонтрагента = Новый Структура;
		ДанныеКонтрагента.Вставить("Ссылка", Контрагент);
		ДанныеКонтрагента.Вставить(
		"ГруппаДоступа", ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Контрагент, "ГруппаДоступа"));
	КонецЕсли;
	
	КонтактыЛида = Справочники.КонтактыЛидов.КонтактыЛида(Ссылка);
	
	ДополнительныйВыборДанных = Новый Структура;
	ДополнительныйВыборДанных.Вставить("Наименование");
	ДополнительныйВыборДанных.Вставить("КонтактнаяИнформация");
	КонтактныеЛица = Справочники.Контрагенты.СвязанныеКонтакты(ДанныеКонтрагента.Ссылка, ДополнительныйВыборДанных);
	
	Для каждого КонтактЛида Из КонтактыЛида Цикл
		
		Если Не ЗначениеЗаполнено(КонтактЛида.Наименование) Тогда
			Продолжить;
		КонецЕсли;
		
		НужноДобавитьКонтактноеЛицо = Истина;
		Для Каждого КонтактноеЛицо Из КонтактныеЛица Цикл
			
			Если КонтактноеЛицо.Наименование <> КонтактЛида.Наименование Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяКИКонтакта = КИОбъектаНаОсновеДругойКИДляПереноса(
			КонтактноеЛицо.Ссылка,
			КонтактЛида.КонтактнаяИнформация,
			КонтактноеЛицо.КонтактнаяИнформация);
			
			Если НоваяКИКонтакта <> Неопределено Тогда
				
				КонтактОбъект = ОбъектСДобавленнойКИ(КонтактноеЛицо.Ссылка, НоваяКИКонтакта);
				Если КонтактОбъект <> Неопределено Тогда
					КонтактОбъект.Записать();
				КонецЕсли;
				
			КонецЕсли;
			
			НужноДобавитьКонтактноеЛицо = Ложь;
			Прервать;
			
		КонецЦикла;
		
		Если Не НужноДобавитьКонтактноеЛицо Тогда
			Продолжить;
		КонецЕсли;
		
		НовыйКонтакт = Справочники.КонтактныеЛица.СоздатьЭлемент();
		НовыйКонтакт.Наименование = КонтактЛида.Наименование;
		НовыйКонтакт.Заполнить(Неопределено);
		НовыйКонтакт.ГруппаДоступа = ДанныеКонтрагента.ГруппаДоступа;
		
		ПеренестиКИВНовыйОбъект(
		НовыйКонтакт, НовыйКонтакт.Ссылка, КонтактЛида.КонтактнаяИнформация);
		НовыйКонтакт.Записать();
		
		РегистрыСведений.СвязиКонтрагентКонтакт.НоваяСвязь(ДанныеКонтрагента.Ссылка, НовыйКонтакт.Ссылка);
		
	КонецЦикла;
	
КонецПроцедуры

Функция КИОбъектаНаОсновеДругойКИДляПереноса(
	Ссылка, КонтактнаяИнформацияИсточника, КонтактнаяИнформацияОбъекта = Неопределено)
	
	Если ТипЗнч(КонтактнаяИнформацияОбъекта) = Тип("ТаблицаЗначений") Тогда
		КИОбъекта = КонтактнаяИнформацияОбъекта;
	Иначе
		КИОбъекта = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		Ссылка, , ТекущаяДатаСеанса(), Ложь);
	КонецЕсли;
	
	ТаблицаНовойКИ = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация();
	ТипОбъекта = ТипЗнч(Ссылка);
	
	Для Каждого СтрокаКИ Из КонтактнаяИнформацияИсточника Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаКИ.Значение) И Не ЗначениеЗаполнено(СтрокаКИ.ЗначенияПолей) Тогда
			Продолжить;
		КонецЕсли;
		
		ПредставлениеКИ = СтрокаКИ.Представление;
		
		НужноДобавитьКИ = Истина;
		Для Каждого СтрокаКИОбъекта Из КИОбъекта Цикл
			
			Если СтрокаКИ.Тип <> СтрокаКИОбъекта.Тип Тогда
				Продолжить;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(СтрокаКИОбъекта.Значение)
				И Не ЗначениеЗаполнено(СтрокаКИОбъекта.ЗначенияПолей) Тогда
				Продолжить;
			КонецЕсли;
			
			ПредставлениеКИОбъекта = СтрокаКИОбъекта.Представление;
			
			Если СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				
				ПредставлениеКИТелефона =
				УправлениеКонтактнойИнформациейУНФКлиентСервер.НомерТелефонаВМеждународномФормате(ПредставлениеКИ);
				Если ПустаяСтрока(ПредставлениеКИТелефона) Тогда
					
					Если ПредставлениеКИОбъекта = ПредставлениеКИ Тогда
						НужноДобавитьКИ = Ложь;
					КонецЕсли;
					
					Прервать;
					
				КонецЕсли;
				
				ПредставлениеКИ = ПредставлениеКИТелефона;
				ПредставлениеКИОбъекта =
				УправлениеКонтактнойИнформациейУНФКлиентСервер.НомерТелефонаВМеждународномФормате(ПредставлениеКИОбъекта);
				
			КонецЕсли;
			
			Если ПредставлениеКИОбъекта = ПредставлениеКИ Тогда
				НужноДобавитьКИ = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если Не НужноДобавитьКИ Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяКИ = ТаблицаНовойКИ.Добавить();
		НоваяКИ.Вид = ВидКИПоТипуОбъекта(ТипОбъекта, СтрокаКИ.Тип, СтрокаКИ.Вид);
		ЗаполнитьЗначенияСвойств(НоваяКИ, СтрокаКИ, "Представление,ЗначенияПолей,Значение,Тип");
		
	КонецЦикла;
	
	Если Не ТаблицаНовойКИ.Количество() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ТаблицаНовойКИ;
	
КонецФункции

Функция ОбъектСДобавленнойКИ(СсылкаИлиОбъект, КонтактнаяИнформация)
	
	ПолученаСсылка = ОбщегоНазначения.ЭтоСсылка(ТипЗнч(СсылкаИлиОбъект));
	Если ПолученаСсылка Тогда
		Объект = СсылкаИлиОбъект.ПолучитьОбъект();
	Иначе
		Объект = СсылкаИлиОбъект;
	КонецЕсли;
	
	Попытка
		Объект.Заблокировать();
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Не удалось заблокировать объект %1
		|
		|Описание ошибки:
		|%2'"),
		Объект,
		ТекстОшибки);
		
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Блокировки.Ошибка'", ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка, Объект.Метаданные(), ,
		ТекстОшибки);
		
		Возврат Неопределено;
		
	КонецПопытки;
	
	УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъекта(
	Объект, КонтактнаяИнформация, Ложь);
	
	Возврат Объект;
	
КонецФункции

Процедура ПеренестиКИВНовыйОбъект(Приемник, Ссылка, КонтактнаяИнформация)
	
	ТаблицаНовойКИ = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация();
	ТипОбъекта = ТипЗнч(Ссылка);
	
	Для каждого СтрокаКИ Из КонтактнаяИнформация Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаКИ.Значение) И Не ЗначениеЗаполнено(СтрокаКИ.ЗначенияПолей) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяКИ = ТаблицаНовойКИ.Добавить();
		НоваяКИ.Вид = ВидКИПоТипуОбъекта(ТипОбъекта, СтрокаКИ.Тип, СтрокаКИ.Вид);
		ЗаполнитьЗначенияСвойств(НоваяКИ, СтрокаКИ, "Представление,ЗначенияПолей,Значение,Тип");
		
	КонецЦикла;
	
	УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъекта(Приемник, ТаблицаНовойКИ);
	
КонецПроцедуры

Функция ВидКИПоТипуОбъекта(ТипСсылки, ТипКИ, ВидКИ = Неопределено)
	
	Если ТипСсылки = Тип("СправочникСсылка.Контрагенты") Тогда
		Возврат Справочники.Лиды.ВидКИКонтрагента(ТипКИ, ВидКИ);
	КонецЕсли;
	
	Если ТипСсылки = Тип("СправочникСсылка.КонтактныеЛица") Тогда
		Возврат Справочники.Лиды.ВидКИКонтактногоЛица(ТипКИ);
	КонецЕсли;
	
КонецФункции

#КонецОбласти

Процедура ДобавитьЗаписиВКанбанПриЗаписи()
	
	Если ЗначениеЗаполнено(ВариантЗавершения) Тогда
		
		Если ДополнительныеСвойства.ВариантЗавершенияПередЗаписью <> ВариантЗавершения Тогда
			РегистрыСведений.КанбанЛидов.ДобавитьЗавершенныйЛид(Ссылка, ВариантЗавершения);
		КонецЕсли;
		Возврат;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДополнительныеСвойства.ВариантЗавершенияПередЗаписью) Тогда
		
		Если ДополнительныеСвойства.Свойство("КанбанЛидов") Тогда
			Порядок = ДополнительныеСвойства.КанбанЛидов.Порядок;
		КонецЕсли;
		
		РегистрыСведений.КанбанЛидов.ПереместитьЛид(
		Справочники.СостоянияЛидов.Завершен,
		СостояниеЛида,
		Ссылка,
		Порядок,
		ДополнительныеСвойства.ВариантЗавершенияПередЗаписью);
		
		Возврат;
		
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("НеЗаписыватьДанныеВРегистр") Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("КанбанЛидов") Тогда
		
		РегистрыСведений.КанбанЛидов.ПереместитьЛид(
		ДополнительныеСвойства.КанбанЛидов.СостояниеЛида,
		СостояниеЛида,
		Ссылка,
		ДополнительныеСвойства.КанбанЛидов.Порядок);
		
	ИначеЕсли ДополнительныеСвойства.ЭтоНовыйЛид Тогда
		
		РегистрыСведений.КанбанЛидов.ДобавитьЛидВКонец(СостояниеЛида, Ссылка);
		
	ИначеЕсли ДополнительныеСвойства.СостояниеЛидаПередЗаписью <> СостояниеЛида Тогда
		
		РегистрыСведений.КанбанЛидов.ПереместитьЛид(
		ДополнительныеСвойства.СостояниеЛидаПередЗаписью, СостояниеЛида, Ссылка);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

