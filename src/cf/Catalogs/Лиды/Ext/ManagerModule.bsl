#Область ОбновлениеИнформационнойБазы

// В программе появились виды лидов: "первичное" и "повторное" обращение.
// Ранее логически были только первичные обращения (первичные лиды).
// Нужно заполнить старых лидов, чтобы они считались первичными с учетом новой функциональности.
// Версия 3.0.9
//
// Параметры:
//  Параметры - См. ОбновлениеИнформационнойБазыУНФ.ПриДобавленииОбработчиковОбновления
//
Процедура ЗаполнитьЛидовПриПоявленииПовторныхЛидов(Параметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	Лиды.Ссылка КАК Ссылка,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Лиды.Ссылка) КАК Представление
		|ИЗ
		|	Справочник.Лиды КАК Лиды
		|ГДЕ
		|	Лиды.Вид = ЗНАЧЕНИЕ(Перечисление.ВидыЛидов.ПустаяСсылка)
		|	И НЕ Лиды.ЭтоГруппа";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		Параметры.ОбработкаЗавершена = Истина;
		ТекстСообщения = НСтр(
		"ru='Процедура ЗаполнитьЛидовПриПоявленииПовторныхЛидов завершила обработку. Запрос вернул пустую порцию объектов.'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
		Возврат;
		
	КонецЕсли;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			ЛидОбъект = Выборка.Ссылка.ПолучитьОбъект();
			Если ЛидОбъект = Неопределено Тогда
				ЗафиксироватьТранзакцию();
				Возврат;
			КонецЕсли;
			
			ЛидОбъект.Заблокировать();
			ЛидОбъект.Вид = Перечисления.ВидыЛидов.ПервичноеОбращение;
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ЛидОбъект);
			
			ЗафиксироватьТранзакцию();
			ОбъектовОбработано = ОбъектовОбработано + 1;
			
		Исключение
			
			ОтменитьТранзакцию();
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			
			ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщения = НСтр("ru='Не удалось обработать объект ""%1"" по причине:
			|%2'", ОбщегоНазначения.КодОсновногоЯзыка());
			ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Представление, ТекстОшибки);
			
			ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.Лиды,
			Выборка.Ссылка,
			ТекстСообщения);
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если ОбъектовОбработано Тогда
		
		ТекстСообщения = НСтр(
		"ru='Процедура ЗаполнитьЛидовПриПоявленииПовторныхЛидов обработала очередную порцию объектов: %1'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектовОбработано);
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
	Иначе
		
		ТекстСообщения = НСтр("ru='Процедуре ЗаполнитьЛидовПриПоявленииПовторныхЛидов не удалось обработать некоторые объекты (пропущены): %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ПроблемныхОбъектов);
		ВызватьИсключение ТекстСообщения;
		
	КонецЕсли;
	
КонецПроцедуры

// Качественные и некачественные (завершенные) лиды теперь отображаются в канбане лидов.
// Необходимо добавить существующих завершенных лидов в регистр КанбанЛидов
// Версия 3.0.9
//
// Параметры:
//  Параметры - См. ОбновлениеИнформационнойБазыУНФ.ПриДобавленииОбработчиковОбновления
//
Процедура ПоместитьЗавершенныеЛидыВКанбан(Параметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	Лиды.Ссылка КАК Ссылка,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Лиды.Ссылка) КАК Представление,
		|	КанбанЛидов.Порядок КАК Порядок,
		|	Лиды.ВариантЗавершения КАК ВариантЗавершения
		|ИЗ
		|	Справочник.Лиды КАК Лиды
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КанбанЛидов КАК КанбанЛидов
		|		ПО Лиды.Ссылка = КанбанЛидов.Лид
		|ГДЕ
		|	НЕ Лиды.ЭтоГруппа
		|	И Лиды.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантЗавершенияРаботыСЛидом.ПустаяСсылка)
		|	И КанбанЛидов.Состояние = ЗНАЧЕНИЕ(Справочник.СостоянияЛидов.Завершен)
		|	И КанбанЛидов.ВариантЗавершения = ЗНАЧЕНИЕ(Перечисление.ВариантЗавершенияРаботыСЛидом.ПустаяСсылка)
		|	И Лиды.Ссылка ЕСТЬ НЕ NULL
		|	И ПРЕДСТАВЛЕНИЕССЫЛКИ(Лиды.Ссылка) ЕСТЬ НЕ NULL";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		Параметры.ОбработкаЗавершена = Истина;
		ТекстСообщения = НСтр(
		"ru='Процедура ПоместитьЗавершенныеЛидыВКанбан завершила обработку. Запрос вернул пустую порцию объектов.'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
		Возврат;
		
	КонецЕсли;
	
	ОбъектовОбработано = 0;
	ПроблемныхОбъектов = 0;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НачатьТранзакцию();
		
		Попытка
			
			НаборЗаписей = РегистрыСведений.КанбанЛидов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Лид.Установить(Выборка.Ссылка);
			
			НоваяЗапись = НаборЗаписей.Добавить();
			НоваяЗапись.Лид = Выборка.Ссылка;
			НоваяЗапись.Состояние = Справочники.СостоянияЛидов.Завершен;
			НоваяЗапись.ВариантЗавершения = Выборка.ВариантЗавершения;
			НоваяЗапись.Порядок = Выборка.Порядок;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей);
			
			ЗафиксироватьТранзакцию();
			ОбъектовОбработано = ОбъектовОбработано + 1;
			
		Исключение
			
			ОтменитьТранзакцию();
			ПроблемныхОбъектов = ПроблемныхОбъектов + 1;
			
			ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщения = НСтр("ru='Не удалось обработать объект ""%1"" по причине:
			|%2'", ОбщегоНазначения.КодОсновногоЯзыка());
			ТекстСообщения = СтрШаблон(ТекстСообщения, Выборка.Представление, ТекстОшибки);
			
			ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Справочники.Лиды,
			Выборка.Ссылка,
			ТекстСообщения);
			
		КонецПопытки;
		
	КонецЦикла;
	
	Если ОбъектовОбработано Тогда
		
		ТекстСообщения = НСтр(
		"ru='Процедура ПоместитьЗавершенныеЛидыВКанбан обработала очередную порцию объектов: %1'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = СтрШаблон(ТекстСообщения, ОбъектовОбработано);
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
	Иначе
		
		ТекстСообщения = НСтр("ru='Процедуре ПоместитьЗавершенныеЛидыВКанбан не удалось обработать некоторые объекты (пропущены): %1'");
		ТекстСообщения = СтрШаблон(ТекстСообщения, ПроблемныхОбъектов);
		ВызватьИсключение ТекстСообщения;
		
	КонецЕсли;
	
КонецПроцедуры

// Изменение фильтра Результат в списке лидов на новые значения
// Версия 3.0.9
//
// Параметры:
//  Параметры - См. ОбновлениеИнформационнойБазыУНФ.ПриДобавленииОбработчиковОбновления
//
Процедура ИзменитьФильтрЛидовПоРезультату(Параметры) Экспорт
	
	ИмяКлючаОбъекта = "СправочникЛидыФормаФормаСписка";
	Отборы = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(ИмяКлючаОбъекта, ИмяКлючаОбъекта + "_ДанныеОтборов");
	Метки = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(ИмяКлючаОбъекта, ИмяКлючаОбъекта + "_ДанныеМеток");
	
	Если ТипЗнч(Отборы) <> Тип("ТаблицаЗначений") Или ТипЗнч(Метки) <> Тип("ТаблицаЗначений") Тогда
		
		Параметры.ОбработкаЗавершена = Истина;
		ТекстСообщения = НСтр(
		"ru='Процедура ИзменитьФильтрЛидовПоРезультату завершила обработку. Необходимые фильтры не найдены.'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
		Возврат;
		
	КонецЕсли;
	
	Если Отборы.Колонки.Найти("ИмяОтбора") = Неопределено
		Или Отборы.Колонки.Найти("Выбран") = Неопределено
		Или Отборы.Колонки.Найти("Заголовок") = Неопределено
		Или Отборы.Колонки.Найти("ТипЗначения") = Неопределено
		Или Отборы.Колонки.Найти("ЭтоПредопределенныйОтбор") = Неопределено
		Или Отборы.Колонки.Найти("ИмяЭлемента") = Неопределено
		Или Метки.Колонки.Найти("Метка") = Неопределено
		Или Метки.Колонки.Найти("ПредставлениеМетки") = Неопределено
		Или Метки.Колонки.Найти("ИмяПоляОтбора") = Неопределено
		Или Метки.Колонки.Найти("ИмяГруппыРодителя") = Неопределено
		Или Метки.Колонки.Найти("ИмяОтбора") = Неопределено Тогда
		
		Параметры.ОбработкаЗавершена = Истина;
		ТекстСообщения = НСтр(
		"ru='Процедура ИзменитьФильтрЛидовПоРезультату завершила обработку. Необходимые фильтры не найдены.'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
		Возврат;
		
	КонецЕсли;
	
	ОтборПоРезультату = Отборы.НайтиСтроки(Новый Структура("ИмяОтбора", "ОтборРезультат"));
	Если ОтборПоРезультату.Количество() Тогда
		ОтборПоРезультату[0].ТипЗначения = Новый ОписаниеТипов("Строка");
	Иначе
		
		НовыйОтбор = Отборы.Добавить();
		НовыйОтбор.ИмяОтбора = "ОтборРезультат";
		НовыйОтбор.Выбран = Истина;
		НовыйОтбор.Заголовок = "Результат";
		НовыйОтбор.ТипЗначения = Новый ОписаниеТипов("Строка");
		НовыйОтбор.ЭтоПредопределенныйОтбор = Истина;
		НовыйОтбор.ИмяЭлемента = "ОтборРезультат";
		
	КонецЕсли;
	
	МеткиПоРезультату = Метки.НайтиСтроки(Новый Структура("ИмяОтбора", "ОтборРезультат"));
	Если МеткиПоРезультату.Количество() Тогда
		
		Для Каждого Метка Из МеткиПоРезультату Цикл
			
			Если Метка.Метка = Перечисления.ВариантЗавершенияРаботыСЛидом.ПереведенВПокупателя Тогда
				ЗначениеМетки = РаботаСЛидами.ПредставлениеРезультатаКачественногоЛида();
			ИначеЕсли Метка.Метка = Перечисления.ВариантЗавершенияРаботыСЛидом.НекачественныйЛид Тогда
				ЗначениеМетки = РаботаСЛидами.ПредставлениеРезультатаНекачественногоЛида();
			Иначе
				Продолжить;
			КонецЕсли;
			
			Метка.ИмяПоляОтбора = "РезультатРаботы";
			Метка.Метка = ЗначениеМетки;
			Метка.ПредставлениеМетки = ЗначениеМетки;
			
		КонецЦикла;
		
	Иначе
		
		НоваяМетка = Метки.Добавить();
		НоваяМетка.Метка = РаботаСЛидами.ПредставлениеРезультатаЛидаВРаботе();
		НоваяМетка.ПредставлениеМетки = РаботаСЛидами.ПредставлениеРезультатаЛидаВРаботе();
		НоваяМетка.ИмяПоляОтбора = "РезультатРаботы";
		НоваяМетка.ИмяГруппыРодителя = "Результат";
		НоваяМетка.ИмяОтбора = "ОтборРезультат";
		
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(ИмяКлючаОбъекта, ИмяКлючаОбъекта + "_ДанныеОтборов", Отборы);
		ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(ИмяКлючаОбъекта, ИмяКлючаОбъекта + "_ДанныеМеток", Метки);
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		Параметры.ОбработкаЗавершена = Истина;
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения = НСтр("ru='Не удалось изменить фильтры по причине:
		|%1'", ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = СтрШаблон(ТекстСообщения, ТекстОшибки);
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Ошибка,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
		Возврат;
		
	КонецПопытки;
	
	Параметры.ОбработкаЗавершена = Истина;
	ТекстСообщения = НСтр(
	"ru='Процедура ИзменитьФильтрЛидовПоРезультату завершила обработку. Фильтры изменены.'",
	ОбщегоНазначения.КодОсновногоЯзыка());
	
	ЗаписьЖурналаРегистрации(
	ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
	УровеньЖурналаРегистрации.Информация,
	Метаданные.Справочники.Лиды, ,
	ТекстСообщения);
	
КонецПроцедуры

// Изменение название фильтра Результат на Завершение
// Версия 3.0.11
//
// Параметры:
//  Параметры - См. ОбновлениеИнформационнойБазыУНФ.ПриДобавленииОбработчиковОбновления
//
Процедура ПоменятьНазваниеФильтраРезультат(Параметры) Экспорт
	
	ИмяФормыСписка = "СправочникЛидыФормаФормаСписка";
	ДанныеОтборов = РаботаСОтборами.ДанныеОтборов(ИмяФормыСписка);
	ДанныеМеток = РаботаСОтборами.ДанныеМеток(ИмяФормыСписка);
	
	Если Не РаботаСОтборами.СтруктураТаблицыОтборовКорректна(ДанныеОтборов)
		Или Не РаботаСОтборами.СтруктураТаблицыМетокКорректна(ДанныеМеток) Тогда
		
		Параметры.ОбработкаЗавершена = Истина;
		ТекстСообщения = НСтр(
		"ru='Процедура ИзменитьФильтрЛидовПоРезультату завершила обработку. Необходимые фильтры не найдены.'",
		ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Информация,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
		Возврат;
		
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		РаботаСОтборами.ИзменитьНазваниеОтбора(
		ИмяФормыСписка, "Результат", "Завершение", "Завершение", НСтр("ru = 'Завершение работы с лидом'"));
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		Параметры.ОбработкаЗавершена = Истина;
		
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщения = НСтр("ru='Не удалось изменить фильтры по причине:
		|%1'", ОбщегоНазначения.КодОсновногоЯзыка());
		ТекстСообщения = СтрШаблон(ТекстСообщения, ТекстОшибки);
		
		ЗаписьЖурналаРегистрации(
		ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Ошибка,
		Метаданные.Справочники.Лиды, ,
		ТекстСообщения);
		
		Возврат;
		
	КонецПопытки;
	
	Параметры.ОбработкаЗавершена = Истина;
	ТекстСообщения = НСтр(
	"ru='Процедура ИзменитьФильтрЛидовПоРезультату завершила обработку. Фильтры изменены.'",
	ОбщегоНазначения.КодОсновногоЯзыка());
	
	ЗаписьЖурналаРегистрации(
	ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
	УровеньЖурналаРегистрации.Информация,
	Метаданные.Справочники.Лиды, ,
	ТекстСообщения);
	
КонецПроцедуры

#КонецОбласти

#Область ПервыйЗапуск

// Первый запуск: включение контроля дублей по данным лидов
//
