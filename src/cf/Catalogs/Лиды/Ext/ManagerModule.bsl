#Область ПрограммныйИнтерфейс

// Изменить состояние лида.
// 
// Параметры:
//  Лид - СправочникСсылка.Лиды - Лид
//  Состояние - СправочникСсылка.СостоянияЛидов - Состояние
//  ВариантЗавершения - Неопределено - Вариант завершения
//  ПричинаОтмены - Неопределено - Причина отмены
//  Заметки - Строка - Заметки
// 
Процедура ИзменитьСостояниеЛида(Лид, Состояние, ВариантЗавершения = Неопределено, ПричинаОтмены = Неопределено, Заметки = "") Экспорт
	
	ДанныеЛида = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Лид, "СостояниеЛида,ВариантЗавершения");
	
	Если ДанныеЛида.СостояниеЛида = Состояние И Состояние <> Справочники.СостоянияЛидов.Завершен
		ИЛИ (ДанныеЛида.СостояниеЛида = Состояние И Состояние = Справочники.СостоянияЛидов.Завершен
		И (ЗначениеЗаполнено(ДанныеЛида.ВариантЗавершения) И ДанныеЛида.ВариантЗавершения = ВариантЗавершения)) Тогда
		Возврат;
	КонецЕсли;
	
	ЛидОбъект = Лид.ПолучитьОбъект();
	
	ЛидОбъект.Заблокировать();
	ЛидОбъект.СостояниеЛида = Состояние;
	
	Если ВариантЗавершения <> Неопределено Тогда
		ЛидОбъект.ВариантЗавершения = ВариантЗавершения;
	КонецЕсли;
	
	Если ПричинаОтмены <> Неопределено Тогда
		ЛидОбъект.ПричинаНеуспешногоЗавершенияРаботы = ПричинаОтмены;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Заметки) Тогда
		ЛидОбъект.ЗаметкиЗавершенияРаботы = Заметки;
	КонецЕсли;
	
	Если Не ЛидОбъект.ПроверитьЗаполнение() Тогда
		ЛидОбъект.Разблокировать();
		Возврат;
	КонецЕсли;
	
	ЛидОбъект.Записать();
	
	ЛидОбъект.Разблокировать();

КонецПроцедуры

// Получатели электронного письма.
// 
// Параметры:
//  Лид - СправочникСсылка.Лиды - Лид
//  ВидКонтактнойИнформации - Неопределено, СправочникСсылка.ВидыКонтактнойИнформации  - Вид контактной информации
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Получатели электронного письма:
//   * Контакт - ОпределяемыеТипы.КонтактСобытия
//   * КакСвязаться - Строка
//
//@skip-check doc-comment-type
Функция ПолучателиЭлектронногоПисьма(Лид, ВидКонтактнойИнформации = Неопределено) Экспорт
	
	ПолучателиЭлектронногоПисьма = Новый ТаблицаЗначений;
	ПолучателиЭлектронногоПисьма.Колонки.Добавить("Контакт", Метаданные.ОпределяемыеТипы.КонтактСобытия.Тип);
	ПолучателиЭлектронногоПисьма.Колонки.Добавить("КакСвязаться", Новый ОписаниеТипов("Строка"));
	
	КонтактнаяИнформацияОбъекта = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Лид,
		ВидКонтактнойИнформации, ТекущаяДатаСеанса(), Ложь);
	
	Если ВидКонтактнойИнформации = Неопределено Тогда
		ОтборКонтактнойИнформации = Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
		СтрокиКонтактнойИнформации = КонтактнаяИнформацияОбъекта.НайтиСтроки(ОтборКонтактнойИнформации);
	Иначе
		СтрокиКонтактнойИнформации = КонтактнаяИнформацияОбъекта;
	КонецЕсли;
	
	Для каждого Строка Из СтрокиКонтактнойИнформации Цикл
		НовыйПолучатель = ПолучателиЭлектронногоПисьма.Добавить();
		НовыйПолучатель.Контакт = Лид;
		НовыйПолучатель.КакСвязаться = Строка.Представление;
	КонецЦикла;
	
	Возврат ПолучателиЭлектронногоПисьма;
	
КонецФункции

// Получатели электронного письма.
// 
// Параметры:
//  Лид - СправочникСсылка.Лиды - Лид
//  ВидКонтактнойИнформации - Неопределено, СправочникСсылка.ВидыКонтактнойИнформации  - Вид контактной информации
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Получатели электронного письма:
//   * Контакт - ОпределяемыеТипы.КонтактСобытия
//   * КакСвязаться - Строка
//
//@skip-check doc-comment-type
Функция ПолучателиСообщенияSMS(Лид, ВидКонтактнойИнформации = Неопределено) Экспорт
	
	ПолучателиСообщенияSMS = Новый ТаблицаЗначений;
	ПолучателиСообщенияSMS.Колонки.Добавить("Контакт", Метаданные.ОпределяемыеТипы.КонтактСобытия.Тип);
	ПолучателиСообщенияSMS.Колонки.Добавить("КакСвязаться", Новый ОписаниеТипов("Строка"));
	
	КонтактнаяИнформацияОбъекта = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Лид,
		ВидКонтактнойИнформации, ТекущаяДатаСеанса(), Ложь);
	
	Если ВидКонтактнойИнформации = Неопределено Тогда
		ОтборКонтактнойИнформации = Новый Структура("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
		СтрокиКонтактнойИнформации = КонтактнаяИнформацияОбъекта.НайтиСтроки(ОтборКонтактнойИнформации);
	Иначе
		СтрокиКонтактнойИнформации = КонтактнаяИнформацияОбъекта;
	КонецЕсли;
	
	Для каждого Строка Из СтрокиКонтактнойИнформации Цикл
		НовыйПолучатель = ПолучателиСообщенияSMS.Добавить();
		НовыйПолучатель.Контакт = Лид;
		НовыйПолучатель.КакСвязаться = Строка.Представление;
	КонецЦикла;
	
	Возврат ПолучателиСообщенияSMS;
	
КонецФункции

// Стандартные реквизиты для выбора полей при переводе лида в контрагента
//
// Возвращаемое значение:
//  - Соответствие из Строка - список реквизитов, Ключ - Имя реквизита, Значение - представление реквизита
//
Функция СтандартныеРеквизитыДляПереводаВПокупателя() Экспорт
	
	Реквизиты = Новый Соответствие;
	Реквизиты.Вставить("Наименование", НСтр("ru = 'Представление в программе'"));
	Реквизиты.Вставить("Комментарий", НСтр("ru = 'Дополнительная информация'"));
	Реквизиты.Вставить("НаименованиеКомпании", НСтр("ru = 'Юридическое название'"));
	Реквизиты.Вставить("ИсточникПривлечения", НСтр("ru = 'Источник'"));
	Реквизиты.Вставить("Тема", НСтр("ru = 'Тема'"));
	
	Возврат Реквизиты;
	
КонецФункции

// Перенос контактной информации контактов лида в служебный справочник
// Версия 1.6.20
// Удалить при удалении обработчика
// 
// Параметры:
//  ЛидОбъект - СправочникОбъект.Лиды - лид, по которому необходимо выполнить перенос
//
Процедура ПеренестиКонтактыЛидаВСправочникКонтактыЛидов(ЛидОбъект) Экспорт
	
	НачатьТранзакцию();
	
	Попытка
		
		ЛидОбъект.Заблокировать();
		НомераТелефонов = Новый Массив;
		АдресаЭП = Новый Массив;
		
		Для Каждого Контакт Из ЛидОбъект.УдалитьКонтакты Цикл
			
			НовыйКонтакт              = Справочники.КонтактыЛидов.СоздатьЭлемент();
			НовыйКонтакт.Владелец     = ЛидОбъект.Ссылка;
			НовыйКонтакт.Наименование = Контакт.Наименование;
			
			Отбор = Новый Структура("ИдентификаторСтрокиТабличнойЧасти", Контакт.ИдентификаторСтрокиТабличнойЧасти);
			КИКонтакта = ЛидОбъект.УдалитьКонтактнаяИнформация.НайтиСтроки(Отбор);
			
			Для Каждого КИ Из КИКонтакта Цикл
				
				НовоеКИ = НовыйКонтакт.КонтактнаяИнформация.Добавить();
				ЗаполнитьЗначенияСвойств(НовоеКИ, КИ,, "Вид");
				НовоеКИ.Вид = Справочники.КонтактыЛидов.ВидКИКонтактаПоВидуЛида(КИ.Вид);
				
				Если КИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
					Если ЗначениеЗаполнено(КИ.НомерТелефона) Тогда
						НомераТелефонов.Добавить(КИ.НомерТелефона);
					Иначе
						НомераТелефонов.Добавить(КонтактнаяИнформацияУНФ.ПреобразоватьНомерДляКонтактнойИнформации(КИ.Представление));
					КонецЕсли;
				КонецЕсли;
				
				Если КИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
					АдресаЭП.Добавить(КИ.Представление);
				КонецЕсли;
				
			КонецЦикла;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(НовыйКонтакт);
			
		КонецЦикла;
		
		НомерТелефона         = СтрСоединить(НомераТелефонов, ", ");
		АдресЭП               = СтрСоединить(АдресаЭП, ",");
		ЛидОбъект.НомерТелефонаДляПоиска = НомерТелефона;
		ЛидОбъект.АдресЭПДляПоиска       = АдресЭП;
		
		ЛидОбъект.КонтактыПеренесены = Истина;
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ЛидОбъект);
		ЛидОбъект.Разблокировать();

		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ОбщегоНазначения.СообщитьПользователю(ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()),
			ЛидОбъект.Ссылка);
		
	КонецПопытки;
	
КонецПроцедуры

// Возвращает вид контактной информации контактного лица по типу контактной информации.
//
// Параметры:
//  ТипКИЛида - ПеречислениеСсылка.ТипыКонтактнойИнформации.
// 
// Возвращаемое значение:
//  - СправочникСсылка.ВидыКонтактнойИнформации - вид контактной информации
//  - Неопределено - если не удалось определить вид.
//
Функция ВидКИКонтактногоЛица(ТипКИЛида) Экспорт
	
	Если ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.EmailКонтактногоЛица;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.ТелефонКонтактногоЛица;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.Другое Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.МессенджерКонтактногоЛица;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.Skype Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.SkypeКонтактногоЛица;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.ВебСтраница Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.СоциальнаяСетьКонтактногоЛица;
	Иначе
		Возврат ВидКИКонтактногоЛицаЗапросом(ТипКИЛида);
	КонецЕсли;
	
КонецФункции

// Функция - Сведения о лиде для печати
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  ДатаПериода - Дата
// 
// Возвращаемое значение:
//  Структура - См. ПечатьДокументовУНФ.СведенияОЮрФизЛице
//
Функция СведенияОЛидеДляПечати(Лид, ДатаПериода) Экспорт
	
	ДанныеЛида = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Лид, "Представление,Наименование,НаименованиеКомпании");
	Если ПустаяСтрока(ДанныеЛида.НаименованиеКомпании) Тогда
		ДанныеЛида.НаименованиеКомпании = ДанныеЛида.Наименование;
	КонецЕсли;
	
	Результат = ПечатьДокументовУНФ.СведенияОЮрФизЛице(Лид, ДатаПериода);
	Результат.Представление = ДанныеЛида.Представление;
	Результат.ПолноеНаименование = ДанныеЛида.НаименованиеКомпании;
	Результат.СокращенноеНаименование = ДанныеЛида.Наименование;
	Результат.НаименованиеДляПечати = ДанныеЛида.НаименованиеКомпании;
	
	Результат.Телефоны = ПечатьДокументовУНФ.КонтактнаяИнформация(
	Лид, Справочники.ВидыКонтактнойИнформации.ТелефонКомпанииЛида, ДатаПериода);
	Результат.ЮридическийАдрес = ПечатьДокументовУНФ.КонтактнаяИнформация(
	Лид, Справочники.ВидыКонтактнойИнформации.ЮрАдресКомпанииЛида, ДатаПериода);
	Результат.ФактическийАдрес = ПечатьДокументовУНФ.КонтактнаяИнформация(
	Лид, Справочники.ВидыКонтактнойИнформации.ФактАдресКомпанииЛида, ДатаПериода);
	Результат.ЭлектроннаяПочта = ПечатьДокументовУНФ.КонтактнаяИнформация(
	Лид, Справочники.ВидыКонтактнойИнформации.EmailКомпанииЛида, ДатаПериода);
	
	Возврат Результат;
	
КонецФункции

#Область Контрагенты

// Контрагент, который был создан на основании лида.
//
// Параметры:
//  Лид - СправочникСсылка.Лиды
//  Отбор - Неопределено, Структура - позволяет устанавливать дополнительный отбор по контрагентам:
//   * ПроверятьРЛС - Произвольный
// 
// Возвращаемое значение:
//   СправочникСсылка.Контрагенты
//
Функция СвязанныйКонтрагент(Лид, Отбор = Неопределено) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Лид) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Если Отбор = Неопределено Тогда
		Отбор = Новый Структура;
	КонецЕсли;
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	СвязиКонтрагентЛид.Контрагент КАК Контрагент
		|ИЗ
		|	РегистрСведений.СвязиКонтрагентЛид КАК СвязиКонтрагентЛид
		|ГДЕ
		|	СвязиКонтрагентЛид.Лид = &Лид";
	
	Если Отбор.Свойство("ПроверятьРЛС") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ВЫБРАТЬ", "ВЫБРАТЬ РАЗРЕШЕННЫЕ");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Лид", Лид);
	
	Выборка = Запрос.Выполнить().Выбрать();
	ЕстьЗаписи = Выборка.Следующий();
	
	Если ЕстьЗаписи Тогда
		Возврат Выборка.Контрагент;
	Иначе
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

// Контрагенты, связанные с лидами
//
// Параметры:
//  Лиды - Массив из СправочникСсылка.Лиды
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ - СправочникСсылка.Лиды
//   * Значение - СправочникСсылка.Контрагенты
//
Функция СвязанныеКонтрагенты(Лиды) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Лиды) Тогда
		Возврат Новый Соответствие;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СвязиКонтрагентЛид.Лид КАК Лид,
	|	СвязиКонтрагентЛид.Контрагент КАК Контрагент
	|ИЗ
	|	РегистрСведений.СвязиКонтрагентЛид КАК СвязиКонтрагентЛид
	|ГДЕ
	|	СвязиКонтрагентЛид.Лид В(&Лиды)";
	
	Запрос.УстановитьПараметр("Лиды", Лиды);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		Результат[Выборка.Лид] = Выборка.Контрагент;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Создает контрагента на основании лида, если контрагент еще не был создан. 
// Если лид уже связан с контрагентом, то возвращает ссылку на связанного контрагента
//
// Параметры:
//  Лид - СправочникСсылка.Лиды, СправочникОбъект.Лиды - лид, для которого нужно получить/создать контрагента
// 
// Возвращаемое значение:
//   - СправочникСсылка.Контрагенты
//
Функция ПолучитьСоздатьКонтрагента(Лид) Экспорт
	
	Если ТипЗнч(Лид) = Тип("СправочникСсылка.Лиды") Тогда
		ЛидОбъект = Лид.ПолучитьОбъект();
	Иначе
		ЛидОбъект = Лид;
	КонецЕсли;
	
	ПараметрыСеанса.ИнтерактивнаяПроверкаЗаполненияСвойств = Истина;
	
	СвязанныйКонтрагент = СвязанныйКонтрагент(ЛидОбъект.Ссылка);
	КонтрагентУжеСоздан = ЗначениеЗаполнено(СвязанныйКонтрагент);
	
	Если КонтрагентУжеСоздан Тогда
		Возврат СвязанныйКонтрагент;
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		НовыйКонтрагент = СоздатьКонтрагентаИИзменитьЛида(ЛидОбъект);
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
	Возврат НовыйКонтрагент;
	
КонецФункции

// Перевод лид в нового покупателя без проверок.
//
// Параметры:
//  Лид - СправочникСсылка.Лиды - лид для перевода.
// 
// Возвращаемое значение:
//  - СправочникСсылка.Контрагенты - новый созданный контрагент.
//  - Неопределено - если не получилось перевести лида.
//
Функция ПеревестиЛидаВПокупателя(Лид) Экспорт
	
	Если ТипЗнч(Лид) = Тип("СправочникСсылка.Лиды") Тогда
		ЛидОбъект = Лид.ПолучитьОбъект();
	Иначе
		ЛидОбъект = Лид;
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		РегистрыСведений.СвязиКонтрагентЛид.УдалитьСвязи(ЛидОбъект.Ссылка);
		НовыйКонтрагент = СоздатьКонтрагентаИИзменитьЛида(ЛидОбъект);
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
	Возврат НовыйКонтрагент;
	
КонецФункции

// Возвращает вид контактной информации контрагента по типу и виду контактной информации.
//
// Параметры:
//  ТипКИЛида - ПеречислениеСсылка.ТипыКонтактнойИнформации.
//  ВидКИЛида - СправочникСсылка.ВидыКонтактнойИнформации.
// 
// Возвращаемое значение:
//  - СправочникСсылка.ВидыКонтактнойИнформации - вид контактной информации
//  - Неопределено - если не удалось определить вид.
//
Функция ВидКИКонтрагента(ТипКИЛида, ВидКИЛида) Экспорт
	
	Если ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.EmailКонтрагента;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.Другое Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.ДругаяИнформацияКонтрагента;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.Skype Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.SkypeКонтрагента;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.ВебСтраница Тогда
		Возврат Справочники.ВидыКонтактнойИнформации.ВебСайтКонтрагента;
	ИначеЕсли ТипКИЛида = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
		
		Если ВидКИЛида = Справочники.ВидыКонтактнойИнформации.ЮрАдресКомпанииЛида Тогда
			Возврат Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
		ИначеЕсли ВидКИЛида = Справочники.ВидыКонтактнойИнформации.ФактАдресКомпанииЛида Тогда
			Возврат Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента;
		Иначе
			Возврат ВидКИКонтрагентаЗапросом(ТипКИЛида);
		КонецЕсли;
		
	Иначе
		Возврат ВидКИКонтрагентаЗапросом(ТипКИЛида);
	КонецЕсли;
	
КонецФункции

#КонецОбласти

