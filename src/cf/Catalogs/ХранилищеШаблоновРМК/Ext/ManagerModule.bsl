// Возвращает имя поля из доступных полей компоновки данных.
//
Функция ИмяПоляВШаблоне(Знач ИмяПоля) Экспорт
	
	ИмяПоля = СтрЗаменить(ИмяПоля, ".DeletionMark", ".ПометкаУдаления");
	ИмяПоля = СтрЗаменить(ИмяПоля, ".Owner", ".Владелец");
	ИмяПоля = СтрЗаменить(ИмяПоля, ".Code", ".Код");
	ИмяПоля = СтрЗаменить(ИмяПоля, ".Parent", ".Родитель");
	ИмяПоля = СтрЗаменить(ИмяПоля, ".Predefined", ".Предопределенный");
	ИмяПоля = СтрЗаменить(ИмяПоля, ".IsFolder", ".ЭтоГруппа");
	ИмяПоля = СтрЗаменить(ИмяПоля, ".Description", ".Наименование");
	Возврат ИмяПоля;
	
КонецФункции

Функция ИмяПараметраШтрихкод() Экспорт
	
	Возврат "Штрихкод";
	
КонецФункции

// Функция-конструктор данных заполнения хранилища шаблонов РМК
// 
// Возвращаемое значение:
//  Структура:
//   * НоваяСсылка - СправочникСсылка.ХранилищеШаблоновРМК - Ссылка, которая будет назначена при записи нового объекта
//   * Наименование - Строка - Наименование шаблона чека
//   * Шаблон - ХранилищеЗначения - содержится структура с параметрами, используемыми в шаблоне чека
//   * СхемаКомпоновкиДанных - ХранилищеЗначения - содержится СхемаКомпоновкиДанных используемая для заполнения шаблона чека
//   * Условия - ТаблицаЗначений - условия применяемые в шаблоне чека
//
Функция ДанныеЗаполненияХранилищаШаблоновРМК() Экспорт
	
	ДанныеЗаполнения = Новый Структура();
	ДанныеЗаполнения.Вставить("НоваяСсылка", Неопределено);
	ДанныеЗаполнения.Вставить("Наименование", "");
	ДанныеЗаполнения.Вставить("Шаблон", Неопределено);
	ДанныеЗаполнения.Вставить("СхемаКомпоновкиДанных", Неопределено);
	ДанныеЗаполнения.Вставить("Условия", Новый ТаблицаЗначений);
	
	Возврат ДанныеЗаполнения;
	
КонецФункции

// Создает новый элемент справочника ХранилищеШаблоновРМК и возвращает его ссылку
//
// Параметры:
//  ДанныеЗаполнения - Структура - см. Справочники.ХранилищеШаблоновРМК.ДанныеЗаполненияХранилищаШаблоновРМК()
// 
// Возвращаемое значение:
//  СправочникСсылка.ХранилищеШаблоновРМК - ссылка на вновь созданный элемент справочника ХранилищеШаблоновРМК.
//
Функция НовоеХранилищеШаблоновРМК(Знач ДанныеЗаполнения) Экспорт
	
	ОбъектШаблонЧека = Справочники.ХранилищеШаблоновРМК.СоздатьЭлемент();
	Если ДанныеЗаполнения.НоваяСсылка <> Неопределено Тогда
		ОбъектШаблонЧека.УстановитьСсылкуНового(ДанныеЗаполнения.НоваяСсылка);
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(ОбъектШаблонЧека, ДанныеЗаполнения, , "Условия");
	Для каждого Условие Из ДанныеЗаполнения.Условия Цикл
		НовоеУсловие = ОбъектШаблонЧека.Условия.Добавить();
		ЗаполнитьЗначенияСвойств(НовоеУсловие, Условие);
	КонецЦикла;
	ОбъектШаблонЧека.Записать();
	
	Возврат ОбъектШаблонЧека.Ссылка;
	
КонецФункции

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		СтандартнаяОбработка = Ложь;
		ВыбраннаяФорма       = "Справочник.ХранилищеШаблоновРМК.Форма.ФормаРедактированияШаблонаЧекаККТ";
		Параметры.Вставить("ОбрабатыватьОбъектВФормеРедактирования", Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
