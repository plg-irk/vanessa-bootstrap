	СтруктураСтрокиШтрихкода.Вставить("ЭтоГруппа", Ложь);
	СтруктураСтрокиШтрихкода.Вставить("Вычислять", Истина);
	СтруктураСтрокиШтрихкода.Вставить("ВыводитьКакШтрихкод", Истина);
	СтруктураСтрокиШтрихкода.Вставить("Префикс", "");
	СтруктураСтрокиШтрихкода.Вставить("Постфикс", "");
	СтруктураСтрокиШтрихкода.Вставить("ТипШтрихкода", 99);
	СтруктураСтрокиШтрихкода.Вставить(ИмяСвойстваЗаголовок, "");
	
	ЗаголовкиПараметров = СловарьЗаголовковПредопределенныхПараметров();
	ПараметрТекст = "Текст";
	
	ИмяПараметра = "ФискальныйДокумент";
	СтруктураПараметраГруппы.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтрокаВерхнийУровень = ДобавитьПараметрВДерево(ШаблонЧека, ИмяПараметра,
		СтруктураПараметраГруппы.Заголовок, СтруктураПараметраГруппы);
	ИмяПараметра = "ПараметрыШапкиЧека";
	СтруктураПараметраГруппы.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтрокаШапка = ДобавитьПараметрВДерево(СтрокаВерхнийУровень, ИмяПараметра,
		СтруктураПараметраГруппы.Заголовок, СтруктураПараметраГруппы);
	ЗаполнитьРазделШапки(СтрокаШапка);
	
	ИмяПараметра = "СоставЧека";
	СтруктураПараметраГруппы.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтрокаСоставЧека = ДобавитьПараметрВДерево(СтрокаВерхнийУровень, ИмяПараметра,
		СтруктураПараметраГруппы.Заголовок, СтруктураПараметраГруппы);
	ИмяПараметра = "ДисконтнаяКарта";
	СтруктураВычисляемойСтроки.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураВычисляемойСтроки.Префикс = СтрШаблон("%1 ", НСтр("ru = 'Карта:'"));
	СтрокаКарты = ДобавитьПараметрВДерево(СтрокаСоставЧека, ПараметрТекст, ИмяПараметра,
		СтруктураВычисляемойСтроки);
	ИмяПараметра = "ТаблицаТовары";
	СтруктураТаблицы.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтрокаПозицииЧека = ДобавитьПараметрВДерево(СтрокаСоставЧека, ИмяПараметра,
		СтруктураТаблицы.Заголовок, СтруктураТаблицы);
	
	КоличествоСимволов = ?(ШиринаЧека < 5, ШиринаЧека, ШиринаЧека - 3);
	ТекстРазделителя = "";
	
	Для Счетчик = 1 По КоличествоСимволов Цикл
		ТекстРазделителя = ТекстРазделителя + "-";
	КонецЦикла;
	
	СтруктураНеВычисляемойСтроки.Заголовок = ТекстРазделителя;
	СтрокаРазделительСтроки = ДобавитьПараметрВДерево(СтрокаПозицииЧека, ПараметрТекст, ТекстРазделителя,
		СтруктураНеВычисляемойСтроки);
	
	ИмяПараметра = "НомерСтрокиТовара";
	СтруктураВычисляемойСтроки.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураВычисляемойСтроки.Префикс = СтрШаблон("%1 ", НСтр("ru = 'Строка №:'"));
	СтруктураВычисляемойСтроки.Постфикс = "";
	СтрокаНомерСтроки = ДобавитьПараметрВДерево(СтрокаПозицииЧека, ПараметрТекст, ИмяПараметра,
		СтруктураВычисляемойСтроки);
	
	ИмяПараметра = "ФискальныйРаздел";
	СтруктураСоставнойСтроки.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтрокаФискальная = ДобавитьПараметрВДерево(СтрокаПозицииЧека, ИмяПараметра,
		СтруктураСоставнойСтроки.Заголовок, СтруктураСоставнойСтроки);
	ЗаполнитьПоляФискальногоРаздела(СтрокаФискальная);
	
	ИмяПараметра = "СуммаСкидки";
	СтруктураВычисляемойСтроки.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураВычисляемойСтроки.Префикс = НСтр("ru = 'Сумма скидки по строке:'") + " ";
	СтруктураВычисляемойСтроки.Постфикс = "";
	СтрокаСкидки = ДобавитьПараметрВДерево(СтрокаПозицииЧека, ПараметрТекст, ИмяПараметра,
		СтруктураВычисляемойСтроки);
		
	ИмяПараметра = "СуммаБезСкидки";
	СтруктураВычисляемойСтроки.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураВычисляемойСтроки.Префикс = НСтр("ru = 'Сумма без скидки по строке:'") + " ";
	СтруктураВычисляемойСтроки.Постфикс = "";
	СтрокаСуммаБезСкидки = ДобавитьПараметрВДерево(СтрокаПозицииЧека, ПараметрТекст, ИмяПараметра,
		СтруктураВычисляемойСтроки);
		
	ИмяПараметра = "Штрихкод";
	СтруктураСтрокиШтрихкода.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтрокаШтрихкода = ДобавитьПараметрВДерево(СтрокаПозицииЧека, ПараметрТекст, ИмяПараметра,
		СтруктураСтрокиШтрихкода);
	
	ШаблонПостфиксаКодаВозврата = НСтр("ru = '%1%2Сохраните чек для возврата%2'");
	
	ИмяПараметра = "КодВозвратаСБП";
	СтруктураСтрокиШтрихкода.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураСтрокиШтрихкода.ТипШтрихкода = 16;
	ТекстТипаПлатежнойСистемыККТ = Символы.ПС
		+ Строка(ПредопределенноеЗначение("Перечисление.ТипыПлатежнойСистемыККТ.СистемаБыстрыхПлатежей"));
	ПостфиксКодаВозврата = СтрШаблон(ШаблонПостфиксаКодаВозврата, ТекстТипаПлатежнойСистемыККТ, Символы.ПС);
	СтруктураСтрокиШтрихкода.Постфикс = ПостфиксКодаВозврата;
	СтрокаКодаВозвратаСБП = ДобавитьПараметрВДерево(СтрокаСоставЧека, ПараметрТекст, ИмяПараметра,
		СтруктураСтрокиШтрихкода);
	
	ИмяПараметра = "КодВозвратаНСПК";
	СтруктураСтрокиШтрихкода.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураСтрокиШтрихкода.ТипШтрихкода = 16;
	ТекстТипаПлатежнойСистемыККТ = Символы.ПС
		+ Строка(ПредопределенноеЗначение("Перечисление.ТипыПлатежнойСистемыККТ.СертификатНСПК"));
	ПостфиксКодаВозврата = СтрШаблон(ШаблонПостфиксаКодаВозврата, ТекстТипаПлатежнойСистемыККТ, Символы.ПС);
	СтруктураСтрокиШтрихкода.Постфикс = ПостфиксКодаВозврата;
	СтрокаКодаВозвратаНСПК = ДобавитьПараметрВДерево(СтрокаСоставЧека, ПараметрТекст, ИмяПараметра,
		СтруктураСтрокиШтрихкода);
	
	ИмяПараметра = "ТаблицаОплат";
	СтруктураПараметраГруппы.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтрокаОплаты = ДобавитьПараметрВДерево(СтрокаВерхнийУровень, ИмяПараметра,
		СтруктураПараметраГруппы.Заголовок, СтруктураПараметраГруппы);
	ЗаполнитьРазделОплат(СтрокаОплаты);
	
	ОбщегоНазначенияРМКПереопределяемый.ДобавитьПараметрыВШаблонЧека(ШаблонЧека);
	
	СформироватьМакетФискальногоЧека();
	
КонецПроцедуры

&НаСервере
Функция ЭкспортироватьШаблонВФайлСервер()
	
	АдресФайла = "";
	ШаблонЧекаОбъект = РеквизитФормыВЗначение("ШаблонЧека", Тип("ДеревоЗначений"));
	УсловияШаблонаЧека = РеквизитФормыВЗначение("ТаблицаУсловий", Тип("ТаблицаЗначений"));
	ДанныеШаблонаЧека = Новый Структура;
	ДанныеШаблонаЧека.Вставить("Шаблон", ШаблонЧекаОбъект);
	ДанныеШаблонаЧека.Вставить("Условия", УсловияШаблонаЧека);
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xml");
	СохранениеВыполнено = ЗначениеВФайл(ИмяВременногоФайла, ДанныеШаблонаЧека);
	
	Если СохранениеВыполнено Тогда
		
		ДвоичныеДанные = Новый ДвоичныеДанные(ИмяВременногоФайла);
		АдресФайла = ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор);
		УдалитьФайлы(ИмяВременногоФайла);
		
	КонецЕсли;
	
	Возврат АдресФайла;
	
КонецФункции

&НаСервере
Процедура ИмпортироватьШаблонИзФайлаСервер(АдресФайла)
	
	Попытка
		
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайла);
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xml");
		ДвоичныеДанные.Записать(ИмяВременногоФайла);
		ДанныеШаблонаЧека = ЗначениеИзФайла(ИмяВременногоФайла);
		
		УдалитьФайлы(ИмяВременногоФайла);
		
		Если ТипЗнч(ДанныеШаблонаЧека) = Тип("Структура") Тогда
			ШаблонЧекаОбъект = ДанныеШаблонаЧека.Шаблон.Скопировать();
			УсловияШаблонаЧека = ДанныеШаблонаЧека.Условия.Скопировать();
		Иначе
			ШаблонЧекаОбъект = ДанныеШаблонаЧека.Скопировать();
			УсловияШаблонаЧека = Новый ТаблицаЗначений;
		КонецЕсли;
		
		КолонкиОбъекта = ШаблонЧекаОбъект.Колонки;
		ШаблонСФормы = РеквизитФормыВЗначение("ШаблонЧека");
		КолонкиШаблона = ШаблонСФормы.Колонки;
		ДополнитьКолонкиОбъектаКолонкамиШаблона(КолонкиОбъекта, КолонкиШаблона);
		
		ЗаполнитьЗаголовкиПараметров(ШаблонЧекаОбъект);
		ЗначениеВРеквизитФормы(ШаблонЧекаОбъект, "ШаблонЧека");
		
		КолонкиОбъекта = УсловияШаблонаЧека.Колонки;
		УсловияСФормы = РеквизитФормыВЗначение("ТаблицаУсловий");
		КолонкиШаблона = УсловияСФормы.Колонки;
		ДополнитьКолонкиОбъектаКолонкамиШаблона(КолонкиОбъекта, КолонкиШаблона);
		ЗначениеВРеквизитФормы(УсловияШаблонаЧека, "ТаблицаУсловий");
		
		СформироватьМакетФискальногоЧека();
		
	Исключение
		
		ТекстОшибки = НСтр("ru = 'Ошибка загрузки шаблона по причине:'") + Символы.ПС 
			+ ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Функция ДобавитьПолеВШаблон(ИмяПараметра, ПредставлениеПараметра, СтруктураПараметра)
	
	ТекстСообщения = "";
	ИдентификаторСтроки = Неопределено;
	МожноДобавлять = Истина;
	Результат = Неопределено;
	ИмяПараметраТаблица = "Таблица";
	ИмяСвойстваЗаголовок = "Заголовок";
	Если ИмяПараметра <> "НефискальныйДокумент"
		И ИмяПараметра <> "Отрезка" Тогда
		
		ТекущаяСтрокаДерева = Элементы.ШаблонЧека.ТекущиеДанные;
		
		Если ТекущаяСтрокаДерева = Неопределено Тогда
			
			ТекстСообщения = ТекстСообщения + НСтр("ru = 'Добавлять строки в корневой раздел нельзя.'");
			МожноДобавлять = Ложь;
			
		Иначе
			
			Если НЕ ТекущаяСтрокаДерева.ЭтоГруппа Тогда
				
				Родитель = ТекущаяСтрокаДерева.ПолучитьРодителя();
				
				Если Родитель = Неопределено Тогда
					
					ТекстСообщения = ТекстСообщения + НСтр("ru = 'Добавлять строки в корневой раздел нельзя.'");
					МожноДобавлять = Ложь;
					
				Иначе
					ТекущаяСтрокаДерева = Родитель;
				КонецЕсли;
				
			КонецЕсли;
			
			Если ТекущаяСтрокаДерева <> Неопределено Тогда
				
				Если ТекущаяСтрокаДерева.ИмяКолонки = "НефискальныйДокумент"
					ИЛИ ТекущаяСтрокаДерева.ИмяКолонки = "ФискальныйДокумент"
					ИЛИ ТекущаяСтрокаДерева.ИмяКолонки = "ПараметрыШапкиЧека"
					ИЛИ ТекущаяСтрокаДерева.ИмяКолонки = "ТаблицаОплат"
					ИЛИ ТекущаяСтрокаДерева.ИмяКолонки = "Отрезка"
					ИЛИ ТекущаяСтрокаДерева.ИмяКолонки = "ФискальныйРаздел" Тогда
					
						ТекстСообщения = СтрШаблон("%1%2", ТекстСообщения,
							НСтр("ru = 'Раздел ""%1"" закрыт для редактирования. Добавлять строки в него нельзя.'"));
						ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения,
							ТекущаяСтрокаДерева.Элемент);
						МожноДобавлять = Ложь;
						
				ИначеЕсли ИмяПараметра = ИмяПараметраТаблица И ТекущаяСтрокаДерева.ИмяКолонки <> "СоставЧека" Тогда

					ТекстСообщения = СтрШаблон("%1%2", ТекстСообщения,
						НСтр("ru = 'Таблицу можно добавлять только в состав чека.'"));
					ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения,
						ТекущаяСтрокаДерева.Элемент);
					МожноДобавлять = Ложь;
					
				ИначеЕсли ИмяПараметра = "СоставнаяСтрока"
					И ТекущаяСтрокаДерева.ИмяКолонки <> "СоставЧека"
					И ТекущаяСтрокаДерева.ИмяКолонки <> ИмяПараметраТаблица
					И ТекущаяСтрокаДерева.ИмяКолонки <> "ТаблицаТовары"Тогда
					
						ТекстСообщения = СтрШаблон("%1%2", ТекстСообщения,
							НСтр("ru = 'Составную строку можно добавлять только в состав чека или в таблицу.'"));
						ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения,
							ТекущаяСтрокаДерева.Элемент);
						МожноДобавлять = Ложь;
						
					КонецЕсли;
					
				ИдентификаторСтроки = ТекущаяСтрокаДерева.ПолучитьИдентификатор();
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если МожноДобавлять Тогда
		
		Результат = ДобавитьПолеВШаблонСервер(ИдентификаторСтроки, ИмяПараметра, ПредставлениеПараметра, СтруктураПараметра);
		Если ИмяПараметра = "НефискальныйДокумент" Тогда
			
			ЗаголовкиПараметров = СловарьЗаголовковПредопределенныхПараметров();
			
			ПараметрСоставЧека = "СоставЧека";
			ЗаголовокПараметраСоставЧека = ЗаголовкиПараметров.Получить(ПараметрСоставЧека);
			СтруктураПараметра.Вставить(ИмяСвойстваЗаголовок, ЗаголовокПараметраСоставЧека);
			Результат = ДобавитьПолеВШаблонСервер(Результат, ПараметрСоставЧека,
				ЗаголовокПараметраСоставЧека, СтруктураПараметра);
				
			Если ИспользоватьПромокоды Тогда
				ПараметрПромокоды = "Промокоды";
				ЗаголовокПараметраПромокоды = ЗаголовкиПараметров.Получить(ПараметрПромокоды);
				СтруктураПараметра.Вставить(ИмяСвойстваЗаголовок, ЗаголовокПараметраПромокоды);
				РезультатПромокоды = ДобавитьПолеВШаблонСервер(Результат,
					ПараметрПромокоды, ЗаголовокПараметраПромокоды, СтруктураПараметра);
				СтруктураТаблицыПромокодов = Новый Структура;
				СтруктураТаблицыПромокодов.Вставить("ИндексКартинки", 10);
				СтруктураТаблицыПромокодов.Вставить("ЭтоГруппа", Истина); 
				СтруктураТаблицыПромокодов.Вставить(ИмяСвойстваЗаголовок, ЗаголовокПараметраПромокоды);
				РезультатПромокодыКВыдаче = ДобавитьПолеВШаблонСервер(РезультатПромокоды,
					ИмяПараметраТаблица, "ПромокодыКВыдаче", СтруктураТаблицыПромокодов);
				ПараметрПоляПромокод = "ПромокодЗначениеПромокода";
				ЗаголовокПоляПромокод = ЗаголовкиПараметров.Получить(ПараметрПоляПромокод);
				СтруктураПоляПромокод = Новый Структура;
				СтруктураПоляПромокод.Вставить("ИндексКартинки", 4);
				СтруктураПоляПромокод.Вставить("ЭтоГруппа", Ложь);
				СтруктураПоляПромокод.Вставить("Вычислять", Истина);
				СтруктураПоляПромокод.Вставить("ВыводитьКакШтрихкод", Истина);
				СтруктураПоляПромокод.Вставить("ТипШтрихкода", 16);
				СтруктураПоляПромокод.Вставить(ИмяСвойстваЗаголовок, ЗаголовокПоляПромокод);
				РезультатПромокод = ДобавитьПолеВШаблонСервер(РезультатПромокодыКВыдаче,
					"Текст", ПараметрПоляПромокод, СтруктураПоляПромокод);
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецЕсли;
	
	Если Результат <> Неопределено Тогда
		Элементы.ШаблонЧека.ТекущаяСтрока = Результат;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ДобавитьПолеВШаблонСервер(Знач ИдентификаторСтроки, Знач ИмяПараметра, Знач ПредставлениеПараметра, Знач СтруктураПараметра)
	
	Если ИдентификаторСтроки = Неопределено Тогда
		Родитель = ШаблонЧека;
	Иначе
		Родитель = ШаблонЧека.НайтиПоИдентификатору(ИдентификаторСтроки);
	КонецЕсли;
	СтрокаПараметр = ДобавитьПараметрВДерево(Родитель, ИмяПараметра, ПредставлениеПараметра, СтруктураПараметра);
	ИдентификаторРезультат = СтрокаПараметр.ПолучитьИдентификатор(); 
	
	СформироватьМакетФискальногоЧека();
	
	Возврат ИдентификаторРезультат;
	
КонецФункции

&НаСервере
Функция ДобавитьПараметрВДерево(Родитель, ИмяПараметра, ПредставлениеПараметра, СтруктураПараметра)
	
	ЭлементыДерева = Родитель.ПолучитьЭлементы();
	СтрокаПараметр = ЭлементыДерева.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаПараметр, СтруктураПараметра);
	
	СтрокаПараметр.ИмяКолонки = ИмяПараметра;
	СтрокаПараметр.Элемент = ПредставлениеПараметра;
	СтрокаПараметр.ИмяОбъекта = "ЧекККМ";
	СтрокаПараметр.ИмяМакета = "ПоляШаблона";
	
	Возврат СтрокаПараметр;
	
КонецФункции

&НаСервере
Процедура ОчиститьШаблонСервер()
	
	ШаблонДерево = РеквизитФормыВЗначение("ШаблонЧека");
	ШаблонДерево.Строки.Очистить();
	ЗначениеВРеквизитФормы(ШаблонДерево, "ШаблонЧека");
	СформироватьМакетФискальногоЧека();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРазделШапки(СтрокаШапка)
	
	СтруктураПредопределенногоПоля = Новый Структура;
	СтруктураПредопределенногоПоля.Вставить("ИндексКартинки", 6);
	СтруктураПредопределенногоПоля.Вставить("ЭтоГруппа", Ложь);
	СтруктураПредопределенногоПоля.Вставить("Вычислять", Истина);
	СтруктураПредопределенногоПоля.Вставить("Заголовок", "");
	
	ЗаголовкиПараметров = СловарьЗаголовковПредопределенныхПараметров();
	
	ПараметрыРазделаШапки = Новый Массив;
	ПараметрыРазделаШапки.Добавить("ТипРасчета");
	ПараметрыРазделаШапки.Добавить("КодСистемыНалогообложения");
	ПараметрыРазделаШапки.Добавить("ОтправительEmail");
	ПараметрыРазделаШапки.Добавить("ПокупательEmail");
	ПараметрыРазделаШапки.Добавить("ПокупательНомер");
	ПараметрыРазделаШапки.Добавить("ТелефонПлатежногоАгента");
	ПараметрыРазделаШапки.Добавить("ТелефонОператораПоПриемуПлатежей");
	ПараметрыРазделаШапки.Добавить("ТелефонОператораПеревода");
	ПараметрыРазделаШапки.Добавить("ТелефонПоставщика");
	ПараметрыРазделаШапки.Добавить("АдресОператораПеревода");
	ПараметрыРазделаШапки.Добавить("ИННОператораПеревода");
	ПараметрыРазделаШапки.Добавить("НаименованиеОператораПеревода");
	ПараметрыРазделаШапки.Добавить("ТелефонБанковскогоАгента");
	ПараметрыРазделаШапки.Добавить("ТелефонБанковскогоСубагента");
	ПараметрыРазделаШапки.Добавить("ОперацияПлатежногоАгента");
	ПараметрыРазделаШапки.Добавить("ОперацияБанковскогоАгента");
	ПараметрыРазделаШапки.Добавить("ОперацияБанковскогоСубагента");
	
	Для каждого ИмяПараметра Из ПараметрыРазделаШапки Цикл
		
		СтруктураПредопределенногоПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
		ДобавитьПараметрВДерево(СтрокаШапка, ИмяПараметра, СтруктураПредопределенногоПоля.Заголовок,
		СтруктураПредопределенногоПоля);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоляФискальногоРаздела(СтрокаФискальная)
	
	СтруктураФискальногоПоля = Новый Структура;
	СтруктураФискальногоПоля.Вставить("ИндексКартинки", 6);
	СтруктураФискальногоПоля.Вставить("ЭтоГруппа", Ложь);
	СтруктураФискальногоПоля.Вставить("Вычислять", Истина);
	СтруктураФискальногоПоля.Вставить("Префикс", "");
	СтруктураФискальногоПоля.Вставить("Постфикс", Символ(182));
	СтруктураФискальногоПоля.Вставить("Заголовок", "");
	
	ЗаголовкиПараметров = СловарьЗаголовковПредопределенныхПараметров();
	
	ИмяПараметра = "Наименование";
	СтруктураФискальногоПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	ДобавитьПараметрВДерево(СтрокаФискальная, ИмяПараметра, ИмяПараметра, СтруктураФискальногоПоля);
	
	ИмяПараметра = "Количество";
	СтруктураФискальногоПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураФискальногоПоля.Префикс = "";
	СтруктураФискальногоПоля.Постфикс = СтрШаблон(" %1 ", НСтр("ru = 'х'"));
	ДобавитьПараметрВДерево(СтрокаФискальная, ИмяПараметра, ИмяПараметра, СтруктураФискальногоПоля);
	
	ИмяПараметра = "ЦенаСоСкидками";
	СтруктураФискальногоПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураФискальногоПоля.Префикс = "";
	СтруктураФискальногоПоля.Постфикс = СтрШаблон(" %1 ", НСтр("ru = '='"));
	ДобавитьПараметрВДерево(СтрокаФискальная, ИмяПараметра, ИмяПараметра, СтруктураФискальногоПоля);
	
	ИмяПараметра = "Сумма";
	СтруктураФискальногоПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураФискальногоПоля.Префикс = "";
	СтруктураФискальногоПоля.Постфикс = Символ(182);
	ДобавитьПараметрВДерево(СтрокаФискальная, ИмяПараметра, ИмяПараметра, СтруктураФискальногоПоля);
	
	ИмяПараметра = "СуммаСкидок";
	СтруктураФискальногоПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураФискальногоПоля.Префикс = СтрШаблон("%1 ", НСтр("ru = 'В т.ч. скидка:'"));
	СтруктураФискальногоПоля.Постфикс = Символ(182);
	ДобавитьПараметрВДерево(СтрокаФискальная, ИмяПараметра, ИмяПараметра, СтруктураФискальногоПоля);
	
	ИмяПараметра = "СтавкаНДС";
	СтруктураФискальногоПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
	СтруктураФискальногоПоля.Префикс = СтрШаблон("%1 ", НСтр("ru = 'Ставка НДС:'"));
	СтруктураФискальногоПоля.Постфикс = "%";
	ДобавитьПараметрВДерево(СтрокаФискальная, ИмяПараметра, ИмяПараметра, СтруктураФискальногоПоля);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРазделОплат(СтрокаОплаты)
	
	СтруктураПоля = Новый Структура;
	СтруктураПоля.Вставить("ИндексКартинки", 6);
	СтруктураПоля.Вставить("ЭтоГруппа", Ложь);
	СтруктураПоля.Вставить("Вычислять", Истина);
	СтруктураПоля.Вставить("Заголовок", "");
	
	ЗаголовкиПараметров = СловарьЗаголовковПредопределенныхПараметров();
	
	ПараметрыРазделаОплат = Новый Массив;
	ПараметрыРазделаОплат.Добавить("Наличные");
	ПараметрыРазделаОплат.Добавить("Электронный1");
	ПараметрыРазделаОплат.Добавить("Электронный2");
	ПараметрыРазделаОплат.Добавить("Электронный3");
	ПараметрыРазделаОплат.Добавить("Электронный4");
	
	Для каждого ИмяПараметра Из ПараметрыРазделаОплат Цикл
		
		СтруктураПоля.Заголовок = ЗаголовкиПараметров.Получить(ИмяПараметра);
		ДобавитьПараметрВДерево(СтрокаОплаты, ИмяПараметра, СтруктураПоля.Заголовок, СтруктураПоля);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ОбойтиПредопределенныеРазделы(Знач Команда)
	
	Результат = Истина;
	ПозицияФискальногоДокумента = 0;
	ЕстьШапка = Ложь;
	ЕстьОплата = Ложь;
	ЕстьТовары = Ложь;
	ЕстьФискальныйРаздел = Ложь;
	
	ЭлементыВерхнегоУровня = ШаблонЧека.ПолучитьЭлементы();
	
	СчетчикСтрок = 0;
	Для Каждого СтрокаВерхнийУровень Из ЭлементыВерхнегоУровня Цикл
		
		СчетчикСтрок = СчетчикСтрок + 1;
		
		Если СтрокаВерхнийУровень.ИмяКолонки = "ФискальныйДокумент" Тогда
			
			ПозицияФискальногоДокумента = СчетчикСтрок;
			ЭлементыФискальногоЧека = СтрокаВерхнийУровень.ПолучитьЭлементы();
			
			Для Каждого СтрокаЧека Из ЭлементыФискальногоЧека Цикл
				
				Если СтрокаЧека.ИмяКолонки = "ПараметрыШапкиЧека" Тогда
					
					ЕстьШапка = Истина;
					
					Если Команда = "Перезаполнить" Тогда
						
						ЭлементыШапки = СтрокаЧека.ПолучитьЭлементы();
						ЭлементыШапки.Очистить();
						ЗаполнитьРазделШапки(СтрокаЧека);
						
					КонецЕсли;
					
				ИначеЕсли СтрокаЧека.ИмяКолонки = "СоставЧека" Тогда
					
					ЭлементыСостава = СтрокаЧека.ПолучитьЭлементы();
					
					Для Каждого СтрокаСостава Из ЭлементыСостава Цикл
						
						Если СтрокаСостава.ИмяКолонки = "ТаблицаТовары" Тогда
							
							ЕстьТовары = Истина;
							ЭлементыТоваров = СтрокаСостава.ПолучитьЭлементы();
							
							Для Каждого СтрокаТовара Из ЭлементыТоваров Цикл
								
								Если СтрокаТовара.ИмяКолонки = "ФискальныйРаздел" Тогда
									
									ЕстьФискальныйРаздел = Истина;
									
									Если Команда = "Перезаполнить" Тогда
										ЭлементыФискальные = СтрокаТовара.ПолучитьЭлементы();
										ЭлементыФискальные.Очистить();
										ЗаполнитьПоляФискальногоРаздела(СтрокаТовара);
									КонецЕсли;
									
								КонецЕсли;
								
							КонецЦикла;
							
						КонецЕсли;
						
					КонецЦикла;
					
				ИначеЕсли СтрокаЧека.ИмяКолонки = "ТаблицаОплат" Тогда
					
					ЕстьОплата = Истина;
					
					Если Команда = "Перезаполнить" Тогда
						
						ЭлементыОплаты = СтрокаЧека.ПолучитьЭлементы();
						ЭлементыОплаты.Очистить();
						ЗаполнитьРазделОплат(СтрокаЧека);
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если Команда = "ПроверитьКорректность" Тогда
		
		Если ПозицияФискальногоДокумента = 0 Тогда
			
			ОбщегоНазначения.СообщитьПользователю(
				НСтр("ru = 'Отсутствует обязательный раздел ""Фискальный документ""'"),
				,
				"ШаблонЧека");
			Результат = Ложь;
			
		ИначеЕсли ПозицияФискальногоДокумента > 1 Тогда
			
			ОбщегоНазначения.СообщитьПользователю(
				НСтр("ru = 'Фискальный документ должен быть первым в шаблоне'"),
				,
				"ШаблонЧека");
			Результат = Ложь;
			
		Иначе
			
			Если НЕ ЕстьШапка Тогда
				
				ОбщегоНазначения.СообщитьПользователю(
					НСтр("ru = 'Отсутствует обязательный раздел ""Шапка"" в фискальном документе'"),
					,
					"ШаблонЧека");
				Результат = Ложь;
				
			КонецЕсли;
			
			Если ЕстьТовары Тогда
				
				Если НЕ ЕстьФискальныйРаздел Тогда
					
					ОбщегоНазначения.СообщитьПользователю(
						НСтр("ru = 'Отсутствует ""Фискальный раздел"" в таблице товаров'"),
						,
						"ШаблонЧека");
					Результат = Ложь;
					
				КонецЕсли;
				
			Иначе
				
				ОбщегоНазначения.СообщитьПользователю(
					НСтр("ru = 'Отсутствует обязательный раздел ""Товары"" в фискальном документе'"),
					,
					"ШаблонЧека");
				Результат = Ложь;
				
			КонецЕсли;
			
			Если НЕ ЕстьОплата Тогда
				
				ОбщегоНазначения.СообщитьПользователю(
					НСтр("ru = 'Отсутствует обязательный раздел ""Оплата"" в фискальном документе'"),
					,
					"ШаблонЧека");
				Результат = Ложь;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	// Очистка от лишних условий, которые могли остаться после удаления строки чека
	ИмяКолонкиИдентификатор = "Идентификатор";
	ТаблицаИдентификаторов = ТаблицаУсловий.Выгрузить(,ИмяКолонкиИдентификатор);
	ТаблицаИдентификаторов.Свернуть(ИмяКолонкиИдентификатор);
	ИдентификаторыУсловий = ТаблицаИдентификаторов.ВыгрузитьКолонку(ИмяКолонкиИдентификатор);
	Для Каждого СуществующийИдентификатор Из ПолучитьИдентификаторыЭлементов(ШаблонЧека) Цикл
		ИндексИдентификатора = ИдентификаторыУсловий.Найти(СуществующийИдентификатор);
		Если Не ИндексИдентификатора = Неопределено Тогда
			ИдентификаторыУсловий.Удалить(ИндексИдентификатора);
		КонецЕсли;
	КонецЦикла;
	// Идентификаторы, которые остались - не используются. Удалим лишние условия.
	УдалитьСтрокиУсловийПоИдентификатору(ИдентификаторыУсловий);
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьИдентификаторыЭлементов(СтрокаДерева)
	
	Результат = Новый Массив;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаДерева, "Идентификатор") Тогда
		Если ЗначениеЗаполнено(СтрокаДерева.Идентификатор) Тогда
			Результат.Добавить(Число(СтрокаДерева.Идентификатор));
		КонецЕсли;
	КонецЕсли;
	
	Строки = СтрокаДерева.ПолучитьЭлементы();
	Для Каждого ПодчиненнаяСтрока Из Строки Цикл
		ИдентификаторыПодчиненнойСтроки = ПолучитьИдентификаторыЭлементов(ПодчиненнаяСтрока);
		Для Каждого ИдентификаторПодчиненнойСтроки Из ИдентификаторыПодчиненнойСтроки Цикл
			Результат.Добавить(ИдентификаторПодчиненнойСтроки);
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура УдалитьСтрокиУсловийПоИдентификатору(Идентификаторы)
	
	ИдентификаторыУсловий = Новый Массив();
	Если ТипЗнч(Идентификаторы) = Тип("Массив") Тогда
		ИдентификаторыУсловий = Идентификаторы;
	ИначеЕсли ТипЗнч(Идентификаторы) = Тип("Строка") Тогда
		ИдентификаторыУсловий = СтрРазделить(Идентификаторы, ",");
	Иначе
		ИдентификаторыУсловий.Добавить(Идентификаторы);
	КонецЕсли;
	Для Каждого ИдентификаторУдалить Из ИдентификаторыУсловий Цикл
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Идентификатор", Число(ИдентификаторУдалить));
		СтрокиУдалить = ТаблицаУсловий.НайтиСтроки(ПараметрыОтбора);
		Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
			ТаблицаУсловий.Удалить(СтрокаУдалить);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтрокиУсловийПоИдентификаторуКлиент(Идентификаторы)
	
	ИдентификаторыУсловий = Новый Массив();
	Если ТипЗнч(Идентификаторы) = Тип("Массив") Тогда
		ИдентификаторыУсловий = Идентификаторы;
	ИначеЕсли ТипЗнч(Идентификаторы) = Тип("Строка") Тогда
		ИдентификаторыУсловий = СтрРазделить(Идентификаторы, ",");
	Иначе
		ИдентификаторыУсловий.Добавить(Идентификаторы);
	КонецЕсли;
	Для Каждого ИдентификаторУдалить Из ИдентификаторыУсловий Цикл
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Идентификатор", Число(ИдентификаторУдалить));
		СтрокиУдалить = ТаблицаУсловий.НайтиСтроки(ПараметрыОтбора);
		Для Каждого СтрокаУдалить Из СтрокиУдалить Цикл
			ТаблицаУсловий.Удалить(СтрокаУдалить);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

