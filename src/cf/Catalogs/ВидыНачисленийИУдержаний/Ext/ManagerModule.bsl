Процедура УстановитьИспользованиеПоОписанию(Описания, ИмяРодителя, Использовать)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыНачисленийИУдержаний.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыНачисленийИУдержаний КАК ВидыНачисленийИУдержаний
	|ГДЕ
	|	ВидыНачисленийИУдержаний.ЭтоГруппа
	|	И ВидыНачисленийИУдержаний.Наименование = &Наименование
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВидыНачисленийИУдержаний.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Наименование", ИмяРодителя);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Родитель = Выборка.Ссылка;
	Иначе
		Родитель = ПустаяСсылка();
	КонецЕсли;
	
	СписокНачислений = Новый Соответствие;
	КлючиНаименованиеФормула = Новый Массив;
	
	ПутьКСправочнику = Метаданные.Справочники.ВидыНачисленийИУдержаний.ПолноеИмя();
	Для Каждого РеквизитыНачисления Из Описания Цикл
		ДанныеДляОбновления = Новый Структура("Ссылка, Предопределенный, Реквизиты", Неопределено, Ложь, РеквизитыНачисления);
		Если ЗначениеЗаполнено(РеквизитыНачисления.ИмяПредопределенныхДанных) Тогда
			ПутьКЭлементу = СтрШаблон("%1.%2", ПутьКСправочнику, РеквизитыНачисления.ИмяПредопределенныхДанных);
			ДанныеДляОбновления.Ссылка = ОбщегоНазначения.ПредопределенныйЭлемент(ПутьКЭлементу);
			ДанныеДляОбновления.Предопределенный = Истина;
			СписокНачислений.Вставить(РеквизитыНачисления.ИмяПредопределенныхДанных, ДанныеДляОбновления);
		Иначе
			КлючПоиска = СтрШаблон("%1_%2", РеквизитыНачисления.Наименование, Лев(РеквизитыНачисления.Формула, 200));
			СписокНачислений.Вставить(КлючПоиска, ДанныеДляОбновления);
			КлючиНаименованиеФормула.Добавить(КлючПоиска);
		КонецЕсли;
	КонецЦикла;
	
	Если КлючиНаименованиеФормула.Количество() > 0 Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ВидыНачисленийИУдержаний.Ссылка КАК Ссылка,
		               |	ВидыНачисленийИУдержаний.Наименование + ""_"" + (ВЫРАЗИТЬ(ВидыНачисленийИУдержаний.Формула КАК СТРОКА(200))) КАК КлючПоиска
		               |ИЗ
		               |	Справочник.ВидыНачисленийИУдержаний КАК ВидыНачисленийИУдержаний
		               |ГДЕ
		               |	ВидыНачисленийИУдержаний.ИмяПредопределенныхДанных = """"
		               |	И ВидыНачисленийИУдержаний.Наименование + ""_"" + (ВЫРАЗИТЬ(ВидыНачисленийИУдержаний.Формула КАК СТРОКА(200))) В (&НаименованиеФормула)";
		Запрос.УстановитьПараметр("НаименованиеФормула", КлючиНаименованиеФормула);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ДанныеНачисления = СписокНачислений[Выборка.КлючПоиска];
			Если НЕ ЗначениеЗаполнено(ДанныеНачисления.Ссылка) Тогда
				ДанныеНачисления.Ссылка = Выборка.Ссылка;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ОбъектыДляИзменения = Новый Массив;
	Для Каждого Элемент Из СписокНачислений Цикл
		
		Данные = Элемент.Значение;
		Если ЗначениеЗаполнено(Данные.Ссылка) Тогда
			ОбъектВид = Данные.Ссылка.ПолучитьОбъект();
		ИначеЕсли Использовать Тогда
			ОбъектВид = СоздатьЭлемент();
			ЗаполнитьЗначенияСвойств(ОбъектВид, РеквизитыНачисления);
			ОбъектВид.Родитель = Родитель;
		Иначе
			Продолжить;
		КонецЕсли;
		ОбъектВид.Используется = Использовать;
		
		ОбъектыДляИзменения.Добавить(ОбъектВид);
	КонецЦикла;
	
	Для Каждого ОбъектВид Из ОбъектыДляИзменения Цикл
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ОбъектВид);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли

