// Определяет настройки начального заполнения элементов.
//
// Параметры:
//  Настройки - Структура - настройки заполнения
//   * ПриНачальномЗаполненииЭлемента - Булево - Если Истина, то для каждого элемента будет
//      вызвана процедура индивидуального заполнения ПриНачальномЗаполненииЭлемента.
Процедура ПриНастройкеНачальногоЗаполненияЭлементов(Настройки) Экспорт
	
	Настройки.ПриНачальномЗаполненииЭлемента = Истина;
	
КонецПроцедуры

// Смотри также ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов
// 
// Параметры:
//   КодыЯзыков - см. ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов.КодыЯзыков
//   Элементы   - см. ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов.Элементы
//   ТабличныеЧасти - см. ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов.ТабличныеЧасти
//
Процедура ПриНачальномЗаполненииЭлементов(КодыЯзыков, Элементы, ТабличныеЧасти) Экспорт
	
	// Виды начислений
	ГруппаНачисление = Элементы.Добавить();
	ГруппаНачисление.Наименование = ГруппаНачисленияНаименование();
	ГруппаНачисление.ЭтоГруппа = Истина;
	ГруппаНачисление.Ссылка = Справочники.ВидыНачисленийИУдержаний.ПолучитьСсылку(Новый УникальныйИдентификатор);
	
	ГруппаУдержание = Элементы.Добавить();
	ГруппаУдержание.Наименование = ГруппаУдержанияНаименование();
	ГруппаУдержание.ЭтоГруппа = Истина;
	ГруппаУдержание.Ссылка = Справочники.ВидыНачисленийИУдержаний.ПолучитьСсылку(Новый УникальныйИдентификатор);
	
	РеквизитыОклад = РеквизитыНачисленияОплатаТруда();
	
	// Оклад по дням
	Элемент = Элементы.Добавить();
	ЗаполнитьЗначенияСвойств(Элемент, РеквизитыОклад);
	Элемент.Родитель 			= ГруппаНачисление.Ссылка;
	Элемент.Наименование 		= НСтр("ru='Оклад по дням (производственный календарь)'");
	Элемент.СчетЗатрат			= ПланыСчетов.Управленческий.УправленческиеРасходы;
	Элемент.Формула				= "[ТарифнаяСтавка] * [ОтработаноДней] / [НормаДней]";
	Элемент.Используется 		= Истина;
	
	// Оклад по часам
	Элемент = Элементы.Добавить();
	ЗаполнитьЗначенияСвойств(Элемент, РеквизитыОклад);
	Элемент.Родитель 			= ГруппаНачисление.Ссылка;
	Элемент.Наименование 		= НСтр("ru='Оклад по часам (производственный календарь)'");
	Элемент.СчетЗатрат			= ПланыСчетов.Управленческий.КосвенныеЗатраты;
	Элемент.Формула 			= "[ТарифнаяСтавка] * [ОтработаноЧасов] / [НормаЧасов]";
	Элемент.Используется 		= Истина;
	
	// Оклад по дням Графики
	Элемент = Элементы.Добавить();
	ЗаполнитьЗначенияСвойств(Элемент, РеквизитыОклад);
	Элемент.Родитель 			= ГруппаНачисление.Ссылка;
	Элемент.Наименование 		= НСтр("ru='Оклад по дням (график работы сотрудника)'");
	Элемент.СчетЗатрат			= ПланыСчетов.Управленческий.УправленческиеРасходы;
	Элемент.Формула				= "[ТарифнаяСтавка] * [ОтработаноДней] / [НормаДнейГрафикСотрудника]";
	Элемент.Используется 		= Истина;
	
	// Оклад по часам Графики
	Элемент = Элементы.Добавить();
	ЗаполнитьЗначенияСвойств(Элемент, РеквизитыОклад);
	Элемент.Родитель 			= ГруппаНачисление.Ссылка;
	Элемент.Наименование 		= НСтр("ru='Оклад по часам (график работы сотрудника)'");
	Элемент.СчетЗатрат			= ПланыСчетов.Управленческий.КосвенныеЗатраты;
	Элемент.Формула 			= "[ТарифнаяСтавка] * [ОтработаноЧасов] / [НормаЧасовГрафикСотрудника]";
	Элемент.Используется 		= Истина;
	
	// Оплата по заданиям
	ОписаниеОплатаЗаданий = ОписаниеОплатаПоЗаданиям();
	Для Каждого ВидОплаты Из ОписаниеОплатаЗаданий Цикл
		Элемент = Элементы.Добавить();
		ЗаполнитьЗначенияСвойств(Элемент, ВидОплаты);
		Элемент.Родитель 			= ГруппаНачисление.Ссылка;
		Элемент.Используется 		= ПолучитьФункциональнуюОпцию("ИспользоватьЗаданияНаРаботу");
	КонецЦикла;
	
	// Процент от продаж по ответственному
	Элемент = Элементы.Добавить();
	ЗаполнитьЗначенияСвойств(Элемент, РеквизитыОклад);
	Элемент.Родитель 			= ГруппаНачисление.Ссылка;
	Элемент.Наименование 		= НСтр("ru='Процент от продаж по ответственному'");
	Элемент.СчетЗатрат			= ПланыСчетов.Управленческий.НезавершенноеПроизводство;
	Элемент.Формула 			= "[СуммуПродажПоОтветственному]  / 100 *  [ТарифнаяСтавка]";
	Элемент.Используется 		= Истина;
	
	ОписаниеСдельнаяОплата = ОписаниеНачисленийСдельнаяОплата();
	Для Каждого ВидОплаты Из ОписаниеСдельнаяОплата Цикл
		Элемент = Элементы.Добавить();
		ЗаполнитьЗначенияСвойств(Элемент, ВидОплаты);
		Элемент.Родитель 		= ГруппаНачисление.Ссылка;
		Элемент.Используется 	= ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуРаботы")
									ИЛИ ПолучитьФункциональнуюОпцию("ИспользоватьТехоперации");
	КонецЦикла;
	
	ОписанияОплатаРабот = ОписаниеНачисленийОплатаРабот();
	Для Каждого ВидОплаты Из ОписанияОплатаРабот Цикл
		Элемент = Элементы.Добавить();
		ЗаполнитьЗначенияСвойств(Элемент, ВидОплаты);
		Элемент.Родитель 		= ГруппаНачисление.Ссылка;
		Элемент.Используется 	= ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуРаботы");
	КонецЦикла;
	
	// Отпускные
	Элемент = Элементы.Добавить();
	Элемент.Родитель 			= ГруппаНачисление.Ссылка;
	Элемент.Наименование 		= НСтр("ru='Отпускные'");
	Элемент.Тип 				= Перечисления.ТипыНачисленийИУдержаний.Начисление;
	Элемент.СчетЗатрат			= ПланыСчетов.Управленческий.УправленческиеРасходы;
	Элемент.Формула				= "";
	Элемент.КодДоходаНДФЛ 		= Справочники.КодыДоходовНДФЛ.Код2012;
	Элемент.Используется		= Истина;
	Элемент.ВидДоходаПоСтраховымВзносам = Справочники.ВидыДоходовПоСтраховымВзносамУНФ.ОблагаетсяЦеликом;
	
	// Премия продавцам
	Элемент = Элементы.Добавить();
	Элемент.ИмяПредопределенныхДанных = "ПремияЗаПродажи";
	Элемент.Родитель 			= ГруппаНачисление.Ссылка;
	Элемент.Наименование 		= НСтр("ru = 'Премия продавцам за продажи'");
	Элемент.Тип 				= Перечисления.ТипыНачисленийИУдержаний.Начисление;
	Элемент.СчетЗатрат			= ПланыСчетов.Управленческий.НезавершенноеПроизводство;
	Элемент.Формула 			= "";
	Элемент.КодДоходаНДФЛ 		= Справочники.КодыДоходовНДФЛ.Код2010;
	Элемент.Используется		= Истина;
	Элемент.ВидДоходаПоСтраховымВзносам = Справочники.ВидыДоходовПоСтраховымВзносамУНФ.ОблагаетсяЦеликом;

	УдержанияЗаймы = ОписаниеУдержанийКредитыЗаймы();
	Для Каждого Удержание Из УдержанияЗаймы Цикл
		Элемент = Элементы.Добавить();
		ЗаполнитьЗначенияСвойств(Элемент, Удержание);
		Элемент.Родитель		= ГруппаУдержание.Ссылка;
		Элемент.Используется 	= ПолучитьФункциональнуюОпцию("КредитыИЗаймы");
	КонецЦикла;
	
	Налоги = ОписаниеНалоги();
	Для Каждого Налог Из Налоги Цикл
		Элемент = Элементы.Добавить();
		ЗаполнитьЗначенияСвойств(Элемент, Налог);
		Элемент.Родитель 		= ГруппаУдержание.Ссылка;
		Элемент.Используется 	= ПолучитьФункциональнуюОпцию("ВестиУчетНалогаНаДоходыИВзносов")
			ИЛИ ПолучитьФункциональнуюОпцию("ИспользоватьРегламентированныйУчетЗарплатыИКадров");
	КонецЦикла;
	
	Взносы = ОписаниеВзносы();
	Для Каждого Взнос Из Взносы Цикл
		Элемент = Элементы.Добавить();
		ЗаполнитьЗначенияСвойств(Элемент, Взнос);
		Элемент.Родитель 		= ГруппаУдержание.Ссылка;
		Элемент.Используется 	= ПолучитьФункциональнуюОпцию("ВестиУчетНалогаНаДоходыИВзносов");
	КонецЦикла;
	
КонецПроцедуры

// Смотри также ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлемента
//
// Параметры:
//  Объект                  - СправочникОбъект.ВидыКонтактнойИнформации - заполняемый объект.
//  Данные                  - СтрокаТаблицыЗначений - данные заполнения объекта.
//  ДополнительныеПараметры - Структура:
//   * ПредопределенныеДанные - ТаблицаЗначений - данные заполненные в процедуре ПриНачальномЗаполненииЭлементов.
//
Процедура ПриНачальномЗаполненииЭлемента(Объект, Данные, ДополнительныеПараметры) Экспорт
	
	Объект.УстановитьНовыйКод();
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

// Функция возвращает список имен «ключевых» реквизитов.
// 
// Возвращаемое значение:
//   - Массив - имена реквизитов
//
Функция ПолучитьБлокируемыеРеквизитыОбъекта() Экспорт
	
	Результат = Новый Массив;
	Результат.Добавить("ВидНалога");
	Результат.Добавить("Тип");
	
	Возврат Результат;
	
КонецФункции // ПолучитьБлокируемыеРеквизитыОбъекта()

// Процедура добавляет начисления - оклад по графику работы сотрудника по дням и часам
//
Процедура ДополнитьВидыНачислений() Экспорт
		
		Группа = Справочники.ВидыНачисленийИУдержаний.НайтиПоНаименованию(ГруппаНачисленияНаименование());
		
		Если Не ЗначениеЗаполнено(Группа) ИЛИ НЕ Группа.ЭтоГруппа Тогда
			ГруппаНачисление = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка();
		Иначе
			ГруппаНачисление = Группа;
		КонецЕсли;
		
		ОкладПоДнямНаименование = НСтр("ru='Оклад по дням (график работы сотрудника)'");
		НайденныйЭлементСправочника = Справочники.ВидыНачисленийИУдержаний.НайтиПоНаименованию(ОкладПоДнямНаименование);
		
		Если Не ЗначениеЗаполнено(НайденныйЭлементСправочника) Тогда
			
			// Оклад по дням Графики
			НовоеНачисление 					= Справочники.ВидыНачисленийИУдержаний.СоздатьЭлемент();
			НовоеНачисление.Родитель 			= ГруппаНачисление;
			НовоеНачисление.Наименование 		= ОкладПоДнямНаименование;
			НовоеНачисление.Тип 				= Перечисления.ТипыНачисленийИУдержаний.Начисление;
			НовоеНачисление.СчетЗатрат			= ПланыСчетов.Управленческий.УправленческиеРасходы;
			НовоеНачисление.Формула				= "[ТарифнаяСтавка] * [ОтработаноДней] / [НормаДнейГрафикСотрудника]";
			НовоеНачисление.КодДоходаНДФЛ		= Справочники.КодыДоходовНДФЛ.Код2000;
			НовоеНачисление.ВидДоходаПоСтраховымВзносам = Справочники.ВидыДоходовПоСтраховымВзносамУНФ.ОблагаетсяЦеликом;
			НовоеНачисление.Записать();
			
		КонецЕсли;
		
		ОкладПоЧасамНаименование = НСтр("ru='Оклад по часам (график работы сотрудника)'");
		НайденныйЭлементСправочника = Справочники.ВидыНачисленийИУдержаний.НайтиПоНаименованию(ОкладПоЧасамНаименование);
		
		Если Не ЗначениеЗаполнено(НайденныйЭлементСправочника) Тогда
			
			// Оклад по часам Графики
			НовоеНачисление 					= Справочники.ВидыНачисленийИУдержаний.СоздатьЭлемент();
			НовоеНачисление.Родитель 			= ГруппаНачисление;
			НовоеНачисление.Наименование 		= ОкладПоЧасамНаименование;
			НовоеНачисление.Тип 				= Перечисления.ТипыНачисленийИУдержаний.Начисление;
			НовоеНачисление.СчетЗатрат			= ПланыСчетов.Управленческий.КосвенныеЗатраты;
			НовоеНачисление.Формула 			= "[ТарифнаяСтавка] * [ОтработаноЧасов] / [НормаЧасовГрафикСотрудника]";
			НовоеНачисление.КодДоходаНДФЛ		= Справочники.КодыДоходовНДФЛ.Код2000;
			НовоеНачисление.ВидДоходаПоСтраховымВзносам = Справочники.ВидыДоходовПоСтраховымВзносамУНФ.ОблагаетсяЦеликом;
			НовоеНачисление.Записать();
			
		КонецЕсли
		
КонецПроцедуры

// Устанавливает реквизит Используется для всех видов начислений 
//
Процедура УстановитьПризнакИспользованияПриОбновлении() Экспорт
	
	НачатьТранзакцию();
	
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ВидыНачисленийИУдержаний.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВидыНачисленийИУдержаний КАК ВидыНачисленийИУдержаний
		|ГДЕ
		|	НЕ ВидыНачисленийИУдержаний.ЭтоГруппа";
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ОбъектНачисления = Выборка.Ссылка.ПолучитьОбъект();
			ОбъектНачисления.Заблокировать();
			ОбъектНачисления.Используется = Истина;
			ОбъектНачисления.Записать();
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		СообщениеОбОшибке = НСтр("ru='Установить признак используется для видов начислений'", 
			ОбщегоНазначения.КодОсновногоЯзыка());
			
		ЗаписьЖурналаРегистрации(СообщениеОбОшибке, УровеньЖурналаРегистрации.Ошибка, , , 
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
КонецПроцедуры

// Включение / отключение использования начислений, которые используются для оплаты работ (заказ-наряд):
// СдельнаяОплата, СдельнаяОплатаПроцент, ФиксированнаяСумма
//
// Параметры:
//  Использование	 - Булево	- новое значение реквизита Используется
//
Процедура УстановитьИспользованиеОплатРабот(Использование) Экспорт
	
	// Сдельная оплата также используется в сдельных нарядах
	Если Использование ИЛИ НЕ ПолучитьФункциональнуюОпцию("ИспользоватьТехоперации") Тогда
		ОписаниеНачислений = ОписаниеНачисленийСдельнаяОплата();
		УстановитьИспользованиеПоОписанию(ОписаниеНачислений, ГруппаНачисленияНаименование(), Использование);
	КонецЕсли;
	
	ОписаниеНачислений = ОписаниеНачисленийОплатаРабот();
	УстановитьИспользованиеПоОписанию(ОписаниеНачислений, ГруппаНачисленияНаименование(), Использование);
	
КонецПроцедуры

// Включение / отключение использования начислений, которые используются в сдельных нарядах - СдельнаяОплата
//
// Параметры:
//  Использование	 - Булево	- новое значение реквизита Используется
//
Процедура УстановитьИспользованиеСдельнойОплаты(Использование) Экспорт
	
	// Сдельная оплата также используется в заказ-нарядах
	Если НЕ Использование И ПолучитьФункциональнуюОпцию("ИспользоватьПодсистемуРаботы") Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеНачислений = ОписаниеНачисленийСдельнаяОплата();
	УстановитьИспользованиеПоОписанию(ОписаниеНачислений, ГруппаНачисленияНаименование(), Использование);
	
КонецПроцедуры

// Включение / отключение использования начислений, которые используются в заданиях на работу - ОплатаПоЗаданиям
//
// Параметры:
//  Использование	 - Булево	- новое значение реквизита Используется
//
Процедура УстановитьИспользованиеОплатаПоЗаданиям(Использование) Экспорт
	
	ОписаниеНачислений = ОписаниеОплатаПоЗаданиям();
	УстановитьИспользованиеПоОписанию(ОписаниеНачислений, ГруппаНачисленияНаименование(), Использование);
	
КонецПроцедуры

// Включение / отключение использования удержаний для возвращения займов: ПогашениеЗаймаИзЗарплаты, ПроцентыПоЗайму 
//
// Параметры:
//  Использование	 - Булево	- новое значение реквизита Используется
//
Процедура УстановитьИспользованиеУдержанийЗаймы(Использование) Экспорт
	
	ОписаниеУдержаний = ОписаниеУдержанийКредитыЗаймы();
	УстановитьИспользованиеПоОписанию(ОписаниеУдержаний, ГруппаУдержанияНаименование(), Использование);
	
КонецПроцедуры

// Включение / отключение использования налога на доходы
//
// Параметры:
//  Использование	 - Булево	- новое значение реквизита Используется
//
Процедура УстановитьИспользованиеНалоги(Использование) Экспорт
	
	// НДФЛ может быть включен для упр. учета
	Если Использование ИЛИ НЕ ПолучитьФункциональнуюОпцию("ВестиУчетНалогаНаДоходыИВзносов") Тогда
		ОписаниеУдержаний = ОписаниеНалоги();
		УстановитьИспользованиеПоОписанию(ОписаниеУдержаний, ГруппаУдержанияНаименование(), Использование);
	КонецЕсли;

КонецПроцедуры

// Включение / отключение использования налога на доходы и страховых взносов
//
// Параметры:
//  Использование	 - Булево	- новое значение реквизита Используется
//
Процедура УстановитьИспользованиеНалогиВзносы(Использование) Экспорт

	// НДФЛ может быть включен для организаций, использующих регламентированный учет зарплаты
	Если Использование ИЛИ НЕ ПолучитьФункциональнуюОпцию("ИспользоватьРегламентированныйУчетЗарплатыИКадров") Тогда
		ОписаниеУдержаний = ОписаниеНалоги();
		УстановитьИспользованиеПоОписанию(ОписаниеУдержаний, ГруппаУдержанияНаименование(), Использование);
	КонецЕсли;
	
	ОписаниеУдержаний = ОписаниеВзносы();
	УстановитьИспользованиеПоОписанию(ОписаниеУдержаний, ГруппаУдержанияНаименование(), Использование);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	Если НЕ Параметры.Свойство("СобственныйВызов") Тогда
		
		СтандартнаяОбработка = Ложь;
		
		Параметры.Вставить("СобственныйВызов");
		Отбор = Новый Структура;
		Отбор.Вставить("Используется", Истина);
		Параметры.Вставить("Отбор", Отбор);
		СтандартныйСписок = ПолучитьДанныеВыбора(Параметры);
		ДанныеВыбора = СтандартныйСписок;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

