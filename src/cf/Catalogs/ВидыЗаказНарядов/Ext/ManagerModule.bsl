	Если Выборка.Следующий() Тогда
		Возврат Выборка.ВидЗаказа;
	КонецЕсли;
	
	Если ЭтоЗаявка Тогда
		Возврат ВидЗаказаСЗаявками();
	КонецЕсли;
	
	Возврат Основной;
	
