// Определяет настройки начального заполнения элементов.
//
// Параметры:
//  Настройки - Структура - настройки заполнения:
//   * ПриНачальномЗаполненииЭлемента - Булево - Если Истина, то для каждого элемента будет
//      вызвана процедура индивидуального заполнения ПриНачальномЗаполненииЭлемента.
Процедура ПриНастройкеНачальногоЗаполненияЭлементов(Настройки) Экспорт
	
	Настройки.ПриНачальномЗаполненииЭлемента = Истина;
	
КонецПроцедуры

// Смотри также ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов
// 
// Параметры:
//   КодыЯзыков - см. ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов.КодыЯзыков
//   Элементы - см. ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов.Элементы
//   ТабличныеЧасти - см. ОбновлениеИнформационнойБазыПереопределяемый.ПриНачальномЗаполненииЭлементов.ТабличныеЧасти
//
Процедура ПриНачальномЗаполненииЭлементов(КодыЯзыков, Элементы, ТабличныеЧасти) Экспорт
	
	Элемент = Элементы.Добавить();
	Элемент.ИмяПредопределенныхДанных = "Основной";
	Элемент.Наименование = НСтр("ru='Основной'");
	
КонецПроцедуры

// Смотри также ОбновлениеИнформационнойБазыПереопределяемый.ПриНастройкеНачальногоЗаполненияЭлемента
//
// Параметры:
//  Объект                  - СправочникОбъект.ВидыКонтактнойИнформации - заполняемый объект.
//  Данные                  - СтрокаТаблицыЗначений - данные заполнения объекта.
//  ДополнительныеПараметры - Структура:
//   * ПредопределенныеДанные - ТаблицаЗначений - данные заполненные в процедуре ПриНачальномЗаполненииЭлементов.
//
Процедура ПриНачальномЗаполненииЭлемента(Объект, Данные, ДополнительныеПараметры) Экспорт
	
	Объект.УстановитьНовыйКод();
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

// Процедура заполняет основной вид заказа. Должна вызываться после заполнения справочника состояний.
//
Процедура ЗаполнитьОсновнойВидЗаказа() Экспорт
	
	ВидЗаказа = Основной.ПолучитьОбъект();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостоянияЗаказНарядов.Ссылка КАК Состояние,
		|	ВЫБОР
		|		КОГДА СостоянияЗаказНарядов.Наименование = &Состояние1
		|			ТОГДА 1
		|		КОГДА СостоянияЗаказНарядов.Наименование = &Состояние2
		|			ТОГДА 2
		|		КОГДА СостоянияЗаказНарядов.Наименование = &Состояние3
		|			ТОГДА 3
		|		КОГДА СостоянияЗаказНарядов.Наименование = &Состояние4
		|			ТОГДА 4
		|		ИНАЧЕ 5
		|	КОНЕЦ КАК Порядок
		|ИЗ
		|	Справочник.СостоянияЗаказНарядов КАК СостоянияЗаказНарядов
		|ГДЕ
		|	СостоянияЗаказНарядов.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Порядок";
	Запрос.УстановитьПараметр("Состояние1", СостоянияЗаказов.СостояниеНеОбработан());
	Запрос.УстановитьПараметр("Состояние2", СостоянияЗаказов.СостояниеВРаботе());
	Запрос.УстановитьПараметр("Состояние3", СостоянияЗаказов.СостояниеВыставленСчет());
	Запрос.УстановитьПараметр("Состояние4", СостоянияЗаказов.СостояниеНаВыполнении());
	
	Состояния = Запрос.Выполнить().Выгрузить();
	
	ВидЗаказа.ПорядокСостояний.Загрузить(Состояния);
	ВидЗаказа.СостояниеВыполнения = Справочники.СостоянияЗаказНарядов.Завершен;
	ВидЗаказа.НомерСостоянияВыполнения = ВидЗаказа.ПорядокСостояний.Количество();
	
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(ВидЗаказа);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ДанныеВыбора = Новый СписокЗначений;
	Запрос = Новый Запрос;
	КоличествоЭлементовБыстрогоВыбора = 15;
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 99
		|	ВидыЗаказНарядов.Ссылка КАК ВидЗаказа,
		|	ВидыЗаказНарядов.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ВидыЗаказНарядов КАК ВидыЗаказНарядов
		|ГДЕ
		|	ВидыЗаказНарядов.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "99", КоличествоЭлементовБыстрогоВыбора);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ДанныеВыбора.Добавить(Выборка.ВидЗаказа, Выборка.Наименование);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Первое состояние после заявки.
// 
// Параметры:
//  Ссылка - СправочникСсылка.ВидыЗаказНарядов - Вид заказ-наряда
// 
// Возвращаемое значение:
//  СправочникСсылка.СостоянияЗаказНарядов - Первое состояние после заявки
Функция ПервоеСостояниеПослеЗаявки(Ссылка) Экспорт
	
	НомерСостоянияЗаявки = НомерСостоянияЗаявки(Ссылка);
	Если НомерСостоянияЗаявки = 0 Тогда
		Возврат ПервоеСостояние(Ссылка);
	КонецЕсли;
	
	Возврат СостояниеПоНомеруСтроки(НомерСостоянияЗаявки + 1, Ссылка);
	
КонецФункции

// Это состояние заявки.
// 
// Параметры:
//  Состояние - СправочникСсылка.СостоянияЗаказНарядов - Состояние
//  Ссылка - СправочникСсылка.ВидыЗаказНарядов - Вид заказ-наряда
//  ВидОперации - Неопределено - Вид операции
// 
// Возвращаемое значение:
//  Булево - Это состояние заявки
Функция ЭтоСостояниеЗаявки(Состояние, Ссылка, ВидОперации = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(ВидОперации)
		И ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд
		И Состояние = Справочники.СостоянияЗаказНарядов.Завершен Тогда
		Возврат Истина;
	КонецЕсли;
	
	НомерСостоянияЗаявки = НомерСостоянияЗаявки(Ссылка);
	Если НомерСостоянияЗаявки = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	НомерСтрокиСостояния = НомерСтрокиСостояния(Состояние, Ссылка);
	Если НомерСтрокиСостояния = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат НомерСтрокиСостояния <= НомерСостоянияЗаявки;
	
КонецФункции

Функция ПервоеСостояние(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВидыЗаказНарядовПорядокСостояний.Состояние КАК Состояние
		|ИЗ
		|	Справочник.ВидыЗаказНарядов.ПорядокСостояний КАК ВидыЗаказНарядовПорядокСостояний
		|ГДЕ
		|	ВидыЗаказНарядовПорядокСостояний.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидыЗаказНарядовПорядокСостояний.НомерСтроки";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда
		Возврат Справочники.СостоянияЗаказНарядов.Завершен;
	КонецЕсли;
	
	Возврат Выборка.Состояние;
	
КонецФункции

Функция ВсеСостоянияЗаявки(Ссылка) Экспорт
	
	ДанныеСостоянияЗаявки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "СостояниеЗаявки,НомерСостоянияЗаявки");
	Если Не ЗначениеЗаполнено(ДанныеСостоянияЗаявки.СостояниеЗаявки) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Результат = ПредыдущиеСостояния(Ссылка, ДанныеСостоянияЗаявки.НомерСостоянияЗаявки);
	Результат.Добавить(ДанныеСостоянияЗаявки.СостояниеЗаявки);
	
	Возврат Результат;
	
КонецФункции

Функция ВсеСостоянияЗаказа(Ссылка) Экспорт
	
	НомерСостоянияЗаявки = НомерСостоянияЗаявки(Ссылка);
	Если НомерСостоянияЗаявки = 0 Тогда
		Возврат ВсеСостояния(Ссылка);
	КонецЕсли;
	
	Возврат СледующиеСостояния(Ссылка, НомерСостоянияЗаявки);
	
КонецФункции

Функция ВидЗаказаСЗаявками() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВидыЗаказНарядов.Ссылка КАК Ссылка,
		|	ВидыЗаказНарядов.Ссылка = ЗНАЧЕНИЕ(Справочник.ВидыЗаказНарядов.Основной) КАК ЭтоОсновной
		|ИЗ
		|	Справочник.ВидыЗаказНарядов КАК ВидыЗаказНарядов
		|ГДЕ
		|	ВидыЗаказНарядов.СостояниеЗаявки <> ЗНАЧЕНИЕ(Справочник.СостоянияЗаказНарядов.ПустаяСсылка)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СостояниеЗаявки = Неопределено;
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если СостояниеЗаявки = Неопределено Тогда
			СостояниеЗаявки = Выборка.Ссылка;
		КонецЕсли;
		
		Если Выборка.ЭтоОсновной Тогда
			Возврат Основной;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СостояниеЗаявки;
	
КонецФункции

Функция ЕстьВидСВключеннымиЗаявками() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВидыЗаказНарядов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВидыЗаказНарядов КАК ВидыЗаказНарядов
		|ГДЕ
		|	ВидыЗаказНарядов.СостояниеЗаявки <> ЗНАЧЕНИЕ(Справочник.СостоянияЗаказНарядов.ПустаяСсылка)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

Функция ПоследнийИспользованныйДоступныйВидЗаказа(ВидОперации, СостояниеЗаказа = Неопределено) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьВидыЗаказНарядов") Тогда
		Возврат Основной;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СостояниеЗаказа) Тогда
		Возврат ПоследнийИспользованныйДоступныйВидЗаказаПоСостоянию(СостояниеЗаказа, ВидОперации);
	Иначе
		Возврат ПоследнийИспользованныйДоступныйВидЗаказаБезСостояния(ВидОперации);
	КонецЕсли;
	
КонецФункции

Функция ВидСодержитСостояние(Ссылка, СостояниеЗаказа) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВидыЗаказНарядовПорядокСостояний.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВидыЗаказНарядов.ПорядокСостояний КАК ВидыЗаказНарядовПорядокСостояний
		|ГДЕ
		|	ВидыЗаказНарядовПорядокСостояний.Состояние = &Состояние
		|	И ВидыЗаказНарядовПорядокСостояний.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Состояние", СостояниеЗаказа);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

Функция КоличествоСостояний(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВидыЗаказНарядовПорядокСостояний.Ссылка) КАК КоличествоСостояний
		|ИЗ
		|	Справочник.ВидыЗаказНарядов.ПорядокСостояний КАК ВидыЗаказНарядовПорядокСостояний
		|ГДЕ
		|	ВидыЗаказНарядовПорядокСостояний.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КоличествоСостояний;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция НомерСостояния(ПорядокСостояний, Состояние) Экспорт
	
	СтрокаСостояния = ПорядокСостояний.Найти(Состояние);
	Если ЗначениеЗаполнено(СтрокаСостояния) Тогда
		Возврат СтрокаСостояния.НомерСтроки;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция ВидыЗаказовГдеСостояниеИспользуетЗаявки(СостояниеЗаказа) Экспорт
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВидыЗаказНарядовПорядокСостояний.Ссылка КАК Ссылка,
		|	ВидыЗаказНарядовПорядокСостояний.НомерСтроки КАК НомерСтроки
		|ПОМЕСТИТЬ втНомераСостояния
		|ИЗ
		|	Справочник.ВидыЗаказНарядов.ПорядокСостояний КАК ВидыЗаказНарядовПорядокСостояний
		|ГДЕ
		|	ВидыЗаказНарядовПорядокСостояний.Состояние = &Состояние
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВидыЗаказНарядов.Ссылка КАК Ссылка,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ВидыЗаказНарядов.Ссылка) КАК Представление
		|ИЗ
		|	втНомераСостояния КАК втНомераСостояния
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЗаказНарядов КАК ВидыЗаказНарядов
		|		ПО втНомераСостояния.Ссылка = ВидыЗаказНарядов.Ссылка
		|ГДЕ
		|	втНомераСостояния.НомерСтроки <= ВидыЗаказНарядов.НомерСостоянияЗаявки";
	
	Запрос.УстановитьПараметр("Состояние", СостояниеЗаказа);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Данные = Новый Структура("Ссылка,Представление");
		ЗаполнитьЗначенияСвойств(Данные, Выборка);
		Результат.Добавить(Данные);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПоследнийИспользованныйДоступныйВидЗаказаПоСостоянию(СостояниеЗаказа, ВидОперации)
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВидыЗаказНарядовПорядокСостояний.Ссылка КАК Ссылка,
		|	ВидыЗаказНарядовПорядокСостояний.Ссылка = ЗНАЧЕНИЕ(Справочник.ВидыЗаказНарядов.Основной) КАК ЭтоОсновнойВид
		|ПОМЕСТИТЬ втНомераСтрокиСостояния
		|ИЗ
		|	Справочник.ВидыЗаказНарядов.ПорядокСостояний КАК ВидыЗаказНарядовПорядокСостояний
		|ГДЕ
		|	ВидыЗаказНарядовПорядокСостояний.Состояние = &СостояниеЗаказа
		|	И ВидыЗаказНарядовПорядокСостояний.НомерСтроки > ВидыЗаказНарядовПорядокСостояний.Ссылка.НомерСостоянияЗаявки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ЗаказПокупателя.ВидЗаказа КАК ВидЗаказа,
		|	ЗаказПокупателя.Дата КАК Дата
		|ИЗ
		|	втНомераСтрокиСостояния КАК втНомераСтрокиСостояния
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|		ПО втНомераСтрокиСостояния.Ссылка = ЗаказПокупателя.ВидЗаказа
		|ГДЕ
		|	ЗаказПокупателя.Автор = &Автор
		|	И ЗаказПокупателя.ВидЗаказа = втНомераСтрокиСостояния.Ссылка
		|	И ЗаказПокупателя.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ЗаказПокупателя.ВидЗаказа,
		|	ЗаказПокупателя.Дата
		|ИЗ
		|	втНомераСтрокиСостояния КАК втНомераСтрокиСостояния
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|		ПО втНомераСтрокиСостояния.Ссылка = ЗаказПокупателя.ВидЗаказа
		|ГДЕ
		|	ЗаказПокупателя.ВидЗаказа = втНомераСтрокиСостояния.Ссылка
		|	И ЗаказПокупателя.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";
	
	Если Не ЕстьВидСВключеннымиЗаявками() Тогда
		
		ТекстЗапроса = СтрЗаменить(
		ТекстЗапроса,
		"И ВидыЗаказНарядовПорядокСостояний.НомерСтроки > ВидыЗаказНарядовПорядокСостояний.Ссылка.НомерСостоянияЗаявки",
		"");
		
	ИначеЕсли РаботаСЗаявкамиКлиентСервер.ЭтоЗаявка(ВидОперации) Тогда
		
		ТекстЗапроса = СтрЗаменить(
		ТекстЗапроса,
		"И ВидыЗаказНарядовПорядокСостояний.НомерСтроки > ВидыЗаказНарядовПорядокСостояний.Ссылка.НомерСостоянияЗаявки",
		"И ВидыЗаказНарядовПорядокСостояний.НомерСтроки <= ВидыЗаказНарядовПорядокСостояний.Ссылка.НомерСостоянияЗаявки");
		
		ТекстЗапроса = СтрЗаменить(
		ТекстЗапроса,
		"И ЗаказПокупателя.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд)",
		"И ЗаказПокупателя.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаявкаЗаказНаряд)");
		
	КонецЕсли;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("СостояниеЗаказа", СостояниеЗаказа);
	Запрос.УстановитьПараметр("Автор", Пользователи.ТекущийПользователь());
	
	ПакетЗапросов = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	Выборка = ПакетЗапросов[1].Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ВидЗаказа;
	КонецЕсли;
	
	Выборка = ПакетЗапросов[2].Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ВидЗаказа;
	КонецЕсли;
	
	Таблица = ПакетЗапросов[0].Выгрузить();
	Для Каждого СтрокаТЗ Из Таблица Цикл
		Если СтрокаТЗ.ЭтоОсновнойВид Тогда
			Возврат СтрокаТЗ.Ссылка;
		КонецЕсли;
	КонецЦикла;
	
	Если Таблица.Количество() Тогда
		Возврат Таблица[0].Ссылка;
	КонецЕсли;
	
	Возврат Основной;
	
КонецФункции

Функция ПоследнийИспользованныйДоступныйВидЗаказаБезСостояния(ВидОперации)
	
	ЭтоЗаявка = РаботаСЗаявкамиКлиентСервер.ЭтоЗаявка(ВидОперации);
	
