#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Для НомерСтроки = 1 По ПорядокСостояний.Количество() Цикл
		Для НомерСтрокиОстатка = НомерСтроки+1 По ПорядокСостояний.Количество() Цикл
			Если ПорядокСостояний[НомерСтроки-1].Состояние = ПорядокСостояний[НомерСтрокиОстатка-1].Состояние Тогда
				ОбщегоНазначения.СообщитьПользователю(СтрШаблон(НСтр("ru='Дублируется состояние ""%1"" в строках %2 и %3'"), ПорядокСостояний[НомерСтроки-1].Состояние, НомерСтроки, НомерСтрокиОстатка),
					Ссылка,
					ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("ПорядокСостояний", НомерСтрокиОстатка, "Состояние"),
					,
					Отказ);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СостояниеВыполнения) И ПорядокСостояний.Найти(СостояниеВыполнения, "Состояние") = Неопределено Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru='Выбранного состояния нет среди используемых в виде заказ-наряда.'"),
		,
		"СостояниеВыполнения",
		"Объект",
		Отказ);
	КонецЕсли;
	
	Данные = Новый Структура;
	Данные.Вставить("Ссылка", Ссылка);
	Данные.Вставить("СостояниеЗаявки", СостояниеЗаявки);
	Данные.Вставить("ПорядокСостояний", ПорядокСостояний);
	Данные.Вставить("СостояниеВыполнения", СостояниеВыполнения);
	Ответ = РаботаСЗаявками.ОбработкаПроверкиЗаполненияВидыЗаказа(Данные);
	Если Не Ответ.ИзменениеВозможно Тогда
		
		Отказ = Истина;
		ИспользоватьВиды = ПолучитьФункциональнуюОпцию("ИспользоватьВидыЗаказовПокупателей");
		
		ПараметрыМетода = Новый Структура;
		ПараметрыМетода.Вставить("РезультатПроверки", Ответ);
		ПараметрыМетода.Вставить("ИспользоватьВидыЗаказов", ИспользоватьВиды);
		ПараметрыМетода.Вставить("НаименованиеВидаЗаказа", Наименование);
		ПараметрыМетода.Вставить("ЗаявкиИспользуютсяДляВида", ЗначениеЗаполнено(СостояниеЗаявки));
		Ответ = РаботаСЗаявкамиКлиентСервер.ОбработатьРезультатПроверкиВозможностиИзмененияИспользованияЗаявокДляСостояния(
		ПараметрыМетода);
		
		Если ЗначениеЗаполнено(Ответ.ДанныеПредупреждения.Текст) Тогда
			ТекстСообщения = Ответ.ДанныеПредупреждения.Текст;
		Иначе
			ТекстСообщения = Ответ.ДанныеВопроса.Текст;
		КонецЕсли;
		
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаТЧ = ПорядокСостояний.Найти(Справочники.СостоянияЗаказНарядов.Завершен, "Состояние");
	Если СтрокаТЧ = Неопределено Тогда
		СтрокаТЧ = ПорядокСостояний.Добавить();
		СтрокаТЧ.Состояние = Справочники.СостоянияЗаказНарядов.Завершен;
	Иначе
		ПорядокСостояний.Сдвинуть(СтрокаТЧ, ПорядокСостояний.Количество() - СтрокаТЧ.НомерСтроки);
	КонецЕсли;
	
	// Реквизиты нужны только для оптимальных запросов, не нужно использовать их для работы с видом заказа напрямую
	НомерСостоянияВыполнения = ПорядокСостояний.Найти(СостояниеВыполнения).НомерСтроки;
	НомерСостоянияЗаявки = Справочники.ВидыЗаказНарядов.НомерСостояния(ПорядокСостояний, СостояниеЗаявки);
	
	ЗаявкиИспользуются = РаботаСЗаявками.ЗаявкиИспользуются(,
	Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд);
	ДополнительныеСвойства.Вставить("ЗаявкиИспользовались", ЗаявкиИспользуются);
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ЗаявкиТеперьИспользуются = РаботаСЗаявками.ЗаявкиИспользуются(,
	Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд);
	
	ИспользованиеЗаявокИзменилось = (ДополнительныеСвойства.ЗаявкиИспользовались <> ЗаявкиТеперьИспользуются);
	Если ИспользованиеЗаявокИзменилось Тогда
		РаботаСЗаявками.ОчиститьОтборВСпискеЗаказов(
		Метаданные.Документы.ЗаказПокупателя.Формы.ФормаСпискаЗаказНаряда.Имя);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли