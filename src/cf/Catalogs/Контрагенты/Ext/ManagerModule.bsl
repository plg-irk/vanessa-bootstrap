	ПредставлениеВестиРасчетыПоЗаказам = НСтр("ru = 'Вести расчеты по заказам'");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ВестиРасчетыПоЗаказам",
