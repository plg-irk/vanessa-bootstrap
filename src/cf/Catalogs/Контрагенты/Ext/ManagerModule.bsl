		ОписанияТиповПолей.ОписаниеТиповСтрока1000);

	ПредставлениеФактическийАдрес = НСтр("ru = 'Факт. адрес'");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "АдресФакт",
		ПредставлениеФактическийАдрес, ОписанияТиповПолей.ОписаниеТиповСтрока1000,
		ОписанияТиповПолей.ОписаниеТиповСтрока1000);

	ПредставлениеТелефон = НСтр("ru = 'Телефон'");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Телефон",
		ПредставлениеТелефон, ОписанияТиповПолей.ОписаниеТиповСтрока100, ОписанияТиповПолей.ОписаниеТиповСтрока100);

	ПредставлениеПочты = НСтр("ru = 'E-mail'");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "АдресЭП", ПредставлениеПочты,
		ОписанияТиповПолей.ОписаниеТиповСтрока100, ОписанияТиповПолей.ОписаниеТиповСтрока100);

	ОписаниеТиповКолонка = Новый ОписаниеТипов("ПеречислениеСсылка.ВидыКонтрагентов");
	ПредставлениеВидКонтрагента = НСтр("ru = 'Вид контрагента'");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ВидКонтрагента",
		ПредставлениеВидКонтрагента, ОписанияТиповПолей.ОписаниеТиповСтрока25, ОписаниеТиповКолонка);

