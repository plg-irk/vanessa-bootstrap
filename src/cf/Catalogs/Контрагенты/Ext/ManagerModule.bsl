	ПредставлениеВестиРасчетыПоСчетам = НСтр("ru = 'Вести расчеты по счетам'");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "ВестиУчетОплатыПоСчетам",
		ПредставлениеВестиРасчетыПоСчетам, ОписанияТиповПолей.ОписаниеТиповСтрока10, ОписаниеТиповКолонка);

	ПредставлениеЮридическийАдрес = НСтр("ru = 'Юр. адрес'");
	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "АдресЮр",
