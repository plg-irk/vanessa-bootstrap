		ДинамическиеПараметры.Добавить(СтрШаблон(НСтр("ru = '%1  в %2 (основной)'"), ОсновнойСчет_Номер, ОсновнойСчет_Банк));
	Иначе
		ДинамическиеПараметры.Добавить(СтрШаблон(НСтр("ru = '<номер счета> в %2 (основной)'"), 
