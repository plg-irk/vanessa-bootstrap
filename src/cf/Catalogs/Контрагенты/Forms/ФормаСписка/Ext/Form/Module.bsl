#Область ПоискИПроверкаКонтрагентов

&НаКлиенте
Процедура ПоискИПроверкаКонтрагентаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	Если НЕ ИспользоватьРаботуСПоискомКонтрагентовВСписке Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;

	ЭтоСтрокаИНН = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Элемент.ТекстРедактирования);
	
	Если НЕ ЭтоСтрокаИНН Тогда
		ПараметрыПоиска = Новый Структура;
		ПараметрыПоиска.Вставить("Наименование", Элемент.ТекстРедактирования);
		ПоискКонтрагентовКлиент.НайтиКонтрагентов(ЭтотОбъект,,ПараметрыПоиска);
		Возврат;
	КонецЕсли;
	
	Если СтрДлина(СокрЛП(Элемент.ТекстРедактирования)) <> 10 ИЛИ СтрДлина(СокрЛП(Элемент.ТекстРедактирования)) <> 12 Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Организация с таким наименованием не найдена. Для поиска организации по ИНН необходимо указать его полностью'"));
		Возврат;
	КонецЕсли;
	
	ПоискИПроверкаКонтрагента = "";
	ПроверкаКонтрагентаКлиент.Проверить(Элемент.ТекстРедактирования, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоискИПроверкаКонтрагентаОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Если НЕ ИспользоватьРаботуСПоискомКонтрагентовВСписке Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Текст) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	ЭтоСтрокаИНН = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Элемент.ТекстРедактирования);
	
	Если НЕ ЭтоСтрокаИНН Тогда
		ПараметрыПоиска = Новый Структура;
		ПараметрыПоиска.Вставить("Наименование", Элемент.ТекстРедактирования);
		ПоискКонтрагентовКлиент.НайтиКонтрагентов(ЭтотОбъект,,ПараметрыПоиска);
		Возврат;
	КонецЕсли;
	
	Если СтрДлина(СокрЛП(Элемент.ТекстРедактирования)) = 10 ИЛИ СтрДлина(СокрЛП(Элемент.ТекстРедактирования)) = 12 Тогда
		ПроверкаКонтрагентаКлиент.Проверить(Элемент.ТекстРедактирования, ЭтотОбъект);
		Возврат;
	КонецЕсли;
	
	ПоказатьПредупреждение(,НСтр("ru = 'Организация с таким наименованием не найдена. Для поиска организации по ИНН необходимо указать его полностью'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ПоискИПроверкаКонтрагентаАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	Если НЕ ИспользоватьРаботуСПоискомКонтрагентовВСписке Тогда
		Возврат;
	КонецЕсли;
	
	БизнесПриложениеПоискИПроверкаКлиент.АвтоПодборПоиск(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоискИПроверкаКонтрагентаОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, СтандартнаяОбработка)
	
	Если НЕ ИспользоватьРаботуСПоискомКонтрагентовВСписке Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Контрагенты") Тогда
		Элементы.Список.ТекущаяСтрока = ВыбранноеЗначение;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	ЭтоСтрокаИНН = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(ВыбранноеЗначение);
	
	Если НЕ ЭтоСтрокаИНН Тогда
		ПроверкаКонтрагентаКлиент.Проверить(ВыбранноеЗначение, ЭтотОбъект);
		ПоискИПроверкаКонтрагента = "";
		Возврат;
	КонецЕсли;
		
	Если СтрДлина(СокрЛП(ВыбранноеЗначение)) = 10 ИЛИ СтрДлина(СокрЛП(ВыбранноеЗначение)) = 12 Тогда
		ПроверкаКонтрагентаКлиент.Проверить(ВыбранноеЗначение, ЭтотОбъект);
		ПоискИПроверкаКонтрагента = "";
		Возврат;
	КонецЕсли;
	
	ПоказатьПредупреждение(,НСтр("ru = 'Организация с таким наименованием не найдена. Для поиска организации по ИНН необходимо указать его полностью'"));
		
КонецПроцедуры

