&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если ИспользоватьРаботуСПоискомКонтрагентовВСписке Тогда
		СтандартнаяОбработка = Ложь;
		Если Элементы.Список.ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		Контрагент = Элементы.Список.ТекущиеДанные.Ссылка;
		ПроверкаКонтрагентаКлиент.Проверить(Контрагент, ЭтотОбъект);
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "ОсновныеСведенияГоловной" ИЛИ Поле.Имя = "КартинкаИерархия" Тогда
		
		Если НЕ ЗначениеЗаполнено(Элементы.Список.ТекущиеДанные.ОсновныеСведенияГоловной) Тогда
			Возврат;
		КонецЕсли;
		
		Если ЭтоМобильныйКлиент Тогда
			Возврат
		КонецЕсли;
		
		СтандартнаяОбработка = Ложь;
		ОповещениеОВыбореКонтрагента = Новый ОписаниеОповещения("ВыборКонтрагентаИзИерархии",ЭтотОбъект);
		
		КонтрагентГоловной = Элементы.Список.ТекущиеДанные.ГоловнойКонтрагент;
		КонтрагентТекущий = Элементы.Список.ТекущиеДанные.Ссылка;
		СписокИерархии = СписокЗначенийИерархииКонтрагента(КонтрагентГоловной,
			КонтрагентТекущий);
			
		ПоказатьВыборИзМеню(ОповещениеОВыбореКонтрагента,СписокИерархии,Элементы.КартинкаИерархия);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

