#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Перем РазрешенРасширенныйРежимНастройкиОбменаУРМК;
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	РежимВыгрузкиПриНеобходимости = Перечисления.РежимыВыгрузкиОбъектовОбмена.ВыгружатьПриНеобходимости;
	
	ЗарегистрироватьТорговыйОбъектКОтправкеПриНеобходимости();
	ЗарегистрироватьВидЦенКОтправкеПриНеобходимости();
	ЗарегистрироватьСотрудникаПриНеобходимости();
	ЗарегистрироватьОстатки();
	
	Если ВыгружатьТолькоТоварыПалитры Тогда
		РежимВыгрузкиПриНеобходимости = Перечисления.РежимыВыгрузкиОбъектовОбмена.ПустаяСсылка();
	КонецЕсли;
	
	Если ОбменДаннымиСервер.НадоВыполнитьОбработчикПослеЗагрузкиДанных(ЭтотОбъект, Ссылка) Тогда
		ПослеЗагрузкиДанных(Отказ);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПослеЗагрузкиДанных(Отказ)

	ВыполнитьОтложеннуюОбработкуОбъектов(Отказ);

КонецПроцедуры

#КонецОбласти

#Область ОтложеннаяОбработка

Процедура ВыполнитьОтложеннуюОбработкуОбъектов(Отказ)
	
	СброситьФлагИзмененияНастроекУзла();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗарегистрироватьТорговыйОбъектКОтправкеПриНеобходимости()
	
	ДанныеУзла = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "ВыгружатьФизическихЛицЧастично, ВыгружатьСерии");
	Если ЗначениеЗаполнено(ТорговыйОбъект)
			И Не (Ссылка.Пустая() Или (ВыгружатьФизическихЛицЧастично = ДанныеУзла.ВыгружатьФизическихЛицЧастично
			И ВыгружатьСерии = ДанныеУзла.ВыгружатьСерии)) Тогда
			
		ПланыОбмена.ЗарегистрироватьИзменения(Ссылка, ТорговыйОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗарегистрироватьСотрудникаПриНеобходимости()
	Если Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ТаблицаНастройкиПользователей");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаСсылка.СотрудникСсылка КАК СотрудникСсылка,
	|	ТаблицаСсылка.ПользовательСсылка КАК ПользовательСсылка,
	|	ТаблицаСсылка.ПользовательСтрока КАК ПользовательСтрока,
	|	ТаблицаСсылка.КодСотрудника КАК КодСотрудника,
	|	ТаблицаСсылка.Роль КАК Роль
	|ПОМЕСТИТЬ НастройкиСсылка
	|ИЗ
	|	&ТаблицаСсылка КАК ТаблицаСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаСсылка.СотрудникСсылка КАК СотрудникСсылка,
	|	ТаблицаСсылка.ПользовательСсылка КАК ПользовательСсылка,
	|	ТаблицаСсылка.ПользовательСтрока КАК ПользовательСтрока,
	|	ТаблицаСсылка.КодСотрудника КАК КодСотрудника,
	|	ТаблицаСсылка.Роль КАК Роль
	|ПОМЕСТИТЬ НастройкиОбъект
	|ИЗ
	|	&ТаблицаОбъект КАК ТаблицаСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НастройкиСсылка.СотрудникСсылка КАК СотрудникСсылка,
	|	ВЫБОР
	|		КОГДА НастройкиОбъект.СотрудникСсылка ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СотрудуникИзменен,
	|	ВЫБОР
	|		КОГДА НастройкиСсылка.ПользовательСсылка <> НастройкиОбъект.ПользовательСсылка
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПользовательСсылкаИзменен,
	|	ВЫБОР
	|		КОГДА НастройкиСсылка.ПользовательСтрока <> НастройкиОбъект.ПользовательСтрока
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПользовательСтрокаИзменен,
	|	ВЫБОР
	|		КОГДА НастройкиСсылка.КодСотрудника <> НастройкиОбъект.КодСотрудника
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК КодСотрудникаИзменен,
	|	ВЫБОР
	|		КОГДА НастройкиСсылка.Роль <> НастройкиОбъект.Роль
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК РольИзменена
	|ПОМЕСТИТЬ РезультатТаблица
	|ИЗ
	|	НастройкиСсылка КАК НастройкиСсылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиОбъект КАК НастройкиОбъект
	|		ПО НастройкиСсылка.СотрудникСсылка = НастройкиОбъект.СотрудникСсылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РезультатТаблица.СотрудникСсылка КАК СотрудникСсылка
	|ИЗ
	|	РезультатТаблица КАК РезультатТаблица
	|ГДЕ
	|	РезультатТаблица.СотрудуникИзменен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РезультатТаблица.СотрудникСсылка
	|ИЗ
	|	РезультатТаблица КАК РезультатТаблица
	|ГДЕ
	|	РезультатТаблица.ПользовательСсылкаИзменен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РезультатТаблица.СотрудникСсылка
	|ИЗ
	|	РезультатТаблица КАК РезультатТаблица
	|ГДЕ
	|	РезультатТаблица.ПользовательСтрокаИзменен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РезультатТаблица.СотрудникСсылка
	|ИЗ
	|	РезультатТаблица КАК РезультатТаблица
	|ГДЕ
	|	РезультатТаблица.КодСотрудникаИзменен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РезультатТаблица.СотрудникСсылка
	|ИЗ
	|	РезультатТаблица КАК РезультатТаблица
	|ГДЕ
	|	РезультатТаблица.РольИзменена";
	Запрос.УстановитьПараметр("ТаблицаСсылка", ТаблицаСсылка);
	Запрос.УстановитьПараметр("ТаблицаОбъект", ТаблицаНастройкиПользователей);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			ПланыОбмена.ЗарегистрироватьИзменения(Ссылка, Выборка.СотрудникСсылка);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Процедура ЗарегистрироватьВидЦенКОтправкеПриНеобходимости()
	
	Если ЗначениеЗаполнено(ВидЦен)
		И Не (Ссылка.Пустая() Или (ВидЦен = Ссылка.ВидЦен)) Тогда
		
		ПланыОбмена.ЗарегистрироватьИзменения(Ссылка, ВидЦен);
		ПланыОбмена.ЗарегистрироватьИзменения(Ссылка, ТорговыйОбъект);

		ИзмененыНастройкиУзла = Истина;
	КонецЕсли;
		
КонецПроцедуры

Процедура СброситьФлагИзмененияНастроекУзла()
	
	НомерОтправленного = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "НомерОтправленного");
	ВыборкаИзменений   = ПланыОбмена.ВыбратьИзменения(Ссылка, НомерОтправленного);
	Если ВыборкаИзменений.Следующий() Тогда
		Возврат;
	КонецЕсли;

	ИзмененыНастройкиУзла = Ложь;
	
КонецПроцедуры

Процедура ЗарегистрироватьОстатки()
	ЗначениеВыгружатьОстатки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ВыгружатьОстаткиНоменклатуры");
	Если Ссылка.Пустая()
		Или ВыгружатьОстаткиНоменклатуры = ЗначениеВыгружатьОстатки Тогда
		Возврат;
	КонецЕсли;
	Если ВыгружатьОстаткиНоменклатуры Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ОстаткиТоваров.Организация КАК Организация,
		|	ОстаткиТоваров.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ОстаткиТоваров.Номенклатура КАК Номенклатура,
		|	ОстаткиТоваров.Характеристика КАК Характеристика,
		|	ОстаткиТоваров.Партия КАК Партия
		|ИЗ
		|	РегистрСведений.ОстаткиТоваров КАК ОстаткиТоваров
		|ГДЕ
		|	ОстаткиТоваров.СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ТорговыйОбъект);
		МассивИзменений = Новый Массив;
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			Возврат;
		КонецЕсли;
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборЗаписей = РегистрыСведений.ОстаткиТоваров.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Организация.Установить(Выборка.Организация);
			НаборЗаписей.Отбор.СтруктурнаяЕдиница.Установить(Выборка.СтруктурнаяЕдиница);
			НаборЗаписей.Отбор.Номенклатура.Установить(Выборка.Номенклатура);
			НаборЗаписей.Отбор.Характеристика.Установить(Выборка.Характеристика);
			НаборЗаписей.Отбор.Партия.Установить(Выборка.Партия);
			МассивИзменений.Добавить(НаборЗаписей);
		КонецЦикла;
		
		Для Каждого Запись Из МассивИзменений Цикл
			ПланыОбмена.ЗарегистрироватьИзменения(Ссылка, Запись);
		КонецЦикла;

	Иначе
		ПланыОбмена.УдалитьРегистрациюИзменений(Ссылка, Метаданные.РегистрыСведений.ОстаткиТоваров);
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли