
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Параметры.Свойство( "КодПриложения", КодПриложения );
	Параметры.Свойство( "ИдентификаторГруппы", ИдентификаторГруппы );
	Параметры.Свойство( "АвторизацияВКонтактеПараметры", АвторизацияВКонтактеПараметры );
	Параметры.Свойство( "МагазинДляИнтеграции", МагазинДляИнтеграции );
	Параметры.Свойство( "СпособАвторизации", СпособАвторизации );
	Параметры.Свойство( "АвторизацияСообщества", АвторизацияСообщества );
	Параметры.Свойство( "УчетнаяЗапись", УчетнаяЗапись );

	Элементы.КнопкаОк.Доступность = Ложь;
	
	Если АвторизацияСообщества Тогда
		Элементы.СпособАвторизации.Видимость = Ложь;
	КонецЕсли;
	
	Элементы.ГруппаУспешнаяАвторизация.Видимость = Ложь;
	Элементы.ГруппаОшибкаАвторизации.Видимость = Ложь;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура КнопкаОбновитьТокен(Команда)

	Если АвторизацияСообщества Тогда
		ОбновитьТокенДоступаСообществаНаКлиенте();
	Иначе
		ОбновитьТокенДоступаНаКлиенте();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КнопкаОк(Команда)

	ПараметрыЗакрытия = Новый Структура;
	ПараметрыЗакрытия.Вставить( "АвторизацияСообщества", АвторизацияСообщества );
	ПараметрыЗакрытия.Вставить( "КодПриложения", КодПриложения );
	ПараметрыЗакрытия.Вставить( "ИдентификаторГруппы", ИдентификаторГруппы );
	ПараметрыЗакрытия.Вставить( "АвторизацияВКонтактеПараметры", АвторизацияВКонтактеПараметры );
	ПараметрыЗакрытия.Вставить( "МагазинДляИнтеграции", МагазинДляИнтеграции );
	ПараметрыЗакрытия.Вставить( "СпособАвторизации", СпособАвторизации );
	ПараметрыЗакрытия.Вставить( "АвторизацияСообщества", АвторизацияСообщества );
	ПараметрыЗакрытия.Вставить( "ИдентификаторПользователя", ИдентификаторПользователя );
	
	ЭтаФорма.Закрыть( ПараметрыЗакрытия );
КонецПроцедуры

&НаКлиенте
Процедура СтрокаАвторизацииИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)

    СтандартнаяОбработка = Ложь;
    
    СтрокаАвторизации = Текст;
    
    ПодключитьОбработчикОжидания( "СтрокаАвторизацииПослеИзменения", 0.1, Истина );
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы


#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьТокенДоступаНаКлиенте() 
	
	Если Не ЗначениеЗаполнено(КодПриложения) Тогда

		ОшибкаТекст = НСтр( "ru = 'Необходимо заполнить поле ""ID приложения.""'" );
		ОбщегоНазначенияКлиент.СообщитьПользователю( ОшибкаТекст );

		Возврат;
	КонецЕсли;
	
	Если СпособАвторизации = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииOAUTH() Тогда
	
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(ПолучитьСсылкуНаСтрокуАвторизацииНаКлиенте());
		
	ИначеЕсли СпособАвторизации = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииVKID() Тогда
	
		АвторизацияВКонтактеПараметры = 
		ИнтеграцияСМагазинамиСоцСетейКлиентСервер.АвторизацияВКонтактеПараметрыНовый( СпособАвторизации );
		
		ИнтеграцияСМагазинамиСоцСетейВызовСервера.АвторизацияVKIDПараметрыЗаполнитьПоУмолчанию( АвторизацияВКонтактеПараметры, КодПриложения );
		
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку( АвторизацияВКонтактеПараметры.АвторизацияСтрокаURL );
	
	Иначе
	
		ОшибкаШаблон = НСтр( "ru = 'Способ авторизации задан некорректно: %1. Необходимо обратиться в техническую поддежку 1С.'" );
		ОшибкаТекст = СтрШаблон( ОшибкаШаблон, СпособАвторизации );
		ОбщегоНазначенияКлиент.СообщитьПользователю( ОшибкаТекст );
		
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСсылкуНаСтрокуАвторизацииНаКлиенте(ЭтоСообщество = Ложь) Экспорт
	
	НастройкиУзла = Новый Структура;
	НастройкиУзла.Вставить("МагазинДляИнтеграции" , МагазинДляИнтеграции);
	НастройкиУзла.Вставить("КодПриложения" , КодПриложения);
	НастройкиУзла.Вставить("ИдентификаторГруппы" , ИдентификаторГруппы);
	
	Возврат ПолучитьСсылкуНаСтрокуАвторизацииНаСервереБезКонтекста(НастройкиУзла, ЭтоСообщество);
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСсылкуНаСтрокуАвторизацииНаСервереБезКонтекста(НастройкиУзла, ЭтоСообщество)
	
	Возврат ПланыОбмена.ИнтеграцияСМагазинамиСоцСетей.ПолучитьСсылкуНаСтрокуАвторизации(НастройкиУзла, ЭтоСообщество);
	
КонецФункции

&НаКлиенте
Процедура СпособАвторизацииПриИзменении(Элемент)
	СтрокаАвторизации = "";
	ОбновитьДанныеФормыИзБезопасногоХранилища();
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуАвторизацииНаКлиенте(ЭтоСообщество = Ложь)
	
	Если ЭтоСообщество Тогда 
		
		Результат = ИзвлечьТокенДоступаИзСтрокиАвторизации(СтрокаАвторизации);
		
		ТокенДоступа = Результат.Получить(СтрШаблон("access_token_%1", ИдентификаторГруппы));
		
		АвторизацияВКонтактеПараметры.access_token_community = ТокенДоступа;
		АвторизацияВКонтактеПараметры.ОкончанияДействияТокенДоступаСообщества = Результат.Получить("ОкончанияДействияТокенаДоступа");
		
	Иначе
		
		Результат = ИзвлечьТокенДоступаИзСтрокиАвторизации(СтрокаАвторизации);
		
		ИдентификаторПользователя = Результат.Получить("user_id");
		ТокенДоступа = Результат.Получить("access_token");
		
		АвторизацияВКонтактеПараметры.access_token = ТокенДоступа;
		АвторизацияВКонтактеПараметры.ОкончанияДействияТокенаДоступа = Результат.Получить("ОкончанияДействияТокенаДоступа");;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ИзвлечьТокенДоступаИзСтрокиАвторизации(СтрокиАвторизации)
	
	СтрокаПоиска = "https://oauth.vk.com/blank.html#";
	
	ТекущаяДата = ОбщегоНазначенияКлиент.ДатаСеанса() - 1;
	
	Результат = Новый Соответствие;
	
	МассивЧастей = СтрРазделить(СтрЗаменить(СтрокиАвторизации,СтрокаПоиска,""),"&",Ложь);
	Если МассивЧастей.Количество() > 0 Тогда
		
		Для Каждого СтрокаПараметры Из МассивЧастей Цикл 
			
			МассивКлючЗначение = СтрРазделить(СтрокаПараметры,"=");
			Если МассивКлючЗначение.Количество() = 2 Тогда 
				Результат.Вставить(МассивКлючЗначение[0],МассивКлючЗначение[1]);
			ИначеЕсли МассивКлючЗначение.Количество() = 1 Тогда
				Результат.Вставить(МассивКлючЗначение[0],Неопределено);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	ОкончанияДействияТокенаДоступа = ТекущаяДата + (60*60*24 * 365); // По умолчанию 1 год
	
	СрокЖизниВСекундах = Результат.Получить("expires_in");
	Если СрокЖизниВСекундах = Неопределено Тогда
		СрокЖизниВСекундах = 0;
	Иначе
		СрокЖизниВСекундах = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(СрокЖизниВСекундах);
	КонецЕсли;
	
	Если СрокЖизниВСекундах <> 0 Тогда  
		ОкончанияДействияТокенаДоступа = ТекущаяДата + СрокЖизниВСекундах;
	КонецЕсли;
	
	Результат.Вставить("ОкончанияДействияТокенаДоступа" , ОкончанияДействияТокенаДоступа);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОбновитьДанныеФормыИзБезопасногоХранилища()
	
	АвторизацияВКонтактеПараметры = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.АвторизацияВКонтактеПараметрыНовый( СпособАвторизации );
	ИнтеграцияСМагазинамиСоцСетейСервер.АвторизацияВКонтактеПараметрыИзБезопасногоХранилищеПолучить( УчетнаяЗапись, АвторизацияВКонтактеПараметры );
	    
	ТокенДоступа = Строка( АвторизацияВКонтактеПараметры.access_token );
	ТокенДоступаСообщества = Строка( АвторизацияВКонтактеПараметры.access_token_community );
	
КонецПроцедуры

&НаКлиенте
Функция ПризнакАвторизацииВидимостьОбновить()
	УспешнаяАвторизация = ЗначениеЗаполнено( ТокенДоступа );
	
	Элементы.КнопкаОк.Доступность = УспешнаяАвторизация;
    Элементы.ГруппаУспешнаяАвторизация.Видимость = УспешнаяАвторизация;
    Элементы.ГруппаОшибкаАвторизации.Видимость = Не УспешнаяАвторизация;
    
    Если УспешнаяАвторизация Тогда
    	ТекущийЭлемент = Элементы.КнопкаОк;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьТокенДоступаСообществаНаКлиенте() 

	Если ЗначениеЗаполнено(КодПриложения) Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(ПолучитьСсылкуНаСтрокуАвторизацииНаКлиенте(Истина));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СтрокаАвторизацииПослеИзменения()

	ТокенДоступа = "";
    ПризнакАвторизацииВидимостьОбновить();
    
    Если ПустаяСтрока( СтрокаАвторизации ) Тогда
    	Возврат;
    КонецЕсли;
    
	Если СпособАвторизации = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииOAUTH()
	Или АвторизацияСообщества Тогда
	
		ОбработатьСтрокуАвторизацииНаКлиенте( АвторизацияСообщества );
		
	ИначеЕсли СпособАвторизации = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.СпособАвторизацииVKID() Тогда
		
		ПараметрыURL = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.ПараметрыURLПолучить( СтрокаАвторизации );
		
		АвторизацияВКонтактеПараметры.code = ПараметрыURL.Получить( "code" );
		АвторизацияВКонтактеПараметры.device_id = ПараметрыURL.Получить( "device_id" );
		
		Если ПустаяСтрока( АвторизацияВКонтактеПараметры.code )
		Или ПустаяСтрока( АвторизацияВКонтактеПараметры.device_id ) Тогда
			ОшибкаТекст = НСтр( "ru = 'В строке авторизации не заполнены обязательные параметры: code, device_id'" );
			ОбщегоНазначенияКлиент.СообщитьПользователю( ОшибкаТекст );
			Возврат;
		КонецЕсли;
		
		ТекущаяДатаСеансаКлиент = ОбщегоНазначенияКлиент.ДатаСеанса();
		ОтветДанные = ИнтеграцияСМагазинамиСоцСетейВызовСервера.АвторизацияVKIDПоменятьКодНаТокен( АвторизацияВКонтактеПараметры );

		Если Не ОтветДанные.Свойство( "error" ) Тогда

			ТокенДоступа = ОтветДанные.access_token;
			ЗаполнитьЗначенияСвойств( АвторизацияВКонтактеПараметры, ОтветДанные );
			
			АвторизацияВКонтактеПараметры.ОкончанияДействияТокенаДоступа = ТекущаяДатаСеансаКлиент + ОтветДанные.expires_in;
			
		КонецЕсли;
	
	Иначе

		ОшибкаШаблон = НСтр( "ru = 'Способ авторизации задан некорректно: %1. Необходимо обратиться в техническую поддержку 1С.'" );
		ОшибкаТекст = СтрШаблон( ОшибкаШаблон, СпособАвторизации );
		ОбщегоНазначенияКлиент.СообщитьПользователю( ОшибкаТекст );
		
		Возврат;
	
	КонецЕсли;
	
	ПризнакАвторизацииВидимостьОбновить();

КонецПроцедуры

#КонецОбласти