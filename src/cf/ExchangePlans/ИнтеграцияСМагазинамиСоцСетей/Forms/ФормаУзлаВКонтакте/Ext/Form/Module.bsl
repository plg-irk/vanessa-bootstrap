&НаСервере
Функция ПолучитьРасписаниеРегламентногоЗадания()
	
	РасписаниеРегламентногоЗадания = Неопределено;
	
	Если Объект.РасписаниеРегламентногоЗадания <> "" Тогда
		Попытка
			РасписаниеРегламентногоЗадания = ЗначениеИзСтрокиВнутр(Объект.РасписаниеРегламентногоЗадания);
		Исключение
			РасписаниеРегламентногоЗадания = Неопределено;
		КонецПопытки;
	КонецЕсли;
	
	Если ТипЗнч(РасписаниеРегламентногоЗадания) <> Тип("РасписаниеРегламентногоЗадания") Тогда
		РасписаниеРегламентногоЗадания =
		ИнтеграцияСМагазинамиСоцСетейСервер.ПолучитьРасписаниеРегламентногоЗаданияПоУмолчанию();
	КонецЕсли;
	
	Возврат РасписаниеРегламентногоЗадания;
	
КонецФункции

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Отказ = Истина Тогда
		Возврат;
	КонецЕсли;

	АвторизацияВКонтактеПараметры.УчетнаяЗапись = ТекущийОбъект.Ссылка;
	
	Если Не ТекущийОбъект.ПометкаУдаления Тогда
	
		УчетнаяЗапись = ТекущийОбъект.Ссылка;
		ИнтеграцияСМагазинамиСоцСетейСервер.АвторизацияВКонтактеПараметрыВБезопасноеХранилищеЗаписать( УчетнаяЗапись, АвторизацияВКонтактеПараметры );
		
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ФормаАвторизацииВКонтактеОткрыть( АвторизацияСообщества = Ложь )

	Если Не ЗначениеЗаполнено( Объект.КодПриложения ) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю( НСтр( "ru = 'Идентификатор приложения ВКонтакте не заполнен.'" ) );
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить( "КодПриложения", Объект.КодПриложения );
	ПараметрыФормы.Вставить( "ИдентификаторГруппы", Объект.ИдентификаторГруппы );
	ПараметрыФормы.Вставить( "АвторизацияВКонтактеПараметры", АвторизацияВКонтактеПараметры );
	ПараметрыФормы.Вставить( "МагазинДляИнтеграции", Объект.МагазинДляИнтеграции );
	ПараметрыФормы.Вставить( "СпособАвторизации", Объект.СпособАвторизации );
	ПараметрыФормы.Вставить( "АвторизацияСообщества", АвторизацияСообщества );
	ПараметрыФормы.Вставить( "УчетнаяЗапись", Объект.Ссылка );
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения( "ФормаАвторизацииВКонтактеПослеЗакрытия", ЭтотОбъект );
	ОткрытьФорму( "ПланОбмена.ИнтеграцияСМагазинамиСоцСетей.Форма.АвторизацияПриложенияВКонтакте", 
	ПараметрыФормы, ЭтотОбъект, ,,, ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца );
	
КонецПроцедуры

&НаКлиенте
Процедура ФормаАвторизацииВКонтактеПослеЗакрытия( РезультатЗакрытия, ДополнительныеПараметры ) Экспорт
	
	Если ТипЗнч( РезультатЗакрытия ) = Тип( "Структура" ) Тогда

		Модифицированность = Истина;

		ОшибкаАвторизации = Ложь;
		ОбновитьНаФормеПризнакОшибкиАвторизации();
		
		Объект.СпособАвторизации = РезультатЗакрытия.СпособАвторизации;
		
		АвторизацияСообществаСвойстваИмена = "access_token_community, ОкончанияДействияТокенДоступаСообщества";
		Если РезультатЗакрытия.АвторизацияСообщества Тогда
		
			ЗаполнитьЗначенияСвойств( АвторизацияВКонтактеПараметры, 
			РезультатЗакрытия.АвторизацияВКонтактеПараметры,
			АвторизацияСообществаСвойстваИмена );
			
			ДанныеАвторизацииСообществаЗаполнены = ИнтеграцияСМагазинамиСоцСетейКлиентСервер.ДанныеАвторизацииСообществаЗаполнены( АвторизацияВКонтактеПараметры );
			
		Иначе

			Объект.ИдентификаторПользователя = РезультатЗакрытия.ИдентификаторПользователя;
			
			ЗаполнитьЗначенияСвойств( АвторизацияВКонтактеПараметры, 
			РезультатЗакрытия.АвторизацияВКонтактеПараметры,
			,
			АвторизацияСообществаСвойстваИмена );
			
			ОбновитьСписокГруппНаСервере( Истина );
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

