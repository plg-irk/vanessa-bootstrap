#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Процедура создает пустую временную таблицу изменения движений.
//
Процедура СоздатьПустуюВременнуюТаблицуИзменение(ДополнительныеСвойства) Экспорт
	
	Если НЕ ДополнительныеСвойства.Свойство("ДляПроведения")
	 ИЛИ НЕ ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 0
	|	НДСАвансыПоДоговорамКомиссии.НомерСтроки КАК НомерСтроки,
	|	НДСАвансыПоДоговорамКомиссии.Комиссионер КАК Комиссионер,
	|	НДСАвансыПоДоговорамКомиссии.СчетФактура КАК СчетФактура,
	|	НДСАвансыПоДоговорамКомиссии.СтавкаНДС КАК СтавкаНДС,
	|	НДСАвансыПоДоговорамКомиссии.Покупатель КАК Покупатель,
	|	НДСАвансыПоДоговорамКомиссии.ДатаСобытия КАК ДатаСобытия,
	|	НДСАвансыПоДоговорамКомиссии.СуммаБезНДС КАК КоличествоПередЗаписью,
	|	НДСАвансыПоДоговорамКомиссии.СуммаБезНДС КАК КоличествоИзменение,
	|	НДСАвансыПоДоговорамКомиссии.СуммаБезНДС КАК КоличествоПриЗаписи,
	|	НДСАвансыПоДоговорамКомиссии.Организация КАК Организация
	|ПОМЕСТИТЬ ДвиженияНДСАвансыПоДоговорамКомиссииИзменение
	|ИЗ
	|	РегистрНакопления.НДСАвансыПоДоговорамКомиссии КАК НДСАвансыПоДоговорамКомиссии");
	
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	//@skip-warning используется для создания временной таблицы
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураВременныеТаблицы.Вставить("ДвиженияНДСАвансыПоДоговорамКомиссииИзменение", Ложь);
	
КонецПроцедуры // СоздатьПустуюВременнуюТаблицуИзменение()

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.УправлениеДоступом

// Параметры:
//   Ограничение - см. УправлениеДоступомПереопределяемый.ПриЗаполненииОграниченияДоступа.Ограничение.
//
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт

	Ограничение.Текст =
	"РазрешитьЧтениеИзменение
	|ГДЕ
	|	ЗначениеРазрешено(Организация)";

КонецПроцедуры

