//
// Возвращаемое значение:
//   Структура:
//   	* ВсегоРасходов				- Число
//   	* ИспользованныйВычет		- Число
//   	* Остаток					- Число
//   	* ДокументРасхода			- Неопределено
//
Функция НовыйИнформацияПоСуммамРасходов()
	
	Результат = Новый Структура;
	Результат.Вставить("ВсегоРасходов", 		0);
	Результат.Вставить("ИспользованныйВычет",	0);
	Результат.Вставить("Остаток", 				0);
	Результат.Вставить("ДокументРасхода",		 Неопределено);
	
	Возврат Результат;
	
