// СтандартныеПодсистемы.ВариантыОтчетов

// Вызывается при работе в модели сервиса для получения сведений о предопределенных вариантах отчета.
//
// Возвращаемое значение:
//  Массив из Структура:
//    * Имя           - Строка - имя варианта отчета; например, "Основной";
//    * Представление - Строка - имя варианта отчета; например, НСтр("ru = 'Динамика изменений файлов'").
//
Функция ВариантыНастроек() Экспорт 
	
	Результат = Новый Массив;
	Результат.Добавить(Новый Структура("Имя, Представление", "ДвижениеДенежныхСредствПоПроектам", 
		НСтр("ru = 'Движение денежных средств по проектам'")));
	Результат.Добавить(Новый Структура("Имя, Представление", "ДинамикаДвиженияДенежныхСредствПоПроектам", 
		НСтр("ru = 'Динамика движения денежных средств по проектам'")));
	Возврат Результат;
	
КонецФункции

// Параметры:
//   Настройки - см. ВариантыОтчетовПереопределяемый.НастроитьВариантыОтчетов.Настройки.
//   НастройкиОтчета - см. ВариантыОтчетов.ОписаниеОтчета.
//
Процедура НастроитьВариантыОтчета(Настройки, НастройкиОтчета) Экспорт
	
	ВариантыОтчетов.УстановитьРежимВыводаВПанеляхОтчетов(Настройки, НастройкиОтчета, Истина);
	НастройкиОтчета.ОпределитьНастройкиФормы = Истина;
			
	Вариант = ВариантыОтчетов.ОписаниеВарианта(Настройки, Метаданные.Отчеты.ДвижениеДенежныхСредствПоПроектам, "ДвижениеДенежныхСредствПоПроектам");
	Вариант.Описание = НСтр("ru = 'Отчет содержит данные о движении денежных средств в разрезе проектов.'");
	Вариант.Размещение.Вставить(Метаданные.Подсистемы.Деньги.Подсистемы.Деньги, "Важный");
	Вариант.Размещение.Вставить(ВариантыОтчетовКлиентСервер.ИдентификаторНачальнойСтраницы());
	Вариант.ФункциональныеОпции.Добавить("УчетПоПроектам");

	Вариант = ВариантыОтчетов.ОписаниеВарианта(Настройки, Метаданные.Отчеты.ДвижениеДенежныхСредствПоПроектам, "ДинамикаДвиженияДенежныхСредствПоПроектам");
	Вариант.Описание = НСтр("ru = 'Отчет показывает динамику движения денежных средств в разрезе проектов за указанный период.'");
	Вариант.Размещение.Вставить(Метаданные.Подсистемы.Деньги.Подсистемы.Деньги, "Важный");
	Вариант.ФункциональныеОпции.Добавить("УчетПоПроектам");
	Вариант.ВидимостьПоУмолчанию = Ложь;
		
КонецПроцедуры

