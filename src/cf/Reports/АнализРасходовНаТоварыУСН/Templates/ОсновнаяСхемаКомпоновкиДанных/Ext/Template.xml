		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Товары
		ПО ПартииТоваровУСН.Номенклатура = Товары.Ссылка
			И (Товары.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас))
ГДЕ
	ПартииТоваровУСН.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
;

