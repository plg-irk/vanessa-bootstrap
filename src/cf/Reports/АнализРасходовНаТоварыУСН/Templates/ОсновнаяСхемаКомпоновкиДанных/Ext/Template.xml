	ВТПартииТоваров.Регистратор,
	ВТПартииТоваров.Организация,
	ВТПартииТоваров.Номенклатура,
	ВТПартииТоваров.ДокументПартии,
	ВТПартииТоваров.ДокументРегистрацииВКУДиР,
	ВТПартииТоваров.ОтражатьВКУДиР,
	0,
	0,
	0,
	ВТПартииТоваров.Количество,
	ВТПартииТоваров.Сумма,
	ВТПартииТоваров.СуммаНДС,
	0,
	0,
