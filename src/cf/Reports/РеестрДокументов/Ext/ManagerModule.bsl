#Область ПрограммныйИнтерфейс

// Конструктор данных заполнения настроек списка.
// 
// Возвращаемое значение:
//  Структура - Данные заполнения:
//  * ЗаголовокФормы - Строка - Заголовок формы.
//  * ИмяТаблицы - Строка - Имя таблицы.
//  * ИмяКоманды - Строка - Имя команды.
//  * ДополнительныеПоля - Массив из Строка - Наименования дополнительных полей для использования в отчете
//  * ЗаменяемыеЗаголовкиПолей - Структура - Заменяемые заголовки полей, где ключ - исходный заголовок,
//  										 значение - новый заголовок поля.
//  * ЗаменяемыеПоляВыбора - Структура - Заменяемые поля выбора, где ключ - исходное имя поля,
//  										значение - имя соответствующего ему поля текущего списка.
//
Функция ПараметрыОтчета() Экспорт
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("ЗаголовокФормы", "");
	ДанныеЗаполнения.Вставить("ИмяТаблицы", "");
	ДанныеЗаполнения.Вставить("ИмяКоманды", "");
	ДанныеЗаполнения.Вставить("ДополнительныеПоля", Новый Массив);
	ДанныеЗаполнения.Вставить("ЗаменяемыеЗаголовкиПолей", Новый Структура);
	ДанныеЗаполнения.Вставить("ЗаменяемыеПоляВыбора", Новый Структура);
	
	Возврат ДанныеЗаполнения;
	
КонецФункции

// Получает настройки динамического списка и сохраняет их во временное хранилище для использования в отчете
// РеестрДокументов
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  ПараметрыОтчета - см. Отчеты.РеестрДокументов.ПараметрыОтчета
//
Процедура НастройкиДинамическогоСписка(Форма, ПараметрыОтчета) Экспорт
	
	Элементы = Форма.Элементы;
	ИмяТаблицы = ПараметрыОтчета.ИмяТаблицы;
	
	НастройкиСписка = Новый Структура("Ключ, Период");
	Ключ = Новый Структура;
	Ключ.Вставить("ТекстЗапроса", "");
	Ключ.Вставить("НастройкиКомпоновки", Новый НастройкиКомпоновкиДанных());
	Ключ.Вставить("ДополнительныеПоля", Новый Массив);
	Ключ.Вставить("ЗаголовокФормы", "");
	Ключ.Вставить("ЗаменяемыеЗаголовкиПолей", Новый Структура);
	Ключ.Вставить("ЗаменяемыеПоляВыбора", Новый Структура);
	НастройкиСписка.Ключ = Ключ;
	
	ТаблицаКоманды = ПолучитьИзВременногоХранилища(Форма.ПараметрыПодключаемыхКоманд.АдресТаблицыКоманд);
	СтрокаТаблицы  = Неопределено;
	ИмяКомандыВФорме = ?(ПустаяСтрока(ПараметрыОтчета.ИмяКоманды), "РеестрДокументов", ПараметрыОтчета.ИмяКоманды);
	
	Для Каждого СтрокаТаблицыКоманды Из ТаблицаКоманды Цикл
		Если СтрНайти(СтрокаТаблицыКоманды.ИмяВФорме, ИмяКомандыВФорме) <> 0 Тогда
			СтрокаТаблицы = СтрокаТаблицыКоманды;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если СтрокаТаблицы <> Неопределено Тогда
		СтрокаТаблицы.ДополнительныеПараметры.ДополнительныеПараметры.Вставить(
			"АдресХранилищаНастроекСпискаДляРеестра", Форма.АдресХранилищаНастроекСпискаДляРеестра);
		ПоместитьВоВременноеХранилище(ТаблицаКоманды, Форма.ПараметрыПодключаемыхКоманд.АдресТаблицыКоманд);
	КонецЕсли;
	
	СхемаКомпоновки     = Элементы[ИмяТаблицы].ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	НастройкиКомпоновки = Элементы[ИмяТаблицы].ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	
	НастройкиСписка.Ключ.ЗаголовокФормы = ПараметрыОтчета.ЗаголовокФормы;
	НастройкиСписка.Ключ.ТекстЗапроса        = СхемаКомпоновки.НаборыДанных.НаборДанныхДинамическогоСписка.Запрос;
	НастройкиСписка.Ключ.НастройкиКомпоновки = НастройкиКомпоновки;
	НастройкиСписка.Ключ.ДополнительныеПоля = ПараметрыОтчета.ДополнительныеПоля;
	НастройкиСписка.Ключ.ЗаменяемыеЗаголовкиПолей = ПараметрыОтчета.ЗаменяемыеЗаголовкиПолей;
	НастройкиСписка.Ключ.ЗаменяемыеПоляВыбора = ПараметрыОтчета.ЗаменяемыеПоляВыбора;
	
	// Для минимизации случаев получения документов за неограниченный период используем следующую последовательность
	// получения периода:
	//  1. В реквизитах формы.
	//  2. В отборе динамического списка.
	//  3. От начала месяца документа текущей строки списка до конца текущего месяца пользователя.
	//  4. Текущий месяц пользователя.
	
	НастройкиСписка.Период = Новый СтандартныйПериод();
	ПериодОтчета = Новый СтандартныйПериод;
	
	ЕстьПериодФормы = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ОтборПериод");
	Если ЕстьПериодФормы Тогда
		ПериодСписка = Форма.ОтборПериод;
	Иначе
		ПериодСписка = ПериодИзОтбораДинамическогоСписка(НастройкиКомпоновки.Отбор);
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ПериодОтчета, ПериодСписка);
	
	ТекущаяДатаПользователя = ОбщегоНазначения.ТекущаяДатаПользователя();
	
	Если Не ЗначениеЗаполнено(ПериодОтчета) Тогда
		ВыделенныеСтроки = Элементы[ИмяТаблицы].ВыделенныеСтроки;
		КоличествоДокументов = ВыделенныеСтроки.Количество();
		Если КоличествоДокументов = 1 Тогда
			ВыделеннаяСтрока = ВыделенныеСтроки[0];
			Если ТипЗнч(ВыделеннаяСтрока) = Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
				ПериодОтчета.ДатаНачала = НачалоМесяца(ТекущаяДатаПользователя);
			Иначе
				ДатаДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыделеннаяСтрока, "Дата");
				ПериодОтчета.ДатаНачала = НачалоМесяца(ДатаДокумента);
			КонецЕсли;
			Если КонецМесяца(ТекущаяДатаПользователя) > КонецМесяца(ДатаДокумента) Тогда
				ПериодОтчета.ДатаОкончания = КонецМесяца(ТекущаяДатаПользователя);
			Иначе
				ПериодОтчета.ДатаОкончания = КонецМесяца(ДатаДокумента);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПериодОтчета) Тогда
		ДатаОтчета = ОбщегоНазначения.ТекущаяДатаПользователя();
		НастройкиСписка.Период.ДатаНачала = НачалоМесяца(ДатаОтчета);
		НастройкиСписка.Период.ДатаОкончания = КонецМесяца(ДатаОтчета);
	Иначе
		ЗаполнитьЗначенияСвойств(НастройкиСписка.Период, ПериодОтчета);
	КонецЕсли;
	
	// Уберем период из отбора, так как будем устанавливать его в отчете.
	ОчиститьПериодВОтборе(НастройкиКомпоновки.Отбор.Элементы);
	
	ПоместитьВоВременноеХранилище(НастройкиСписка, Форма.АдресХранилищаНастроекСпискаДляРеестра);
	
КонецПроцедуры

// Возвращает синоним объекта.
// 
// Параметры:
//  Ссылка - ЛюбаяСсылка
// 
// Возвращаемое значение:
//  Строка
//  
Функция ПредставлениеДокумента(Ссылка) Экспорт
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		ВидОперации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ВидОперации");
		Если ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд Тогда
			ПредставлениеДокумента = НСтр("ru = 'Заказ-наряд'");
		Иначе
			ПредставлениеДокумента = НСтр("ru = 'Заказ покупателя'");
		КонецЕсли;
	Иначе
		ПредставлениеДокумента = Ссылка.Метаданные().Синоним;
	КонецЕсли;
	
	Возврат ПредставлениеДокумента;
	
КонецФункции

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.ВариантыОтчетов

// Вызывается при работе в модели сервиса для получения сведений о предопределенных вариантах отчета.
//
// Возвращаемое значение:
//  Массив из Структура:
//    * Имя           - Строка - имя варианта отчета; например, "Основной";
//    * Представление - Строка - имя варианта отчета; например, НСтр("ru = 'Динамика изменений файлов'").
//
Функция ВариантыНастроек() Экспорт 
	
	Результат = Новый Массив;
	Результат.Добавить(Новый Структура("Имя, Представление", "Основной", 
		НСтр("ru = 'Реестр документов'")));
		
	Возврат Результат;
	
КонецФункции

// См. ВариантыОтчетовПереопределяемый.НастроитьВариантыОтчетов.
// Параметры:
//   Настройки - см. ВариантыОтчетовПереопределяемый.НастроитьВариантыОтчетов.Настройки.
//   НастройкиОтчета - см. ВариантыОтчетов.ОписаниеОтчета.
//
Процедура НастроитьВариантыОтчета(Настройки, НастройкиОтчета) Экспорт
	
	ВариантыОтчетов.УстановитьРежимВыводаВПанеляхОтчетов(Настройки, НастройкиОтчета, Ложь);
	НастройкиОтчета.ОпределитьНастройкиФормы = Истина;
	
	Вариант = ВариантыОтчетов.ОписаниеВарианта(Настройки, Метаданные.Отчеты.РеестрДокументов, "Основной");
	Вариант.Описание = НСтр("ru = 'Отчет предназначен для вывода реестра из списка документов.'");
	
КонецПроцедуры


// Конец СтандартныеПодсистемы.ВариантыОтчетов

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОчиститьПериодВОтборе(КоллекцияЭлементовОтбора)
	
	ГруппаОтбор = ОбщегоНазначенияКлиентСервер.НайтиЭлементОтбораПоПредставлению(КоллекцияЭлементовОтбора, "Период");
	Если ГруппаОтбор <> Неопределено Тогда
		КоллекцияЭлементовОтбора.Удалить(ГруппаОтбор);
	КонецЕсли;
	
КонецПроцедуры

Функция ПериодИзОтбораДинамическогоСписка(Отбор)
	
	Период = Новый СтандартныйПериод;
	
	ЭлементыОтбора = ОбщегоНазначенияКлиентСервер.НайтиЭлементыИГруппыОтбора(Отбор, "Дата");
	Если ЭлементыОтбора.Количество() <> 0 Тогда
		Для каждого ЭлементОтбора Из ЭлементыОтбора Цикл
			
			Если Не ЭлементОтбора.Использование Тогда
				Продолжить;
			КонецЕсли;
			
			ПравоеЗначение = ЭлементОтбора.ПравоеЗначение;
			
			Если ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.БольшеИлиРавно Тогда
				Период.ДатаНачала = ПравоеЗначение;
			Иначе
				Период.ДатаОкончания = ПравоеЗначение;
			КонецЕсли;
			
		КонецЦикла;
	Иначе
		
	КонецЕсли;
	
	Возврат Период;
	
КонецФункции

#КонецОбласти

#КонецЕсли
