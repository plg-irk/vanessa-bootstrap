#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

#Область ДляВызоваИзДругихПодсистем

 //СтандартныеПодсистемы.ВариантыОтчетов

// Задать настройки формы отчета.
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения
//         - Неопределено
//   КлючВарианта - Строка
//                - Неопределено
//   Настройки - см. ОтчетыКлиентСервер.НастройкиОтчетаПоУмолчанию
//
Процедура ОпределитьНастройкиФормы(Форма, КлючВарианта, Настройки) Экспорт

	Настройки.РазрешеноИзменятьВарианты = Истина;
	Настройки.РазрешеноЗагружатьСхему = Ложь;
	Настройки.РазрешеноРедактироватьСхему = Ложь;
	Настройки.События.ПриСозданииНаСервере = Истина;
	Настройки.События.ПередЗагрузкойНастроекВКомпоновщик = Истина;
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ВариантыОтчетов

// Вызывается в обработчике одноименного события формы отчета после выполнения кода формы.
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения - Форма отчета.
//   Отказ - Булево - Передается из параметров обработчика "как есть".
//   СтандартнаяОбработка - Булево - Передается из параметров обработчика "как есть".
//
// См. также:
//   "ФормаКлиентскогоПриложения.ПриСозданииНаСервере" в синтакс-помощнике.
//
Процедура ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка) Экспорт
	
	ОтчетыУНФ.ФормаОтчетаПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка);
	
	Если НЕ (Форма.Параметры.Свойство("Ключ") И ТипЗнч(Форма.Параметры.Ключ) = Тип("Структура")) Тогда
		ТекстСообщения = НСтр("ru = 'Реестр документов может быть сформирован только из формы списка документов'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,, Отказ);
	КонецЕсли;
	
КонецПроцедуры

// Вызывается перед загрузкой новых настроек. Используется для изменения СКД отчета.
//
// Параметры:
//   Контекст - Произвольный
//   КлючСхемы - Строка
//   КлючВарианта - Строка
//                - Неопределено
//   НовыеНастройкиКД - НастройкиКомпоновкиДанных
//                    - Неопределено
//   НовыеПользовательскиеНастройкиКД - ПользовательскиеНастройкиКомпоновкиДанных
//                                    - Неопределено
//
Процедура ПередЗагрузкойНастроекВКомпоновщик(Контекст, КлючСхемы, КлючВарианта, НовыеНастройкиКД,
	НовыеПользовательскиеНастройкиКД) Экспорт
	
	Если КлючСхемы <> КлючВарианта Тогда
		КлючСхемы = КлючВарианта;
		Если ТипЗнч(Контекст) = Тип("ФормаКлиентскогоПриложения") И НовыеНастройкиКД <> Неопределено Тогда
			Если Не Контекст.Параметры.Свойство("Ключ") Тогда
				Возврат;
			КонецЕсли;
			
			НастройкиКомпоновщикаИсточника = Контекст.Параметры.Ключ.НастройкиКомпоновки;
			ПериодРеестра = Контекст.Параметры.Период;
			ЗаменяемыеЗаголовкиПолей = Контекст.Параметры.Ключ.ЗаменяемыеЗаголовкиПолей;
			ЗаменяемыеПоляВыбора = Контекст.Параметры.Ключ.ЗаменяемыеПоляВыбора;
			ДополнительныеПоля = Контекст.Параметры.Ключ.ДополнительныеПоля;
			ЗаголовокСписка = Контекст.Параметры.Ключ.ЗаголовокФормы;
			ТекстЗапроса = Контекст.Параметры.Ключ.ТекстЗапроса;
			
			ДополнитьТекстЗапросаПериодом(ПериодРеестра, ТекстЗапроса);
			
			СхемаКомпоновкиДанныхЭталон = Отчеты.РеестрДокументов.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
			// Заменим эталонный набор данных новым по полученному тексту запроса
			ЗаменитьНаборДанныхПоТекстуЗапроса(СхемаКомпоновкиДанныхЭталон, ТекстЗапроса, ЗаменяемыеПоляВыбора);
			// Обновим отборы по полученным из формы списка
			ЗаполнитьОтборыКД(НастройкиКомпоновщикаИсточника.Отбор.Элементы, НовыеНастройкиКД.Отбор.Элементы,
				НовыеНастройкиКД.Отбор);
			ЗаполнитьПредставленияПолей(СхемаКомпоновкиДанныхЭталон, ЗаменяемыеЗаголовкиПолей);
			ЗаполнитьПериодФормы(ПериодРеестра);
			ОтчетыУНФ.УстановитьОтборДляПараметра("Период", ПериодРеестра, НовыеНастройкиКД,
				НовыеПользовательскиеНастройкиКД);
			ЗаполнитьЭлементыПользовательскихНастроек(НовыеПользовательскиеНастройкиКД, НовыеНастройкиКД.Отбор);
			ВключитьИспользованиеДополнительныхПолей(НовыеНастройкиКД.Выбор.Элементы, ДополнительныеПоля);
			ШаблонЗаголовок = НСтр("ru = 'Реестр документов ""%1""'");
			ЗаголовокФормы = СтрШаблон(ШаблонЗаголовок, ЗаголовокСписка);
			
			НовыеНастройкиКД.ПараметрыВывода.УстановитьЗначениеПараметра("Заголовок", ЗаголовокФормы); 
			ОтчетыСервер.ПодключитьСхему(ЭтотОбъект, Контекст, СхемаКомпоновкиДанныхЭталон, КлючСхемы);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

Процедура ВключитьИспользованиеДополнительныхПолей(НастройкиВыборЭлементы, ДополнительныеПоля)
	
	Для Каждого ИмяПоля из ДополнительныеПоля Цикл
		Для Каждого ТекЭл Из НастройкиВыборЭлементы Цикл
	        Если Строка(ТекЭл.Поле) = ИмяПоля Тогда
	            ТекЭл.Использование = Истина;
	        КонецЕсли;
		КонецЦикла;  
	КонецЦикла;
	
КонецПроцедуры

Процедура ДополнитьТекстЗапросаПериодом(Период, ТекстЗапроса)
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.РежимКомпоновкиДанных = Истина;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	ПакетЗапросов    = СхемаЗапроса.ПакетЗапросов[СхемаЗапроса.ПакетЗапросов.Количество() - 1];
	Оператор         = ПакетЗапросов.Операторы[0];
	ИсточникЗапроса  = Оператор.Источники[0];
	Псевдоним        = ИсточникЗапроса.Источник.Псевдоним;
	ВыраженияОтбораКомпоновкиДанных = Оператор.ВыраженияОтбораКомпоновкиДанных;
	
	ВыражениеОтбора = "Псевдоним.Дата >= &НачалоПериода И Псевдоним.Дата <= &ОкончаниеПериода";
	ВыражениеОтбора = СтрЗаменить(ВыражениеОтбора, "Псевдоним", Псевдоним);
	
	ОтборПоДате = ВыраженияОтбораКомпоновкиДанных.Добавить(ВыражениеОтбора);
	ОтборПоДате.Псевдоним = "";
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	
КонецПроцедуры

Процедура ЗаменитьНаборДанныхПоТекстуЗапроса(СхемаЭталон, ТекстЗапроса, ЗаменяемыеПоля)

	НаборДанных = СхемаЭталон.НаборыДанных.Добавить(Тип("НаборДанныхЗапросСхемыКомпоновкиДанных"));
	НаборДанных.Имя = "НаборДанных1";
	НаборДанных.ИсточникДанных = "ИсточникДанных1";
	НаборДанных.Запрос = ТекстЗапроса;
	НаборДанных.АвтоЗаполнениеДоступныхПолей = Истина;
	
	Для каждого ПолеЭталон Из СхемаЭталон.НаборыДанных.НаборДанныхЭталон.Поля Цикл
		ПолеСхемыКомпоновки = НаборДанных.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
		ЗаполнитьЗначенияСвойств(ПолеСхемыКомпоновки, ПолеЭталон);
		Если ЗаменяемыеПоля.Свойство(ПолеСхемыКомпоновки.Поле) Тогда
			ПолеСхемыКомпоновки.Поле = ЗаменяемыеПоля[ПолеСхемыКомпоновки.Поле];
		КонецЕсли;
		
		Для каждого ОформлениеЭталон Из ПолеЭталон.Оформление.Элементы Цикл
			Оформление = ПолеСхемыКомпоновки.Оформление.Элементы.Найти(ОформлениеЭталон.Параметр);
			ЗаполнитьЗначенияСвойств(Оформление, ОформлениеЭталон);
		КонецЦикла;
	КонецЦикла;
	
	НаборЭталон = СхемаЭталон.НаборыДанных.НаборДанныхЭталон;
	СхемаЭталон.НаборыДанных.Удалить(НаборЭталон);
	
КонецПроцедуры

Процедура ЗаполнитьОтборыКД(ЭлементыИсточник, ЭлементыПриемник, КоллекцияПриемник)
	
	Для каждого ЭлементОтбораИсточник Из ЭлементыИсточник Цикл
		
		Если ЭлементОтбораИсточник.Использование = Ложь Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЭлементОтбораИсточник) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда
			// Все отборы добавляем в корневую коллекцию
			ЗаполнитьОтборыКД(ЭлементОтбораИсточник.Элементы, ЭлементыПриемник, КоллекцияПриемник);
			Продолжить;
		КонецЕсли;
		
		ЭлементНастройки = ОбщегоНазначенияКлиентСервер.НайтиЭлементыИГруппыОтбора(КоллекцияПриемник, Строка(
			ЭлементОтбораИсточник.ЛевоеЗначение));
		// Проверяем, есть ли элемент отбора в "стандартных" отборах
		Если ЭлементНастройки.Количество() <> 0 Тогда
			ЭлементНастройкиПриемник = ЭлементНастройки[0];
			ЗаполнитьЗначенияСвойств(ЭлементНастройкиПриемник, ЭлементОтбораИсточник, ,
				"ИдентификаторПользовательскойНастройки");
			ЭлементНастройкиПриемник.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
			Если ТипЗнч(ЭлементНастройкиПриемник.ПравоеЗначение) = Тип("СписокЗначений")
				И ЭлементНастройкиПриемник.ПравоеЗначение.Количество() = 1 Тогда
				ЭлементНастройкиПриемник.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			КонецЕсли;
		Иначе
			ЭлементНастройкиПриемник = ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(КоллекцияПриемник,
				Строка(ЭлементОтбораИсточник.ЛевоеЗначение), ВидСравненияКомпоновкиДанных.Равно);
			ЗаполнитьЗначенияСвойств(ЭлементНастройкиПриемник, ЭлементОтбораИсточник, , "Представление");
			ЭлементНастройкиПриемник.ИдентификаторПользовательскойНастройки = Строка(Новый УникальныйИдентификатор);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьПериодФормы(Знач ПериодРеестра)
	
	Если ЗначениеЗаполнено(ПериодРеестра) Тогда
		ДатаНачала = ПериодРеестра.ДатаНачала;
		ДатаОкончания = ПериодРеестра.ДатаОкончания;
		Настройки = КомпоновщикНастроек.ПолучитьНастройки();
		КомпоновкаДанныхКлиентСервер.УстановитьПараметр(Настройки, "Период", ПериодРеестра, Истина);
		КомпоновкаДанныхКлиентСервер.УстановитьПараметр(Настройки, "НачалоПериода", ДатаНачала, Истина);
		КомпоновкаДанныхКлиентСервер.УстановитьПараметр(Настройки, "КонецПериода", ДатаОкончания, Истина);
		КомпоновщикНастроек.ЗагрузитьНастройки(Настройки);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПредставленияПолей(Схема, ПредставленияПолей)
	
	Если не ЗначениеЗаполнено(ПредставленияПолей) Тогда
		Возврат;
	КонецЕсли;
	
	ПоляСхемы = Схема.НаборыДанных[0].Поля;
	Для каждого ПолеСхемы из ПоляСхемы Цикл
		Если ПредставленияПолей.Свойство(ПолеСхемы.Поле) Тогда
			ПолеСхемы.Заголовок = ПредставленияПолей[ПолеСхемы.Поле];
		КонецЕсли;
		
	КонецЦикла
	
КонецПроцедуры

Процедура ЗаполнитьЭлементыПользовательскихНастроек(НовыеПользовательскиеНастройкиКД, НастройкиОтбор)
	
	Для каждого Элемент из НастройкиОтбор.Элементы Цикл
		Если ЗначениеЗаполнено(Элемент.ИдентификаторПользовательскойНастройки) Тогда
			Для Каждого ТекущийЭлемент Из НовыеПользовательскиеНастройкиКД.Элементы Цикл
				Если ТекущийЭлемент.ИдентификаторПользовательскойНастройки
					= Элемент.ИдентификаторПользовательскойНастройки Тогда
					ЭлементПользовательскойНастройки = ТекущийЭлемент;
					ЗаполнитьЗначенияСвойств(ЭлементПользовательскойНастройки, Элемент,
						"Использование, ВидСравнения, ПравоеЗначение");
					Если ТипЗнч("Элемент.ПравоеЗначение") = Тип("СписокЗначений")
						И Элемент.ПравоеЗначение.Количество() = 0 Тогда
						ЭлементПользовательскойНастройки.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
						ЭлементПользовательскойНастройки.ПравоеЗначение = Элемент.ПравоеЗначение[0];
					КонецЕсли;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли