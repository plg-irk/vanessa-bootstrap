		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВЫБОР
		КОГДА ВидыДисконтныхКарт.ТипКарты = ЗНАЧЕНИЕ(Перечисление.ТипыКарт.Магнитная)
			ТОГДА ДисконтныеКарты.КодКартыМагнитный
		ИНАЧЕ ДисконтныеКарты.КодКартыШтрихкод
	КОНЕЦ КАК КодКарты,
	Контрагенты.Ссылка КАК ВладелецДисконтнойКарты,
	Контрагенты.НомерТелефонаДляПоиска КАК НомерТелефона,
	ДисконтныеКарты.Ссылка КАК ДисконтнаяКарта,
	ЕСТЬNULL(БонусныеБаллыОстатки.НачисленоОстаток, 0) - ЕСТЬNULL(БонусныеБаллыОстатки.КСписаниюОстаток, 0) КАК ОстатокБонусныхБаллов,
	ЕСТЬNULL(ПродажиПоДисконтнымКартамОбороты.СуммаОборот, 0) КАК ОборотПродаж,
	ВидыДисконтныхКарт.ЭтоИменнаяКарта КАК ЭтоИменнаяКарта,
	ВидыДисконтныхКарт.Ссылка КАК ВидДисконтнойКарты
ПОМЕСТИТЬ втДанныеКарт
ИЗ
	Справочник.ДисконтныеКарты КАК ДисконтныеКарты
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
		ПО ДисконтныеКарты.ВладелецКарты = Контрагенты.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыДисконтныхКарт КАК ВидыДисконтныхКарт
		ПО ДисконтныеКарты.Владелец = ВидыДисконтныхКарт.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.БонусныеБаллы.Остатки КАК БонусныеБаллыОстатки
		ПО ДисконтныеКарты.Ссылка = БонусныеБаллыОстатки.БонуснаяКарта
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПродажиПоДисконтнымКартам.Обороты КАК ПродажиПоДисконтнымКартамОбороты
		ПО ДисконтныеКарты.Ссылка = ПродажиПоДисконтнымКартамОбороты.ДисконтнаяКарта
ГДЕ
	НЕ ДисконтныеКарты.КартаНедействительна
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втДанныеКарт.ВладелецДисконтнойКарты КАК ВладелецДисконтнойКарты,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ втДанныеКарт.ДисконтнаяКарта) КАК КоличествоДисконтныхКарт
ПОМЕСТИТЬ втДублиПоВладельцу
ИЗ
	втДанныеКарт КАК втДанныеКарт
ГДЕ
	втДанныеКарт.ЭтоИменнаяКарта

СГРУППИРОВАТЬ ПО
	втДанныеКарт.ВладелецДисконтнойКарты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ втДанныеКарт.ДисконтнаяКарта) КАК КоличествоДисконтныхКарт,
	втДанныеКарт.КодКарты КАК КодКарты
ПОМЕСТИТЬ втДублиПоКодуКарты
ИЗ
	втДанныеКарт КАК втДанныеКарт
ГДЕ
	втДанныеКарт.ЭтоИменнаяКарта

СГРУППИРОВАТЬ ПО
	втДанныеКарт.КодКарты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ втДанныеКарт.ДисконтнаяКарта) КАК КоличествоДисконтныхКарт,
	втДанныеКарт.НомерТелефона КАК НомерТелефона
ПОМЕСТИТЬ втДублиПоНомеруТелефона
ИЗ
	втДанныеКарт КАК втДанныеКарт
ГДЕ
	втДанныеКарт.ЭтоИменнаяКарта

СГРУППИРОВАТЬ ПО
	втДанныеКарт.НомерТелефона
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втДанныеКарт.ДисконтнаяКарта КАК ДисконтнаяКарта,
	МАКСИМУМ(ПродажиПоДисконтнымКартамОбороты.Период) КАК ПоследняяДатаПродажи
ПОМЕСТИТЬ втПоследняяДатаПродажи
ИЗ
	втДанныеКарт КАК втДанныеКарт
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПродажиПоДисконтнымКартам.Обороты(, , Запись, ) КАК ПродажиПоДисконтнымКартамОбороты
		ПО втДанныеКарт.ДисконтнаяКарта = ПродажиПоДисконтнымКартамОбороты.ДисконтнаяКарта

СГРУППИРОВАТЬ ПО
	втДанныеКарт.ДисконтнаяКарта
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	втДанныеКарт.КодКарты КАК КодКарты,
	втДанныеКарт.ВладелецДисконтнойКарты КАК ВладелецДисконтнойКарты,
	втДанныеКарт.НомерТелефона КАК НомерТелефона,
	втДанныеКарт.ДисконтнаяКарта КАК ДисконтнаяКарта,
	втДанныеКарт.ОстатокБонусныхБаллов КАК ОстатокБонусныхБаллов,
	втДанныеКарт.ОборотПродаж КАК ОборотПродаж,
	втПоследняяДатаПродажи.ПоследняяДатаПродажи КАК ПоследняяДатаПродажи,
	ЕСТЬNULL(втДублиПоВладельцу.КоличествоДисконтныхКарт, 0) КАК КоличествоДисконтныхКартПоВладельцу,
	втДанныеКарт.ВидДисконтнойКарты КАК ВидДисконтнойКарты,
	ЕСТЬNULL(втДублиПоКодуКарты.КоличествоДисконтныхКарт, 0) КАК КоличествоДисконтныхКартПоКодуКарты,
	ЕСТЬNULL(втДублиПоНомеруТелефона.КоличествоДисконтныхКарт, 0) КАК КоличествоДисконтныхКартПоНомеруТелефона
ИЗ
	втДанныеКарт КАК втДанныеКарт
		ЛЕВОЕ СОЕДИНЕНИЕ втПоследняяДатаПродажи КАК втПоследняяДатаПродажи
		ПО втДанныеКарт.ДисконтнаяКарта = втПоследняяДатаПродажи.ДисконтнаяКарта
		ЛЕВОЕ СОЕДИНЕНИЕ втДублиПоВладельцу КАК втДублиПоВладельцу
		ПО втДанныеКарт.ВладелецДисконтнойКарты = втДублиПоВладельцу.ВладелецДисконтнойКарты
		ЛЕВОЕ СОЕДИНЕНИЕ втДублиПоКодуКарты КАК втДублиПоКодуКарты
		ПО втДанныеКарт.КодКарты = втДублиПоКодуКарты.КодКарты
		ЛЕВОЕ СОЕДИНЕНИЕ втДублиПоНомеруТелефона КАК втДублиПоНомеруТелефона
		ПО втДанныеКарт.НомерТелефона = втДублиПоНомеруТелефона.НомерТелефона</query>
	</dataSet>
	<totalField>
		<dataPath>КоличествоДисконтныхКартПоВладельцу</dataPath>
		<expression>Сумма(КоличествоДисконтныхКартПоВладельцу)</expression>
	</totalField>
	<totalField>
