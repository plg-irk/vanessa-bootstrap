#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Процедура - обработчик события ОбработкаПроверкиЗаполнения объекта.
//
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого Запись Из ЭтотОбъект Цикл
		
		Если Запись.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
			
	        ПроверяемыеРеквизиты.Добавить("СтавкаНДС");
			
		КонецЕсли;	
			
	КонецЦикла;	
	
КонецПроцедуры // ОбработкаПроверкиЗаполнения()

Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого Строка Из ЭтотОбъект Цикл
		Строка.ПлательщикУСН = (Строка.СистемаНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная);
		Если НЕ Строка.ПлательщикУСН Тогда
			Строка.ПлательщикНДСПрименяющийУСН = Ложь;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Количество() > 0 Тогда
		
		Если ВозможностиПриложения.КонстантаДоступнаВПриложении("ФункциональнаяОпцияИспользуетсяОСНО") Тогда
			РегистрыСведений.СистемыНалогообложенияОрганизаций.ОбновитьИспользованиеОСНО();
		КонецЕсли;
	
		РегистрыСведений.СистемыНалогообложенияОрганизаций.ОбновитьИспользованиеРозничнойПродажиАлкоголя();
	КонецЕсли;
	
	Для Каждого Запись Из ЭтотОбъект Цикл
		СинхронизироватьСистемуНалогообложения(Запись);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СинхронизироватьСистемуНалогообложения(Запись)
	
	Если Запись.ПлательщикНДСПрименяющийУСН Тогда
		
		ОтборНДС = Новый Структура("Организация", Запись.Организация);
		ПоследняяЗапись = РегистрыСведений.НастройкиУчетаНДС.ПолучитьПоследнее(Запись.Период, ОтборНДС);
		
		Если НЕ ЗначениеЗаполнено(ПоследняяЗапись.СтавкаНалогообложенияПриУСН) Тогда
			НоваяЗапись = РегистрыСведений.НастройкиУчетаНДС.СоздатьМенеджерЗаписи();
			НоваяЗапись.Организация = Запись.Организация;
			НоваяЗапись.Период = Запись.Период;
			НоваяЗапись.СтавкаНалогообложенияПриУСН = Перечисления.ВидыСтавокНДС.ПониженнаяУСН;
			НоваяЗапись.Записать();
		КонецЕсли;
		
	КонецЕсли;
	
	Если Запись.ПлательщикУСН Тогда
		РегистрыСведений.НастройкиУчетаУСН.УстановитьНачальныеНастройкиУчета(Запись.Период);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли