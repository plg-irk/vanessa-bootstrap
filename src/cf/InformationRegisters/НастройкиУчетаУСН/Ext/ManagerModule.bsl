#Область ПрограммныйИнтерфейс

// Устанавливает значения настроек по умолчанию на указанный период, если их нет
//
// Параметры:
//  Период	 - Дата
//
Процедура УстановитьНачальныеНастройкиУчета(Период) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	НастройкиУчетаУСНСрезПоследних.Период КАК Период,
	|	НастройкиУчетаУСНСрезПоследних.ПризнаватьДоходОтКомиссионераНаДатуОтчета КАК ПризнаватьДоходОтКомиссионераНаДатуОтчета
	|ИЗ
	|	РегистрСведений.НастройкиУчетаУСН.СрезПоследних(&Период, ) КАК НастройкиУчетаУСНСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", Период);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		НоваяЗапись = СоздатьМенеджерЗаписи();
		НоваяЗапись.Период = НачалоКвартала(Период);
		НоваяЗапись.ПризнаватьДоходОтКомиссионераНаДатуОтчета = Истина;
		НоваяЗапись.Записать();
	КонецЕсли;				
	
КонецПроцедуры

// Обработчик обновления - включает признание дохода по дате документа Отчет комиссионера с 01.01.2024,
// если в базе есть организации на УСН
//
Процедура ВключитьПризнаниеДоходаНаДатуОтчетаКомиссионера() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	НастройкиУчетаУСН.Период КАК Период,
	|	НастройкиУчетаУСН.ПризнаватьДоходОтКомиссионераНаДатуОтчета КАК ПризнаватьДоходОтКомиссионераНаДатуОтчета
	|ИЗ
	|	РегистрСведений.НастройкиУчетаУСН КАК НастройкиУчетаУСН";

	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ДатаНачалаДействия = Дата(2024, 1, 1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	МИНИМУМ(СистемыНалогообложенияОрганизаций.Период) КАК Период
	|ИЗ
	|	РегистрСведений.СистемыНалогообложенияОрганизаций КАК СистемыНалогообложенияОрганизаций
	|ГДЕ
	|	СистемыНалогообложенияОрганизаций.ПлательщикУСН";
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	ПериодЗаписи = Неопределено;
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Период) Тогда
		ПериодЗаписи = Макс(Выборка.Период, ДатаНачалаДействия);
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ПериодЗаписи) Тогда
		Возврат;
	КонецЕсли;

	НачатьТранзакцию();
	Попытка
		НаборЗаписей = СоздатьНаборЗаписей();
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = ПериодЗаписи;
		НоваяЗапись.ПризнаватьДоходОтКомиссионераНаДатуОтчета = Истина;
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Не удалось выполнить процедуру ""РегистрыСведений.НастройкиУчетаУСН.ВключитьПризнаниеДоходаНаДатуОтчетаКомиссионера"" по причине:
					|%1'"),
					ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				
		ЗаписьЖурналаРегистрации(
			ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Предупреждение,
			Метаданные.РегистрыСведений.НастройкиУчетаУСН,
			,
			ТекстСообщения);
	
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли