
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ТекущаяДата = Параметры.Период; // Период чтения настроек УСН
	Если НЕ ЗначениеЗаполнено(ТекущаяДата) Тогда
		ТекущаяДата = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ПрочитатьНастройкиУСН();
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)

	Если ЗначениеЗаполнено(ПериодИзменения) Тогда
		Оповестить("ИзмененыНастройкиФормированияКУДиР", ПериодИзменения);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПорядокПризнанияДоходаОтКомиссионераПриИзменении(Элемент)

	НастройкиУчетаУСНКлючЗаписи.ПризнаватьДоходОтКомиссионераНаДатуОтчета = (ПорядокПризнанияДоходаОтКомиссионера = 0);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименяетсяСНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	ПараметрыВыбора = Новый Структура;
	
	ПараметрыВыбора.Вставить("НачалоПериода", НастройкиУчетаУСНКлючЗаписи.Период);
	ПараметрыВыбора.Вставить("КонецПериода",  КонецГода(НастройкиУчетаУСНКлючЗаписи.Период));
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыбратьПериодЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("ОбщаяФорма.ВыборСтандартногоПериодаКвартал",	ПараметрыВыбора, , , , , ОписаниеОповещения);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	ЗаписатьНаСервере();
	Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура Записать(Команда)
	ЗаписатьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура История(Команда)
	ОповещениеЗакрытия = Новый ОписаниеОповещения("НастройкиУчетаУСНПриЗакрытииСписка", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.НастройкиУчетаУСН.ФормаСписка", , ЭтотОбъект, , , , ОповещениеЗакрытия,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Форма.ПорядокПризнанияДоходаОтКомиссионера = ?(Форма.НастройкиУчетаУСНКлючЗаписи.ПризнаватьДоходОтКомиссионераНаДатуОтчета, 0, 1);
	Форма.ПрименяетсяС = СтрокаПериода(Форма.НастройкиУчетаУСНКлючЗаписи.Период);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиУчетаУСНПриЗакрытииСписка(РезультатЗакрытия, ДополнительныеПараметры) Экспорт

	ПрочитатьНастройкиУСН();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьПериодЗавершение(РезультатВыбора, ДополнительныеПараметры) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НастройкиУчетаУСНКлючЗаписи.Период = РезультатВыбора.НачалоПериода;
	ПрименяетсяС = СтрокаПериода(НастройкиУчетаУСНКлючЗаписи.Период);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СтрокаПериода(Знач Период)
	
	Возврат ПредставлениеПериода(НачалоКвартала(Период), КонецКвартала(Период));
	
КонецФункции

&НаСервере
Процедура ПрочитатьНастройкиУСН()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	НастройкиУчетаУСН.Период КАК Период,
	               |	НастройкиУчетаУСН.ПризнаватьДоходОтКомиссионераНаДатуОтчета КАК ПризнаватьДоходОтКомиссионераНаДатуОтчета
	               |ИЗ
	               |	РегистрСведений.НастройкиУчетаУСН.СрезПоследних(&Период,) КАК НастройкиУчетаУСН";

	Запрос.УстановитьПараметр("Период", ТекущаяДата);

	Выборка = Запрос.Выполнить().Выбрать();

	Если Выборка.Следующий() Тогда
		МенеджерЗаписи = РегистрыСведений.НастройкиУчетаУСН.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Период = Выборка.Период;
		МенеджерЗаписи.Прочитать();
		ЗначениеВРеквизитФормы(МенеджерЗаписи, "НастройкиУчетаУСНКлючЗаписи");
	Иначе
		НастройкиУчетаУСНКлючЗаписи.Период = НачалоКвартала(ТекущаяДата);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНаСервере()
	
	Если Модифицированность Тогда
		ПериодИзменения = ?(ЗначениеЗаполнено(ПериодИзменения), Мин(ПериодИзменения, НастройкиУчетаУСНКлючЗаписи.Период),
			НастройкиУчетаУСНКлючЗаписи.Период);
		Модифицированность = Ложь;
	КонецЕсли;
	
	ЗаписьНастройки = РегистрыСведений.НастройкиУчетаУСН.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(ЗаписьНастройки, НастройкиУчетаУСНКлючЗаписи);
	ЗаписьНастройки.Записать();
	
КонецПроцедуры

#КонецОбласти