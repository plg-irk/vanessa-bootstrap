#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

Функция СтатусЧекаВФНС(ДокументОснование) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ 
	|	СтатусыЧековВФНС.СтатусЧекаВФНС КАК СтатусЧекаВФНС
	|ИЗ
	|	РегистрСведений.СтатусыЧековВФНС КАК СтатусыЧековВФНС
	|ГДЕ
	|	СтатусыЧековВФНС.ДокументОснование = &ДокументОснование");
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "Нет данных";
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	СтатусЧека = Выборка.СтатусЧекаВФНС;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат СтатусЧека;
	
КонецФункции

#КонецОбласти

#КонецЕсли
