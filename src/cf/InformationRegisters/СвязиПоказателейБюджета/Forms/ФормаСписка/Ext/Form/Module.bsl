#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ПоказательБизнеса") Тогда
		ПоказательБизнеса = Параметры.ПоказательБизнеса;
		Список.Параметры.УстановитьЗначениеПараметра("ПоказательБизнеса", ПоказательБизнеса);
		Список.Параметры.УстановитьЗначениеПараметра("ПоказыватьВсе",Ложь);
		
		ТипПоказателя = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПоказательБизнеса, "ТипПоказателя");
		Если ТипПоказателя = Перечисления.ТипыПоказателейБизнеса.Группа
			ИЛИ ТипПоказателя = Перечисления.ТипыПоказателейБизнеса.Формула Тогда
			
			ТолькоПросмотр = Истина;
			Элементы.ДекорацияПредупреждение.Видимость = Истина;
			Элементы.Список.Видимость = Ложь;
			Элементы.ФормаКоманднаяПанель.Видимость = Ложь;
			
		КонецЕсли;
		
	Иначе
		Список.Параметры.УстановитьЗначениеПараметра("ПоказательБизнеса",Справочники.ПоказателиБизнеса.ПустаяСсылка());
		Список.Параметры.УстановитьЗначениеПараметра("ПоказыватьВсе",Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементов

&НаКлиенте
Процедура СписокПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ = Истина;
	ПараметрыФормы = Новый Структура("ПоказательБизнеса", ПоказательБизнеса);
	ОткрытьФорму("РегистрСведений.СвязиПоказателейБюджета.ФормаЗаписи", ПараметрыФормы);
КонецПроцедуры


#КонецОбласти





