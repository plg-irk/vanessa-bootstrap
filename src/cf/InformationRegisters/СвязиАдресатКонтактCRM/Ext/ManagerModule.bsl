// Связывание адресатов контрагента с лидом
//
// Параметры:
//  Контрагент - СправочникСсылка.Контрагенты
//  Лид - СправочникСсылка.Лиды
//
Процедура СвязатьАдресатовКонтрагентаСЛидом(Контрагент, Лид) Экспорт
	
	НаборЗаписейКонтрагента = РегистрыСведений.СвязиАдресатКонтактCRM.СоздатьНаборЗаписей();
	НаборЗаписейКонтрагента.Отбор.КонтактCRM.Установить(Контрагент);
	НаборЗаписейКонтрагента.Прочитать();
	
	НаборЗаписейЛида = РегистрыСведений.СвязиАдресатКонтактCRM.СоздатьНаборЗаписей();
	НаборЗаписейЛида.Отбор.КонтактCRM.Установить(Лид);
	НаборЗаписейЛида.Прочитать();
	
	ЗаписиНаУдаление = Новый Массив;
	Для Каждого ЗаписьЛида Из НаборЗаписейЛида Цикл
		
		ЗаписиЛидаНетУКонтрагента = Истина;
		
		Для Каждого ЗаписьКонтрагента Из НаборЗаписейКонтрагента Цикл
			
			Если ЗаписьЛида.Адресат = ЗаписьКонтрагента.Адресат И ЗаписьЛида.КонтактCRM = ЗаписьКонтрагента.КонтактCRM Тогда
				ЗаписиЛидаНетУКонтрагента = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЗаписиЛидаНетУКонтрагента Тогда
			ЗаписиНаУдаление.Добавить(ЗаписьЛида);
		КонецЕсли;
		
	КонецЦикла;
	
	АдресатыНаДобавление = Новый Массив;
	Для Каждого ЗаписьКонтрагента Из НаборЗаписейКонтрагента Цикл
		
		ЗаписиКонтрагентаНетУЛида = Истина;
		
		Для Каждого ЗаписьЛида Из НаборЗаписейЛида Цикл
			
			Если ЗаписьЛида.Адресат = ЗаписьКонтрагента.Адресат И ЗаписьЛида.КонтактCRM = ЗаписьКонтрагента.КонтактCRM Тогда
				ЗаписиКонтрагентаНетУЛида = Ложь;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЗаписиКонтрагентаНетУЛида Тогда
			АдресатыНаДобавление.Добавить(ЗаписьКонтрагента.Адресат);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Запись Из ЗаписиНаУдаление Цикл
		НаборЗаписейЛида.Удалить(Запись);
	КонецЦикла;
	Для Каждого Адресат Из АдресатыНаДобавление Цикл
		НоваяЗапись = НаборЗаписейЛида.Добавить();
		НоваяЗапись.Адресат = Адресат;
		НоваяЗапись.КонтактCRM = Лид;
	КонецЦикла;
	
	НаборЗаписейЛида.Записать();
	
КонецПроцедуры

// Возвращает массив адресатов контакта
//
// Параметры:
//  КонтактCRM - ОпределяемыйТип.КонтактПисьма
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.АдресатыПисем
//
Функция Адресаты(КонтактCRM) Экспорт
	
	НаборЗаписей = РегистрыСведений.СвязиАдресатКонтактCRM.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.КонтактCRM.Установить(КонтактCRM);
	НаборЗаписей.Прочитать();
	
	Результат = Новый Массив;
	Для Каждого Запись Из НаборЗаписей Цикл
		Результат.Добавить(Запись.Адресат);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Очистка связей контакта crm с адресатами
//
// Параметры:
//  КонтактCRM - ОпределяемыйТип.КонтактПисьма
//
Процедура ОчиститьСвязи(КонтактCRM) Экспорт
	
	НаборЗаписей = РегистрыСведений.СвязиАдресатКонтактCRM.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.КонтактCRM.Установить(КонтактCRM);
	НаборЗаписей.Записать();
	
КонецПроцедуры

