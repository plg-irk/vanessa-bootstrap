#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КнопкаДанныеОбъекта(Команда)
	Стр = ДанныеОбъектаНаСервере();
	Текст = Новый ТекстовыйДокумент;
	Текст.ДобавитьСтроку( Стр );
	Текст.Показать( "ДанныеОбъекта" );
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ДанныеОбъектаНаСервере()
	ЗаписьЗначение = РеквизитФормыВЗначение( "Запись" );
	ДанныеОбъектаЗначение = ЗаписьЗначение.ДанныеОбъекта.Получить();
	Стр = ЗначениеВСтрокуВнутр( ДанныеОбъектаЗначение );
	Возврат Стр;
КонецФункции

#КонецОбласти