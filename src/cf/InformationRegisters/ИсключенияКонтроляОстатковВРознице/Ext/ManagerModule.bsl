#Область ПрограммныйИнтерфейс

// Проверяет есть ли хоть одна настройка исключений
// контроля остатков
//
// Возвращаемое значение:
//  Булево - Истина, если найдена хотя бы одна запись в регистре
//
Функция ЕстьНастройкиИсключений() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсключенияКонтроляОстатковВРознице.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрСведений.ИсключенияКонтроляОстатковВРознице КАК ИсключенияКонтроляОстатковВРознице");
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

#КонецОбласти