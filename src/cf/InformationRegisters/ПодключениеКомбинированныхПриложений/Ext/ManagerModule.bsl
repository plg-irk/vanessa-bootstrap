#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТЗОписанияПриложений(ИменаПриложений = Неопределено)
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить(
	"Имя", Метаданные.РегистрыСведений.ПодключениеКомбинированныхПриложений.Измерения.ИмяПриложения.Тип);
	
	ОписаниеПриложений = ТарификацияБизнес.ОписаниеВсехПриложений();
	Для каждого ОписаниеПриложения Из ОписаниеПриложений Цикл
		
		Если ИменаПриложений <> Неопределено И ИменаПриложений.Найти(ОписаниеПриложения.Имя) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Имя = ОписаниеПриложения.Имя;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеПриложенийСОтборомПоИмени(ИменаПриложений)
	
	Результат = Новый Массив;
	
	ОписаниеПриложений = ТарификацияБизнес.ОписаниеВсехПриложений();
	Для каждого ОписаниеПриложения Из ОписаниеПриложений Цикл
		Если ИменаПриложений.Найти(ОписаниеПриложения.Имя) <> Неопределено Тогда
			Результат.Добавить(ОписаниеПриложения);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецЕсли
