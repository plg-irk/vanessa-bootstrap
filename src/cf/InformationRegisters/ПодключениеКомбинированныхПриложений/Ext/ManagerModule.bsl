#Область ПрограммныйИнтерфейс

// Возвращает статусы приложений
//
// Параметры:
//  ИменаПриложений - Массив из Строка, Неопределено - если передано, то будут получены статусы указанных приложений
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//   * Период - Дата
//   * ИмяПриложения - Строка
//   * Статус - ПеречислениеСсылка.СтатусКомбинированногоПриложения
//   * ОписаниеСобытия - Строка
//
Функция СтатусПриложений(ИменаПриложений = Неопределено) Экспорт
	
	ОписаниеПриложений = ТЗОписанияПриложений(ИменаПриложений);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОписаниеПриложений.Имя КАК Имя
	|ПОМЕСТИТЬ ВТОписаниеПриложений
	|ИЗ
	|	&ОписаниеПриложений КАК ОписаниеПриложений
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПодключениеКомбинированныхПриложенийСрезПоследних.Период КАК Период,
	|	ВТОписаниеПриложений.Имя КАК ИмяПриложения,
	|	ЕСТЬNULL(ПодключениеКомбинированныхПриложенийСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусКомбинированногоПриложения.НеИспользовалось)) КАК Статус,
	|	ПодключениеКомбинированныхПриложенийСрезПоследних.ОписаниеСобытия КАК ОписаниеСобытия
	|ИЗ
	|	ВТОписаниеПриложений КАК ВТОписаниеПриложений
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних КАК ПодключениеКомбинированныхПриложенийСрезПоследних
	|		ПО ВТОписаниеПриложений.Имя = ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения";
	
	Запрос.УстановитьПараметр("ОписаниеПриложений", ОписаниеПриложений);
	
	УстановитьПривилегированныйРежим(Истина);
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ЗарегистрироватьСобытие(ИмяПриложения, Статус, ОписаниеСобытия = "") Экспорт
	
	Запись = РегистрыСведений.ПодключениеКомбинированныхПриложений.СоздатьМенеджерЗаписи();
	Запись.Период = ТекущаяДатаСеанса();
	Запись.ИмяПриложения = ИмяПриложения;
	Запись.Статус = Статус;
	Запись.ОписаниеСобытия = ОписаниеСобытия;
	
	УстановитьПривилегированныйРежим(Истина);
	Запись.Записать(Истина);
	
КонецПроцедуры

// Проверяет, есть ли подключенные комбинированные приложения
// 
// Возвращаемое значение:
//  Булево
//
Функция ЕстьПодключенныеПриложения() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения КАК ИмяПриложения
	|ИЗ
	|	РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних КАК ПодключениеКомбинированныхПриложенийСрезПоследних
	|ГДЕ
	|	ПодключениеКомбинированныхПриложенийСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусКомбинированногоПриложения.Подключено)";
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ПриложенияДляОтключения() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПодключениеКомбинированныхПриложенийСрезПоследних.ИмяПриложения КАК ИмяПриложения
	|ИЗ
	|	РегистрСведений.ПодключениеКомбинированныхПриложений.СрезПоследних КАК ПодключениеКомбинированныхПриложенийСрезПоследних
	|ГДЕ
	|	ПодключениеКомбинированныхПриложенийСрезПоследних.Статус = &Статус";
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусКомбинированногоПриложения.ЗарегистрированоУдаление);
	
	ИменаПриложений = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ИмяПриложения");
	Возврат ОписаниеПриложенийСОтборомПоИмени(ИменаПриложений);
	
КонецФункции

