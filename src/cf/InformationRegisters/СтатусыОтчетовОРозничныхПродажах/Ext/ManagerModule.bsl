#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// Запускает обновление отражения отрицательных остатков по документам ОРП в служебном регистре
//
Процедура ЗапуститьОбновлениеОтраженияОтрицательныхОстатков(ДокументСсылка) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ОтслеживатьСтатусыОтчетовОРозничныхПродажах") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ДокументСсылка)
		ИЛИ НЕ ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументСсылка, "Дата") Тогда
		
		Возврат;
	КонецЕсли;
	
	ДатаДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Дата");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ОРП.Ссылка КАК Ссылка,
		|	ОРП.Дата КАК Дата,
		|	ОРП.Организация КАК Организация,
		|	ОРП.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ИЗ
		|	РегистрСведений.СтатусыОтчетовОРозничныхПродажах КАК СтатусыОтчетовОРозничныхПродажах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах КАК ОРП
		|		ПО (СтатусыОтчетовОРозничныхПродажах.ЕстьОтрицательныеОстатки)
		|			И СтатусыОтчетовОРозничныхПродажах.ОтчетОРозничныхПродажах = ОРП.Ссылка
		|			И (ОРП.Ссылка = &ДокументСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ОРП.Ссылка,
		|	ОРП.Дата,
		|	ОРП.Организация,
		|	ОРП.СтруктурнаяЕдиница
		|ИЗ
		|	РегистрСведений.СтатусыОтчетовОРозничныхПродажах КАК СтатусыОтчетовОРозничныхПродажах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах КАК ОРП
		|		ПО (СтатусыОтчетовОРозничныхПродажах.ЕстьОтрицательныеОстатки)
		|			И СтатусыОтчетовОРозничныхПродажах.ОтчетОРозничныхПродажах = ОРП.Ссылка
		|			И (ОРП.Дата >= &ДатаДокумента)
		|			И (ОРП.Ссылка <> &ДокументСсылка)";
	
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		Отбор =Новый Структура;
		Отбор.Вставить("Ключ", "ОбновлениеОтраженияОтрицательныхОстатковОРП");
		Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
		ФоновоеЗадание = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
		Если ФоновоеЗадание.Количество() Тогда
			Возврат;
		КонецЕсли;
		
		ИмяПроцедуры = "РегистрыСведений.СтатусыОтчетовОРозничныхПродажах.ОбновитьОтражениеОтрицательныхОстатков";
		ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
		ПараметрыВыполнения.КлючФоновогоЗадания = "ОбновлениеОтраженияОтрицательныхОстатковОРП";
		ПараметрыВыполнения.ОжидатьЗавершение = 0;
		ПараметрыВыполнения.ЗапуститьВФоне = Истина;
		ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, ИмяПроцедуры, ДокументСсылка, ДатаДокумента);
		
	КонецЕсли;
	
КонецПроцедуры

// Обновляет отражение отрицательных остатков по документам ОРП в служебном регистре
//
Процедура ОбновитьОтражениеОтрицательныхОстатков(ДокументСсылка, ДатаДокумента) Экспорт
	
	// Получим список ОРП  у которых больше нет отрицательных остатков
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОРП.Ссылка КАК Ссылка,
		|	ОРП.Дата КАК Дата,
		|	ОРП.Организация КАК Организация,
		|	ОРП.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ПОМЕСТИТЬ ОРППроверкаОтрицательныхОстатков
		|ИЗ
		|	РегистрСведений.СтатусыОтчетовОРозничныхПродажах КАК СтатусыОтчетовОРозничныхПродажах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах КАК ОРП
		|		ПО (СтатусыОтчетовОРозничныхПродажах.ЕстьОтрицательныеОстатки)
		|			И СтатусыОтчетовОРозничныхПродажах.ОтчетОРозничныхПродажах = ОРП.Ссылка
		|			И (ОРП.Ссылка = &ДокументСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ОРП.Ссылка,
		|	ОРП.Дата,
		|	ОРП.Организация,
		|	ОРП.СтруктурнаяЕдиница
		|ИЗ
		|	РегистрСведений.СтатусыОтчетовОРозничныхПродажах КАК СтатусыОтчетовОРозничныхПродажах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах КАК ОРП
		|		ПО (СтатусыОтчетовОРозничныхПродажах.ЕстьОтрицательныеОстатки)
		|			И СтатусыОтчетовОРозничныхПродажах.ОтчетОРозничныхПродажах = ОРП.Ссылка
		|			И (ОРП.Дата >= &ДатаДокумента)
		|			И (ОРП.Ссылка <> &ДокументСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОРППроверкаОтрицательныхОстатков.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ОРПОтрицательныеОстатки
		|ИЗ
		|	Документ.ОтчетОРозничныхПродажах.Запасы КАК ОРПЗапасы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОРППроверкаОтрицательныхОстатков КАК ОРППроверкаОтрицательныхОстатков
		|		ПО ОРПЗапасы.Ссылка = ОРППроверкаОтрицательныхОстатков.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО (СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас))
		|			И ОРПЗапасы.Номенклатура = СпрНоменклатура.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.ОстаткиИОбороты(, , Секунда, , ) КАК ЗапасыОстаткиИОбороты
		|		ПО (ОРППроверкаОтрицательныхОстатков.Дата = ЗапасыОстаткиИОбороты.Период)
		|			И (ОРППроверкаОтрицательныхОстатков.Организация = ЗапасыОстаткиИОбороты.Организация)
		|			И (ОРППроверкаОтрицательныхОстатков.СтруктурнаяЕдиница = ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница)
		|			И ОРПЗапасы.Номенклатура = ЗапасыОстаткиИОбороты.Номенклатура
		|			И ОРПЗапасы.Характеристика = ЗапасыОстаткиИОбороты.Характеристика
		|			И ОРПЗапасы.Партия = ЗапасыОстаткиИОбороты.Партия
		|			И (ЗапасыОстаткиИОбороты.КоличествоКонечныйОстаток < 0)
		|
		|СГРУППИРОВАТЬ ПО
		|	ОРППроверкаОтрицательныхОстатков.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОРППроверкаОтрицательныхОстатков.Ссылка КАК Ссылка
		|ИЗ
		|	ОРППроверкаОтрицательныхОстатков КАК ОРППроверкаОтрицательныхОстатков
		|ГДЕ
		|	НЕ ОРППроверкаОтрицательныхОстатков.Ссылка В
		|				(ВЫБРАТЬ
		|					ОРПОтрицательныеОстатки.Ссылка КАК Ссылка
		|				ИЗ
		|					ОРПОтрицательныеОстатки КАК ОРПОтрицательныеОстатки)";
	
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		// Установим флаг ЕстьОтрицательныеОстатки в значение ЛОЖЬ или удалим запись, если остальные флаги тоже ЛОЖЬ
		ДанныеИзменения = Новый Структура;
		ДанныеИзменения.Вставить("ЕстьОтрицательныеОстатки", Ложь);
		ОбновитьЗапись(Выборка.Ссылка, ДанныеИзменения);
		
	КонецЦикла;
	
КонецПроцедуры

// Обновляет отражение не оформленного акта списания ЕГАИС для документа ОРП в служебном регистре
//
Процедура ОбновитьОтражениеНеОформленногоАктаСписанияЕГАИС(ДокументОбъект, Отказ, РежимЗаписи) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ОтслеживатьСтатусыОтчетовОРозничныхПродажах") Тогда
		Возврат;
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ(ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.АктСписанияЕГАИС")
		И ЗначениеЗаполнено(ДокументОбъект.ДокументОснование)
		И ТипЗнч(ДокументОбъект.ДокументОснование) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах")) Тогда
		
		Возврат;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		
		// Установим флаг НеОформленАктСписанияЕГАИС в значение ЛОЖЬ или удалим запись, если остальные флаги тоже ЛОЖЬ
		ДанныеИзменения = Новый Структура;
		ДанныеИзменения.Вставить("НеОформленАктСписанияЕГАИС", Ложь);
		ОбновитьЗапись(ДокументОбъект.ДокументОснование, ДанныеИзменения);
		
	Иначе
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	СпрНоменклатура.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Номенклатура КАК СпрНоменклатура
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Константа.ВестиСведенияДляДекларацийПоАлкогольнойПродукции КАК ИспользуетсяЕГАИС
			|		ПО (ИспользуетсяЕГАИС.Значение)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах.Запасы КАК ОРПЗапасы
			|		ПО (ОРПЗапасы.Ссылка = &ОРПСсылка)
			|			И СпрНоменклатура.Ссылка = ОРПЗапасы.Номенклатура
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыАлкогольнойПродукции КАК ВидыАлкогольнойПродукции
			|		ПО СпрНоменклатура.ВидАлкогольнойПродукции = ВидыАлкогольнойПродукции.Ссылка
			|			И (НЕ ВидыАлкогольнойПродукции.Маркируемый)
			|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АктСписанияЕГАИС КАК АктСписанияЕГАИС
			|		ПО (ОРПЗапасы.Ссылка = АктСписанияЕГАИС.ДокументОснование)
			|			И (АктСписанияЕГАИС.Проведен)
			|			И (АктСписанияЕГАИС.Ссылка <> &ДокументСсылка)
			|ГДЕ
			|	АктСписанияЕГАИС.Ссылка ЕСТЬ NULL";
		
		Запрос.УстановитьПараметр("ОРПСсылка", ДокументОбъект.ДокументОснование);
		Запрос.УстановитьПараметр("ДокументСсылка", ДокументОбъект.Ссылка);
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда
			Возврат;
		КонецЕсли;
		
		// Установим флаг НеОформленАктСписанияЕГАИС в значение ИСТИНА или добавим запись, если запись уже есть
		ДанныеИзменения = Новый Структура;
		ДанныеИзменения.Вставить("НеОформленАктСписанияЕГАИС", Истина);
		ОбновитьЗапись(ДокументОбъект.ДокументОснование, ДанныеИзменения);
		
	КонецЕсли;
	
КонецПроцедуры

// Обновляет запись в служебном регистре Статусы отчетов о розничных продажах.
//
Процедура ОбновитьЗапись(ОтчетОРозничныхПродажахСсылка, ДанныеИзменения) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ОтслеживатьСтатусыОтчетовОРозничныхПродажах") Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ОтчетОРозничныхПродажахСсылка)
		ИЛИ ТипЗнч(ОтчетОРозничныхПродажахСсылка) <> Тип("ДокументСсылка.ОтчетОРозничныхПродажах")
		ИЛИ ТипЗнч(ДанныеИзменения) <> Тип("Структура") Тогда
		
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запись = РегистрыСведений.СтатусыОтчетовОРозничныхПродажах.СоздатьМенеджерЗаписи();
	Запись.ОтчетОРозничныхПродажах = ОтчетОРозничныхПродажахСсылка;
	Запись.Прочитать();
	
	ЗаполнитьЗначенияСвойств(Запись, ДанныеИзменения);
	
	Если Запись.ЕстьОтрицательныеОстатки
		ИЛИ Запись.ЕстьРасхождениеПоТоварам
		ИЛИ Запись.ЕстьРасхождениеПоОплате
		ИЛИ Запись.НеОформленАктСписанияЕГАИС Тогда
		
		Запись.ОтчетОРозничныхПродажах = ОтчетОРозничныхПродажахСсылка;
		Запись.Записать();
	ИначеЕсли Запись.Выбран() Тогда
		Запись.Удалить();
	Иначе
		// Действие не требуется
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли