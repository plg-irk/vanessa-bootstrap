#Область ПрограммныйИнтерфейс

// Установить переданные настройки пользователя.
// 
// Параметры:
//  Пользователь - СправочникСсылка.Пользователи - Пользователь
//  ПолноеИмяФормы - Строка - полное имя формы объекта метаданных
//  ИмяПечатнойФормы  - Строка - имя печатной формы, вызываемой по умолчанию
//  СписокПечатныхФорм  - Строка - содержит список значений печатных форм
//   в требуемом порядке и с отметкой видимости
//
Процедура ЗаписатьНастройкиПользователя(Пользователь, ПолноеИмяФормы, ИмяПечатнойФормы, СписокПечатныхФорм) Экспорт
	
	Попытка
		
		НаборЗаписей = СоздатьНаборЗаписей();
		СокращенноеИмяФормы = ПечатьДокументовУНФ.СократитьПолноеИмяФормы(ПолноеИмяФормы); 
		НаборЗаписей.Отбор.Пользователь.Использование = Истина;
		НаборЗаписей.Отбор.Пользователь.Значение = Пользователь;
		НаборЗаписей.Отбор.ПолноеИмяФормы.Использование = Истина;
		НаборЗаписей.Отбор.ПолноеИмяФормы.Значение = СокращенноеИмяФормы;

		Запись = НаборЗаписей.Добавить();

		Запись.Пользователь = Пользователь;
		Запись.ПолноеИмяФормы = СокращенноеИмяФормы;
		Запись.ИмяПечатнойФормы = ИмяПечатнойФормы;
		Запись.Хранилище = Новый ХранилищеЗначения(СписокПечатныхФорм);
		
		НаборЗаписей.Записать();
		
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(НСтр("ru='Печатные формы по умолчанию.Запись настроек пользователя.'",
			ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстОшибки);
		
	КонецПопытки;

КонецПроцедуры

// Получить сохраненные настройки пользователя.
// 
// Параметры:
//  Пользователь - СправочникСсылка.Пользователи - Пользователь
//  ПолноеИмяФормы - Строка - полное имя формы объекта метаданных
// 
// Возвращаемое значение:
// 	Строка - имя печатной формы, вызываемой по умолчанию
//
Функция НастройкиПользователя(Пользователь, ПолноеИмяФормы) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НастройкиПечатныхФормПоУмолчанию.ИмяПечатнойФормы КАК ИмяПечатнойФормы,
	|	НастройкиПечатныхФормПоУмолчанию.Хранилище
	|ИЗ
	|	РегистрСведений.НастройкиПечатныхФормПоУмолчанию КАК НастройкиПечатныхФормПоУмолчанию
	|ГДЕ
	|	НастройкиПечатныхФормПоУмолчанию.Пользователь = &Пользователь
	|	И НастройкиПечатныхФормПоУмолчанию.ПолноеИмяФормы = &СокращенноеИмяФормы";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("СокращенноеИмяФормы", ПечатьДокументовУНФ.СократитьПолноеИмяФормы(ПолноеИмяФормы));
	РезультатЗапроса = Запрос.Выполнить();  

	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	СтруктураНастроек = Новый Структура("ПечатнаяФормаПоУмолчанию, ПечатныеФормы", Выборка.ИмяПечатнойФормы, Выборка.Хранилище.Получить());
	Возврат СтруктураНастроек;

КонецФункции

// Удалить настройки пользователя для указанного имени формы.
// 
// Параметры:
//  Пользователь - СправочникСсылка.Пользователи - Пользователь
//  ПолноеИмяФормы - Строка - полное имя формы объекта метаданных
//
Процедура УдалитьНастройкиПользователя(Пользователь, ПолноеИмяФормы) Экспорт
	
	Попытка
		
		НаборЗаписей = СоздатьНаборЗаписей();

		НаборЗаписей.Отбор.Пользователь.Использование = Истина;
		НаборЗаписей.Отбор.Пользователь.Значение = Пользователь;
		НаборЗаписей.Отбор.ПолноеИмяФормы.Использование = Истина;
		НаборЗаписей.Отбор.ПолноеИмяФормы.Значение = ПечатьДокументовУНФ.СократитьПолноеИмяФормы(ПолноеИмяФормы);
		НаборЗаписей.Очистить();
		НаборЗаписей.Записать();
		
	Исключение
		
		ТекстОшибки = ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации(НСтр("ru='Печатные формы по умолчанию.Удаление настроек пользователя.'",
			ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстОшибки);
		
	КонецПопытки;

КонецПроцедуры

#КонецОбласти


#КонецЕсли

